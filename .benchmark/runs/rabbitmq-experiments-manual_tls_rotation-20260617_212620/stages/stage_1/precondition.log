[precondition:tls_material_ready:preconditionUnits[5] 'tls_material_ready':apply] $ /bin/sh -c 'set -e
TMP_DIR=$(mktemp -d)
kubectl -n ${BENCH_NAMESPACE} exec openssl-toolbox -- /bin/sh -c '"'"'
set -e
mkdir -p /tmp/certs
cat > /tmp/certs/openssl.cnf <<EOF
distinguished_name=req_distinguished_name
req_extensions=v3_req
prompt=no
[req_distinguished_name]
CN=rabbitmq
[v3_req]
keyUsage=critical,digitalSignature,keyEncipherment
extendedKeyUsage=serverAuth,clientAuth
subjectAltName=@alt_names
[alt_names]
DNS.1=rabbitmq
DNS.2=rabbitmq.rabbitmq
DNS.3=rabbitmq.rabbitmq.svc
DNS.4=rabbitmq.${BENCH_NAMESPACE}.svc.cluster.local
DNS.5=rabbitmq-headless
DNS.6=rabbitmq-headless.rabbitmq
DNS.7=rabbitmq-headless.rabbitmq.svc
DNS.8=rabbitmq-headless.${BENCH_NAMESPACE}.svc.cluster.local
DNS.9=rabbitmq-0.rabbitmq-headless.${BENCH_NAMESPACE}.svc.cluster.local
DNS.10=rabbitmq-1.rabbitmq-headless.${BENCH_NAMESPACE}.svc.cluster.local
DNS.11=rabbitmq-2.rabbitmq-headless.${BENCH_NAMESPACE}.svc.cluster.local
EOF
openssl genrsa -out /tmp/certs/ca.key 2048
openssl req -x509 -new -nodes -key /tmp/certs/ca.key -sha256 -days 730 \
  -subj "/CN=rabbitmq-ca" -out /tmp/certs/ca.crt
openssl genrsa -out /tmp/certs/tls.key 2048
openssl req -new -key /tmp/certs/tls.key -out /tmp/certs/tls.csr \
  -config /tmp/certs/openssl.cnf
openssl x509 -req -in /tmp/certs/tls.csr -CA /tmp/certs/ca.crt \
  -CAkey /tmp/certs/ca.key -CAcreateserial -out /tmp/certs/tls.crt \
  -days 1 -extensions v3_req -extfile /tmp/certs/openssl.cnf
'"'"'
kubectl -n ${BENCH_NAMESPACE} cp openssl-toolbox:/tmp/certs "${TMP_DIR}/certs"
kubectl -n ${BENCH_NAMESPACE} create secret generic rabbitmq-tls \
  --from-file=ca.crt="${TMP_DIR}/certs/ca.crt" \
  --from-file=tls.crt="${TMP_DIR}/certs/tls.crt" \
  --from-file=tls.key="${TMP_DIR}/certs/tls.key" \
  --dry-run=client -o yaml | kubectl apply -f -
CA_FP=$(openssl x509 -noout -fingerprint -sha256 -in "${TMP_DIR}/certs/ca.crt" | cut -d= -f2)
LEAF_FP=$(openssl x509 -noout -fingerprint -sha256 -in "${TMP_DIR}/certs/tls.crt" | cut -d= -f2)
kubectl -n ${BENCH_NAMESPACE} create configmap rabbitmq-tls-old \
  --from-literal=ca_fingerprint_sha256="${CA_FP}" \
  --from-literal=leaf_fingerprint_sha256="${LEAF_FP}" \
  --dry-run=client -o yaml | kubectl apply -f -
'
