{
  "apiVersion": "benchmark/v1",
  "kind": "Workflow",
  "metadata": {
    "name": "repeat-mongodb-monitoring-integration"
  },
  "spec": {
    "prompt_mode": "progressive",
    "stages": [
      {
        "id": "stage_first",
        "service": "mongodb",
        "case": "monitoring-integration",
        "namespaces": [
          "mongodb",
          "monitoring"
        ]
      },
      {
        "id": "stage_second",
        "service": "mongodb",
        "case": "monitoring-integration",
        "namespaces": [
          "mongodb",
          "monitoring"
        ]
      }
    ],
    "namespaces": [
      "mongodb",
      "monitoring"
    ]
  }
}