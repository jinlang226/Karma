    "name": "repeat-mongodb-initialize"
  },
  "spec": {
    "prompt_mode": "progressive",
    "stages": [
      {
        "id": "stage_first",
        "service": "mongodb",
        "case": "initialize",
        "namespaces": [
          "mongodb"
        ]
      },
      {
        "id": "stage_second",
        "service": "mongodb",
        "case": "initialize",
        "namespaces": [
          "mongodb"
        ]
      }
    ],
    "namespaces": [
      "mongodb"
    ]
  }
}