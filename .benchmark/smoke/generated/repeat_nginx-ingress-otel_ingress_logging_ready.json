{
  "apiVersion": "benchmark/v1",
  "kind": "Workflow",
  "metadata": {
    "name": "repeat-nginx-ingress-otel_ingress_logging_ready"
  },
  "spec": {
    "prompt_mode": "progressive",
    "stages": [
      {
        "id": "stage_first",
        "service": "nginx-ingress",
        "case": "otel_ingress_logging_ready",
        "namespaces": [
          "app",
          "ingress",
          "otel"
        ]
      },
      {
        "id": "stage_second",
        "service": "nginx-ingress",
        "case": "otel_ingress_logging_ready",
        "namespaces": [
          "app",
          "ingress",
          "otel"
        ]
      }
    ],
    "namespaces": [
      "app",
      "ingress",
      "otel"
    ]
  }
}