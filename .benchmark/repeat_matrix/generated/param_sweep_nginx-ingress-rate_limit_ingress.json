{
  "apiVersion": "benchmark/v1",
  "kind": "Workflow",
  "metadata": {
    "name": "param-sweep-nginx-ingress-rate_limit_ingress"
  },
  "spec": {
    "prompt_mode": "progressive",
    "stages": [
      {
        "id": "stage_first",
        "service": "nginx-ingress",
        "case": "rate_limit_ingress",
        "namespaces": [
          "app",
          "ingress"
        ],
        "param_overrides": {
          "api_ingress_name": "rate-api-ps",
          "health_ingress_name": "rate-health-ps",
          "host": "rate-ps.example.com"
        }
      },
      {
        "id": "stage_second",
        "service": "nginx-ingress",
        "case": "rate_limit_ingress",
        "namespaces": [
          "app",
          "ingress"
        ],
        "param_overrides": {
          "api_ingress_name": "rate-api-ps",
          "health_ingress_name": "rate-health-ps",
          "host": "rate-ps.example.com"
        }
      }
    ],
    "namespaces": [
      "app",
      "ingress"
    ]
  }
}