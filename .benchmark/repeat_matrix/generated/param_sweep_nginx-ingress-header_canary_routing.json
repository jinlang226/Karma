{
  "apiVersion": "benchmark/v1",
  "kind": "Workflow",
  "metadata": {
    "name": "param-sweep-nginx-ingress-header_canary_routing"
  },
  "spec": {
    "prompt_mode": "progressive",
    "stages": [
      {
        "id": "stage_first",
        "service": "nginx-ingress",
        "case": "header_canary_routing",
        "namespaces": [
          "app",
          "ingress"
        ],
        "param_overrides": {
          "stable_ingress_name": "canary-stable-ps",
          "canary_ingress_name": "canary-canary-ps",
          "host": "canary-ps.example.com"
        }
      },
      {
        "id": "stage_second",
        "service": "nginx-ingress",
        "case": "header_canary_routing",
        "namespaces": [
          "app",
          "ingress"
        ],
        "param_overrides": {
          "stable_ingress_name": "canary-stable-ps",
          "canary_ingress_name": "canary-canary-ps",
          "host": "canary-ps.example.com"
        }
      }
    ],
    "namespaces": [
      "app",
      "ingress"
    ]
  }
}