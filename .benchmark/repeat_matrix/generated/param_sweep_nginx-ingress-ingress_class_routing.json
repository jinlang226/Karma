{
  "apiVersion": "benchmark/v1",
  "kind": "Workflow",
  "metadata": {
    "name": "param-sweep-nginx-ingress-ingress_class_routing"
  },
  "spec": {
    "prompt_mode": "progressive",
    "stages": [
      {
        "id": "stage_first",
        "service": "nginx-ingress",
        "case": "ingress_class_routing",
        "namespaces": [
          "app",
          "ingress"
        ],
        "param_overrides": {
          "service_name": "demo-app-ps",
          "ingress_name": "demo-app-ps",
          "host": "class-ps.example.com"
        }
      },
      {
        "id": "stage_second",
        "service": "nginx-ingress",
        "case": "ingress_class_routing",
        "namespaces": [
          "app",
          "ingress"
        ],
        "param_overrides": {
          "service_name": "demo-app-ps",
          "ingress_name": "demo-app-ps",
          "host": "class-ps.example.com"
        }
      }
    ],
    "namespaces": [
      "app",
      "ingress"
    ]
  }
}