{
  "apiVersion": "benchmark/v1",
  "kind": "Workflow",
  "metadata": {
    "name": "repeat-nginx-ingress-https_ingress_ready"
  },
  "spec": {
    "prompt_mode": "progressive",
    "stages": [
      {
        "id": "stage_first",
        "service": "nginx-ingress",
        "case": "https_ingress_ready",
        "namespaces": [
          "app",
          "ingress"
        ]
      },
      {
        "id": "stage_second",
        "service": "nginx-ingress",
        "case": "https_ingress_ready",
        "namespaces": [
          "app",
          "ingress"
        ]
      }
    ],
    "namespaces": [
      "app",
      "ingress"
    ]
  }
}