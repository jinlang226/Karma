{
  "apiVersion": "benchmark/v1",
  "kind": "Workflow",
  "metadata": {
    "name": "param-sweep-nginx-ingress-https_ingress_ready"
  },
  "spec": {
    "prompt_mode": "progressive",
    "stages": [
      {
        "id": "stage_first",
        "service": "nginx-ingress",
        "case": "https_ingress_ready",
        "namespaces": [
          "app",
          "ingress"
        ],
        "param_overrides": {
          "service_name": "echo-server-ps",
          "ingress_name": "demo-ingress-ps",
          "tls_secret_name": "demo-tls-ps"
        }
      },
      {
        "id": "stage_second",
        "service": "nginx-ingress",
        "case": "https_ingress_ready",
        "namespaces": [
          "app",
          "ingress"
        ],
        "param_overrides": {
          "service_name": "echo-server-ps",
          "ingress_name": "demo-ingress-ps",
          "tls_secret_name": "demo-tls-ps"
        }
      }
    ],
    "namespaces": [
      "app",
      "ingress"
    ]
  }
}