{
  "apiVersion": "benchmark/v1",
  "kind": "Workflow",
  "metadata": {
    "name": "param-sweep-nginx-ingress-otel_ingress_logging_ready"
  },
  "spec": {
    "prompt_mode": "progressive",
    "stages": [
      {
        "id": "stage_first",
        "service": "nginx-ingress",
        "case": "otel_ingress_logging_ready",
        "namespaces": [
          "app",
          "ingress",
          "otel"
        ],
        "param_overrides": {
          "ingress_name": "otel-echo-ps",
          "host": "otel-ps.example.com",
          "collector_service_name": "otel-collector-ps"
        }
      },
      {
        "id": "stage_second",
        "service": "nginx-ingress",
        "case": "otel_ingress_logging_ready",
        "namespaces": [
          "app",
          "ingress",
          "otel"
        ],
        "param_overrides": {
          "ingress_name": "otel-echo-ps",
          "host": "otel-ps.example.com",
          "collector_service_name": "otel-collector-ps"
        }
      }
    ],
    "namespaces": [
      "app",
      "ingress",
      "otel"
    ]
  }
}