{
  "apiVersion": "benchmark/v1",
  "kind": "Workflow",
  "metadata": {
    "name": "param-sweep-mongodb-deploy"
  },
  "spec": {
    "prompt_mode": "progressive",
    "stages": [
      {
        "id": "stage_first",
        "service": "mongodb",
        "case": "deploy",
        "namespaces": [
          "mongodb"
        ],
        "param_overrides": {
          "cluster_prefix": "mongodb-replica-ps"
        }
      },
      {
        "id": "stage_second",
        "service": "mongodb",
        "case": "deploy",
        "namespaces": [
          "mongodb"
        ],
        "param_overrides": {
          "cluster_prefix": "mongodb-replica-ps"
        }
      }
    ],
    "namespaces": [
      "mongodb"
    ]
  }
}