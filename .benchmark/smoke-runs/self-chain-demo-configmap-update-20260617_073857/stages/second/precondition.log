[precondition:configmap_ready:preconditionUnits[0] 'configmap_ready':probe] $ /bin/sh -c 'set -e; [ "$(kubectl -n ${BENCH_NAMESPACE} get configmap demo-config -o jsonpath='"'"'{.data.value}'"'"')" = "seed" ]'

[precondition:configmap_ready:preconditionUnits[0] 'configmap_ready':apply] $ kubectl -n "${BENCH_NAMESPACE}" apply -f resources/demo/configmap-update/resource/config.yaml
configmap/demo-config configured

[precondition:configmap_ready:preconditionUnits[0] 'configmap_ready':verify] $ /bin/sh -c 'set -e; [ "$(kubectl -n ${BENCH_NAMESPACE} get configmap demo-config -o jsonpath='"'"'{.data.value}'"'"')" = "seed" ]'

