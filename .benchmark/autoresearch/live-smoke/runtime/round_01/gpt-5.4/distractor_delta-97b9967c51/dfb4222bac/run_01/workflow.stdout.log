[agent]   if (existing) {
[agent]     database.updateUser(username, { pwd: password, roles });
[agent]     print("updated user " + username);
[agent]   } else {
[agent]     database.createUser({ user: username, pwd: password, roles });
[agent]     print("created user " + username);
[agent]   }
[agent] }
[agent] function upsertRole(database, roleName, privileges, roles) {
