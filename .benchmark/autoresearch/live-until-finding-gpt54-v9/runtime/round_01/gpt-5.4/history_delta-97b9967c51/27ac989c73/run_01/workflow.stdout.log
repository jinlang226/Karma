[agent] +    exec_mongo "$primary_pod" "$app_js"
[agent] +    exec_mongo "$primary_pod" "$reporting_js"
[agent] +    ;;
[agent] +  app)
[agent] +    exec_mongo "$primary_pod" "$app_js"
[agent] +    ;;
[agent] +  reporting)
[agent] +    exec_mongo "$primary_pod" "$reporting_js"
[agent] +    ;;
[agent] +esac
