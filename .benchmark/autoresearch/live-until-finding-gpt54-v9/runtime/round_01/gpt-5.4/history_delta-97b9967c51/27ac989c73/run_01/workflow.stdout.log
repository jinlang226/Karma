[agent] #!/bin/sh
[agent] set -eu
[agent] NAMESPACE="${NAMESPACE:-wf-2026-04-28t02-22-20z-workflow-r-afb07d7e-control-cluster-a}"
[agent] CLUSTER_PREFIX="${CLUSTER_PREFIX:-mongodb-replica}"
[agent] SERVICE_NAME="${SERVICE_NAME:-mongodb-replica-svc}"
[agent] ADMIN_SECRET_NAME="${ADMIN_SECRET_NAME:-admin-user-password}"
[agent] ADMIN_USERNAME="${ADMIN_USERNAME:-admin-user}"
[agent] APP_SECRET_NAME="${APP_SECRET_NAME:-app-user-password}"
[agent] APP_USERNAME="${APP_USERNAME:-app-user}"
[agent] REPORTING_SECRET_NAME="${REPORTING_SECRET_NAME:-reporting-user-password}"
[agent] REPORTING_USERNAME="${REPORTING_USERNAME:-reporting-user}"
[agent] APP_DATABASE="${APP_DATABASE:-appdb}"
[agent] REPORTING_ROLE_NAME="${REPORTING_ROLE_NAME:-reportingRole}"
[agent] BAD_ROLE_NAME="${BAD_ROLE_NAME:-rawRead}"
[agent] REPORTS_COLLECTION="${REPORTS_COLLECTION:-reports}"
[agent] MODE=""
[agent] usage() {
[agent]   echo "Usage: $0 --mode all|app|reporting" >&2
[agent]   exit 1
[agent] }
[agent] while [ "$#" -gt 0 ]; do
[agent]   case "$1" in
[agent]     --mode)
[agent]       [ "$#" -ge 2 ] || usage
[agent]       MODE="$2"
[agent]       shift 2
[agent]       ;;
[agent]     *)
[agent]       usage
[agent]       ;;
[agent]   esac
[agent] done
[agent] [ -n "$MODE" ] || usage
[agent] case "$MODE" in
[agent]   all|app|reporting)
[agent]     ;;
[agent]   *)
[agent]     usage
[agent]     ;;
[agent] esac
[agent] kubectl_bin="${KUBECTL_BIN:-kubectl}"
[agent] get_secret_value() {
[agent]   secret_name="$1"
[agent]   key_name="${2:-password}"
[agent]   "$kubectl_bin" -n "$NAMESPACE" get secret "$secret_name" -o "jsonpath={.data.$key_name}" | base64 -d
[agent] }
[agent] exec_mongo() {
[agent]   pod_name="$1"
[agent]   js="$2"
[agent]   "$kubectl_bin" -n "$NAMESPACE" exec "$pod_name" -- sh -c '
[agent]     mongosh --quiet \
[agent]       -u "$MONGO_ADMIN_USERNAME" \
[agent]       -p "$MONGO_ADMIN_PASSWORD" \
[agent]       --authenticationDatabase admin \
[agent]       --eval "$MONGO_EVAL"
[agent]   ' -- MONGO_ADMIN_USERNAME="$ADMIN_USERNAME" MONGO_ADMIN_PASSWORD="$ADMIN_PASSWORD" MONGO_EVAL="$js"
[agent] }
[agent] ADMIN_PASSWORD="$(get_secret_value "$ADMIN_SECRET_NAME")"
[agent] APP_PASSWORD="$(get_secret_value "$APP_SECRET_NAME")"
[agent] REPORTING_PASSWORD="$(get_secret_value "$REPORTING_SECRET_NAME")"
[agent] seed_pod="${CLUSTER_PREFIX}-0"
[agent] primary_host="$(exec_mongo "$seed_pod" 'db.hello().primary')"
[agent] primary_pod="${primary_host%%.*}"
[agent] app_js=$(cat <<EOF
[agent] const adminDb = db.getSiblingDB("admin");
[agent] const user = adminDb.getUser("${APP_USERNAME}");
[agent] const roles = [{ role: "readWrite", db: "${APP_DATABASE}" }];
[agent] if (user) {
[agent]   adminDb.updateUser("${APP_USERNAME}", { pwd: "${APP_PASSWORD}", roles });
[agent] } else {
[agent]   adminDb.createUser({ user: "${APP_USERNAME}", pwd: "${APP_PASSWORD}", roles });
[agent] }
[agent] EOF
[agent] )
[agent] reporting_js=$(cat <<EOF
[agent] const adminDb = db.getSiblingDB("admin");
[agent] const appDb = db.getSiblingDB("${APP_DATABASE}");
[agent] const roleName = "${REPORTING_ROLE_NAME}";
[agent] const privileges = [{
[agent]   resource: { db: "${APP_DATABASE}", collection: "${REPORTS_COLLECTION}" },
[agent]   actions: ["find"]
[agent] }];
[agent] const inheritedRoles = [];
[agent] if (appDb.getRole(roleName, { showPrivileges: true })) {
[agent]   appDb.updateRole(roleName, { privileges, roles: inheritedRoles });
[agent] } else {
[agent]   appDb.createRole({ role: roleName, privileges, roles: inheritedRoles });
[agent] }
[agent] const desiredRoles = [{ role: roleName, db: "${APP_DATABASE}" }];
[agent] const reportingUser = adminDb.getUser("${REPORTING_USERNAME}");
[agent] if (reportingUser) {
[agent]   adminDb.updateUser("${REPORTING_USERNAME}", { pwd: "${REPORTING_PASSWORD}", roles: desiredRoles });
[agent] } else {
[agent]   adminDb.createUser({ user: "${REPORTING_USERNAME}", pwd: "${REPORTING_PASSWORD}", roles: desiredRoles });
[agent] }
[agent] EOF
[agent] )
[agent] case "$MODE" in
[agent]   all)
[agent]     exec_mongo "$primary_pod" "$app_js"
[agent]     exec_mongo "$primary_pod" "$reporting_js"
[agent]     ;;
[agent]   app)
[agent]     exec_mongo "$primary_pod" "$app_js"
[agent]     ;;
[agent]   reporting)
[agent]     exec_mongo "$primary_pod" "$reporting_js"
[agent]     ;;
[agent] esac
