[agent] +      [ "$#" -ge 2 ] || usage
[agent] +      MODE="$2"
[agent] +      shift 2
[agent] +      ;;
[agent] +    *)
[agent] +      usage
[agent] +      ;;
[agent] +  esac
[agent] +done
[agent] +
[agent] +[ -n "$MODE" ] || usage
[agent] +
[agent] +case "$MODE" in
[agent] +  all|app|reporting)
[agent] +    ;;
[agent] +  *)
[agent] +    usage
[agent] +    ;;
