[agent] +const appDb = db.getSiblingDB("${APP_DATABASE}");
[agent] +const roleName = "${REPORTING_ROLE_NAME}";
[agent] +const privileges = [{
[agent] +  resource: { db: "${APP_DATABASE}", collection: "${REPORTS_COLLECTION}" },
[agent] +  actions: ["find"]
[agent] +}];
[agent] +const inheritedRoles = [];
[agent] +
[agent] +if (appDb.getRole(roleName, { showPrivileges: true })) {
[agent] +  appDb.updateRole(roleName, { privileges, roles: inheritedRoles });
[agent] +} else {
[agent] +  appDb.createRole({ role: roleName, privileges, roles: inheritedRoles });
[agent] +}
[agent] +
[agent] +const desiredRoles = [{ role: roleName, db: "${APP_DATABASE}" }];
[agent] +const reportingUser = adminDb.getUser("${REPORTING_USERNAME}");
[agent] +if (reportingUser) {
[agent] +  adminDb.updateUser("${REPORTING_USERNAME}", { pwd: "${REPORTING_PASSWORD}", roles: desiredRoles });
[agent] +} else {
[agent] +  adminDb.createUser({ user: "${REPORTING_USERNAME}", pwd: "${REPORTING_PASSWORD}", roles: desiredRoles });
[agent] +}
[agent] +EOF
[agent] +)
[agent] +
[agent] +case "$MODE" in
