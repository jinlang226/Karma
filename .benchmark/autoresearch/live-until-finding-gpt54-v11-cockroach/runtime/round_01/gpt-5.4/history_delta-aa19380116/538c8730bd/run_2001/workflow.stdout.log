[agent]   template:
[agent]     metadata:
[agent]       labels:
[agent]         app.kubernetes.io/instance: crdb-cluster
[agent]         app.kubernetes.io/name: cockroachdb
[agent]     spec:
[agent]       serviceAccountName: crdb-cluster-sa
[agent]       terminationGracePeriodSeconds: 60
[agent]       containers:
[agent]         - name: cockroachdb
[agent]           image: cockroachdb/cockroach:v24.1.0
[agent]           imagePullPolicy: IfNotPresent
[agent]           ports:
[agent]             - name: grpc
[agent]               containerPort: 26257
[agent]             - name: http
[agent]               containerPort: 8080
[agent]           env:
[agent]             - name: POD_NAME
[agent]               valueFrom:
[agent]                 fieldRef:
[agent]                   fieldPath: metadata.name
[agent]             - name: POD_NAMESPACE
[agent]               valueFrom:
[agent]                 fieldRef:
[agent]                   fieldPath: metadata.namespace
[agent]           command:
[agent]             - /bin/bash
[agent]             - -ec
[agent]             - |
[agent]               exec cockroach start \
[agent]                 --insecure \
[agent]                 --logtostderr=INFO \
[agent]                 --store=/cockroach/cockroach-data \
[agent]                 --advertise-addr="${POD_NAME}.crdb-cluster.${POD_NAMESPACE}.svc.cluster.local" \
[agent]                 --http-addr=0.0.0.0:8080 \
[agent]                 --listen-addr=0.0.0.0:26257 \
[agent]                 --join=crdb-cluster-0.crdb-cluster.${POD_NAMESPACE}.svc.cluster.local:26257,crdb-cluster-1.crdb-cluster.${POD_NAMESPACE}.svc.cluster.local:26257,crdb-cluster-2.crdb-cluster.${POD_NAMESPACE}.svc.cluster.local:26257
[agent]           readinessProbe:
[agent]             httpGet:
[agent]               path: /health?ready=1
[agent]               port: http
[agent]             initialDelaySeconds: 10
[agent]             periodSeconds: 5
[agent]             failureThreshold: 6
[agent]           livenessProbe:
[agent]             httpGet:
[agent]               path: /health
[agent]               port: http
[agent]             initialDelaySeconds: 30
[agent]             periodSeconds: 10
[agent]             failureThreshold: 6
[agent]           volumeMounts:
[agent]             - name: datadir
[agent]               mountPath: /cockroach/cockroach-data
[agent]           resources:
[agent]             requests:
[agent]               cpu: 250m
[agent]               memory: 512Mi
[agent]   volumeClaimTemplates:
[agent]     - metadata:
[agent]         name: datadir
[agent]       spec:
[agent]         accessModes:
[agent]           - ReadWriteOnce
[agent]         resources:
[agent]           requests:
[agent]             storage: 10Gi
[agent] ---
