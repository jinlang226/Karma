const appDbName = process.env.APP_DATABASE;
const appUser = process.env.APP_USERNAME;
const reportingUser = process.env.REPORTING_USERNAME;
const reportingRole = process.env.REPORTING_ROLE_NAME;
const badRole = process.env.BAD_ROLE_NAME;
const reportsCollection = process.env.REPORTS_COLLECTION;
const appPassword = Buffer.from(process.env.APP_PASSWORD_B64, "base64").toString("utf8");
const reportingPassword = Buffer.from(process.env.REPORTING_PASSWORD_B64, "base64").toString("utf8");

const appDb = db.getSiblingDB(appDbName);

function sameRoles(actual, expected) {
  const normalize = (roles) => roles
    .map((r) => ({ role: r.role, db: r.db }))
    .sort((a, b) => `${a.db}.${a.role}`.localeCompare(`${b.db}.${b.role}`));
  return JSON.stringify(normalize(actual || [])) === JSON.stringify(normalize(expected));
}

function ensureUser(database, username, password, roles) {
  const existing = database.getUser(username);
  if (!existing) {
    database.createUser({ user: username, pwd: password, roles });
    print(`created user ${database.getName()}.${username}`);
    return;
  }
  if (!sameRoles(existing.roles, roles)) {
    database.updateUser(username, { roles });
    print(`updated roles for ${database.getName()}.${username}`);
  } else {
    print(`roles already correct for ${database.getName()}.${username}`);
  }
}

function ensureReportingRole() {
  const desiredPrivileges = [{
    resource: { db: appDbName, collection: reportsCollection },
    actions: ["find"],
  }];
  const existing = appDb.getRole(reportingRole, { showPrivileges: true });
  if (!existing) {
    appDb.createRole({
      role: reportingRole,
      privileges: desiredPrivileges,
      roles: [],
    });
    print(`created role ${appDbName}.${reportingRole}`);
    return;
  }
  appDb.updateRole(reportingRole, {
    privileges: desiredPrivileges,
    roles: [],
  });
  print(`reset role ${appDbName}.${reportingRole}`);
}

if (mode === "all" || mode === "app") {
  ensureUser(appDb, appUser, appPassword, [{ role: "readWrite", db: appDbName }]);
}

if (mode === "all" || mode === "reporting") {
  ensureReportingRole();
  ensureUser(appDb, reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);
  const user = appDb.getUser(reportingUser);
  if ((user.roles || []).some((r) => r.role === badRole)) {
    throw new Error(`${reportingUser} still has ${badRole}`);
  }
}

print(`rbac reset complete: mode=${mode}`);'
