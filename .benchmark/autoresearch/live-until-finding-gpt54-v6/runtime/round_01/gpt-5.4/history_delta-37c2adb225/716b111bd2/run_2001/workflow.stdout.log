[agent]       {"apiVersion":"batch/v1","kind":"Job","metadata":{"annotations":{},"name":"rabbitmq-seed","namespace":"wf-2026-04-21t19-33-15z-workflow-r-da2cc215-control-cluster-a"},"spec":{"backoffLimit":0,"template":{"spec":{"containers":[{"command":["/bin/sh","-c","python - \u003c\u003c'PY'\nimport base64, json, os, sys, time\nfrom urllib.request import Request, urlopen\nfrom urllib.error import URLError, HTTPError\n\nbase = \"http://rabbitmq:15672/api\"\nuser = os.environ[\"RABBITMQ_APP_USER\"]\npw = os.environ[\"RABBITMQ_APP_PASS\"]\nseed = int(os.environ[\"SEED_COUNT\"])\nauth = base64.b64encode(f\"{user}:{pw}\".encode()).decode()\n\ndef req(path, method=\"GET\", body=None, timeout=5):\n    url = f\"{base}{path}\"\n    data = None\n    headers = {\"Authorization\": f\"Basic {auth}\"}\n    if body is not None:\n        data = json.dumps(body).encode()\n        headers[\"content-type\"] = \"application/json\"\n    r = Request(url, data=data, method=method, headers=headers)\n    with urlopen(r, timeout=timeout) as resp:\n        return resp.read().decode()\n\ndef wait_for(fn, label, retries=60, delay=2):\n    for i in range(1, retries + 1):\n        try:\n            if fn():\n                return True\n        except Exception:\n            pass\n        print(f\"seed: waiting for {label} ({i}/{retries})\", file=sys.stderr, flush=True)\n        time.sleep(delay)\n    return False\n\nprint(f\"seed: starting (SEED_COUNT={seed})\", file=sys.stderr, flush=True)\n\nif not wait_for(lambda: req(\"/overview\") is not None, \"management API\"):\n    print(\"seed: management API not ready after retries\", file=sys.stderr, flush=True)\n    sys.exit(1)\n\nif not wait_for(lambda: '\"name\":\"app-queue\"' in req(\"/queues/%2Fapp/app-queue\"), \"/app/app-queue\"):\n    print(\"seed: queue /app/app-queue not ready after retries\", file=sys.stderr, flush=True)\n    sys.exit(1)\n\nfor i in range(1, seed + 1):\n    payload = {\"id\": i}\n    ok = False\n    for _ in range(10):\n        try:\n            resp = req(\n                \"/exchanges/%2Fapp/amq.default/publish\",\n                method=\"POST\",\n                body={\n                    \"properties\": {\"delivery_mode\": 2},\n                    \"routing_key\": \"app-queue\",\n                    \"payload\": json.dumps(payload),\n                    \"payload_encoding\": \"string\",\n                },\n            )\n            if '\"routed\":true' in resp:\n                ok = True\n                break\n        except (HTTPError, URLError):\n            pass\n        time.sleep(1)\n    if not ok:\n        print(f\"seed: failed to publish id {i}\", file=sys.stderr, flush=True)\n        sys.exit(1)\n    if i % 10 == 0:\n        print(f\"seed: published {i}/{seed}\", file=sys.stderr, flush=True)\nPY\n"],"env":[{"name":"RABBITMQ_APP_USER","valueFrom":{"secretKeyRef":{"key":"username","name":"rabbitmq-admin"}}},{"name":"RABBITMQ_APP_PASS","valueFrom":{"secretKeyRef":{"key":"password","name":"rabbitmq-admin"}}},{"name":"SEED_COUNT","valueFrom":{"configMapKeyRef":{"key":"seed_count","name":"migration-seed"}}}],"image":"python:3.11-alpine","name":"seed"}],"restartPolicy":"Never"}}}}
