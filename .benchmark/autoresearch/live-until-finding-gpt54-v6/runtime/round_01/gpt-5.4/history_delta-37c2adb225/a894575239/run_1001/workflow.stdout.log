[agent] apiVersion: batch/v1
[agent] kind: Job
[agent] metadata:
[agent]   name: rabbitmq-migrate-blue-green
[agent] spec:
[agent]   backoffLimit: 2
[agent]   template:
[agent]     spec:
[agent]       restartPolicy: Never
[agent]       containers:
[agent]       - name: migrate
[agent]         image: python:3.11-alpine
[agent]         command: [\"/bin/sh\", \"-c\"]
[agent]         args:
[agent]         - |
[agent]           python - <<'PY'
[agent]           import base64, json, time, urllib.request
[agent]           from urllib.error import HTTPError
[agent]           user = 'admin'
[agent]           password = 'adminpass'
[agent]           auth = base64.b64encode(f'{user}:{password}'.encode()).decode()
[agent]           headers = {'Authorization': f'Basic {auth}', 'Content-Type': 'application/json'}
[agent]           blue = 'http://rabbitmq.wf-2026-04-21t19-25-30z-workflow-r-c6ae5182-history-m-da954b10.svc.cluster.local:15672/api'
[agent]           green = 'http://rabbitmq:15672/api'
[agent]           def request(method, url, data=None):
[agent]               body = None if data is None else json.dumps(data).encode()
[agent]               req = urllib.request.Request(url, data=body, headers=headers, method=method)
[agent]               with urllib.request.urlopen(req, timeout=20) as resp:
[agent]                   raw = resp.read().decode()
[agent]                   return json.loads(raw) if raw else None
[agent]           # Let the management API see the latest ready count, then copy a large single snapshot.
[agent]           time.sleep(1)
[agent]           got = request('POST', blue + '/queues/%2Fapp/app-queue/get', {
[agent]               'count': 10000,
[agent]               'ackmode': 'ack_requeue_true',
[agent]               'encoding': 'auto',
[agent]               'truncate': 1000,
[agent]           })
[agent]           messages = {}
[agent]           bad = 0
[agent]           for msg in got:
[agent]               try:
[agent]                   payload = msg.get('payload') or ''
[agent]                   parsed = json.loads(payload)
[agent]                   mid = int(parsed['id'])
[agent]                   messages[mid] = payload
[agent]               except Exception:
[agent]                   bad += 1
[agent]           if bad:
[agent]               print(f'skipped_bad_payloads={bad}')
[agent]           if not messages:
[agent]               raise SystemExit('no messages copied from blue')
[agent]           ids = sorted(messages)
[agent]           expected = list(range(ids[0], ids[-1] + 1))
[agent]           missing = sorted(set(expected) - set(ids))
[agent]           if ids[0] "'!= 1 or missing:
[agent]               raise SystemExit(f'"'blue snapshot has gaps: first={ids[0]} last={ids[-1]} missing_head={missing[:20]}')
[agent]           published = 0
[agent]           for mid in ids:
[agent]               res = request('POST', green + '/exchanges/%2Fapp/amq.default/publish', {
[agent]                   'properties': {'delivery_mode': 2},
[agent]                   'routing_key': 'app-queue',
[agent]                   'payload': messages[mid],
[agent]                   'payload_encoding': 'string',
[agent]               })
[agent]               if not res or not res.get('routed'):
[agent]                   raise SystemExit(f'publish failed for id={mid}: {res}')
[agent]               published += 1
[agent]           print(f'copied_count={published}')
[agent]           print(f'first_id={ids[0]}')
[agent]           print(f'last_id={ids[-1]}')
[agent]           print(f'next_id={ids[-1] + 1}')
[agent]           PY
