set -eu
cat >/tmp/reset-rbac.js <<'"'"'EOF'"'"'
const admin = db.getSiblingDB("admin");
const appDb = db.getSiblingDB(process.env.APP_DB);

function ensureUser(targetDb, username, password, roles) {
  if (targetDb.getUser(username)) {
    targetDb.updateUser(username, { pwd: password, roles });
  } else {
    targetDb.createUser({ user: username, pwd: password, roles });
  }
}

function ensureReportingRole() {
  const privileges = [
    {
      resource: { db: process.env.APP_DB, collection: process.env.REPORTS_COLLECTION },
      actions: ["find"],
    },
  ];
  if (appDb.getRole(process.env.REPORTING_ROLE, { showPrivileges: true })) {
    appDb.updateRole(process.env.REPORTING_ROLE, { privileges, roles: [] });
  } else {
    appDb.createRole({ role: process.env.REPORTING_ROLE, privileges, roles: [] });
  }
}

if (process.env.MODE === "all" || process.env.MODE === "app") {
  ensureUser(appDb, process.env.APP_USERNAME, process.env.APP_PASSWORD, [
    { role: "readWrite", db: process.env.APP_DB },
  ]);
}

if (process.env.MODE === "all" || process.env.MODE === "reporting") {
  ensureReportingRole();
  ensureUser(appDb, process.env.REPORTING_USERNAME, process.env.REPORTING_PASSWORD, [
    { role: process.env.REPORTING_ROLE, db: process.env.APP_DB },
  ]);

  const rawRole = appDb.getRole(process.env.BAD_ROLE);
  if (rawRole) {
    const user = appDb.getUser(process.env.REPORTING_USERNAME);
    const stillHasRawRole =
      user &&
      user.roles.some((role) => role.role === process.env.BAD_ROLE && role.db === process.env.APP_DB);
    if (stillHasRawRole) {
      throw new Error("reporting-user still has deprecated rawRead role");
    }
  }
}

printjson({
  ok: 1,
  mode: process.env.MODE,
  appUser: appDb.getUser(process.env.APP_USERNAME),
  reportingUser: appDb.getUser(process.env.REPORTING_USERNAME),
  reportingRole: appDb.getRole(process.env.REPORTING_ROLE, { showPrivileges: true }),
});
EOF
mongosh --quiet \
  --username "$ADMIN_USERNAME" \
  --password "$ADMIN_PASSWORD" \
  --authenticationDatabase admin \
  /tmp/reset-rbac.js
rm -f /tmp/reset-rbac.js
