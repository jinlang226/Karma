[agent] Current state has `reportingRole` on `appdb`, and `reporting-user` is an `admin` database user with that appdb role. I’m going to create/update `appdb.rawRead`, switch the user to only that role, then drop `appdb.reportingRole`.
[kubectl] 2026-04-21T08:09:43Z kubectl -n wf-2026-04-21t08-08-00z-workflow-r-82dd8d82-control-cluster-a exec mongodb-replica-0 -- mongosh --quiet -u admin-user -p admin123password --authenticationDatabase admin --eval '
const app = db.getSiblingDB("appdb");
const admin = db.getSiblingDB("admin");
const rawRead = app.getRole("rawRead", {showPrivileges: true});
const rawPrivs = [{resource: {db: "appdb", collection: "raw"}, actions: ["find"]}];
if (rawRead) {
  app.updateRole("rawRead", {privileges: rawPrivs, roles: []});
} else {
  app.createRole({role: "rawRead", privileges: rawPrivs, roles: []});
}
admin.updateUser("reporting-user", {roles: [{role: "rawRead", db: "appdb"}]});
if (app.getRole("reportingRole")) {
  app.dropRole("reportingRole");
}
printjson({rawRead: app.getRole("rawRead", {showPrivileges: true}), reportingRole: app.getRole("reportingRole"), reportingUser: admin.getUser("reporting-user")});
'
