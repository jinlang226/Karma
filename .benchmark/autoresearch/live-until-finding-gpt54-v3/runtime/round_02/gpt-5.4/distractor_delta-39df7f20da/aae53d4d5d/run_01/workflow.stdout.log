[kubectl] 2026-04-21T07:51:21Z kubectl -n wf-2026-04-21t07-49-22z-workflow-r-b166558d-control-cluster-a exec mongodb-replica-0 -- mongosh --quiet --username admin-user --password admin123password --authenticationDatabase admin admin --eval '
const app = db.getSiblingDB("appdb");
const admin = db.getSiblingDB("admin");
const rawRead = app.getRole("rawRead", {showPrivileges: true});
const rawReadPrivileges = [{resource: {db: "appdb", collection: "raw"}, actions: ["find"]}];
if (rawRead) {
  app.updateRole("rawRead", {privileges: rawReadPrivileges, roles: []});
  print("updated rawRead");
} else {
  app.createRole({role: "rawRead", privileges: rawReadPrivileges, roles: []});
  print("created rawRead");
}
const user = admin.getUser("reporting-user");
if (!user) {
  throw new Error("reporting-user not found in admin database");
}
const hasReporting = user.roles.some(r => r.role === "reportingRole" && r.db === "appdb");
if (hasReporting) {
  admin.revokeRolesFromUser("reporting-user", [{role: "reportingRole", db: "appdb"}]);
  print("revoked reportingRole from reporting-user");
}
const refreshed = admin.getUser("reporting-user");
const hasRawRead = refreshed.roles.some(r => r.role === "rawRead" && r.db === "appdb");
if (!hasRawRead) {
  admin.grantRolesToUser("reporting-user", [{role: "rawRead", db: "appdb"}]);
  print("granted rawRead to reporting-user");
}
if (app.getRole("reportingRole")) {
  app.dropRole("reportingRole");
  print("dropped reportingRole");
}
print("done");
'
