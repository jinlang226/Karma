const app = db.getSiblingDB("appdb");
const admin = db.getSiblingDB("admin");
const rawPrivilege = [{ resource: { db: "appdb", collection: "raw" }, actions: ["find"] }];
try {
  app.createRole({ role: "rawRead", privileges: rawPrivilege, roles: [] });
  print("created rawRead");
} catch (e) {
  if (e.codeName === "DuplicateKey" || /already exists/i.test(e.message)) {
    app.updateRole("rawRead", { privileges: rawPrivilege, roles: [] });
    print("updated rawRead");
  } else {
    throw e;
  }
}
admin.updateUser("reporting-user", { roles: [{ role: "rawRead", db: "appdb" }] });
try {
  app.dropRole("reportingRole");
  print("dropped reportingRole");
} catch (e) {
  if (e.codeName === "RoleNotFound" || /Role.*not found|not found/i.test(e.message)) {
    print("reportingRole already absent");
  } else {
    throw e;
  }
}
print("done");
