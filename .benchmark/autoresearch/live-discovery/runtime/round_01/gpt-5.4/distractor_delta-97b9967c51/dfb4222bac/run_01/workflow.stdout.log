[agent] #!/bin/sh
[agent] set -eu
[agent] NAMESPACE="${NAMESPACE:-wf-2026-04-09t18-39-23z-workflow-r-fa32722d-control-cluster-a}"
[agent] ADMIN_SECRET="${ADMIN_SECRET:-admin-user-password}"
[agent] APP_SECRET="${APP_SECRET:-app-user-password}"
[agent] REPORTING_SECRET="${REPORTING_SECRET:-reporting-user-password}"
[agent] ADMIN_USERNAME="${ADMIN_USERNAME:-admin-user}"
[agent] APP_USERNAME="${APP_USERNAME:-app-user}"
[agent] REPORTING_USERNAME="${REPORTING_USERNAME:-reporting-user}"
[agent] APP_DATABASE="${APP_DATABASE:-appdb}"
[agent] REPORTING_ROLE="${REPORTING_ROLE:-reportingRole}"
[agent] POD_NAME="${POD_NAME:-mongodb-replica-0}"
[agent] REPLICA_SET="${REPLICA_SET:-mongodb-replica}"
[agent] SERVICE_NAME="${SERVICE_NAME:-mongodb-replica-svc}"
[agent] MODE="all"
[agent] while [ "$#" -gt 0 ]; do
[agent]   case "$1" in
[agent]     --mode)
[agent]       shift
[agent]       [ "$#" -gt 0 ] || {
[agent]         echo "missing value for --mode" >&2
[agent]         exit 2
[agent]       }
[agent]       MODE="$1"
[agent]       ;;
[agent]     --mode=*)
[agent]       MODE="${1#*=}"
[agent]       ;;
[agent]     *)
[agent]       echo "unknown argument: $1" >&2
[agent]       exit 2
[agent]       ;;
[agent]   esac
[agent]   shift
[agent] done
[agent] case "$MODE" in
[agent]   all|app|reporting) ;;
[agent]   *)
[agent]     echo "invalid mode: $MODE" >&2
[agent]     exit 2
[agent]     ;;
[agent] esac
[agent] secret_value() {
[agent]   kubectl -n "$NAMESPACE" get secret "$1" -o jsonpath='{.data.password}' | base64 -d
[agent] }
[agent] ADMIN_PASSWORD="$(secret_value "$ADMIN_SECRET")"
[agent] APP_PASSWORD="$(secret_value "$APP_SECRET")"
[agent] REPORTING_PASSWORD="$(secret_value "$REPORTING_SECRET")"
[agent] MONGO_URI="mongodb://${ADMIN_USERNAME}:${ADMIN_PASSWORD}@${REPLICA_SET}-0.${SERVICE_NAME},${REPLICA_SET}-1.${SERVICE_NAME},${REPLICA_SET}-2.${SERVICE_NAME}/admin?replicaSet=${REPLICA_SET}&authSource=admin"
[agent] TMP_JS="$(mktemp)"
[agent] trap 'rm -f "$TMP_JS"' EXIT INT TERM
[agent] cat >"$TMP_JS" <<EOF
[agent] const mode = ${MODE@Q};
[agent] const appDatabase = ${APP_DATABASE@Q};
[agent] const appUsername = ${APP_USERNAME@Q};
[agent] const appPassword = ${APP_PASSWORD@Q};
[agent] const reportingUsername = ${REPORTING_USERNAME@Q};
[agent] const reportingPassword = ${REPORTING_PASSWORD@Q};
[agent] const reportingRole = ${REPORTING_ROLE@Q};
[agent] const appDb = db.getSiblingDB(appDatabase);
[agent] function ensureUser(user, pwd, roles) {
