       try:\n            resp = req(\n                \"/exchanges/%2Fapp/amq.default/publish\",\n                method=\"POST\",\n                body={\n                    \"properties\": {\"delivery_mode\": 2},\n                    \"routing_key\": \"app-queue\",\n                    \"payload\": json.dumps(payload),\n                    \"payload_encoding\": \"string\",\n                },\n            )\n            if '\"routed\":true' in resp:\n                ok = True\n                break\n        except (HTTPError, URLError):\n            pass\n        time.sleep(1)\n    if not ok:\n        print(f\"seed: failed to publish id {i}\", file=sys.stderr, flush=True)\n        sys.exit(1)\n    if i % 10 == 0:\n        print(f\"seed: published {i}/{seed}\", file=sys.stderr, flush=True)\nPY\n"],"env":[{"name":"RABBITMQ_APP_USER","valueFrom":{"secretKeyRef":{"key":"username","name":"rabbitmq-admin"}}},{"name":"RABBITMQ_APP_PASS","valueFrom":{"secretKeyRef":{"key":"password","name":"rabbitmq-admin"}}},{"name":"SEED_COUNT","valueFrom":{"configMapKeyRef":{"key":"seed_count","name":"migration-seed"}}}],"image":"python:3.11-alpine","name":"seed"}],"restartPolicy":"Never"}}}}
