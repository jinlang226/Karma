[agent]           ;;
[agent]         --mode=*)
[agent]           MODE="${1#--mode=}"
[agent]           shift
[agent]           ;;
[agent]         -h|--help)
[agent]           echo "usage: $0 [--mode all|app|reporting]"
[agent]           exit 0
[agent]           ;;
[agent]         *)
[agent]           echo "unknown argument: $1" >&2
[agent]           exit 2
[agent]           ;;
[agent]       esac
[agent]     done
[agent]     case "$MODE" in
[agent]       all|app|reporting) ;;
[agent]       *)
[agent]         echo "invalid mode: $MODE" >&2
[agent]         exit 2
[agent]         ;;
[agent]     esac
[agent]     ADMIN_USERNAME="${ADMIN_USERNAME:-${MONGO_ADMIN_USERNAME:-admin-user}}"
[agent]     ADMIN_PASSWORD="${ADMIN_PASSWORD:-${MONGO_ADMIN_PASSWORD:-admin123password}}"
[agent]     APP_USERNAME="${APP_USERNAME:-app-user}"
[agent]     APP_PASSWORD="${APP_PASSWORD:-app123password}"
[agent]     REPORTING_USERNAME="${REPORTING_USERNAME:-reporting-user}"
[agent]     REPORTING_PASSWORD="${REPORTING_PASSWORD:-reporting123password}"
[agent]     APP_DATABASE="${APP_DATABASE:-appdb}"
[agent]     REPORTS_COLLECTION="${REPORTS_COLLECTION:-reports}"
[agent]     REPORTING_ROLE_NAME="${REPORTING_ROLE_NAME:-reportingRole}"
[agent]     BAD_ROLE_NAME="${BAD_ROLE_NAME:-rawRead}"
[agent]     MONGO_URI="${MONGO_URI:-mongodb://mongodb-replica-0.mongodb-replica-svc:27017,mongodb-replica-1.mongodb-replica-svc:27017,mongodb-replica-2.mongodb-replica-svc:27017/admin?replicaSet=mongodb-replica}"
[agent]     mongosh "$MONGO_URI" --quiet -u "$ADMIN_USERNAME" -p "$ADMIN_PASSWORD" --authenticationDatabase admin --eval "
[agent]     const mode = '"'"'$MODE'"';
[agent]     const admin = db.getSiblingDB('admin');
[agent]     const appdb = db.getSiblingDB('"'$APP_DATABASE'"');
[agent]     const appDatabase = '"'$APP_DATABASE'"';
[agent]     const reportsCollection = '"'$REPORTS_COLLECTION'"';
[agent]     const appUsername = '"'$APP_USERNAME'"';
[agent]     const appPassword = '"'$APP_PASSWORD'"';
[agent]     const reportingUsername = '"'$REPORTING_USERNAME'"';
[agent]     const reportingPassword = '"'$REPORTING_PASSWORD'"';
[agent]     const reportingRoleName = '"'$REPORTING_ROLE_NAME'"';
[agent]     const badRoleName = '"'$BAD_ROLE_NAME'"';
[agent]     function ensureAdminUser(user, password, roles) {
[agent]       if (admin.getUser(user) === null) {
[agent]         admin.createUser({user, pwd: password, roles});
[agent]       } else {
[agent]         admin.updateUser(user, {roles});
[agent]       }
[agent]     }
[agent]     function ensureReportingRole() {
[agent]       const roleSpec = {
[agent]         privileges: [{resource: {db: appDatabase, collection: reportsCollection}, actions: ['find']}],
[agent]         roles: []
[agent]       };
[agent]       if (appdb.getRole(reportingRoleName) === null) {
[agent]         appdb.createRole({role: reportingRoleName, ...roleSpec});
[agent]       } else {
[agent]         appdb.updateRole(reportingRoleName, roleSpec);
[agent]       }
[agent]     }
[agent]     if (mode === 'all' || mode === 'app') {
[agent]       ensureAdminUser(appUsername, appPassword, [{role: 'readWrite', db: appDatabase}]);
[agent]     }
[agent]     if (mode === 'all' || mode === 'reporting') {
[agent]       ensureReportingRole();
[agent]       ensureAdminUser(reportingUsername, reportingPassword, [{role: reportingRoleName, db: appDatabase}]);
[agent]     }
[agent]     printjson({
[agent]       mode,
[agent]       appUser: admin.getUser(appUsername),
[agent]       reportingUser: admin.getUser(reportingUsername),
[agent]       reportingRole: appdb.getRole(reportingRoleName, {showPrivileges: true}),
