[agent]     while [ "$#" -gt 0 ]; do
[agent]       case "$1" in
[agent]         --mode)
[agent]           if [ "$#" -lt 2 ]; then
[agent]             echo "missing value for --mode" >&2
[agent]             exit 2
[agent]           fi
[agent]           MODE="$2"
