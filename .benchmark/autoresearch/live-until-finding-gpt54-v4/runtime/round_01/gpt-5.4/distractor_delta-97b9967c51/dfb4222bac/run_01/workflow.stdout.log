[agent] #!/bin/sh
[agent] set -eu
[agent] NAMESPACE="${NAMESPACE:-wf-2026-04-21t08-40-08z-workflow-r-1222c04b-control-cluster-a}"
[agent] POD="${POD:-mongodb-replica-0}"
[agent] ADMIN_USERNAME="${ADMIN_USERNAME:-admin-user}"
[agent] APP_USERNAME="${APP_USERNAME:-app-user}"
[agent] REPORTING_USERNAME="${REPORTING_USERNAME:-reporting-user}"
[agent] APP_DATABASE="${APP_DATABASE:-appdb}"
[agent] REPORTING_ROLE_NAME="${REPORTING_ROLE_NAME:-reportingRole}"
[agent] BAD_ROLE_NAME="${BAD_ROLE_NAME:-rawRead}"
[agent] REPORTS_COLLECTION="${REPORTS_COLLECTION:-reports}"
[agent] ADMIN_SECRET_NAME="${ADMIN_SECRET_NAME:-admin-user-password}"
[agent] APP_SECRET_NAME="${APP_SECRET_NAME:-app-user-password}"
[agent] REPORTING_SECRET_NAME="${REPORTING_SECRET_NAME:-reporting-user-password}"
[agent] MODE="all"
[agent] while [ "$#" -gt 0 ]; do
[agent]   case "$1" in
[agent]     --mode)
[agent]       [ "$#" -ge 2 ] || {
[agent]         echo "missing value for --mode" >&2
[agent]         exit 2
[agent]       }
[agent]       MODE="$2"
[agent]       shift 2
[agent]       ;;
[agent]     --mode=*)
[agent]       MODE="${1#--mode=}"
[agent]       shift
[agent]       ;;
[agent]     -h|--help)
[agent]       echo "usage: $0 [--mode all|app|reporting]"
[agent]       exit 0
[agent]       ;;
[agent]     *)
[agent]       echo "unknown argument: $1" >&2
[agent]       exit 2
[agent]       ;;
[agent]   esac
[agent] done
[agent] case "$MODE" in
[agent]   all|app|reporting) ;;
[agent]   *)
[agent]     echo "invalid mode: $MODE" >&2
[agent]     exit 2
[agent]     ;;
[agent] esac
[agent] secret_password() {
