[agent] +" <<EOF
[agent] +const mode = $(printf '%s' "$MODE" | sed "s/'/'\\\\''/g" | awk '{printf("'"'"'%s'"'"'", $0)}');
[agent] +const appDb = db.getSiblingDB('${APP_DB}');
[agent] +const adminDb = db.getSiblingDB('admin');
[agent] +
[agent] +function ensureRole(roleName, privileges) {
[agent] +  if (appDb.getRole(roleName, { showPrivileges: true })) {
[agent] +    appDb.updateRole(roleName, { privileges, roles: [] });
[agent] +  } else {
[agent] +    appDb.createRole({ role: roleName, privileges, roles: [] });
[agent] +  }
[agent] +}
[agent] +
[agent] +function ensureUserRoles(userName, roles) {
[agent] +  adminDb.updateUser(userName, { roles });
[agent] +}
[agent] +
[agent] +if (mode === 'app' || mode === 'all') {
[agent] +  ensureUserRoles('${APP_USER}', [{ role: 'readWrite', db: '${APP_DB}' }]);
[agent] +}
[agent] +
[agent] +if (mode === 'reporting' || mode === 'all') {
[agent] +  ensureRole('${REPORTING_ROLE}', [{
[agent] +    resource: { db: '${APP_DB}', collection: '${REPORTS_COLLECTION}' },
[agent] +    actions: ['find']
[agent] +  }]);
[agent] +  ensureUserRoles('${REPORTING_USER}', [{ role: '${REPORTING_ROLE}', db: '${APP_DB}' }]);
[agent] +}
[agent] +
[agent] +printjson({
[agent] +  ok: 1,
[agent] +  mode,
[agent] +  appUser: adminDb.getUser('${APP_USER}'),
[agent] +  reportingUser: adminDb.getUser('${REPORTING_USER}'),
[agent] +  reportingRole: appDb.getRole('${REPORTING_ROLE}', { showPrivileges: true }),
[agent] +  legacyRole: appDb.getRole('${LEGACY_ROLE}', { showPrivileges: true })
[agent] +});
[agent] +EOF
