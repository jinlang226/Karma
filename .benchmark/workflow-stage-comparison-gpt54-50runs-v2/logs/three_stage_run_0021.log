[agent] +    if kubectl -n "$NAMESPACE" exec "$pod" -- sh -lc \
[agent] +      "mongosh --quiet -u '$ADMIN_USERNAME' -p '$admin_password' --authenticationDatabase admin --eval 'db.hello().isWritablePrimary'" \
[agent] +      2>/dev/null | grep -qx true; then
