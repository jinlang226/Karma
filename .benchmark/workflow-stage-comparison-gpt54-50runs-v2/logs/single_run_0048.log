ret_value \"$APP_SECRET\")\"\nREPORTING_PASSWORD=\"$(secret_value \"$REPORTING_SECRET\")\"\nPRIMARY_POD=\"$(find_primary_pod)\"\n\nkubectl -n \"$NAMESPACE\" exec -i \"$PRIMARY_POD\" -- env \\\n  MODE=\"$MODE\" \\\n  APP_DB=\"$APP_DB\" \\\n  APP_USER=\"$APP_USER\" \\\n  APP_PASSWORD=\"$APP_PASSWORD\" \\\n  REPORTING_USER=\"$REPORTING_USER\" \\\n  REPORTING_PASSWORD=\"$REPORTING_PASSWORD\" \\\n  REPORTING_ROLE=\"$REPORTING_ROLE\" \\\n  BAD_ROLE=\"$BAD_ROLE\" \\\n  mongosh --quiet \\\n    -u \"$ADMIN_USER\" \\\n    -p \"$ADMIN_PASSWORD\" \\\n    --authenticationDatabase admin \\\n    --file /dev/stdin \u003c\u003c'EOF'\nconst mode = process.env.MODE;\nconst appDbName = process.env.APP_DB;\nconst appUser = process.env.APP_USER;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUser = process.env.REPORTING_USER;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRole = process.env.REPORTING_ROLE;\nconst badRole = process.env.BAD_ROLE;\n\nconst appDb = db.getSiblingDB(appDbName);\n\nfunction userExists(database, username) {\n  return database.getUser(username) !== null;\n}\n\nfunction roleExists(database, roleName) {\n  return database.getRole(roleName, { showPrivileges: true }) !== null;\n}\n\nfunction ensureAppUser() {\n  const roles = [{ role: \"readWrite\", db: appDbName }];\n  if (userExists(appDb, appUser)) {\n    appDb.updateUser(appUser, { pwd: appPassword, roles });\n  } else {\n    appDb.createUser({ user: appUser, pwd: appPassword, roles });\n  }\n}\n\nfunction ensureReportingRole() {\n  const privileges = [{\n    resource: { db: appDbName, collection: \"reports\" },\n    actions: [\"find\"]\n  }];\n  if (roleExists(appDb, reportingRole)) {\n    appDb.updateRole(reportingRole, { privileges, roles: [] });\n  } else {\n    appDb.createRole({ role: reportingRole, privileges, roles: [] });\n  }\n}\n\nfunction ensureReportingUser() {\n  const roles = [{ role: reportingRole, db: appDbName }];\n  if (userExists(appDb, reportingUser)) {\n    appDb.updateUser(reportingUser, { pwd: reportingPassword, roles });\n  } else {\n    appDb.createUser({ user: reportingUser, pwd: reportingPassword, roles });\n  }\n}\n\nfunction dropDeprecatedRole() {\n  if (roleExists(appDb, badRole)) {\n    appDb.dropRole(badRole);\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  ensureAppUser();\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  ensureReportingRole();\n  ensureReportingUser();\n  dropDeprecatedRole();\n}\nEOF\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-21t07-10-08z-workflow-r-a4cc7b05-cluster-a"}}
