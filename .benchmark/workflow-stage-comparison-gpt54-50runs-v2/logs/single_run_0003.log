[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/bin/sh\nset -eu\n\nNAMESPACE=\"wf-2026-05-20t05-08-48z-workflow-r-7e52fadf-cluster-a\"\nLABEL_SELECTOR=\"app=mongodb-replica\"\nADMIN_SECRET=\"admin-user-password\"\nAPP_SECRET=\"app-user-password\"\nREPORTING_SECRET=\"reporting-user-password\"\nADMIN_USERNAME=\"admin-user\"\nAPP_USERNAME=\"app-user\"\nREPORTING_USERNAME=\"reporting-user\"\nAPP_DATABASE=\"appdb\"\nREPORTING_ROLE=\"reportingRole\"\nDEPRECATED_ROLE=\"rawRead\"\nREPORTS_COLLECTION=\"reports\"\n\nusage() {\n  cat \u003c\u003c'EOF'\nUsage: reset_rbac.sh --mode all|app|reporting\nEOF\n}\n\nMODE=\"\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      if [ \"$#\" -lt 2 ]; then\n        usage \u003e\u00262\n        exit 1\n      fi\n      MODE=\"$2\"\n      shift 2\n      ;;\n    -h|--help)\n      usage\n      exit 0\n      ;;\n    *)\n      echo \"unknown argument: $1\" \u003e\u00262\n      usage \u003e\u00262\n      exit 1\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting)\n    ;;\n  *)\n    echo \"--mode must be one of: all, app, reporting\" \u003e\u00262\n    usage \u003e\u00262\n    exit 1\n    ;;\nesac\n\nneed_cmd() {\n  command -v \"$1\" \u003e/dev/null 2\u003e\u00261 || {\n    echo \"required command not found: $1\" \u003e\u00262\n    exit 1\n  }\n}\n\nneed_cmd kubectl\nneed_cmd base64\nneed_cmd tr\nneed_cmd cut\n\nget_secret_value() {\n  kubectl -n \"$NAMESPACE\" get secret \"$1\" -o jsonpath='{.data.password}' | base64 -d\n}\n\nADMIN_PASSWORD=$(get_secret_value \"$ADMIN_SECRET\")\nAPP_PASSWORD=$(get_secret_value \"$APP_SECRET\")\nREPORTING_PASSWORD=$(get_secret_value \"$REPORTING_SECRET\")\n\nPRIMARY_HOST=$(\n  kubectl -n \"$NAMESPACE\" exec mongodb-replica-0 -- mongosh \\\n    --quiet \\\n    --host localhost \\\n    --username \"$ADMIN_USERNAME\" \\\n    --password \"$ADMIN_PASSWORD\" \\\n    --authenticationDatabase admin \\\n    --eval 'db.hello().primary'\n)\n\nPRIMARY_POD=$(printf '%s\\n' \"$PRIMARY_HOST\" | cut -d. -f1)\nif [ -z \"$PRIMARY_POD\" ]; then\n  echo \"failed to determine primary pod\" \u003e\u00262\n  exit 1\nfi\n\nMODE_B64=$(printf '%s' \"$MODE\" | base64 | tr -d '\\n')\nAPP_PASSWORD_B64=$(printf '%s' \"$APP_PASSWORD\" | base64 | tr -d '\\n')\nREPORTING_PASSWORD_B64=$(printf '%s' \"$REPORTING_PASSWORD\" | base64 | tr -d '\\n')\n\nkubectl -n \"$NAMESPACE\" exec -i \"$PRIMARY_POD\" -- sh -lc \"\nexport MODE_B64='$MODE_B64'\nexport APP_PASSWORD_B64='$APP_PASSWORD_B64'\nexport REPORTING_PASSWORD_B64='$REPORTING_PASSWORD_B64'\nexport APP_USERNAME='$APP_USERNAME'\nexport REPORTING_USERNAME='$REPORTING_USERNAME'\nexport APP_DATABASE='$APP_DATABASE'\nexport REPORTING_ROLE='$REPORTING_ROLE'\nexport DEPRECATED_ROLE='$DEPRECATED_ROLE'\nexport REPORTS_COLLECTION='$REPORTS_COLLECTION'\nexport ADMIN_PASSWORD='$(printf \"%s\" \"$ADMIN_PASSWORD\" | sed \"s/'/'\\\\\\\\''/g\")'\n\ncat \u003e /tmp/reset_rbac.js \u003c\u003c'EOF_JS'\nconst mode = Buffer.from(process.env.MODE_B64, 'base64').toString('utf8');\nconst appPassword = Buffer.from(process.env.APP_PASSWORD_B64, 'base64').toString('utf8');\nconst reportingPassword = Buffer.from(process.env.REPORTING_PASSWORD_B64, 'base64').toString('utf8');\nconst appUsername = process.env.APP_USERNAME;\nconst reportingUsername = process.env.REPORTING_USERNAME;\nconst appDatabase = process.env.APP_DATABASE;\nconst reportingRole = process.env.REPORTING_ROLE;\nconst deprecatedRole = process.env.DEPRECATED_ROLE;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\n\nconst appDb = db.getSiblingDB(appDatabase);\n\nfunction userExists(database, username) {\n  return database.getUser(username) !== null;\n}\n\nfunction roleExists(database, roleName) {\n  return database.getRole(roleName, { showPrivileges: true }) !== null;\n}\n\nfunction ensureAppUser() {\n  const roles = [{ role: 'readWrite', db: appDatabase }];\n  if (userExists(appDb, appUsername)) {\n    appDb.updateUser(appUsername, { pwd: appPassword, roles: roles });\n  } else {\n    appDb.createUser({ user: appUsername, pwd: appPassword, roles: roles });\n  }\n}\n\nfunction ensureReportingRole() {\n  const privileges = [{\n    resource: { db: appDatabase, collection: reportsCollection },\n    actions: ['find']\n  }];\n  if (roleExists(appDb, reportingRole)) {\n    appDb.updateRole(reportingRole, { privileges: privileges, roles: [] });\n  } else {\n    appDb.createRole({ role: reportingRole, privileges: privileges, roles: [] });\n  }\n}\n\nfunction ensureReportingUser() {\n  const roles = [{ role: reportingRole, db: appDatabase }];\n  if (userExists(appDb, reportingUsername)) {\n    appDb.updateUser(reportingUsername, { pwd: reportingPassword, roles: roles });\n  } else {\n    appDb.createUser({ user: reportingUsername, pwd: reportingPassword, roles: roles });\n  }\n}\n\nif (mode === 'all' || mode === 'app') {\n  ensureAppUser();\n}\n\nif (mode === 'all' || mode === 'reporting') {\n  ensureReportingRole();\n  ensureReportingUser();\n}\n\nconst result = {\n  mode,\n  appUser: appDb.getUser(appUsername),\n  reportingUser: appDb.getUser(reportingUsername),\n  reportingRole: appDb.getRole(reportingRole, { showPrivileges: true })\n};\nprint(EJSON.stringify(result, null, 2));\nEOF_JS\n\nmongosh --quiet --host localhost --username '$ADMIN_USERNAME' --password \\\"\\$ADMIN_PASSWORD\\\" --authenticationDatabase admin /tmp/reset_rbac.js\n\"\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-20t05-08-48z-workflow-r-7e52fadf-cluster-a"}}
