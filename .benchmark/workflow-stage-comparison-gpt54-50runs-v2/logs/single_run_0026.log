[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/bin/sh\nset -eu\n\nNAMESPACE=\"wf-2026-05-20t23-40-50z-workflow-r-1b145bef-cluster-a\"\nPOD_NAME=\"mongodb-replica-0\"\nREPLICA_SET_NAME=\"mongodb-replica\"\nHEADLESS_SERVICE_NAME=\"mongodb-replica-svc\"\nAPP_DATABASE=\"appdb\"\nADMIN_USERNAME=\"admin-user\"\nAPP_USERNAME=\"app-user\"\nREPORTING_USERNAME=\"reporting-user\"\nREPORTING_ROLE_NAME=\"reportingRole\"\nREPORTS_COLLECTION=\"reports\"\n\nusage() {\n  cat \u003c\u003c'EOF'\nUsage: reset_rbac.sh --mode all|app|reporting\nEOF\n}\n\nMODE=\"\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      if [ \"$#\" -lt 2 ]; then\n        usage \u003e\u00262\n        exit 1\n      fi\n      MODE=\"$2\"\n      shift 2\n      ;;\n    -h|--help)\n      usage\n      exit 0\n      ;;\n    *)\n      usage \u003e\u00262\n      exit 1\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting)\n    ;;\n  *)\n    usage \u003e\u00262\n    exit 1\n    ;;\nesac\n\nget_secret_password() {\n  secret_name=\"$1\"\n  kubectl -n \"$NAMESPACE\" get secret \"$secret_name\" -o jsonpath='{.data.password}' | base64 -d\n}\n\nADMIN_PASSWORD=\"$(get_secret_password admin-user-password)\"\nAPP_PASSWORD=\"$(get_secret_password app-user-password)\"\nREPORTING_PASSWORD=\"$(get_secret_password reporting-user-password)\"\n\nHOSTS=\"mongodb-replica-0.${HEADLESS_SERVICE_NAME}.${NAMESPACE}.svc.cluster.local:27017,mongodb-replica-1.${HEADLESS_SERVICE_NAME}.${NAMESPACE}.svc.cluster.local:27017,mongodb-replica-2.${HEADLESS_SERVICE_NAME}.${NAMESPACE}.svc.cluster.local:27017\"\nMONGO_HOST=\"${REPLICA_SET_NAME}/${HOSTS}\"\n\nkubectl -n \"$NAMESPACE\" exec -i \"$POD_NAME\" -- env \\\n  RESET_MODE=\"$MODE\" \\\n  APP_DATABASE=\"$APP_DATABASE\" \\\n  APP_USERNAME=\"$APP_USERNAME\" \\\n  APP_PASSWORD=\"$APP_PASSWORD\" \\\n  REPORTING_USERNAME=\"$REPORTING_USERNAME\" \\\n  REPORTING_PASSWORD=\"$REPORTING_PASSWORD\" \\\n  REPORTING_ROLE_NAME=\"$REPORTING_ROLE_NAME\" \\\n  REPORTS_COLLECTION=\"$REPORTS_COLLECTION\" \\\n  mongosh --quiet --host \"$MONGO_HOST\" -u \"$ADMIN_USERNAME\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin --file /dev/stdin \u003c\u003c'EOF'\nconst mode = process.env.RESET_MODE;\nconst appDatabase = process.env.APP_DATABASE;\nconst appUsername = process.env.APP_USERNAME;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUsername = process.env.REPORTING_USERNAME;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRoleName = process.env.REPORTING_ROLE_NAME;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\n\nconst appDb = db.getSiblingDB(appDatabase);\n\nfunction upsertUser(targetDb, username, password, roles) {\n  const existingUser = targetDb.getUser(username);\n  if (existingUser) {\n    targetDb.updateUser(username, { pwd: password, roles });\n    return \"updated\";\n  }\n\n  targetDb.createUser({ user: username, pwd: password, roles });\n  return \"created\";\n}\n\nfunction ensureReportingRole() {\n  const roleDocument = {\n    privileges: [\n      {\n        resource: { db: appDatabase, collection: reportsCollection },\n        actions: [\"find\"],\n      },\n    ],\n    roles: [],\n  };\n\n  const existingRole = appDb.getRole(reportingRoleName, { showPrivileges: true });\n  if (existingRole) {\n    appDb.updateRole(reportingRoleName, roleDocument);\n    return \"updated\";\n  }\n\n  appDb.createRole({ role: reportingRoleName, ...roleDocument });\n  return \"created\";\n}\n\nconst result = { mode };\n\nif (mode === \"app\" || mode === \"all\") {\n  result.appUser = upsertUser(appDb, appUsername, appPassword, [\n    { role: \"readWrite\", db: appDatabase },\n  ]);\n}\n\nif (mode === \"reporting\" || mode === \"all\") {\n  result.reportingRole = ensureReportingRole();\n  result.reportingUser = upsertUser(appDb, reportingUsername, reportingPassword, [\n    { role: reportingRoleName, db: appDatabase },\n  ]);\n}\n\nprintjson(result);\nEOF\n"},"kind":"ConfigMap","metadata":{"