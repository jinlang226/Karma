t_secret_password() {\n  kubectl -n \"$NAMESPACE\" get secret \"$1\" -o jsonpath='{.data.password}' | base64 -d\n}\n\nrequire_bin kubectl\nrequire_bin base64\n\nADMIN_PASSWORD=\"${ADMIN_PASSWORD:-$(get_secret_password \"$ADMIN_SECRET_NAME\")}\"\nAPP_PASSWORD=\"${APP_PASSWORD:-$(get_secret_password \"$APP_SECRET_NAME\")}\"\nREPORTING_PASSWORD=\"${REPORTING_PASSWORD:-$(get_secret_password \"$REPORTING_SECRET_NAME\")}\"\n\nkubectl -n \"$NAMESPACE\" exec -i \"$POD_NAME\" -- env \\\n  MODE=\"$MODE\" \\\n  APP_DATABASE=\"$APP_DATABASE\" \\\n  APP_USERNAME=\"$APP_USERNAME\" \\\n  APP_PASSWORD=\"$APP_PASSWORD\" \\\n  REPORTING_USERNAME=\"$REPORTING_USERNAME\" \\\n  REPORTING_PASSWORD=\"$REPORTING_PASSWORD\" \\\n  REPORTING_ROLE_NAME=\"$REPORTING_ROLE_NAME\" \\\n  REPORTS_COLLECTION=\"$REPORTS_COLLECTION\" \\\n  mongosh \"mongodb://$SERVICE_NAME/admin?replicaSet=$REPLICA_SET_NAME\" \\\n    --username \"$ADMIN_USERNAME\" \\\n    --password \"$ADMIN_PASSWORD\" \\\n    --authenticationDatabase admin \\\n    --quiet /dev/stdin \u003c\u003c'EOF'\nconst mode = process.env.MODE;\nconst appDatabase = process.env.APP_DATABASE;\nconst appUsername = process.env.APP_USERNAME;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUsername = process.env.REPORTING_USERNAME;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRoleName = process.env.REPORTING_ROLE_NAME;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\n\nconst appDb = db.getSiblingDB(appDatabase);\n\nfunction ensureUser(user, password, roles) {\n  const existing = appDb.getUser(user);\n  if (existing) {\n    appDb.updateUser(user, { roles });\n    return \"updated\";\n  }\n\n  appDb.createUser({ user, pwd: password, roles });\n  return \"created\";\n}\n\nfunction ensureReportingRole() {\n  const privileges = [\n    {\n      resource: { db: appDatabase, collection: reportsCollection },\n      actions: [\"find\"],\n    },\n  ];\n\n  const existing = appDb.getRole(reportingRoleName, {\n