[agent] +
[agent] +kubectl -n "$NAMESPACE" exec -i "$POD" -- env \
[agent] +  MODE="$MODE" \
[agent] +  APP_DB="$APP_DB" \
[agent] +  APP_USER="$APP_USER" \
[agent] +  APP_PASS="$APP_PASS" \
[agent] +  REPORTING_USER="$REPORTING_USER" \
[agent] +  REPORTING_PASS="$REPORTING_PASS" \
[agent] +  REPORTING_ROLE="$REPORTING_ROLE" \
[agent] +  BAD_ROLE="$BAD_ROLE" \
