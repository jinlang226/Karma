[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/usr/bin/env bash\nset -euo pipefail\n\nNAMESPACE=\"${NAMESPACE:-wf-2026-05-21t00-27-57z-workflow-r-537ba50d-cluster-a}\"\nPOD=\"${POD:-mongodb-replica-0}\"\nADMIN_SECRET=\"${ADMIN_SECRET:-admin-user-password}\"\nAPP_SECRET=\"${APP_SECRET:-app-user-password}\"\nREPORTING_SECRET=\"${REPORTING_SECRET:-reporting-user-password}\"\nADMIN_USER=\"${ADMIN_USER:-admin-user}\"\nAPP_DB=\"${APP_DB:-appdb}\"\nAPP_USER=\"${APP_USER:-app-user}\"\nREPORTING_USER=\"${REPORTING_USER:-reporting-user}\"\nREPORTING_ROLE=\"${REPORTING_ROLE:-reportingRole}\"\nBAD_ROLE=\"${BAD_ROLE:-rawRead}\"\nREPORTS_COLLECTION=\"${REPORTS_COLLECTION:-reports}\"\n\nMODE=\"\"\n\nusage() {\n  cat \u003c\u003c'EOF'\nUsage: reset_rbac.sh --mode \u003call|app|reporting\u003e\nEOF\n}\n\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      if [ \"$#\" -lt 2 ]; then\n        usage \u003e\u00262\n        exit 1\n      fi\n      MODE=\"$2\"\n      shift 2\n      ;;\n    -h|--help)\n      usage\n      exit 0\n      ;;\n    *)\n      echo \"Unknown argument: $1\" \u003e\u00262\n      usage \u003e\u00262\n      exit 1\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting)\n    ;;\n  *)\n    echo \"--mode must be one of: all, app, reporting\" \u003e\u00262\n    usage \u003e\u00262\n    exit 1\n    ;;\nesac\n\nget_secret_field() {\n  kubectl -n \"$NAMESPACE\" get secret \"$1\" -o jsonpath=\"{.data.password}\" | base64 -d\n}\n\nADMIN_PASS=\"$(get_secret_field \"$ADMIN_SECRET\")\"\nAPP_PASS=\"$(get_secret_field \"$APP_SECRET\")\"\nREPORTING_PASS=\"$(get_secret_field \"$REPORTING_SECRET\")\"\n\nkubectl -n \"$NAMESPACE\" exec -i \"$POD\" -- env \\\n  MODE=\"$MODE\" \\\n  APP_DB=\"$APP_DB\" \\\n  APP_USER=\"$APP_USER\" \\\n  APP_PASS=\"$APP_PASS\" \\\n  REPORTING_USER=\"$REPORTING_USER\" \\\n  REPORTING_PASS=\"$REPORTING_PASS\" \\\n  REPORTING_ROLE=\"$REPORTING_ROLE\" \\\n  BAD_ROLE=\"$BAD_ROLE\" \\\n  REPORTS_COLLECTION=\"$REPORTS_COLLECTION\" \\\n  mongosh --quiet -u \"$ADMIN_USER\" -p \"$ADMIN_PASS\" --authenticationDatabase admin \u003c\u003c'MONGO'\nconst mode = process.env.MODE;\nconst appDbName = process.env.APP_DB;\nconst appUser = process.env.APP_USER;\nconst appPass = process.env.APP_PASS;\nconst reportingUser = process.env.REPORTING_USER;\nconst reportingPass = process.env.REPORTING_PASS;\nconst reportingRole = process.env.REPORTING_ROLE;\nconst badRole = process.env.BAD_ROLE;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\n\nconst appDb = db.getSiblingDB(appDbName);\n\nfunction ensureUser(userName, pwd, roles) {\n  const existing = appDb.getUser(userName);\n  if (existing) {\n    appDb.updateUser(userName, { pwd, roles });\n    return \"updated\";\n  }\n  appDb.createUser({ user: userName, pwd, roles });\n  return \"created\";\n}\n\nfunction ensureRole(roleName, privileges, roles) {\n  const existing = appDb.getRole(roleName, { showPrivileges: true });\n  if (existing) {\n    appDb.updateRole(roleName, { privileges, roles });\n    return \"updated\";\n  }\n  appDb.createRole({ role: roleName, privileges, roles });\n  return \"created\";\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  ensureUser(appUser, appPass, [{ role: \"readWrite\", db: appDbName }]);\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  ensureRole(\n    reportingRole,\n    [\n      {\n        resource: { db: appDbName, collection: reportsCollection },\n        actions: [\"find\"]\n      }\n    ],\n    []\n  );\n\n  ensureUser(reportingUser, reportingPass, [{ role: reportingRole, db: appDbName }]);\n\n  const refreshed = appDb.getUser(reportingUser);\n  const hasBadRole = refreshed \u0026\u0026 refreshed.roles.some(\n    (roleDoc) =\u003e roleDoc.role === badRole \u0026\u0026 roleDoc.db === appDbName\n  );\n  if (hasBadRole) {\n    throw new Error(`unexpected retained role ${badRole} on ${reportingUser}`);\n  }\n}\n\nprintjson({\n  ok: 1,\n  mode,\n  appUser: appDb.getUser(appUser),\n  reportingUser: appDb.getUser(reportingUser),\n  reportingRole: appDb.getRole(reportingRole, { showPrivileges: true })\n});\nMONGO\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-21t00-27-57z-workflow-r-537ba50d-cluster-a"}}
