[agent] +  mongosh --quiet -u "$ADMIN_USER" -p "$ADMIN_PASS" --authenticationDatabase admin --file /dev/stdin <<'MONGO'
[agent] +const mode = process.env.MODE;
[agent] +const appDbName = process.env.APP_DB;
[agent] +const appUser = process.env.APP_USER;
[agent] +const appPass = process.env.APP_PASS;
[agent] +const reportingUser = process.env.REPORTING_USER;
[agent] +const reportingPass = process.env.REPORTING_PASS;
[agent] +const reportingRole = process.env.REPORTING_ROLE;
[agent] +const badRole = process.env.BAD_ROLE;
[agent] +const reportsCollection = process.env.REPORTS_COLLECTION;
[agent] +
[agent] +const appDb = db.getSiblingDB(appDbName);
[agent] +
[agent] +function ensureUser(userName, pwd, roles) {
[agent] +  const existing = appDb.getUser(userName);
[agent] +  if (existing) {
[agent] +    appDb.updateUser(userName, { pwd, roles });
[agent] +    return "updated";
[agent] +  }
[agent] +  appDb.createUser({ user: userName, pwd, roles });
[agent] +  return "created";
[agent] +}
[agent] +
[agent] +function ensureRole(roleName, privileges, roles) {
[agent] +  const existing = appDb.getRole(roleName, { showPrivileges: true });
[agent] +  if (existing) {
[agent] +    appDb.updateRole(roleName, { privileges, roles });
[agent] +    return "updated";
[agent] +  }
[agent] +  appDb.createRole({ role: roleName, privileges, roles });
[agent] +  return "created";
[agent] +}
[agent] +
[agent] +if (mode === "all" || mode === "app") {
[agent] +  ensureUser(appUser, appPass, [{ role: "readWrite", db: appDbName }]);
[agent] +}
[agent] +
[agent] +if (mode === "all" || mode === "reporting") {
[agent] +  ensureRole(
[agent] +    reportingRole,
[agent] +    [
[agent] +      {
[agent] +        resource: { db: appDbName, collection: reportsCollection },
[agent] +        actions: ["find"]
[agent] +      }
[agent] +    ],
[agent] +    []
[agent] +  );
[agent] +
[agent] +  ensureUser(reportingUser, reportingPass, [{ role: reportingRole, db: appDbName }]);
[agent] +
[agent] +  const refreshed = appDb.getUser(reportingUser);
[agent] +  const hasBadRole = refreshed && refreshed.roles.some(
[agent] +    (roleDoc) => roleDoc.role === badRole && roleDoc.db === appDbName
[agent] +  );
[agent] +  if (hasBadRole) {
[agent] +    throw new Error(`unexpected retained role ${badRole} on ${reportingUser}`);
[agent] +  }
[agent] +}
[agent] +
[agent] +printjson({
[agent] +  ok: 1,
[agent] +  mode,
[agent] +  appUser: appDb.getUser(appUser),
[agent] +  reportingUser: appDb.getUser(reportingUser),
[agent] +  reportingRole: appDb.getRole(reportingRole, { showPrivileges: true })
[agent] +});
[agent] +MONGO
