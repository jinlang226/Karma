export APP_USER="$1"
export APP_PASSWORD="$2"
export REPORTING_USER="$3"
export REPORTING_PASSWORD="$4"
export APP_DB="$5"
export REPORTING_ROLE="$6"
export REPORTS_COLLECTION="$7"
export MODE="$8"
export MONGO_URI="$9"
export ADMIN_USER="${10}"
export ADMIN_PASSWORD="${11}"
cat > /tmp/reset_rbac.js <<'"'"'MONGO'"'"'
const mode = process.env.MODE;
const appUser = process.env.APP_USER;
const appPassword = process.env.APP_PASSWORD;
const reportingUser = process.env.REPORTING_USER;
const reportingPassword = process.env.REPORTING_PASSWORD;
const appDbName = process.env.APP_DB;
const reportingRole = process.env.REPORTING_ROLE;
const reportsCollection = process.env.REPORTS_COLLECTION;

const appDb = db.getSiblingDB(appDbName);

function ensureUser(targetDb, username, password, roles) {
  if (targetDb.getUser(username)) {
    targetDb.updateUser(username, {pwd: password, roles: roles});
  } else {
    targetDb.createUser({user: username, pwd: password, roles: roles});
  }
}

function ensureReportingRole() {
  const roleDoc = {
    privileges: [
      {
        resource: {db: appDbName, collection: reportsCollection},
        actions: [find]
      }
    ],
    roles: []
  };

  if (appDb.getRole(reportingRole, {showPrivileges: true})) {
    appDb.updateRole(reportingRole, roleDoc);
  } else {
    appDb.createRole({role: reportingRole, ...roleDoc});
  }
}

if (mode === app || mode === all) {
  ensureUser(appDb, appUser, appPassword, [{role: readWrite, db: appDbName}]);
}

if (mode === reporting || mode === all) {
  ensureReportingRole();
  ensureUser(appDb, reportingUser, reportingPassword, [{role: reportingRole, db: appDbName}]);
}

printjson({
  ok: 1,
  mode: mode,
  appUser: appDb.getUser(appUser),
  reportingUser: appDb.getUser(reportingUser),
  reportingRole: appDb.getRole(reportingRole, {showPrivileges: true})
});
MONGO
mongosh --quiet "$MONGO_URI" \
  --username "$ADMIN_USER" \
  --password "$ADMIN_PASSWORD" \
  --authenticationDatabase admin --file /tmp/reset_rbac.js
rc=$?
rm -f /tmp/reset_rbac.js
exit $rc
