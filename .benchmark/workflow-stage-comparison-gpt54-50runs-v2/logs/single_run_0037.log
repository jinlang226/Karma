      actions: ["find"],
    },
  ];
  const existingRole = appDb.getRole(reportingRole, { showPrivileges: true });
  if (existingRole) {
    appDb.updateRole(reportingRole, { privileges: desiredPrivileges, roles: [] });
  } else {
    appDb.createRole({ role: reportingRole, privileges: desiredPrivileges, roles: [] });
  }
}

if (mode === "all" || mode === "app") {
  ensureUser(appUser, appPassword, [{ role: "readWrite", db: appDbName }]);
}

if (mode === "all" || mode === "reporting") {
  ensureReportingRole();
  ensureUser(reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);
}

const result = {
