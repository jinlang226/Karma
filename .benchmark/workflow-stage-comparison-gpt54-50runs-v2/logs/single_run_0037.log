const reportsCollection = process.env.REPORTS_COLLECTION;

if (!["all", "app", "reporting"].includes(mode)) {
  throw new Error(`unsupported mode: ${mode}`);
}

const appDb = db.getSiblingDB(appDbName);

function ensureUser(userName, password, roles) {
  const user = appDb.getUser(userName);
  if (user) {
    appDb.updateUser(userName, { pwd: password, roles: roles });
  } else {
    appDb.createUser({ user: userName, pwd: password, roles: roles });
  }
}

