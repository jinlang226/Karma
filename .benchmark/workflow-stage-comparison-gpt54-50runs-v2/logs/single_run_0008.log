const appInput = JSON.parse(process.env.APP_INPUT);
const reportingInput = JSON.parse(process.env.REPORTING_INPUT);
const adminDb = db.getSiblingDB("admin");
const appDb = db.getSiblingDB(appInput.appDb);

function upsertUser(user, password, roles) {
  const existing = adminDb.getUser(user);
  if (existing) {
    adminDb.updateUser(user, { pwd: password, roles });
  } else {
    adminDb.createUser({ user, pwd: password, roles });
  }
}

if (appInput.mode === "all" || appInput.mode === "app") {
  upsertUser(
    appInput.appUser,
    appInput.appPassword,
    [{ role: "readWrite", db: appInput.appDb }]
  );
}

if (reportingInput.mode === "all" || reportingInput.mode === "reporting") {
  if (appDb.getRole(reportingInput.reportingRole, { showPrivileges: true }) === null) {
    appDb.createRole({
      role: reportingInput.reportingRole,
      privileges: [{
        resource: {
          db: reportingInput.appDb,
          collection: reportingInput.reportsCollection
        },
        actions: ["find"]
      }],
      roles: []
    });
  } else {
    appDb.updateRole(reportingInput.reportingRole, {
      privileges: [{
        resource: {
          db: reportingInput.appDb,
          collection: reportingInput.reportsCollection
        },
        actions: ["find"]
      }],
      roles: []
    });
  }

  upsertUser(
    reportingInput.reportingUser,
    reportingInput.reportingPassword,
    [{ role: reportingInput.reportingRole, db: reportingInput.appDb }]
  );
}
'
