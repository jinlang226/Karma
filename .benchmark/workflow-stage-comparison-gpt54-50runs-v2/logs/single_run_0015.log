[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/bin/sh\n\nset -eu\n\nNAMESPACE=\"wf-2026-05-20t07-00-00z-workflow-r-3ff3296a-cluster-a\"\nAPP_DB=\"appdb\"\nAPP_USER=\"app-user\"\nREPORTING_USER=\"reporting-user\"\nREPORTING_ROLE=\"reportingRole\"\nBAD_ROLE=\"rawRead\"\nAPP_SECRET=\"app-user-password\"\nREPORTING_SECRET=\"reporting-user-password\"\nADMIN_SECRET=\"admin-user-password\"\nADMIN_USER=\"admin-user\"\nSTATEFULSET=\"mongodb-replica\"\n\nusage() {\n  echo \"Usage: $0 --mode all|app|reporting\" \u003e\u00262\n  exit 1\n}\n\nMODE=\"\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      [ \"$#\" -ge 2 ] || usage\n      MODE=\"$2\"\n      shift 2\n      ;;\n    *)\n      usage\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting)\n    ;;\n  *)\n    usage\n    ;;\nesac\n\nget_secret() {\n  kubectl -n \"$NAMESPACE\" get secret \"$1\" -o jsonpath='{.data.password}' | base64 -d\n}\n\nfind_primary_pod() {\n  for pod in $(kubectl -n \"$NAMESPACE\" get pods -o name | sed 's#^pod/##' | grep \"^${STATEFULSET}-[0-9][0-9]*$\" | sort); do\n    if kubectl -n \"$NAMESPACE\" exec \"$pod\" -- mongosh --quiet -u \"$ADMIN_USER\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin --eval 'db.hello().isWritablePrimary' | grep -qx 'true'; then\n      echo \"$pod\"\n      return 0\n    fi\n  done\n\n  echo \"Unable to locate MongoDB primary pod in namespace $NAMESPACE\" \u003e\u00262\n  exit 1\n}\n\nADMIN_PASSWORD=\"$(get_secret \"$ADMIN_SECRET\")\"\nAPP_PASSWORD=\"$(get_secret \"$APP_SECRET\")\"\nREPORTING_PASSWORD=\"$(get_secret \"$REPORTING_SECRET\")\"\nPRIMARY_POD=\"$(find_primary_pod)\"\n\nexport MODE APP_DB APP_USER REPORTING_USER REPORTING_ROLE BAD_ROLE APP_PASSWORD REPORTING_PASSWORD\n\nkubectl -n \"$NAMESPACE\" exec \"$PRIMARY_POD\" -- env \\\n  MODE=\"$MODE\" \\\n  APP_DB=\"$APP_DB\" \\\n  APP_USER=\"$APP_USER\" \\\n  REPORTING_USER=\"$REPORTING_USER\" \\\n  REPORTING_ROLE=\"$REPORTING_ROLE\" \\\n  BAD_ROLE=\"$BAD_ROLE\" \\\n  APP_PASSWORD=\"$APP_PASSWORD\" \\\n  REPORTING_PASSWORD=\"$REPORTING_PASSWORD\" \\\n  mongosh --quiet -u \"$ADMIN_USER\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin \u003c\u003c'EOF'\nconst mode = process.env.MODE;\nconst appDbName = process.env.APP_DB;\nconst appUser = process.env.APP_USER;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUser = process.env.REPORTING_USER;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRole = process.env.REPORTING_ROLE;\n\nconst appDb = db.getSiblingDB(appDbName);\n\nfunction upsertUser(database, username, password, roles) {\n  const existing = database.getUser(username);\n  if (existing) {\n    database.updateUser(username, { pwd: password, roles });\n  } else {\n    database.createUser({ user: username, pwd: password, roles });\n  }\n}\n\nfunction ensureReportingRole() {\n  const privileges = [\n    {\n      resource: { db: appDbName, collection: \"reports\" },\n      actions: [\"find\"],\n    },\n  ];\n  const roles = [];\n\n  if (appDb.getRole(reportingRole)) {\n    appDb.updateRole(reportingRole, { privileges, roles });\n  } else {\n    appDb.createRole({ role: reportingRole, privileges, roles });\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  upsertUser(appDb, appUser, appPassword, [{ role: \"readWrite\", db: appDbName }]);\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  ensureReportingRole();\n  upsertUser(appDb, reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);\n}\n\nprintjson({\n  ok: 1,\n  mode,\n  appUserRoles: appDb.getUser(appUser)?.roles || null,\n  reportingUserRoles: appDb.getUser(reportingUser)?.roles || null,\n  reportingRole: appDb.getRole(reportingRole, { showPrivileges: true }) || null,\n});\nEOF\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-20t07-00-00z-workflow-r-3ff3296a-cluster-a"}}
