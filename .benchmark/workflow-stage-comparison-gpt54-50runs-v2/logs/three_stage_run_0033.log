ce: { db: \"appdb\", collection: \"reports\" },\n          actions: [\"find\"]\n        }\n      ],\n      roles: []\n    };\n\n    if (appdb.getRole(\"reportingRole\", { showPrivileges: true })) {\n      appdb.updateRole(\"reportingRole\", roleDoc);\n    } else {\n      appdb.createRole(Object.assign({ role: \"reportingRole\" }, roleDoc));\n    }\n\n    admin.updateUser(\"reporting-user\", {\n      roles: [{ role: \"reportingRole\", db: \"appdb\" }]\n    });\n  '\n}\n\ncase \"$MODE\" in\n  app)\n    reset_app\n    ;;\n  reporting)\n    reset_reporting\n    ;;\n  all)\n    reset_app\n    reset_reporting\n    ;;\nesac\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-21t01-57-29z-workflow-r-4746889f-cluster-a"}}
