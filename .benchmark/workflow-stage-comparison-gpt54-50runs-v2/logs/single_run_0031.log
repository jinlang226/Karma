[agent] +        REPORTING_PASSWORD="$reporting_password" \
[agent] +        mongosh "$mongo_uri" \
[agent] +          --quiet \
[agent] +          -u "$admin_user" \
[agent] +          -p "$admin_password" \
[agent] +          --authenticationDatabase admin \
[agent] +          --eval "$js"
[agent] +    }
[agent] +
[agent] +    reset_app() {
[agent] +      run_mongo_eval 'const appDb = db.getSiblingDB("appdb");
[agent] +      const roles = [{ role: "readWrite", db: "appdb" }];
[agent] +      if (appDb.getUser("app-user")) {
[agent] +        appDb.updateUser("app-user", { pwd: process.env.APP_PASSWORD, roles: roles });
[agent] +      } else {
[agent] +        appDb.createUser({ user: "app-user", pwd: process.env.APP_PASSWORD, roles: roles });
[agent] +      }'
[agent] +    }
[agent] +
[agent] +    reset_reporting() {
[agent] +      run_mongo_eval 'const appDb = db.getSiblingDB("appdb");
[agent] +      const privileges = [{ resource: { db: "appdb", collection: "reports" }, actions: ["find"] }];
[agent] +      if (appDb.getRole("reportingRole")) {
[agent] +        appDb.updateRole("reportingRole", { privileges: privileges, roles: [] });
[agent] +      } else {
[agent] +        appDb.createRole({ role: "reportingRole", privileges: privileges, roles: [] });
[agent] +      }
[agent] +      const roles = [{ role: "reportingRole", db: "appdb" }];
[agent] +      if (appDb.getUser("reporting-user")) {
[agent] +        appDb.updateUser("reporting-user", { pwd: process.env.REPORTING_PASSWORD, roles: roles });
[agent] +      } else {
[agent] +        appDb.createUser({ user: "reporting-user", pwd: process.env.REPORTING_PASSWORD, roles: roles });
[agent] +      }'
[agent] +    }
[agent] +
[agent] +    case "$mode" in
[agent] +      all)
[agent] +        reset_app
[agent] +        reset_reporting
[agent] +        ;;
[agent] +      app)
[agent] +        reset_app
[agent] +        ;;
[agent] +      reporting)
[agent] +        reset_reporting
[agent] +        ;;
[agent] +      *)
[agent] +        usage
[agent] +        ;;
[agent] +    esac
