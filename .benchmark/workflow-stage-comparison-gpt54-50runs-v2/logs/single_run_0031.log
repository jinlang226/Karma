[agent] +    app_user="app-user"
[agent] +    reporting_user="reporting-user"
[agent] +    reporting_role="reportingRole"
[agent] +    reports_collection="reports"
[agent] +
[agent] +    usage() {
[agent] +      echo "Usage: $0 --mode all|app|reporting" >&2
[agent] +      exit 1
[agent] +    }
[agent] +
[agent] +    mode=""
[agent] +    while [ "$#" -gt 0 ]; do
[agent] +      case "$1" in
[agent] +        --mode)
[agent] +          [ "$#" -ge 2 ] || usage
[agent] +          mode="$2"
[agent] +          shift 2
[agent] +          ;;
[agent] +        --help|-h)
[agent] +          usage
[agent] +          ;;
[agent] +        *)
[agent] +          usage
[agent] +          ;;
[agent] +      esac
[agent] +    done
[agent] +
[agent] +    [ -n "$mode" ] || usage
[agent] +
[agent] +    get_secret_password() {
[agent] +      kubectl -n "$namespace" get secret "$1" -o jsonpath='{.data.password}' | base64 -d
[agent] +    }
[agent] +
[agent] +    admin_password="$(get_secret_password "$admin_secret")"
[agent] +    app_password="$(get_secret_password "$app_secret")"
[agent] +    reporting_password="$(get_secret_password "$reporting_secret")"
[agent] +    mongo_uri="mongodb://${mongo_host}:27017/admin?replicaSet=${replica_set}"
[agent] +
[agent] +    run_mongo_eval() {
[agent] +      js="$1"
[agent] +      kubectl -n "$namespace" exec "$mongo_pod" -- env \
