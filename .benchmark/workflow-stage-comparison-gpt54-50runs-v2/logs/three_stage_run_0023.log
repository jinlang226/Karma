[agent] +        run_reporting_reset
[agent] +        ;;
[agent] +      all)
[agent] +        run_app_reset
[agent] +        run_reporting_reset
[agent] +        ;;
[agent] +    esac
[agent] +
[agent] +    run_mongo '
