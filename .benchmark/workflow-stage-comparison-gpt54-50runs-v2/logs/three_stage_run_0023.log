[agent] +    RAW_ROLE="rawRead"
[agent] +    REPORTS_COLLECTION="reports"
[agent] +
[agent] +    usage() {
[agent] +      echo "Usage: $0 --mode all|app|reporting" >&2
[agent] +      exit 1
[agent] +    }
[agent] +
[agent] +    MODE=""
[agent] +    while [ "$#" -gt 0 ]; do
[agent] +      case "$1" in
[agent] +        --mode)
[agent] +          [ "$#" -ge 2 ] || usage
[agent] +          MODE="$2"
[agent] +          shift 2
[agent] +          ;;
[agent] +        *)
[agent] +          usage
[agent] +          ;;
[agent] +      esac
[agent] +    done
[agent] +
[agent] +    case "$MODE" in
[agent] +      all|app|reporting)
[agent] +        ;;
[agent] +      *)
[agent] +        usage
[agent] +        ;;
[agent] +    esac
[agent] +
[agent] +    get_secret() {
