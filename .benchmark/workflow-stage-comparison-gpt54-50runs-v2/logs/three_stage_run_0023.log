[agent] +        } else {
[agent] +          adminDb.createUser({ user: "'"$APP_USERNAME"'", pwd: "'"$APP_PASSWORD"'", roles: roles });
[agent] +        }
[agent] +      '
[agent] +    }
[agent] +
