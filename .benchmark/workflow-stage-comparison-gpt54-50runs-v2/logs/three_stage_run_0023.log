[agent] +          shift 2
[agent] +          ;;
[agent] +        *)
[agent] +          usage
[agent] +          ;;
[agent] +      esac
[agent] +    done
[agent] +
[agent] +    case "$MODE" in
[agent] +      all|app|reporting)
[agent] +        ;;
[agent] +      *)
[agent] +        usage
[agent] +        ;;
[agent] +    esac
[agent] +
[agent] +    get_secret() {
[agent] +      kubectl -n "$NAMESPACE" get secret "$1" -o jsonpath='{.data.password}' | base64 -d
[agent] +    }
[agent] +
