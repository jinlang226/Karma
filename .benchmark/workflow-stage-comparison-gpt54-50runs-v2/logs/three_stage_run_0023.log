[agent] +    ADMIN_SECRET="admin-user-password"
[agent] +    APP_USERNAME="app-user"
[agent] +    APP_SECRET="app-user-password"
[agent] +    REPORTING_USERNAME="reporting-user"
[agent] +    REPORTING_SECRET="reporting-user-password"
