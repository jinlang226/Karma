pdateUser(\"'\"$APP_USERNAME\"'\", { roles: roles });\n    } else {\n      adminDb.createUser({ user: \"'\"$APP_USERNAME\"'\", pwd: \"'\"$APP_PASSWORD\"'\", roles: roles });\n    }\n  '\n}\n\nrun_reporting_reset() {\n  run_mongo '\n    const adminDb = db.getSiblingDB(\"admin\");\n    const appDb = db.getSiblingDB(\"'\"$APP_DB\"'\");\n    const roleDoc = {\n      privileges: [\n        {\n          resource: { db: \"'\"$APP_DB\"'\", collection: \"'\"$REPORTS_COLLECTION\"'\" },\n          actions: [\"find\"]\n        }\n      ],\n      roles: []\n    };\n    if (appDb.getRole(\"'\"$REPORTING_ROLE\"'\")) {\n      appDb.updateRole(\"'\"$REPORTING_ROLE\"'\", roleDoc);\n    } else {\n      appDb.createRole(Object.assign({ role: \"'\"$REPORTING_ROLE\"'\" }, roleDoc));\n    }\n    const existing = adminDb.getUser(\"'\"$REPORTING_USERNAME\"'\");\n    const roles = [{ role: \"'\"$REPORTING_ROLE\"'\", db: \"'\"$APP_DB\"'\" }];\n    if (existing) {\n      adminDb.updateUser(\"'\"$REPORTING_USERNAME\"'\", { roles: roles });\n    } else {\n      adminDb.createUser({ user: \"'\"$REPORTING_USERNAME\"'\", pwd: \"'\"$REPORTING_PASSWORD\"'\", roles: roles });\n    }\n  '\n}\n\ncase \"$MODE\" in\n  app)\n    run_app_reset\n    ;;\n  reporting)\n    run_reporting_reset\n    ;;\n  all)\n    run_app_reset\n    run_reporting_reset\n    ;;\nesac\n\nrun_mongo '\n  const adminDb = db.getSiblingDB(\"admin\");\n  const appDb = db.getSiblingDB(\"'\"$APP_DB\"'\");\n  printjson({\n    appUser: adminDb.getUser(\"'\"$APP_USERNAME\"'\"),\n    reportingUser: adminDb.getUser(\"'\"$REPORTING_USERNAME\"'\"),\n    reportingRole: appDb.getRole(\"'\"$REPORTING_ROLE\"'\", { showPrivileges: true }),\n    rawReadRole: appDb.getRole(\"'\"$RAW_ROLE\"'\", { showPrivileges: true })\n  });\n'\n"},"kind":"ConfigMap","metadata":{"annotations":{},"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-20t21-36-56z-workflow-r-47a1fe52-cluster-a"}}
