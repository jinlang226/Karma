[agent] +        run_reporting_reset
[agent] +        ;;
[agent] +      all)
[agent] +        run_app_reset
[agent] +        run_reporting_reset
[agent] +        ;;
[agent] +    esac
[agent] +
[agent] +    run_mongo '
[agent] +      const adminDb = db.getSiblingDB("admin");
[agent] +      const appDb = db.getSiblingDB("'"$APP_DB"'");
[agent] +      printjson({
[agent] +        appUser: adminDb.getUser("'"$APP_USERNAME"'"),
[agent] +        reportingUser: adminDb.getUser("'"$REPORTING_USERNAME"'"),
[agent] +        reportingRole: appDb.getRole("'"$REPORTING_ROLE"'", { showPrivileges: true }),
[agent] +        rawReadRole: appDb.getRole("'"$RAW_ROLE"'", { showPrivileges: true })
[agent] +      });
