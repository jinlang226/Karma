[agent] +        const roles = [{ role: "'"$REPORTING_ROLE"'", db: "'"$APP_DB"'" }];
[agent] +        if (existing) {
[agent] +          adminDb.updateUser("'"$REPORTING_USERNAME"'", { roles: roles });
[agent] +        } else {
[agent] +          adminDb.createUser({ user: "'"$REPORTING_USERNAME"'", pwd: "'"$REPORTING_PASSWORD"'", roles: roles });
[agent] +        }
[agent] +      '
[agent] +    }
[agent] +
[agent] +    case "$MODE" in
