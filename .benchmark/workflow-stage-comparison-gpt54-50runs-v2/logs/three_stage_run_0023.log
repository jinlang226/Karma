[agent] +    }
[agent] +
[agent] +    ADMIN_PASSWORD="$(get_secret "$ADMIN_SECRET")"
[agent] +    APP_PASSWORD="$(get_secret "$APP_SECRET" 2>/dev/null || true)"
[agent] +    REPORTING_PASSWORD="$(get_secret "$REPORTING_SECRET" 2>/dev/null || true)"
[agent] +
[agent] +    MONGO_URI="mongodb://mongodb-replica-0.mongodb-replica-svc,mongodb-replica-1.mongodb-replica-svc,mongodb-replica-2.mongodb-replica-svc/admin?replicaSet=${REPLICA_SET}"
[agent] +
