[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/bin/sh\nset -eu\n\nNAMESPACE=\"wf-2026-05-20t05-45-20z-workflow-r-353b673e-cluster-a\"\nAPP_LABEL=\"mongodb-replica\"\nADMIN_POD_PREFIX=\"mongodb-replica\"\nADMIN_SECRET_NAME=\"admin-user-password\"\nAPP_SECRET_NAME=\"app-user-password\"\nREPORTING_SECRET_NAME=\"reporting-user-password\"\nADMIN_USERNAME=\"admin-user\"\nAPP_USERNAME=\"app-user\"\nREPORTING_USERNAME=\"reporting-user\"\nAPP_DATABASE=\"appdb\"\nREPORTING_ROLE_NAME=\"reportingRole\"\nBAD_ROLE_NAME=\"rawRead\"\nREPORTS_COLLECTION=\"reports\"\nKUBECTL_BIN=\"${KUBECTL_BIN:-kubectl}\"\n\nusage() {\n  cat \u003c\u003c'EOF'\nUsage: reset_rbac.sh --mode all|app|reporting\nEOF\n}\n\nMODE=\"\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      if [ \"$#\" -lt 2 ]; then\n        usage \u003e\u00262\n        exit 1\n      fi\n      MODE=\"$2\"\n      shift 2\n      ;;\n    -h|--help)\n      usage\n      exit 0\n      ;;\n    *)\n      echo \"unknown argument: $1\" \u003e\u00262\n      usage \u003e\u00262\n      exit 1\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting)\n    ;;\n  *)\n    usage \u003e\u00262\n    exit 1\n    ;;\nesac\n\nget_secret_password() {\n  secret_name=\"$1\"\n  \"$KUBECTL_BIN\" -n \"$NAMESPACE\" get secret \"$secret_name\" -o jsonpath='{.data.password}' | base64 -d\n}\n\nfind_primary_pod() {\n  pods=$(\"$KUBECTL_BIN\" -n \"$NAMESPACE\" get pods -l \"app=$APP_LABEL\" -o jsonpath='{range .items[*]}{.metadata.name}{\"\\n\"}{end}' | sort)\n  admin_password=\"$1\"\n\n  for pod in $pods; do\n    if \"$KUBECTL_BIN\" -n \"$NAMESPACE\" exec \"$pod\" -- \\\n      mongosh --quiet -u \"$ADMIN_USERNAME\" -p \"$admin_password\" --authenticationDatabase admin \\\n      --eval 'db.hello().isWritablePrimary' 2\u003e/dev/null | grep -qx 'true'; then\n      printf '%s\\n' \"$pod\"\n      return 0\n    fi\n  done\n\n  return 1\n}\n\nADMIN_PASSWORD=\"$(get_secret_password \"$ADMIN_SECRET_NAME\")\"\nAPP_PASSWORD=\"$(get_secret_password \"$APP_SECRET_NAME\")\"\nREPORTING_PASSWORD=\"$(get_secret_password \"$REPORTING_SECRET_NAME\")\"\nPRIMARY_POD=\"$(find_primary_pod \"$ADMIN_PASSWORD\")\"\n\nif [ -z \"$PRIMARY_POD\" ]; then\n  echo \"unable to find writable primary pod in namespace $NAMESPACE\" \u003e\u00262\n  exit 1\nfi\n\nAPP_PASSWORD_B64=\"$(printf '%s' \"$APP_PASSWORD\" | base64 | tr -d '\\n')\"\nREPORTING_PASSWORD_B64=\"$(printf '%s' \"$REPORTING_PASSWORD\" | base64 | tr -d '\\n')\"\n\n\"$KUBECTL_BIN\" -n \"$NAMESPACE\" exec -i \"$PRIMARY_POD\" -- env \\\n  MODE=\"$MODE\" \\\n  APP_PASSWORD_B64=\"$APP_PASSWORD_B64\" \\\n  REPORTING_PASSWORD_B64=\"$REPORTING_PASSWORD_B64\" \\\n  APP_DATABASE=\"$APP_DATABASE\" \\\n  APP_USERNAME=\"$APP_USERNAME\" \\\n  REPORTING_USERNAME=\"$REPORTING_USERNAME\" \\\n  REPORTING_ROLE_NAME=\"$REPORTING_ROLE_NAME\" \\\n  BAD_ROLE_NAME=\"$BAD_ROLE_NAME\" \\\n  REPORTS_COLLECTION=\"$REPORTS_COLLECTION\" \\\n  mongosh --quiet -u \"$ADMIN_USERNAME\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin --file /dev/stdin \u003c\u003c'EOF'\nconst mode = process.env.MODE;\nconst appDbName = process.env.APP_DATABASE;\nconst appUsername = process.env.APP_USERNAME;\nconst reportingUsername = process.env.REPORTING_USERNAME;\nconst reportingRoleName = process.env.REPORTING_ROLE_NAME;\nconst badRoleName = process.env.BAD_ROLE_NAME;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\nconst appPassword = Buffer.from(process.env.APP_PASSWORD_B64, \"base64\").toString(\"utf8\");\nconst reportingPassword = Buffer.from(process.env.REPORTING_PASSWORD_B64, \"base64\").toString(\"utf8\");\n\nconst appDb = db.getSiblingDB(appDbName);\n\nfunction ensureUser(targetDb, username, password, roles) {\n  if (targetDb.getUser(username)) {\n    targetDb.updateUser(username, { roles });\n  } else {\n    targetDb.createUser({ user: username, pwd: password, roles });\n  }\n}\n\nfunction ensureRole(targetDb, roleName, privileges, inheritedRoles) {\n  if (targetDb.getRole(roleName)) {\n    targetDb.updateRole(roleName, { privileges, roles: inheritedRoles });\n  } else {\n    targetDb.createRole({ role: roleName, privileges, roles: inheritedRoles });\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  ensureUser(appDb, appUsername, appPassword, [{ role: \"readWrite\", db: appDbName }]);\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  ensureRole(\n    appDb,\n    reportingRoleName,\n    [{ resource: { db: appDbName, collection: reportsCollection }, actions: [\"find\"] }],\n    []\n  );\n  ensureUser(appDb, reportingUsername, reportingPassword, [{ role: reportingRoleName, db: appDbName }]);\n}\n\nprint(EJSON.stringify({\n  ok: 1,\n  mode,\n  appUser: appDb.getUser(appUsername),\n  reportingUser: appDb.getUser(reportingUsername),\n  reportingRole: appDb.getRole(reportingRoleName, { showPrivileges: true }),\n  rawReadRolePresent: !!appDb.getRole(badRoleName)\n}));\nEOF\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-20t05-45-20z-workflow-r-353b673e-cluster-a"}}
