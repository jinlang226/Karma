const appPassword = Buffer.from("YXBwMTIzcGFzc3dvcmQ=", "base64").toString("utf8");
const reportingPassword = Buffer.from("cmVwb3J0aW5nMTIzcGFzc3dvcmQ=", "base64").toString("utf8");

function ensureRole() {
  const privileges = [
    {
      resource: { db: "appdb", collection: "reports" },
      actions: ["find"]
    }
  ];

  if (appDb.getRole("reportingRole", { showPrivileges: true })) {
    appDb.updateRole("reportingRole", { privileges, roles: [] });
  } else {
    appDb.createRole({ role: "reportingRole", privileges, roles: [] });
  }
}

function ensureUser(user, password, roles) {
  if (appDb.getUser(user)) {
    appDb.updateUser(user, { pwd: password, roles });
  } else {
    appDb.createUser({ user, pwd: password, roles });
  }
}

if (mode === "app" || mode === "all") {
  ensureUser("app-user", appPassword, [{ role: "readWrite", db: "appdb" }]);
}

if (mode === "reporting" || mode === "all") {
  ensureRole();
  ensureUser("reporting-user", reportingPassword, [{ role: "reportingRole", db: "appdb" }]);
}

printjson({
  mode,
  appUser: appDb.getUser("app-user"),
  reportingUser: appDb.getUser("reporting-user"),
  reportingRole: appDb.getRole("reportingRole", { showPrivileges: true })
});'
