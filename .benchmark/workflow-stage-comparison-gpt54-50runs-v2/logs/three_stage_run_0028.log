owPrivileges: true });\n    const privileges = [{\n      resource: { db: '$APP_DATABASE', collection: '$REPORTS_COLLECTION' },\n      actions: ['find']\n    }];\n\n    if (reportingRole) {\n      appDb.updateRole('$REPORTING_ROLE_NAME', {\n        privileges: privileges,\n        roles: []\n      });\n    } else {\n      appDb.createRole({\n        role: '$REPORTING_ROLE_NAME',\n        privileges: privileges,\n        roles: []\n      });\n    }\n\n    adminDb.updateUser('$REPORTING_USERNAME', {\n      roles: [{ role: '$REPORTING_ROLE_NAME', db: '$APP_DATABASE' }]\n    });\n\n    if (appDb.getRole('$RAW_ROLE_NAME')) {\n      appDb.dropRole('$RAW_ROLE_NAME');\n    }\n  \"\n}\n\ncase \"$MODE\" in\n  app)\n    reset_app\n    ;;\n  reporting)\n    reset_reporting\n    ;;\n  all)\n    reset_app\n    reset_reporting\n    ;;\nesac\n\necho \"RBAC reset completed for mode: $MODE\"\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-21t01-21-37z-workflow-r-6f228065-cluster-a"}}
