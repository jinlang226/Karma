[agent] +#!/bin/sh
[agent] +set -eu
[agent] +
[agent] +NAMESPACE="${NAMESPACE:-wf-2026-05-21t01-21-37z-workflow-r-6f228065-cluster-a}"
[agent] +POD_NAME="${POD_NAME:-mongodb-replica-0}"
[agent] +ADMIN_USERNAME="${ADMIN_USERNAME:-admin-user}"
[agent] +ADMIN_SECRET_NAME="${ADMIN_SECRET_NAME:-admin-user-password}"
[agent] +APP_DATABASE="${APP_DATABASE:-appdb}"
[agent] +APP_USERNAME="${APP_USERNAME:-app-user}"
[agent] +REPORTING_USERNAME="${REPORTING_USERNAME:-reporting-user}"
[agent] +REPORTING_ROLE_NAME="${REPORTING_ROLE_NAME:-reportingRole}"
[agent] +RAW_ROLE_NAME="${RAW_ROLE_NAME:-rawRead}"
[agent] +REPORTS_COLLECTION="${REPORTS_COLLECTION:-reports}"
[agent] +
[agent] +usage() {
[agent] +  echo "Usage: $0 --mode all|app|reporting" >&2
[agent] +  exit 2
[agent] +}
[agent] +
[agent] +MODE=""
[agent] +while [ "$#" -gt 0 ]; do
[agent] +  case "$1" in
[agent] +    --mode)
[agent] +      [ "$#" -ge 2 ] || usage
[agent] +      MODE="$2"
[agent] +      shift 2
[agent] +      ;;
[agent] +    *)
[agent] +      usage
[agent] +      ;;
[agent] +  esac
[agent] +done
[agent] +
[agent] +case "$MODE" in
[agent] +  all|app|reporting) ;;
[agent] +  *) usage ;;
[agent] +esac
[agent] +
[agent] +ADMIN_PASSWORD="$(kubectl -n "$NAMESPACE" get secret "$ADMIN_SECRET_NAME" -o jsonpath='{.data.password}' | base64 -d)"
[agent] +
[agent] +run_mongo() {
[agent] +  kubectl -n "$NAMESPACE" exec "$POD_NAME" -- \
[agent] +    mongosh -u "$ADMIN_USERNAME" -p "$ADMIN_PASSWORD" --authenticationDatabase admin --quiet --eval "$1"
[agent] +}
[agent] +
[agent] +reset_app() {
[agent] +  run_mongo "
[agent] +    const adminDb = db.getSiblingDB('admin');
[agent] +    const user = adminDb.getUser('$APP_USERNAME');
[agent] +    if (!user) {
[agent] +      throw new Error('missing user: $APP_USERNAME');
[agent] +    }
[agent] +    adminDb.updateUser('$APP_USERNAME', {
[agent] +      roles: [{ role: 'readWrite', db: '$APP_DATABASE' }]
[agent] +    });
[agent] +  "
[agent] +}
[agent] +
[agent] +reset_reporting() {
[agent] +  run_mongo "
[agent] +    const adminDb = db.getSiblingDB('admin');
[agent] +    const appDb = db.getSiblingDB('$APP_DATABASE');
[agent] +
[agent] +    const reportingUser = adminDb.getUser('$REPORTING_USERNAME');
[agent] +    if (!reportingUser) {
[agent] +      throw new Error('missing user: $REPORTING_USERNAME');
[agent] +    }
[agent] +
[agent] +    const reportingRole = appDb.getRole('$REPORTING_ROLE_NAME', { showPrivileges: true });
[agent] +    const privileges = [{
[agent] +      resource: { db: '$APP_DATABASE', collection: '$REPORTS_COLLECTION' },
[agent] +      actions: ['find']
[agent] +    }];
[agent] +
[agent] +    if (reportingRole) {
[agent] +      appDb.updateRole('$REPORTING_ROLE_NAME', {
[agent] +        privileges: privileges,
[agent] +        roles: []
[agent] +      });
[agent] +    } else {
[agent] +      appDb.createRole({
[agent] +        role: '$REPORTING_ROLE_NAME',
[agent] +        privileges: privileges,
[agent] +        roles: []
[agent] +      });
[agent] +    }
[agent] +
[agent] +    adminDb.updateUser('$REPORTING_USERNAME', {
[agent] +      roles: [{ role: '$REPORTING_ROLE_NAME', db: '$APP_DATABASE' }]
[agent] +    });
[agent] +
[agent] +    if (appDb.getRole('$RAW_ROLE_NAME')) {
[agent] +      appDb.dropRole('$RAW_ROLE_NAME');
[agent] +    }
[agent] +  "
[agent] +}
[agent] +
[agent] +case "$MODE" in
[agent] +  app)
[agent] +    reset_app
[agent] +    ;;
