[agent] +const mode = process.env.RESET_MODE;
[agent] +const adminDb = db.getSiblingDB("admin");
[agent] +const appDb = db.getSiblingDB(process.env.APP_DATABASE);
[agent] +
[agent] +function syncUser(userDb, username, password, roles) {
[agent] +  const existing = userDb.getUser(username);
[agent] +  if (existing) {
[agent] +    userDb.updateUser(username, { pwd: password, roles: roles });
[agent] +  } else {
[agent] +    userDb.createUser({ user: username, pwd: password, roles: roles });
[agent] +  }
[agent] +}
[agent] +
[agent] +function syncReportingRole() {
[agent] +  const roleName = process.env.REPORTING_ROLE_NAME;
[agent] +  const privileges = [
[agent] +    {
[agent] +      resource: { db: process.env.APP_DATABASE, collection: process.env.REPORTS_COLLECTION },
[agent] +      actions: ["find"],
[agent] +    },
[agent] +  ];
[agent] +  const existing = appDb.getRole(roleName, { showPrivileges: true });
[agent] +  if (existing) {
[agent] +    appDb.updateRole(roleName, { privileges: privileges, roles: [] });
[agent] +  } else {
[agent] +    appDb.createRole({ role: roleName, privileges: privileges, roles: [] });
[agent] +  }
[agent] +}
[agent] +
[agent] +if (mode === "all" || mode === "app") {
[agent] +  syncUser(
[agent] +    adminDb,
[agent] +    process.env.APP_USERNAME,
[agent] +    process.env.APP_PASSWORD,
[agent] +    [{ role: "readWrite", db: process.env.APP_DATABASE }],
[agent] +  );
[agent] +}
[agent] +
[agent] +if (mode === "all" || mode === "reporting") {
[agent] +  syncReportingRole();
[agent] +  syncUser(
[agent] +    adminDb,
[agent] +    process.env.REPORTING_USERNAME,
[agent] +    process.env.REPORTING_PASSWORD,
[agent] +    [{ role: process.env.REPORTING_ROLE_NAME, db: process.env.APP_DATABASE }],
[agent] +  );
[agent] +}
[agent] +
[agent] +printjson({
[agent] +  ok: 1,
[agent] +  mode: mode,
[agent] +  users: adminDb.getUsers().users.map((user) => ({
[agent] +    user: user.user,
[agent] +    db: user.db,
[agent] +    roles: user.roles,
[agent] +  })),
[agent] +  reportingRole: appDb.getRole(process.env.REPORTING_ROLE_NAME, { showPrivileges: true }),
[agent] +});
