[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/usr/bin/env bash\nset -euo pipefail\n\nNAMESPACE=\"wf-2026-05-20t05-14-29z-workflow-r-d9d9ff20-cluster-a\"\nSTATEFULSET_NAME=\"mongodb-replica\"\nADMIN_SECRET_NAME=\"admin-user-password\"\nAPP_SECRET_NAME=\"app-user-password\"\nREPORTING_SECRET_NAME=\"reporting-user-password\"\nADMIN_USERNAME=\"admin-user\"\nAPP_USERNAME=\"app-user\"\nREPORTING_USERNAME=\"reporting-user\"\nAPP_DATABASE=\"appdb\"\nREPORTING_ROLE_NAME=\"reportingRole\"\nDEPRECATED_ROLE_NAME=\"rawRead\"\nREPORTS_COLLECTION=\"reports\"\nEXPECTED_REPLICAS=3\n\nusage() {\n  cat \u003c\u003c'EOF'\nUsage: reset_rbac.sh --mode all|app|reporting\nEOF\n}\n\nMODE=\"\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      if [ \"$#\" -lt 2 ]; then\n        usage\n        exit 1\n      fi\n      MODE=\"$2\"\n      shift 2\n      ;;\n    -h|--help)\n      usage\n      exit 0\n      ;;\n    *)\n      echo \"unknown argument: $1\" \u003e\u00262\n      usage\n      exit 1\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting)\n    ;;\n  *)\n    echo \"invalid or missing --mode: expected all, app, or reporting\" \u003e\u00262\n    usage\n    exit 1\n    ;;\nesac\n\nget_secret_value() {\n  local secret_name=\"$1\"\n  kubectl -n \"$NAMESPACE\" get secret \"$secret_name\" -o jsonpath='{.data.password}' | base64 -d\n}\n\nfind_primary_pod() {\n  local ordinal\n  for ordinal in $(seq 0 $((EXPECTED_REPLICAS - 1))); do\n    local pod_name=\"${STATEFULSET_NAME}-${ordinal}\"\n    if kubectl -n \"$NAMESPACE\" exec \"$pod_name\" -- mongosh --quiet --eval 'quit(db.hello().isWritablePrimary ? 0 : 1)' \u003e/dev/null 2\u003e\u00261; then\n      printf '%s\\n' \"$pod_name\"\n      return 0\n    fi\n  done\n\n  echo \"could not find writable primary pod in namespace $NAMESPACE\" \u003e\u00262\n  return 1\n}\n\nADMIN_PASSWORD=\"$(get_secret_value \"$ADMIN_SECRET_NAME\")\"\nAPP_PASSWORD=\"$(get_secret_value \"$APP_SECRET_NAME\")\"\nREPORTING_PASSWORD=\"$(get_secret_value \"$REPORTING_SECRET_NAME\")\"\nPRIMARY_POD=\"$(find_primary_pod)\"\n\nkubectl -n \"$NAMESPACE\" exec -i \"$PRIMARY_POD\" -- env \\\n  RESET_MODE=\"$MODE\" \\\n  ADMIN_USERNAME=\"$ADMIN_USERNAME\" \\\n  ADMIN_PASSWORD=\"$ADMIN_PASSWORD\" \\\n  APP_USERNAME=\"$APP_USERNAME\" \\\n  APP_PASSWORD=\"$APP_PASSWORD\" \\\n  REPORTING_USERNAME=\"$REPORTING_USERNAME\" \\\n  REPORTING_PASSWORD=\"$REPORTING_PASSWORD\" \\\n  APP_DATABASE=\"$APP_DATABASE\" \\\n  REPORTING_ROLE_NAME=\"$REPORTING_ROLE_NAME\" \\\n  DEPRECATED_ROLE_NAME=\"$DEPRECATED_ROLE_NAME\" \\\n  REPORTS_COLLECTION=\"$REPORTS_COLLECTION\" \\\n  mongosh --quiet -u \"$ADMIN_USERNAME\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin --file /dev/stdin \u003c\u003c'MONGO'\nconst mode = process.env.RESET_MODE;\nconst adminDb = db.getSiblingDB(\"admin\");\nconst appDb = db.getSiblingDB(process.env.APP_DATABASE);\n\nfunction syncUser(userDb, username, password, roles) {\n  const existing = userDb.getUser(username);\n  if (existing) {\n    userDb.updateUser(username, { pwd: password, roles: roles });\n  } else {\n    userDb.createUser({ user: username, pwd: password, roles: roles });\n  }\n}\n\nfunction syncReportingRole() {\n  const roleName = process.env.REPORTING_ROLE_NAME;\n  const privileges = [\n    {\n      resource: { db: process.env.APP_DATABASE, collection: process.env.REPORTS_COLLECTION },\n      actions: [\"find\"],\n    },\n  ];\n  const existing = appDb.getRole(roleName, { showPrivileges: true });\n  if (existing) {\n    appDb.updateRole(roleName, { privileges: privileges, roles: [] });\n  } else {\n    appDb.createRole({ role: roleName, privileges: privileges, roles: [] });\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  syncUser(\n    adminDb,\n    process.env.APP_USERNAME,\n    process.env.APP_PASSWORD,\n    [{ role: \"readWrite\", db: process.env.APP_DATABASE }],\n  );\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  syncReportingRole();\n  syncUser(\n    adminDb,\n    process.env.REPORTING_USERNAME,\n    process.env.REPORTING_PASSWORD,\n    [{ role: process.env.REPORTING_ROLE_NAME, db: process.env.APP_DATABASE }],\n  );\n}\n\nprintjson({\n  ok: 1,\n  mode: mode,\n  users: adminDb.getUsers().users.map((user) =\u003e ({\n    user: user.user,\n    db: user.db,\n    roles: user.roles,\n  })),\n  reportingRole: appDb.getRole(process.env.REPORTING_ROLE_NAME, { showPrivileges: true }),\n});\nMONGO\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-20t05-14-29z-workflow-r-d9d9ff20-cluster-a"}}
