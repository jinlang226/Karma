[agent] +        } else {
[agent] +          appDb.createRole({
[agent] +            role: "'"$REPORTING_ROLE"'",
[agent] +            privileges: rolePrivileges,
[agent] +            roles: []
[agent] +          });
[agent] +          print("created role '"$REPORTING_ROLE"'");
[agent] +        }
[agent] +
[agent] +        const existingUser = adminDb.getUser("'"$REPORTING_USER"'");
