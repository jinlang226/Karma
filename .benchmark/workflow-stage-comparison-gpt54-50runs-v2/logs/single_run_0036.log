[agent] +          usage
[agent] +          ;;
[agent] +      esac
[agent] +    done
[agent] +
[agent] +    case "$MODE" in
[agent] +      all|app|reporting)
[agent] +        ;;
[agent] +      *)
[agent] +        usage
[agent] +        ;;
[agent] +    esac
[agent] +
[agent] +    get_secret_password() {
[agent] +      kubectl -n "$NAMESPACE" get secret "$1" -o jsonpath='{.data.password}' | base64 -d
[agent] +    }
[agent] +
[agent] +    ADMIN_PASSWORD="$(get_secret_password "$ADMIN_SECRET")"
[agent] +    APP_PASSWORD="$(get_secret_password "$APP_SECRET")"
[agent] +    REPORTING_PASSWORD="$(get_secret_password "$REPORTING_SECRET")"
