  appDb.createRole({ role: roleName, privileges: desiredPrivileges, roles: [] });
}
if (appDb.getUser(userName)) {
  appDb.updateUser(userName, { roles: desiredRoles });
} else {
  appDb.createUser({ user: userName, pwd: password, roles: desiredRoles });
}
