const mode = process.env.MODE;
const appDbName = process.env.APP_DATABASE;
const appUser = process.env.APP_USERNAME;
const appPassword = process.env.APP_PASSWORD;
const reportingUser = process.env.REPORTING_USERNAME;
const reportingPassword = process.env.REPORTING_PASSWORD;
const reportingRoleName = process.env.REPORTING_ROLE_NAME;
const reportsCollection = process.env.REPORTS_COLLECTION;

function ensureUser(db, username, password, roles) {
  const existing = db.getUser(username);
  if (existing) {
    db.updateUser(username, { pwd: password, roles });
  } else {
    db.createUser({ user: username, pwd: password, roles });
  }
}

function ensureReportingRole(db) {
  const privilege = {
    resource: { db: appDbName, collection: reportsCollection },
    actions: ["find"],
  };
  const existing = db.getRole(reportingRoleName, { showPrivileges: true });
  if (existing) {
    db.updateRole(reportingRoleName, { privileges: [privilege], roles: [] });
  } else {
    db.createRole({ role: reportingRoleName, privileges: [privilege], roles: [] });
  }
}

const appDb = db.getSiblingDB(appDbName);

if (mode === "all" || mode === "app") {
  ensureUser(appDb, appUser, appPassword, [{ role: "readWrite", db: appDbName }]);
}

if (mode === "all" || mode === "reporting") {
  ensureReportingRole(appDb);
  ensureUser(appDb, reportingUser, reportingPassword, [{ role: reportingRoleName, db: appDbName }]);
}

printjson({
  ok: 1,
  mode,
  appUserRoles: (appDb.getUser(appUser) || {}).roles || null,
  reportingUserRoles: (appDb.getUser(reportingUser) || {}).roles || null,
  reportingRole: appDb.getRole(reportingRoleName, { showPrivileges: true }),
});
EOF'
