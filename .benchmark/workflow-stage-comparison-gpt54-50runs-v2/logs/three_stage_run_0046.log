[agent] +#!/bin/sh
[agent] +set -eu
[agent] +
[agent] +NAMESPACE="${NAMESPACE:-wf-2026-05-21t07-42-09z-workflow-r-16388f59-cluster-a}"
[agent] +POD="${POD:-mongodb-replica-0}"
[agent] +ADMIN_USER="${ADMIN_USER:-admin-user}"
[agent] +ADMIN_SECRET="${ADMIN_SECRET:-admin-user-password}"
[agent] +APP_DB="${APP_DB:-appdb}"
[agent] +APP_USER="${APP_USER:-app-user}"
[agent] +REPORTING_USER="${REPORTING_USER:-reporting-user}"
[agent] +REPORTING_ROLE="${REPORTING_ROLE:-reportingRole}"
[agent] +BAD_ROLE="${BAD_ROLE:-rawRead}"
[agent] +REPORTS_COLLECTION="${REPORTS_COLLECTION:-reports}"
[agent] +MODE=""
[agent] +
[agent] +usage() {
[agent] +  echo "Usage: $0 --mode all|app|reporting" >&2
[agent] +  exit 1
[agent] +}
[agent] +
[agent] +while [ "$#" -gt 0 ]; do
[agent] +  case "$1" in
[agent] +    --mode)
[agent] +      [ "$#" -ge 2 ] || usage
[agent] +      MODE="$2"
[agent] +      shift 2
[agent] +      ;;
[agent] +    *)
[agent] +      usage
[agent] +      ;;
[agent] +  esac
[agent] +done
[agent] +
[agent] +case "$MODE" in
[agent] +  all|app|reporting)
[agent] +    ;;
[agent] +  *)
[agent] +    usage
[agent] +    ;;
[agent] +esac
[agent] +
[agent] +ADMIN_PASSWORD="$(kubectl -n "$NAMESPACE" get secret "$ADMIN_SECRET" -o jsonpath='{.data.password}' | base64 -d)"
[agent] +
[agent] +build_js() {
[agent] +  cat <<EOF
[agent] +const appDb = db.getSiblingDB("${APP_DB}");
[agent] +
[agent] +function ensureAppUser() {
[agent] +  db.getSiblingDB("admin").updateUser("${APP_USER}", {
[agent] +    roles: [{ role: "readWrite", db: "${APP_DB}" }]
[agent] +  });
[agent] +}
[agent] +
[agent] +function ensureReportingRole() {
[agent] +  const privileges = [{
[agent] +    resource: { db: "${APP_DB}", collection: "${REPORTS_COLLECTION}" },
[agent] +    actions: ["find"]
[agent] +  }];
[agent] +  if (appDb.getRole("${REPORTING_ROLE}")) {
[agent] +    appDb.updateRole("${REPORTING_ROLE}", { privileges: privileges, roles: [] });
[agent] +  } else {
[agent] +    appDb.createRole({ role: "${REPORTING_ROLE}", privileges: privileges, roles: [] });
[agent] +  }
[agent] +}
[agent] +
[agent] +function ensureReportingUser() {
[agent] +  db.getSiblingDB("admin").updateUser("${REPORTING_USER}", {
[agent] +    roles: [{ role: "${REPORTING_ROLE}", db: "${APP_DB}" }]
[agent] +  });
[agent] +}
[agent] +
[agent] +switch ("${MODE}") {
[agent] +  case "app":
[agent] +    ensureAppUser();
[agent] +    break;
[agent] +  case "reporting":
[agent] +    ensureReportingRole();
[agent] +    ensureReportingUser();
[agent] +    break;
[agent] +  case "all":
[agent] +    ensureAppUser();
[agent] +    ensureReportingRole();
[agent] +    ensureReportingUser();
[agent] +    break;
[agent] +}
[agent] +EOF
[agent] +}
[agent] +
[agent] +run_mongosh() {
[agent] +  kubectl -n "$NAMESPACE" exec -i "$POD" -- sh -lc \
[agent] +    "cat >/tmp/reset_rbac.js && mongosh --quiet -u \"$ADMIN_USER\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin /tmp/reset_rbac.js && rm -f /tmp/reset_rbac.js"
[agent] +}
