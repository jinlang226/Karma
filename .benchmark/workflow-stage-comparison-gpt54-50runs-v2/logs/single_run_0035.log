[kubectl] 2026-05-21T00:36:44Z kubectl -n wf-2026-05-21t00-33-49z-workflow-r-96589abf-cluster-a exec mongodb-replica-0 -- env RESET_MODE=all APP_PASSWORD=app123password REPORTING_PASSWORD=reporting123password mongosh --quiet 'mongodb://mongodb-replica-0.mongodb-replica-svc.wf-2026-05-21t00-33-49z-workflow-r-96589abf-cluster-a.svc.cluster.local:27017,mongodb-replica-1.mongodb-replica-svc.wf-2026-05-21t00-33-49z-workflow-r-96589abf-cluster-a.svc.cluster.local:27017,mongodb-replica-2.mongodb-replica-svc.wf-2026-05-21t00-33-49z-workflow-r-96589abf-cluster-a.svc.cluster.local:27017/admin?replicaSet=mongodb-replica' --username admin-user --password admin123password --authenticationDatabase admin --eval 'const mode = process.env.RESET_MODE;
const appPassword = process.env.APP_PASSWORD;
const reportingPassword = process.env.REPORTING_PASSWORD;

const appDb = db.getSiblingDB("appdb");

function upsertUser(targetDb, username, password, roles) {
  const existing = targetDb.getUser(username);
  if (existing) {
    targetDb.updateUser(username, { pwd: password, roles });
  } else {
    targetDb.createUser({ user: username, pwd: password, roles });
  }
}

function ensureAppUser() {
  upsertUser(appDb, "app-user", appPassword, [
    { role: "readWrite", db: "appdb" }
  ]);
}

function ensureReportingRole() {
  const privileges = [
    {
      resource: { db: "appdb", collection: "reports" },
      actions: ["find"]
    }
  ];
  const inheritedRoles = [];
  const existing = appDb.getRole("reportingRole", { showPrivileges: true });
  if (existing) {
    appDb.updateRole("reportingRole", { privileges, roles: inheritedRoles });
  } else {
    appDb.createRole({
      role: "reportingRole",
      privileges,
      roles: inheritedRoles
    });
  }
}

function ensureReportingUser() {
  upsertUser(appDb, "reporting-user", reportingPassword, [
    { role: "reportingRole", db: "appdb" }
  ]);
}

if (mode === "all" || mode === "app") {
  ensureAppUser();
}

if (mode === "all" || mode === "reporting") {
  ensureReportingRole();
  ensureReportingUser();
}'
