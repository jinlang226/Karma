[agent] +    APP_DB="appdb"
[agent] +    APP_USERNAME="app-user"
[agent] +    REPORTING_USERNAME="reporting-user"
[agent] +    REPORTING_ROLE="reportingRole"
[agent] +    REPORTS_COLLECTION="reports"
[agent] +
[agent] +    usage() {
[agent] +      echo "Usage: $0 --mode {all|app|reporting}" >&2
[agent] +      exit 1
[agent] +    }
[agent] +
[agent] +    MODE=""
