[agent] +        { role: "readWrite", db: "appdb" }
[agent] +      ]);
[agent] +    }
[agent] +
[agent] +    function ensureReportingRole() {
[agent] +      const privileges = [
[agent] +        {
[agent] +          resource: { db: "appdb", collection: "reports" },
[agent] +          actions: ["find"]
[agent] +        }
[agent] +      ];
[agent] +      const inheritedRoles = [];
[agent] +      const existing = appDb.getRole("reportingRole", { showPrivileges: true });
