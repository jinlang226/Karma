[agent] +    }
[agent] +
[agent] +    ADMIN_PASSWORD="$(get_secret_field admin-user-password password)"
[agent] +    APP_PASSWORD="$(get_secret_field app-user-password password)"
[agent] +    REPORTING_PASSWORD="$(get_secret_field reporting-user-password password)"
[agent] +
[agent] +    MONGODB_URI="mongodb://mongodb-replica-0.${SERVICE_NAME}.${NAMESPACE}.svc.cluster.local:27017,mongodb-replica-1.${SERVICE_NAME}.${NAMESPACE}.svc.cluster.local:27017,mongodb-replica-2.${SERVICE_NAME}.${NAMESPACE}.svc.cluster.local:27017/admin?replicaSet=${REPLICA_SET}"
[agent] +
[agent] +    JS="$(cat <<'EOF'
[agent] +    const mode = process.env.RESET_MODE;
[agent] +    const appPassword = process.env.APP_PASSWORD;
[agent] +    const reportingPassword = process.env.REPORTING_PASSWORD;
[agent] +
[agent] +    const appDb = db.getSiblingDB("appdb");
[agent] +
[agent] +    function upsertUser(targetDb, username, password, roles) {
[agent] +      const existing = targetDb.getUser(username);
[agent] +      if (existing) {
[agent] +        targetDb.updateUser(username, { pwd: password, roles });
[agent] +      } else {
[agent] +        targetDb.createUser({ user: username, pwd: password, roles });
[agent] +      }
[agent] +    }
[agent] +
[agent] +    function ensureAppUser() {
