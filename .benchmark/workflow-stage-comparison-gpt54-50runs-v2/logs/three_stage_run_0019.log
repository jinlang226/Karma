te', db: '${APP_DB}' } ] });\n  \"\nfi\n\nif [ \"$MODE\" = \"reporting\" ] || [ \"$MODE\" = \"all\" ]; then\n  mongo_eval \"\n    const appDb = db.getSiblingDB('${APP_DB}');\n    const adminDb = db.getSiblingDB('admin');\n    const roleSpec = {\n      privileges: [\n        {\n          resource: { db: '${APP_DB}', collection: '${REPORTS_COLLECTION}' },\n          actions: ['find']\n        }\n      ],\n      roles: []\n    };\n\n    if (appDb.getRole('${REPORTING_ROLE}', { showPrivileges: true })) {\n      appDb.updateRole('${REPORTING_ROLE}', roleSpec);\n    } else {\n      appDb.createRole(Object.assign({ role: '${REPORTING_ROLE}' }, roleSpec));\n    }\n\n    const reportingUser = adminDb.getUser('${REPORTING_USER}');\n    if (!reportingUser) {\n      throw new Error('reporting-user is missing');\n    }\n\n    const appUser = adminDb.getUser('${APP_USER}');\n    if (!appUser) {\n      throw new Error('app-user is missing');\n    }\n\n    adminDb.updateUser('${REPORTING_USER}', { roles: [ { role: '${REPORTING_ROLE}', db: '${APP_DB}' } ] });\n\n    const rawRole = appDb.getRole('${RAW_ROLE}');\n    if (rawRole) {\n      const stillAssigned = adminDb.getUsers().users.some((user) =\u003e\n        user.roles.some((role) =\u003e role.role === '${RAW_ROLE}' \u0026\u0026 role.db === '${APP_DB}')\n      );\n      if (!stillAssigned) {\n        appDb.dropRole('${RAW_ROLE}');\n      }\n    }\n  \"\nfi\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-20t21-11-21z-workflow-r-9299c638-cluster-a"}}
