[agent] +apiVersion: v1
[agent] +kind: ConfigMap
[agent] +metadata:
[agent] +  name: mongodb-rbac-reset-script
[agent] +  namespace: wf-2026-05-20t21-30-19z-workflow-r-26c3777b-cluster-a
[agent] +data:
[agent] +  reset_rbac.sh: |
[agent] +    #!/bin/sh
[agent] +    set -eu
[agent] +
[agent] +    NAMESPACE="wf-2026-05-20t21-30-19z-workflow-r-26c3777b-cluster-a"
[agent] +    POD="mongodb-replica-0"
[agent] +    ADMIN_USER="admin-user"
[agent] +    ADMIN_SECRET="admin-user-password"
[agent] +
[agent] +    usage() {
[agent] +      echo "Usage: $0 --mode all|app|reporting" >&2
[agent] +      exit 1
[agent] +    }
[agent] +
[agent] +    MODE=""
[agent] +    while [ "$#" -gt 0 ]; do
[agent] +      case "$1" in
[agent] +        --mode)
[agent] +          shift
[agent] +          [ "$#" -gt 0 ] || usage
[agent] +          MODE="$1"
[agent] +          ;;
[agent] +        *)
[agent] +          usage
[agent] +          ;;
[agent] +      esac
[agent] +      shift
[agent] +    done
[agent] +
[agent] +    [ -n "$MODE" ] || usage
[agent] +
[agent] +    case "$MODE" in
[agent] +      all|app|reporting)
[agent] +        ;;
[agent] +      *)
[agent] +        usage
[agent] +        ;;
[agent] +    esac
[agent] +
[agent] +    ADMIN_PASSWORD="$(
[agent] +      kubectl -n "$NAMESPACE" get secret "$ADMIN_SECRET" -o jsonpath='{.data.password}' | base64 -d
[agent] +    )"
[agent] +
[agent] +    run_mongo() {
[agent] +      kubectl -n "$NAMESPACE" exec "$POD" -- mongosh \
[agent] +        -u "$ADMIN_USER" \
[agent] +        -p "$ADMIN_PASSWORD" \
[agent] +        --authenticationDatabase admin \
[agent] +        --quiet \
[agent] +        --eval "$1"
[agent] +    }
[agent] +
[agent] +    apply_app_mode() {
[agent] +      run_mongo 'db.getSiblingDB("admin").updateUser("app-user", {roles: [{role: "readWrite", db: "appdb"}]})'
[agent] +    }
[agent] +
[agent] +    apply_reporting_mode() {
[agent] +      run_mongo '
[agent] +        const appdb = db.getSiblingDB("appdb");
[agent] +        const roleSpec = {
[agent] +          privileges: [
[agent] +            {
[agent] +              resource: {db: "appdb", collection: "reports"},
[agent] +              actions: ["find"]
[agent] +            }
[agent] +          ],
[agent] +          roles: []
[agent] +        };
[agent] +        if (appdb.getRole("reportingRole", {showPrivileges: true})) {
[agent] +          appdb.updateRole("reportingRole", roleSpec);
[agent] +        } else {
[agent] +          appdb.createRole(Object.assign({role: "reportingRole"}, roleSpec));
[agent] +        }
[agent] +        db.getSiblingDB("admin").updateUser("reporting-user", {
[agent] +          roles: [{role: "reportingRole", db: "appdb"}]
[agent] +        });
[agent] +      '
[agent] +    }
[agent] +
[agent] +    case "$MODE" in
[agent] +      app)
[agent] +        apply_app_mode
[agent] +        ;;
[agent] +      reporting)
[agent] +        apply_reporting_mode
[agent] +        ;;
[agent] +      all)
[agent] +        apply_app_mode
[agent] +        apply_reporting_mode
[agent] +        ;;
[agent] +    esac
