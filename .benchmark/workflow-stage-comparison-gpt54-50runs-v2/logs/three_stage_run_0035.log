[agent] @@ -0,0 +1,74 @@
[agent] +#!/bin/sh
[agent] +set -eu
[agent] +
[agent] +NAMESPACE="${NAMESPACE:-wf-2026-05-21t02-10-49z-workflow-r-327e8b73-cluster-a}"
[agent] +MODE=""
[agent] +
[agent] +usage() {
[agent] +  cat <<'EOF'
[agent] +Usage: reset_rbac.sh --mode all|app|reporting
[agent] +EOF
[agent] +}
[agent] +
[agent] +while [ "$#" -gt 0 ]; do
[agent] +  case "$1" in
[agent] +    --mode)
[agent] +      shift
[agent] +      [ "$#" -gt 0 ] || {
[agent] +        usage >&2
[agent] +        exit 1
[agent] +      }
[agent] +      MODE="$1"
[agent] +      ;;
[agent] +    -h|--help)
[agent] +      usage
[agent] +      exit 0
[agent] +      ;;
[agent] +    *)
[agent] +      echo "Unknown argument: $1" >&2
[agent] +      usage >&2
[agent] +      exit 1
[agent] +      ;;
[agent] +  esac
[agent] +  shift
[agent] +done
[agent] +
[agent] +case "$MODE" in
[agent] +  all|app|reporting) ;;
[agent] +  *)
[agent] +    usage >&2
[agent] +    exit 1
[agent] +    ;;
[agent] +esac
[agent] +
[agent] +ADMIN_PASSWORD="$(kubectl -n "$NAMESPACE" get secret admin-user-password -o jsonpath='{.data.password}' | base64 -d)"
[agent] +CLIENT_POD="mongodb-replica-0"
[agent] +MONGO_URI="mongodb://admin-user:${ADMIN_PASSWORD}@mongodb-replica-0.mongodb-replica-svc.${NAMESPACE}.svc.cluster.local:27017,mongodb-replica-1.mongodb-replica-svc.${NAMESPACE}.svc.cluster.local:27017,mongodb-replica-2.mongodb-replica-svc.${NAMESPACE}.svc.cluster.local:27017/admin?replicaSet=mongodb-replica&authSource=admin"
[agent] +
[agent] +run_mongo() {
[agent] +  kubectl -n "$NAMESPACE" exec "$CLIENT_POD" -- \
[agent] +    mongosh --quiet "$MONGO_URI" --eval "$1"
[agent] +}
[agent] +
[agent] +reset_app() {
[agent] +  run_mongo 'db.getSiblingDB("admin").updateUser("app-user", {roles: [{role: "readWrite", db: "appdb"}]})'
[agent] +}
[agent] +
[agent] +reset_reporting() {
[agent] +  run_mongo 'const appdb = db.getSiblingDB("appdb"); const privileges = [{resource: {db: "appdb", collection: "reports"}, actions: ["find"]}]; if (appdb.getRole("reportingRole")) { appdb.updateRole("reportingRole", {privileges: privileges, roles: []}); } else { appdb.createRole({role: "reportingRole", privileges: privileges, roles: []}); } db.getSiblingDB("admin").updateUser("reporting-user", {roles: [{role: "reportingRole", db: "appdb"}]})'
[agent] +}
[agent] +
[agent] +case "$MODE" in
[agent] +  app)
[agent] +    reset_app
[agent] +    ;;
[agent] +  reporting)
[agent] +    reset_reporting
[agent] +    ;;
[agent] +  all)
[agent] +    reset_app
[agent] +    reset_reporting
[agent] +    ;;
[agent] +esac
[agent] +
[agent] +echo "RBAC reset completed for mode: $MODE"
