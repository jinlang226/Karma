const appPassword = process.env.APP_PASSWORD;
const reportingPassword = process.env.REPORTING_PASSWORD;

const appDb = db.getSiblingDB("appdb");

function ensureAppUser() {
  const user = appDb.getUser("app-user");
  const roles = [{ role: "readWrite", db: "appdb" }];
  if (user) {
    appDb.updateUser("app-user", { roles });
  } else {
    appDb.createUser({ user: "app-user", pwd: appPassword, roles });
  }
}

function ensureReportingRole() {
  const role = appDb.getRole("reportingRole", { showPrivileges: true });
  const privileges = [{
    resource: { db: "appdb", collection: "reports" },
    actions: ["find"]
  }];
  const roleDoc = { privileges, roles: [] };
  if (role) {
    appDb.updateRole("reportingRole", roleDoc);
  } else {
    appDb.createRole({ role: "reportingRole", ...roleDoc });
  }
}

function ensureReportingUser() {
  const user = appDb.getUser("reporting-user");
  const roles = [{ role: "reportingRole", db: "appdb" }];
  if (user) {
    appDb.updateUser("reporting-user", { roles });
  } else {
    appDb.createUser({ user: "reporting-user", pwd: reportingPassword, roles });
  }
}

if (mode === "all" || mode === "app") {
  ensureAppUser();
}

if (mode === "all" || mode === "reporting") {
  ensureReportingRole();
  ensureReportingUser();
}'
