TER_PREFIX}-1.${HEADLESS_SERVICE_NAME}.${NAMESPACE}.svc.cluster.local:27017,${CLUSTER_PREFIX}-2.${HEADLESS_SERVICE_NAME}.${NAMESPACE}.svc.cluster.local:27017/?replicaSet=${REPLICA_SET_NAME}\"\n\njs_string() {\n  printf '%s' \"$1\" | sed 's/\\\\/\\\\\\\\/g; s/\"/\\\\\"/g'\n}\n\nmongo_eval() {\n  js_file=\"$1\"\n  kubectl -n \"$NAMESPACE\" exec -i \"$EXEC_POD\" -- sh -lc '\n    set -eu\n    cat \u003e /tmp/reset_rbac.js\n    mongosh --quiet \\\n      \"$2\" \\\n      -u \"$0\" \\\n      -p \"$1\" \\\n      --authenticationDatabase admin \\\n      /tmp/reset_rbac.js\n  ' \"$ADMIN_USERNAME\" \"$ADMIN_PASSWORD\" \"$MONGO_URI\" \u003c \"$js_file\"\n}\n\njs_file=\"$(mktemp)\"\ntrap 'rm -f \"$js_file\"' EXIT HUP INT TERM\n\ncat \u003e \"$js_file\" \u003c\u003cEOFJS\nconst mode = \"$(js_string \"$MODE\")\";\nconst adminDb = db.getSiblingDB(\"admin\");\nconst appDbName = \"$(js_string \"$APP_DATABASE\")\";\nconst appUsername = \"$(js_string \"$APP_USERNAME\")\";\nconst appPassword = \"$(js_string \"$APP_PASSWORD\")\";\nconst reportingUsername = \"$(js_string \"$REPORTING_USERNAME\")\";\nconst reportingPassword = \"$(js_string \"$REPORTING_PASSWORD\")\";\nconst reportingRoleName = \"$(js_string \"$REPORTING_ROLE_NAME\")\";\nconst badRoleName = \"$(js_string \"$BAD_ROLE_NAME\")\";\nconst reportsCollection = \"$(js_string \"$REPORTS_COLLECTION\")\";\n\nfunction upsertUser(user, pwd, roles) {\n  const existing = adminDb.getUser(user);\n  if (existing) {\n    adminDb.updateUser(user, { pwd: pwd, roles: roles });\n  } else {\n    adminDb.createUser({ user: user, pwd: pwd, roles: roles });\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  upsertUser(appUsername, appPassword, [{ role: \"readWrite\", db: appDbName }]);\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  const rolePrivileges = [{\n    resource: { db: appDbName, collection: reportsCollection },\n    actions: [\"find\"]\n  }];\n  const existingRole = db.getSiblingDB(appDbName).getRole(reportingRoleName, { 