SWORD=\"$(get_secret_password \"$ADMIN_SECRET\")\"\nAPP_PASSWORD=\"$(get_secret_password \"$APP_SECRET\")\"\nREPORTING_PASSWORD=\"$(get_secret_password \"$REPORTING_SECRET\")\"\nPRIMARY_POD=\"$(find_primary_pod)\"\n\nkubectl -n \"$NAMESPACE\" exec \"$PRIMARY_POD\" -- env \\\n  MONGO_MODE=\"$MODE\" \\\n  APP_PASSWORD=\"$APP_PASSWORD\" \\\n  REPORTING_PASSWORD=\"$REPORTING_PASSWORD\" \\\n  APP_DB=\"$APP_DB\" \\\n  APP_USER=\"$APP_USER\" \\\n  REPORTING_USER=\"$REPORTING_USER\" \\\n  REPORTING_ROLE=\"$REPORTING_ROLE\" \\\n  mongosh --quiet -u admin-user -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin \u003c\u003c'EOF'\nconst mode = process.env.MONGO_MODE;\nconst appDbName = process.env.APP_DB;\nconst appUser = process.env.APP_USER;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUser = process.env.REPORTING_USER;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRole = process.env.REPORTING_ROLE;\n\nconst adminDb = db.getSiblingDB(\"admin\");\nconst appDb = db.getSiblingDB(appDbName);\n\nfunction upsertUser(targetDb, username, password, roles) {\n  const existing = targetDb.getUser(username);\n  if (existing) {\n    targetDb.updateUser(username, { pwd: password, roles });\n  } else {\n    targetDb.createUser({ user: username, pwd: password, roles });\n  }\n}\n\nfunction upsertReportingRole() {\n  const roleDoc = {\n    privileges: [\n      {\n        resource: { db: appDbName, collection: \"reports\" },\n        actions: [\"find\"],\n      },\n    ],\n    roles: [],\n    authenticationRestrictions: [],\n  };\n\n  if (appDb.getRole(reportingRole, { showPrivileges: true })) {\n    appDb.updateRole(reportingRole, roleDoc);\n  } else {\n    appDb.createRole({ role: reportingRole, ...roleDoc });\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  upsertUser(adminDb, appUser, appPassword, [{ role: \"readWrite\", db: appDbName }]);\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  upsertReportingRole();\n  upsertUser(adminDb, reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);\n}\nEOF\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-20t04-58-10z-workflow-r-9cf98369-cluster-a"}}
