{STATEFULSET}-1.${SERVICE}:27017,${STATEFULSET}-2.${SERVICE}:27017\"\n\nrun_js() {\n  k exec \"$POD\" -- \\\n    mongosh --quiet \\\n    --host \"${MONGO_HOSTS}/?replicaSet=${REPLICA_SET}\" \\\n    -u \"$ADMIN_USER\" \\\n    -p \"$ADMIN_PASSWORD\" \\\n    --authenticationDatabase admin \\\n    --eval \"$1\"\n}\n\nreset_app_js() {\n  cat \u003c\u003cEOF\nconst adminDb = db.getSiblingDB(\"admin\");\nif (adminDb.getUser(\"${APP_USER}\")) {\n  adminDb.updateUser(\"${APP_USER}\", { roles: [ { role: \"readWrite\", db: \"appdb\" } ] });\n} else {\n  adminDb.createUser({\n    user: \"${APP_USER}\",\n    pwd: \"${APP_PASSWORD}\",\n    roles: [ { role: \"readWrite\", db: \"appdb\" } ]\n  });\n}\nprintjson({ mode: \"app\", user: adminDb.getUser(\"${APP_USER}\") });\nEOF\n}\n\nreset_reporting_js() {\n  cat \u003c\u003cEOF\nconst adminDb = db.getSiblingDB(\"admin\");\nconst appDb = db.getSiblingDB(\"appdb\");\nconst roleSpec = {\n  privileges: [ { resource: { db: \"appdb\", collection: \"reports\" }, actions: [ \"find\" ] } ],\n  roles: []\n};\nif (appDb.getRole(\"reportingRole\")) {\n  appDb.updateRole(\"reportingRole\", roleSpec);\n} else {\n  appDb.createRole(Object.assign({ role: \"reportingRole\" }, roleSpec));\n}\nif (adminDb.getUser(\"${REPORTING_USER}\")) {\n  adminDb.updateUser(\"${REPORTING_USER}\", { roles: [ { role: \"reportingRole\", db: \"appdb\" } ] });\n} else {\n  adminDb.createUser({\n    user: \"${REPORTING_USER}\",\n    pwd: \"${REPORTING_PASSWORD}\",\n    roles: [ { role: \"reportingRole\", db: \"appdb\" } ]\n  });\n}\nprintjson({\n  mode: \"reporting\",\n  user: adminDb.getUser(\"${REPORTING_USER}\"),\n  role: appDb.getRole(\"reportingRole\", { showPrivileges: true })\n});\nEOF\n}\n\ncase \"$MODE\" in\n  app)\n    run_js \"$(reset_app_js)\"\n    ;;\n  reporting)\n    run_js \"$(reset_reporting_js)\"\n    ;;\n  all)\n    run_js \"$(reset_app_js)\"\n    run_js \"$(reset_reporting_js)\"\n    ;;\nesac\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-21t01-34-21z-workflow-r-0e0ef2fe-cluster-a"}}
