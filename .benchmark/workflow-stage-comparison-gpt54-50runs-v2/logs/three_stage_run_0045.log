set -eu
cat <<'"'"'MONGO_EOF'"'"' >/tmp/reset_rbac.js
const mode = "all";
const adminDb = db.getSiblingDB("admin");
const appDb = db.getSiblingDB("appdb");

function hasRole(roleName) {
  return appDb.getRole(roleName, { showPrivileges: false }) !== null;
}

if (mode === "app" || mode === "all") {
  adminDb.updateUser("app-user", {
    roles: [{ role: "readWrite", db: "appdb" }]
  });
}

if (mode === "reporting" || mode === "all") {
  if (hasRole("reportingRole")) {
    appDb.updateRole("reportingRole", {
      privileges: [{
        resource: { db: "appdb", collection: "reports" },
        actions: ["find"]
      }],
      roles: []
    });
  } else {
    appDb.createRole({
      role: "reportingRole",
      privileges: [{
        resource: { db: "appdb", collection: "reports" },
        actions: ["find"]
      }],
      roles: []
    });
  }

  adminDb.updateUser("reporting-user", {
    roles: [{ role: "reportingRole", db: "appdb" }]
  });

  if (hasRole("rawRead")) {
    appDb.dropRole("rawRead");
  }
}
MONGO_EOF
mongosh --quiet -u "admin-user" -p "admin123password" --authenticationDatabase admin /tmp/reset_rbac.js
'
