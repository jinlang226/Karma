const adminDb = db.getSiblingDB("admin");
const appDb = db.getSiblingDB("appdb");
const appPassword = process.env.APP_PASSWORD;
const reportingPassword = process.env.REPORTING_PASSWORD;

function ensureUser(user, password, roles) {
  if (adminDb.getUser(user)) {
    adminDb.updateUser(user, { pwd: password, roles });
    return;
  }

  adminDb.createUser({ user, pwd: password, roles });
}

function ensureReportingRole() {
  const spec = {
    privileges: [
      {
        resource: { db: "appdb", collection: "reports" },
        actions: ["find"],
      },
    ],
    roles: [],
  };

  if (appDb.getRole("reportingRole")) {
    appDb.updateRole("reportingRole", spec);
    return;
  }

  appDb.createRole({ role: "reportingRole", ...spec });
}

if (mode === "app" || mode === "all") {
  ensureUser("app-user", appPassword, [{ role: "readWrite", db: "appdb" }]);
}

if (mode === "reporting" || mode === "all") {
  ensureReportingRole();
  ensureUser("reporting-user", reportingPassword, [{ role: "reportingRole", db: "appdb" }]);
}'
