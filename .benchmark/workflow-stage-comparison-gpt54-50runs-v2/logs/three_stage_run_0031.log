[agent] +const adminDb = db.getSiblingDB("admin");
[agent] +const appDb = db.getSiblingDB("appdb");
[agent] +const appPassword = process.env.APP_PASSWORD;
[agent] +const reportingPassword = process.env.REPORTING_PASSWORD;
[agent] +
[agent] +function ensureUser(user, password, roles) {
[agent] +  if (adminDb.getUser(user)) {
[agent] +    adminDb.updateUser(user, { pwd: password, roles });
[agent] +    return;
[agent] +  }
[agent] +
[agent] +  adminDb.createUser({ user, pwd: password, roles });
[agent] +}
[agent] +
[agent] +function ensureReportingRole() {
[agent] +  const spec = {
[agent] +    privileges: [
[agent] +      {
[agent] +        resource: { db: "appdb", collection: "reports" },
[agent] +        actions: ["find"],
[agent] +      },
[agent] +    ],
[agent] +    roles: [],
[agent] +  };
[agent] +
[agent] +  if (appDb.getRole("reportingRole")) {
[agent] +    appDb.updateRole("reportingRole", spec);
[agent] +    return;
[agent] +  }
[agent] +
[agent] +  appDb.createRole({ role: "reportingRole", ...spec });
[agent] +}
[agent] +
[agent] +if (mode === "app" || mode === "all") {
[agent] +  ensureUser("app-user", appPassword, [{ role: "readWrite", db: "appdb" }]);
[agent] +}
[agent] +
[agent] +if (mode === "reporting" || mode === "all") {
[agent] +  ensureReportingRole();
[agent] +  ensureUser("reporting-user", reportingPassword, [{ role: "reportingRole", db: "appdb" }]);
[agent] +}
[agent] +EOF
[agent] +)"
[agent] +
[agent] +kubectl -n "$NAMESPACE" exec "$EXEC_POD" -- env \
[agent] +  MODE="$MODE" \
[agent] +  APP_PASSWORD="$APP_PASSWORD" \
[agent] +  REPORTING_PASSWORD="$REPORTING_PASSWORD" \
[agent] +  mongosh "$MONGODB_URI" \
[agent] +    --quiet \
[agent] +    --username "$ADMIN_USERNAME" \
[agent] +    --password "$ADMIN_PASSWORD" \
[agent] +    --authenticationDatabase admin \
[agent] +    --eval "$JS"
