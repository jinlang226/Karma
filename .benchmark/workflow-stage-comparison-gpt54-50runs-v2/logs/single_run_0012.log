[agent] +    APP_DB="appdb"
[agent] +    APP_USER="app-user"
[agent] +    APP_SECRET="app-user-password"
[agent] +    REPORTING_USER="reporting-user"
[agent] +    REPORTING_SECRET="reporting-user-password"
[agent] +    REPORTING_ROLE="reportingRole"
[agent] +
[agent] +    usage() {
[agent] +      echo "Usage: $0 --mode all|app|reporting" >&2
[agent] +      exit 1
[agent] +    }
[agent] +
[agent] +    MODE=""
[agent] +    while [ "$#" -gt 0 ]; do
[agent] +      case "$1" in
[agent] +        --mode)
[agent] +          shift
[agent] +          [ "$#" -gt 0 ] || usage
[agent] +          MODE="$1"
[agent] +          ;;
[agent] +        *)
[agent] +          usage
[agent] +          ;;
[agent] +      esac
[agent] +      shift
[agent] +    done
[agent] +
[agent] +    case "$MODE" in
[agent] +      all|app|reporting) ;;
[agent] +      *) usage ;;
[agent] +    esac
[agent] +
[agent] +    get_secret() {
[agent] +      kubectl -n "$NAMESPACE" get secret "$1" -o jsonpath='{.data.password}' | base64 -d
[agent] +    }
[agent] +
[agent] +    ADMIN_PASSWORD="$(get_secret "$ADMIN_SECRET")"
[agent] +    APP_PASSWORD="$(get_secret "$APP_SECRET")"
[agent] +    REPORTING_PASSWORD="$(get_secret "$REPORTING_SECRET")"
[agent] +
[agent] +    mongo_eval() {
[agent] +      kubectl -n "$NAMESPACE" exec "$POD" -- \
[agent] +        mongosh --quiet \
[agent] +          -u "$ADMIN_USER" \
[agent] +          -p "$ADMIN_PASSWORD" \
[agent] +          --authenticationDatabase admin \
[agent] +          --eval "$1"
[agent] +    }
[agent] +
[agent] +    reset_app_user() {
[agent] +      mongo_eval "
[agent] +        const dbName = '$APP_DB';
[agent] +        const username = '$APP_USER';
[agent] +        const password = '$APP_PASSWORD';
[agent] +        const targetRoles = [{ role: 'readWrite', db: dbName }];
[agent] +        const targetDb = db.getSiblingDB(dbName);
[agent] +        if (targetDb.getUser(username)) {
[agent] +          targetDb.updateUser(username, { pwd: password, roles: targetRoles });
[agent] +        } else {
[agent] +          targetDb.createUser({ user: username, pwd: password, roles: targetRoles });
[agent] +        }
[agent] +      "
[agent] +    }
[agent] +
[agent] +    reset_reporting_access() {
[agent] +      mongo_eval "
[agent] +        const dbName = '$APP_DB';
[agent] +        const username = '$REPORTING_USER';
[agent] +        const password = '$REPORTING_PASSWORD';
[agent] +        const roleName = '$REPORTING_ROLE';
[agent] +        const targetDb = db.getSiblingDB(dbName);
[agent] +        const targetRole = [{ role: roleName, db: dbName }];
[agent] +        const rolePrivileges = [{
[agent] +          resource: { db: dbName, collection: 'reports' },
[agent] +          actions: ['find']
[agent] +        }];
[agent] +
[agent] +        if (targetDb.getRole(roleName, { showPrivileges: true })) {
[agent] +          targetDb.updateRole(roleName, { privileges: rolePrivileges, roles: [] });
[agent] +        } else {
[agent] +          targetDb.createRole({ role: roleName, privileges: rolePrivileges, roles: [] });
[agent] +        }
[agent] +
[agent] +        if (targetDb.getUser(username)) {
[agent] +          targetDb.updateUser(username, { pwd: password, roles: targetRole });
[agent] +        } else {
[agent] +          targetDb.createUser({ user: username, pwd: password, roles: targetRole });
[agent] +        }
[agent] +      "
[agent] +    }
[agent] +
[agent] +    case "$MODE" in
[agent] +      all)
[agent] +        reset_app_user
[agent] +        reset_reporting_access
[agent] +        ;;
[agent] +      app)
[agent] +        reset_app_user
[agent] +        ;;
[agent] +      reporting)
[agent] +        reset_reporting_access
[agent] +        ;;
[agent] +    esac
