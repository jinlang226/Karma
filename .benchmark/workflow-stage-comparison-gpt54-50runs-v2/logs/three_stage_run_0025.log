const mode = process.env.MODE;
const adminDb = db.getSiblingDB("admin");
const appDb = db.getSiblingDB("appdb");

function hasRole(userDoc, roleName, roleDb) {
  return (userDoc.roles || []).some((role) => role.role === roleName && role.db === roleDb);
}

function ensureUserRole(userName, roleName, roleDb) {
  const user = adminDb.getUser(userName);
  if (!user) {
    throw new Error(`User ${userName} does not exist`);
  }
  if (!hasRole(user, roleName, roleDb) || user.roles.length !== 1) {
    adminDb.updateUser(userName, { roles: [{ role: roleName, db: roleDb }] });
  }
}

function dropRoleIfPresent(roleName, roleDb) {
  const role = db.getSiblingDB(roleDb).getRole(roleName);
  if (role) {
    db.getSiblingDB(roleDb).dropRole(roleName);
  }
}

function ensureReportingRole() {
  const existing = appDb.getRole("reportingRole", { showPrivileges: true });
  const wantedPrivilege = {
    resource: { db: "appdb", collection: "reports" },
    actions: ["find"]
  };

  if (!existing) {
    appDb.createRole({
      role: "reportingRole",
      privileges: [wantedPrivilege],
      roles: []
    });
    return;
  }

  const privileges = existing.privileges || [];
  const hasExactPrivilege =
    privileges.length === 1 &&
    privileges[0].resource &&
    privileges[0].resource.db === "appdb" &&
    privileges[0].resource.collection === "reports" &&
    Array.isArray(privileges[0].actions) &&
    privileges[0].actions.length === 1 &&
    privileges[0].actions[0] === "find";

  if (!hasExactPrivilege || (existing.roles || []).length !== 0) {
    appDb.updateRole("reportingRole", {
      privileges: [wantedPrivilege],
      roles: []
    });
  }
}

if (mode === "all" || mode === "app") {
  ensureUserRole("app-user", "readWrite", "appdb");
}

if (mode === "all" || mode === "reporting") {
  ensureReportingRole();
  ensureUserRole("reporting-user", "reportingRole", "appdb");
  dropRoleIfPresent("rawRead", "appdb");
}
'
