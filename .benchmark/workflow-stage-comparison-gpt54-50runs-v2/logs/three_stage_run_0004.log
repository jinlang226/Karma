[agent]     NAMESPACE="${NAMESPACE:-wf-2026-05-20t07-27-36z-workflow-r-80059a37-cluster-a}"
[agent]     POD="${POD:-mongodb-replica-0}"
[agent]     ADMIN_SECRET="${ADMIN_SECRET:-admin-user-password}"
[agent]     ADMIN_USER="${ADMIN_USER:-admin-user}"
[agent]     usage() {
[agent]       echo "Usage: $0 --mode all|app|reporting" >&2
[agent]       exit 1
[agent]     }
[agent]     MODE=""
[agent]     while [ "$#" -gt 0 ]; do
[agent]       case "$1" in
[agent]         --mode)
[agent]           shift
[agent]           [ "$#" -gt 0 ] || usage
[agent]           MODE="$1"
[agent]           ;;
[agent]         *)
[agent]           usage
[agent]           ;;
[agent]       esac
[agent]       shift
[agent]     done
[agent]     case "$MODE" in
[agent]       all|app|reporting)
[agent]         ;;
[agent]       *)
[agent]         usage
[agent]         ;;
[agent]     esac
[agent]     if ! command -v kubectl >/dev/null 2>&1; then
