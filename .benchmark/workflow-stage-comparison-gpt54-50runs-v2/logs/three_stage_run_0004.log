[agent]     const adminDb = db.getSiblingDB("admin");
[agent]     const appDb = db.getSiblingDB("appdb");
[agent]     function ensureAppUser() {
[agent]       adminDb.updateUser("app-user", {
[agent]         roles: [{ role: "readWrite", db: "appdb" }]
[agent]       });
[agent]     }
[agent]     function ensureReportingRole() {
[agent]       const privileges = [{
[agent]         resource: { db: "appdb", collection: "reports" },
[agent]         actions: ["find"]
[agent]       }];
[agent]       const existing = appDb.getRole("reportingRole", { showPrivileges: true });
[agent]       if (existing) {
[agent]         appDb.updateRole("reportingRole", {
[agent]           privileges: privileges,
[agent]           roles: []
[agent]         });
[agent]       } else {
[agent]         appDb.createRole({
[agent]           role: "reportingRole",
[agent]           privileges: privileges,
[agent]           roles: []
[agent]         });
[agent]       }
[agent]     }
[agent]     function ensureReportingUser() {
[agent]       adminDb.updateUser("reporting-user", {
[agent]         roles: [{ role: "reportingRole", db: "appdb" }]
[agent]       });
[agent]     }
