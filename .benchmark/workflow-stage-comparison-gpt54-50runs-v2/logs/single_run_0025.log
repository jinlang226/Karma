const appDbName = process.env.APP_DB;
const reportingRoleName = process.env.REPORTING_ROLE;
const reportsCollection = process.env.REPORTS_COLLECTION;
const mode = process.env.MODE;
const appDb = db.getSiblingDB(appDbName);
const adminDb = db.getSiblingDB("admin");

function ensureUser(db, username, password, roles) {
  const existing = adminDb.system.users.findOne({ user: username, db: db.getName() });
  if (existing) {
    db.dropUser(username);
  }
  db.createUser({ user: username, pwd: password, roles: roles });
}

function ensureReportingRole() {
  const privileges = [
    {
      resource: { db: appDbName, collection: reportsCollection },
      actions: ["find"],
    },
  ];
  const existing = adminDb.system.roles.findOne({ role: reportingRoleName, db: appDbName });
  if (existing) {
    appDb.updateRole(reportingRoleName, { privileges: privileges, roles: [] });
  } else {
    appDb.createRole({ role: reportingRoleName, privileges: privileges, roles: [] });
  }
}

function ensureAppUser() {
  ensureUser(appDb, appUser, appPassword, [{ role: "readWrite", db: appDbName }]);
}

function ensureReportingUser() {
  ensureReportingRole();
  ensureUser(appDb, reportingUser, reportingPassword, [{ role: reportingRoleName, db: appDbName }]);
}

if (mode === "app") {
  ensureAppUser();
} else if (mode === "reporting") {
  ensureReportingUser();
} else if (mode === "all") {
  ensureAppUser();
  ensureReportingUser();
