const adminDb = conn.getDB("admin");
if (!adminDb.auth(adminUser, adminPassword)) {
  throw new Error("admin authentication failed");
}
const appDb = conn.getDB(appDbName);

function ensureUser(db, username, password, roles) {
  const existing = db.getUser(username);
  if (existing) {
    db.updateUser(username, { pwd: password, roles: roles });
  } else {
    db.createUser({ user: username, pwd: password, roles: roles });
  }
}

function ensureReportingRole() {
  const privileges = [
    {
      resource: { db: appDbName, collection: reportsCollection },
      actions: ["find"],
    },
  ];
  const existing = appDb.getRole(reportingRoleName, { showPrivileges: true });
  if (existing) {
    appDb.updateRole(reportingRoleName, { privileges: privileges, roles: [] });
  } else {
    appDb.createRole({ role: reportingRoleName, privileges: privileges, roles: [] });
  }
}

function ensureAppUser() {
  ensureUser(appDb, appUser, appPassword, [{ role: "readWrite", db: appDbName }]);
}

function ensureReportingUser() {
  ensureReportingRole();
  ensureUser(appDb, reportingUser, reportingPassword, [{ role: reportingRoleName, db: appDbName }]);
}

if (mode === "app") {
  ensureAppUser();
} else if (mode === "reporting") {
  ensureReportingUser();
} else if (mode === "all") {
  ensureAppUser();
  ensureReportingUser();
} else {
  throw new Error(`unsupported mode: ${mode}`);
}' REPLICA_SET=mongodb-replica mongosh --quiet --authenticationDatabase admin --eval 'eval(process.env.RESET_JS)'
