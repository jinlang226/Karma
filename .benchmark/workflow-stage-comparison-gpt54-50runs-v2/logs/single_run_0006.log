[kubectl] 2026-05-20T05:32:02Z kubectl -n wf-2026-05-20t05-28-43z-workflow-r-c38bc6da-cluster-a exec mongodb-replica-0 -- env RESET_MODE=all MONGO_HOSTS=mongodb-replica-0.mongodb-replica-svc.wf-2026-05-20t05-28-43z-workflow-r-c38bc6da-cluster-a.svc.cluster.local:27017,mongodb-replica-1.mongodb-replica-svc.wf-2026-05-20t05-28-43z-workflow-r-c38bc6da-cluster-a.svc.cluster.local:27017,mongodb-replica-2.mongodb-replica-svc.wf-2026-05-20t05-28-43z-workflow-r-c38bc6da-cluster-a.svc.cluster.local:27017 ADMIN_USERNAME=admin-user ADMIN_PASSWORD=admin123password APP_USERNAME=app-user APP_PASSWORD=app123password REPORTING_USERNAME=reporting-user REPORTING_PASSWORD=reporting123password APP_DATABASE=appdb REPORTING_ROLE_NAME=reportingRole REPORTS_COLLECTION=reports sh -lc '
    mongosh --quiet \
      --host "$MONGO_HOSTS" \
