[agent] +
[agent] +    mongo_eval() {
[agent] +      js_b64="$(printf '%s' "$1" | base64 | tr -d '\n')"
[agent] +      kubectl -n "$NAMESPACE" exec "$POD" -- sh -lc "
[agent] +        primary=\$(mongosh --quiet -u '$ADMIN_USER' -p '$ADMIN_PASSWORD' --authenticationDatabase admin --eval 'db.hello().primary');
[agent] +        js=\$(printf '%s' '$js_b64' | base64 -d);
[agent] +        mongosh --quiet --host \"\$primary\" -u '$ADMIN_USER' -p '$ADMIN_PASSWORD' --authenticationDatabase admin --eval \"\$js\"
[agent] +      "
[agent] +    }
[agent] +
[agent] +    APP_JS='
[agent] +    const admin = db.getSiblingDB("admin");
[agent] +    const user = admin.getUser("app-user");
[agent] +    if (!user) {
[agent] +      throw new Error("app-user is missing");
[agent] +    }
[agent] +    admin.updateUser("app-user", {roles: [{role: "readWrite", db: "appdb"}]});
[agent] +    '
[agent] +
[agent] +    REPORTING_JS='
[agent] +    const admin = db.getSiblingDB("admin");
[agent] +    const appdb = db.getSiblingDB("appdb");
[agent] +    const privileges = [{resource: {db: "appdb", collection: "reports"}, actions: ["find"]}];
[agent] +    const roleDoc = appdb.getRole("reportingRole", {showPrivileges: true});
[agent] +    if (roleDoc) {
[agent] +      appdb.updateRole("reportingRole", {privileges, roles: []});
[agent] +    } else {
[agent] +      appdb.createRole({role: "reportingRole", privileges, roles: []});
[agent] +    }
[agent] +    const user = admin.getUser("reporting-user");
[agent] +    if (!user) {
[agent] +      throw new Error("reporting-user is missing");
[agent] +    }
[agent] +    admin.updateUser("reporting-user", {roles: [{role: "reportingRole", db: "appdb"}]});
[agent] +    '
[agent] +
[agent] +    case "$MODE" in
[agent] +      app)
[agent] +        mongo_eval "$APP_JS"
[agent] +        ;;
[agent] +      reporting)
[agent] +        mongo_eval "$REPORTING_JS"
[agent] +        ;;
[agent] +      all)
[agent] +        mongo_eval "$APP_JS"
[agent] +        mongo_eval "$REPORTING_JS"
[agent] +        ;;
[agent] +    esac
