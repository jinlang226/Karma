[agent] +#!/bin/sh
[agent] +set -eu
[agent] +
[agent] +usage() {
[agent] +  echo "Usage: $0 --mode all|app|reporting" >&2
[agent] +  exit 1
[agent] +}
[agent] +
[agent] +MODE=""
[agent] +while [ "$#" -gt 0 ]; do
[agent] +  case "$1" in
[agent] +    --mode)
[agent] +      shift
[agent] +      [ "$#" -gt 0 ] || usage
[agent] +      MODE="$1"
[agent] +      ;;
[agent] +    --mode=*)
[agent] +      MODE="${1#--mode=}"
[agent] +      ;;
[agent] +    *)
[agent] +      usage
[agent] +      ;;
[agent] +  esac
[agent] +  shift
[agent] +done
[agent] +
[agent] +case "$MODE" in
[agent] +  all|app|reporting) ;;
[agent] +  *) usage ;;
[agent] +esac
[agent] +
[agent] +NAMESPACE="${NAMESPACE:-wf-2026-05-21t02-26-08z-workflow-r-483419f5-cluster-a}"
[agent] +SERVICE_NAME="${SERVICE_NAME:-mongodb-replica-svc}"
[agent] +POD_NAME="${POD_NAME:-mongodb-replica-0}"
[agent] +REPLICA_SET="${REPLICA_SET:-mongodb-replica}"
[agent] +ADMIN_USER="${ADMIN_USER:-admin-user}"
[agent] +ADMIN_SECRET="${ADMIN_SECRET:-admin-user-password}"
[agent] +APP_USER="${APP_USER:-app-user}"
[agent] +APP_SECRET="${APP_SECRET:-app-user-password}"
[agent] +REPORTING_USER="${REPORTING_USER:-reporting-user}"
[agent] +REPORTING_SECRET="${REPORTING_SECRET:-reporting-user-password}"
[agent] +APP_DB="${APP_DB:-appdb}"
[agent] +REPORTS_COLLECTION="${REPORTS_COLLECTION:-reports}"
[agent] +
[agent] +get_password() {
[agent] +  kubectl -n "$NAMESPACE" get secret "$1" -o jsonpath='{.data.password}' | base64 -d
[agent] +}
[agent] +
[agent] +ADMIN_PASSWORD="$(get_password "$ADMIN_SECRET")"
[agent] +APP_PASSWORD="$(get_password "$APP_SECRET")"
[agent] +REPORTING_PASSWORD="$(get_password "$REPORTING_SECRET")"
[agent] +MONGO_URI="mongodb://${ADMIN_USER}:${ADMIN_PASSWORD}@${POD_NAME}.${SERVICE_NAME}.${NAMESPACE}.svc.cluster.local:27017/admin?replicaSet=${REPLICA_SET}&authSource=admin"
[agent] +
[agent] +mongo_eval() {
[agent] +  kubectl -n "$NAMESPACE" exec "$POD_NAME" -- env \
[agent] +    APP_USER="$APP_USER" \
[agent] +    APP_PASSWORD="$APP_PASSWORD" \
[agent] +    REPORTING_USER="$REPORTING_USER" \
[agent] +    REPORTING_PASSWORD="$REPORTING_PASSWORD" \
[agent] +    APP_DB="$APP_DB" \
[agent] +    REPORTS_COLLECTION="$REPORTS_COLLECTION" \
[agent] +    mongosh "$MONGO_URI" --quiet --eval "$1"
[agent] +}
[agent] +
[agent] +reset_app_js='
[agent] +const adminDb = db.getSiblingDB("admin");
[agent] +const appUser = process.env.APP_USER;
[agent] +const appDb = process.env.APP_DB;
[agent] +const roles = [{ role: "readWrite", db: appDb }];
[agent] +
[agent] +if (adminDb.getUser(appUser)) {
[agent] +  adminDb.updateUser(appUser, { roles });
[agent] +} else {
[agent] +  adminDb.createUser({ user: appUser, pwd: process.env.APP_PASSWORD, roles });
[agent] +}
[agent] +'
[agent] +
[agent] +reset_reporting_js='
[agent] +const adminDb = db.getSiblingDB("admin");
[agent] +const appDb = db.getSiblingDB(process.env.APP_DB);
[agent] +const reportingUser = process.env.REPORTING_USER;
[agent] +const reportingRole = "reportingRole";
[agent] +const reportsCollection = process.env.REPORTS_COLLECTION;
[agent] +const rolePrivileges = [
[agent] +  {
[agent] +    resource: { db: process.env.APP_DB, collection: reportsCollection },
[agent] +    actions: ["find"]
[agent] +  }
[agent] +];
[agent] +const roles = [{ role: reportingRole, db: process.env.APP_DB }];
[agent] +
[agent] +if (appDb.getRole(reportingRole, { showPrivileges: true })) {
[agent] +  appDb.updateRole(reportingRole, { privileges: rolePrivileges, roles: [] });
[agent] +} else {
[agent] +  appDb.createRole({ role: reportingRole, privileges: rolePrivileges, roles: [] });
[agent] +}
[agent] +
[agent] +if (adminDb.getUser(reportingUser)) {
[agent] +  adminDb.updateUser(reportingUser, { roles });
[agent] +} else {
[agent] +  adminDb.createUser({ user: reportingUser, pwd: process.env.REPORTING_PASSWORD, roles });
[agent] +}
[agent] +
[agent] +if (appDb.getRole("rawRead")) {
[agent] +  appDb.dropRole("rawRead");
[agent] +}
[agent] +'
[agent] +
[agent] +case "$MODE" in
[agent] +  app)
[agent] +    mongo_eval "$reset_app_js"
[agent] +    ;;
[agent] +  reporting)
[agent] +    mongo_eval "$reset_reporting_js"
[agent] +    ;;
[agent] +  all)
[agent] +    mongo_eval "$reset_app_js"
[agent] +    mongo_eval "$reset_reporting_js"
[agent] +    ;;
[agent] +esac
