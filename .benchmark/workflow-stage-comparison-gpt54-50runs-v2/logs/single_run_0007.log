/\\\\\"/g; s/^/\"/; s/$/\"/');\nconst reportingPassword = $(printf '%s' \"$REPORTING_PASSWORD\" | sed 's/\\\\/\\\\\\\\/g; s/\"/\\\\\"/g; s/^/\"/; s/$/\"/');\nconst adminDb = db.getSiblingDB(\"admin\");\nconst appDb = db.getSiblingDB(\"$APP_DATABASE\");\n\nfunction ensureUser(dbRef, username, password, roles) {\n  const existing = dbRef.getUser(username);\n  if (existing) {\n    dbRef.updateUser(username, { pwd: password, roles: roles });\n  } else {\n    dbRef.createUser({ user: username, pwd: password, roles: roles });\n  }\n}\n\nfunction ensureReportingRole() {\n  const roleDefinition = {\n    privileges: [\n      {\n        resource: { db: \"$APP_DATABASE\", collection: \"$REPORTS_COLLECTION\" },\n        actions: [\"find\"]\n      }\n    ],\n    roles: []\n  };\n  const existing = appDb.getRole(\"$REPORTING_ROLE_NAME\", { showPrivileges: true });\n  if (existing) {\n    appDb.updateRole(\"$REPORTING_ROLE_NAME\", roleDefinition);\n  } else {\n    appDb.createRole(Object.assign({ role: \"$REPORTING_ROLE_NAME\" }, roleDefinition));\n  }\n}\n\nswitch (\"$MODE\") {\n  case \"app\":\n    ensureUser(adminDb, \"$APP_USERNAME\", appPassword, [{ role: \"readWrite\", db: \"$APP_DATABASE\" }]);\n    break;\n  case \"reporting\":\n    ensureReportingRole();\n    ensureUser(adminDb, \"$REPORTING_USERNAME\", reportingPassword, [{ role: \"$REPORTING_ROLE_NAME\", db: \"$APP_DATABASE\" }]);\n    break;\n  case \"all\":\n    ensureUser(adminDb, \"$APP_USERNAME\", appPassword, [{ role: \"readWrite\", db: \"$APP_DATABASE\" }]);\n    ensureReportingRole();\n    ensureUser(adminDb, \"$REPORTING_USERNAME\", reportingPassword, [{ role: \"$REPORTING_ROLE_NAME\", db: \"$APP_DATABASE\" }]);\n    break;\n  default:\n    throw new Error(\"Unsupported mode\");\n}\nEOF\n}\n\nbuild_js | kubectl_ns exec -i \"$PRIMARY_POD\" -- mongosh --quiet \\\n  -u \"$ADMIN_USERNAME\" \\\n  -p \"$ADMIN_PASSWORD\" \\\n  --authenticationDatabase admin\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creation