[agent] +
[agent] +run_mongosh() {
[agent] +  kubectl -n "$NAMESPACE" exec "$POD_NAME" -- \
[agent] +    mongosh --quiet \
[agent] +      --authenticationDatabase admin \
[agent] +      -u "$ADMIN_USERNAME" \
[agent] +      -p "$ADMIN_PASSWORD" \
[agent] +      --eval "$1"
[agent] +}
[agent] +
[agent] +reset_app() {
[agent] +  run_mongosh '
[agent] +    db.getSiblingDB("admin").updateUser(
[agent] +      "'"$APP_USER"'",
[agent] +      { roles: [ { role: "readWrite", db: "'"$APP_DB"'" } ] }
[agent] +    );
[agent] +  '
[agent] +}
[agent] +
[agent] +reset_reporting() {
[agent] +  run_mongosh '
[agent] +    const appdb = db.getSiblingDB("'"$APP_DB"'");
[agent] +    const roleName = "'"$REPORTING_ROLE"'";
[agent] +    const roleSpec = {
[agent] +      privileges: [
[agent] +        {
[agent] +          resource: { db: "'"$APP_DB"'", collection: "'"$REPORTS_COLLECTION"'" },
[agent] +          actions: ["find"]
[agent] +        }
[agent] +      ],
[agent] +      roles: []
[agent] +    };
[agent] +
[agent] +    if (appdb.getRole(roleName, { showPrivileges: true })) {
[agent] +      appdb.updateRole(roleName, roleSpec);
[agent] +    } else {
[agent] +      appdb.createRole(Object.assign({ role: roleName }, roleSpec));
[agent] +    }
[agent] +
[agent] +    db.getSiblingDB("admin").updateUser(
[agent] +      "'"$REPORTING_USER"'",
[agent] +      { roles: [ { role: roleName, db: "'"$APP_DB"'" } ] }
[agent] +    );
[agent] +  '
[agent] +}
[agent] +
[agent] +case "$MODE" in
