reateRole(Object.assign({ role: roleName }, roleSpec));\n    }\n\n    db.getSiblingDB(\"admin\").updateUser(\n      \"'\"$REPORTING_USER\"'\",\n      { roles: [ { role: roleName, db: \"'\"$APP_DB\"'\" } ] }\n    );\n  '\n}\n\ncase \"$MODE\" in\n  app)\n    reset_app\n    ;;\n  reporting)\n    reset_reporting\n    ;;\n  all)\n    reset_app\n    reset_reporting\n    ;;\nesac\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-20t21-06-11z-workflow-r-3c81edc0-cluster-a"}}
