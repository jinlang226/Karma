[agent] +ADMIN_SECRET="${ADMIN_SECRET_NAME:-admin-user-password}"
[agent] +ADMIN_USERNAME="${ADMIN_USERNAME:-admin-user}"
[agent] +APP_DB="${APP_DB:-appdb}"
