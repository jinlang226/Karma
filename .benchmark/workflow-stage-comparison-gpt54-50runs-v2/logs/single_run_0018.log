[agent] +#!/bin/sh
[agent] +set -eu
[agent] +
[agent] +NAMESPACE="${NAMESPACE:-wf-2026-05-20t20-02-06z-workflow-r-f24b5650-cluster-a}"
[agent] +STATEFULSET_NAME="${STATEFULSET_NAME:-mongodb-replica}"
[agent] +EXPECTED_REPLICAS="${EXPECTED_REPLICAS:-3}"
[agent] +ADMIN_SECRET_NAME="${ADMIN_SECRET_NAME:-admin-user-password}"
[agent] +APP_SECRET_NAME="${APP_SECRET_NAME:-app-user-password}"
[agent] +REPORTING_SECRET_NAME="${REPORTING_SECRET_NAME:-reporting-user-password}"
[agent] +ADMIN_USER="${ADMIN_USER:-admin-user}"
[agent] +APP_DB="${APP_DB:-appdb}"
[agent] +APP_USER="${APP_USER:-app-user}"
[agent] +REPORTING_USER="${REPORTING_USER:-reporting-user}"
[agent] +REPORTING_ROLE="${REPORTING_ROLE:-reportingRole}"
[agent] +REPORTS_COLLECTION="${REPORTS_COLLECTION:-reports}"
[agent] +
[agent] +usage() {
[agent] +  cat <<'EOF'
[agent] +Usage: reset_rbac.sh --mode all|app|reporting
[agent] +EOF
[agent] +}
[agent] +
[agent] +json_escape() {
[agent] +  printf '%s' "$1" | sed 's/\\/\\\\/g; s/"/\\"/g'
[agent] +}
[agent] +
[agent] +get_secret_field() {
[agent] +  secret_name="$1"
[agent] +  field_name="${2:-password}"
[agent] +  kubectl -n "$NAMESPACE" get secret "$secret_name" -o "jsonpath={.data.$field_name}" | base64 -d
[agent] +}
[agent] +
[agent] +find_primary_pod() {
[agent] +  index=0
[agent] +  while [ "$index" -lt "$EXPECTED_REPLICAS" ]; do
[agent] +    pod_name="${STATEFULSET_NAME}-${index}"
[agent] +    if kubectl -n "$NAMESPACE" get pod "$pod_name" >/dev/null 2>&1; then
[agent] +      if [ "$(kubectl -n "$NAMESPACE" exec "$pod_name" -- mongosh --quiet -u "$ADMIN_USER" -p "$ADMIN_PASS" --authenticationDatabase admin --eval 'db.hello().isWritablePrimary')" = "true" ]; then
[agent] +        printf '%s\n' "$pod_name"
[agent] +        return 0
[agent] +      fi
[agent] +    fi
[agent] +    index=$((index + 1))
[agent] +  done
[agent] +
[agent] +  echo "Unable to find writable primary pod in $NAMESPACE" >&2
[agent] +  return 1
[agent] +}
[agent] +
[agent] +MODE=""
[agent] +while [ "$#" -gt 0 ]; do
[agent] +  case "$1" in
[agent] +    --mode)
[agent] +      shift
[agent] +      MODE="${1:-}"
[agent] +      ;;
[agent] +    --help|-h)
[agent] +      usage
[agent] +      exit 0
[agent] +      ;;
[agent] +    *)
[agent] +      echo "Unknown argument: $1" >&2
[agent] +      usage >&2
[agent] +      exit 1
[agent] +      ;;
[agent] +  esac
[agent] +  shift
[agent] +done
[agent] +
[agent] +case "$MODE" in
[agent] +  all|app|reporting)
[agent] +    ;;
[agent] +  *)
[agent] +    echo "A valid --mode is required." >&2
[agent] +    usage >&2
[agent] +    exit 1
[agent] +    ;;
[agent] +esac
[agent] +
[agent] +ADMIN_PASS="$(get_secret_field "$ADMIN_SECRET_NAME")"
[agent] +APP_PASS="$(get_secret_field "$APP_SECRET_NAME")"
[agent] +REPORTING_PASS="$(get_secret_field "$REPORTING_SECRET_NAME")"
[agent] +PRIMARY_POD="$(find_primary_pod)"
[agent] +
[agent] +TMP_JS="$(mktemp)"
[agent] +trap 'rm -f "$TMP_JS"' EXIT INT TERM
[agent] +
[agent] +cat >"$TMP_JS" <<EOF
[agent] +const mode = "$(json_escape "$MODE")";
[agent] +const appDbName = "$(json_escape "$APP_DB")";
[agent] +const appUser = "$(json_escape "$APP_USER")";
[agent] +const appPass = "$(json_escape "$APP_PASS")";
[agent] +const reportingUser = "$(json_escape "$REPORTING_USER")";
[agent] +const reportingPass = "$(json_escape "$REPORTING_PASS")";
[agent] +const reportingRole = "$(json_escape "$REPORTING_ROLE")";
[agent] +const reportsCollection = "$(json_escape "$REPORTS_COLLECTION")";
[agent] +
[agent] +const appDb = db.getSiblingDB(appDbName);
[agent] +
[agent] +function upsertUser(targetDb, username, password, roles) {
[agent] +  if (targetDb.getUser(username)) {
[agent] +    targetDb.updateUser(username, { pwd: password, roles });
[agent] +  } else {
[agent] +    targetDb.createUser({ user: username, pwd: password, roles });
[agent] +  }
[agent] +}
[agent] +
[agent] +if (mode === "all" || mode === "app") {
[agent] +  upsertUser(appDb, appUser, appPass, [{ role: "readWrite", db: appDbName }]);
[agent] +}
[agent] +
[agent] +if (mode === "all" || mode === "reporting") {
[agent] +  const privileges = [
[agent] +    {
[agent] +      resource: { db: appDbName, collection: reportsCollection },
[agent] +      actions: ["find"]
[agent] +    }
[agent] +  ];
[agent] +
[agent] +  if (appDb.getRole(reportingRole, { showPrivileges: true, showBuiltinRoles: false })) {
[agent] +    appDb.updateRole(reportingRole, { privileges, roles: [] });
[agent] +  } else {
[agent] +    appDb.createRole({ role: reportingRole, privileges, roles: [] });
[agent] +  }
[agent] +
[agent] +  upsertUser(
[agent] +    appDb,
[agent] +    reportingUser,
[agent] +    reportingPass,
[agent] +    [{ role: reportingRole, db: appDbName }]
[agent] +  );
[agent] +}
[agent] +
[agent] +printjson({
[agent] +  ok: 1,
[agent] +  mode,
[agent] +  appUser: appDb.getUser(appUser),
[agent] +  reportingUser: appDb.getUser(reportingUser),
[agent] +  reportingRole: appDb.getRole(reportingRole, { showPrivileges: true, showBuiltinRoles: false })
[agent] +});
[agent] +EOF
[agent] +
[agent] +kubectl -n "$NAMESPACE" exec -i "$PRIMARY_POD" -- sh -lc '
[agent] +  remote_js="$(mktemp /tmp/reset_rbac.XXXXXX.js)" &&
[agent] +  cat >"$remote_js" &&
[agent] +  mongosh --quiet -u "$1" -p "$2" --authenticationDatabase admin "$remote_js"
[agent] +  status=$?
[agent] +  rm -f "$remote_js"
[agent] +  exit $status
[agent] +' sh "$ADMIN_USER" "$ADMIN_PASS" <"$TMP_JS"
