[kubectl] 2026-05-21T01:55:08Z kubectl -n wf-2026-05-21t01-51-52z-workflow-r-7aef2b52-cluster-a exec mongodb-replica-0 -- mongosh --quiet -u admin-user -p admin123password --authenticationDatabase admin --eval '
    const appdb = db.getSiblingDB("appdb");
    const admin = db.getSiblingDB("admin");
    const roleSpec = {
      privileges: [
        {
          resource: { db: "appdb", collection: "reports" },
          actions: ["find"]
        }
      ],
      roles: []
    };

    if (appdb.getRole("reportingRole", { showPrivileges: true }) === null) {
      appdb.createRole(Object.assign({ role: "reportingRole" }, roleSpec));
    } else {
      appdb.updateRole("reportingRole", roleSpec);
    }

    admin.updateUser("reporting-user", { roles: [{ role: "reportingRole", db: "appdb" }] });
  '
