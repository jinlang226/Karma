[agent] +  mongo_eval 'db.getSiblingDB("admin").updateUser("app-user", {roles: [{role: "readWrite", db: "appdb"}]})'
[agent] +}
[agent] +
[agent] +reset_reporting() {
[agent] +  mongo_eval '
[agent] +    const appdb = db.getSiblingDB("appdb");
[agent] +    const admin = db.getSiblingDB("admin");
[agent] +    const roleSpec = {
[agent] +      privileges: [
[agent] +        {
[agent] +          resource: { db: "appdb", collection: "reports" },
[agent] +          actions: ["find"]
[agent] +        }
[agent] +      ],
[agent] +      roles: []
[agent] +    };
[agent] +
[agent] +    if (appdb.getRole("reportingRole", { showPrivileges: true }) === null) {
[agent] +      appdb.createRole(Object.assign({ role: "reportingRole" }, roleSpec));
[agent] +    } else {
[agent] +      appdb.updateRole("reportingRole", roleSpec);
[agent] +    }
[agent] +
[agent] +    admin.updateUser("reporting-user", { roles: [{ role: "reportingRole", db: "appdb" }] });
[agent] +  '
[agent] +}
[agent] +
[agent] +case "$MODE" in
[agent] +  app)
[agent] +    reset_app
[agent] +    ;;
[agent] +  reporting)
[agent] +    reset_reporting
[agent] +    ;;
[agent] +  all)
