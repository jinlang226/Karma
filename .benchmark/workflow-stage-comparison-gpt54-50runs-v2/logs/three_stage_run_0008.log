[agent] +data:
[agent] +  reset_rbac.sh: |
[agent] +    #!/bin/sh
[agent] +    set -eu
[agent] +
[agent] +    NAMESPACE="wf-2026-05-20t07-56-10z-workflow-r-302b7fc7-cluster-a"
[agent] +    POD="mongodb-replica-0"
[agent] +    ADMIN_SECRET="admin-user-password"
[agent] +    ADMIN_USERNAME="admin-user"
[agent] +    REPLICA_SET="mongodb-replica"
[agent] +    HOSTS="mongodb-replica-0.mongodb-replica-svc,mongodb-replica-1.mongodb-replica-svc,mongodb-replica-2.mongodb-replica-svc"
[agent] +
[agent] +    usage() {
[agent] +      echo "Usage: $0 --mode all|app|reporting" >&2
[agent] +      exit 1
[agent] +    }
[agent] +
[agent] +    MODE=""
[agent] +    while [ "$#" -gt 0 ]; do
[agent] +      case "$1" in
[agent] +        --mode)
[agent] +          [ "$#" -ge 2 ] || usage
[agent] +          MODE="$2"
[agent] +          shift 2
[agent] +          ;;
[agent] +        -h|--help)
[agent] +          usage
[agent] +          ;;
[agent] +        *)
[agent] +          usage
[agent] +          ;;
[agent] +      esac
[agent] +    done
[agent] +
[agent] +    case "$MODE" in
[agent] +      all|app|reporting)
[agent] +        ;;
[agent] +      *)
[agent] +        usage
[agent] +        ;;
[agent] +    esac
[agent] +
[agent] +    ADMIN_PASSWORD="$(kubectl -n "$NAMESPACE" get secret "$ADMIN_SECRET" -o jsonpath='{.data.password}' | base64 -d)"
[agent] +    MONGO_TARGET="$HOSTS/admin?replicaSet=$REPLICA_SET"
[agent] +
[agent] +    run_mongo() {
[agent] +      kubectl -n "$NAMESPACE" exec "$POD" -- env \
[agent] +        ADMIN_USERNAME="$ADMIN_USERNAME" \
[agent] +        ADMIN_PASSWORD="$ADMIN_PASSWORD" \
[agent] +        MONGO_TARGET="$MONGO_TARGET" \
[agent] +        sh -lc "mongosh --quiet --host \"\$MONGO_TARGET\" --authenticationDatabase admin -u \"\$ADMIN_USERNAME\" -p \"\$ADMIN_PASSWORD\" --eval '$1'"
[agent] +    }
[agent] +
[agent] +    reset_app() {
[agent] +      run_mongo 'db.getSiblingDB("admin").updateUser("app-user", {roles: [{role: "readWrite", db: "appdb"}]})'
[agent] +    }
[agent] +
