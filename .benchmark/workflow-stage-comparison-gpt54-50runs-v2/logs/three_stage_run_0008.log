[agent] +      run_mongo '\''const appdb = db.getSiblingDB("appdb");
[agent] +      const roleName = "reportingRole";
[agent] +      const desiredPrivileges = [{ resource: { db: "appdb", collection: "reports" }, actions: ["find"] }];
[agent] +      if (appdb.getRole(roleName, { showPrivileges: true })) {
[agent] +        appdb.updateRole(roleName, { privileges: desiredPrivileges, roles: [] });
[agent] +      } else {
[agent] +        appdb.createRole({ role: roleName, privileges: desiredPrivileges, roles: [] });
[agent] +      }
[agent] +      db.getSiblingDB("admin").updateUser("reporting-user", { roles: [{ role: roleName, db: "appdb" }] });'\''
[agent] +    }
[agent] +
[agent] +    case "$MODE" in
[agent] +      app)
[agent] +        reset_app
[agent] +        ;;
