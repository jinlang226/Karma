.env.REPORTING_USER;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRole = process.env.REPORTING_ROLE;\n\nconst appDb = db.getSiblingDB(appDbName);\n\nfunction ensureUser(targetDb, username, password, roles) {\n  if (targetDb.getUser(username)) {\n    targetDb.updateUser(username, { pwd: password, roles: roles });\n  } else {\n    targetDb.createUser({ user: username, pwd: password, roles: roles });\n  }\n}\n\nfunction ensureReportingRole() {\n  const privileges = [\n    {\n      resource: { db: appDbName, collection: \"reports\" },\n      actions: [\"find\"],\n    },\n  ];\n  if (appDb.getRole(reportingRole, { showPrivileges: true })) {\n    appDb.updateRole(reportingRole, { privileges: privileges, roles: [] });\n  } else {\n    appDb.createRole({ role: reportingRole, privileges: privileges, roles: [] });\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  ensureUser(appDb, appUser, appPassword, [{ role: \"readWrite\", db: appDbName }]);\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  ensureReportingRole();\n  ensureUser(appDb, reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);\n}\nEOF\n  '\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-20t05-56-50z-workflow-r-a12df44f-cluster-a"}}
