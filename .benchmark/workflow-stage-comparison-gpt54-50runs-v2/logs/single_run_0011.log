[kubectl] 2026-05-20T05:59:02Z kubectl -n wf-2026-05-20t05-56-50z-workflow-r-a12df44f-cluster-a exec -i mongodb-replica-0 -- env ADMIN_PASSWORD=admin123password APP_PASSWORD=app123password REPORTING_PASSWORD=reporting123password RESET_MODE=all APP_DB=appdb APP_USER=app-user REPORTING_USER=reporting-user REPORTING_ROLE=reportingRole HOSTS=mongodb-replica-0.mongodb-replica-svc:27017,mongodb-replica-1.mongodb-replica-svc:27017,mongodb-replica-2.mongodb-replica-svc:27017 REPLICA_SET=mongodb-replica sh -lc '
    cat <<'"'"'EOF'"'"' | mongosh --quiet "mongodb://admin-user:${ADMIN_PASSWORD}@${HOSTS}/admin?replicaSet=${REPLICA_SET}" /dev/stdin
const mode = process.env.RESET_MODE;
const appDbName = process.env.APP_DB;
const appUser = process.env.APP_USER;
const appPassword = process.env.APP_PASSWORD;
const reportingUser = process.env.REPORTING_USER;
const reportingPassword = process.env.REPORTING_PASSWORD;
const reportingRole = process.env.REPORTING_ROLE;

const appDb = db.getSiblingDB(appDbName);

function ensureUser(targetDb, username, password, roles) {
  if (targetDb.getUser(username)) {
    targetDb.updateUser(username, { pwd: password, roles: roles });
  } else {
    targetDb.createUser({ user: username, pwd: password, roles: roles });
  }
}

function ensureReportingRole() {
  const privileges = [
    {
      resource: { db: appDbName, collection: "reports" },
      actions: ["find"],
    },
  ];
  if (appDb.getRole(reportingRole, { showPrivileges: true })) {
    appDb.updateRole(reportingRole, { privileges: privileges, roles: [] });
  } else {
    appDb.createRole({ role: reportingRole, privileges: privileges, roles: [] });
  }
}

if (mode === "all" || mode === "app") {
  ensureUser(appDb, appUser, appPassword, [{ role: "readWrite", db: appDbName }]);
}

if (mode === "all" || mode === "reporting") {
  ensureReportingRole();
  ensureUser(appDb, reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);
}
EOF
  '
