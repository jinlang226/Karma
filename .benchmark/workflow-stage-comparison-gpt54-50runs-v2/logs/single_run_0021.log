[agent] +const reportsCollection = process.env.REPORTS_COLLECTION;
[agent] +
[agent] +function roleDoc(role, dbName) {
[agent] +  return { role, db: dbName };
[agent] +}
[agent] +
[agent] +function sameRole(left, right) {
[agent] +  return left.role === right.role && left.db === right.db;
[agent] +}
[agent] +
[agent] +function ensureUser(dbRef, username, password, roles) {
[agent] +  const existing = dbRef.getUser(username);
[agent] +  if (existing) {
