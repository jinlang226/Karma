 /dev/stdin \u003c\u003c'EOF'\nconst admin = db.getMongo().getDB(\"admin\");\nconst appdb = db.getMongo().getDB(process.env.APP_DB);\nconst mode = process.env.MODE;\nconst appUser = process.env.APP_USER;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUser = process.env.REPORTING_USER;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRole = process.env.REPORTING_ROLE;\nconst legacyRole = process.env.LEGACY_ROLE;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\n\nfunction roleDoc(role, dbName) {\n  return { role, db: dbName };\n}\n\nfunction sameRole(left, right) {\n  return left.role === right.role \u0026\u0026 left.db === right.db;\n}\n\nfunction ensureUser(dbRef, username, password, roles) {\n  const existing = dbRef.getUser(username);\n  if (existing) {\n    dbRef.updateUser(username, { pwd: password, roles });\n  } else {\n    dbRef.createUser({ user: username, pwd: password, roles });\n  }\n}\n\nfunction ensureRole() {\n  const privilege = {\n    resource: { db: process.env.APP_DB, collection: reportsCollection },\n    actions: [\"find\"],\n  };\n  const existing = appdb.getRole(reportingRole, { showPrivileges: true });\n  if (existing) {\n    const roles = existing.roles || [];\n    const privileges = existing.privileges || [];\n    const exactPrivilege =\n      privileges.length === 1 \u0026\u0026\n      privileges[0].resource \u0026\u0026\n      privileges[0].resource.db === privilege.resource.db \u0026\u0026\n      privileges[0].resource.collection === privilege.resource.collection \u0026\u0026\n      Array.isArray(privileges[0].actions) \u0026\u0026\n      privileges[0].actions.length === 1 \u0026\u0026\n      privileges[0].actions[0] === \"find\";\n    if (!exactPrivilege || roles.length !== 0) {\n      appdb.updateRole(reportingRole, { privileges: [privilege], roles: [] });\n    }\n  } else {\n    appdb.createRole({ role: reportingRole, privileges: [privilege], roles: [] });\n  }\n}\n\nfunction ensureAppUser() {\n  ensureUser(appdb, appUser, appPassword, [roleDoc(\"readWrite\", process.env.APP_DB)]);\n}\n\nfunction ensureReporting() {\n  ensureRole();\n  const desiredRoles = [roleDoc(reportingRole, process.env.APP_DB)];\n  const existing = appdb.getUser(reportingUser);\n  if (existing) {\n    const filteredRoles = (existing.roles || []).filter((role) =\u003e !sameRole(role, roleDoc(legacyRole, process.env.APP_DB)));\n    const exact = filteredRoles.length === desiredRoles.length \u0026\u0026 filteredRoles.every((role) =\u003e sameRole(role, desiredRoles[0]));\n    if (!exact || existing.roles.length !== filteredRoles.length) {\n      appdb.updateUser(reportingUser, { roles: desiredRoles });\n    } else {\n      appdb.updateUser(reportingUser, { pwd: reportingPassword, roles: desiredRoles });\n    }\n  } else {\n    appdb.createUser({ user: reportingUser, pwd: reportingPassword, roles: desiredRoles });\n  }\n}\n\nif (mode === \"app\" || mode === \"all\") {\n  ensureAppUser();\n}\n\nif (mode === \"reporting\" || mode === \"all\") {\n  ensureReporting();\n}\n\nprintjson({\n  ok: 1,\n  mode,\n  appUser: appdb.getUser(appUser),\n  reportingUser: appdb.getUser(reportingUser),\n  reportingRole: appdb.getRole(reportingRole, { showPrivileges: true }),\n});\nEOF\n}\n\nrun_js\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-20t20-19-41z-workflow-r-3f8ac20b-cluster-a"}}
