[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/bin/sh\nset -eu\n\nusage() {\n  echo \"Usage: $0 --mode all|app|reporting\" \u003e\u00262\n}\n\nMODE=\"\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      [ \"$#\" -ge 2 ] || { usage; exit 2; }\n      MODE=\"$2\"\n      shift 2\n      ;;\n    --mode=*)\n      MODE=\"${1#--mode=}\"\n      shift\n      ;;\n    -h|--help)\n      usage\n      exit 0\n      ;;\n    *)\n      usage\n      exit 2\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *) usage; exit 2 ;;\nesac\n\nADMIN_USERNAME=\"${ADMIN_USERNAME:-admin-user}\"\nADMIN_PASSWORD=\"${ADMIN_PASSWORD:-admin123password}\"\nAPP_USERNAME=\"${APP_USERNAME:-app-user}\"\nAPP_PASSWORD=\"${APP_PASSWORD:-app123password}\"\nREPORTING_USERNAME=\"${REPORTING_USERNAME:-reporting-user}\"\nREPORTING_PASSWORD=\"${REPORTING_PASSWORD:-reporting123password}\"\nAPP_DATABASE=\"${APP_DATABASE:-appdb}\"\nREPORTING_ROLE_NAME=\"${REPORTING_ROLE_NAME:-reportingRole}\"\nBAD_ROLE_NAME=\"${BAD_ROLE_NAME:-rawRead}\"\nREPORTS_COLLECTION=\"${REPORTS_COLLECTION:-reports}\"\nMONGO_HOST=\"${MONGO_HOST:-localhost:27017}\"\nAUTH_DATABASE=\"${AUTH_DATABASE:-admin}\"\nUSER_DATABASE=\"${USER_DATABASE:-admin}\"\n\nexport RESET_MODE=\"$MODE\"\nexport APP_USERNAME APP_PASSWORD REPORTING_USERNAME REPORTING_PASSWORD\nexport APP_DATABASE REPORTING_ROLE_NAME BAD_ROLE_NAME REPORTS_COLLECTION USER_DATABASE\n\nMONGO_SCRIPT=$(cat \u003c\u003c'MONGOJS'\nconst mode = process.env.RESET_MODE;\nconst userDbName = process.env.USER_DATABASE;\nconst appDbName = process.env.APP_DATABASE;\nconst appUser = process.env.APP_USERNAME;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUser = process.env.REPORTING_USERNAME;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRole = process.env.REPORTING_ROLE_NAME;\nconst badRole = process.env.BAD_ROLE_NAME;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\n\nconst userDb = db.getSiblingDB(userDbName);\nconst appDb = db.getSiblingDB(appDbName);\n\nfunction ensureUser(database, username, password, roles) {\n  const existing = database.getUser(username);\n  if (existing) {\n    database.updateUser(username, { pwd: password, roles });\n  } else {\n    database.createUser({ user: username, pwd: password, roles });\n  }\n}\n\nfunction ensureReportingRole() {\n  const desiredPrivileges = [\n    {\n      resource: { db: appDbName, collection: reportsCollection },\n      actions: [\"find\"],\n    },\n  ];\n  const existing = appDb.getRole(reportingRole, { showPrivileges: true });\n  if (existing) {\n    appDb.updateRole(reportingRole, { privileges: desiredPrivileges, roles: [] });\n  } else {\n    appDb.createRole({\n      role: reportingRole,\n      privileges: desiredPrivileges,\n      roles: [],\n    });\n  }\n}\n\nfunction resetAppUser() {\n  ensureUser(userDb, appUser, appPassword, [\n    { role: \"readWrite\", db: appDbName },\n  ]);\n}\n\nfunction resetReportingUser() {\n  ensureReportingRole();\n  ensureUser(userDb, reportingUser, reportingPassword, [\n    { role: reportingRole, db: appDbName },\n  ]);\n  if (appDb.getRole(badRole)) {\n    appDb.dropRole(badRole);\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  resetAppUser();\n}\nif (mode === \"all\" || mode === \"reporting\") {\n  resetReportingUser();\n}\n\nprint(`rbac reset complete: mode=${mode}`);\nMONGOJS\n)\n\nmongosh --quiet --host \"$MONGO_HOST\" \\\n  -u \"$ADMIN_USERNAME\" \\\n  -p \"$ADMIN_PASSWORD\" \\\n  --authenticationDatabase \"$AUTH_DATABASE\" \\\n  --eval \"$MONGO_SCRIPT\"\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-18t18-11-02z-workflow-r-a698c918-cluster-a"}}
