set -euo pipefail

MODE="all"
while [ "$#" -gt 0 ]; do
  case "$1" in
    --mode)
      if [ "$#" -lt 2 ]; then
        echo "missing value for --mode" >&2
        exit 2
      fi
      MODE="$2"
      shift 2
      ;;
    --mode=*)
      MODE="${1#--mode=}"
      shift
      ;;
    -h|--help)
      echo "usage: $0 [--mode all|app|reporting]"
      exit 0
      ;;
    *)
      echo "unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

case "$MODE" in
  all|app|reporting) ;;
  *)
    echo "invalid mode: $MODE" >&2
    exit 2
    ;;
esac

MONGO_HOST="${MONGO_HOST:-localhost}"
MONGO_PORT="${MONGO_PORT:-27017}"
MONGO_ADMIN_USER="${MONGO_ADMIN_USER:-${ADMIN_USERNAME:-admin-user}}"
MONGO_ADMIN_PASSWORD="${MONGO_ADMIN_PASSWORD:-${ADMIN_PASSWORD:-admin123password}}"
MONGO_AUTH_DB="${MONGO_AUTH_DB:-admin}"
APP_DB="${APP_DB:-appdb}"
APP_USER="${APP_USER:-app-user}"
APP_PASSWORD="${APP_PASSWORD:-app123password}"
REPORTING_USER="${REPORTING_USER:-reporting-user}"
REPORTING_PASSWORD="${REPORTING_PASSWORD:-reporting123password}"
REPORTING_ROLE="${REPORTING_ROLE:-reportingRole}"
REPORTS_COLLECTION="${REPORTS_COLLECTION:-reports}"

mongosh --quiet --host "$MONGO_HOST" --port "$MONGO_PORT" \
  -u "$MONGO_ADMIN_USER" -p "$MONGO_ADMIN_PASSWORD" \
  --authenticationDatabase "$MONGO_AUTH_DB" --eval "
const mode = \"$MODE\";
const appDbName = \"$APP_DB\";
const appUser = \"$APP_USER\";
const appPassword = \"$APP_PASSWORD\";
const reportingUser = \"$REPORTING_USER\";
const reportingPassword = \"$REPORTING_PASSWORD\";
const reportingRole = \"$REPORTING_ROLE\";
const reportsCollection = \"$REPORTS_COLLECTION\";
const adminDb = db.getSiblingDB(\"admin\");
const appDb = db.getSiblingDB(appDbName);

function userExists(name) {
  return adminDb.getUser(name) !== null;
}

function ensureUserRoles(name, password, roles) {
  if (userExists(name)) {
    adminDb.updateUser(name, { roles });
  } else {
    adminDb.createUser({ user: name, pwd: password, roles });
  }
}

function ensureReportingRole() {
  const spec = {
    privileges: [
      { resource: { db: appDbName, collection: reportsCollection }, actions: [\"find\"] }
    ],
    roles: []
  };
  if (appDb.getRole(reportingRole) === null) {
