[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/usr/bin/env bash\nset -euo pipefail\n\nMODE=\"all\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      [ \"$#\" -ge 2 ] || { echo \"missing value for --mode\" \u003e\u00262; exit 2; }\n      MODE=\"$2\"\n      shift 2\n      ;;\n    --mode=*)\n      MODE=\"${1#--mode=}\"\n      shift\n      ;;\n    -h|--help)\n      cat \u003c\u003c'EOF'\nUsage: reset_rbac.sh [--mode all|app|reporting]\n\nIdempotently reset MongoDB RBAC for the benchmark app and reporting users.\nConnection and credential values can be overridden with environment variables:\nMONGO_HOST, MONGO_PORT, ADMIN_USERNAME, ADMIN_PASSWORD, APP_USERNAME,\nAPP_PASSWORD, REPORTING_USERNAME, REPORTING_PASSWORD.\nEOF\n      exit 0\n      ;;\n    *)\n      echo \"unknown argument: $1\" \u003e\u00262\n      exit 2\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *) echo \"invalid mode '$MODE'; expected all, app, or reporting\" \u003e\u00262; exit 2 ;;\nesac\n\nexport RBAC_MODE=\"$MODE\"\nexport APP_DATABASE=\"${APP_DATABASE:-appdb}\"\nexport REPORTS_COLLECTION=\"${REPORTS_COLLECTION:-reports}\"\nexport APP_USERNAME=\"${APP_USERNAME:-app-user}\"\nexport APP_PASSWORD=\"${APP_PASSWORD:-app123password}\"\nexport REPORTING_USERNAME=\"${REPORTING_USERNAME:-reporting-user}\"\nexport REPORTING_PASSWORD=\"${REPORTING_PASSWORD:-reporting123password}\"\nexport REPORTING_ROLE_NAME=\"${REPORTING_ROLE_NAME:-reportingRole}\"\nexport BAD_ROLE_NAME=\"${BAD_ROLE_NAME:-rawRead}\"\n\nMONGO_HOST=\"${MONGO_HOST:-localhost}\"\nMONGO_PORT=\"${MONGO_PORT:-27017}\"\nADMIN_USERNAME=\"${ADMIN_USERNAME:-admin-user}\"\nADMIN_PASSWORD=\"${ADMIN_PASSWORD:-admin123password}\"\nAUTH_DB=\"${AUTH_DB:-admin}\"\n\nmongosh --quiet --host \"$MONGO_HOST\" --port \"$MONGO_PORT\" \\\n  -u \"$ADMIN_USERNAME\" -p \"$ADMIN_PASSWORD\" \\\n  --authenticationDatabase \"$AUTH_DB\" \u003c\u003c'JS'\nconst mode = process.env.RBAC_MODE;\nconst appDbName = process.env.APP_DATABASE;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\nconst appUsername = process.env.APP_USERNAME;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUsername = process.env.REPORTING_USERNAME;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRoleName = process.env.REPORTING_ROLE_NAME;\nconst badRoleName = process.env.BAD_ROLE_NAME;\n\nconst appDb = db.getSiblingDB(appDbName);\n\nfunction sameRoleSet(a, b) {\n  const normalize = roles =\u003e roles\n    .map(role =\u003e `${role.db}.${role.role}`)\n    .sort()\n    .join(\"\\n\");\n  return normalize(a || []) === normalize(b || []);\n}\n\nfunction ensureUserRoles(database, username, password, roles) {\n  const user = database.getUser(username);\n  if (!user) {\n    database.createUser({ user: username, pwd: password, roles });\n    return;\n  }\n  if (!sameRoleSet(user.roles, roles)) {\n    database.updateUser(username, { roles });\n  }\n}\n\nfunction ensureAppUser() {\n  ensureUserRoles(appDb, appUsername, appPassword, [\n    { role: \"readWrite\", db: appDbName }\n  ]);\n}\n\nfunction ensureReportingRole() {\n  const desiredPrivileges = [{\n    resource: { db: appDbName, collection: reportsCollection },\n    actions: [ \"find\" ]\n  }];\n  const desiredRoles = [];\n  const existing = appDb.getRole(reportingRoleName, { showPrivileges: true });\n  if (!existing) {\n    appDb.createRole({\n      role: reportingRoleName,\n      privileges: desiredPrivileges,\n      roles: desiredRoles\n    });\n    return;\n  }\n  appDb.updateRole(reportingRoleName, {\n    privileges: desiredPrivileges,\n    roles: desiredRoles\n  });\n}\n\nfunction removeDeprecatedRoleFromReportingUser() {\n  const user = appDb.getUser(reportingUsername);\n  if (!user) {\n    return;\n  }\n  const filteredRoles = user.roles.filter(role =\u003e\n    !(role.db === appDbName \u0026\u0026 role.role === badRoleName)\n  );\n  if (!sameRoleSet(user.roles, filteredRoles)) {\n    appDb.updateUser(reportingUsername, { roles: filteredRoles });\n  }\n}\n\nfunction ensureReportingUser() {\n  ensureReportingRole();\n  removeDeprecatedRoleFromReportingUser();\n  ensureUserRoles(appDb, reportingUsername, reportingPassword, [\n    { role: reportingRoleName, db: appDbName }\n  ]);\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  ensureAppUser();\n}\nif (mode === \"all\" || mode === \"reporting\") {\n  ensureReportingUser();\n}\n\nprint(`RBAC reset complete: mode=${mode}`);\nJS\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-18t18-27-14z-workflow-r-c88538d9-cluster-a"}}
