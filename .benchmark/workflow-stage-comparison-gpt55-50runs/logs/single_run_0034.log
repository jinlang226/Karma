 [ -n \"${MONGO_URI:-}\" ]; then\n  URI=\"$MONGO_URI\"\nelse\n  HOSTS=\"${MONGO_HOSTS:-$REPLICA_SET-0.$SERVICE.$NS.svc.cluster.local:27017,$REPLICA_SET-1.$SERVICE.$NS.svc.cluster.local:27017,$REPLICA_SET-2.$SERVICE.$NS.svc.cluster.local:27017}\"\n  URI=\"mongodb://$HOSTS/admin?replicaSet=$REPLICA_SET\"\nfi\n\nexport MODE APP_DB REPORTS_COLLECTION APP_USERNAME REPORTING_USERNAME REPORTING_ROLE BAD_ROLE APP_PASSWORD REPORTING_PASSWORD\n\nmongosh \"$URI\" --quiet -u \"$ADMIN_USERNAME\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin \u003c\u003c'MONGOJS'\nconst mode = process.env.MODE;\nconst appDbName = process.env.APP_DB;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\nconst appUsername = process.env.APP_USERNAME;\nconst reportingUsername = process.env.REPORTING_USERNAME;\nconst reportingRole = process.env.REPORTING_ROLE;\nconst badRole = process.env.BAD_ROLE;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst app = db.getSiblingDB(appDbName);\n\nfunction userExists(database, username) {\n  return database.getUser(username) !== null;\n}\n\nfunction ensureUser(database, username, password, roles) {\n  if (userExists(database, username)) {\n    database.updateUser(username, { pwd: password, roles: roles });\n  } else {\n    database.createUser({ user: username, pwd: password, roles: roles });\n  }\n}\n\nfunction ensureReportingRole() {\n  const privileges = [\n    {\n      resource: { db: appDbName, collection: reportsCollection },\n      actions: [ \"find\" ]\n    }\n  ];\n\n  if (app.getRole(reportingRole, { showPrivileges: true }) === null) {\n    app.createRole({ role: reportingRole, privileges: privileges, roles: [] });\n  } else {\n    app.updateRole(reportingRole, { privileges: privileges, roles: [] });\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  ensureUser(app, appUsername, appPassword, [ { role: \"readWrite\", db: appDbName } ]);\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  ensureReportingRole();\n  ensureUser(app, reportingUsername, reportingPassword, [ { role: reportingRole, db: appDbName } ]);\n\n  const user = app.getUser(reportingUsername);\n  if (user \u0026\u0026 user.roles.some((role) =\u003e role.role === badRole)) {\n    app.updateUser(reportingUsername, { roles: [ { role: reportingRole, db: appDbName } ] });\n  }\n}\n\nprint(`RBAC reset completed for mode=${mode}`);\nMONGOJS\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t01-56-50z-workflow-r-12a4d809-cluster-a"}}
