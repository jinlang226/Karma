const admin=db.getSiblingDB("admin");
const app=db.getSiblingDB("appdb");
function roleExists(dbh, role) { return dbh.getRole(role, {showPrivileges:true}) !== null; }
function userExists(dbh, user) { return dbh.getUser(user) !== null; }
if (roleExists(app, "rawRead")) {
  app.updateRole("rawRead", {privileges:[{resource:{db:"appdb", collection:"raw"}, actions:["find"]}], roles:[]});
} else {
  app.createRole({role:"rawRead", privileges:[{resource:{db:"appdb", collection:"raw"}, actions:["find"]}], roles:[]});
}
if (userExists(admin, "reporting-user")) {
  admin.updateUser("reporting-user", {pwd:"reporting123password", roles:[{role:"rawRead", db:"appdb"}]});
} else {
  admin.createUser({user:"reporting-user", pwd:"reporting123password", roles:[{role:"rawRead", db:"appdb"}]});
}
try { if (roleExists(app, "reportingRole")) app.dropRole("reportingRole"); } catch (e) {
  const users = admin.getUsers().users || [];
  users.forEach(u => {
    const has = (u.roles || []).some(r => r.role === "reportingRole" && r.db === "appdb");
    if (has) admin.revokeRolesFromUser(u.user, [{role:"reportingRole", db:"appdb"}]);
  });
  if (roleExists(app, "reportingRole")) app.dropRole("reportingRole");
}
printjson({rawRead:app.getRole("rawRead", {showPrivileges:true}), reportingRole:app.getRole("reportingRole"), reportingUser:admin.getUser("reporting-user").roles});
'
