[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/usr/bin/env bash\nset -euo pipefail\n\nNAMESPACE=\"${NAMESPACE:-wf-2026-05-18t20-01-43z-workflow-r-7b50c3dc-cluster-a}\"\nPOD=\"${POD:-mongodb-replica-0}\"\nADMIN_USER=\"${ADMIN_USER:-admin-user}\"\nADMIN_SECRET=\"${ADMIN_SECRET:-admin-user-password}\"\nAPP_USER=\"${APP_USER:-app-user}\"\nAPP_SECRET=\"${APP_SECRET:-app-user-password}\"\nREPORTING_USER=\"${REPORTING_USER:-reporting-user}\"\nREPORTING_SECRET=\"${REPORTING_SECRET:-reporting-user-password}\"\nAPP_DB=\"${APP_DB:-appdb}\"\nREPORTS_COLLECTION=\"${REPORTS_COLLECTION:-reports}\"\nREPORTING_ROLE=\"${REPORTING_ROLE:-reportingRole}\"\nBAD_ROLE=\"${BAD_ROLE:-rawRead}\"\nMODE=\"all\"\n\nusage() {\n  printf 'Usage: %s [--mode all|app|reporting]\\n' \"$0\" \u003e\u00262\n}\n\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      [ \"$#\" -ge 2 ] || { usage; exit 2; }\n      MODE=\"$2\"\n      shift 2\n      ;;\n    --mode=*)\n      MODE=\"${1#--mode=}\"\n      shift\n      ;;\n    -h|--help)\n      usage\n      exit 0\n      ;;\n    *)\n      usage\n      exit 2\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *) usage; exit 2 ;;\nesac\n\nsecret_password() {\n  kubectl -n \"$NAMESPACE\" get secret \"$1\" -o jsonpath='{.data.password}' | base64 -d\n}\n\nADMIN_PASSWORD=\"${ADMIN_PASSWORD:-$(secret_password \"$ADMIN_SECRET\")}\"\nAPP_PASSWORD=\"${APP_PASSWORD:-$(secret_password \"$APP_SECRET\")}\"\nREPORTING_PASSWORD=\"${REPORTING_PASSWORD:-$(secret_password \"$REPORTING_SECRET\")}\"\n\nkubectl -n \"$NAMESPACE\" exec \"$POD\" -- \\\n  env RESET_MODE=\"$MODE\" \\\n      APP_USER=\"$APP_USER\" \\\n      APP_PASSWORD=\"$APP_PASSWORD\" \\\n      REPORTING_USER=\"$REPORTING_USER\" \\\n      REPORTING_PASSWORD=\"$REPORTING_PASSWORD\" \\\n      APP_DB=\"$APP_DB\" \\\n      REPORTS_COLLECTION=\"$REPORTS_COLLECTION\" \\\n      REPORTING_ROLE=\"$REPORTING_ROLE\" \\\n      BAD_ROLE=\"$BAD_ROLE\" \\\n  mongosh --quiet -u \"$ADMIN_USER\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin --eval '\nconst mode = process.env.RESET_MODE;\nconst appDbName = process.env.APP_DB;\nconst app = db.getSiblingDB(appDbName);\nconst admin = db.getSiblingDB(\"admin\");\nconst appUser = process.env.APP_USER;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUser = process.env.REPORTING_USER;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\nconst reportingRole = process.env.REPORTING_ROLE;\nconst badRole = process.env.BAD_ROLE;\n\nfunction roleExists(name) {\n  return app.getRole(name, {showPrivileges: true}) !== null;\n}\n\nfunction userExists(name) {\n  return admin.getUser(name) !== null;\n}\n\nfunction setAdminUser(name, password, roles) {\n  if (userExists(name)) {\n    admin.updateUser(name, {pwd: password, roles: roles});\n  } else {\n    admin.createUser({user: name, pwd: password, roles: roles});\n  }\n}\n\nfunction resetAppUser() {\n  setAdminUser(appUser, appPassword, [{role: \"readWrite\", db: appDbName}]);\n}\n\nfunction resetReportingUser() {\n  if (roleExists(reportingRole)) {\n    app.updateRole(reportingRole, {\n      privileges: [{resource: {db: appDbName, collection: reportsCollection}, actions: [\"find\"]}],\n      roles: []\n    });\n  } else {\n    app.createRole({\n      role: reportingRole,\n      privileges: [{resource: {db: appDbName, collection: reportsCollection}, actions: [\"find\"]}],\n      roles: []\n    });\n  }\n\n  setAdminUser(reportingUser, reportingPassword, [{role: reportingRole, db: appDbName}]);\n\n  if (roleExists(badRole)) {\n    try {\n      app.dropRole(badRole);\n    } catch (e) {\n      const users = admin.getUsers().users || [];\n      users.forEach((u) =\u003e {\n        const hasBadRole = (u.roles || []).some((r) =\u003e r.role === badRole \u0026\u0026 r.db === appDbName);\n        if (hasBadRole) {\n          admin.revokeRolesFromUser(u.user, [{role: badRole, db: appDbName}]);\n        }\n      });\n      if (roleExists(badRole)) {\n        app.dropRole(badRole);\n      }\n    }\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  resetAppUser();\n}\nif (mode === \"all\" || mode === \"reporting\") {\n  resetReportingUser();\n}\n\nprintjson({\n  mode,\n  appUserRoles: admin.getUser(appUser).roles,\n  reportingUserRoles: admin.getUser(reportingUser).roles,\n  reportingRole: app.getRole(reportingRole, {showPrivileges: true}),\n  rawReadRole: app.getRole(badRole, {showPrivileges: true})\n});\n'"},"kind":"ConfigMap","metadata":{"annotations":{},"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-18t20-01-43z-workflow-r-7b50c3dc-cluster-a"}}
