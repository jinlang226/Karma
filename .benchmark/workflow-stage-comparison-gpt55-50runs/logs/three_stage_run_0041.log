[agent] Stage 2 needs deliberate drift: a narrow `rawRead` role on `appdb.raw`, no `reportingRole`, and `reporting-user` assigned only that deprecated role. I’m applying that through MongoDB’s role/user APIs so repeated runs remain deterministic.
[kubectl] 2026-05-19T06:32:23Z kubectl -n wf-2026-05-19t06-30-07z-workflow-r-1085c72d-cluster-a exec mongodb-replica-0 -- mongosh --quiet -u admin-user -p admin123password --authenticationDatabase admin --eval '
const app = db.getSiblingDB("appdb");
const admin = db.getSiblingDB("admin");
const roleNames = app.getRoles().roles.map(r => r.role);
if (roleNames.includes("reportingRole")) {
  app.dropRole("reportingRole");
}
if (roleNames.includes("rawRead")) {
  app.updateRole("rawRead", { privileges: [ { resource: { db: "appdb", collection: "raw" }, actions: [ "find" ] } ], roles: [] });
} else {
  app.createRole({ role: "rawRead", privileges: [ { resource: { db: "appdb", collection: "raw" }, actions: [ "find" ] } ], roles: [] });
}
const reporting = admin.getUser("reporting-user");
if (reporting) {
  admin.updateUser("reporting-user", { pwd: "reporting123password", roles: [ { role: "rawRead", db: "appdb" } ] });
} else {
  admin.createUser({ user: "reporting-user", pwd: "reporting123password", roles: [ { role: "rawRead", db: "appdb" } ] });
}
JSON.stringify({ users: admin.getUsers().users.filter(u => u.user === "reporting-user"), roles: app.getRoles({showPrivileges:true}).roles }, null, 2);
'
