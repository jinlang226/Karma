[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/bin/sh\nset -eu\n\nMODE=\"all\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      [ \"$#\" -ge 2 ] || { echo \"missing value for --mode\" \u003e\u00262; exit 2; }\n      MODE=\"$2\"\n      shift 2\n      ;;\n    --mode=*)\n      MODE=\"${1#--mode=}\"\n      shift\n      ;;\n    -h|--help)\n      echo \"usage: $0 [--mode all|app|reporting]\"\n      exit 0\n      ;;\n    *)\n      echo \"unknown argument: $1\" \u003e\u00262\n      exit 2\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *) echo \"invalid mode: $MODE\" \u003e\u00262; exit 2 ;;\nesac\n\nMONGO_HOST=\"${MONGO_HOST:-localhost:27017}\"\nADMIN_USERNAME=\"${ADMIN_USERNAME:-admin-user}\"\nADMIN_PASSWORD=\"${ADMIN_PASSWORD:-admin123password}\"\nAPP_USERNAME=\"${APP_USERNAME:-app-user}\"\nAPP_PASSWORD=\"${APP_PASSWORD:-app123password}\"\nREPORTING_USERNAME=\"${REPORTING_USERNAME:-reporting-user}\"\nREPORTING_PASSWORD=\"${REPORTING_PASSWORD:-reporting123password}\"\nAPP_DATABASE=\"${APP_DATABASE:-appdb}\"\nREPORTING_ROLE=\"${REPORTING_ROLE:-reportingRole}\"\nDEPRECATED_ROLE=\"${DEPRECATED_ROLE:-rawRead}\"\nREPORTS_COLLECTION=\"${REPORTS_COLLECTION:-reports}\"\n\nexport MODE APP_USERNAME APP_PASSWORD REPORTING_USERNAME REPORTING_PASSWORD\nexport APP_DATABASE REPORTING_ROLE DEPRECATED_ROLE REPORTS_COLLECTION\n\nmongosh --quiet \"mongodb://${MONGO_HOST}/admin\" \\\n  -u \"$ADMIN_USERNAME\" \\\n  -p \"$ADMIN_PASSWORD\" \\\n  --authenticationDatabase admin \u003c\u003c'MONGOJS'\nconst mode = process.env.MODE;\nconst appUser = process.env.APP_USERNAME;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUser = process.env.REPORTING_USERNAME;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst appDbName = process.env.APP_DATABASE;\nconst reportingRole = process.env.REPORTING_ROLE;\nconst deprecatedRole = process.env.DEPRECATED_ROLE;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\n\nconst admin = db.getSiblingDB(\"admin\");\nconst app = db.getSiblingDB(appDbName);\n\nfunction sameRoles(actual, expected) {\n  const normalize = roles =\u003e roles\n    .map(role =\u003e ({ role: role.role, db: role.db }))\n    .sort((a, b) =\u003e (a.db + \".\" + a.role).localeCompare(b.db + \".\" + b.role));\n  return JSON.stringify(normalize(actual || [])) === JSON.stringify(normalize(expected));\n}\n\nfunction ensureAdminUser(user, password, roles) {\n  const existing = admin.getUser(user);\n  if (!existing) {\n    admin.createUser({ user, pwd: password, roles });\n    return;\n  }\n  if (!sameRoles(existing.roles, roles)) {\n    admin.updateUser(user, { roles });\n  }\n}\n\nfunction ensureAppUser() {\n  ensureAdminUser(appUser, appPassword, [{ role: \"readWrite\", db: appDbName }]);\n}\n\nfunction roleExists(roleName) {\n  return app.getRole(roleName, { showPrivileges: false }) !== null;\n}\n\nfunction ensureReportingRole() {\n  const desiredPrivileges = [\n    {\n      resource: { db: appDbName, collection: reportsCollection },\n      actions: [\"find\"]\n    }\n  ];\n  if (roleExists(reportingRole)) {\n    app.updateRole(reportingRole, { privileges: desiredPrivileges, roles: [] });\n  } else {\n    app.createRole({ role: reportingRole, privileges: desiredPrivileges, roles: [] });\n  }\n}\n\nfunction ensureReportingUser() {\n  ensureReportingRole();\n  ensureAdminUser(reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);\n  if (roleExists(deprecatedRole)) {\n    app.dropRole(deprecatedRole);\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  ensureAppUser();\n}\nif (mode === \"all\" || mode === \"reporting\") {\n  ensureReportingUser();\n}\n\nprintjson({\n  ok: 1,\n  mode,\n  users: admin.getUsers().users\n    .filter(user =\u003e [appUser, reportingUser].includes(user.user))\n    .map(user =\u003e ({ user: user.user, roles: user.roles })),\n  roles: app.getRoles({ showPrivileges: true }).roles\n    .filter(role =\u003e [reportingRole, deprecatedRole].includes(role.role))\n    .map(role =\u003e ({ role: role.role, privileges: role.privileges, roles: role.roles }))\n});\nMONGOJS\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t06-30-07z-workflow-r-1085c72d-cluster-a"}}
