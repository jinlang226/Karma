[agent] +reset_app_user() {
[agent] +  mongo_eval "
[agent] +const appDbName = \"$APP_DATABASE_JS\";
[agent] +const appUser = \"$APP_USERNAME_JS\";
[agent] +const appPassword = \"$APP_PASSWORD_JS\";
[agent] +const appDb = db.getSiblingDB(appDbName);
[agent] +const desiredRoles = [{ role: \"readWrite\", db: appDbName }];
[agent] +if (appDb.getUser(appUser)) {
[agent] +  appDb.updateUser(appUser, { pwd: appPassword, roles: desiredRoles });
[agent] +} else {
[agent] +  appDb.createUser({ user: appUser, pwd: appPassword, roles: desiredRoles });
[agent] +}
[agent] +print(\"app RBAC reset complete\");
[agent] +"
[agent] +}
