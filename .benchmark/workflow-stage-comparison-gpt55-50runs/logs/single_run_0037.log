[agent] +const reportsCollection = \"$REPORTS_COLLECTION_JS\";
[agent] +const badRole = \"$BAD_ROLE_NAME_JS\";
[agent] +const appDb = db.getSiblingDB(appDbName);
[agent] +const desiredPrivileges = [{
