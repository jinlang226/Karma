[agent] +    const mode = process.env.MODE;
[agent] +    const appDbName = process.env.APP_DATABASE;
[agent] +    const appUser = process.env.APP_USERNAME;
[agent] +    const appPassword = process.env.APP_PASSWORD;
[agent] +    const reportingUser = process.env.REPORTING_USERNAME;
[agent] +    const reportingPassword = process.env.REPORTING_PASSWORD;
[agent] +    const reportingRole = process.env.REPORTING_ROLE_NAME;
[agent] +    const reportsCollection = process.env.REPORTS_COLLECTION;
[agent] +
[agent] +    const adminDb = db.getSiblingDB("admin");
[agent] +    const appDb = db.getSiblingDB(appDbName);
[agent] +
[agent] +    function ensureUser(database, username, password, roles) {
[agent] +      if (database.getUser(username)) {
[agent] +        database.updateUser(username, { pwd: password, roles });
[agent] +      } else {
[agent] +        database.createUser({ user: username, pwd: password, roles });
[agent] +      }
[agent] +    }
[agent] +
[agent] +    function ensureReportingRole() {
[agent] +      const roleDefinition = {
[agent] +        privileges: [
[agent] +          {
[agent] +            resource: { db: appDbName, collection: reportsCollection },
[agent] +            actions: [ "find" ]
[agent] +          }
[agent] +        ],
[agent] +        roles: []
[agent] +      };
[agent] +
[agent] +      if (appDb.getRole(reportingRole, { showPrivileges: true })) {
[agent] +        appDb.updateRole(reportingRole, roleDefinition);
[agent] +      } else {
[agent] +        appDb.createRole({ role: reportingRole, ...roleDefinition });
[agent] +      }
[agent] +    }
[agent] +
[agent] +    if (mode === "all" || mode === "app") {
[agent] +      ensureUser(adminDb, appUser, appPassword, [
[agent] +        { role: "readWrite", db: appDbName }
[agent] +      ]);
[agent] +    }
[agent] +
[agent] +    if (mode === "all" || mode === "reporting") {
[agent] +      ensureReportingRole();
[agent] +      ensureUser(adminDb, reportingUser, reportingPassword, [
[agent] +        { role: reportingRole, db: appDbName }
[agent] +      ]);
[agent] +    }
[agent] +    MONGOJS
