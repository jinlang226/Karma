(database, username, password, roles) {\n  if (database.getUser(username)) {\n    database.updateUser(username, { pwd: password, roles });\n  } else {\n    database.createUser({ user: username, pwd: password, roles });\n  }\n}\n\nfunction ensureReportingRole() {\n  const roleDefinition = {\n    privileges: [\n      {\n        resource: { db: appDbName, collection: reportsCollection },\n        actions: [ \"find\" ]\n      }\n    ],\n    roles: []\n  };\n\n  if (appDb.getRole(reportingRole, { showPrivileges: true })) {\n    appDb.updateRole(reportingRole, roleDefinition);\n  } else {\n    appDb.createRole({ role: reportingRole, ...roleDefinition });\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  ensureUser(adminDb, appUser, appPassword, [\n    { role: \"readWrite\", db: appDbName }\n  ]);\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  ensureReportingRole();\n  ensureUser(adminDb, reportingUser, reportingPassword, [\n    { role: reportingRole, db: appDbName }\n  ]);\n}\nMONGOJS\n"},"kind":"ConfigMap","metadata":{"annotations":{},"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-18t19-43-02z-workflow-r-c0e91998-cluster-a"}}
