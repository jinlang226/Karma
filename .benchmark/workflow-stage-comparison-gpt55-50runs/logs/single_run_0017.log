[agent] +    esac
[agent] +
[agent] +    MONGO_HOST="${MONGO_HOST:-127.0.0.1}"
[agent] +    MONGO_PORT="${MONGO_PORT:-27017}"
[agent] +    ADMIN_USERNAME="${ADMIN_USERNAME:-admin-user}"
[agent] +    ADMIN_PASSWORD="${ADMIN_PASSWORD:-admin123password}"
[agent] +    APP_USERNAME="${APP_USERNAME:-app-user}"
[agent] +    APP_PASSWORD="${APP_PASSWORD:-app123password}"
[agent] +    REPORTING_USERNAME="${REPORTING_USERNAME:-reporting-user}"
[agent] +    REPORTING_PASSWORD="${REPORTING_PASSWORD:-reporting123password}"
[agent] +    APP_DATABASE="${APP_DATABASE:-appdb}"
[agent] +    REPORTING_ROLE_NAME="${REPORTING_ROLE_NAME:-reportingRole}"
[agent] +    REPORTS_COLLECTION="${REPORTS_COLLECTION:-reports}"
[agent] +
[agent] +    export MODE APP_USERNAME APP_PASSWORD REPORTING_USERNAME REPORTING_PASSWORD
[agent] +    export APP_DATABASE REPORTING_ROLE_NAME REPORTS_COLLECTION
[agent] +
