[agent] +
[agent] +    MODE=""
[agent] +    while [ "$#" -gt 0 ]; do
[agent] +      case "$1" in
[agent] +        --mode)
[agent] +          [ "$#" -ge 2 ] || { usage; exit 2; }
[agent] +          MODE="$2"
[agent] +          shift 2
[agent] +          ;;
[agent] +        --mode=*)
[agent] +          MODE="${1#--mode=}"
[agent] +          shift
[agent] +          ;;
