[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/bin/sh\nset -eu\n\nMODE=all\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      [ \"$#\" -ge 2 ] || { echo \"--mode requires a value\" \u003e\u00262; exit 2; }\n      MODE=\"$2\"\n      shift 2\n      ;;\n    --mode=*)\n      MODE=\"${1#--mode=}\"\n      shift\n      ;;\n    -h|--help)\n      echo \"Usage: $0 [--mode all|app|reporting]\"\n      exit 0\n      ;;\n    *)\n      echo \"Unknown argument: $1\" \u003e\u00262\n      exit 2\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *) echo \"Invalid mode: $MODE\" \u003e\u00262; exit 2 ;;\nesac\n\nMONGOSH_BIN=\"${MONGOSH_BIN:-mongosh}\"\nMONGO_HOST=\"${MONGO_HOST:-127.0.0.1}\"\nMONGO_PORT=\"${MONGO_PORT:-27017}\"\nAUTH_DB=\"${AUTH_DB:-admin}\"\nADMIN_USERNAME=\"${ADMIN_USERNAME:-admin-user}\"\nADMIN_PASSWORD=\"${ADMIN_PASSWORD:-admin123password}\"\nAPP_USERNAME=\"${APP_USERNAME:-app-user}\"\nAPP_PASSWORD=\"${APP_PASSWORD:-app123password}\"\nREPORTING_USERNAME=\"${REPORTING_USERNAME:-reporting-user}\"\nREPORTING_PASSWORD=\"${REPORTING_PASSWORD:-reporting123password}\"\nAPP_DB=\"${APP_DB:-appdb}\"\nREPORTS_COLLECTION=\"${REPORTS_COLLECTION:-reports}\"\nREPORTING_ROLE=\"${REPORTING_ROLE:-reportingRole}\"\nDEPRECATED_RAW_ROLE=\"${DEPRECATED_RAW_ROLE:-rawRead}\"\n\n\"$MONGOSH_BIN\" --quiet --host \"$MONGO_HOST\" --port \"$MONGO_PORT\" \\\n  -u \"$ADMIN_USERNAME\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase \"$AUTH_DB\" \u003c\u003cEOF\nconst mode = \"$MODE\";\nconst authDbName = \"$AUTH_DB\";\nconst appDbName = \"$APP_DB\";\nconst appUser = \"$APP_USERNAME\";\nconst appPassword = \"$APP_PASSWORD\";\nconst reportingUser = \"$REPORTING_USERNAME\";\nconst reportingPassword = \"$REPORTING_PASSWORD\";\nconst reportingRole = \"$REPORTING_ROLE\";\nconst deprecatedRawRole = \"$DEPRECATED_RAW_ROLE\";\nconst reportsCollection = \"$REPORTS_COLLECTION\";\n\nconst authDb = db.getSiblingDB(authDbName);\nconst appDb = db.getSiblingDB(appDbName);\n\nfunction ensureUserWithExactRoles(database, user, password, roles) {\n  if (database.getUser(user) === null) {\n    database.createUser({ user: user, pwd: password, roles: roles });\n  } else {\n    database.updateUser(user, { roles: roles });\n  }\n}\n\nfunction ensureRoleWithExactPrivileges(database, role, privileges, inheritedRoles) {\n  if (database.getRole(role) === null) {\n    database.createRole({ role: role, privileges: privileges, roles: inheritedRoles });\n  } else {\n    database.updateRole(role, { privileges: privileges, roles: inheritedRoles });\n  }\n}\n\nfunction resetAppUser() {\n  ensureUserWithExactRoles(authDb, appUser, appPassword, [\n    { role: \"readWrite\", db: appDbName }\n  ]);\n}\n\nfunction resetReportingUserAndRole() {\n  ensureRoleWithExactPrivileges(appDb, reportingRole, [\n    { resource: { db: appDbName, collection: reportsCollection }, actions: [\"find\"] }\n  ], []);\n\n  ensureUserWithExactRoles(authDb, reportingUser, reportingPassword, [\n    { role: reportingRole, db: appDbName }\n  ]);\n\n  if (appDb.getRole(deprecatedRawRole) !== null) {\n    appDb.dropRole(deprecatedRawRole);\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  resetAppUser();\n}\nif (mode === \"all\" || mode === \"reporting\") {\n  resetReportingUserAndRole();\n}\n\nprint(\"RBAC reset complete: mode=\" + mode);\nEOF\n"},"kind":"ConfigMap","metadata":{"annotations":{},"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t07-30-24z-workflow-r-fe6ef5e3-cluster-a"}}
