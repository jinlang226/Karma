const mode = process.env.RESET_MODE;
const admin = db.getSiblingDB("admin");
const appdb = db.getSiblingDB("appdb");

function resetAppUser() {
  const roles = [{ role: "readWrite", db: "appdb" }];
  if (admin.getUser("app-user")) {
    admin.updateUser("app-user", { roles: roles });
  } else {
    admin.createUser({ user: "app-user", pwd: process.env.APP_PASSWORD, roles: roles });
  }
}

function resetReporting() {
  const privileges = [{
    resource: { db: "appdb", collection: "reports" },
    actions: ["find"]
  }];

  if (appdb.getRole("reportingRole")) {
    appdb.updateRole("reportingRole", { privileges: privileges, roles: [] });
  } else {
    appdb.createRole({ role: "reportingRole", privileges: privileges, roles: [] });
  }

  const roles = [{ role: "reportingRole", db: "appdb" }];
  if (admin.getUser("reporting-user")) {
    admin.updateUser("reporting-user", { roles: roles });
  } else {
    admin.createUser({ user: "reporting-user", pwd: process.env.REPORTING_PASSWORD, roles: roles });
  }
}

if (mode === "app" || mode === "all") {
  resetAppUser();
}

if (mode === "reporting" || mode === "all") {
  resetReporting();
}

print("mongodb RBAC reset complete: mode=" + mode);
'
