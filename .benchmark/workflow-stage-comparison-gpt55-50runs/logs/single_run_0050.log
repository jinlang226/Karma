ionDatabase admin \\\n    --eval \"$1\"\n}\n\nreset_app() {\n  run_mongo \"\nconst admin = db.getSiblingDB('admin');\nconst appdb = db.getSiblingDB('$APP_DATABASE');\nconst password = Buffer.from('$APP_PASSWORD_B64', 'base64').toString('utf8');\nconst roles = [{ role: 'readWrite', db: '$APP_DATABASE' }];\nconst userDb = admin.getUser('$APP_USERNAME') ? admin : (appdb.getUser('$APP_USERNAME') ? appdb : admin);\n\nif (userDb.getUser('$APP_USERNAME') === null) {\n  userDb.createUser({ user: '$APP_USERNAME', pwd: password, roles });\n} else {\n  userDb.updateUser('$APP_USERNAME', { roles });\n}\n\"\n}\n\nreset_reporting() {\n  run_mongo \"\nconst admin = db.getSiblingDB('admin');\nconst appdb = db.getSiblingDB('$APP_DATABASE');\nconst roleName = '$REPORTING_ROLE_NAME';\nconst password = Buffer.from('$REPORTING_PASSWORD_B64', 'base64').toString('utf8');\nconst roleSpec = {\n  privileges: [{\n    resource: { db: '$APP_DATABASE', collection: '$REPORTS_COLLECTION' },\n    actions: ['find']\n  }],\n  roles: []\n};\n\nif (appdb.getRole(roleName) === null) {\n  appdb.createRole(Object.assign({ role: roleName }, roleSpec));\n} else {\n  appdb.updateRole(roleName, roleSpec);\n}\n\nconst roles = [{ role: roleName, db: '$APP_DATABASE' }];\nconst userDb = admin.getUser('$REPORTING_USERNAME') ? admin : (appdb.getUser('$REPORTING_USERNAME') ? appdb : admin);\n\nif (userDb.getUser('$REPORTING_USERNAME') === null) {\n  userDb.createUser({ user: '$REPORTING_USERNAME', pwd: password, roles });\n} else {\n  userDb.updateUser('$REPORTING_USERNAME', { roles });\n}\n\"\n}\n\ncase \"$MODE\" in\n  all)\n    reset_app\n    reset_reporting\n    ;;\n  app)\n    reset_app\n    ;;\n  reporting)\n    reset_reporting\n    ;;\nesac\n\necho \"RBAC reset completed for mode: $MODE\"\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t06-03-36z-workflow-r-5835edd6-cluster-a"}}
