mode = '$JS_MODE';\nconst appDbName = '$JS_APP_DB';\nconst appUserName = '$JS_APP_USER';\nconst appPassword = '$JS_APP_PASSWORD';\nconst reportingUserName = '$JS_REPORTING_USER';\nconst reportingPassword = '$JS_REPORTING_PASSWORD';\nconst reportsCollection = '$JS_REPORTS_COLLECTION';\nconst reportingRole = '$JS_REPORTING_ROLE';\nconst badRole = '$JS_BAD_ROLE';\nconst adminDb = db.getSiblingDB('admin');\nconst appDb = db.getSiblingDB(appDbName);\n\nfunction userExists(name) {\n  return adminDb.getUser(name) !== null;\n}\n\nfunction roleExists(name) {\n  return appDb.getRole(name) !== null;\n}\n\nfunction resetAppUser() {\n  const roles = [{ role: 'readWrite', db: appDbName }];\n  if (userExists(appUserName)) {\n    adminDb.updateUser(appUserName, { roles });\n  } else {\n    adminDb.createUser({ user: appUserName, pwd: appPassword, roles });\n  }\n}\n\nfunction resetReporting() {\n  if (userExists(reportingUserName)) {\n    adminDb.updateUser(reportingUserName, { roles: [] });\n  }\n  if (roleExists(reportingRole)) {\n    appDb.dropRole(reportingRole);\n  }\n  appDb.createRole({\n    role: reportingRole,\n    privileges: [{\n      resource: { db: appDbName, collection: reportsCollection },\n      actions: ['find']\n    }],\n    roles: []\n  });\n  if (roleExists(badRole)) {\n    appDb.dropRole(badRole);\n  }\n  const roles = [{ role: reportingRole, db: appDbName }];\n  if (userExists(reportingUserName)) {\n    adminDb.updateUser(reportingUserName, { roles });\n  } else {\n    adminDb.createUser({ user: reportingUserName, pwd: reportingPassword, roles });\n  }\n}\n\nif (mode === 'all' || mode === 'app') {\n  resetAppUser();\n}\nif (mode === 'all' || mode === 'reporting') {\n  resetReporting();\n}\nprint('RBAC reset complete: ' + mode);\n\"\n\nif command -v kubectl \u003e/dev/null 2\u003e\u00261 \u0026\u0026 [ \"${USE_LOCAL_MONGOSH:-}\" != \"true\" ]; then\n  printf '%s\\n' \"$JS\" | kubectl -n \"$NAMESPACE\" exec -i \"$POD\" -- mongosh --quiet -u \"$ADMIN_USER\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin\nelse\n  printf '%s\\n' \"$JS\" | mongosh --quiet -u \"$ADMIN_USER\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin\nfi\n"},"kind":"ConfigMap","metadata":{"annotations":{},"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-18t20-13-17z-workflow-r-f584270d-cluster-a"}}
