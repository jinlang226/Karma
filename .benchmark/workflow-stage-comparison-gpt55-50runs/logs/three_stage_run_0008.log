const admin = db.getSiblingDB("admin");
const app = db.getSiblingDB("appdb");
const reportingPassword = process.env.REPORTING_PW;

function userExists(database, username) {
  return database.runCommand({usersInfo: username}).users.length > 0;
}
function roleExists(database, role) {
  return database.runCommand({rolesInfo: role}).roles.length > 0;
}

if (userExists(admin, "reporting-user")) {
  admin.updateUser("reporting-user", {pwd: reportingPassword, roles: [{role: "rawRead", db: "appdb"}]});
} else {
  admin.createUser({user: "reporting-user", pwd: reportingPassword, roles: [{role: "rawRead", db: "appdb"}]});
}

if (roleExists(app, "reportingRole")) {
  const users = admin.runCommand({usersInfo: 1}).users;
  for (const u of users) {
    const hasRole = (u.roles || []).some(r => r.role === "reportingRole" && r.db === "appdb");
    if (hasRole) admin.revokeRolesFromUser(u.user, [{role: "reportingRole", db: "appdb"}]);
  }
  app.dropRole("reportingRole");
}

const rawRead = {
  privileges: [{resource: {db: "appdb", collection: "raw"}, actions: ["find"]}],
  roles: []
};
if (roleExists(app, "rawRead")) {
  app.updateRole("rawRead", rawRead);
} else {
  app.createRole(Object.assign({role: "rawRead"}, rawRead));
}
admin.updateUser("reporting-user", {roles: [{role: "rawRead", db: "appdb"}]});

printjson({
  reportingUser: admin.runCommand({usersInfo: "reporting-user"}).users[0],
  roles: app.runCommand({rolesInfo: 1, showPrivileges: true}).roles
});
'
