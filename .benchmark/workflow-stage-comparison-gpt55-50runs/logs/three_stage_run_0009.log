[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/bin/sh\nset -eu\n\nMODE=\"all\"\n\nusage() {\n  echo \"Usage: $0 [--mode all|app|reporting]\" \u003e\u00262\n}\n\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      [ \"$#\" -ge 2 ] || { usage; exit 2; }\n      MODE=\"$2\"\n      shift 2\n      ;;\n    --mode=*)\n      MODE=\"${1#--mode=}\"\n      shift\n      ;;\n    -h|--help)\n      usage\n      exit 0\n      ;;\n    *)\n      usage\n      exit 2\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *) usage; exit 2 ;;\nesac\n\nNAMESPACE=\"${NAMESPACE:-wf-2026-05-18t09-21-37z-workflow-r-55081bc6-cluster-a}\"\nREPLICA_SET=\"${REPLICA_SET:-mongodb-replica}\"\nSERVICE=\"${SERVICE:-mongodb-replica-svc}\"\nMONGO_URI=\"${MONGO_URI:-mongodb://mongodb-replica-0.${SERVICE}.${NAMESPACE}.svc.cluster.local:27017,mongodb-replica-1.${SERVICE}.${NAMESPACE}.svc.cluster.local:27017,mongodb-replica-2.${SERVICE}.${NAMESPACE}.svc.cluster.local:27017/admin?replicaSet=${REPLICA_SET}}\"\n\nADMIN_USERNAME=\"${ADMIN_USERNAME:-admin-user}\"\nADMIN_PASSWORD=\"${ADMIN_PASSWORD:-admin123password}\"\nAPP_USERNAME=\"${APP_USERNAME:-app-user}\"\nAPP_PASSWORD=\"${APP_PASSWORD:-app123password}\"\nREPORTING_USERNAME=\"${REPORTING_USERNAME:-reporting-user}\"\nREPORTING_PASSWORD=\"${REPORTING_PASSWORD:-reporting123password}\"\nAPP_DATABASE=\"${APP_DATABASE:-appdb}\"\nREPORTS_COLLECTION=\"${REPORTS_COLLECTION:-reports}\"\nREPORTING_ROLE=\"${REPORTING_ROLE:-reportingRole}\"\nBAD_ROLE=\"${BAD_ROLE:-rawRead}\"\n\nexport MODE APP_USERNAME APP_PASSWORD REPORTING_USERNAME REPORTING_PASSWORD\nexport APP_DATABASE REPORTS_COLLECTION REPORTING_ROLE BAD_ROLE\n\nSCRIPT_FILE=\"/tmp/reset_rbac.$$.js\"\ntrap 'rm -f \"$SCRIPT_FILE\"' EXIT HUP INT TERM\n\ncat \u003e \"$SCRIPT_FILE\" \u003c\u003c'JS'\nconst mode = process.env.MODE;\nconst appDbName = process.env.APP_DATABASE;\nconst appUser = process.env.APP_USERNAME;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUser = process.env.REPORTING_USERNAME;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\nconst reportingRole = process.env.REPORTING_ROLE;\nconst badRole = process.env.BAD_ROLE;\n\nconst admin = db.getSiblingDB(\"admin\");\nconst appdb = db.getSiblingDB(appDbName);\n\nfunction sameRoles(actual, expected) {\n  return JSON.stringify((actual || []).map(r =\u003e ({ role: r.role, db: r.db })).sort((a, b) =\u003e (a.db + a.role).localeCompare(b.db + b.role))) ===\n    JSON.stringify(expected.map(r =\u003e ({ role: r.role, db: r.db })).sort((a, b) =\u003e (a.db + a.role).localeCompare(b.db + b.role)));\n}\n\nfunction ensureAdminUserRoles(username, password, roles) {\n  const existing = admin.getUser(username);\n  if (existing === null) {\n    admin.createUser({ user: username, pwd: password, roles });\n    return;\n  }\n  if (!sameRoles(existing.roles, roles)) {\n    admin.updateUser(username, { roles });\n  }\n}\n\nfunction ensureReportingRole() {\n  const privileges = [\n    {\n      resource: { db: appDbName, collection: reportsCollection },\n      actions: [ \"find\" ]\n    }\n  ];\n  const existing = appdb.getRole(reportingRole, { showPrivileges: true });\n  if (existing === null) {\n    appdb.createRole({ role: reportingRole, privileges, roles: [] });\n  } else {\n    appdb.updateRole(reportingRole, { privileges, roles: [] });\n  }\n}\n\nfunction resetApp() {\n  ensureAdminUserRoles(appUser, appPassword, [ { role: \"readWrite\", db: appDbName } ]);\n}\n\nfunction resetReporting() {\n  ensureReportingRole();\n  ensureAdminUserRoles(reportingUser, reportingPassword, [ { role: reportingRole, db: appDbName } ]);\n  if (appdb.getRole(badRole) !== null) {\n    appdb.dropRole(badRole);\n  }\n}\n\nif (mode === \"app\" || mode === \"all\") {\n  resetApp();\n}\n\nif (mode === \"reporting\" || mode === \"all\") {\n  resetReporting();\n}\n\nprintjson({\n  ok: 1,\n  mode,\n  appUser: admin.getUser(appUser),\n  reportingUser: admin.getUser(reportingUser),\n  appRoles: appdb.getRoles({ showPrivileges: true })\n});\nJS\n\nmongosh --quiet \"$MONGO_URI\" -u \"$ADMIN_USERNAME\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin \"$SCRIPT_FILE\"\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-18t09-21-37z-workflow-r-55081bc6-cluster-a"}}
