[agent] +    usage
[agent] +    exit 2
[agent] +    ;;
[agent] +esac
[agent] +
[agent] +export MODE APP_DATABASE APP_USERNAME APP_PASSWORD REPORTING_USERNAME REPORTING_PASSWORD REPORTING_ROLE_NAME REPORTS_COLLECTION
[agent] +
[agent] +mongosh --quiet \
[agent] +  --host "$MONGO_HOST" \
[agent] +  --port "$MONGO_PORT" \
[agent] +  -u "$ADMIN_USERNAME" \
[agent] +  -p "$ADMIN_PASSWORD" \
[agent] +  --authenticationDatabase "$AUTH_DB" <<'EOF'
[agent] +const mode = process.env.MODE;
[agent] +const appDbName = process.env.APP_DATABASE;
[agent] +const appUser = process.env.APP_USERNAME;
[agent] +const appPassword = process.env.APP_PASSWORD;
[agent] +const reportingUser = process.env.REPORTING_USERNAME;
[agent] +const reportingPassword = process.env.REPORTING_PASSWORD;
[agent] +const reportingRole = process.env.REPORTING_ROLE_NAME;
[agent] +const reportsCollection = process.env.REPORTS_COLLECTION;
[agent] +
[agent] +const appDb = db.getSiblingDB(appDbName);
[agent] +
[agent] +function ensureUser(database, username, password, roles) {
[agent] +  const existing = database.getUser(username);
[agent] +  if (existing) {
[agent] +    database.updateUser(username, { roles });
[agent] +  } else {
[agent] +    database.createUser({ user: username, pwd: password, roles });
[agent] +  }
[agent] +}
[agent] +
[agent] +function resetAppUser() {
[agent] +  ensureUser(appDb, appUser, appPassword, [{ role: "readWrite", db: appDbName }]);
[agent] +}
[agent] +
[agent] +function resetReportingRoleAndUser() {
[agent] +  const roleDefinition = {
[agent] +    privileges: [
[agent] +      {
[agent] +        resource: { db: appDbName, collection: reportsCollection },
[agent] +        actions: ["find"]
[agent] +      }
[agent] +    ],
[agent] +    roles: []
[agent] +  };
[agent] +
[agent] +  if (appDb.getRole(reportingRole)) {
[agent] +    appDb.updateRole(reportingRole, roleDefinition);
[agent] +  } else {
[agent] +    appDb.createRole(Object.assign({ role: reportingRole }, roleDefinition));
[agent] +  }
[agent] +
[agent] +  ensureUser(appDb, reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);
[agent] +}
[agent] +
[agent] +if (mode === "all" || mode === "app") {
[agent] +  resetAppUser();
[agent] +}
[agent] +
[agent] +if (mode === "all" || mode === "reporting") {
[agent] +  resetReportingRoleAndUser();
[agent] +}
[agent] +
[agent] +print(`rbac reset complete: mode=${mode}`);
[agent] +EOF
