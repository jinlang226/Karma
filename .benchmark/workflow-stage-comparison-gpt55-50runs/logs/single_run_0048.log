[agent] +MONGO_PORT="${MONGO_PORT:-27017}"
[agent] +ADMIN_USERNAME="${ADMIN_USERNAME:-admin-user}"
[agent] +ADMIN_PASSWORD="${ADMIN_PASSWORD:-admin123password}"
[agent] +AUTH_DB="${AUTH_DB:-admin}"
[agent] +APP_DATABASE="${APP_DATABASE:-appdb}"
[agent] +APP_USERNAME="${APP_USERNAME:-app-user}"
[agent] +APP_PASSWORD="${APP_PASSWORD:-app123password}"
