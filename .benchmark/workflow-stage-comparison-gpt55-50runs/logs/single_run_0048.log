[agent] +REPORTING_PASSWORD="${REPORTING_PASSWORD:-reporting123password}"
[agent] +REPORTING_ROLE_NAME="${REPORTING_ROLE_NAME:-reportingRole}"
[agent] +REPORTS_COLLECTION="${REPORTS_COLLECTION:-reports}"
[agent] +
[agent] +usage() {
[agent] +  echo "usage: $0 [--mode all|app|reporting]" >&2
[agent] +}
[agent] +
[agent] +while [ "$#" -gt 0 ]; do
[agent] +  case "$1" in
[agent] +    --mode)
[agent] +      [ "$#" -ge 2 ] || { usage; exit 2; }
[agent] +      MODE="$2"
[agent] +      shift 2
[agent] +      ;;
[agent] +    --mode=*)
