[agent]         actions: ['find']
[agent]       }];
[agent]       const inheritedRoles = [];
[agent]       if (appdb.getRole(reportingRole)) {
[agent]         appdb.updateRole(reportingRole, { privileges: privileges, roles: inheritedRoles });
[agent]       } else {
[agent]         appdb.createRole({ role: reportingRole, privileges: privileges, roles: inheritedRoles });
[agent]       }
[agent]       const role = appdb.getRole(reportingRole, { showPrivileges: true });
[agent]       if ("'!role || role.privileges.length !== 1 || role.privileges[0].resource.db !== appDbName ||
[agent]           role.privileges[0].resource.collection !== reportsCollection ||
[agent]           JSON.stringify(role.privileges[0].actions.slice().sort()) !== JSON.stringify(['"'find'])) {
[agent]         throw new Error('failed to converge role ' + reportingRole);
[agent]       }
[agent]     }
[agent]     if (mode === 'all' || mode === 'app') {
[agent]       ensureUser(appdb, appUser, appPassword, [{ role: 'readWrite', db: appDbName }]);
[agent]     }
[agent]     if (mode === 'all' || mode === 'reporting') {
[agent]       ensureReportingRole();
[agent]       ensureUser(appdb, reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);
[agent]       const updatedReportingUser = appdb.getUser(reportingUser);
[agent]       if ((updatedReportingUser.roles || []).some(r => r.role === badRole)) {
