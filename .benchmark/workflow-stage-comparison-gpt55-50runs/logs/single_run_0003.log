ord = process.env.REPORTING_PASSWORD;\nconst reportingRole = process.env.REPORTING_ROLE_NAME;\nconst badRole = process.env.BAD_ROLE_NAME;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\nconst appdb = db.getSiblingDB(appDbName);\n\nfunction sameRoles(actual, expected) {\n  const normalize = roles =\u003e roles\n    .map(r =\u003e ({ role: r.role, db: r.db }))\n    .sort((a, b) =\u003e (a.db + '.' + a.role).localeCompare(b.db + '.' + b.role));\n  return JSON.stringify(normalize(actual || [])) === JSON.stringify(normalize(expected));\n}\n\nfunction ensureUser(database, username, password, roles) {\n  const existing = database.getUser(username);\n  if (existing) {\n    database.updateUser(username, { pwd: password, roles: roles });\n  } else {\n    database.createUser({ user: username, pwd: password, roles: roles });\n  }\n  const updated = database.getUser(username);\n  if (!updated || !sameRoles(updated.roles, roles)) {\n    throw new Error('failed to converge user roles for ' + username);\n  }\n}\n\nfunction ensureReportingRole() {\n  const privileges = [{\n    resource: { db: appDbName, collection: reportsCollection },\n    actions: ['find']\n  }];\n  const inheritedRoles = [];\n  if (appdb.getRole(reportingRole)) {\n    appdb.updateRole(reportingRole, { privileges: privileges, roles: inheritedRoles });\n  } else {\n    appdb.createRole({ role: reportingRole, privileges: privileges, roles: inheritedRoles });\n  }\n  const role = appdb.getRole(reportingRole, { showPrivileges: true });\n  if (!role || role.privileges.length !== 1 || role.privileges[0].resource.db !== appDbName ||\n      role.privileges[0].resource.collection !== reportsCollection ||\n      JSON.stringify(role.privileges[0].actions.slice().sort()) !== JSON.stringify(['find'])) {\n    throw new Error('failed to converge role ' + reportingRole);\n  }\n}\n\nif (mode === 'all' || mode === 'app') {\n  ensureUser(appdb, appUser, appPassword, [{ role: 'readWrite', db: appDbName }]);\n}\n\nif (mode