[agent]     function sameRoles(actual, expected) {
[agent]       const normalize = roles => roles
[agent]         .map(r => ({ role: r.role, db: r.db }))
[agent]         .sort((a, b) => (a.db + '.' + a.role).localeCompare(b.db + '.' + b.role));
[agent]       return JSON.stringify(normalize(actual || [])) === JSON.stringify(normalize(expected));
[agent]     }
[agent]     function ensureUser(database, username, password, roles) {
[agent]       const existing = database.getUser(username);
[agent]       if (existing) {
[agent]         database.updateUser(username, { pwd: password, roles: roles });
[agent]       } else {
[agent]         database.createUser({ user: username, pwd: password, roles: roles });
[agent]       }
[agent]       const updated = database.getUser(username);
[agent]       if ("'!updated || !sameRoles(updated.roles, roles)) {
[agent]         throw new Error('"'failed to converge user roles for ' + username);
[agent]       }
[agent]     }
