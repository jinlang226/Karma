[agent]           fi
[agent]           MODE="$2"
[agent]           shift 2
[agent]           ;;
[agent]         --mode=*)
[agent]           MODE="${1#--mode=}"
[agent]           shift
[agent]           ;;
[agent]         -h|--help)
[agent]           echo "usage: $0 [--mode all|app|reporting]"
[agent]           exit 0
[agent]           ;;
[agent]         *)
[agent]           echo "unknown argument: $1" >&2
[agent]           exit 2
[agent]           ;;
[agent]       esac
[agent]     done
[agent]     case "$MODE" in
[agent]       all|app|reporting) ;;
[agent]       *)
[agent]         echo "invalid mode: $MODE (expected all, app, or reporting)" >&2
[agent]         exit 2
[agent]         ;;
[agent]     esac
[agent]     MONGO_HOST="${MONGO_HOST:-127.0.0.1}"
[agent]     MONGO_PORT="${MONGO_PORT:-27017}"
[agent]     ADMIN_DB="${ADMIN_DB:-admin}"
[agent]     ADMIN_USERNAME="${ADMIN_USERNAME:-admin-user}"
[agent]     ADMIN_PASSWORD="${ADMIN_PASSWORD:-admin123password}"
[agent]     APP_DATABASE="${APP_DATABASE:-appdb}"
[agent]     APP_USERNAME="${APP_USERNAME:-app-user}"
[agent]     APP_PASSWORD="${APP_PASSWORD:-app123password}"
[agent]     REPORTING_USERNAME="${REPORTING_USERNAME:-reporting-user}"
[agent]     REPORTING_PASSWORD="${REPORTING_PASSWORD:-reporting123password}"
[agent]     REPORTING_ROLE_NAME="${REPORTING_ROLE_NAME:-reportingRole}"
[agent]     BAD_ROLE_NAME="${BAD_ROLE_NAME:-rawRead}"
[agent]     REPORTS_COLLECTION="${REPORTS_COLLECTION:-reports}"
[agent]     export RESET_MODE="$MODE"
[agent]     export APP_DATABASE APP_USERNAME APP_PASSWORD
[agent]     export REPORTING_USERNAME REPORTING_PASSWORD REPORTING_ROLE_NAME BAD_ROLE_NAME REPORTS_COLLECTION
[agent]     mongosh --quiet --host "$MONGO_HOST" --port "$MONGO_PORT" \
[agent]       -u "$ADMIN_USERNAME" -p "$ADMIN_PASSWORD" --authenticationDatabase "$ADMIN_DB" <<'MONGOJS'
[agent]     const mode = process.env.RESET_MODE;
[agent]     const appDbName = process.env.APP_DATABASE;
[agent]     const appUser = process.env.APP_USERNAME;
[agent]     const appPassword = process.env.APP_PASSWORD;
[agent]     const reportingUser = process.env.REPORTING_USERNAME;
[agent]     const reportingPassword = process.env.REPORTING_PASSWORD;
[agent]     const reportingRole = process.env.REPORTING_ROLE_NAME;
[agent]     const badRole = process.env.BAD_ROLE_NAME;
[agent]     const reportsCollection = process.env.REPORTS_COLLECTION;
[agent]     const appdb = db.getSiblingDB(appDbName);
[agent]     function sameRoles(actual, expected) {
[agent]       const normalize = roles => roles
[agent]         .map(r => ({ role: r.role, db: r.db }))
[agent]         .sort((a, b) => (a.db + '.' + a.role).localeCompare(b.db + '.' + b.role));
[agent]       return JSON.stringify(normalize(actual || [])) === JSON.stringify(normalize(expected));
[agent]     }
[agent]     function ensureUser(database, username, password, roles) {
[agent]       const existing = database.getUser(username);
[agent]       if (existing) {
[agent]         database.updateUser(username, { pwd: password, roles: roles });
[agent]       } else {
[agent]         database.createUser({ user: username, pwd: password, roles: roles });
[agent]       }
[agent]       const updated = database.getUser(username);
[agent]       if (!updated || !sameRoles(updated.roles, roles)) {
[agent]         throw new Error('failed to converge user roles for ' + username);
[agent]       }
[agent]     }
[agent]     function ensureReportingRole() {
[agent]       const privileges = [{
[agent]         resource: { db: appDbName, collection: reportsCollection },
[agent]         actions: ['find']
[agent]       }];
[agent]       const inheritedRoles = [];
[agent]       if (appdb.getRole(reportingRole)) {
[agent]         appdb.updateRole(reportingRole, { privileges: privileges, roles: inheritedRoles });
[agent]       } else {
[agent]         appdb.createRole({ role: reportingRole, privileges: privileges, roles: inheritedRoles });
[agent]       }
[agent]       const role = appdb.getRole(reportingRole, { showPrivileges: true });
[agent]       if (!role || role.privileges.length !== 1 || role.privileges[0].resource.db !== appDbName ||
[agent]           role.privileges[0].resource.collection !== reportsCollection ||
[agent]           JSON.stringify(role.privileges[0].actions.slice().sort()) !== JSON.stringify(['find'])) {
[agent]         throw new Error('failed to converge role ' + reportingRole);
[agent]       }
[agent]     }
[agent]     if (mode === 'all' || mode === 'app') {
[agent]       ensureUser(appdb, appUser, appPassword, [{ role: 'readWrite', db: appDbName }]);
[agent]     }
[agent]     if (mode === 'all' || mode === 'reporting') {
[agent]       ensureReportingRole();
[agent]       ensureUser(appdb, reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);
[agent]       const updatedReportingUser = appdb.getUser(reportingUser);
[agent]       if ((updatedReportingUser.roles || []).some(r => r.role === badRole)) {
[agent]         throw new Error(reportingUser + ' still has deprecated role ' + badRole);
[agent]       }
[agent]     }
[agent]     print('RBAC reset complete for mode=' + mode);
[agent]     MONGOJS
