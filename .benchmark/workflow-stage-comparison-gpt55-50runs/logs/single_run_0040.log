[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/bin/sh\nset -eu\n\nNAMESPACE=\"${NAMESPACE:-wf-2026-05-19t05-09-32z-workflow-r-aad2517f-cluster-a}\"\nPOD_PREFIX=\"${POD_PREFIX:-mongodb-replica}\"\nEXPECTED_REPLICAS=\"${EXPECTED_REPLICAS:-3}\"\n\nADMIN_USERNAME=\"${ADMIN_USERNAME:-admin-user}\"\nAPP_USERNAME=\"${APP_USERNAME:-app-user}\"\nREPORTING_USERNAME=\"${REPORTING_USERNAME:-reporting-user}\"\n\nADMIN_SECRET_NAME=\"${ADMIN_SECRET_NAME:-admin-user-password}\"\nAPP_SECRET_NAME=\"${APP_SECRET_NAME:-app-user-password}\"\nREPORTING_SECRET_NAME=\"${REPORTING_SECRET_NAME:-reporting-user-password}\"\nSECRET_KEY=\"${SECRET_KEY:-password}\"\n\nAPP_DATABASE=\"${APP_DATABASE:-appdb}\"\nREPORTING_ROLE_NAME=\"${REPORTING_ROLE_NAME:-reportingRole}\"\nBAD_ROLE_NAME=\"${BAD_ROLE_NAME:-rawRead}\"\nREPORTS_COLLECTION=\"${REPORTS_COLLECTION:-reports}\"\n\nMODE=\"all\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      [ \"$#\" -ge 2 ] || { echo \"missing value for --mode\" \u003e\u00262; exit 2; }\n      MODE=\"$2\"\n      shift 2\n      ;;\n    --mode=*)\n      MODE=\"${1#--mode=}\"\n      shift\n      ;;\n    -h|--help)\n      echo \"Usage: $0 [--mode all|app|reporting]\"\n      exit 0\n      ;;\n    *)\n      echo \"unknown argument: $1\" \u003e\u00262\n      exit 2\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *) echo \"invalid mode: $MODE (expected all, app, or reporting)\" \u003e\u00262; exit 2 ;;\nesac\n\nneed() {\n  command -v \"$1\" \u003e/dev/null 2\u003e\u00261 || { echo \"required command not found: $1\" \u003e\u00262; exit 1; }\n}\n\nsecret_value() {\n  kubectl -n \"$NAMESPACE\" get secret \"$1\" -o \"jsonpath={.data.${SECRET_KEY}}\" | base64 -d\n}\n\njson_quote() {\n  printf '%s' \"$1\" | sed 's/\\\\/\\\\\\\\/g; s/\"/\\\\\"/g'\n}\n\nfind_primary_pod() {\n  i=0\n  while [ \"$i\" -lt \"$EXPECTED_REPLICAS\" ]; do\n    pod=\"${POD_PREFIX}-${i}\"\n    state=\"$(kubectl -n \"$NAMESPACE\" exec \"$pod\" -- mongosh --quiet \\\n      -u \"$ADMIN_USERNAME\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin \\\n      --eval 'db.hello().isWritablePrimary ? \"PRIMARY\" : \"NOT_PRIMARY\"' 2\u003e/dev/null || true)\"\n    if [ \"$state\" = \"PRIMARY\" ]; then\n      printf '%s\\n' \"$pod\"\n      return 0\n    fi\n    i=$((i + 1))\n  done\n  echo \"could not find writable primary pod\" \u003e\u00262\n  return 1\n}\n\nneed kubectl\nneed base64\nneed sed\n\nADMIN_PASSWORD=\"${ADMIN_PASSWORD:-$(secret_value \"$ADMIN_SECRET_NAME\")}\"\nAPP_PASSWORD=\"${APP_PASSWORD:-$(secret_value \"$APP_SECRET_NAME\")}\"\nREPORTING_PASSWORD=\"${REPORTING_PASSWORD:-$(secret_value \"$REPORTING_SECRET_NAME\")}\"\n\nADMIN_PASSWORD_JSON=\"$(json_quote \"$ADMIN_PASSWORD\")\"\nAPP_PASSWORD_JSON=\"$(json_quote \"$APP_PASSWORD\")\"\nREPORTING_PASSWORD_JSON=\"$(json_quote \"$REPORTING_PASSWORD\")\"\n\nPRIMARY_POD=\"$(find_primary_pod)\"\n\nkubectl -n \"$NAMESPACE\" exec -i \"$PRIMARY_POD\" -- mongosh --quiet \\\n  -u \"$ADMIN_USERNAME\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin \\\n  --file /dev/stdin \u003c\u003cMONGOJS\nconst mode = \"$MODE\";\nconst adminDb = db.getSiblingDB(\"admin\");\nconst appDb = db.getSiblingDB(\"$APP_DATABASE\");\n\nfunction userExists(database, username) {\n  return database.getUser(username) !== null;\n}\n\nfunction ensureUser(database, username, password, roles) {\n  if (userExists(database, username)) {\n    database.updateUser(username, {pwd: password, roles: roles});\n  } else {\n    database.createUser({user: username, pwd: password, roles: roles});\n  }\n}\n\nfunction ensureReportingRole() {\n  const desiredPrivileges = [{\n    resource: {db: \"$APP_DATABASE\", collection: \"$REPORTS_COLLECTION\"},\n    actions: [\"find\"]\n  }];\n  const existing = appDb.getRole(\"$REPORTING_ROLE_NAME\", {showPrivileges: true});\n  if (existing) {\n    appDb.updateRole(\"$REPORTING_ROLE_NAME\", {\n      privileges: desiredPrivileges,\n      roles: []\n    });\n  } else {\n    appDb.createRole({\n      role: \"$REPORTING_ROLE_NAME\",\n      privileges: desiredPrivileges,\n      roles: []\n    });\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  ensureUser(adminDb, \"$APP_USERNAME\", \"$APP_PASSWORD_JSON\", [\n    {role: \"readWrite\", db: \"$APP_DATABASE\"}\n  ]);\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  ensureReportingRole();\n  ensureUser(adminDb, \"$REPORTING_USERNAME\", \"$REPORTING_PASSWORD_JSON\", [\n    {role: \"$REPORTING_ROLE_NAME\", db: \"$APP_DATABASE\"}\n  ]);\n}\n\nprint(\"mongodb RBAC reset complete: mode=\" + mode);\nMONGOJS\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t05-09-32z-workflow-r-aad2517f-cluster-a"}}
