[agent] +      actions: [ "find" ]
[agent] +    }
[agent] +  ], []);
[agent] +
[agent] +  ensureUser(appdb, reportingUsername, reportingPassword, [
[agent] +    { role: reportingRoleName, db: appDatabaseName }
[agent] +  ]);
[agent] +}
[agent] +
[agent] +print(`rbac reset complete: mode=${mode}`);
