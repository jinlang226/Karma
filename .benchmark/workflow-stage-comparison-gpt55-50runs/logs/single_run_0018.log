[agent] +  --authenticationDatabase admin <<'MONGOJS'
[agent] +const mode = process.env.MODE;
[agent] +const appDatabaseName = process.env.APP_DATABASE;
[agent] +const appUsername = process.env.APP_USERNAME;
[agent] +const appPassword = process.env.APP_PASSWORD;
[agent] +const reportingUsername = process.env.REPORTING_USERNAME;
[agent] +const reportingPassword = process.env.REPORTING_PASSWORD;
[agent] +const reportingRoleName = process.env.REPORTING_ROLE_NAME;
[agent] +const reportsCollection = process.env.REPORTS_COLLECTION;
[agent] +const appdb = db.getSiblingDB(appDatabaseName);
[agent] +
[agent] +function ensureUser(database, username, password, roles) {
[agent] +  if (database.getUser(username)) {
[agent] +    database.updateUser(username, { pwd: password, roles: roles });
[agent] +  } else {
[agent] +    database.createUser({ user: username, pwd: password, roles: roles });
[agent] +  }
[agent] +}
[agent] +
[agent] +function ensureRole(database, roleName, privileges, roles) {
[agent] +  if (database.getRole(roleName)) {
[agent] +    database.updateRole(roleName, { privileges: privileges, roles: roles });
[agent] +  } else {
[agent] +    database.createRole({ role: roleName, privileges: privileges, roles: roles });
[agent] +  }
[agent] +}
[agent] +
[agent] +if (mode === "all" || mode === "app") {
[agent] +  ensureUser(appdb, appUsername, appPassword, [
[agent] +    { role: "readWrite", db: appDatabaseName }
[agent] +  ]);
[agent] +}
[agent] +
[agent] +if (mode === "all" || mode === "reporting") {
