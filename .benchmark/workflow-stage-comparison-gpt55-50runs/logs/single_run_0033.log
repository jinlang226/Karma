 ]; then\n  APP_PASSWORD=\"$(secret_password \"$APP_SECRET_NAME\" APP_PASSWORD)\"\nfi\nif [ \"$MODE\" = \"all\" ] || [ \"$MODE\" = \"reporting\" ]; then\n  REPORTING_PASSWORD=\"$(secret_password \"$REPORTING_SECRET_NAME\" REPORTING_PASSWORD)\"\nfi\n\nJS='\nconst mode = process.env.RESET_MODE;\nconst appDbName = process.env.APP_DATABASE;\nconst appUser = process.env.APP_USERNAME;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUser = process.env.REPORTING_USERNAME;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRole = process.env.REPORTING_ROLE_NAME;\nconst badRole = process.env.BAD_ROLE_NAME;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\nconst appDb = db.getSiblingDB(appDbName);\n\nfunction ensureUser(user, password, roles) {\n  if (appDb.getUser(user)) {\n    appDb.updateUser(user, { roles: roles });\n  } else {\n    if (!password) {\n      throw new Error(\"cannot create missing user \" + user + \" without a password\");\n    }\n    appDb.createUser({ user: user, pwd: password, roles: roles });\n  }\n}\n\nfunction resetAppUser() {\n  ensureUser(appUser, appPassword, [{ role: \"readWrite\", db: appDbName }]);\n}\n\nfunction resetReportingUser() {\n  const privileges = [{\n    resource: { db: appDbName, collection: reportsCollection },\n    actions: [\"find\"]\n  }];\n  if (appDb.getRole(reportingRole)) {\n    appDb.updateRole(reportingRole, { privileges: privileges, roles: [] });\n  } else {\n    appDb.createRole({ role: reportingRole, privileges: privileges, roles: [] });\n  }\n  ensureUser(reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);\n  if (appDb.getRole(badRole)) {\n    try {\n      appDb.dropRole(badRole);\n    } catch (err) {\n      if (!String(err).includes(\"RoleNotFound\")) {\n        throw err;\n      }\n    }\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  resetAppUser();\n}\nif (mode === \"all\" || mode === \"reporting\") {\n  resetReportingUser();\n}\nprint(\"rbac reset complete: mode=\" + mode);\n'\n\nrun_direct() {\n  host=\"${MONGO_HOST:-localhost}\"\n  RESET_MODE=\"$MODE\" \\\n  APP_DATABASE=\"$APP_DATABASE\" \\\n  APP_USERNAME=\"$APP_USERNAME\" \\\n  APP_PASSWORD=\"$APP_PASSWORD\" \\\n  REPORTING_USERNAME=\"$REPORTING_USERNAME\" \\\n  REPORTING_PASSWORD=\"$REPORTING_PASSWORD\" \\\n  REPORTING_ROLE_NAME=\"$REPORTING_ROLE_NAME\" \\\n  BAD_ROLE_NAME=\"$BAD_ROLE_NAME\" \\\n  REPORTS_COLLECTION=\"$REPORTS_COLLECTION\" \\\n  mongosh --quiet --host \"$host\" -u \"$ADMIN_USERNAME\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin --eval \"$JS\"\n}\n\nrun_via_kubectl() {\n  printf '%s\\n' \"$JS\" | kubectl -n \"$NAMESPACE\" exec -i \"$POD\" -- env \\\n    RESET_MODE=\"$MODE\" \\\n    APP_DATABASE=\"$APP_DATABASE\" \\\n    APP_USERNAME=\"$APP_USERNAME\" \\\n    APP_PASSWORD=\"$APP_PASSWORD\" \\\n    REPORTING_USERNAME=\"$REPORTING_USERNAME\" \\\n    REPORTING_PASSWORD=\"$REPORTING_PASSWORD\" \\\n    REPORTING_ROLE_NAME=\"$REPORTING_ROLE_NAME\" \\\n    BAD_ROLE_NAME=\"$BAD_ROLE_NAME\" \\\n    REPORTS_COLLECTION=\"$REPORTS_COLLECTION\" \\\n    mongosh --quiet --host localhost -u \"$ADMIN_USERNAME\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin\n}\n\nif [ \"${USE_KUBECTL_EXEC:-}\" = \"1\" ]; then\n  run_via_kubectl\nelif command -v mongosh \u003e/dev/null 2\u003e\u00261; then\n  run_direct\nelif command -v kubectl \u003e/dev/null 2\u003e\u00261; then\n  run_via_kubectl\nelse\n  echo \"neither mongosh nor kubectl is available\" \u003e\u00262\n  exit 1\nfi\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t01-51-01z-workflow-r-d58a6cdd-cluster-a"}}
