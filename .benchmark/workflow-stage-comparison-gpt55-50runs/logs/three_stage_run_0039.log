env.BAD_ROLE;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\n\nfunction userExists(database, username) {\n  return database.getUser(username) !== null;\n}\n\nfunction roleExists(database, roleName) {\n  return database.getRole(roleName) !== null;\n}\n\nfunction resetAppUser() {\n  const desiredRoles = [{ role: \"readWrite\", db: appdbName }];\n  if (userExists(admin, appUser)) {\n    admin.updateUser(appUser, { roles: desiredRoles });\n  } else {\n    admin.createUser({ user: appUser, pwd: appPassword, roles: desiredRoles });\n  }\n}\n\nfunction resetReportingRole() {\n  const desiredPrivileges = [\n    {\n      resource: { db: appdbName, collection: reportsCollection },\n      actions: [\"find\"],\n    },\n  ];\n  if (roleExists(appdb, reportingRole)) {\n    appdb.updateRole(reportingRole, { privileges: desiredPrivileges, roles: [] });\n  } else {\n    appdb.createRole({ role: reportingRole, privileges: desiredPrivileges, roles: [] });\n  }\n\n  const desiredRoles = [{ role: reportingRole, db: appdbName }];\n  if (userExists(admin, reportingUser)) {\n    admin.updateUser(reportingUser, { roles: desiredRoles });\n  } else {\n    admin.createUser({ user: reportingUser, pwd: reportingPassword, roles: desiredRoles });\n  }\n\n  if (roleExists(appdb, badRole)) {\n    appdb.dropRole(badRole);\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  resetAppUser();\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  resetReportingRole();\n}\n\nconst users = admin\n  .getUsers()\n  .users\n  .filter((user) =\u003e [appUser, reportingUser].includes(user.user))\n  .map((user) =\u003e ({ user: user.user, db: user.db, roles: user.roles }));\nconst roles = appdb\n  .getRoles({ showPrivileges: true })\n  .roles\n  .filter((role) =\u003e [reportingRole, badRole].includes(role.role))\n  .map((role) =\u003e ({ role: role.role, privileges: role.privileges, roles: role.roles }));\n\nprint(EJSON.stringify({ mode, users, roles }, null, 2));\nJS\n\nmongosh --quiet \\\n  --host \"$MONGO_HOST\" \\\n  --port \"$MONGO_PORT\" \\\n  -u \"$ADMIN_USERNAME\" \\\n  -p \"$ADMIN_PASSWORD\" \\\n  --authenticationDatabase admin \\\n  --file \"$JS_FILE\"\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t06-14-16z-workflow-r-5e8a5c9a-cluster-a"}}
