[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/usr/bin/env bash\nset -euo pipefail\n\nMODE=\"all\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      if [ \"$#\" -lt 2 ]; then\n        echo \"missing value for --mode\" \u003e\u00262\n        exit 2\n      fi\n      MODE=\"$2\"\n      shift 2\n      ;;\n    --mode=*)\n      MODE=\"${1#--mode=}\"\n      shift\n      ;;\n    -h|--help)\n      cat \u003c\u003c'USAGE'\nUsage: reset_rbac.sh [--mode all|app|reporting]\n\nEnvironment:\n  ADMIN_USERNAME       defaults to admin-user\n  ADMIN_PASSWORD       required unless ADMIN_PASSWORD_FILE or known mounted secret path exists\n  APP_PASSWORD         required only if app-user must be created\n  REPORTING_PASSWORD   required only if reporting-user must be created\n  MONGO_URI            optional full admin auth URI override\n  MONGO_HOSTS          optional replica set seed list\nUSAGE\n      exit 0\n      ;;\n    *)\n      echo \"unknown argument: $1\" \u003e\u00262\n      exit 2\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *)\n    echo \"invalid --mode '$MODE'; expected all, app, or reporting\" \u003e\u00262\n    exit 2\n    ;;\nesac\n\nread_value() {\n  var_name=\"$1\"\n  shift\n  eval \"value=\\${$var_name:-}\"\n  if [ -n \"${value:-}\" ]; then\n    printf '%s' \"$value\"\n    return 0\n  fi\n  eval \"file_value=\\${${var_name}_FILE:-}\"\n  if [ -n \"${file_value:-}\" ] \u0026\u0026 [ -r \"$file_value\" ]; then\n    tr -d '\\r\\n' \u003c \"$file_value\"\n    return 0\n  fi\n  for candidate in \"$@\"; do\n    if [ -r \"$candidate\" ]; then\n      tr -d '\\r\\n' \u003c \"$candidate\"\n      return 0\n    fi\n  done\n  return 1\n}\n\nADMIN_USERNAME=\"${ADMIN_USERNAME:-admin-user}\"\nAPP_USERNAME=\"${APP_USERNAME:-app-user}\"\nREPORTING_USERNAME=\"${REPORTING_USERNAME:-reporting-user}\"\nAPP_DATABASE=\"${APP_DATABASE:-appdb}\"\nREPORTING_ROLE_NAME=\"${REPORTING_ROLE_NAME:-reportingRole}\"\nBAD_ROLE_NAME=\"${BAD_ROLE_NAME:-rawRead}\"\nREPORTS_COLLECTION=\"${REPORTS_COLLECTION:-reports}\"\nREPLICA_SET_NAME=\"${REPLICA_SET_NAME:-mongodb-replica}\"\nMONGO_HOSTS=\"${MONGO_HOSTS:-mongodb-replica-0.mongodb-replica-svc:27017,mongodb-replica-1.mongodb-replica-svc:27017,mongodb-replica-2.mongodb-replica-svc:27017}\"\n\nADMIN_PASSWORD=\"$(read_value ADMIN_PASSWORD \\\n  /etc/secrets/admin-user-password/password \\\n  /etc/mongodb-secrets/admin-user-password/password \\\n  /run/secrets/admin-user-password/password \\\n  /var/run/secrets/admin-user-password/password)\" || {\n  echo \"ADMIN_PASSWORD or ADMIN_PASSWORD_FILE is required\" \u003e\u00262\n  exit 1\n}\n\nAPP_PASSWORD=\"$(read_value APP_PASSWORD \\\n  /etc/secrets/app-user-password/password \\\n  /etc/mongodb-secrets/app-user-password/password \\\n  /run/secrets/app-user-password/password \\\n  /var/run/secrets/app-user-password/password || true)\"\nREPORTING_PASSWORD=\"$(read_value REPORTING_PASSWORD \\\n  /etc/secrets/reporting-user-password/password \\\n  /etc/mongodb-secrets/reporting-user-password/password \\\n  /run/secrets/reporting-user-password/password \\\n  /var/run/secrets/reporting-user-password/password || true)\"\n\nif [ -z \"${MONGO_URI:-}\" ]; then\n  encoded_user=\"$(node -e 'process.stdout.write(encodeURIComponent(process.argv[1]))' \"$ADMIN_USERNAME\" 2\u003e/dev/null || printf '%s' \"$ADMIN_USERNAME\")\"\n  encoded_pass=\"$(node -e 'process.stdout.write(encodeURIComponent(process.argv[1]))' \"$ADMIN_PASSWORD\" 2\u003e/dev/null || printf '%s' \"$ADMIN_PASSWORD\")\"\n  MONGO_URI=\"mongodb://${encoded_user}:${encoded_pass}@${MONGO_HOSTS}/admin?replicaSet=${REPLICA_SET_NAME}\"\nfi\n\nexport RESET_MODE=\"$MODE\"\nexport APP_USERNAME REPORTING_USERNAME APP_DATABASE REPORTING_ROLE_NAME BAD_ROLE_NAME REPORTS_COLLECTION APP_PASSWORD REPORTING_PASSWORD\n\nmongosh --quiet \"$MONGO_URI\" \u003c\u003c'MONGOJS'\nconst mode = process.env.RESET_MODE;\nconst appDbName = process.env.APP_DATABASE;\nconst appDb = db.getSiblingDB(appDbName);\nconst appUser = process.env.APP_USERNAME;\nconst reportingUser = process.env.REPORTING_USERNAME;\nconst reportingRole = process.env.REPORTING_ROLE_NAME;\nconst badRole = process.env.BAD_ROLE_NAME;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\nconst appPassword = process.env.APP_PASSWORD || '';\nconst reportingPassword = process.env.REPORTING_PASSWORD || '';\n\nfunction ensureUserWithExactRoles(database, username, password, roles) {\n  const existing = database.getUser(username);\n  if (existing) {\n    database.updateUser(username, { roles });\n    return;\n  }\n  if (!password) {\n    throw new Error(`user ${database.getName()}.${username} does not exist and no password was provided`);\n  }\n  database.createUser({ user: username, pwd: password, roles });\n}\n\nfunction roleExists(database, roleName) {\n  return database.getRole(roleName, { showPrivileges: true }) !== null;\n}\n\nfunction ensureReportingRole() {\n  const roleSpec = {\n    privileges: [\n      {\n        resource: { db: appDbName, collection: reportsCollection },\n        actions: ['find']\n      }\n    ],\n    roles: []\n  };\n  if (roleExists(appDb, reportingRole)) {\n    appDb.updateRole(reportingRole, roleSpec);\n  } else {\n    appDb.createRole({ role: reportingRole, ...roleSpec });\n  }\n}\n\nfunction dropDeprecatedRoleIfUnused() {\n  if (!roleExists(appDb, badRole)) return;\n  try {\n    appDb.dropRole(badRole);\n  } catch (err) {\n    print(`deprecated role ${badRole} left in place: ${err.message}`);\n  }\n}\n\nif (mode === 'all' || mode === 'app') {\n  ensureUserWithExactRoles(appDb, appUser, appPassword, [{ role: 'readWrite', db: appDbName }]);\n}\n\nif (mode === 'all' || mode === 'reporting') {\n  ensureReportingRole();\n  ensureUserWithExactRoles(appDb, reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);\n  dropDeprecatedRoleIfUnused();\n}\n\nprint(`RBAC reset complete: mode=${mode}`);\nMONGOJS\n"},"kind":"ConfigMap","metadata":{"annotations"