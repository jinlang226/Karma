RD APP_DATABASE REPORTS_COLLECTION REPORTING_ROLE_NAME\n\njs='const mode = process.env.MODE;\nconst appDbName = process.env.APP_DATABASE;\nconst appUser = process.env.APP_USERNAME;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUser = process.env.REPORTING_USERNAME;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRole = process.env.REPORTING_ROLE_NAME;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\nconst appdb = db.getSiblingDB(appDbName);\n\nfunction ensureUser(database, username, password, roles) {\n  if (database.getUser(username)) {\n    database.updateUser(username, { roles: roles });\n  } else {\n    database.createUser({ user: username, pwd: password, roles: roles });\n  }\n}\n\nfunction resetAppUser() {\n  ensureUser(appdb, appUser, appPassword, [{ role: \"readWrite\", db: appDbName }]);\n}\n\nfunction resetReportingRoleAndUser() {\n  const roleSpec = {\n    privileges: [{ resource: { db: appDbName, collection: reportsCollection }, actions: [\"find\"] }],\n    roles: []\n  };\n\n  if (appdb.getRole(reportingRole, { showPrivileges: true })) {\n    appdb.updateRole(reportingRole, roleSpec);\n  } else {\n    appdb.createRole(Object.assign({ role: reportingRole }, roleSpec));\n  }\n\n  ensureUser(appdb, reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  resetAppUser();\n}\nif (mode === \"all\" || mode === \"reporting\") {\n  resetReportingRoleAndUser();\n}\nprint(\"rbac reset complete: \" + mode);'\n\nmongosh --quiet --host \"$MONGO_HOST\" -u \"$ADMIN_USERNAME\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin --eval \"$js\"\n"},"kind":"ConfigMap","metadata":{"annotations":{},"labels":{"app.kubernetes.io/name":"mongodb-rbac-reset-script"},"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-18t07-30-36z-workflow-r-7392596b-cluster-a"}}
