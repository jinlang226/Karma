SWORD;\nconst reportingRole = process.env.REPORTING_ROLE;\nconst badRole = process.env.BAD_ROLE;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\n\nconst admin = db.getSiblingDB('admin');\nconst app = db.getSiblingDB(appDbName);\n\nfunction userExists(name) {\n  return admin.getUser(name) !== null;\n}\n\nfunction roleExists(name) {\n  return app.getRoles().roles.some((roleDoc) =\u003e roleDoc.role === name);\n}\n\nfunction resetAppUser() {\n  const desiredRoles = [{ role: 'readWrite', db: appDbName }];\n  if (userExists(appUser)) {\n    admin.updateUser(appUser, { roles: desiredRoles });\n  } else {\n    admin.createUser({ user: appUser, pwd: appPassword, roles: desiredRoles });\n  }\n}\n\nfunction resetReportingUser() {\n  const reportPrivileges = [{\n    resource: { db: appDbName, collection: reportsCollection },\n    actions: ['find']\n  }];\n\n  if (roleExists(reportingRole)) {\n    app.updateRole(reportingRole, { privileges: reportPrivileges, roles: [] });\n  } else {\n    app.createRole({ role: reportingRole, privileges: reportPrivileges, roles: [] });\n  }\n\n  const desiredRoles = [{ role: reportingRole, db: appDbName }];\n  if (userExists(reportingUser)) {\n    admin.updateUser(reportingUser, { roles: desiredRoles });\n  } else {\n    admin.createUser({ user: reportingUser, pwd: reportingPassword, roles: desiredRoles });\n  }\n\n  if (roleExists(badRole)) {\n    app.dropRole(badRole);\n  }\n}\n\nif (mode === 'all' || mode === 'app') {\n  resetAppUser();\n}\nif (mode === 'all' || mode === 'reporting') {\n  resetReportingUser();\n}\n\nprint(`rbac reset complete: mode=${mode}`);\nMONGOJS\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-18t07-50-38z-workflow-r-f962d733-cluster-a"}}
