[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/usr/bin/env bash\nset -euo pipefail\n\nusage() {\n  echo \"Usage: $0 --mode all|app|reporting\" \u003e\u00262\n}\n\nMODE=\"\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      [ \"$#\" -ge 2 ] || { usage; exit 2; }\n      MODE=\"$2\"\n      shift 2\n      ;;\n    --mode=*)\n      MODE=\"${1#--mode=}\"\n      shift\n      ;;\n    -h|--help)\n      usage\n      exit 0\n      ;;\n    *)\n      usage\n      exit 2\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *) usage; exit 2 ;;\nesac\n\nADMIN_USERNAME=\"${ADMIN_USERNAME:-admin-user}\"\nADMIN_PASSWORD=\"${ADMIN_PASSWORD:-admin123password}\"\nADMIN_AUTH_DB=\"${ADMIN_AUTH_DB:-admin}\"\nAPP_DATABASE=\"${APP_DATABASE:-appdb}\"\nAPP_USERNAME=\"${APP_USERNAME:-app-user}\"\nAPP_PASSWORD=\"${APP_PASSWORD:-app123password}\"\nREPORTING_USERNAME=\"${REPORTING_USERNAME:-reporting-user}\"\nREPORTING_PASSWORD=\"${REPORTING_PASSWORD:-reporting123password}\"\nREPORTING_ROLE_NAME=\"${REPORTING_ROLE_NAME:-reportingRole}\"\nREPORTS_COLLECTION=\"${REPORTS_COLLECTION:-reports}\"\n\nif [ -z \"${MONGO_URI:-}\" ]; then\n  if [ -n \"${MONGO_HOSTS:-}\" ]; then\n    MONGO_URI=\"mongodb://${MONGO_HOSTS}/?replicaSet=${REPLICA_SET_NAME:-mongodb-replica}\"\n  else\n    MONGO_HOST=\"${MONGO_HOST:-127.0.0.1:27017}\"\n    MONGO_URI=\"mongodb://${MONGO_HOST}/?directConnection=true\"\n  fi\nfi\n\nmongosh \"$MONGO_URI\" --quiet \\\n  -u \"$ADMIN_USERNAME\" \\\n  -p \"$ADMIN_PASSWORD\" \\\n  --authenticationDatabase \"$ADMIN_AUTH_DB\" \\\n  --eval \"\nconst mode = '$MODE';\nconst appDatabase = '$APP_DATABASE';\nconst appUsername = '$APP_USERNAME';\nconst appPassword = '$APP_PASSWORD';\nconst reportingUsername = '$REPORTING_USERNAME';\nconst reportingPassword = '$REPORTING_PASSWORD';\nconst reportingRoleName = '$REPORTING_ROLE_NAME';\nconst reportsCollection = '$REPORTS_COLLECTION';\n\nconst appdb = db.getSiblingDB(appDatabase);\n\nfunction resetAppUser() {\n  const roles = [{ role: 'readWrite', db: appDatabase }];\n  const existing = appdb.getUser(appUsername);\n  if (existing) {\n    appdb.updateUser(appUsername, { roles });\n  } else {\n    appdb.createUser({ user: appUsername, pwd: appPassword, roles });\n  }\n}\n\nfunction resetReportingAccess() {\n  const privileges = [{\n    resource: { db: appDatabase, collection: reportsCollection },\n    actions: ['find']\n  }];\n  const roleSpec = { privileges, roles: [] };\n\n  if (appdb.getRole(reportingRoleName, { showPrivileges: true })) {\n    appdb.updateRole(reportingRoleName, roleSpec);\n  } else {\n    appdb.createRole({ role: reportingRoleName, privileges, roles: [] });\n  }\n\n  const roles = [{ role: reportingRoleName, db: appDatabase }];\n  const existing = appdb.getUser(reportingUsername);\n  if (existing) {\n    appdb.updateUser(reportingUsername, { roles });\n  } else {\n    appdb.createUser({ user: reportingUsername, pwd: reportingPassword, roles });\n  }\n}\n\nif (mode === 'all' || mode === 'app') {\n  resetAppUser();\n}\nif (mode === 'all' || mode === 'reporting') {\n  resetReportingAccess();\n}\n\nprint('mongodb RBAC reset completed for mode=' + mode);\n\"\n"},"kind":"ConfigMap","metadata":{"annotations":{},"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-18t07-40-30z-workflow-r-af335ec1-cluster-a"}}
