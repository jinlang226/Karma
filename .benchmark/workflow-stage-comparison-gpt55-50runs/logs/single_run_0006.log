t mode = process.env.RESET_MODE;\nconst appDbName = process.env.APP_DATABASE;\nconst appUsername = process.env.APP_USERNAME;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUsername = process.env.REPORTING_USERNAME;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRoleName = process.env.REPORTING_ROLE_NAME;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\n\nfunction ensureUser(database, username, password, roles) {\n  const targetDb = db.getSiblingDB(database);\n  if (targetDb.getUser(username) === null) {\n    targetDb.createUser({ user: username, pwd: password, roles });\n  } else {\n    targetDb.updateUser(username, { pwd: password, roles });\n  }\n}\n\nfunction ensureReportingRole() {\n  const appDb = db.getSiblingDB(appDbName);\n  const role = {\n    privileges: [\n      {\n        resource: { db: appDbName, collection: reportsCollection },\n        actions: [ \"find\" ]\n      }\n    ],\n    roles: []\n  };\n\n  if (appDb.getRole(reportingRoleName, { showPrivileges: true }) === null) {\n    appDb.createRole({ role: reportingRoleName, ...role });\n  } else {\n    appDb.updateRole(reportingRoleName, role);\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  ensureUser(appDbName, appUsername, appPassword, [\n    { role: \"readWrite\", db: appDbName }\n  ]);\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  ensureReportingRole();\n  ensureUser(appDbName, reportingUsername, reportingPassword, [\n    { role: reportingRoleName, db: appDbName }\n  ]);\n}\n\nprint(`RBAC reset complete for mode=${mode}`);\nMONGOJS\n\nif [ -n \"${MONGO_URI:-}\" ]; then\n  mongosh --quiet \"$MONGO_URI\" --file \"$js_file\"\nelse\n  mongosh --quiet --host \"$MONGO_HOST\" -u \"$ADMIN_USERNAME\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase \"$AUTH_DB\" --file \"$js_file\"\nfi\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-18t08-33-31z-