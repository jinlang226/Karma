[agent] +const appDbName = process.env.APP_DATABASE;
[agent] +const appUsername = process.env.APP_USERNAME;
[agent] +const appPassword = process.env.APP_PASSWORD;
[agent] +const reportingUsername = process.env.REPORTING_USERNAME;
[agent] +const reportingPassword = process.env.REPORTING_PASSWORD;
[agent] +const reportingRoleName = process.env.REPORTING_ROLE_NAME;
[agent] +const reportsCollection = process.env.REPORTS_COLLECTION;
[agent] +
[agent] +function ensureUser(database, username, password, roles) {
[agent] +  const targetDb = db.getSiblingDB(database);
[agent] +  if (targetDb.getUser(username) === null) {
[agent] +    targetDb.createUser({ user: username, pwd: password, roles });
[agent] +  } else {
[agent] +    targetDb.updateUser(username, { pwd: password, roles });
[agent] +  }
[agent] +}
[agent] +
[agent] +function ensureReportingRole() {
[agent] +  const appDb = db.getSiblingDB(appDbName);
[agent] +  const role = {
[agent] +    privileges: [
[agent] +      {
[agent] +        resource: { db: appDbName, collection: reportsCollection },
[agent] +        actions: [ "find" ]
[agent] +      }
[agent] +    ],
[agent] +    roles: []
[agent] +  };
[agent] +
[agent] +  if (appDb.getRole(reportingRoleName, { showPrivileges: true }) === null) {
[agent] +    appDb.createRole({ role: reportingRoleName, ...role });
[agent] +  } else {
[agent] +    appDb.updateRole(reportingRoleName, role);
[agent] +  }
[agent] +}
[agent] +
[agent] +if (mode === "all" || mode === "app") {
[agent] +  ensureUser(appDbName, appUsername, appPassword, [
[agent] +    { role: "readWrite", db: appDbName }
[agent] +  ]);
[agent] +}
[agent] +
[agent] +if (mode === "all" || mode === "reporting") {
[agent] +  ensureReportingRole();
[agent] +  ensureUser(appDbName, reportingUsername, reportingPassword, [
[agent] +    { role: reportingRoleName, db: appDbName }
[agent] +  ]);
[agent] +}
[agent] +
[agent] +print(`RBAC reset complete for mode=${mode}`);
[agent] +MONGOJS
