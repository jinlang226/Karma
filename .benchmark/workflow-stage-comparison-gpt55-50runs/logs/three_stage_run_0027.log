[kubectl] 2026-05-19T00:44:40Z kubectl -n wf-2026-05-19t00-41-20z-workflow-r-45a534e8-cluster-a exec mongodb-replica-0 -- mongosh --quiet -u admin-user -p admin123password --authenticationDatabase admin --eval '
const admin = db.getSiblingDB("admin");
const appdb = db.getSiblingDB("appdb");
const reportingPassword = "reporting123password";
const rawRead = appdb.getRole("rawRead", {showPrivileges: true});
const desiredRawPrivileges = [{resource: {db: "appdb", collection: "raw"}, actions: ["find"]}];
if (rawRead) {
  appdb.updateRole("rawRead", {privileges: desiredRawPrivileges, roles: []});
} else {
  appdb.createRole({role: "rawRead", privileges: desiredRawPrivileges, roles: []});
}
const u = admin.getUser("reporting-user");
if (u) {
  admin.updateUser("reporting-user", {pwd: reportingPassword, roles: [{role: "rawRead", db: "appdb"}]});
} else {
  admin.createUser({user: "reporting-user", pwd: reportingPassword, roles: [{role: "rawRead", db: "appdb"}]});
}
if (appdb.getRole("reportingRole")) {
  appdb.dropRole("reportingRole");
}
print("stage2-rbac-ready");
'
