[agent] +[ -n "$MODE" ] || MODE="all"
[agent] +case "$MODE" in
[agent] +  all|app|reporting) ;;
[agent] +  *) usage; exit 2 ;;
[agent] +esac
[agent] +
[agent] +ADMIN_USERNAME="${ADMIN_USERNAME:-admin-user}"
[agent] +ADMIN_PASSWORD="${ADMIN_PASSWORD:-admin123password}"
[agent] +MONGO_URI="${MONGO_URI:-mongodb://mongodb-replica-0.mongodb-replica-svc:27017,mongodb-replica-1.mongodb-replica-svc:27017,mongodb-replica-2.mongodb-replica-svc:27017/admin?replicaSet=mongodb-replica}"
