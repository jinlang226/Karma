[agent] +
[agent] +cat > "$JS_FILE" <<'JS'
[agent] +const mode = process.env.RESET_MODE;
[agent] +const adminDb = db.getSiblingDB("admin");
[agent] +const appDb = db.getSiblingDB("appdb");
[agent] +
[agent] +function sameRoles(actual, expected) {
[agent] +  const normalize = roles => roles
[agent] +    .map(r => ({ role: r.role, db: r.db }))
[agent] +    .sort((a, b) => (a.db + "." + a.role).localeCompare(b.db + "." + b.role));
[agent] +  return JSON.stringify(normalize(actual || [])) === JSON.stringify(normalize(expected));
[agent] +}
[agent] +
[agent] +function ensureUserRoles(dbh, username, roles) {
[agent] +  const user = dbh.getUser(username);
[agent] +  if (!user) {
[agent] +    throw new Error("Required user is missing: " + username);
[agent] +  }
[agent] +  if (!sameRoles(user.roles, roles)) {
[agent] +    dbh.updateUser(username, { roles });
[agent] +  }
[agent] +}
[agent] +
[agent] +function ensureReportingRole() {
[agent] +  const privileges = [
[agent] +    { resource: { db: "appdb", collection: "reports" }, actions: ["find"] }
[agent] +  ];
[agent] +  const existing = appDb.getRole("reportingRole", { showPrivileges: true });
