[agent] +    --mode=*)
[agent] +      MODE="${1#--mode=}"
[agent] +      shift
[agent] +      ;;
[agent] +    -h|--help)
[agent] +      usage
[agent] +      exit 0
[agent] +      ;;
[agent] +    *)
[agent] +      usage
[agent] +      exit 2
[agent] +      ;;
