[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/usr/bin/env bash\nset -euo pipefail\n\nMODE=\"all\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      if [ \"$#\" -lt 2 ]; then\n        echo \"missing value for --mode\" \u003e\u00262\n        exit 2\n      fi\n      MODE=\"$2\"\n      shift 2\n      ;;\n    --mode=*)\n      MODE=\"${1#--mode=}\"\n      shift\n      ;;\n    -h|--help)\n      echo \"usage: $0 [--mode all|app|reporting]\"\n      exit 0\n      ;;\n    *)\n      echo \"unknown argument: $1\" \u003e\u00262\n      exit 2\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *)\n    echo \"invalid --mode: $MODE (expected all, app, or reporting)\" \u003e\u00262\n    exit 2\n    ;;\nesac\n\nexport RESET_MODE=\"$MODE\"\nexport MONGO_HOST=\"${MONGO_HOST:-localhost}\"\nexport MONGO_PORT=\"${MONGO_PORT:-27017}\"\nexport MONGO_AUTH_DB=\"${MONGO_AUTH_DB:-admin}\"\nexport MONGO_ADMIN_USER=\"${MONGO_ADMIN_USER:-admin-user}\"\nexport MONGO_ADMIN_PASSWORD=\"${MONGO_ADMIN_PASSWORD:-${ADMIN_PASSWORD:-admin123password}}\"\nexport APP_DATABASE=\"${APP_DATABASE:-appdb}\"\nexport APP_USERNAME=\"${APP_USERNAME:-app-user}\"\nexport APP_PASSWORD=\"${APP_PASSWORD:-app123password}\"\nexport REPORTING_USERNAME=\"${REPORTING_USERNAME:-reporting-user}\"\nexport REPORTING_PASSWORD=\"${REPORTING_PASSWORD:-reporting123password}\"\nexport REPORTING_ROLE_NAME=\"${REPORTING_ROLE_NAME:-reportingRole}\"\nexport BAD_ROLE_NAME=\"${BAD_ROLE_NAME:-rawRead}\"\nexport REPORTS_COLLECTION=\"${REPORTS_COLLECTION:-reports}\"\n\nmongosh --quiet \\\n  --host \"$MONGO_HOST\" \\\n  --port \"$MONGO_PORT\" \\\n  -u \"$MONGO_ADMIN_USER\" \\\n  -p \"$MONGO_ADMIN_PASSWORD\" \\\n  --authenticationDatabase \"$MONGO_AUTH_DB\" \u003c\u003c'MONGOJS'\nconst mode = process.env.RESET_MODE;\nconst appDbName = process.env.APP_DATABASE;\nconst appUser = process.env.APP_USERNAME;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUser = process.env.REPORTING_USERNAME;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRole = process.env.REPORTING_ROLE_NAME;\nconst badRole = process.env.BAD_ROLE_NAME;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\n\nconst adminDb = db.getSiblingDB(\"admin\");\nconst appDb = db.getSiblingDB(appDbName);\n\nfunction ensureAdminUser(userName, password, roles) {\n  if (adminDb.getUser(userName) === null) {\n    adminDb.createUser({ user: userName, pwd: password, roles });\n  } else {\n    adminDb.updateUser(userName, { pwd: password, roles });\n  }\n}\n\nfunction resetAppUser() {\n  ensureAdminUser(appUser, appPassword, [{ role: \"readWrite\", db: appDbName }]);\n}\n\nfunction resetReportingRole() {\n  const roleSpec = {\n    privileges: [\n      {\n        resource: { db: appDbName, collection: reportsCollection },\n        actions: [\"find\"]\n      }\n    ],\n    roles: []\n  };\n\n  if (appDb.getRole(reportingRole) === null) {\n    appDb.createRole({ role: reportingRole, ...roleSpec });\n  } else {\n    appDb.updateRole(reportingRole, roleSpec);\n  }\n}\n\nfunction resetReportingUser() {\n  resetReportingRole();\n  ensureAdminUser(reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);\n\n  if (appDb.getRole(badRole) !== null) {\n    appDb.dropRole(badRole);\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  resetAppUser();\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  resetReportingUser();\n}\n\nprint(`rbac reset complete: mode=${mode}`);\nMONGOJS\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-18t20-50-13z-workflow-r-aa374c66-cluster-a"}}
