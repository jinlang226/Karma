[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/bin/sh\nset -eu\n\nMODE=\"all\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      [ \"$#\" -ge 2 ] || { echo \"missing value for --mode\" \u003e\u00262; exit 2; }\n      MODE=\"$2\"\n      shift 2\n      ;;\n    --mode=*)\n      MODE=\"${1#--mode=}\"\n      shift\n      ;;\n    -h|--help)\n      echo \"Usage: $0 [--mode all|app|reporting]\"\n      exit 0\n      ;;\n    *)\n      echo \"unknown argument: $1\" \u003e\u00262\n      exit 2\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *) echo \"invalid mode: $MODE (expected all, app, or reporting)\" \u003e\u00262; exit 2 ;;\nesac\n\nMONGO_HOST=\"${MONGO_HOST:-127.0.0.1}\"\nMONGO_PORT=\"${MONGO_PORT:-27017}\"\nADMIN_USERNAME=\"${ADMIN_USERNAME:-admin-user}\"\nADMIN_PASSWORD=\"${ADMIN_PASSWORD:-admin123password}\"\nAPP_DATABASE=\"${APP_DATABASE:-appdb}\"\nAPP_USERNAME=\"${APP_USERNAME:-app-user}\"\nAPP_PASSWORD=\"${APP_PASSWORD:-app123password}\"\nREPORTING_USERNAME=\"${REPORTING_USERNAME:-reporting-user}\"\nREPORTING_PASSWORD=\"${REPORTING_PASSWORD:-reporting123password}\"\nREPORTING_ROLE_NAME=\"${REPORTING_ROLE_NAME:-reportingRole}\"\nBAD_ROLE_NAME=\"${BAD_ROLE_NAME:-rawRead}\"\nREPORTS_COLLECTION=\"${REPORTS_COLLECTION:-reports}\"\n\nexport RESET_MODE=\"$MODE\" APP_DATABASE APP_USERNAME APP_PASSWORD REPORTING_USERNAME REPORTING_PASSWORD REPORTING_ROLE_NAME BAD_ROLE_NAME REPORTS_COLLECTION\n\nmongosh --quiet --host \"$MONGO_HOST\" --port \"$MONGO_PORT\" \\\n  -u \"$ADMIN_USERNAME\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin \u003c\u003c'MONGO'\nconst mode = process.env.RESET_MODE;\nconst appDbName = process.env.APP_DATABASE;\nconst appUser = process.env.APP_USERNAME;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUser = process.env.REPORTING_USERNAME;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRole = process.env.REPORTING_ROLE_NAME;\nconst badRole = process.env.BAD_ROLE_NAME;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\nconst appdb = db.getSiblingDB(appDbName);\n\nfunction roleSpec(role, dbName) {\n  return { role: role, db: dbName };\n}\n\nfunction ensureUser(database, username, password, roles) {\n  if (database.getUser(username)) {\n    database.updateUser(username, { roles: roles });\n  } else {\n    database.createUser({ user: username, pwd: password, roles: roles });\n  }\n}\n\nfunction resetAppUser() {\n  ensureUser(appdb, appUser, appPassword, [roleSpec('readWrite', appDbName)]);\n}\n\nfunction resetReporting() {\n  const desiredPrivileges = [\n    { resource: { db: appDbName, collection: reportsCollection }, actions: ['find'] }\n  ];\n\n  if (appdb.getRole(reportingRole, { showPrivileges: true })) {\n    appdb.updateRole(reportingRole, { privileges: desiredPrivileges, roles: [] });\n  } else {\n    appdb.createRole({ role: reportingRole, privileges: desiredPrivileges, roles: [] });\n  }\n\n  ensureUser(appdb, reportingUser, reportingPassword, [roleSpec(reportingRole, appDbName)]);\n\n  const rawRead = appdb.getRole(badRole);\n  if (rawRead) {\n    try {\n      appdb.dropRole(badRole);\n    } catch (err) {\n      if (!String(err).match(/RoleNotFound/)) {\n        throw err;\n      }\n    }\n  }\n}\n\nif (mode === 'all' || mode === 'app') {\n  resetAppUser();\n}\nif (mode === 'all' || mode === 'reporting') {\n  resetReporting();\n}\n\nprint(`rbac reset complete: mode=${mode}`);\nMONGO\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t05-38-41z-workflow-r-daf9cd11-cluster-a"}}
