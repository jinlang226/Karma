ord, roles) {\n  if (adminDb.getUser(userName)) {\n    adminDb.updateUser(userName, { roles: roles });\n  } else {\n    adminDb.createUser({ user: userName, pwd: password, roles: roles });\n  }\n}\n\nfunction resetAppUser() {\n  ensureAdminUser(appUserName, appPassword, [roleSpec(\"readWrite\", appDbName)]);\n}\n\nfunction resetReportingRole() {\n  const privileges = [\n    {\n      resource: { db: appDbName, collection: reportsCollection },\n      actions: [\"find\"]\n    }\n  ];\n\n  if (appDb.getRole(reportingRoleName, { showPrivileges: false })) {\n    appDb.updateRole(reportingRoleName, { privileges: privileges, roles: [] });\n  } else {\n    appDb.createRole({ role: reportingRoleName, privileges: privileges, roles: [] });\n  }\n}\n\nfunction resetReportingUser() {\n  resetReportingRole();\n  ensureAdminUser(reportingUserName, reportingPassword, [roleSpec(reportingRoleName, appDbName)]);\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  resetAppUser();\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  resetReportingUser();\n}\n\nprint(\"RBAC reset complete: mode=\" + mode);\nJS\n\nRESET_MODE=\"$MODE\" \\\nAPP_DATABASE=\"$APP_DATABASE\" \\\nAPP_USERNAME=\"$APP_USERNAME\" \\\nAPP_PASSWORD=\"$APP_PASSWORD\" \\\nREPORTING_USERNAME=\"$REPORTING_USERNAME\" \\\nREPORTING_PASSWORD=\"$REPORTING_PASSWORD\" \\\nREPORTING_ROLE_NAME=\"$REPORTING_ROLE_NAME\" \\\nREPORTS_COLLECTION=\"$REPORTS_COLLECTION\" \\\nmongosh \"$MONGO_URI\" --quiet \"$JS_FILE\"\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-18t21-06-09z-workflow-r-6a1a7cab-cluster-a"}}
