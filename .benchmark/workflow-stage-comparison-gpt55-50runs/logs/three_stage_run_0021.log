[agent] +#!/bin/sh
[agent] +set -eu
[agent] +
[agent] +MODE="all"
[agent] +
[agent] +usage() {
[agent] +  echo "Usage: $0 [--mode all|app|reporting]" >&2
[agent] +}
[agent] +
[agent] +while [ "$#" -gt 0 ]; do
[agent] +  case "$1" in
[agent] +    --mode)
[agent] +      [ "$#" -ge 2 ] || { usage; exit 2; }
[agent] +      MODE="$2"
[agent] +      shift 2
[agent] +      ;;
[agent] +    --mode=*)
[agent] +      MODE="${1#--mode=}"
[agent] +      shift
[agent] +      ;;
[agent] +    -h|--help)
[agent] +      usage
[agent] +      exit 0
[agent] +      ;;
[agent] +    *)
[agent] +      usage
[agent] +      exit 2
[agent] +      ;;
[agent] +  esac
[agent] +done
[agent] +
[agent] +case "$MODE" in
[agent] +  all|app|reporting) ;;
[agent] +  *) usage; exit 2 ;;
[agent] +esac
[agent] +
[agent] +ADMIN_USERNAME="${ADMIN_USERNAME:-admin-user}"
[agent] +ADMIN_PASSWORD="${ADMIN_PASSWORD:-admin123password}"
[agent] +MONGO_HOST="${MONGO_HOST:-localhost}"
[agent] +MONGO_PORT="${MONGO_PORT:-27017}"
[agent] +MONGO_URI="${MONGO_URI:-mongodb://${ADMIN_USERNAME}:${ADMIN_PASSWORD}@${MONGO_HOST}:${MONGO_PORT}/admin?authSource=admin}"
[agent] +
[agent] +APP_DATABASE="${APP_DATABASE:-appdb}"
[agent] +APP_USERNAME="${APP_USERNAME:-app-user}"
[agent] +APP_PASSWORD="${APP_PASSWORD:-app123password}"
[agent] +REPORTING_USERNAME="${REPORTING_USERNAME:-reporting-user}"
[agent] +REPORTING_PASSWORD="${REPORTING_PASSWORD:-reporting123password}"
[agent] +REPORTING_ROLE_NAME="${REPORTING_ROLE_NAME:-reportingRole}"
[agent] +REPORTS_COLLECTION="${REPORTS_COLLECTION:-reports}"
[agent] +
[agent] +JS_FILE="$(mktemp)"
[agent] +trap 'rm -f "$JS_FILE"' EXIT
[agent] +
[agent] +cat > "$JS_FILE" <<'JS'
[agent] +const mode = process.env.RESET_MODE;
[agent] +const appDbName = process.env.APP_DATABASE;
[agent] +const appUserName = process.env.APP_USERNAME;
[agent] +const appPassword = process.env.APP_PASSWORD;
[agent] +const reportingUserName = process.env.REPORTING_USERNAME;
[agent] +const reportingPassword = process.env.REPORTING_PASSWORD;
[agent] +const reportingRoleName = process.env.REPORTING_ROLE_NAME;
[agent] +const reportsCollection = process.env.REPORTS_COLLECTION;
[agent] +
[agent] +const adminDb = db.getSiblingDB("admin");
[agent] +const appDb = db.getSiblingDB(appDbName);
[agent] +
[agent] +function roleSpec(role, dbName) {
[agent] +  return { role: role, db: dbName };
[agent] +}
[agent] +
[agent] +function ensureAdminUser(userName, password, roles) {
[agent] +  if (adminDb.getUser(userName)) {
[agent] +    adminDb.updateUser(userName, { roles: roles });
[agent] +  } else {
[agent] +    adminDb.createUser({ user: userName, pwd: password, roles: roles });
[agent] +  }
[agent] +}
[agent] +
[agent] +function resetAppUser() {
[agent] +  ensureAdminUser(appUserName, appPassword, [roleSpec("readWrite", appDbName)]);
[agent] +}
[agent] +
[agent] +function resetReportingRole() {
[agent] +  const privileges = [
[agent] +    {
[agent] +      resource: { db: appDbName, collection: reportsCollection },
[agent] +      actions: ["find"]
[agent] +    }
[agent] +  ];
[agent] +
[agent] +  if (appDb.getRole(reportingRoleName, { showPrivileges: false })) {
[agent] +    appDb.updateRole(reportingRoleName, { privileges: privileges, roles: [] });
[agent] +  } else {
[agent] +    appDb.createRole({ role: reportingRoleName, privileges: privileges, roles: [] });
[agent] +  }
[agent] +}
[agent] +
[agent] +function resetReportingUser() {
[agent] +  resetReportingRole();
[agent] +  ensureAdminUser(reportingUserName, reportingPassword, [roleSpec(reportingRoleName, appDbName)]);
[agent] +}
[agent] +
[agent] +if (mode === "all" || mode === "app") {
[agent] +  resetAppUser();
[agent] +}
[agent] +
[agent] +if (mode === "all" || mode === "reporting") {
[agent] +  resetReportingUser();
[agent] +}
[agent] +
[agent] +print("RBAC reset complete: mode=" + mode);
