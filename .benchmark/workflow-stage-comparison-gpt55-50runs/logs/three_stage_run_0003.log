[agent] +  } else {
[agent] +    admin.createUser({ user, pwd: password, roles });
[agent] +  }
[agent] +
[agent] +  if (appdb.getRole(badRole)) {
[agent] +    appdb.dropRole(badRole);
[agent] +  }
[agent] +}
[agent] +
[agent] +if (mode === "all" || mode === "app") {
[agent] +  resetAppUser();
