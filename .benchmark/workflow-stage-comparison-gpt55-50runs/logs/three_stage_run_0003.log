const admin = db.getSiblingDB("admin");
const appdb = db.getSiblingDB("appdb");
const reportingPass = process.env.REPORTING_PASS;

const reportingRole = appdb.getRole("reportingRole");
if (reportingRole) {
  appdb.dropRole("reportingRole");
}

const rawReadSpec = {
  privileges: [{ resource: { db: "appdb", collection: "raw" }, actions: ["find"] }],
  roles: []
};
if (appdb.getRole("rawRead")) {
  appdb.updateRole("rawRead", rawReadSpec);
} else {
  appdb.createRole(Object.assign({ role: "rawRead" }, rawReadSpec));
}

if (admin.getUser("reporting-user")) {
  admin.updateUser("reporting-user", { pwd: reportingPass, roles: [{ role: "rawRead", db: "appdb" }] });
} else {
  admin.createUser({ user: "reporting-user", pwd: reportingPass, roles: [{ role: "rawRead", db: "appdb" }] });
}

print("USERS"); printjson(admin.getUsers());
print("APP ROLES"); printjson(appdb.getRoles({showPrivileges:true}));
'
