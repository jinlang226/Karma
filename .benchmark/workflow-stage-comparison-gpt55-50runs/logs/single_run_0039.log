[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/usr/bin/env bash\nset -euo pipefail\n\nMODE=\"all\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      if [ \"$#\" -lt 2 ]; then\n        echo \"missing value for --mode\" \u003e\u00262\n        exit 2\n      fi\n      MODE=\"$2\"\n      shift 2\n      ;;\n    --help|-h)\n      echo \"Usage: $0 [--mode all|app|reporting]\"\n      exit 0\n      ;;\n    *)\n      echo \"unknown argument: $1\" \u003e\u00262\n      exit 2\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *)\n    echo \"invalid --mode '$MODE'; expected all, app, or reporting\" \u003e\u00262\n    exit 2\n    ;;\nesac\n\nADMIN_USERNAME=\"${ADMIN_USERNAME:-admin-user}\"\nADMIN_PASSWORD=\"${ADMIN_PASSWORD:-admin123password}\"\nAPP_USERNAME=\"${APP_USERNAME:-app-user}\"\nAPP_PASSWORD=\"${APP_PASSWORD:-app123password}\"\nREPORTING_USERNAME=\"${REPORTING_USERNAME:-reporting-user}\"\nREPORTING_PASSWORD=\"${REPORTING_PASSWORD:-reporting123password}\"\nAPP_DATABASE=\"${APP_DATABASE:-appdb}\"\nREPORTING_ROLE_NAME=\"${REPORTING_ROLE_NAME:-reportingRole}\"\nREPORTS_COLLECTION=\"${REPORTS_COLLECTION:-reports}\"\nMONGO_HOST=\"${MONGO_HOST:-localhost:27017}\"\nREPLICA_SET_NAME=\"${REPLICA_SET_NAME:-mongodb-replica}\"\n\nMONGO_URI=\"${MONGO_URI:-mongodb://${MONGO_HOST}/admin?replicaSet=${REPLICA_SET_NAME}}\"\n\nmongosh \"$MONGO_URI\" --quiet \\\n  -u \"$ADMIN_USERNAME\" \\\n  -p \"$ADMIN_PASSWORD\" \\\n  --authenticationDatabase admin \\\n  --eval \"\nconst mode = '$MODE';\nconst appDbName = '$APP_DATABASE';\nconst appUser = '$APP_USERNAME';\nconst appPassword = '$APP_PASSWORD';\nconst reportingUser = '$REPORTING_USERNAME';\nconst reportingPassword = '$REPORTING_PASSWORD';\nconst reportingRole = '$REPORTING_ROLE_NAME';\nconst reportsCollection = '$REPORTS_COLLECTION';\nconst appdb = db.getSiblingDB(appDbName);\n\nfunction ensureUser(database, username, password, roles) {\n  const existing = database.getUser(username);\n  if (existing) {\n    database.updateUser(username, { roles: roles });\n  } else {\n    database.createUser({ user: username, pwd: password, roles: roles });\n  }\n}\n\nfunction resetAppUser() {\n  ensureUser(appdb, appUser, appPassword, [{ role: 'readWrite', db: appDbName }]);\n}\n\nfunction resetReporting() {\n  const roleDef = {\n    privileges: [\n      { resource: { db: appDbName, collection: reportsCollection }, actions: ['find'] }\n    ],\n    roles: []\n  };\n\n  if (appdb.getRole(reportingRole)) {\n    appdb.updateRole(reportingRole, roleDef);\n  } else {\n    appdb.createRole(Object.assign({ role: reportingRole }, roleDef));\n  }\n\n  ensureUser(appdb, reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);\n}\n\nif (mode === 'all' || mode === 'app') {\n  resetAppUser();\n}\nif (mode === 'all' || mode === 'reporting') {\n  resetReporting();\n}\n\nprint('rbac reset complete: mode=' + mode);\n\" \n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t05-05-01z-workflow-r-32e4bd14-cluster-a"}}
