[agent]         admin.createUser({user: \"reporting-user\", pwd: reportingPassword, roles: [reportingRole]});
[agent]       } else {
[agent]         admin.updateUser(\"reporting-user\", {roles: [reportingRole]});
[agent]       }
[agent]       if (appdb.getRole(\"rawRead\") "'!= null) {
[agent]         appdb.dropRole("rawRead");
[agent]       }
[agent]     }
