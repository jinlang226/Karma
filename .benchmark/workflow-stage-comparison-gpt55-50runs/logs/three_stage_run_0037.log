[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/bin/sh\nset -eu\n\nMODE=\"all\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      if [ \"$#\" -lt 2 ]; then\n        echo \"missing value for --mode\" \u003e\u00262\n        exit 2\n      fi\n      MODE=\"$2\"\n      shift 2\n      ;;\n    --mode=*)\n      MODE=\"${1#--mode=}\"\n      shift\n      ;;\n    -h|--help)\n      echo \"usage: $0 [--mode all|app|reporting]\"\n      exit 0\n      ;;\n    *)\n      echo \"unknown argument: $1\" \u003e\u00262\n      exit 2\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *)\n    echo \"invalid mode: $MODE\" \u003e\u00262\n    exit 2\n    ;;\nesac\n\nDEFAULT_HOSTS=\"mongodb-replica-0.mongodb-replica-svc:27017,mongodb-replica-1.mongodb-replica-svc:27017,mongodb-replica-2.mongodb-replica-svc:27017\"\nMONGO_URI=\"${MONGO_URI:-mongodb://admin-user:admin123password@${DEFAULT_HOSTS}/admin?replicaSet=mongodb-replica}\"\nREPORTING_PASSWORD=\"${REPORTING_PASSWORD:-reporting123password}\"\nexport RESET_MODE=\"$MODE\"\nexport REPORTING_PASSWORD\n\nmongosh --quiet \"$MONGO_URI\" \u003c\u003c'JS'\nconst mode = process.env.RESET_MODE;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst admin = db.getSiblingDB(\"admin\");\nconst appdb = db.getSiblingDB(\"appdb\");\n\nfunction resetAppUser() {\n  if (admin.getUser(\"app-user\") == null) {\n    throw new Error(\"app-user does not exist in admin database\");\n  }\n  admin.updateUser(\"app-user\", {roles: [{role: \"readWrite\", db: \"appdb\"}]});\n}\n\nfunction resetReportingUser() {\n  const reportingPrivileges = [\n    {resource: {db: \"appdb\", collection: \"reports\"}, actions: [\"find\"]}\n  ];\n  if (appdb.getRole(\"reportingRole\") == null) {\n    appdb.createRole({role: \"reportingRole\", privileges: reportingPrivileges, roles: []});\n  } else {\n    appdb.updateRole(\"reportingRole\", {privileges: reportingPrivileges, roles: []});\n  }\n\n  const reportingRole = {role: \"reportingRole\", db: \"appdb\"};\n  if (admin.getUser(\"reporting-user\") == null) {\n    admin.createUser({user: \"reporting-user\", pwd: reportingPassword, roles: [reportingRole]});\n  } else {\n    admin.updateUser(\"reporting-user\", {roles: [reportingRole]});\n  }\n\n  if (appdb.getRole(\"rawRead\") != null) {\n    appdb.dropRole(\"rawRead\");\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  resetAppUser();\n}\nif (mode === \"all\" || mode === \"reporting\") {\n  resetReportingUser();\n}\n\nprintjson({\n  mode,\n  appUser: admin.getUser(\"app-user\", {showPrivileges: false}),\n  reportingUser: admin.getUser(\"reporting-user\", {showPrivileges: false}),\n  roles: appdb.getRoles({showPrivileges: true})\n});\nJS\n"},"kind":"ConfigMap","metadata":{"annotations":{},"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t04-39-12z-workflow-r-6d2b5221-cluster-a"}}
