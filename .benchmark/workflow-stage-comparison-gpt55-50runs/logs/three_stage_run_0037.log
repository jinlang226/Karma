const admin = db.getSiblingDB("admin");
const appdb = db.getSiblingDB("appdb");
const rawReadRole = {role:"rawRead", db:"appdb"};
const rawPrivilege = [{resource:{db:"appdb", collection:"raw"}, actions:["find"]}];
if (appdb.getRole("rawRead") == null) {
  appdb.createRole({role:"rawRead", privileges:rawPrivilege, roles:[]});
} else {
  appdb.updateRole("rawRead", {privileges:rawPrivilege, roles:[]});
}
const reportingUser = admin.getUser("reporting-user");
if (reportingUser == null) {
  admin.createUser({user:"reporting-user", pwd:"reporting123password", roles:[rawReadRole]});
} else {
  admin.updateUser("reporting-user", {roles:[rawReadRole]});
}
if (appdb.getRole("reportingRole") != null) {
  appdb.dropRole("reportingRole");
}
printjson({users: admin.getUsers(), roles: appdb.getRoles({showPrivileges:true})});
'
