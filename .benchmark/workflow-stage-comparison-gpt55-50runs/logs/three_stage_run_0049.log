const admin = db.getSiblingDB("admin");
const appdb = db.getSiblingDB("appdb");
const rawRead = { role: "rawRead", privileges: [ { resource: { db: "appdb", collection: "raw" }, actions: [ "find" ] } ], roles: [] };
const existingRawRead = appdb.getRole("rawRead", { showPrivileges: true });
if (existingRawRead) {
  appdb.updateRole("rawRead", { privileges: rawRead.privileges, roles: rawRead.roles });
} else {
  appdb.createRole(rawRead);
}
if (appdb.getRole("reportingRole")) {
  appdb.dropRole("reportingRole");
}
const reportingRoles = [ { role: "rawRead", db: "appdb" } ];
const reporting = admin.getUser("reporting-user");
if (reporting) {
  admin.updateUser("reporting-user", { pwd: "reporting123password", roles: reportingRoles });
} else {
  admin.createUser({ user: "reporting-user", pwd: "reporting123password", roles: reportingRoles });
}
printjson({ users: admin.getUsers().users.filter(u => ["reporting-user", "app-user", "readonly-user"].includes(u.user)).map(u => ({user: u.user, roles: u.roles})), roles: appdb.getRoles({showPrivileges:true}).roles.map(r => ({role: r.role, privileges: r.privileges, roles: r.roles})) });
'
