[agent] +
[agent] +case "$MODE" in
[agent] +  all|app|reporting) ;;
[agent] +  *)
[agent] +    usage
[agent] +    exit 2
[agent] +    ;;
[agent] +esac
[agent] +
[agent] +export RESET_MODE="$MODE"
[agent] +export APP_DATABASE="${APP_DATABASE:-appdb}"
[agent] +export APP_USERNAME="${APP_USERNAME:-app-user}"
[agent] +export APP_PASSWORD="${APP_PASSWORD:-app123password}"
[agent] +export REPORTING_USERNAME="${REPORTING_USERNAME:-reporting-user}"
[agent] +export REPORTING_PASSWORD="${REPORTING_PASSWORD:-reporting123password}"
[agent] +export REPORTING_ROLE_NAME="${REPORTING_ROLE_NAME:-reportingRole}"
[agent] +export BAD_ROLE_NAME="${BAD_ROLE_NAME:-rawRead}"
[agent] +export REPORTS_COLLECTION="${REPORTS_COLLECTION:-reports}"
[agent] +
[agent] +MONGO_HOST="${MONGO_HOST:-localhost}"
[agent] +MONGO_PORT="${MONGO_PORT:-27017}"
[agent] +MONGO_AUTH_DB="${MONGO_AUTH_DB:-admin}"
[agent] +MONGO_ADMIN_USERNAME="${MONGO_ADMIN_USERNAME:-admin-user}"
[agent] +MONGO_ADMIN_PASSWORD="${MONGO_ADMIN_PASSWORD:-admin123password}"
[agent] +
[agent] +MONGO_SCRIPT="$(cat <<'MONGOJS'
[agent] +const env = process.env;
[agent] +const mode = env.RESET_MODE;
[agent] +const appDbName = env.APP_DATABASE;
[agent] +const appUser = env.APP_USERNAME;
[agent] +const appPassword = env.APP_PASSWORD;
[agent] +const reportingUser = env.REPORTING_USERNAME;
[agent] +const reportingPassword = env.REPORTING_PASSWORD;
[agent] +const reportingRole = env.REPORTING_ROLE_NAME;
[agent] +const badRole = env.BAD_ROLE_NAME;
[agent] +const reportsCollection = env.REPORTS_COLLECTION;
[agent] +
[agent] +const admin = db.getSiblingDB("admin");
[agent] +const appdb = db.getSiblingDB(appDbName);
[agent] +
[agent] +function setUserRoles(database, user, password, roles) {
[agent] +  if (database.getUser(user)) {
[agent] +    database.updateUser(user, { roles });
[agent] +  } else {
[agent] +    database.createUser({ user, pwd: password, roles });
[agent] +  }
[agent] +}
[agent] +
[agent] +function resetAppUser() {
[agent] +  setUserRoles(admin, appUser, appPassword, [
[agent] +    { role: "readWrite", db: appDbName }
[agent] +  ]);
[agent] +}
[agent] +
[agent] +function resetReportingRole() {
[agent] +  const desired = {
[agent] +    privileges: [
[agent] +      {
[agent] +        resource: { db: appDbName, collection: reportsCollection },
[agent] +        actions: [ "find" ]
[agent] +      }
[agent] +    ],
[agent] +    roles: []
[agent] +  };
[agent] +
[agent] +  if (appdb.getRole(reportingRole)) {
[agent] +    appdb.updateRole(reportingRole, desired);
[agent] +  } else {
[agent] +    appdb.createRole({
[agent] +      role: reportingRole,
[agent] +      privileges: desired.privileges,
[agent] +      roles: desired.roles
[agent] +    });
[agent] +  }
[agent] +
[agent] +  setUserRoles(admin, reportingUser, reportingPassword, [
[agent] +    { role: reportingRole, db: appDbName }
[agent] +  ]);
[agent] +
[agent] +  if (appdb.getRole(badRole)) {
[agent] +    appdb.dropRole(badRole);
[agent] +  }
[agent] +}
[agent] +
[agent] +if (mode === "all" || mode === "app") {
[agent] +  resetAppUser();
[agent] +}
[agent] +
[agent] +if (mode === "all" || mode === "reporting") {
[agent] +  resetReportingRole();
[agent] +}
[agent] +
[agent] +const users = admin.getUsers().users
[agent] +  .filter((user) => [appUser, reportingUser].includes(user.user))
[agent] +  .map((user) => ({ user: user.user, roles: user.roles }));
[agent] +const roles = appdb.getRoles({ showPrivileges: true }).roles
[agent] +  .filter((role) => [reportingRole, badRole].includes(role.role))
[agent] +  .map((role) => ({
[agent] +    role: role.role,
[agent] +    privileges: role.privileges,
[agent] +    roles: role.roles
[agent] +  }));
[agent] +
[agent] +printjson({ mode, users, roles });
[agent] +MONGOJS
[agent] +)"
[agent] +
[agent] +mongosh --quiet \
[agent] +  --host "$MONGO_HOST" \
[agent] +  --port "$MONGO_PORT" \
[agent] +  -u "$MONGO_ADMIN_USERNAME" \
[agent] +  -p "$MONGO_ADMIN_PASSWORD" \
[agent] +  --authenticationDatabase "$MONGO_AUTH_DB" \
[agent] +  --eval "$MONGO_SCRIPT"
