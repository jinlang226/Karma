);\n\nfunction sameRoles(actual, expected) {\n  const normalize = roles =\u003e roles\n    .map(role =\u003e ({ role: role.role, db: role.db }))\n    .sort((a, b) =\u003e (a.db + \".\" + a.role).localeCompare(b.db + \".\" + b.role));\n  return JSON.stringify(normalize(actual || [])) === JSON.stringify(normalize(expected));\n}\n\nfunction ensureAdminUser(user, password, roles) {\n  const existing = adminDb.getUser(user);\n  if (existing) {\n    if (!sameRoles(existing.roles, roles)) {\n      adminDb.updateUser(user, { roles: roles });\n    }\n  } else {\n    adminDb.createUser({ user: user, pwd: password, roles: roles });\n  }\n}\n\nfunction ensureReportingRole() {\n  const privileges = [\n    {\n      resource: { db: appDbName, collection: reportsCollection },\n      actions: [ \"find\" ]\n    }\n  ];\n  const existing = appDb.getRole(reportingRole, { showPrivileges: true });\n  if (existing) {\n    appDb.updateRole(reportingRole, { privileges: privileges, roles: [] });\n  } else {\n    appDb.createRole({ role: reportingRole, privileges: privileges, roles: [] });\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  ensureAdminUser(appUser, appPassword, [ { role: \"readWrite\", db: appDbName } ]);\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  ensureReportingRole();\n  ensureAdminUser(reportingUser, reportingPassword, [ { role: reportingRole, db: appDbName } ]);\n}\n\nprint(\"RBAC reset completed for mode: \" + mode);\n'\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t00-25-52z-workflow-r-fbfd534b-cluster-a"}}
