[kubectl] 2026-05-19T06:58:22Z kubectl -n wf-2026-05-19t06-54-41z-workflow-r-0dedc92d-cluster-a exec mongodb-replica-0 -- mongosh --quiet -u admin-user -p admin123password --authenticationDatabase admin --eval '
const appdb = db.getSiblingDB("appdb");
const admin = db.getSiblingDB("admin");
try { appdb.dropRole("reportingRole"); } catch (e) { if (e.codeName !== "RoleNotFound" && e.code !== 31) throw e; }
const rawReadPrivileges = [{ resource: { db: "appdb", collection: "raw" }, actions: ["find"] }];
if (appdb.getRole("rawRead", { showPrivileges: true })) {
  appdb.updateRole("rawRead", { privileges: rawReadPrivileges, roles: [] });
} else {
  appdb.createRole({ role: "rawRead", privileges: rawReadPrivileges, roles: [] });
}
const reportingPassword = "reporting123password";
if (admin.getUser("reporting-user")) {
  admin.updateUser("reporting-user", { pwd: reportingPassword, roles: [{ role: "rawRead", db: "appdb" }] });
} else {
  admin.createUser({ user: "reporting-user", pwd: reportingPassword, roles: [{ role: "rawRead", db: "appdb" }] });
}
JSON.stringify({ reportingUser: admin.getUser("reporting-user"), roles: appdb.getRoles({ showPrivileges: true }) }, null, 2);
