[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/bin/sh\nset -eu\n\nusage() {\n  echo \"Usage: $0 --mode all|app|reporting\" \u003e\u00262\n}\n\nMODE=\"\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      [ \"$#\" -ge 2 ] || { usage; exit 2; }\n      MODE=\"$2\"\n      shift 2\n      ;;\n    --mode=*)\n      MODE=\"${1#--mode=}\"\n      shift\n      ;;\n    -h|--help)\n      usage\n      exit 0\n      ;;\n    *)\n      usage\n      exit 2\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *) usage; exit 2 ;;\nesac\n\nADMIN_USERNAME=\"${ADMIN_USERNAME:-admin-user}\"\nADMIN_PASSWORD=\"${ADMIN_PASSWORD:-admin123password}\"\nAUTH_DB=\"${AUTH_DB:-admin}\"\nMONGO_URI=\"${MONGO_URI:-mongodb://localhost:27017/admin?directConnection=true}\"\n\nAPP_DATABASE=\"${APP_DATABASE:-appdb}\"\nAPP_USERNAME=\"${APP_USERNAME:-app-user}\"\nAPP_PASSWORD=\"${APP_PASSWORD:-app123password}\"\nREPORTING_USERNAME=\"${REPORTING_USERNAME:-reporting-user}\"\nREPORTING_PASSWORD=\"${REPORTING_PASSWORD:-reporting123password}\"\nREPORTING_ROLE_NAME=\"${REPORTING_ROLE_NAME:-reportingRole}\"\nBAD_ROLE_NAME=\"${BAD_ROLE_NAME:-rawRead}\"\nREPORTS_COLLECTION=\"${REPORTS_COLLECTION:-reports}\"\n\nRESET_MODE=\"$MODE\" \\\nAPP_DATABASE=\"$APP_DATABASE\" \\\nAPP_USERNAME=\"$APP_USERNAME\" \\\nAPP_PASSWORD=\"$APP_PASSWORD\" \\\nREPORTING_USERNAME=\"$REPORTING_USERNAME\" \\\nREPORTING_PASSWORD=\"$REPORTING_PASSWORD\" \\\nREPORTING_ROLE_NAME=\"$REPORTING_ROLE_NAME\" \\\nBAD_ROLE_NAME=\"$BAD_ROLE_NAME\" \\\nREPORTS_COLLECTION=\"$REPORTS_COLLECTION\" \\\nmongosh --quiet \"$MONGO_URI\" \\\n  --username \"$ADMIN_USERNAME\" \\\n  --password \"$ADMIN_PASSWORD\" \\\n  --authenticationDatabase \"$AUTH_DB\" \u003c\u003c'MONGOJS'\nconst mode = process.env.RESET_MODE;\nconst appDbName = process.env.APP_DATABASE;\nconst appUser = process.env.APP_USERNAME;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUser = process.env.REPORTING_USERNAME;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRole = process.env.REPORTING_ROLE_NAME;\nconst badRole = process.env.BAD_ROLE_NAME;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\n\nconst appDb = db.getSiblingDB(appDbName);\n\nfunction roleKey(role) {\n  return role.db + \".\" + role.role;\n}\n\nfunction sameRoleSet(a, b) {\n  const left = a.map(roleKey).sort();\n  const right = b.map(roleKey).sort();\n  return left.length === right.length \u0026\u0026 left.every((value, index) =\u003e value === right[index]);\n}\n\nfunction ensureUser(dbRef, userName, password, roles) {\n  const existing = dbRef.getUser(userName);\n  if (!existing) {\n    dbRef.createUser({ user: userName, pwd: password, roles });\n    return;\n  }\n\n  const update = {};\n  if (!sameRoleSet(existing.roles, roles)) {\n    update.roles = roles;\n  }\n  if (Object.keys(update).length \u003e 0) {\n    dbRef.updateUser(userName, update);\n  }\n}\n\nfunction ensureAppUser() {\n  ensureUser(appDb, appUser, appPassword, [{ role: \"readWrite\", db: appDbName }]);\n}\n\nfunction ensureReportingRole() {\n  const desiredPrivileges = [{\n    resource: { db: appDbName, collection: reportsCollection },\n    actions: [\"find\"]\n  }];\n  const existing = appDb.getRole(reportingRole, { showPrivileges: true });\n\n  if (!existing) {\n    appDb.createRole({\n      role: reportingRole,\n      privileges: desiredPrivileges,\n      roles: []\n    });\n    return;\n  }\n\n  appDb.updateRole(reportingRole, {\n    privileges: desiredPrivileges,\n    roles: []\n  });\n}\n\nfunction removeDeprecatedRawRole() {\n  const existing = appDb.getRole(badRole);\n  if (existing) {\n    try {\n      appDb.dropRole(badRole);\n    } catch (error) {\n      if (!String(error).includes(\"RoleNotFound\")) {\n        throw error;\n      }\n    }\n  }\n}\n\nfunction ensureReportingUser() {\n  ensureReportingRole();\n  ensureUser(appDb, reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);\n  removeDeprecatedRawRole();\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  ensureAppUser();\n}\nif (mode === \"all\" || mode === \"reporting\") {\n  ensureReportingUser();\n}\n\nprint(\"RBAC reset complete for mode: \" + mode);\nMONGOJS\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-18t07-45-02z-workflow-r-b17b7a6c-cluster-a"}}
