[agent]     const mode = "$MODE";
[agent]     const appDbName = "$APP_DB";
[agent]     const appUserName = "$APP_USER";
[agent]     const appPassword = "$APP_PASSWORD";
[agent]     const reportingUserName = "$REPORTING_USER";
[agent]     const reportingPassword = "$REPORTING_PASSWORD";
[agent]     const reportingRoleName = "$REPORTING_ROLE";
[agent]     const badRoleName = "$BAD_ROLE";
[agent]     const reportsCollection = "$REPORTS_COLLECTION";
[agent]     const adminDb = db.getSiblingDB("admin");
[agent]     const appDb = db.getSiblingDB(appDbName);
[agent]     function setAdminUserRoles(userName, password, roles) {
[agent]       const existing = adminDb.getUser(userName);
[agent]       if (existing) {
[agent]         adminDb.updateUser(userName, { roles: roles });
[agent]       } else {
[agent]         adminDb.createUser({ user: userName, pwd: password, roles: roles });
[agent]       }
[agent]     }
[agent]     function resetAppUser() {
[agent]       setAdminUserRoles(appUserName, appPassword, [ { role: "readWrite", db: appDbName } ]);
[agent]     }
[agent]     function ensureReportingRole() {
[agent]       const desiredPrivileges = [
[agent]         { resource: { db: appDbName, collection: reportsCollection }, actions: [ "find" ] }
[agent]       ];
[agent]       const existing = appDb.getRole(reportingRoleName, { showPrivileges: true });
[agent]       if (existing) {
[agent]         appDb.updateRole(reportingRoleName, { privileges: desiredPrivileges, roles: [] });
[agent]       } else {
[agent]         appDb.createRole({ role: reportingRoleName, privileges: desiredPrivileges, roles: [] });
[agent]       }
[agent]     }
[agent]     function dropDeprecatedRoleIfUnused() {
[agent]       const reportingUser = adminDb.getUser(reportingUserName);
[agent]       const stillAssigned = reportingUser && reportingUser.roles.some(
[agent]         (role) => role.role === badRoleName && role.db === appDbName
[agent]       );
[agent]       if (!stillAssigned && appDb.getRole(badRoleName)) {
[agent]         appDb.dropRole(badRoleName);
[agent]       }
[agent]     }
[agent]     function resetReportingUser() {
[agent]       ensureReportingRole();
[agent]       setAdminUserRoles(reportingUserName, reportingPassword, [ { role: reportingRoleName, db: appDbName } ]);
[agent]       dropDeprecatedRoleIfUnused();
[agent]     }
[agent]     if (mode === "app" || mode === "all") {
[agent]       resetAppUser();
[agent]     }
[agent]     if (mode === "reporting" || mode === "all") {
[agent]       resetReportingUser();
[agent]     }
[agent]     print(`RBAC reset complete for mode ${mode}`);
[agent]     MONGOJS
