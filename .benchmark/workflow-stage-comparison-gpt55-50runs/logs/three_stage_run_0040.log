[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/bin/sh\nset -eu\n\nMODE=\"all\"\nMONGO_HOST=\"${MONGO_HOST:-localhost}\"\nMONGO_PORT=\"${MONGO_PORT:-27017}\"\nADMIN_USER=\"${ADMIN_USER:-admin-user}\"\nADMIN_PASSWORD=\"${ADMIN_PASSWORD:-admin123password}\"\nAUTH_DB=\"${AUTH_DB:-admin}\"\nAPP_DB=\"${APP_DB:-appdb}\"\nAPP_USER=\"${APP_USER:-app-user}\"\nREPORTING_USER=\"${REPORTING_USER:-reporting-user}\"\nREPORTING_ROLE=\"${REPORTING_ROLE:-reportingRole}\"\nBAD_ROLE=\"${BAD_ROLE:-rawRead}\"\nREPORTS_COLLECTION=\"${REPORTS_COLLECTION:-reports}\"\n\nusage() {\n  echo \"Usage: $0 [--mode all|app|reporting]\" \u003e\u00262\n  exit 2\n}\n\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      [ \"$#\" -ge 2 ] || usage\n      MODE=\"$2\"\n      shift 2\n      ;;\n    --mode=*)\n      MODE=\"${1#--mode=}\"\n      shift\n      ;;\n    -h|--help)\n      usage\n      ;;\n    *)\n      usage\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *) usage ;;\nesac\n\nexport MODE APP_DB APP_USER REPORTING_USER REPORTING_ROLE BAD_ROLE REPORTS_COLLECTION\n\nmongosh --quiet \\\n  --host \"$MONGO_HOST\" \\\n  --port \"$MONGO_PORT\" \\\n  -u \"$ADMIN_USER\" \\\n  -p \"$ADMIN_PASSWORD\" \\\n  --authenticationDatabase \"$AUTH_DB\" \\\n  --eval '\n    const mode = process.env.MODE;\n    const appDbName = process.env.APP_DB;\n    const appUser = process.env.APP_USER;\n    const reportingUser = process.env.REPORTING_USER;\n    const reportingRole = process.env.REPORTING_ROLE;\n    const badRole = process.env.BAD_ROLE;\n    const reportsCollection = process.env.REPORTS_COLLECTION;\n    const adminDb = db.getSiblingDB(\"admin\");\n    const appDb = db.getSiblingDB(appDbName);\n\n    function assertUserExists(userName) {\n      if (!adminDb.getUser(userName)) {\n        throw new Error(\"Required user is missing: \" + userName);\n      }\n    }\n\n    function setUserRoles(userName, roles) {\n      assertUserExists(userName);\n      adminDb.updateUser(userName, { roles: roles });\n    }\n\n    function resetApp() {\n      setUserRoles(appUser, [{ role: \"readWrite\", db: appDbName }]);\n    }\n\n    function resetReporting() {\n      const desiredPrivileges = [{\n        resource: { db: appDbName, collection: reportsCollection },\n        actions: [\"find\"]\n      }];\n      if (appDb.getRole(reportingRole)) {\n        appDb.updateRole(reportingRole, { privileges: desiredPrivileges, roles: [] });\n      } else {\n        appDb.createRole({ role: reportingRole, privileges: desiredPrivileges, roles: [] });\n      }\n      setUserRoles(reportingUser, [{ role: reportingRole, db: appDbName }]);\n      if (appDb.getRole(badRole)) {\n        appDb.dropRole(badRole);\n      }\n    }\n\n    if (mode === \"all\" || mode === \"app\") {\n      resetApp();\n    }\n    if (mode === \"all\" || mode === \"reporting\") {\n      resetReporting();\n    }\n    print(\"rbac reset complete: \" + mode);\n  '\n"},"kind":"ConfigMap","metadata":{"annotations":{},"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t06-22-49z-workflow-r-262058cd-cluster-a"}}
