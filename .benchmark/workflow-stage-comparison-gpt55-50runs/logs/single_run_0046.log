SWORD;\nconst reportingUsername = process.env.REPORTING_USERNAME;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRoleName = process.env.REPORTING_ROLE_NAME;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\n\nconst adminDb = db.getSiblingDB(\"admin\");\nconst appDb = db.getSiblingDB(appDatabase);\n\nfunction ensureUser(userDb, username, password, roles) {\n  const existing = userDb.getUser(username);\n  if (existing) {\n    userDb.updateUser(username, { pwd: password, roles: roles });\n  } else {\n    userDb.createUser({ user: username, pwd: password, roles: roles });\n  }\n}\n\nfunction ensureReportingRole() {\n  const privileges = [\n    {\n      resource: { db: appDatabase, collection: reportsCollection },\n      actions: [ \"find\" ]\n    }\n  ];\n  const existing = appDb.getRole(reportingRoleName, { showPrivileges: true });\n  if (existing) {\n    appDb.updateRole(reportingRoleName, { privileges: privileges, roles: [] });\n  } else {\n    appDb.createRole({ role: reportingRoleName, privileges: privileges, roles: [] });\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  if (!appPassword) {\n    throw new Error(\"APP_PASSWORD is required for app reset\");\n  }\n  ensureUser(adminDb, appUsername, appPassword, [\n    { role: \"readWrite\", db: appDatabase }\n  ]);\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  if (!reportingPassword) {\n    throw new Error(\"REPORTING_PASSWORD is required for reporting reset\");\n  }\n  ensureReportingRole();\n  ensureUser(adminDb, reportingUsername, reportingPassword, [\n    { role: reportingRoleName, db: appDatabase }\n  ]);\n}\n\nprint(`rbac reset complete: mode=${mode}`);\n'\n\nif command -v kubectl \u003e/dev/null 2\u003e\u00261 \u0026\u0026 [ \"${USE_LOCAL_MONGOSH:-0}\" != \"1\" ]; then\n  ADMIN_PASSWORD=\"${ADMIN_PASSWORD:-$(secret_password \"$ADMIN_SECRET_NAME\")}\"\n  if [ \"$MODE\" = \"all\" ] || [ \"$MODE\" = \"app\" ]; then\n    APP_PASSWORD=\"${APP_PASSWORD:-$(secret_password \"$APP_SECRET_NAME\")}\"\n  else\n    APP_PASSWORD=\"${APP_PASSWORD:-}\"\n  fi\n  if [ \"$MODE\" = \"all\" ] || [ \"$MODE\" = \"reporting\" ]; then\n    REPORTING_PASSWORD=\"${REPORTING_PASSWORD:-$(secret_password \"$REPORTING_SECRET_NAME\")}\"\n  else\n    REPORTING_PASSWORD=\"${REPORTING_PASSWORD:-}\"\n  fi\n\n  kubectl -n \"$NAMESPACE\" exec -i \"$POD\" -- env \\\n    MODE=\"$MODE\" \\\n    ADMIN_USERNAME=\"$ADMIN_USERNAME\" \\\n    ADMIN_PASSWORD=\"$ADMIN_PASSWORD\" \\\n    APP_USERNAME=\"$APP_USERNAME\" \\\n    APP_PASSWORD=\"$APP_PASSWORD\" \\\n    APP_DATABASE=\"$APP_DATABASE\" \\\n    REPORTING_USERNAME=\"$REPORTING_USERNAME\" \\\n    REPORTING_PASSWORD=\"$REPORTING_PASSWORD\" \\\n    REPORTING_ROLE_NAME=\"$REPORTING_ROLE_NAME\" \\\n    REPORTS_COLLECTION=\"$REPORTS_COLLECTION\" \\\n    MONGO_URI=\"$MONGO_URI\" \\\n    bash -ceu 'run_mongosh() {\n      mongosh \"$MONGO_URI\" --quiet -u \"$ADMIN_USERNAME\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin\n    }\n    run_mongosh' \u003c\u003c\u003c\"$js_program\"\nelse\n  ADMIN_PASSWORD=\"${ADMIN_PASSWORD:-admin123password}\"\n  APP_PASSWORD=\"${APP_PASSWORD:-app123password}\"\n  REPORTING_PASSWORD=\"${REPORTING_PASSWORD:-reporting123password}\"\n  export MODE APP_DATABASE APP_USERNAME APP_PASSWORD REPORTING_USERNAME REPORTING_PASSWORD REPORTING_ROLE_NAME REPORTS_COLLECTION\n  run_mongosh \u003c\u003c\u003c\"$js_program\"\nfi\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t05-42-45z-workflow-r-a81cbb41-cluster-a"}}
