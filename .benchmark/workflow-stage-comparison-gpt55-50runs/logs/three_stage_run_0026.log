set -eu

MODE="all"
while [ "$#" -gt 0 ]; do
  case "$1" in
    --mode)
      if [ "$#" -lt 2 ]; then
        echo "--mode requires one of: all, app, reporting" >&2
        exit 2
      fi
      MODE="$2"
      shift 2
      ;;
    --mode=*)
      MODE="${1#--mode=}"
      shift
      ;;
    -h|--help)
      echo "Usage: $0 [--mode all|app|reporting]"
      exit 0
      ;;
    *)
      echo "Unknown argument: $1" >&2
      exit 2
      ;;
  esac
done

case "$MODE" in
  all|app|reporting) ;;
  *)
    echo "Invalid mode: $MODE" >&2
    echo "Expected one of: all, app, reporting" >&2
    exit 2
    ;;
esac

MONGO_HOST="${MONGO_HOST:-127.0.0.1}"
MONGO_PORT="${MONGO_PORT:-27017}"
ADMIN_USERNAME="${ADMIN_USERNAME:-${MONGO_ADMIN_USERNAME:-admin-user}}"
ADMIN_PASSWORD="${ADMIN_PASSWORD:-${MONGO_ADMIN_PASSWORD:-admin123password}}"
ADMIN_AUTH_DB="${ADMIN_AUTH_DB:-admin}"
APP_DATABASE="${APP_DATABASE:-appdb}"
APP_USERNAME="${APP_USERNAME:-app-user}"
APP_PASSWORD="${APP_PASSWORD:-app123password}"
REPORTING_USERNAME="${REPORTING_USERNAME:-reporting-user}"
REPORTING_PASSWORD="${REPORTING_PASSWORD:-reporting123password}"
REPORTING_ROLE="${REPORTING_ROLE:-reportingRole}"
BAD_ROLE="${BAD_ROLE:-rawRead}"
REPORTS_COLLECTION="${REPORTS_COLLECTION:-reports}"

mongosh --quiet --host "$MONGO_HOST" --port "$MONGO_PORT" \
  -u "$ADMIN_USERNAME" -p "$ADMIN_PASSWORD" --authenticationDatabase "$ADMIN_AUTH_DB" \
  --eval "
const mode = ${MODE@Q};
const appDatabase = ${APP_DATABASE@Q};
const appUsername = ${APP_USERNAME@Q};
const appPassword = ${APP_PASSWORD@Q};
const reportingUsername = ${REPORTING_USERNAME@Q};
const reportingPassword = ${REPORTING_PASSWORD@Q};
const reportingRole = ${REPORTING_ROLE@Q};
const badRole = ${BAD_ROLE@Q};
const reportsCollection = ${REPORTS_COLLECTION@Q};
const adminDb = db.getSiblingDB(admin);
const appDb = db.getSiblingDB(appDatabase);

function resetAppUser() {
  const desiredRoles = [{ role: readWrite, db: appDatabase }];
  if (adminDb.getUser(appUsername) === null) {
    adminDb.createUser({ user: appUsername, pwd: appPassword, roles: desiredRoles });
  } else {
    adminDb.updateUser(appUsername, { roles: desiredRoles });
  }
}

function resetReporting() {
  const desiredRole = {
    privileges: [{ resource: { db: appDatabase, collection: reportsCollection }, actions: [find] }],
    roles: []
  };
  if (appDb.getRole(reportingRole) === null) {
    appDb.createRole({ role: reportingRole, privileges: desiredRole.privileges, roles: desiredRole.roles });
  } else {
    appDb.updateRole(reportingRole, desiredRole);
  }

  const desiredUserRoles = [{ role: reportingRole, db: appDatabase }];
  if (adminDb.getUser(reportingUsername) === null) {
    adminDb.createUser({ user: reportingUsername, pwd: reportingPassword, roles: desiredUserRoles });
  } else {
    adminDb.updateUser(reportingUsername, { roles: desiredUserRoles });
  }

  if (appDb.getRole(badRole) !== null) {
    appDb.dropRole(badRole);
  }
}

if (mode === all || mode === app) {
  resetAppUser();
}
if (mode === all || mode === reporting) {
  resetReporting();
}
printjson({ ok: 1, mode });
"
' --dry-run=client -o yaml
