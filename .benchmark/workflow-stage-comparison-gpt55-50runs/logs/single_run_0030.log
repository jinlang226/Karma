[agent] codex
[agent] The live app database currently has no app users or custom roles, so the reset script needs to create missing objects as well as repair existing ones. I’m going to create the ConfigMap with an idempotent shell script that uses `mongosh` and can run from a MongoDB pod with sane defaults for this namespace.
[agent] exec
[agent] /bin/sh -lc "cat > /tmp/reset_rbac.sh <<'EOF'
[agent] #"'!/usr/bin/env bash
[agent] set -euo pipefail
[agent] usage() {
[agent]   cat <<'"'USAGE'
[agent] Usage: reset_rbac.sh --mode all|app|reporting
[agent] Environment overrides:
[agent]   MONGO_HOST, MONGO_PORT, MONGO_ADMIN_USERNAME, MONGO_ADMIN_PASSWORD
[agent]   APP_USERNAME, APP_PASSWORD, REPORTING_USERNAME, REPORTING_PASSWORD
[agent] USAGE
[agent] }
[agent] MODE=\"all\"
[agent] while [ \""'$#" -gt 0 ]; do
[agent]   case "$1" in
[agent]     --mode)
[agent]       [ "$#" -ge 2 ] || { usage >&2; exit 2; }
[agent]       MODE="$2"
[agent]       shift 2
[agent]       ;;
[agent]     --mode=*)
[agent]       MODE="${1#--mode=}"
[agent]       shift
[agent]       ;;
[agent]     -h|--help)
[agent]       usage
[agent]       exit 0
[agent]       ;;
[agent]     *)
[agent]       echo "unknown argument: $1" >&2
[agent]       usage >&2
[agent]       exit 2
[agent]       ;;
[agent]   esac
[agent] done
[agent] case "$MODE" in
[agent]   all|app|reporting) ;;
[agent]   *) echo "invalid mode: $MODE" >&2; usage >&2; exit 2 ;;
