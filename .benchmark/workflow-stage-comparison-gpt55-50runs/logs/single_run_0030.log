[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/usr/bin/env bash\nset -euo pipefail\n\nusage() {\n  cat \u003c\u003c'USAGE'\nUsage: reset_rbac.sh --mode all|app|reporting\n\nEnvironment overrides:\n  MONGO_HOST, MONGO_PORT, MONGO_ADMIN_USERNAME, MONGO_ADMIN_PASSWORD\n  APP_USERNAME, APP_PASSWORD, REPORTING_USERNAME, REPORTING_PASSWORD\nUSAGE\n}\n\nMODE=\"all\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      [ \"$#\" -ge 2 ] || { usage \u003e\u00262; exit 2; }\n      MODE=\"$2\"\n      shift 2\n      ;;\n    --mode=*)\n      MODE=\"${1#--mode=}\"\n      shift\n      ;;\n    -h|--help)\n      usage\n      exit 0\n      ;;\n    *)\n      echo \"unknown argument: $1\" \u003e\u00262\n      usage \u003e\u00262\n      exit 2\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *) echo \"invalid mode: $MODE\" \u003e\u00262; usage \u003e\u00262; exit 2 ;;\nesac\n\nMONGO_HOST=\"${MONGO_HOST:-127.0.0.1}\"\nMONGO_PORT=\"${MONGO_PORT:-27017}\"\nMONGO_ADMIN_USERNAME=\"${MONGO_ADMIN_USERNAME:-admin-user}\"\nMONGO_ADMIN_PASSWORD=\"${MONGO_ADMIN_PASSWORD:-admin123password}\"\nAPP_DB=\"${APP_DB:-appdb}\"\nAPP_USERNAME=\"${APP_USERNAME:-app-user}\"\nAPP_PASSWORD=\"${APP_PASSWORD:-app123password}\"\nREPORTING_USERNAME=\"${REPORTING_USERNAME:-reporting-user}\"\nREPORTING_PASSWORD=\"${REPORTING_PASSWORD:-reporting123password}\"\nREPORTING_ROLE_NAME=\"${REPORTING_ROLE_NAME:-reportingRole}\"\nBAD_ROLE_NAME=\"${BAD_ROLE_NAME:-rawRead}\"\nREPORTS_COLLECTION=\"${REPORTS_COLLECTION:-reports}\"\n\nexport MODE APP_DB APP_USERNAME APP_PASSWORD REPORTING_USERNAME REPORTING_PASSWORD REPORTING_ROLE_NAME BAD_ROLE_NAME REPORTS_COLLECTION\n\nmongosh --quiet --host \"$MONGO_HOST\" --port \"$MONGO_PORT\" \\\n  -u \"$MONGO_ADMIN_USERNAME\" -p \"$MONGO_ADMIN_PASSWORD\" \\\n  --authenticationDatabase admin \u003c\u003c'MONGOJS'\nconst mode = process.env.MODE;\nconst appDbName = process.env.APP_DB;\nconst appUser = process.env.APP_USERNAME;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUser = process.env.REPORTING_USERNAME;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRole = process.env.REPORTING_ROLE_NAME;\nconst badRole = process.env.BAD_ROLE_NAME;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\nconst appdb = db.getSiblingDB(appDbName);\n\nfunction ensureUser(database, username, password, roles) {\n  if (database.getUser(username)) {\n    database.updateUser(username, {pwd: password, roles: roles});\n  } else {\n    database.createUser({user: username, pwd: password, roles: roles});\n  }\n}\n\nfunction roleExists(database, roleName) {\n  return database.getRole(roleName, {showPrivileges: true}) !== null;\n}\n\nfunction ensureReportingRole() {\n  const roleSpec = {\n    privileges: [{resource: {db: appDbName, collection: reportsCollection}, actions: ['find']}],\n    roles: []\n  };\n\n  if (roleExists(appdb, reportingRole)) {\n    appdb.updateRole(reportingRole, roleSpec);\n  } else {\n    appdb.createRole(Object.assign({role: reportingRole}, roleSpec));\n  }\n}\n\nfunction dropDeprecatedRoleIfUnused() {\n  if (!roleExists(appdb, badRole)) {\n    return;\n  }\n  try {\n    appdb.dropRole(badRole);\n  } catch (err) {\n    if (!String(err).includes('RoleNotFound')) {\n      throw err;\n    }\n  }\n}\n\nif (mode === 'all' || mode === 'app') {\n  ensureUser(appdb, appUser, appPassword, [{role: 'readWrite', db: appDbName}]);\n}\n\nif (mode === 'all' || mode === 'reporting') {\n  ensureReportingRole();\n  ensureUser(appdb, reportingUser, reportingPassword, [{role: reportingRole, db: appDbName}]);\n  dropDeprecatedRoleIfUnused();\n}\n\nprint(`rbac reset complete: mode=${mode}`);\nMONGOJS\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t00-30-40z-workflow-r-b50178fd-cluster-a"}}
