pUsername = process.env.APP_USERNAME;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUsername = process.env.REPORTING_USERNAME;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRoleName = process.env.REPORTING_ROLE_NAME;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\nconst badRoleName = process.env.BAD_ROLE_NAME;\n\nconst appDb = db.getSiblingDB(appDatabaseName);\n\nfunction sameJson(a, b) {\n  return JSON.stringify(a) === JSON.stringify(b);\n}\n\nfunction ensureUser(database, username, password, roles) {\n  const existing = database.getUser(username);\n  if (existing) {\n    if (!sameJson(existing.roles, roles)) {\n      database.updateUser(username, { roles });\n    }\n    database.changeUserPassword(username, password);\n  } else {\n    database.createUser({ user: username, pwd: password, roles });\n  }\n}\n\nfunction ensureReportingRole() {\n  const privileges = [{\n    resource: { db: appDatabaseName, collection: reportsCollection },\n    actions: [ \"find\" ]\n  }];\n  const roles = [];\n  if (appDb.getRole(reportingRoleName)) {\n    appDb.updateRole(reportingRoleName, { privileges, roles });\n  } else {\n    appDb.createRole({ role: reportingRoleName, privileges, roles });\n  }\n}\n\nfunction resetAppUser() {\n  ensureUser(appDb, appUsername, appPassword, [\n    { role: \"readWrite\", db: appDatabaseName }\n  ]);\n}\n\nfunction resetReportingUser() {\n  ensureReportingRole();\n  ensureUser(appDb, reportingUsername, reportingPassword, [\n    { role: reportingRoleName, db: appDatabaseName }\n  ]);\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  resetAppUser();\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  resetReportingUser();\n}\n\nconst appUser = appDb.getUser(appUsername);\nconst reportingUser = appDb.getUser(reportingUsername);\nconst reportingRole = appDb.getRole(reportingRoleName, { showPrivileges: true });\n\nprintjson({\n  ok: 1,\n  mode,\n  appUserRoles: appUser ? appUser.roles : 