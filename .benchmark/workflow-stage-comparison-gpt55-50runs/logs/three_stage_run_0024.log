[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/bin/sh\nset -eu\n\nNAMESPACE=\"${NAMESPACE:-wf-2026-05-18t21-23-53z-workflow-r-ad1c9aa7-cluster-a}\"\nPOD=\"${POD:-mongodb-replica-0}\"\nADMIN_USER=\"${ADMIN_USER:-admin-user}\"\nADMIN_SECRET=\"${ADMIN_SECRET:-admin-user-password}\"\nAPP_USER=\"${APP_USER:-app-user}\"\nAPP_SECRET=\"${APP_SECRET:-app-user-password}\"\nREPORTING_USER=\"${REPORTING_USER:-reporting-user}\"\nREPORTING_SECRET=\"${REPORTING_SECRET:-reporting-user-password}\"\nAPP_DB=\"${APP_DB:-appdb}\"\nREPORTS_COLLECTION=\"${REPORTS_COLLECTION:-reports}\"\nREPORTING_ROLE=\"${REPORTING_ROLE:-reportingRole}\"\nDEPRECATED_RAW_ROLE=\"${DEPRECATED_RAW_ROLE:-rawRead}\"\n\nMODE=\"all\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      [ \"$#\" -ge 2 ] || { echo \"missing value for --mode\" \u003e\u00262; exit 2; }\n      MODE=\"$2\"\n      shift 2\n      ;;\n    --mode=*)\n      MODE=\"${1#--mode=}\"\n      shift\n      ;;\n    -h|--help)\n      echo \"usage: $0 [--mode all|app|reporting]\"\n      exit 0\n      ;;\n    *)\n      echo \"unknown argument: $1\" \u003e\u00262\n      exit 2\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *) echo \"invalid mode: $MODE\" \u003e\u00262; exit 2 ;;\nesac\n\nsecret_password() {\n  kubectl -n \"$NAMESPACE\" get secret \"$1\" -o jsonpath='{.data.password}' | base64 -d\n}\n\nADMIN_PASSWORD=\"$(secret_password \"$ADMIN_SECRET\")\"\nAPP_PASSWORD=\"$(secret_password \"$APP_SECRET\")\"\nREPORTING_PASSWORD=\"$(secret_password \"$REPORTING_SECRET\")\"\n\nmongo_eval() {\n  kubectl -n \"$NAMESPACE\" exec \"$POD\" -- mongosh --quiet \\\n    -u \"$ADMIN_USER\" \\\n    -p \"$ADMIN_PASSWORD\" \\\n    --authenticationDatabase admin \\\n    --eval \"$1\"\n}\n\njs_string() {\n  printf '%s' \"$1\" | sed \"s/\\\\\\\\/\\\\\\\\\\\\\\\\/g; s/'/\\\\\\\\'/g\"\n}\n\nAPP_PASSWORD_JS=\"$(js_string \"$APP_PASSWORD\")\"\nREPORTING_PASSWORD_JS=\"$(js_string \"$REPORTING_PASSWORD\")\"\n\nJS=\"\nconst mode = '$MODE';\nconst admin = db.getSiblingDB('admin');\nconst appdb = db.getSiblingDB('$APP_DB');\n\nfunction ensureAdminUser(user, password, roles) {\n  if (admin.getUser(user)) {\n    admin.updateUser(user, { roles: roles });\n  } else {\n    admin.createUser({ user: user, pwd: password, roles: roles });\n  }\n}\n\nfunction resetApp() {\n  ensureAdminUser('$APP_USER', '$APP_PASSWORD_JS', [{ role: 'readWrite', db: '$APP_DB' }]);\n}\n\nfunction resetReporting() {\n  const roleSpec = {\n    privileges: [\n      {\n        resource: { db: '$APP_DB', collection: '$REPORTS_COLLECTION' },\n        actions: ['find']\n      }\n    ],\n    roles: []\n  };\n\n  if (appdb.getRole('$REPORTING_ROLE')) {\n    appdb.updateRole('$REPORTING_ROLE', roleSpec);\n  } else {\n    appdb.createRole(Object.assign({ role: '$REPORTING_ROLE' }, roleSpec));\n  }\n\n  ensureAdminUser('$REPORTING_USER', '$REPORTING_PASSWORD_JS', [{ role: '$REPORTING_ROLE', db: '$APP_DB' }]);\n\n  if (appdb.getRole('$DEPRECATED_RAW_ROLE')) {\n    appdb.dropRole('$DEPRECATED_RAW_ROLE');\n  }\n}\n\nif (mode === 'all' || mode === 'app') {\n  resetApp();\n}\nif (mode === 'all' || mode === 'reporting') {\n  resetReporting();\n}\n\nprintjson({\n  ok: 1,\n  mode: mode,\n  appUser: admin.getUser('$APP_USER').roles,\n  reportingUser: admin.getUser('$REPORTING_USER').roles,\n  reportingRole: appdb.getRole('$REPORTING_ROLE', { showPrivileges: true })\n});\n\"\n\nmongo_eval \"$JS\"\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-18t21-23-53z-workflow-r-ad1c9aa7-cluster-a"}}
