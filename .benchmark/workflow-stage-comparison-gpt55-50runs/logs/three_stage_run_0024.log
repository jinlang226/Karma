const mode = '"'"'all'"'"';
const admin = db.getSiblingDB('"'"'admin'"'"');
const appdb = db.getSiblingDB('"'"'appdb'"'"');

function ensureAdminUser(user, password, roles) {
  if (admin.getUser(user)) {
    admin.updateUser(user, { roles: roles });
  } else {
    admin.createUser({ user: user, pwd: password, roles: roles });
  }
}

function resetApp() {
  ensureAdminUser('"'"'app-user'"'"', '"'"'app123password'"'"', [{ role: '"'"'readWrite'"'"', db: '"'"'appdb'"'"' }]);
}

function resetReporting() {
  const roleSpec = {
    privileges: [
      {
        resource: { db: '"'"'appdb'"'"', collection: '"'"'reports'"'"' },
        actions: ['"'"'find'"'"']
      }
    ],
    roles: []
  };

  if (appdb.getRole('"'"'reportingRole'"'"')) {
    appdb.updateRole('"'"'reportingRole'"'"', roleSpec);
  } else {
    appdb.createRole(Object.assign({ role: '"'"'reportingRole'"'"' }, roleSpec));
  }

  ensureAdminUser('"'"'reporting-user'"'"', '"'"'reporting123password'"'"', [{ role: '"'"'reportingRole'"'"', db: '"'"'appdb'"'"' }]);
}

if (mode === '"'"'all'"'"' || mode === '"'"'app'"'"') {
  resetApp();
}
if (mode === '"'"'all'"'"' || mode === '"'"'reporting'"'"') {
  resetReporting();
}

printjson({
  ok: 1,
