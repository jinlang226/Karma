les = [{ role: 'readWrite', db: '$APP_DB' }];\nif (admin.getUser(user) == null) {\n  admin.createUser({ user: user, pwd: pwd, roles: roles });\n} else {\n  admin.updateUser(user, { pwd: pwd, roles: roles });\n}\n\"\nfi\n\nif [ \"$MODE\" = \"all\" ] || [ \"$MODE\" = \"reporting\" ]; then\n  run_mongo \"\nconst admin = db.getSiblingDB('admin');\nconst appdb = db.getSiblingDB('$APP_DB');\nconst roleName = '$REPORTING_ROLE';\nconst roleSpec = {\n  privileges: [\n    { resource: { db: '$APP_DB', collection: '$REPORTS_COLLECTION' }, actions: ['find'] }\n  ],\n  roles: []\n};\nif (appdb.getRole(roleName, { showPrivileges: true }) == null) {\n  appdb.createRole(Object.assign({ role: roleName }, roleSpec));\n} else {\n  appdb.updateRole(roleName, roleSpec);\n}\nconst user = '$REPORTING_USER';\nconst pwd = '$REPORTING_PASSWORD';\nconst roles = [{ role: roleName, db: '$APP_DB' }];\nif (admin.getUser(user) == null) {\n  admin.createUser({ user: user, pwd: pwd, roles: roles });\n} else {\n  admin.updateUser(user, { pwd: pwd, roles: roles });\n}\n\"\nfi\n\necho \"RBAC reset completed for mode: $MODE\"\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t02-01-17z-workflow-r-908b9b2c-cluster-a"}}
