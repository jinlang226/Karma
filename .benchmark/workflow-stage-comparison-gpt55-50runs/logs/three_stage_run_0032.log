[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/bin/sh\nset -eu\n\nMODE=\"all\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      [ \"$#\" -ge 2 ] || { echo \"--mode requires a value\" \u003e\u00262; exit 2; }\n      MODE=\"$2\"\n      shift 2\n      ;;\n    --mode=*)\n      MODE=\"${1#--mode=}\"\n      shift\n      ;;\n    -h|--help)\n      echo \"Usage: $0 [--mode all|app|reporting]\"\n      exit 0\n      ;;\n    *)\n      echo \"unknown argument: $1\" \u003e\u00262\n      exit 2\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *) echo \"invalid mode: $MODE\" \u003e\u00262; exit 2 ;;\nesac\n\nMONGO_HOST=\"${MONGO_HOST:-localhost}\"\nMONGO_PORT=\"${MONGO_PORT:-27017}\"\nAUTH_DB=\"${AUTH_DB:-admin}\"\nADMIN_USERNAME=\"${ADMIN_USERNAME:-admin-user}\"\nADMIN_PASSWORD=\"${ADMIN_PASSWORD:-admin123password}\"\nAPP_DATABASE=\"${APP_DATABASE:-appdb}\"\nAPP_USERNAME=\"${APP_USERNAME:-app-user}\"\nAPP_PASSWORD=\"${APP_PASSWORD:-app123password}\"\nREPORTING_USERNAME=\"${REPORTING_USERNAME:-reporting-user}\"\nREPORTING_PASSWORD=\"${REPORTING_PASSWORD:-reporting123password}\"\nREPORTING_ROLE_NAME=\"${REPORTING_ROLE_NAME:-reportingRole}\"\nREPORTS_COLLECTION=\"${REPORTS_COLLECTION:-reports}\"\n\nRESET_MODE=\"$MODE\" \\\nAPP_DATABASE=\"$APP_DATABASE\" \\\nAPP_USERNAME=\"$APP_USERNAME\" \\\nAPP_PASSWORD=\"$APP_PASSWORD\" \\\nREPORTING_USERNAME=\"$REPORTING_USERNAME\" \\\nREPORTING_PASSWORD=\"$REPORTING_PASSWORD\" \\\nREPORTING_ROLE_NAME=\"$REPORTING_ROLE_NAME\" \\\nREPORTS_COLLECTION=\"$REPORTS_COLLECTION\" \\\nmongosh --quiet --host \"$MONGO_HOST\" --port \"$MONGO_PORT\" \\\n  -u \"$ADMIN_USERNAME\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase \"$AUTH_DB\" \u003c\u003c'MONGOJS'\nconst mode = process.env.RESET_MODE;\nconst appDatabase = process.env.APP_DATABASE;\nconst appUsername = process.env.APP_USERNAME;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUsername = process.env.REPORTING_USERNAME;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRoleName = process.env.REPORTING_ROLE_NAME;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\n\nconst adminDb = db.getSiblingDB(\"admin\");\nconst appDb = db.getSiblingDB(appDatabase);\n\nfunction userExists(database, username) {\n  return database.getUser(username) !== null;\n}\n\nfunction resetAppUser() {\n  const roles = [ { role: \"readWrite\", db: appDatabase } ];\n  if (userExists(adminDb, appUsername)) {\n    adminDb.updateUser(appUsername, { roles });\n  } else {\n    adminDb.createUser({ user: appUsername, pwd: appPassword, roles });\n  }\n}\n\nfunction upsertReportingRole() {\n  const spec = {\n    privileges: [\n      {\n        resource: { db: appDatabase, collection: reportsCollection },\n        actions: [ \"find\" ]\n      }\n    ],\n    roles: []\n  };\n\n  if (appDb.getRole(reportingRoleName) === null) {\n    appDb.createRole(Object.assign({ role: reportingRoleName }, spec));\n  } else {\n    appDb.updateRole(reportingRoleName, spec);\n  }\n}\n\nfunction resetReportingUser() {\n  upsertReportingRole();\n  const roles = [ { role: reportingRoleName, db: appDatabase } ];\n  if (userExists(adminDb, reportingUsername)) {\n    adminDb.updateUser(reportingUsername, { roles });\n  } else {\n    adminDb.createUser({ user: reportingUsername, pwd: reportingPassword, roles });\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  resetAppUser();\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  resetReportingUser();\n}\n\nprintjson({ ok: 1, mode });\nMONGOJS\n"},"kind":"ConfigMap","metadata":{"annotations":{},"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t02-13-47z-workflow-r-3ac02d08-cluster-a"}}
