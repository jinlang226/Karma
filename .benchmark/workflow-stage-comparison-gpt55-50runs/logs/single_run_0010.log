st appUsername = \"$APP_USERNAME\";\nconst appPassword = \"$APP_PASSWORD\";\nconst reportingUsername = \"$REPORTING_USERNAME\";\nconst reportingPassword = \"$REPORTING_PASSWORD\";\nconst reportingRole = \"$REPORTING_ROLE\";\nconst reportsCollection = \"$REPORTS_COLLECTION\";\n\nconst adminDb = db.getSiblingDB(\"admin\");\nconst appDb = db.getSiblingDB(appDbName);\n\nfunction sameRoles(actual, expected) {\n  const normalize = (roles) =\u003e roles\n    .map((role) =\u003e ({ role: role.role, db: role.db }))\n    .sort((a, b) =\u003e (a.db + \".\" + a.role).localeCompare(b.db + \".\" + b.role));\n  return EJSON.stringify(normalize(actual)) === EJSON.stringify(normalize(expected));\n}\n\nfunction ensureUser(dbHandle, username, password, desiredRoles) {\n  const existing = dbHandle.getUser(username);\n  if (existing) {\n    if (!sameRoles(existing.roles, desiredRoles)) {\n      dbHandle.updateUser(username, { roles: desiredRoles });\n    }\n    return;\n  }\n  if (!password) {\n    throw new Error(\"password is required to create missing user \" + username);\n  }\n  dbHandle.createUser({ user: username, pwd: password, roles: desiredRoles });\n}\n\nfunction ensureReportingRole() {\n  const desiredPrivileges = [\n    {\n      resource: { db: appDbName, collection: reportsCollection },\n      actions: [ \"find\" ]\n    }\n  ];\n  const existing = appDb.getRole(reportingRole, { showPrivileges: true });\n  if (existing) {\n    appDb.updateRole(reportingRole, { privileges: desiredPrivileges, roles: [] });\n  } else {\n    appDb.createRole({ role: reportingRole, privileges: desiredPrivileges, roles: [] });\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  ensureUser(adminDb, appUsername, appPassword, [ { role: \"readWrite\", db: appDbName } ]);\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  ensureReportingRole();\n  ensureUser(adminDb, reportingUsername, reportingPassword, [ { role: reportingRole, db: appDbName } ]);\n}\n\nprint(\"mongodb RBAC reset completed for mode=\" + mode);\nMONGOJS\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-18t08-54-59z-workflow-r-d426d300-cluster-a"}}
