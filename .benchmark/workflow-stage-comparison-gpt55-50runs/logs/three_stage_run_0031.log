[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/bin/sh\nset -eu\n\nNAMESPACE=\"${NAMESPACE:-wf-2026-05-19t02-06-37z-workflow-r-dfa94997-cluster-a}\"\nPOD=\"${POD:-mongodb-replica-0}\"\nADMIN_USER=\"${ADMIN_USER:-admin-user}\"\nADMIN_SECRET=\"${ADMIN_SECRET:-admin-user-password}\"\nAPP_SECRET=\"${APP_SECRET:-app-user-password}\"\nREPORTING_SECRET=\"${REPORTING_SECRET:-reporting-user-password}\"\nMODE=\"all\"\n\nusage() {\n  echo \"Usage: $0 [--mode all|app|reporting]\" \u003e\u00262\n}\n\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      [ \"$#\" -ge 2 ] || { usage; exit 2; }\n      MODE=\"$2\"\n      shift 2\n      ;;\n    --mode=*)\n      MODE=\"${1#--mode=}\"\n      shift\n      ;;\n    -h|--help)\n      usage\n      exit 0\n      ;;\n    *)\n      usage\n      exit 2\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *) usage; exit 2 ;;\nesac\n\nsecret_password() {\n  kubectl -n \"$NAMESPACE\" get secret \"$1\" -o jsonpath='{.data.password}' | base64 -d\n}\n\nADMIN_PASSWORD=\"${ADMIN_PASSWORD:-$(secret_password \"$ADMIN_SECRET\")}\"\nAPP_PASSWORD=\"${APP_PASSWORD:-$(secret_password \"$APP_SECRET\")}\"\nREPORTING_PASSWORD=\"${REPORTING_PASSWORD:-$(secret_password \"$REPORTING_SECRET\")}\"\n\nJS='\nconst mode = process.env.RESET_MODE;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst admin = db.getSiblingDB(\"admin\");\nconst appdb = db.getSiblingDB(\"appdb\");\n\nfunction ensureAdminUser(user, password, roles) {\n  if (admin.getUser(user) == null) {\n    admin.createUser({ user: user, pwd: password, roles: roles });\n  } else {\n    admin.updateUser(user, { pwd: password, roles: roles });\n  }\n}\n\nfunction resetApp() {\n  ensureAdminUser(\"app-user\", appPassword, [{ role: \"readWrite\", db: \"appdb\" }]);\n}\n\nfunction resetReporting() {\n  const reportingPrivileges = [\n    { resource: { db: \"appdb\", collection: \"reports\" }, actions: [\"find\"] }\n  ];\n\n  if (appdb.getRole(\"reportingRole\", { showPrivileges: true }) == null) {\n    appdb.createRole({ role: \"reportingRole\", privileges: reportingPrivileges, roles: [] });\n  } else {\n    appdb.updateRole(\"reportingRole\", { privileges: reportingPrivileges, roles: [] });\n  }\n\n  ensureAdminUser(\"reporting-user\", reportingPassword, [{ role: \"reportingRole\", db: \"appdb\" }]);\n\n  if (appdb.getRole(\"rawRead\") != null) {\n    appdb.dropRole(\"rawRead\");\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  resetApp();\n}\nif (mode === \"all\" || mode === \"reporting\") {\n  resetReporting();\n}\n\nprint(\"rbac reset complete: \" + mode);\n'\n\nkubectl -n \"$NAMESPACE\" exec \"$POD\" -- env \\\n  RESET_MODE=\"$MODE\" \\\n  APP_PASSWORD=\"$APP_PASSWORD\" \\\n  REPORTING_PASSWORD=\"$REPORTING_PASSWORD\" \\\n  mongosh --quiet -u \"$ADMIN_USER\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin --eval \"$JS\"\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t02-06-37z-workflow-r-dfa94997-cluster-a"}}
