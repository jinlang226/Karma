[kubectl] 2026-05-19T02:10:03Z kubectl -n wf-2026-05-19t02-06-37z-workflow-r-dfa94997-cluster-a exec mongodb-replica-0 -- mongosh --quiet -u admin-user -p admin123password --authenticationDatabase admin --eval '
const admin = db.getSiblingDB("admin");
const appdb = db.getSiblingDB("appdb");
const reportingPassword = "reporting123password";
const rawRole = { role: "rawRead", db: "appdb" };
const rawPrivileges = [{ resource: { db: "appdb", collection: "raw" }, actions: ["find"] }];
if (appdb.getRole("rawRead", {showPrivileges: true}) == null) {
  appdb.createRole({ role: "rawRead", privileges: rawPrivileges, roles: [] });
} else {
  appdb.updateRole("rawRead", { privileges: rawPrivileges, roles: [] });
}
const reportingUser = admin.getUser("reporting-user");
if (reportingUser == null) {
  admin.createUser({ user: "reporting-user", pwd: reportingPassword, roles: [rawRole] });
} else {
  admin.updateUser("reporting-user", { pwd: reportingPassword, roles: [rawRole] });
}
if (appdb.getRole("reportingRole") != null) {
  try { appdb.dropRole("reportingRole"); } catch (e) { print("dropRole reportingRole failed: " + e); throw e; }
}
print("admin users"); printjson(admin.getUsers());
print("appdb roles"); printjson(appdb.getRoles({showPrivileges:true}));
'
