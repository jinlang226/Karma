s, roles: [] },\n      { w: \"majority\" }\n    );\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  ensureUserRoles(\"app-user\", [{ role: \"readWrite\", db: \"appdb\" }]);\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  ensureReportingRole();\n  ensureUserRoles(\"reporting-user\", [{ role: \"reportingRole\", db: \"appdb\" }]);\n  if (app.getRole(\"rawRead\")) {\n    app.dropRole(\"rawRead\", { w: \"majority\" });\n  }\n}\n\nprintjson({\n  ok: 1,\n  mode,\n  appUser: admin.getUser(\"app-user\"),\n  reportingUser: admin.getUser(\"reporting-user\"),\n  appdbRoles: app.getRoles({ showPrivileges: true })\n});\nMONGOJS\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t07-11-15z-workflow-r-7b0c4315-cluster-a"}}
