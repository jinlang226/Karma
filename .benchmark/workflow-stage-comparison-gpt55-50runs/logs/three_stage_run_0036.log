\"$REPORTS_COLLECTION\"'\";\nconst privileges = [{\n  resource: { db: appDbName, collection: reportsCollection },\n  actions: [\"find\"]\n}];\n\nif (appDb.getRole(roleName, { showPrivileges: true })) {\n  appDb.updateRole(roleName, {\n    privileges: privileges,\n    roles: []\n  });\n} else {\n  appDb.createRole({\n    role: roleName,\n    privileges: privileges,\n    roles: []\n  });\n}\n\nif (!adminDb.getUser(username)) {\n  throw new Error(\"missing user: \" + username);\n}\nadminDb.updateUser(username, {\n  roles: [{ role: roleName, db: appDbName }]\n});\nprint(\"reporting RBAC reset complete\");\n'\n}\n\ncase \"$MODE\" in\n  all)\n    reset_app\n    reset_reporting\n    ;;\n  app)\n    reset_app\n    ;;\n  reporting)\n    reset_reporting\n    ;;\nesac\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t04-22-08z-workflow-r-428e881f-cluster-a"}}
