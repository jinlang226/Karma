[agent] MONGO_URI="mongodb://${hosts}/admin?replicaSet=${REPLICA_SET_NAME}"
[agent] APP_DATABASE_JS="$(js_string "$APP_DATABASE")"
[agent] APP_USERNAME_JS="$(js_string "$APP_USERNAME")"
[agent] REPORTING_USERNAME_JS="$(js_string "$REPORTING_USERNAME")"
[agent] REPORTING_ROLE_NAME_JS="$(js_string "$REPORTING_ROLE_NAME")"
[agent] REPORTS_COLLECTION_JS="$(js_string "$REPORTS_COLLECTION")"
[agent] run_mongo() {
[agent]   kubectl -n "$NAMESPACE" exec "$POD" -- mongosh --quiet "$MONGO_URI" \
[agent]     -u "$ADMIN_USERNAME" -p "$ADMIN_PASSWORD" --authenticationDatabase admin \
[agent]     --eval "$1"
[agent] }
[agent] reset_app() {
[agent]   run_mongo "
[agent]     const admin = db.getSiblingDB('admin');
[agent]     admin.updateUser('${APP_USERNAME_JS}', { roles: [ { role: 'readWrite', db: '${APP_DATABASE_JS}' } ] });
[agent]     print('${APP_USERNAME_JS} roles reset to ${APP_DATABASE_JS}.readWrite');
[agent]   "
[agent] }
[agent] reset_reporting() {
[agent]   run_mongo "
[agent]     const admin = db.getSiblingDB('admin');
[agent]     const appdb = db.getSiblingDB('${APP_DATABASE_JS}');
[agent]     const roleName = '${REPORTING_ROLE_NAME_JS}';
[agent]     const desiredPrivileges = [
[agent]       { resource: { db: '${APP_DATABASE_JS}', collection: '${REPORTS_COLLECTION_JS}' }, actions: [ 'find' ] }
[agent]     ];
[agent]     const existing = appdb.getRole(roleName, { showPrivileges: true });
[agent]     if (existing) {
[agent]       appdb.updateRole(roleName, { privileges: desiredPrivileges, roles: [] });
[agent]     } else {
[agent]       appdb.createRole({ role: roleName, privileges: desiredPrivileges, roles: [] });
[agent]     }
[agent]     admin.updateUser('${REPORTING_USERNAME_JS}', { roles: [ { role: roleName, db: '${APP_DATABASE_JS}' } ] });
[agent]     print('${REPORTING_ROLE_NAME_JS} reset and ${REPORTING_USERNAME_JS} roles reset');
[agent]   "
[agent] }
[agent] case "$MODE" in
[agent]   all)
[agent]     reset_app
[agent]     reset_reporting
[agent]     ;;
[agent]   app)
[agent]     reset_app
[agent]     ;;
[agent]   reporting)
[agent]     reset_reporting
[agent]     ;;
[agent] esac
