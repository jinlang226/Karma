[agent] }
[agent] require_cmd kubectl
[agent] ADMIN_PASSWORD="$(kubectl -n "$NAMESPACE" get secret "$ADMIN_SECRET_NAME" -o jsonpath='{.data.password}' | base64 -d)"
[agent] hosts=""
