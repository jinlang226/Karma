[agent] +      }
[agent] +      const users = adminDb.getUsers().users.concat(appDb.getUsers().users);
[agent] +      const stillAssigned = users.some((user) =>
[agent] +        (user.roles || []).some((assigned) => assigned.role === badRole && assigned.db === appDbName)
[agent] +      );
[agent] +      if (!stillAssigned) {
[agent] +        appDb.dropRole(badRole);
[agent] +      }
[agent] +    }
