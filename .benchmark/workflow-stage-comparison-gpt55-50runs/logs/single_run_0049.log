[agent] +    function ensureAdminUserRoles(username, password, desiredRoles) {
[agent] +      const existing = adminDb.getUser(username);
[agent] +      if (existing === null) {
[agent] +        adminDb.createUser({ user: username, pwd: password, roles: desiredRoles });
[agent] +        return;
[agent] +      }
[agent] +      if (!sameRoleSet(existing.roles, desiredRoles)) {
[agent] +        adminDb.updateUser(username, { roles: desiredRoles });
[agent] +      }
[agent] +    }
[agent] +
[agent] +    function sameReportingPrivileges(roleInfo) {
[agent] +      if (roleInfo === null) {
[agent] +        return false;
[agent] +      }
[agent] +      const desired = [{
