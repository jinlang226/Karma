[agent] +    const mode = process.env.MODE;
[agent] +    const adminDb = db.getSiblingDB("admin");
[agent] +    const appDbName = process.env.APP_DATABASE;
[agent] +    const appDb = db.getSiblingDB(appDbName);
[agent] +    const appUser = process.env.APP_USERNAME;
[agent] +    const appPassword = process.env.APP_PASSWORD;
[agent] +    const reportingUser = process.env.REPORTING_USERNAME;
[agent] +    const reportingPassword = process.env.REPORTING_PASSWORD;
[agent] +    const reportingRole = process.env.REPORTING_ROLE_NAME;
[agent] +    const reportsCollection = process.env.REPORTS_COLLECTION;
[agent] +    const badRole = process.env.BAD_ROLE_NAME;
[agent] +
[agent] +    function userExists(database, username) {
[agent] +      return database.getUser(username) !== null;
[agent] +    }
[agent] +
[agent] +    function sameRoleSet(actual, desired) {
[agent] +      const normalize = (roles) => roles
[agent] +        .map((role) => ({ role: role.role, db: role.db }))
[agent] +        .sort((a, b) => (a.db + "." + a.role).localeCompare(b.db + "." + b.role));
[agent] +      return JSON.stringify(normalize(actual || [])) === JSON.stringify(normalize(desired));
[agent] +    }
[agent] +
[agent] +    function ensureAdminUserRoles(username, password, desiredRoles) {
[agent] +      const existing = adminDb.getUser(username);
[agent] +      if (existing === null) {
[agent] +        adminDb.createUser({ user: username, pwd: password, roles: desiredRoles });
[agent] +        return;
[agent] +      }
[agent] +      if (!sameRoleSet(existing.roles, desiredRoles)) {
[agent] +        adminDb.updateUser(username, { roles: desiredRoles });
[agent] +      }
[agent] +    }
[agent] +
[agent] +    function sameReportingPrivileges(roleInfo) {
[agent] +      if (roleInfo === null) {
[agent] +        return false;
[agent] +      }
[agent] +      const desired = [{
[agent] +        resource: { db: appDbName, collection: reportsCollection },
[agent] +        actions: ["find"]
[agent] +      }];
[agent] +      const actual = (roleInfo.privileges || []).map((privilege) => ({
[agent] +        resource: privilege.resource,
[agent] +        actions: [...privilege.actions].sort()
[agent] +      }));
[agent] +      return JSON.stringify(actual) === JSON.stringify(desired) &&
[agent] +        JSON.stringify(roleInfo.roles || []) === JSON.stringify([]);
[agent] +    }
[agent] +
[agent] +    function ensureReportingRole() {
[agent] +      const desiredPrivileges = [{
[agent] +        resource: { db: appDbName, collection: reportsCollection },
[agent] +        actions: ["find"]
[agent] +      }];
[agent] +      const existing = appDb.getRole(reportingRole, { showPrivileges: true });
[agent] +      if (existing === null) {
[agent] +        appDb.createRole({ role: reportingRole, privileges: desiredPrivileges, roles: [] });
[agent] +        return;
[agent] +      }
[agent] +      if (!sameReportingPrivileges(existing)) {
[agent] +        appDb.updateRole(reportingRole, { privileges: desiredPrivileges, roles: [] });
[agent] +      }
[agent] +    }
[agent] +
[agent] +    function dropDeprecatedRawRoleIfUnused() {
[agent] +      const role = appDb.getRole(badRole);
[agent] +      if (role === null) {
[agent] +        return;
[agent] +      }
[agent] +      const users = adminDb.getUsers().users.concat(appDb.getUsers().users);
[agent] +      const stillAssigned = users.some((user) =>
[agent] +        (user.roles || []).some((assigned) => assigned.role === badRole && assigned.db === appDbName)
[agent] +      );
[agent] +      if (!stillAssigned) {
[agent] +        appDb.dropRole(badRole);
[agent] +      }
[agent] +    }
[agent] +
[agent] +    if (mode === "all" || mode === "app") {
[agent] +      ensureAdminUserRoles(appUser, appPassword, [{ role: "readWrite", db: appDbName }]);
[agent] +    }
[agent] +
[agent] +    if (mode === "all" || mode === "reporting") {
[agent] +      ensureReportingRole();
[agent] +      ensureAdminUserRoles(reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);
[agent] +      dropDeprecatedRawRoleIfUnused();
[agent] +    }
