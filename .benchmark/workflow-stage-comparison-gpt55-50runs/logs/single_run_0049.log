[agent] +        actions: ["find"]
[agent] +      }];
[agent] +      const actual = (roleInfo.privileges || []).map((privilege) => ({
[agent] +        resource: privilege.resource,
[agent] +        actions: [...privilege.actions].sort()
[agent] +      }));
[agent] +      return JSON.stringify(actual) === JSON.stringify(desired) &&
[agent] +        JSON.stringify(roleInfo.roles || []) === JSON.stringify([]);
[agent] +    }
[agent] +
[agent] +    function ensureReportingRole() {
[agent] +      const desiredPrivileges = [{
[agent] +        resource: { db: appDbName, collection: reportsCollection },
[agent] +        actions: ["find"]
[agent] +      }];
[agent] +      const existing = appDb.getRole(reportingRole, { showPrivileges: true });
[agent] +      if (existing === null) {
[agent] +        appDb.createRole({ role: reportingRole, privileges: desiredPrivileges, roles: [] });
[agent] +        return;
[agent] +      }
[agent] +      if (!sameReportingPrivileges(existing)) {
[agent] +        appDb.updateRole(reportingRole, { privileges: desiredPrivileges, roles: [] });
[agent] +      }
[agent] +    }
[agent] +
[agent] +    function dropDeprecatedRawRoleIfUnused() {
[agent] +      const role = appDb.getRole(badRole);
[agent] +      if (role === null) {
[agent] +        return;
[agent] +      }
[agent] +      const users = adminDb.getUsers().users.concat(appDb.getUsers().users);
[agent] +      const stillAssigned = users.some((user) =>
[agent] +        (user.roles || []).some((assigned) => assigned.role === badRole && assigned.db === appDbName)
[agent] +      );
[agent] +      if (!stillAssigned) {
[agent] +        appDb.dropRole(badRole);
[agent] +      }
[agent] +    }
[agent] +
[agent] +    if (mode === "all" || mode === "app") {
[agent] +      ensureAdminUserRoles(appUser, appPassword, [{ role: "readWrite", db: appDbName }]);
[agent] +    }
[agent] +
[agent] +    if (mode === "all" || mode === "reporting") {
[agent] +      ensureReportingRole();
[agent] +      ensureAdminUserRoles(reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);
[agent] +      dropDeprecatedRawRoleIfUnused();
[agent] +    }
[agent] +    MONGOJS
[agent] +    )"
