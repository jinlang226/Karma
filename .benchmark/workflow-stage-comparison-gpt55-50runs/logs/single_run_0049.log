[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/bin/sh\nset -eu\n\nusage() {\n  echo \"Usage: $0 --mode all|app|reporting\" \u003e\u00262\n  exit 2\n}\n\nMODE=\"\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      shift\n      [ \"$#\" -gt 0 ] || usage\n      MODE=\"$1\"\n      ;;\n    --mode=*)\n      MODE=\"${1#--mode=}\"\n      ;;\n    -h|--help)\n      usage\n      ;;\n    *)\n      usage\n      ;;\n  esac\n  shift\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *) usage ;;\nesac\n\nMONGO_HOST=\"${MONGO_HOST:-localhost}\"\nMONGO_PORT=\"${MONGO_PORT:-27017}\"\nADMIN_USERNAME=\"${ADMIN_USERNAME:-admin-user}\"\nADMIN_PASSWORD=\"${ADMIN_PASSWORD:-admin123password}\"\nAPP_USERNAME=\"${APP_USERNAME:-app-user}\"\nAPP_PASSWORD=\"${APP_PASSWORD:-app123password}\"\nREPORTING_USERNAME=\"${REPORTING_USERNAME:-reporting-user}\"\nREPORTING_PASSWORD=\"${REPORTING_PASSWORD:-reporting123password}\"\nAPP_DATABASE=\"${APP_DATABASE:-appdb}\"\nREPORTING_ROLE_NAME=\"${REPORTING_ROLE_NAME:-reportingRole}\"\nREPORTS_COLLECTION=\"${REPORTS_COLLECTION:-reports}\"\nBAD_ROLE_NAME=\"${BAD_ROLE_NAME:-rawRead}\"\n\nexport MODE APP_USERNAME APP_PASSWORD REPORTING_USERNAME REPORTING_PASSWORD \\\n  APP_DATABASE REPORTING_ROLE_NAME REPORTS_COLLECTION BAD_ROLE_NAME\n\nmongosh --quiet --host \"$MONGO_HOST\" --port \"$MONGO_PORT\" \\\n  -u \"$ADMIN_USERNAME\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin \u003c\u003c'MONGOJS'\nconst mode = process.env.MODE;\nconst adminDb = db.getSiblingDB(\"admin\");\nconst appDbName = process.env.APP_DATABASE;\nconst appDb = db.getSiblingDB(appDbName);\nconst appUser = process.env.APP_USERNAME;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUser = process.env.REPORTING_USERNAME;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRole = process.env.REPORTING_ROLE_NAME;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\nconst badRole = process.env.BAD_ROLE_NAME;\n\nfunction userExists(database, username) {\n  return database.getUser(username) !== null;\n}\n\nfunction sameRoleSet(actual, desired) {\n  const normalize = (roles) =\u003e roles\n    .map((role) =\u003e ({ role: role.role, db: role.db }))\n    .sort((a, b) =\u003e (a.db + \".\" + a.role).localeCompare(b.db + \".\" + b.role));\n  return JSON.stringify(normalize(actual || [])) === JSON.stringify(normalize(desired));\n}\n\nfunction ensureAdminUserRoles(username, password, desiredRoles) {\n  const existing = adminDb.getUser(username);\n  if (existing === null) {\n    adminDb.createUser({ user: username, pwd: password, roles: desiredRoles });\n    return;\n  }\n  if (!sameRoleSet(existing.roles, desiredRoles)) {\n    adminDb.updateUser(username, { roles: desiredRoles });\n  }\n}\n\nfunction sameReportingPrivileges(roleInfo) {\n  if (roleInfo === null) {\n    return false;\n  }\n  const desired = [{\n    resource: { db: appDbName, collection: reportsCollection },\n    actions: [\"find\"]\n  }];\n  const actual = (roleInfo.privileges || []).map((privilege) =\u003e ({\n    resource: privilege.resource,\n    actions: [...privilege.actions].sort()\n  }));\n  return JSON.stringify(actual) === JSON.stringify(desired) \u0026\u0026\n    JSON.stringify(roleInfo.roles || []) === JSON.stringify([]);\n}\n\nfunction ensureReportingRole() {\n  const desiredPrivileges = [{\n    resource: { db: appDbName, collection: reportsCollection },\n    actions: [\"find\"]\n  }];\n  const existing = appDb.getRole(reportingRole, { showPrivileges: true });\n  if (existing === null) {\n    appDb.createRole({ role: reportingRole, privileges: desiredPrivileges, roles: [] });\n    return;\n  }\n  if (!sameReportingPrivileges(existing)) {\n    appDb.updateRole(reportingRole, { privileges: desiredPrivileges, roles: [] });\n  }\n}\n\nfunction dropDeprecatedRawRoleIfUnused() {\n  const role = appDb.getRole(badRole);\n  if (role === null) {\n    return;\n  }\n  const users = adminDb.getUsers().users.concat(appDb.getUsers().users);\n  const stillAssigned = users.some((user) =\u003e\n    (user.roles || []).some((assigned) =\u003e assigned.role === badRole \u0026\u0026 assigned.db === appDbName)\n  );\n  if (!stillAssigned) {\n    appDb.dropRole(badRole);\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  ensureAdminUserRoles(appUser, appPassword, [{ role: \"readWrite\", db: appDbName }]);\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  ensureReportingRole();\n  ensureAdminUserRoles(reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);\n  dropDeprecatedRawRoleIfUnused();\n}\nMONGOJS\n"},"kind":"ConfigMap","metadata":{"annotations":{},"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t05-58-25z-workflow-r-8bdfaf44-cluster-a"}}
