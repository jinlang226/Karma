NAMESPACE}.svc.cluster.local:27017,${REPLICA_SET_NAME}-2.${HEADLESS_SERVICE_NAME}.${NAMESPACE}.svc.cluster.local:27017\"\n\nkubectl -n \"$NAMESPACE\" exec -i \"$POD\" -- \\\n  env RESET_MODE=\"$MODE\" \\\n      APP_USERNAME=\"$APP_USERNAME\" \\\n      APP_PASSWORD=\"$APP_PASSWORD\" \\\n      REPORTING_USERNAME=\"$REPORTING_USERNAME\" \\\n      REPORTING_PASSWORD=\"$REPORTING_PASSWORD\" \\\n      APP_DATABASE=\"$APP_DATABASE\" \\\n      REPORTING_ROLE_NAME=\"$REPORTING_ROLE_NAME\" \\\n      REPORTS_COLLECTION=\"$REPORTS_COLLECTION\" \\\n  mongosh --quiet \\\n    --host \"${REPLICA_SET_NAME}/${HOSTS}\" \\\n    -u \"$ADMIN_USERNAME\" \\\n    -p \"$ADMIN_PASSWORD\" \\\n    --authenticationDatabase admin \u003c\u003c'MONGOSH'\nconst mode = process.env.RESET_MODE;\nconst appDbName = process.env.APP_DATABASE;\nconst appUserName = process.env.APP_USERNAME;\nconst reportingUserName = process.env.REPORTING_USERNAME;\nconst reportingRoleName = process.env.REPORTING_ROLE_NAME;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\n\nconst adminDb = db.getSiblingDB(\"admin\");\nconst appDb = db.getSiblingDB(appDbName);\n\nfunction ensureUser(database, userName, password, roles) {\n  if (database.getUser(userName)) {\n    database.updateUser(userName, { roles });\n  } else {\n    database.createUser({ user: userName, pwd: password, roles });\n  }\n}\n\nfunction ensureRole(database, roleName, privileges, roles) {\n  if (database.getRole(roleName, { showPrivileges: true })) {\n    database.updateRole(roleName, { privileges, roles });\n  } else {\n    database.createRole({ role: roleName, privileges, roles });\n  }\n}\n\nfunction resetAppUser() {\n  ensureUser(adminDb, appUserName, process.env.APP_PASSWORD, [\n    { role: \"readWrite\", db: appDbName }\n  ]);\n}\n\nfunction resetReportingUser() {\n  ensureRole(appDb, reportingRoleName, [\n    {\n      resource: { db: appDbName, collection: reportsCollection },\n      actions: [\"find\"]\n    }\n  ], []);\n\n  ensureUser(adminDb, reportingUserName, process.env.REPORTING_PASSWORD, [\n    { role: reportingRoleName, db: appDbName }\n  ]);\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  resetAppUser();\n}\n\nif (mode === \"all\" || mode === \"reporting\") {\n  resetReportingUser();\n}\n\nprint(`mongodb RBAC reset complete: mode=${mode}`);\nMONGOSH"},"kind":"ConfigMap","metadata":{"annotations":{},"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-18t18-16-00z-workflow-r-d41684b3-cluster-a"}}
