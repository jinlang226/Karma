[agent] +          [ "$#" -ge 2 ] || {
[agent] +            echo "missing value for --mode" >&2
[agent] +            exit 2
[agent] +          }
[agent] +          MODE="$2"
[agent] +          shift 2
[agent] +          ;;
[agent] +        --mode=*)
[agent] +          MODE="${1#--mode=}"
[agent] +          shift
[agent] +          ;;
[agent] +        -h|--help)
[agent] +          echo "usage: $0 [--mode all|app|reporting]"
[agent] +          exit 0
[agent] +          ;;
[agent] +        *)
[agent] +          echo "unknown argument: $1" >&2
[agent] +          exit 2
[agent] +          ;;
[agent] +      esac
[agent] +    done
[agent] +
[agent] +    case "$MODE" in
