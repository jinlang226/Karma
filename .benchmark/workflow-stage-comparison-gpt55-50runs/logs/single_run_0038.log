[agent] +    const mode = process.env.RBAC_RESET_MODE;
[agent] +    const adminDb = db.getSiblingDB("admin");
[agent] +    const appDbName = process.env.APP_DATABASE;
[agent] +    const appDb = db.getSiblingDB(appDbName);
[agent] +    const appUser = process.env.APP_USERNAME;
[agent] +    const appPassword = process.env.APP_PASSWORD;
[agent] +    const reportingUser = process.env.REPORTING_USERNAME;
[agent] +    const reportingPassword = process.env.REPORTING_PASSWORD;
[agent] +    const reportingRole = process.env.REPORTING_ROLE_NAME;
[agent] +    const reportsCollection = process.env.REPORTS_COLLECTION;
[agent] +    const badRole = process.env.BAD_ROLE_NAME;
[agent] +
[agent] +    function assertOk(result, action) {
[agent] +      if (!result || result.ok !== 1) {
[agent] +        throw new Error(`${action} failed: ${tojson(result)}`);
[agent] +      }
[agent] +    }
[agent] +
[agent] +    function userExists(database, username) {
[agent] +      const result = database.runCommand({ usersInfo: { user: username, db: database.getName() } });
[agent] +      assertOk(result, `lookup user ${database.getName()}.${username}`);
[agent] +      return result.users.length > 0;
[agent] +    }
[agent] +
[agent] +    function setUserRoles(database, username, password, roles) {
[agent] +      if (userExists(database, username)) {
[agent] +        assertOk(database.runCommand({ updateUser: username, roles }), `update user ${database.getName()}.${username}`);
[agent] +      } else {
[agent] +        assertOk(database.runCommand({ createUser: username, pwd: password, roles }), `create user ${database.getName()}.${username}`);
[agent] +      }
[agent] +    }
[agent] +
[agent] +    function resetApp() {
[agent] +      setUserRoles(adminDb, appUser, appPassword, [{ role: "readWrite", db: appDbName }]);
[agent] +    }
[agent] +
[agent] +    function resetReporting() {
[agent] +      const privileges = [
[agent] +        {
[agent] +          resource: { db: appDbName, collection: reportsCollection },
[agent] +          actions: ["find"]
[agent] +        }
[agent] +      ];
[agent] +
[agent] +      const roleInfo = appDb.runCommand({ rolesInfo: { role: reportingRole, db: appDbName } });
[agent] +      assertOk(roleInfo, `lookup role ${appDbName}.${reportingRole}`);
[agent] +      if (roleInfo.roles.length > 0) {
[agent] +        assertOk(appDb.runCommand({ updateRole: reportingRole, privileges, roles: [] }), `update role ${appDbName}.${reportingRole}`);
[agent] +      } else {
[agent] +        assertOk(appDb.runCommand({ createRole: reportingRole, privileges, roles: [] }), `create role ${appDbName}.${reportingRole}`);
[agent] +      }
[agent] +
[agent] +      setUserRoles(adminDb, reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);
[agent] +
[agent] +      const badRoleInfo = appDb.runCommand({ rolesInfo: { role: badRole, db: appDbName } });
[agent] +      assertOk(badRoleInfo, `lookup role ${appDbName}.${badRole}`);
[agent] +      if (badRoleInfo.roles.length > 0) {
[agent] +        assertOk(appDb.runCommand({ dropRole: badRole, writeConcern: { w: "majority" } }), `drop role ${appDbName}.${badRole}`);
[agent] +      }
[agent] +    }
[agent] +
[agent] +    if (mode === "all" || mode === "app") {
[agent] +      resetApp();
[agent] +    }
[agent] +    if (mode === "all" || mode === "reporting") {
[agent] +      resetReporting();
[agent] +    }
[agent] +
[agent] +    print(`rbac reset complete: mode=${mode}`);
[agent] +    MONGO_JS
