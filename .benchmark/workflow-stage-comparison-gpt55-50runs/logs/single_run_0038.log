[agent]       {"apiVersion":"v1","data":{"reset_rbac.sh":"#!/bin/sh\nset -eu\n\nMODE=\"all\"\nwhile [ \"$#\" -gt 0 ]; do\n  case \"$1\" in\n    --mode)\n      [ \"$#\" -ge 2 ] || {\n        echo \"missing value for --mode\" \u003e\u00262\n        exit 2\n      }\n      MODE=\"$2\"\n      shift 2\n      ;;\n    --mode=*)\n      MODE=\"${1#--mode=}\"\n      shift\n      ;;\n    -h|--help)\n      echo \"usage: $0 [--mode all|app|reporting]\"\n      exit 0\n      ;;\n    *)\n      echo \"unknown argument: $1\" \u003e\u00262\n      exit 2\n      ;;\n  esac\ndone\n\ncase \"$MODE\" in\n  all|app|reporting) ;;\n  *)\n    echo \"invalid mode: $MODE (expected all, app, or reporting)\" \u003e\u00262\n    exit 2\n    ;;\nesac\n\nexport RBAC_RESET_MODE=\"$MODE\"\nexport ADMIN_USERNAME=\"${ADMIN_USERNAME:-admin-user}\"\nexport ADMIN_PASSWORD=\"${ADMIN_PASSWORD:-admin123password}\"\nexport APP_USERNAME=\"${APP_USERNAME:-app-user}\"\nexport APP_PASSWORD=\"${APP_PASSWORD:-app123password}\"\nexport REPORTING_USERNAME=\"${REPORTING_USERNAME:-reporting-user}\"\nexport REPORTING_PASSWORD=\"${REPORTING_PASSWORD:-reporting123password}\"\nexport APP_DATABASE=\"${APP_DATABASE:-appdb}\"\nexport REPORTING_ROLE_NAME=\"${REPORTING_ROLE_NAME:-reportingRole}\"\nexport REPORTS_COLLECTION=\"${REPORTS_COLLECTION:-reports}\"\nexport BAD_ROLE_NAME=\"${BAD_ROLE_NAME:-rawRead}\"\n\nMONGO_HOST=\"${MONGO_HOST:-localhost}\"\nMONGO_PORT=\"${MONGO_PORT:-27017}\"\n\nmongosh --quiet --host \"$MONGO_HOST\" --port \"$MONGO_PORT\" \\\n  -u \"$ADMIN_USERNAME\" -p \"$ADMIN_PASSWORD\" --authenticationDatabase admin \u003c\u003c'MONGO_JS'\nconst mode = process.env.RBAC_RESET_MODE;\nconst adminDb = db.getSiblingDB(\"admin\");\nconst appDbName = process.env.APP_DATABASE;\nconst appDb = db.getSiblingDB(appDbName);\nconst appUser = process.env.APP_USERNAME;\nconst appPassword = process.env.APP_PASSWORD;\nconst reportingUser = process.env.REPORTING_USERNAME;\nconst reportingPassword = process.env.REPORTING_PASSWORD;\nconst reportingRole = process.env.REPORTING_ROLE_NAME;\nconst reportsCollection = process.env.REPORTS_COLLECTION;\nconst badRole = process.env.BAD_ROLE_NAME;\n\nfunction assertOk(result, action) {\n  if (!result || result.ok !== 1) {\n    throw new Error(`${action} failed: ${tojson(result)}`);\n  }\n}\n\nfunction userExists(database, username) {\n  const result = database.runCommand({ usersInfo: { user: username, db: database.getName() } });\n  assertOk(result, `lookup user ${database.getName()}.${username}`);\n  return result.users.length \u003e 0;\n}\n\nfunction setUserRoles(database, username, password, roles) {\n  if (userExists(database, username)) {\n    assertOk(database.runCommand({ updateUser: username, roles }), `update user ${database.getName()}.${username}`);\n  } else {\n    assertOk(database.runCommand({ createUser: username, pwd: password, roles }), `create user ${database.getName()}.${username}`);\n  }\n}\n\nfunction resetApp() {\n  setUserRoles(adminDb, appUser, appPassword, [{ role: \"readWrite\", db: appDbName }]);\n}\n\nfunction resetReporting() {\n  const privileges = [\n    {\n      resource: { db: appDbName, collection: reportsCollection },\n      actions: [\"find\"]\n    }\n  ];\n\n  const roleInfo = appDb.runCommand({ rolesInfo: { role: reportingRole, db: appDbName } });\n  assertOk(roleInfo, `lookup role ${appDbName}.${reportingRole}`);\n  if (roleInfo.roles.length \u003e 0) {\n    assertOk(appDb.runCommand({ updateRole: reportingRole, privileges, roles: [] }), `update role ${appDbName}.${reportingRole}`);\n  } else {\n    assertOk(appDb.runCommand({ createRole: reportingRole, privileges, roles: [] }), `create role ${appDbName}.${reportingRole}`);\n  }\n\n  setUserRoles(adminDb, reportingUser, reportingPassword, [{ role: reportingRole, db: appDbName }]);\n\n  const badRoleInfo = appDb.runCommand({ rolesInfo: { role: badRole, db: appDbName } });\n  assertOk(badRoleInfo, `lookup role ${appDbName}.${badRole}`);\n  if (badRoleInfo.roles.length \u003e 0) {\n    assertOk(appDb.runCommand({ dropRole: badRole, writeConcern: { w: \"majority\" } }), `drop role ${appDbName}.${badRole}`);\n  }\n}\n\nif (mode === \"all\" || mode === \"app\") {\n  resetApp();\n}\nif (mode === \"all\" || mode === \"reporting\") {\n  resetReporting();\n}\n\nprint(`rbac reset complete: mode=${mode}`);\nMONGO_JS\n"},"kind":"ConfigMap","metadata":{"annotations":{},"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-19t05-00-01z-workflow-r-71135681-cluster-a"}}
