[agent] +ADMIN_SECRET="${ADMIN_SECRET:-admin-user-password}"
[agent] +APP_USER="${APP_USER:-app-user}"
[agent] +APP_SECRET="${APP_SECRET:-app-user-password}"
[agent] +REPORTING_USER="${REPORTING_USER:-reporting-user}"
[agent] +REPORTING_SECRET="${REPORTING_SECRET:-reporting-user-password}"
[agent] +APP_DB="${APP_DB:-appdb}"
[agent] +REPORTING_ROLE="${REPORTING_ROLE:-reportingRole}"
[agent] +BAD_ROLE="${BAD_ROLE:-rawRead}"
[agent] +REPORTS_COLLECTION="${REPORTS_COLLECTION:-reports}"
[agent] +MODE="all"
[agent] +
[agent] +usage() {
[agent] +  echo "Usage: $0 [--mode all|app|reporting]" >&2
[agent] +}
[agent] +
[agent] +while [ "$#" -gt 0 ]; do
[agent] +  case "$1" in
[agent] +    --mode)
[agent] +      [ "$#" -ge 2 ] || { usage; exit 2; }
[agent] +      MODE="$2"
[agent] +      shift 2
[agent] +      ;;
[agent] +    --mode=*)
[agent] +      MODE="${1#--mode=}"
[agent] +      shift
[agent] +      ;;
[agent] +    -h|--help)
[agent] +      usage
[agent] +      exit 0
[agent] +      ;;
[agent] +    *)
[agent] +      usage
[agent] +      exit 2
[agent] +      ;;
[agent] +  esac
[agent] +done
[agent] +
[agent] +case "$MODE" in
[agent] +  all|app|reporting) ;;
[agent] +  *) usage; exit 2 ;;
[agent] +esac
[agent] +
[agent] +secret_password() {
[agent] +  kubectl -n "$NAMESPACE" get secret "$1" -o jsonpath='{.data.password}' | base64 -d
[agent] +}
[agent] +
[agent] +ADMIN_PASSWORD="$(secret_password "$ADMIN_SECRET")"
[agent] +APP_PASSWORD=""
[agent] +REPORTING_PASSWORD=""
[agent] +
[agent] +if [ "$MODE" = "all" ] || [ "$MODE" = "app" ]; then
[agent] +  APP_PASSWORD="$(secret_password "$APP_SECRET")"
[agent] +fi
[agent] +
[agent] +if [ "$MODE" = "all" ] || [ "$MODE" = "reporting" ]; then
[agent] +  REPORTING_PASSWORD="$(secret_password "$REPORTING_SECRET")"
[agent] +fi
[agent] +
[agent] +APP_PASSWORD="$APP_PASSWORD" REPORTING_PASSWORD="$REPORTING_PASSWORD" \
[agent] +kubectl -n "$NAMESPACE" exec "$POD" -- env \
[agent] +  APP_PASSWORD="$APP_PASSWORD" \
[agent] +  REPORTING_PASSWORD="$REPORTING_PASSWORD" \
[agent] +  mongosh --quiet -u "$ADMIN_USER" -p "$ADMIN_PASSWORD" --authenticationDatabase admin --eval "
[agent] +const mode = '$MODE';
[agent] +const appDbName = '$APP_DB';
[agent] +const appUserName = '$APP_USER';
[agent] +const reportingUserName = '$REPORTING_USER';
[agent] +const reportingRoleName = '$REPORTING_ROLE';
[agent] +const badRoleName = '$BAD_ROLE';
[agent] +const reportsCollection = '$REPORTS_COLLECTION';
[agent] +const adminDb = db.getSiblingDB('admin');
[agent] +const appDb = db.getSiblingDB(appDbName);
[agent] +
[agent] +function ensureAdminUser(userName, password, roles) {
[agent] +  const existing = adminDb.getUser(userName);
[agent] +  if (existing) {
[agent] +    adminDb.updateUser(userName, {pwd: password, roles: roles});
[agent] +  } else {
[agent] +    adminDb.createUser({user: userName, pwd: password, roles: roles});
[agent] +  }
[agent] +}
[agent] +
[agent] +function ensureAppUser() {
[agent] +  ensureAdminUser(appUserName, process.env.APP_PASSWORD, [
[agent] +    {role: 'readWrite', db: appDbName}
[agent] +  ]);
[agent] +}
[agent] +
[agent] +function ensureReportingRole() {
[agent] +  const roleSpec = {
[agent] +    privileges: [
[agent] +      {
[agent] +        resource: {db: appDbName, collection: reportsCollection},
[agent] +        actions: ['find']
[agent] +      }
[agent] +    ],
[agent] +    roles: []
[agent] +  };
[agent] +
[agent] +  if (appDb.getRole(reportingRoleName)) {
[agent] +    appDb.updateRole(reportingRoleName, roleSpec);
[agent] +  } else {
[agent] +    appDb.createRole(Object.assign({role: reportingRoleName}, roleSpec));
[agent] +  }
[agent] +}
[agent] +
[agent] +function resetReportingUser() {
[agent] +  ensureReportingRole();
[agent] +  ensureAdminUser(reportingUserName, process.env.REPORTING_PASSWORD, [
[agent] +    {role: reportingRoleName, db: appDbName}
[agent] +  ]);
[agent] +
[agent] +  if (appDb.getRole(badRoleName)) {
[agent] +    appDb.dropRole(badRoleName);
[agent] +  }
[agent] +}
[agent] +
[agent] +if (mode === 'all' || mode === 'app') {
[agent] +  ensureAppUser();
[agent] +}
[agent] +
[agent] +if (mode === 'all' || mode === 'reporting') {
[agent] +  resetReportingUser();
[agent] +}
[agent] +
[agent] +print('rbac reset complete: mode=' + mode);
[agent] +"
