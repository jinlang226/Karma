const mode = '"'"'all'"'"';
const appDbName = '"'"'appdb'"'"';
const appUserName = '"'"'app-user'"'"';
const reportingUserName = '"'"'reporting-user'"'"';
const reportingRoleName = '"'"'reportingRole'"'"';
const badRoleName = '"'"'rawRead'"'"';
const reportsCollection = '"'"'reports'"'"';
const adminDb = db.getSiblingDB('"'"'admin'"'"');
const appDb = db.getSiblingDB(appDbName);

function ensureAdminUser(userName, password, roles) {
  const existing = adminDb.getUser(userName);
  if (existing) {
    adminDb.updateUser(userName, {pwd: password, roles: roles});
  } else {
    adminDb.createUser({user: userName, pwd: password, roles: roles});
  }
}

function ensureAppUser() {
  ensureAdminUser(appUserName, process.env.APP_PASSWORD, [
    {role: '"'"'readWrite'"'"', db: appDbName}
  ]);
}

function ensureReportingRole() {
  const roleSpec = {
    privileges: [
      {
        resource: {db: appDbName, collection: reportsCollection},
        actions: ['"'"'find'"'"']
      }
    ],
    roles: []
  };

  if (appDb.getRole(reportingRoleName)) {
    appDb.updateRole(reportingRoleName, roleSpec);
  } else {
    appDb.createRole(Object.assign({role: reportingRoleName}, roleSpec));
  }
}

function resetReportingUser() {
  ensureReportingRole();
  ensureAdminUser(reportingUserName, process.env.REPORTING_PASSWORD, [
    {role: reportingRoleName, db: appDbName}
  ]);

  if (appDb.getRole(badRoleName)) {
    appDb.dropRole(badRoleName);
  }
}

if (mode === '"'"'all'"'"' || mode === '"'"'app'"'"') {
  ensureAppUser();
}

if (mode === '"'"'all'"'"' || mode === '"'"'reporting'"'"') {
  resetReportingUser();
}

print('"'"'rbac reset complete: mode='"'"' + mode);
