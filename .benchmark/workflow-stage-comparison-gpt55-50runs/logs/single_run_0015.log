[agent] +data:
[agent] +  reset_rbac.sh: |
[agent] +    #!/bin/sh
[agent] +    set -eu
[agent] +
[agent] +    MODE="all"
[agent] +    while [ "$#" -gt 0 ]; do
[agent] +      case "$1" in
[agent] +        --mode)
[agent] +          [ "$#" -ge 2 ] || { echo "missing value for --mode" >&2; exit 2; }
[agent] +          MODE="$2"
[agent] +          shift 2
[agent] +          ;;
[agent] +        --mode=*)
[agent] +          MODE="${1#--mode=}"
[agent] +          shift
[agent] +          ;;
[agent] +        -h|--help)
[agent] +          echo "usage: $0 [--mode all|app|reporting]"
[agent] +          exit 0
[agent] +          ;;
[agent] +        *)
[agent] +          echo "unknown argument: $1" >&2
[agent] +          exit 2
[agent] +          ;;
[agent] +      esac
[agent] +    done
[agent] +
[agent] +    case "$MODE" in
[agent] +      all|app|reporting) ;;
[agent] +      *) echo "invalid mode: $MODE" >&2; exit 2 ;;
[agent] +    esac
[agent] +
[agent] +    ADMIN_USERNAME="${ADMIN_USERNAME:-admin-user}"
[agent] +    ADMIN_PASSWORD="${ADMIN_PASSWORD:-admin123password}"
[agent] +    APP_USERNAME="${APP_USERNAME:-app-user}"
[agent] +    APP_PASSWORD="${APP_PASSWORD:-app123password}"
[agent] +    REPORTING_USERNAME="${REPORTING_USERNAME:-reporting-user}"
[agent] +    REPORTING_PASSWORD="${REPORTING_PASSWORD:-reporting123password}"
[agent] +    APP_DATABASE="${APP_DATABASE:-appdb}"
[agent] +    REPORTS_COLLECTION="${REPORTS_COLLECTION:-reports}"
[agent] +    REPORTING_ROLE_NAME="${REPORTING_ROLE_NAME:-reportingRole}"
[agent] +    REPLICA_SET_NAME="${REPLICA_SET_NAME:-mongodb-replica}"
[agent] +    MONGO_HOSTS="${MONGO_HOSTS:-mongodb-replica-0.mongodb-replica-svc:27017,mongodb-replica-1.mongodb-replica-svc:27017,mongodb-replica-2.mongodb-replica-svc:27017}"
[agent] +
[agent] +    MONGO_URI="mongodb://${ADMIN_USERNAME}:${ADMIN_PASSWORD}@${MONGO_HOSTS}/admin?replicaSet=${REPLICA_SET_NAME}&authSource=admin"
[agent] +
[agent] +    mongosh "$MONGO_URI" --quiet --eval "
[agent] +    const mode = '$MODE';
[agent] +    const adminDb = db.getSiblingDB('admin');
[agent] +    const appDb = db.getSiblingDB('$APP_DATABASE');
[agent] +
[agent] +    function ensureUser(database, user, password, roles) {
[agent] +      if (database.getUser(user) === null) {
[agent] +        database.createUser({user: user, pwd: password, roles: roles});
[agent] +      } else {
[agent] +        database.updateUser(user, {pwd: password, roles: roles});
[agent] +      }
[agent] +    }
[agent] +
[agent] +    function resetAppUser() {
[agent] +      ensureUser(adminDb, '$APP_USERNAME', '$APP_PASSWORD', [
[agent] +        {role: 'readWrite', db: '$APP_DATABASE'}
[agent] +      ]);
[agent] +    }
[agent] +
[agent] +    function resetReporting() {
[agent] +      const privileges = [{
[agent] +        resource: {db: '$APP_DATABASE', collection: '$REPORTS_COLLECTION'},
[agent] +        actions: ['find']
[agent] +      }];
[agent] +      if (appDb.getRole('$REPORTING_ROLE_NAME') === null) {
[agent] +        appDb.createRole({role: '$REPORTING_ROLE_NAME', privileges: privileges, roles: []});
[agent] +      } else {
[agent] +        appDb.updateRole('$REPORTING_ROLE_NAME', {privileges: privileges, roles: []});
[agent] +      }
[agent] +      ensureUser(adminDb, '$REPORTING_USERNAME', '$REPORTING_PASSWORD', [
[agent] +        {role: '$REPORTING_ROLE_NAME', db: '$APP_DATABASE'}
[agent] +      ]);
[agent] +    }
[agent] +
[agent] +    if (mode === 'all' || mode === 'app') {
[agent] +      resetAppUser();
[agent] +    }
[agent] +    if (mode === 'all' || mode === 'reporting') {
[agent] +      resetReporting();
[agent] +    }
[agent] +    "
