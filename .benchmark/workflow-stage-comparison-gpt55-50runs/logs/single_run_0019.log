s.env.REPORTS_COLLECTION;\nconst appdb = db.getSiblingDB(appDbName);\n\nfunction sameRoles(actual, expected) {\n  const normalize = roles =\u003e (roles || [])\n    .map(r =\u003e ({ role: r.role, db: r.db }))\n    .sort((a, b) =\u003e (a.db + '.' + a.role).localeCompare(b.db + '.' + b.role));\n  return JSON.stringify(normalize(actual)) === JSON.stringify(normalize(expected));\n}\n\nfunction ensureUser(database, username, password, roles) {\n  const existing = database.getUser(username);\n  if (existing) {\n    const update = { roles };\n    update.pwd = password;\n    database.updateUser(username, update);\n  } else {\n    database.createUser({ user: username, pwd: password, roles });\n  }\n  const current = database.getUser(username);\n  if (!current || !sameRoles(current.roles, roles)) {\n    throw new Error(`failed to converge user ${database.getName()}.${username}`);\n  }\n}\n\nfunction samePrivileges(actual, expected) {\n  const normalize = privileges =\u003e (privileges || [])\n    .map(p =\u003e ({\n      resource: {\n        db: p.resource \u0026\u0026 p.resource.db || '',\n        collection: p.resource \u0026\u0026 p.resource.collection || ''\n      },\n      actions: (p.actions || []).slice().sort()\n    }))\n    .sort((a, b) =\u003e (a.resource.db + '.' + a.resource.collection).localeCompare(b.resource.db + '.' + b.resource.collection));\n  return JSON.stringify(normalize(actual)) === JSON.stringify(normalize(expected));\n}\n\nfunction ensureRole() {\n  const privileges = [{\n    resource: { db: appDbName, collection: reportsCollection },\n    actions: ['find']\n  }];\n  const existing = appdb.getRole(reportingRole, { showPrivileges: true });\n  if (existing) {\n    appdb.updateRole(reportingRole, { privileges, roles: [] });\n  } else {\n    appdb.createRole({ role: reportingRole, privileges, roles: [] });\n  }\n  const current = appdb.getRole(reportingRole, { showPrivileges: true });\n  if (!current || !samePrivileges(current.privileges, privileges) ||