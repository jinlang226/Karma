const admin = db.getSiblingDB("admin");
const app = db.getSiblingDB("appdb");
const rawRead = { role: "rawRead", privileges: [{ resource: { db: "appdb", collection: "raw" }, actions: ["find"] }], roles: [] };
try { app.dropRole("reportingRole"); } catch (e) { if (e.codeName !== "RoleNotFound" && e.code !== 31) throw e; }
const roles = app.getRoles().roles.map(r => r.role);
if (roles.includes("rawRead")) {
  app.updateRole("rawRead", { privileges: rawRead.privileges, roles: rawRead.roles });
} else {
  app.createRole(rawRead);
}
const user = admin.getUser("reporting-user");
if (user) {
  admin.updateUser("reporting-user", { roles: [{ role: "rawRead", db: "appdb" }] });
} else {
  admin.createUser({ user: "reporting-user", pwd: "reporting123password", roles: [{ role: "rawRead", db: "appdb" }] });
}
printjson({ users: admin.getUsers().users.filter(u => ["reporting-user"].includes(u.user)), roles: app.getRoles({showPrivileges:true}).roles });
'
