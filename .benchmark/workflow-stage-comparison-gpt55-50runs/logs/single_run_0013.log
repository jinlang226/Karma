ORTING_ROLE;\nconst badRole = process.env.BAD_ROLE;\n\nconst adminDb = db.getSiblingDB(\"admin\");\nconst appDb = db.getSiblingDB(appDbName);\n\nfunction userExists(database, username) {\n  return database.runCommand({usersInfo: username}).users.length \u003e 0;\n}\n\nfunction ensureUserRoles(database, username, password, roles) {\n  if (userExists(database, username)) {\n    database.updateUser(username, {roles: roles});\n  } else {\n    database.createUser({user: username, pwd: password, roles: roles});\n  }\n}\n\nfunction ensureAppUser() {\n  ensureUserRoles(adminDb, appUser, appPassword, [{role: \"readWrite\", db: appDbName}]);\n}\n\nfunction ensureReportingRole() {\n  const roleInfo = appDb.runCommand({rolesInfo: reportingRole, showPrivileges: true}).roles;\n  const roleDoc = {\n    privileges: [{\n      resource: {db: appDbName, collection: reportsCollection},\n      actions: [\"find\"]\n    }],\n    roles: []\n  };\n\n  if (roleInfo.length === 0) {\n    appDb.createRole(Object.assign({role: reportingRole}, roleDoc));\n  } else {\n    appDb.updateRole(reportingRole, roleDoc);\n  }\n}\n\nfunction ensureReportingUser() {\n  ensureReportingRole();\n  ensureUserRoles(adminDb, reportingUser, reportingPassword, [{role: reportingRole, db: appDbName}]);\n\n  const current = adminDb.runCommand({usersInfo: reportingUser}).users[0];\n  if (current \u0026\u0026 current.roles.some((role) =\u003e role.role === badRole)) {\n    adminDb.updateUser(reportingUser, {roles: [{role: reportingRole, db: appDbName}]});\n  }\n}\n\nif (mode === \"app\" || mode === \"all\") {\n  ensureAppUser();\n}\n\nif (mode === \"reporting\" || mode === \"all\") {\n  ensureReportingUser();\n}\n\nprint(`rbac reset complete: mode=${mode}`);\nMONGOJS\n"},"kind":"ConfigMap","metadata":{"annotations":{},"creationTimestamp":null,"name":"mongodb-rbac-reset-script","namespace":"wf-2026-05-18t18-22-37z-workflow-r-7f539526-cluster-a"}}
