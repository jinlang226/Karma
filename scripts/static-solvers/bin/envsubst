#!/usr/bin/env python3
import os
import re
import sys
from typing import Match, Optional, Sequence, Set


VAR_PATTERN = re.compile(r"\$(?:\{([A-Za-z_][A-Za-z0-9_]*)\}|([A-Za-z_][A-Za-z0-9_]*))")


def _allowed_vars(argv: Sequence[str]) -> Optional[Set[str]]:
    if not argv:
        return None
    allowed: Set[str] = set()
    for arg in argv:
        for match in VAR_PATTERN.finditer(arg):
            name = match.group(1) or match.group(2)
            if name:
                allowed.add(name)
    return allowed


def main() -> int:
    allowed = _allowed_vars(sys.argv[1:])
    text = sys.stdin.read()

    def repl(match: Match[str]) -> str:
        name = match.group(1) or match.group(2) or ""
        if allowed is not None and name not in allowed:
            return match.group(0)
        return os.environ.get(name, "")

    sys.stdout.write(VAR_PATTERN.sub(repl, text))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
