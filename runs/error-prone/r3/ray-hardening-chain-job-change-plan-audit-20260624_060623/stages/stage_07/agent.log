    # Upgrade ray-worker image\n      kubectl -n ray set image deployment/ray-worker \\\n        ray-worker=rayproject/ray:2.10.0\n\n      # Wait for rollouts\n      kubectl -n ray rollout status deployment/ray-head\n      kubectl -n ray rollout status deployment/ray-worker\n      ```\n\n      ### 3b. Apply resource requests and limits\n\n      ```bash\n      # ray-head resources\n      kubectl -n ray patch deployment ray-head --type=json -p='[\n        {\n          \"op\": \"add\",\n          \"path\": \"/spec/template/spec/containers/0/resources\",\n          \"value\": {\n            \"requests\": {\"cpu\": \"500m\", \"memory\": \"1Gi\"},\n            \"limits\":   {\"cpu\": \"1000m\", \"memory\": \"2Gi\"}\n          }\n        }\n      ]'\n\n      # ray-worker resources\n      kubectl -n ray patch deployment ray-worker --type=json -p='[\n        {\n          \"op\": \"add\",\n          \"path\": \"/spec/template/spec/containers/0/resources\",\n          \"value\": {\n            \"requests\": {\"cpu\": \"500m\", \"memory\": \"1Gi\"},\n            \"limits\":   {\"cpu\": \"2000m\", \"memory\": \"4Gi\"}\n          }\n        }\n      ]'\n\n      kubectl -n ray rollout status deployment/ray-head\n      kubectl -n ray rollout status deployment/ray-worker\n      ```\n\n      ### 3c. Scale ray-worker to 5 replicas\n\n      ```bash\n      kubectl -n ray scale deployment ray-worker --replicas=5\n      kubectl -n ray rollout status deployment/ray-worker\n      ```\n\n      ### 3d. (Optional) Expose dashboard as NodePort\n\n      ```bash\n      kubectl -n ray patch svc ray-head -p '{\"spec\":{\"type\":\"NodePort\"}}'\n      # Record the assigned node port:\n      kubectl -n ray get svc ray-head -o jsonpath='{.spec.ports[?(@.name==\"dashboard\")].nodePort}'\n      ```\n\n      ---\n\n      ## 4. Rollback Procedure\n\n      If any step introduces instability:\n\n      ```bash\n      # Roll back image change\n      kubectl -n ray rollout undo deployment/ray-head\n      kubectl -n ray rollout undo deployment/ray-worker\n\n      # Restore worker replica count to 3\n      kubectl -n ray scale deployment ray-worker --replicas=3\n\n      # Remove resource limits (revert to empty resources)\n      kubectl -n ray patch deployment ray-head --type=json -p='[\n        {\"op\": \"remove\", \"path\": \"/spec/template/spec/containers/0/resources\"}\n      ]'\n      kubectl -n ray patch deployment ray-worker --type=json -p='[\n        {\"op\": \"remove\", \"path\": \"/spec/template/spec/containers/0/resources\"}\n      ]'\n      ```\n\n      ---\n\n      ## 5. Change Sequencing\n\n      Apply changes in this order during the upgrade window to limit blast radius:\n\n      1. Resource requests/limits (no pod restarts beyond normal rollout)\n      2. Image upgrade (rolling restart, head first, then workers)\n      3. Scale-up (additive, no disruption to existing pods)\n      4. NodePort exposure (optional, requires separate security sign-off)\n\n      Each step should be verified with `kubectl -n ray get pods` and a smoke-test\n      Ray job before proceeding to the next step.\n\n      ---\n\n      *This plan is READ-ONLY. No live resources were modified during its generation.*\n  kind: ConfigMap\n  metadata:\n    creationTimestamp: \"2026-06-24T06:34:09Z\"\n    name: change-plan\n    namespace: ray\n    resourceVersion: \"43783\"\n    uid: 934e16fc-af4b-4b99-8be8-83a403b78597\n- apiVersion: v1\n  data:\n    job.py: |\n      import subprocess\n      import socket\n      import ray\n\n      my_ip = socket.gethostbyname(socket.gethostname())\n\n      subprocess.run([\"ray\", \"stop\", \"--force\"], capture_output=True)\n      subprocess.run(\n          [\"ray\", \"start\", \"--address=ray-head:6379\", \"--node-ip-address=\" + my_ip, \"--num-cpus=0\"],\n          check=True\n      )\n\n      ray.init(address=\"ray-head:6379\", _node_ip_address=my_ip)\n\n      print(\"pong\")\n\n      ray.shutdown()\n      subprocess.run([\"ray\", \"stop\", \"--force\"], c