ev/null -w '%{http_code}' \\\n                -u \"elastic:${ELASTIC_PASSWORD}\" \\\n                https://localhost:9200/_cluster/health | grep -qE '^2'\n          initialDelaySeconds: 60\n          periodSeconds: 10\n          failureThreshold: 30\n          timeoutSeconds: 10\n        resources:\n          requests:\n            memory: \"1Gi\"\n            cpu: \"200m\"\n          limits:\n            memory: \"1Gi\"\n        volumeMounts:\n        - name: config\n          mountPath: /usr/share/elasticsearch/config/elasticsearch.yml\n          subPath: elasticsearch.yml\n        - name: certs\n          mountPath: /usr/share/elasticsearch/config/certs\n          readOnly: true\n        - name: data\n          mountPath: /usr/share/elasticsearch/data\n      volumes:\n      - name: config\n        configMap:\n          name: es-config\n      - name: certs\n        secret:\n          secretName: es-http-tls\n  volumeClaimTemplates:\n  - metadata:\n      name: data\n    spec:\n      accessModes: [\"ReadWriteOnce\"]\n      resources:\n        requests:\n          storage: 1Gi\n","structuredPatch":[{"oldStart":9,"oldLines":7,"newStart":9,"newLines":7,"lines":["     cluster.name: elasticsearch","     node.name: ${NODE_NAME}","     network.host: 0.0.0.0","-    discovery.seed_hosts: es-nodes","+    discovery.seed_hosts: es-0.es-nodes.elasticsearch.svc.cluster.local,es-1.es-nodes.elasticsearch.svc.cluster.local,es-2.es-nodes.elasticsearch.svc.cluster.local","     cluster.initial_master_nodes: es-0,es-1,es-2","     xpack.security.enabled: true","     xpack.security.http.ssl.enabled: true"]}],"userModified":false,"replaceAll":false}}
