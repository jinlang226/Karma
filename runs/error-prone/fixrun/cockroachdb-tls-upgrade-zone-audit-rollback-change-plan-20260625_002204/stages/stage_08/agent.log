{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Rs9V8mK7pshZxcbZV6LbGq","type":"tool_result","content":"1\t#!/bin/bash\n2\t# rollback.sh — Reverts spark-pi namespace to pre-customization defaults.\n3\t#\n4\t# Non-default settings detected (current cluster state vs. upstream defaults):\n5\t#   1. spark-pi-role: 'pods' added to permitted resources after initial creation\n6\t#      (last-applied-configuration annotation shows original: services/configmaps/pvcs only)\n7\t#   2. spark-master + spark-worker: explicit CPU/memory requests and limits applied\n8\t#      (K8s default = no requests/limits = BestEffort QoS)\n9\t#   3. spark-master + spark-worker: image pinned to apache/spark:3.5.3\n10\t#      (upstream default: apache/spark:latest)\n11\t#   4. spark-worker: replicas scaled to 1\n12\t#      (standard Spark worker default: 2)\n13\t#\n14\t# DO NOT execute against a live cluster outside an approved change window.\n15\t# This script is stored as a ConfigMap for review only.\n16\t\n17\tset -euo pipefail\n18\t\n19\tNS=\"spark-pi\"\n20\t\n21\techo \"[1/4] Reverting spark-pi-role: removing 'pods' from permitted resources...\"\n22\tkubectl patch role spark-pi-role -n \"${NS}\" --type=json -p '[\n23\t  {\n24\t    \"op\": \"replace\",\n25\t    \"path\": \"/rules/0/resources\",\n26\t    \"value\": [\"services\", \"configmaps\", \"persistentvolumeclaims\"]\n27\t  }\n28\t]'\n29\t\n30\techo \"[2/4] Reverting spark-master deployment...\"\n31\t\n32\t# Replicas: master default is 1 — already at 1, set explicitly for idempotency\n33\tkubectl scale deployment spark-master -n \"${NS}\" --replicas=1\n34\t\n35\t# Image: revert pinned version to upstream default\n36\tkubectl set image deployment/spark-master \\\n37\t  spark-master=apache/spark:latest -n \"${NS}\"\n38\t\n39\t# Resources: remove non-default requests/limits (replace with empty object)\n40\tkubectl patch deployment spark-master -n \"${NS}\" \\\n41\t  --type=json \\\n42\t  -p '[{\"op\": \"replace\", \"path\": \"/spec/template/spec/containers/0/resources\", \"value\": {}}]'\n43\t\n44\techo \"[3/4] Reverting spark-worker deployment...\"\n45\t\n46\t# Replicas: revert from adjusted value (1) to standard worker default (2)\n47\tkubectl scale deployment spark-worker -n \"${NS}\" --replicas=2\n48\t\n49\t# Image: revert pinned version to upstream default\n50\tkubectl set image deployment/spark-worker \\\n51\t  spark-worker=apache/spark:latest -n \"${NS}\"\n52\t\n53\t# Resources: remove non-default requests/limits\n54\tkubectl patch deployment spark-worker -n \"${NS}\" \\\n55\t  --type=json \\\n56\t  -p '[{\"op\": \"replace\", \"path\": \"/spec/template/spec/containers/0/resources\", \"value\": {}}]'\n57\t\n58\techo \"[4/4] Rollback applied. Verify with:\"\n59\techo \"  kubectl get deployments -n ${NS} -o wide\"\n60\techo \"  kubectl get role spark-pi-role -n ${NS} -o yaml\"\n61\techo \"  kubectl describe deployment spark-master spark-worker -n ${NS} | grep -A5 Limits\"\n62\t"}]},"parent_tool_use_id":null,"session_id":"121126aa-e511-45d3-8b9d-1768fed48aec","uuid":"3e6f7a3d-32aa-4017-bc04-48f020cadd09","timestamp":"2026-06-25T00:43:51.748Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/rollback.sh","content":"#!/bin/bash\n# rollback.sh — Reverts spark-pi namespace to pre-customization defaults.\n#\n# Non-default settings detected (current cluster state vs. upstream defaults):\n#   1. spark-pi-role: 'pods' added to permitted resources after initial creation\n#      (last-applied-configuration annotation shows original: services/configmaps/pvcs only)\n#   2. spark-master + spark-worker: explicit CPU/memory requests and limits applied\n#      (K8s default = no requests/limits = BestEffort QoS)\n#   3. spark-master + spark-worker: image pinned to apache/spark:3.5.3\n#      (upstream default: apache/spark:latest)\n#   4. spark-worker: replicas scaled to 1\n#      (standard Spark worker default: 2)\n#\n# DO NOT execute against a live cluster outside an approved change window.\n# This script is stored as a ConfigMap for review only.\n\nset -euo pipefail\n\nNS=\"spark-pi\"\n\necho \"[1/4] Reverting spark-pi-role: removing 'pods' from permitted resources...\"\nkubectl patch role spark-pi-role -n \"${NS}\" --type=json -p '[\n  {\n    \"op\": \"replace\",\n    \"path\": \"/rules/0/resources\",\n    \"value\": [\"services\", \"configmaps\", \"persistentvolumeclaims\"]\n  }\n]'\n\necho \"[2/4] Reverting spark-master deployment...\"\n\n# Replicas: master default is 1 — already at 1, set explicitly for idempotency\nkubectl scale deployment spark-master -n \"${NS}\" --replicas=1\n\n# Image: revert pinned version to upstream default\nkubectl set image deployment/spark-master \\\n  spark-master=apache/spark:latest -n \"${NS}\"\n\n# Resources: remove non-default requests/limits (replace with empty object)\nkubectl patch deployment spark-master -n \"${NS}\" \\\n  --type=json \\\n  -p '[{\"op\": \"replace\", \"path\": \"/spec/template/spec/containers/0/resources\", \"value\": {}}]'\n\necho \"[3/4] Reverting spark-worker deployment...\"\n\n# Replicas: revert from adjusted value (1) to standard worker default (2)\nkubectl scale deployment spark-worker -n \"${NS}\" --replicas=2\n\n# Image: revert pinned version to upstream default\nkubectl set image deployment/spark-worker \\\n  spark-worker=apache/spark:latest -n \"${NS}\"\n\n# Resources: remove non-default requests/limits\nkubectl patch deployment spark-worker -n \"${NS}\" \\\n  --type=json \\\n  -p '[{\"op\": \"replace\", \"path\": \"/spec/template/spec/containers/0/resources\", \"value\": {}}]'\n\necho \"[4/4] Rollback applied. Verify with:\"\necho \"  kubectl get deployments -n ${NS} -o wide\"\necho \"  kubectl get role spark-pi-role -n ${NS} -o yaml\"\necho \"  kubectl describe deployment spark-master spark-worker -n ${NS} | grep -A5 Limits\"\n","numLines":62,"startLine":1,"totalLines":62}}}
