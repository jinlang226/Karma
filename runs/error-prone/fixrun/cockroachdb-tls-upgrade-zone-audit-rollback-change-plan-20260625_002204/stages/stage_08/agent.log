:3.5.3\n#      (upstream default: apache/spark:latest)\n#   4. spark-worker: replicas scaled to 1\n#      (standard Spark worker default: 2)\n#\n# DO NOT execute against a live cluster outside an approved change window.\n# This script is stored as a ConfigMap for review only.\n\nset -euo pipefail\n\nNS=\"spark-pi\"\n\necho \"[1/4] Reverting spark-pi-role: removing 'pods' from permitted resources...\"\nkubectl patch role spark-pi-role -n \"${NS}\" --type=json -p '[\n  {\n    \"op\": \"replace\",\n    \"path\": \"/rules/0/resources\",\n    \"value\": [\"services\", \"configmaps\", \"persistentvolumeclaims\"]\n  }\n]'\n\necho \"[2/4] Reverting spark-master deployment...\"\n\n# Replicas: master default is 1 — already at 1, set explicitly for idempotency\nkubectl scale deployment spark-master -n \"${NS}\" --replicas=1\n\n# Image: revert pinned version to upstream default\nkubectl set image deployment/spark-master \\\n  spark-master=apache/spark:latest -n \"${NS}\"\n\n# Resources: remove non-default requests/limits (replace with empty object)\nkubectl patch deployment spark-master -n \"${NS}\" \\\n  --type=json \\\n  -p '[{\"op\": \"replace\", \"path\": \"/spec/template/spec/containers/0/resources\", \"value\": {}}]'\n\necho \"[3/4] Reverting spark-worker deployment...\"\n\n# Replicas: revert from adjusted value (1) to standard worker default (2)\nkubectl scale deployment spark-worker -n \"${NS}\" --replicas=2\n\n# Image: revert pinned version to upstream default\nkubectl set image deployment/spark-worker \\\n  spark-worker=apache/spark:latest -n \"${NS}\"\n\n# Resources: remove non-default requests/limits\nkubectl patch deployment spark-worker -n \"${NS}\" \\\n  --type=json \\\n  -p '[{\"op\": \"replace\", \"path\": \"/spec/template/spec/containers/0/resources\", \"value\": {}}]'\n\necho \"[4/4] Rollback applied. Verify with:\"\necho \"  kubectl get deployments -n ${NS} -o wide\"\necho \"  kubectl get role spark-pi-role -n ${NS} -o yaml\"\necho \"  kubectl describe deployment spark-master spark-worker -n ${NS} | grep -A5 Limits\"\n","userModified":false}}
