ade validation** — per-Ingress curl commands verifying rewrite, 429 rate limiting, canary header routing\n\n6. **Rollback** — `rollout undo` path with history check\n\n7. **Non-blocking observations** — no resource limits, no PDB, `publish-status-address=localhost` note, decoy Ingress audit note"}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":464,"cache_read_input_tokens":66849,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":464},"output_tokens":21,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"c55de4f8-cd8b-4135-bcf7-a3df0f711d9c","uuid":"38d65148-acd5-4f7f-a06d-833a3e0ce6fb","request_id":"req_011CcQ57cg2kbtZMD32SwgXe"}
