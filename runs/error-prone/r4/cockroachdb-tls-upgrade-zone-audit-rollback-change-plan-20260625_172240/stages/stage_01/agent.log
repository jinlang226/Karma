 x509 -in /tmp/certs/node.crt -noout -text 2>/dev/null | grep -A1 \"Subject Alternative\"\n'\n","description":"Generate CA, node, and client certs inside openssl-toolbox pod"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1939,"cache_read_input_tokens":29331,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1939},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"d20a2231-bc6f-49fd-8355-a04957b22fce","uuid":"c5efeeea-2e00-4879-9432-979f61be866c","request_id":"req_011CcQND6LoSf2Yp1iyv7vNE"}
