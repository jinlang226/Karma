{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01RkxfV9qu9Xgtike1G5Z5i3","type":"tool_result","content":"1\tapiVersion: apps/v1\n2\tkind: StatefulSet\n3\tmetadata:\n4\t  name: crdb-cluster\n5\t  namespace: cockroachdb\n6\t  labels:\n7\t    app.kubernetes.io/name: cockroachdb\n8\t    app.kubernetes.io/instance: crdb-cluster\n9\tspec:\n10\t  serviceName: crdb-cluster\n11\t  podManagementPolicy: Parallel\n12\t  replicas: 3\n13\t  selector:\n14\t    matchLabels:\n15\t      app.kubernetes.io/name: cockroachdb\n16\t      app.kubernetes.io/instance: crdb-cluster\n17\t  template:\n18\t    metadata:\n19\t      labels:\n20\t        app.kubernetes.io/name: cockroachdb\n21\t        app.kubernetes.io/instance: crdb-cluster\n22\t    spec:\n23\t      serviceAccountName: crdb-cluster-sa\n24\t      containers:\n25\t      - name: db\n26\t        image: cockroachdb/cockroach:v23.2.0\n27\t        imagePullPolicy: IfNotPresent\n28\t        ports:\n29\t        - containerPort: 26257\n30\t          name: grpc\n31\t        - containerPort: 8080\n32\t          name: http\n33\t        volumeMounts:\n34\t        - name: datadir\n35\t          mountPath: /cockroach/cockroach-data\n36\t        env:\n37\t        - name: POD_NAME\n38\t          valueFrom:\n39\t            fieldRef:\n40\t              fieldPath: metadata.name\n41\t        - name: POD_NAMESPACE\n42\t          valueFrom:\n43\t            fieldRef:\n44\t              fieldPath: metadata.namespace\n45\t        command:\n46\t        - /bin/bash\n47\t        - -c\n48\t        - >-\n49\t          exec /cockroach/cockroach start\n50\t          --logtostderr=INFO\n51\t          --insecure\n52\t          --advertise-host=$(POD_NAME).crdb-cluster.$(POD_NAMESPACE).svc.cluster.local\n53\t          --http-addr=0.0.0.0:8080\n54\t          --port=26257\n55\t          --cache=25%\n56\t          --max-sql-memory=25%\n57\t          --join=crdb-cluster-0.crdb-cluster.$(POD_NAMESPACE).svc.cluster.local:26257,crdb-cluster-1.crdb-cluster.$(POD_NAMESPACE).svc.cluster.local:26257,crdb-cluster-2.crdb-cluster.$(POD_NAMESPACE).svc.cluster.local:26257\n58\t        resources:\n59\t          requests:\n60\t            cpu: \"1\"\n61\t            memory: \"2Gi\"\n62\t          limits:\n63\t            cpu: \"1\"\n64\t            memory: \"2Gi\"\n65\t        livenessProbe:\n66\t          httpGet:\n67\t            path: /health\n68\t            port: http\n69\t          initialDelaySeconds: 30\n70\t          periodSeconds: 5\n71\t        readinessProbe:\n72\t          httpGet:\n73\t            path: /health?ready=1\n74\t            port: http\n75\t          initialDelaySeconds: 10\n76\t          periodSeconds: 5\n77\t          failureThreshold: 2\n78\t      terminationGracePeriodSeconds: 60\n79\t  volumeClaimTemplates:\n80\t  - metadata:\n81\t      name: datadir\n82\t      labels:\n83\t        app.kubernetes.io/name: cockroachdb\n84\t        app.kubernetes.io/instance: crdb-cluster\n85\t    spec:\n86\t      accessModes:\n87\t      - ReadWriteOnce\n88\t      resources:\n89\t        requests:\n90\t          storage: 10Gi\n91\t      volumeMode: Filesystem\n92\t"}]},"parent_tool_use_id":null,"session_id":"816a0482-3c85-4513-b4d8-10bd2e6cb492","uuid":"212d1fdd-d280-4d1b-b9d1-ce7dc3a7bc79","timestamp":"2026-06-25T17:30:42.664Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/cockroachdb/major-upgrade-finalize/resource/statefulset.yaml","content":"apiVersion: apps/v1\nkind: StatefulSet\nmetadata:\n  name: crdb-cluster\n  namespace: cockroachdb\n  labels:\n    app.kubernetes.io/name: cockroachdb\n    app.kubernetes.io/instance: crdb-cluster\nspec:\n  serviceName: crdb-cluster\n  podManagementPolicy: Parallel\n  replicas: 3\n  selector:\n    matchLabels:\n      app.kubernetes.io/name: cockroachdb\n      app.kubernetes.io/instance: crdb-cluster\n  template:\n    metadata:\n      labels:\n        app.kubernetes.io/name: cockroachdb\n        app.kubernetes.io/instance: crdb-cluster\n    spec:\n      serviceAccountName: crdb-cluster-sa\n      containers:\n      - name: db\n        image: cockroachdb/cockroach:v23.2.0\n        imagePullPolicy: IfNotPresent\n        ports:\n        - containerPort: 26257\n          name: grpc\n        - containerPort: 8080\n          name: http\n        volumeMounts:\n        - name: datadir\n          mountPath: /cockroach/cockroach-data\n        env:\n        - name: POD_NAME\n          valueFrom:\n            fieldRef:\n              fieldPath: metadata.name\n        - name: POD_NAMESPACE\n          valueFrom:\n            fieldRef:\n              fieldPath: metadata.namespace\n        command:\n        - /bin/bash\n        - -c\n        - >-\n          exec /cockroach/cockroach start\n          --logtostderr=INFO\n          --insecure\n          --advertise-host=$(POD_NAME).crdb-cluster.$(POD_NAMESPACE).svc.cluster.local\n          --http-addr=0.0.0.0:8080\n          --port=26257\n          --cache=25%\n          --max-sql-memory=25%\n          --join=crdb-cluster-0.crdb-cluster.$(POD_NAMESPACE).svc.cluster.local:26257,crdb-cluster-1.crdb-cluster.$(POD_NAMESPACE).svc.cluster.local:26257,crdb-cluster-2.crdb-cluster.$(POD_NAMESPACE).svc.cluster.local:26257\n        resources:\n          requests:\n            cpu: \"1\"\n            memory: \"2Gi\"\n          limits:\n            cpu: \"1\"\n            memory: \"2Gi\"\n        livenessProbe:\n          httpGet:\n            path: /health\n            port: http\n          initialDelaySeconds: 30\n          periodSeconds: 5\n        readinessProbe:\n          httpGet:\n            path: /health?ready=1\n            port: http\n          initialDelaySeconds: 10\n          periodSeconds: 5\n          failureThreshold: 2\n      terminationGracePeriodSeconds: 60\n  volumeClaimTemplates:\n  - metadata:\n      name: datadir\n      labels:\n        app.kubernetes.io/name: cockroachdb\n        app.kubernetes.io/instance: crdb-cluster\n    spec:\n      accessModes:\n      - ReadWriteOnce\n      resources:\n        requests:\n          storage: 10Gi\n      volumeMode: Filesystem\n","numLines":92,"startLine":1,"totalLines":92}}}
