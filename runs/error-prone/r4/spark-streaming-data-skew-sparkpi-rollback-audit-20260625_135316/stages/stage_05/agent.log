{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NNGqWfHMFGwVupQgUzyfmi","type":"tool_result","content":"apiVersion: v1\ndata:\n  rollback.sh: |\n    #!/bin/bash\n    # rollback.sh\n    #\n    # Reverts spark-pi namespace Spark deployments and RBAC to their original\n    # defaults, undoing the following non-default customisations:\n    #\n    #   spark-master deployment\n    #     image     : apache/spark:3.5.3  ->  apache/spark:latest\n    #     resources : cpu req=200m lim=500m, mem req=512Mi lim=1Gi  ->  (none)\n    #     SA        : spark-pi  ->  default\n    #\n    #   spark-worker deployment\n    #     replicas  : 1  ->  2\n    #     image     : apache/spark:3.5.3  ->  apache/spark:latest\n    #     resources : cpu req=200m lim=500m, mem req=512Mi lim=1Gi  ->  (none)\n    #     SA        : spark-pi  ->  default\n    #\n    #   RBAC (non-default additions — all removed)\n    #     RoleBinding  spark-pi-role-binding\n    #     Role         spark-pi-role\n    #     ServiceAccount spark-pi\n    #\n    # WARNING: Do NOT execute this on the live cluster during normal operations.\n    #          The current settings are load-bearing for the running workload.\n    #          This script exists solely for pre-change-window review.\n\n    set -euo pipefail\n\n    NS=\"spark-pi\"\n    DEFAULT_IMAGE=\"apache/spark:latest\"\n\n    echo \"=== spark-pi rollback — restoring original defaults ===\"\n    echo \"Namespace    : $NS\"\n    echo \"Target image : $DEFAULT_IMAGE\"\n    echo \"\"\n\n    # ── 1. spark-master: reset image, remove resource constraints, restore default SA ──\n    echo \"[1/4] Patching spark-master...\"\n    kubectl -n \"$NS\" patch deployment spark-master --type='json' -p=\"[\n      {\\\"op\\\": \\\"replace\\\", \\\"path\\\": \\\"/spec/template/spec/serviceAccountName\\\",    \\\"value\\\": \\\"default\\\"},\n      {\\\"op\\\": \\\"replace\\\", \\\"path\\\": \\\"/spec/template/spec/containers/0/image\\\",    \\\"value\\\": \\\"${DEFAULT_IMAGE}\\\"},\n      {\\\"op\\\": \\\"remove\\\",  \\\"path\\\": \\\"/spec/template/spec/containers/0/resources\\\"}\n    ]\"\n    echo \"  spark-master patched.\"\n\n    # ── 2. spark-worker: restore replicas=2, reset image, remove resources, default SA ──\n    echo \"[2/4] Patching spark-worker...\"\n    kubectl -n \"$NS\" patch deployment spark-worker --type='json' -p=\"[\n      {\\\"op\\\": \\\"replace\\\", \\\"path\\\": \\\"/spec/replicas\\\",                             \\\"value\\\": 2},\n      {\\\"op\\\": \\\"replace\\\", \\\"path\\\": \\\"/spec/template/spec/serviceAccountName\\\",    \\\"value\\\": \\\"default\\\"},\n      {\\\"op\\\": \\\"replace\\\", \\\"path\\\": \\\"/spec/template/spec/containers/0/image\\\",    \\\"value\\\": \\\"${DEFAULT_IMAGE}\\\"},\n      {\\\"op\\\": \\\"remove\\\",  \\\"path\\\": \\\"/spec/template/spec/containers/0/resources\\\"}\n    ]\"\n    echo \"  spark-worker patched.\"\n\n    # ── 3. Remove custom RBAC binding and role ──\n    echo \"[3/4] Removing custom RBAC...\"\n    kubectl -n \"$NS\" delete rolebinding spark-pi-role-binding --ignore-not-found\n    kubectl -n \"$NS\" delete role         spark-pi-role         --ignore-not-found\n    echo \"  RoleBinding and Role removed.\"\n\n    # ── 4. Remove custom ServiceAccount (deployments already switched to 'default') ──\n    echo \"[4/4] Removing custom ServiceAccount spark-pi...\"\n    kubectl -n \"$NS\" delete serviceaccount spark-pi --ignore-not-found\n    echo \"  ServiceAccount removed.\"\n\n    echo \"\"\n    echo \"=== Rollback complete ===\"\n    echo \"Verify rollout with:\"\n    echo \"  kubectl rollout status deployment/spark-master deployment/spark-worker -n $NS\"\n    echo \"  kubectl get deploy,sa,role,rolebinding -n $NS\"\nkind: ConfigMap\nmetadata:\n  creationTimestamp: \"2026-06-25T14:10:06Z\"\n  name: rollback-rehearsal\n  namespace: spark-pi\n  resourceVersion: \"189422\"\n  uid: 4cfd2de7-e955-4a3c-9bcd-edc495e2941b","is_error":false}]},"parent_tool_use_id":null,"session_id":"bf8e4292-3249-4061-8505-81eed68f4945","uuid":"bcb7857e-2a4c-403a-a6e4-062e60f62c81","timestamp":"2026-06-25T14:10:38.813Z","tool_use_result":{"stdout":"apiVersion: v1\ndata:\n  rollback.sh: |\n    #!/bin/bash\n    # rollback.sh\n    #\n    # Reverts spark-pi namespace Spark deployments and RBAC to their original\n    # defaults, undoing the following non-default customisations:\n    #\n    #   spark-master deployment\n    #     image     : apache/spark:3.5.3  ->  apache/spark:latest\n    #     resources : cpu req=200m lim=500m, mem req=512Mi lim=1Gi  ->  (none)\n    #     SA        : spark-pi  ->  default\n    #\n    #   spark-worker deployment\n    #     replicas  : 1  ->  2\n    #     image     : apache/spark:3.5.3  ->  apache/spark:latest\n    #     resources : cpu req=200m lim=500m, mem req=512Mi lim=1Gi  ->  (none)\n    #     SA        : spark-pi  ->  default\n    #\n    #   RBAC (non-default additions — all removed)\n    #     RoleBinding  spark-pi-role-binding\n    #     Role         spark-pi-role\n    #     ServiceAccount spark-pi\n    #\n    # WARNING: Do NOT execute this on the live cluster during normal operations.\n    #          The current settings are load-bearing for the running workload.\n    #          This script exists solely for pre-change-window review.\n\n    set -euo pipefail\n\n    NS=\"spark-pi\"\n    DEFAULT_IMAGE=\"apache/spark:latest\"\n\n    echo \"=== spark-pi rollback — restoring original defaults ===\"\n    echo \"Namespace    : $NS\"\n    echo \"Target image : $DEFAULT_IMAGE\"\n    echo \"\"\n\n    # ── 1. spark-master: reset image, remove resource constraints, restore default SA ──\n    echo \"[1/4] Patching spark-master...\"\n    kubectl -n \"$NS\" patch deployment spark-master --type='json' -p=\"[\n      {\\\"op\\\": \\\"replace\\\", \\\"path\\\": \\\"/spec/template/spec/serviceAccountName\\\",    \\\"value\\\": \\\"default\\\"},\n      {\\\"op\\\": \\\"replace\\\", \\\"path\\\": \\\"/spec/template/spec/containers/0/image\\\",    \\\"value\\\": \\\"${DEFAULT_IMAGE}\\\"},\n      {\\\"op\\\": \\\"remove\\\",  \\\"path\\\": \\\"/spec/template/spec/containers/0/resources\\\"}\n    ]\"\n    echo \"  spark-master patched.\"\n\n    # ── 2. spark-worker: restore replicas=2, reset image, remove resources, default SA ──\n    echo \"[2/4] Patching spark-worker...\"\n    kubectl -n \"$NS\" patch deployment spark-worker --type='json' -p=\"[\n      {\\\"op\\\": \\\"replace\\\", \\\"path\\\": \\\"/spec/replicas\\\",                             \\\"value\\\": 2},\n      {\\\"op\\\": \\\"replace\\\", \\\"path\\\": \\\"/spec/template/spec/serviceAccountName\\\",    \\\"value\\\": \\\"default\\\"},\n      {\\\"op\\\": \\\"replace\\\", \\\"path\\\": \\\"/spec/template/spec/containers/0/image\\\",    \\\"value\\\": \\\"${DEFAULT_IMAGE}\\\"},\n      {\\\"op\\\": \\\"remove\\\",  \\\"path\\\": \\\"/spec/template/spec/containers/0/resources\\\"}\n    ]\"\n    echo \"  spark-worker patched.\"\n\n    # ── 3. Remove custom RBAC binding and role ──\n    echo \"[3/4] Removing custom RBAC...\"\n    kubectl -n \"$NS\" delete rolebinding spark-pi-role-binding --ignore-not-found\n    kubectl -n \"$NS\" delete role         spark-pi-role         --ignore-not-found\n    echo \"  RoleBinding and Role removed.\"\n\n    # ── 4. Remove custom ServiceAccount (deployments already switched to 'default') ──\n    echo \"[4/4] Removing custom ServiceAccount spark-pi...\"\n    kubectl -n \"$NS\" delete serviceaccount spark-pi --ignore-not-found\n    echo \"  ServiceAccount removed.\"\n\n    echo \"\"\n    echo \"=== Rollback complete ===\"\n    echo \"Verify rollout with:\"\n    echo \"  kubectl rollout status deployment/spark-master deployment/spark-worker -n $NS\"\n    echo \"  kubectl get deploy,sa,role,rolebinding -n $NS\"\nkind: ConfigMap\nmetadata:\n  creationTimestamp: \"2026-06-25T14:10:06Z\"\n  name: rollback-rehearsal\n  namespace: spark-pi\n  resourceVersion: \"189422\"\n  uid: 4cfd2de7-e955-4a3c-9bcd-edc495e2941b","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
