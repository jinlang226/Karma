added 8265 container port.\nkubectl -n \"$NS\" patch deploy ray-head --type merge -p '{\n  \"spec\": {\n    \"replicas\": 1,\n    \"template\": {\n      \"spec\": {\n        \"containers\": [\n          {\n            \"name\": \"ray-head\",\n            \"image\": \"rayproject/ray:2.9.0\",\n            \"command\": [\"sh\",\"-c\",\"ray start --head --node-ip-address=\\\"${MY_POD_IP}\\\" --port=6379 --include-dashboard=false --num-cpus=0 --block\\n\"],\n            \"env\": [\n              {\"name\":\"MY_POD_IP\",\"valueFrom\":{\"fieldRef\":{\"fieldPath\":\"status.podIP\"}}},\n              {\"name\":\"RAY_NODE_ID\",\"valueFrom\":{\"fieldRef\":{\"fieldPath\":\"metadata.uid\"}}},\n              {\"name\":\"RAY_RAYLET_PID\",\"value\":\"1\"}\n            ],\n            \"ports\": [{\"containerPort\":6379,\"name\":\"gcs\",\"protocol\":\"TCP\"}]\n          }\n        ]\n      }\n    }\n  }\n}'","originalFile":"#!/usr/bin/env bash\n#\n# rollback-rehearsal: revert the ray namespace to its original baseline config.\n#\n# Drift detected (2026-06-18) vs each resource's last-applied baseline:\n#   - ray-worker:   replicas scaled 2 -> 3            (revert to 2)\n#   - ray-head:     dashboard enabled in start cmd +  (revert to include-dashboard=false)\n#                   container port 8265 added         (remove dashboard port)\n#   - ray-head svc: dashboard port 8265 exposed       (remove dashboard port)\n#   - images:       unchanged (rayproject/ray:2.9.0)  (re-asserted to baseline anyway)\n#\n# This re-applies the recorded baseline manifests, which restores worker replica\n# count, container images, resource limits, and exposed ports in one step.\n# Review before running. DO NOT run during a live change window unless the\n# dashboard/extra workers are confirmed no longer needed.\n\nset -euo pipefail\nNS=ray\n\necho \">> Reverting ray-head Deployment to baseline...\"\nkubectl -n \"$NS\" apply -f - <<'EOF'\napiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: ray-head\n  namespace: ray\n  labels:\n    app.kubernetes.io/component: head\n    app.kubernetes.io/name: ray\n    bench.ray.cluster: ray\nspec:\n  replicas: 1\n  selector:\n    matchLabels:\n      app.kubernetes.io/component: head\n      app.kubernetes.io/name: ray\n      bench.ray.cluster: ray\n  template:\n    metadata:\n      labels:\n        app.kubernetes.io/component: head\n        app.kubernetes.io/name: ray\n        bench.ray.cluster: ray\n    spec:\n      containers:\n      - name: ray-head\n        image: rayproject/ray:2.9.0\n        command:\n        - sh\n        - -c\n        - |\n          ray start --head --node-ip-address=\"${MY_POD_IP}\" --port=6379 --include-dashboard=false --num-cpus=0 --block\n        env:\n        - name: MY_POD_IP\n          valueFrom:\n            fieldRef:\n              fieldPath: status.podIP\n        - name: RAY_NODE_ID\n          valueFrom:\n            fieldRef:\n              fieldPath: metadata.uid\n        - name: RAY_RAYLET_PID\n          value: \"1\"\n        ports:\n        - containerPort: 6379\n          name: gcs\nEOF\n\necho \">> Reverting ray-worker Deployment to baseline (replicas 2)...\"\nkubectl -n \"$NS\" apply -f - <<'EOF'\napiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: ray-worker\n  namespace: ray\n  labels:\n    app.kubernetes.io/component: worker\n    app.kubernetes.io/name: ray\n    bench.ray.cluster: ray\nspec:\n  replicas: 2\n  selector:\n    matchLabels:\n      app.kubernetes.io/component: worker\n      app.kubernetes.io/name: ray\n      bench.ray.cluster: ray\n  template:\n    metadata:\n      labels:\n        app.kubernetes.io/component: worker\n        app.kubernetes.io/name: ray\n        bench.ray.cluster: ray\n    spec:\n      containers:\n      - name: ray-worker\n        image: rayproject/ray:2.9.0\n        command:\n        - sh\n        - -c\n        - |\n          ray start --address=ray-head:6379 --node-ip-address=\"${MY_POD_IP}\" --num-cpus=1 --block\n        env:\n        - name: MY_POD_IP\n          valueFrom:\n            fieldRef:\n              fieldPath: status.podIP\n        - name: RAY_NODE_ID\n          valueFrom:\n            fieldRef:\n              fieldPath: metadata.uid\n        - name: RAY_RAYLET_PID\n          value: \"1\"\nEOF\n\necho \">> Reverting ray-head Service to baseline (remove dashboard port 8265)...\"\n# JSON merge patch replaces the ports array wholesale -> deterministic removal of 8265,\n# regardless of how the dashboard port was originally added (apply vs imperative edit).\nkubectl -n \"$NS\" patch svc ray-head --type merge -p \\\n  '{\"spec\":{\"ports\":[{\"name\":\"gcs\",\"port\":6379,\"targetPort\":6379,\"protocol\":\"TCP\"}]}}'\n\necho \">> Rollback applied. Verifying...\"\nkubectl -n \"$NS\" rollout status deploy/ray-head  --timeout=180s\nkubectl -n \"$NS\" rollout status deploy/ray-worker --timeout=180s\necho \">> Done. Cluster reverted to baseline.\"\n","structuredPatch":[{"oldStart":17,"oldLines":54,"newStart":17,"newLines":31,"lines":[" set -euo pipefail"," NS=ray"," ","-echo \">> Reverting ray-head Deployment to baseline...\"","-kubectl -n \"$NS\" apply -f - <<'EOF'","-apiVersion: apps/v1","-kind: Deployment","-metadata:","-  name: ray-head","-  namespace: ray","-  labels:","-    app.kubernetes.io/component: head","-    app.kubernetes.io/name: ray","-    bench.ray.cluster: ray","-spec:","-  replicas: 1","-  selector:","-    matchLabels:","-      app.kubernetes.io/component: head","-      app.kubernetes.io/name: ray","-      bench.ray.cluster: ray","-  template:","-    metadata:","-      labels:","-        app.kubernetes.io/component: head","-        app.kubernetes.io/name: ray","-        bench.ray.cluster: ray","-    spec:","-      containers:","-      - name: ray-head","-        image: rayproject/ray:2.9.0","-        command:","-        - sh","-        - -c","-        - |","-          ray start --head --node-ip-address=\"${MY_POD_IP}\" --port=6379 --include-dashboard=false --num-cpus=0 --block","-        env:","-        - name: MY_POD_IP","-          valueFrom:","-            fieldRef:","-              fieldPath: status.podIP","-        - name: RAY_NODE_ID","-          valueFrom:","-            fieldRef:","-              fieldPath: metadata.uid","-        - name: RAY_RAYLET_PID","-          value: \"1\"","-        ports:","-        - containerPort: 6379","-          name: gcs","-EOF","+echo \">> Reverting ray-head Deployment to baseline (disable dashboard, remove port 8265)...\"","+# Merge patch replaces the containers array wholesale: resets the start command to","+# --include-dashboard=false and removes the imperatively-added 8265 container port.","+kubectl -n \"$NS\" patch deploy ray-head --type merge -p '{","+  \"spec\": {","+    \"replicas\": 1,","+    \"template\": {","+      \"spec\": {","+        \"containers\": [","+          {","+            \"name\": \"ray-head\",","+            \"image\": \"rayproject/ray:2.9.0\",","+            \"command\": [\"sh\",\"-c\",\"ray start --head --node-ip-address=\\\"${MY_POD_IP}\\\" --port=6379 --include-dashboard=false --num-cpus=0 --block\\n\"],","+            \"env\": [","+              {\"name\":\"MY_POD_IP\",\"valueFrom\":{\"fieldRef\":{\"fieldPath\":\"status.podIP\"}}},","+              {\"name\":\"RAY_NODE_ID\",\"valueFrom\":{\"fieldRef\":{\"fieldPath\":\"metadata.uid\"}}},","+              {\"name\":\"RAY_RAYLET_PID\",\"value\":\"1\"}","+            ],","+            \"ports\": [{\"containerPort\":6379,\"name\":\"gcs\",\"protocol\":\"TCP\"}]","+          }","+        ]","+      }","+    }","+  }","+}'"," "," echo \">> Reverting ray-worker Deployment to baseline (replicas 2)...\""," kubectl -n \"$NS\" apply -f - <<'EOF'"]}],"userModified":false,"replaceAll":false}}
