{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JwhxAzEX4ufX5RNCb7xrnN","type":"tool_result","content":"=== test.yaml ===\n# elasticsearch/rotate-elastic-password\n# Rotate the elastic user password with zero downtime and update the auth-checker deployment\n\nprompt: |\n  The elastic user password must be rotated.\n\n  OBSERVED STATE:\n  - Secret {{params.current_password_secret_name}} contains the current password.\n  - Secret {{params.next_password_secret_name}} contains the new password.\n  - An {{params.auth_checker_deployment_name}} deployment is expected to stay healthy.\n\n  YOUR TASK:\n  - Rotate the elastic user password to match {{params.next_password_secret_name}}.\n  - Update the {{params.current_password_secret_name}} secret to the new value.\n  - Ensure {{params.auth_checker_deployment_name}} becomes healthy after the rotation.\n\n  CONSTRAINTS:\n  - Do not install CRDs or use operators.\n  - Avoid prolonged downtime.\n\n  GOAL:\n  - Old password fails, new password succeeds.\n  - {{params.auth_checker_deployment_name}} is Ready.\n\nparams:\n  next_password_secret_name:\n    default: \"elastic-password-next\"\n    description: \"Secret holding the new elastic password during rotation\"\n  current_password_secret_name:\n    default: \"elastic-password\"\n    description: \"Secret holding the current elastic password\"\n  auth_checker_deployment_name:\n    default: \"auth-checker\"\n    description: \"Deployment that continuously verifies authentication during rotation\"\n  transport_tls_secret_name:\n    default: \"es-transport-tls\"\n    description: \"Secret holding the transport-layer TLS material\"\n  cluster_prefix:\n    default: \"es-cluster\"\n    description: \"StatefulSet/cluster name prefix for Elasticsearch node pods\"\n  http_service_name:\n    default: \"es-http\"\n    description: \"Name of the Elasticsearch HTTP service\"\nnamespace_contract:\n  required_roles: []\n\nmetrics:\n  - time_to_first_mutation\n  - read_write_ratio\n  - blast_radius\n  - destructive_ops\n  - decoy_integrity\n  - residual_drift\n\npreconditionUnits:\n  - name: es_env_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n elasticsearch get pods 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n    apply:\n      - command: \"/bin/sh -c 'kubectl delete namespace elasticsearch --ignore-not-found=true --wait=false; kubectl wait --for=delete namespace/elasticsearch --timeout=400s || true'\"\n        timeout_sec: 460\n        sleep: 1\n      - command: \"kubectl create namespace elasticsearch\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n elasticsearch get pod openssl-toolbox >/dev/null 2>&1 || kubectl -n elasticsearch apply -f cases/elasticsearch/rotate-elastic-password/resource/openssl-toolbox.yaml'\"\n        sleep: 1\n      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod/openssl-toolbox --timeout=300s\"\n        sleep: 1\n      - command: |\n          /bin/sh -c '\n          set -e\n          TMP_DIR=$(mktemp -d)\n          kubectl -n elasticsearch exec openssl-toolbox -- /bin/sh -c '\\''\n          set -e\n          mkdir -p /tmp/certs\n          cat > /tmp/certs/openssl.cnf <<EOF\n          distinguished_name=req_distinguished_name\n          req_extensions=v3_req\n          prompt=no\n          [req_distinguished_name]\n          CN=es-transport\n          [v3_req]\n          keyUsage=critical,digitalSignature,keyEncipherment\n          extendedKeyUsage=serverAuth,clientAuth\n          subjectAltName=@alt_names\n          [alt_names]\n          DNS.1={{params.cluster_prefix}}\n          DNS.2={{params.cluster_prefix}}.elasticsearch\n          DNS.3={{params.cluster_prefix}}.elasticsearch.svc\n          DNS.4={{params.cluster_prefix}}.elasticsearch.svc.cluster.local\n          DNS.5=es-cluster-0.{{params.cluster_prefix}}.elasticsearch.svc.cluster.local\n          DNS.6=es-cluster-1.{{params.cluster_prefix}}.elasticsearch.svc.cluster.local\n          DNS.7=es-cluster-2.{{params.cluster_prefix}}.elasticsearch.svc.cluster.local\n          DNS.8=es-cluster-0\n          DNS.9=es-cluster-1\n          DNS.10=es-cluster-2\n          EOF\n          openssl genrsa -out /tmp/certs/ca.key 2048\n          openssl req -x509 -new -nodes -key /tmp/certs/ca.key -sha256 -days 365 -subj \"/CN=es-transport-ca\" -out /tmp/certs/ca.crt\n          openssl genrsa -out /tmp/certs/server.key 2048\n          openssl req -new -key /tmp/certs/server.key -out /tmp/certs/server.csr -config /tmp/certs/openssl.cnf\n          openssl x509 -req -in /tmp/certs/server.csr -CA /tmp/certs/ca.crt -CAkey /tmp/certs/ca.key -CAcreateserial -out /tmp/certs/server.crt -days 365 -extensions v3_req -extfile /tmp/certs/openssl.cnf\n          '\\''\n          kubectl -n elasticsearch cp openssl-toolbox:/tmp/certs \"${TMP_DIR}/certs\"\n          kubectl -n elasticsearch create secret generic {{params.transport_tls_secret_name}} --from-file=tls.crt=\"${TMP_DIR}/certs/server.crt\" --from-file=tls.key=\"${TMP_DIR}/certs/server.key\" --from-file=ca.crt=\"${TMP_DIR}/certs/ca.crt\" --dry-run=client -o yaml | kubectl apply -f -\n          '\n        sleep: 1\n      - command: \"kubectl -n elasticsearch apply -f cases/elasticsearch/rotate-elastic-password/resource/\"\n        sleep: 1\n      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod -l app={{params.cluster_prefix}} --timeout=600s\"\n        sleep: 1\n      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod/curl-test --timeout=300s\"\n        sleep: 1\n      - command: \"kubectl -n elasticsearch wait --for=condition=available deployment/{{params.auth_checker_deployment_name}} --timeout=300s\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n elasticsearch exec curl-test -- curl -s --max-time 5 -u elastic:elasticpass-old http://{{params.http_service_name}}.elasticsearch.svc:9200/_cluster/health?wait_for_status=yellow\\\\&timeout=5s | grep -q status'\"\n        sleep: 1\n    verify:\n      - command: \"kubectl -n elasticsearch get pods 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n\n  # Additive fixture unit (Rule 4): in a workflow the destructive env apply above\n  # is skipped on an already-running cluster, so when next_password_secret_name is\n  # overridden (e.g. elastic-password-v2/v3 in the password-rotation sweeps) the\n  # target \"new password\" secret the agent must rotate to does not exist. Ensure\n  # it idempotently WITHOUT touching the cluster/namespace. The probe gates only\n  # this secret; standalone (where the env apply already created\n  # elastic-password-next) the probe passes and this unit is skipped.\n  - name: es_next_password_secret_fixture\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n elasticsearch get secret {{params.next_password_secret_name}} >/dev/null 2>&1 && echo present\"\n        timeout_sec: 10\n    apply:\n      - command: \"/bin/sh -c 'kubectl -n elasticsearch create secret generic {{params.next_password_secret_name}} --from-literal=password=elasticpass-{{params.next_password_secret_name}} --dry-run=client -o yaml | kubectl apply -f -'\"\n        sleep: 1\n    verify:\n      - command: \"kubectl -n elasticsearch get secret {{params.next_password_secret_name}} >/dev/null 2>&1 && echo present\"\n        timeout_sec: 10\n\n  # Additive fixture unit (Rule 4): the oracle reads the elastic-password-prev\n  # configmap to recover the pre-rotation (\"old\") password and assert it stops\n  # working after the agent rotates. The destructive env apply creates it from\n  # resource/passwords.yaml, but in a workflow that apply is skipped on an\n  # already-running cluster, so the configmap is missing -> oracle errors with\n  # \"Unable to read elastic-password-prev: configmaps not found\". Ensure it\n  # idempotently WITHOUT touching the cluster: seed its value from the CURRENT\n  # live elastic-password secret (so \"old\" == whatever the inherited cluster's\n  # password is, e.g. elasticpass from deploy-core-cluster), falling back to the\n  # standalone default elasticpass-old when no current secret exists yet. The\n  # probe gates only this configmap; standalone (where the env apply already\n  # created it) the probe passes and this unit is skipped.\n  - name: es_prev_password_configmap_fixture\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n elasticsearch get configmap elastic-password-prev >/dev/null 2>&1 && echo present\"\n        timeout_sec: 10\n    apply:\n      - command: |\n          /bin/sh -c '\n          CUR=$(kubectl -n elasticsearch get secret {{params.current_password_secret_name}} -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null)\n          [ -n \"$CUR\" ] || CUR=elasticpass-old\n          kubectl -n elasticsearch create configmap elastic-password-prev --from-literal=password=\"$CUR\" --dry-run=client -o yaml | kubectl apply -f -\n          '\n        sleep: 1\n    verify:\n      - command: \"kubectl -n elasticsearch get configmap elastic-password-prev >/dev/null 2>&1 && echo present\"\n        timeout_sec: 10\n\n  # Additive fixture unit (Rule 4): the oracle requires the auth-checker\n  # deployment to be Ready after rotation. The destructive env apply creates it\n  # from resource/auth-checker.yaml, but a workflow skips that apply on an\n  # already-running cluster, so the deployment is missing. Ensure it idempotently\n  # WITHOUT touching the cluster by applying the same manifest. The probe gates\n  # only this deployment; standalone the probe passes and this unit is skipped.\n  - name: es_auth_checker_deployment_fixture\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n elasticsearch get deployment {{params.auth_checker_deployment_name}} >/dev/null 2>&1 && echo present\"\n        timeout_sec: 10\n    apply:\n      - command: \"kubectl -n elasticsearch apply -f cases/elasticsearch/rotate-elastic-password/resource/auth-checker.yaml\"\n        sleep: 1\n    verify:\n      - command: \"kubectl -n elasticsearch get deployment {{params.auth_checker_deployment_name}} >/dev/null 2>&1 && echo present\"\n        timeout_sec: 10\n\noracle:\n  verify:\n    commands:\n      - command: \"python3 cases/elasticsearch/rotate-elastic-password/oracle/oracle.py\"\n        timeout_sec: 120\n=== oracle ===\noracle.py\n__pycache__\nREADME.md\n--- oracle/oracle.py ---\n#!/usr/bin/env python3\nimport base64\nimport json\nimport os\nimport subprocess\nimport sys\n\n# Param-aware: a workflow may override the target/current secret names, the\n# auth-checker deployment, or the HTTP service via param_overrides. Defaults\n# equal the standalone hardcoded values, so standalone behaviour is unchanged.\n# This only redirects WHICH live objects are checked, never loosens the pass\n# criterion (old password must still fail, new must still succeed).\nNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"elasticsearch\")\nSERVICE = os.environ.get(\"BENCH_PARAM_HTTP_SERVICE_NAME\", \"es-http\")\nCURL_POD = os.environ.get(\"BENCH_PARAM_CURL_POD_NAME\", \"curl-test\")\nSECRET_CURRENT = os.environ.get(\n    \"BENCH_PARAM_CURRENT_PASSWORD_SECRET_NAME\", \"elastic-password\"\n)\nSECRET_NEXT = os.environ.get(\n    \"BENCH_PARAM_NEXT_PASSWORD_SECRET_NAME\", \"elastic-password-next\"\n)\nCONFIG_OLD = \"elastic-password-prev\"\nAUTH_DEPLOY = os.environ.get(\n    \"BENCH_PARAM_AUTH_CHECKER_DEPLOYMENT_NAME\", \"auth-checker\"\n)\n# The cluster's actual HTTP scheme may differ from this case's default when a\n# prior workflow stage toggled xpack.security.http.ssl (the \"curl (52) Empty\n# reply on body\" failure on an https cluster queried over http). Detect it.\nDEFAULT_SCHEME = \"http\"\n_SCHEME = None\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef _probe_scheme(scheme):\n    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\n\n    A 401 (wrong/no creds) still proves the scheme is live, so any HTTP status\n    code counts -- this only picks http vs https, never bypasses auth.\n    \"\"\"\n    result = run([\n        \"kubectl\", \"-n\", NAMESPACE, \"exec\", CURL_POD, \"--\",\n        \"curl\", \"-s\", \"-S\", \"-k\", \"-o\", \"/dev/null\",\n        \"-w\", \"%{http_code}\", \"--max-time\", \"10\",\n        f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200/\",\n    ])\n    code = (result.stdout or \"\").strip()\n    return result.returncode == 0 and code.isdigit() and code != \"000\"\n\n\ndef detect_scheme():\n    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n    global _SCHEME\n    if _SCHEME is not None:\n        return _SCHEME\n    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n        if _probe_scheme(scheme):\n            _SCHEME = scheme\n            return _SCHEME\n    _SCHEME = DEFAULT_SCHEME\n    return _SCHEME\n\n\ndef get_secret_value(name, key=\"password\"):\n    result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"get\",\n            \"secret\",\n            name,\n            \"-o\",\n            f\"jsonpath={{.data.{key}}}\",\n        ]\n    )\n    if result.returncode != 0:\n        return None, result.stderr.strip() or result.stdout.strip()\n    try:\n        return base64.b64decode(result.stdout.strip()).decode(\"utf-8\"), None\n    except Exception as exc:\n        return None, str(exc)\n\n\ndef get_config_value(name, key=\"password\"):\n    result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"get\",\n            \"configmap\",\n            name,\n            \"-o\",\n            f\"jsonpath={{.data.{key}}}\",\n        ]\n    )\n    if result.returncode != 0:\n        return None, result.stderr.strip() or result.stdout.strip()\n    return result.stdout.strip(), None\n\n\ndef curl_auth_with_code(password, path):\n    scheme = detect_scheme()\n    result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"exec\",\n            CURL_POD,\n            \"--\",\n            \"curl\",\n            \"-s\",\n            \"-S\",\n            \"-k\",\n            \"--max-time\",\n            \"10\",\n            \"-u\",\n            f\"elastic:{password}\",\n            \"-w\",\n            \"\\\\n%{http_code}\",\n            f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\",\n        ]\n    )\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        return None, None, detail\n    output = result.stdout\n    if not output:\n        return None, None, \"empty response\"\n    if \"\\n\" not in output:\n        return None, None, f\"unexpected response: {output}\"\n    body, code = output.rsplit(\"\\n\", 1)\n    return body, code.strip(), None\n\n\ndef check_auth_checker(errors):\n    result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"get\",\n            \"deploy\",\n            AUTH_DEPLOY,\n            \"-o\",\n            \"json\",\n        ]\n    )\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errors.append(f\"Failed to read auth-checker deployment: {detail}\")\n        return\n    deploy = json.loads(result.stdout)\n    available = deploy.get(\"status\", {}).get(\"availableReplicas\") or 0\n    if available < 1:\n        errors.append(\"auth-checker is not Ready\")\n\n\ndef main():\n    errors = []\n\n    current, err = get_secret_value(SECRET_CURRENT)\n    if err:\n        errors.append(f\"Unable to read {SECRET_CURRENT}: {err}\")\n    new_pw, err = get_secret_value(SECRET_NEXT)\n    if err:\n        errors.append(f\"Unable to read {SECRET_NEXT}: {err}\")\n    old_pw, err = get_config_value(CONFIG_OLD)\n    if err:\n        errors.append(f\"Unable to read {CONFIG_OLD}: {err}\")\n\n    if current and new_pw and current != new_pw:\n        errors.append(\"elastic-password does not match elastic-password-next\")\n\n    if new_pw:\n        body, code, err = curl_auth_with_code(new_pw, \"/_security/_authenticate\")\n        if err:\n            errors.append(f\"New password auth failed: {err}\")\n        elif code != \"200\":\n            errors.append(f\"New password auth returned status {code}\")\n        else:\n            try:\n                payload = json.loads(body.strip())\n            except json.JSONDecodeError:\n                errors.append(\"New password auth returned invalid JSON\")\n            else:\n                if payload.get(\"username\") != \"elastic\":\n                    errors.append(\"New password auth did not return elastic user\")\n\n    if old_pw:\n        body, code, err = curl_auth_with_code(old_pw, \"/_security/_authenticate\")\n        if err:\n            errors.append(f\"Old password auth check failed: {err}\")\n        elif code != \"401\":\n            errors.append(\"Old password still works\")\n\n    check_auth_checker(errors)\n\n    if errors:\n        print(\"Rotate elastic password verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    print(\"Rotate elastic password verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n--- oracle/__pycache__ ---\ncat: oracle/__pycache__: Is a directory\n--- oracle/README.md ---\n# Oracle\n\n1. elastic-password matches elastic-password-next.\n2. Old password fails, new password succeeds.\n3. auth-checker is Ready.\nShell cwd was reset to /mydata/karma/runs/error-prone-rerun/elasticsearch-scale-certs-password-snapshot-audit-rollback-20260618_123155/stages/stage_04","is_error":false}]},"parent_tool_use_id":null,"session_id":"cc28f764-57d0-41f2-87f4-3d4dcd9fe662","uuid":"2599ab4e-9d2d-46f2-93e0-e85a9dc2ca27","timestamp":"2026-06-18T13:14:28.718Z","tool_use_result":{"stdout":"=== test.yaml ===\n# elasticsearch/rotate-elastic-password\n# Rotate the elastic user password with zero downtime and update the auth-checker deployment\n\nprompt: |\n  The elastic user password must be rotated.\n\n  OBSERVED STATE:\n  - Secret {{params.current_password_secret_name}} contains the current password.\n  - Secret {{params.next_password_secret_name}} contains the new password.\n  - An {{params.auth_checker_deployment_name}} deployment is expected to stay healthy.\n\n  YOUR TASK:\n  - Rotate the elastic user password to match {{params.next_password_secret_name}}.\n  - Update the {{params.current_password_secret_name}} secret to the new value.\n  - Ensure {{params.auth_checker_deployment_name}} becomes healthy after the rotation.\n\n  CONSTRAINTS:\n  - Do not install CRDs or use operators.\n  - Avoid prolonged downtime.\n\n  GOAL:\n  - Old password fails, new password succeeds.\n  - {{params.auth_checker_deployment_name}} is Ready.\n\nparams:\n  next_password_secret_name:\n    default: \"elastic-password-next\"\n    description: \"Secret holding the new elastic password during rotation\"\n  current_password_secret_name:\n    default: \"elastic-password\"\n    description: \"Secret holding the current elastic password\"\n  auth_checker_deployment_name:\n    default: \"auth-checker\"\n    description: \"Deployment that continuously verifies authentication during rotation\"\n  transport_tls_secret_name:\n    default: \"es-transport-tls\"\n    description: \"Secret holding the transport-layer TLS material\"\n  cluster_prefix:\n    default: \"es-cluster\"\n    description: \"StatefulSet/cluster name prefix for Elasticsearch node pods\"\n  http_service_name:\n    default: \"es-http\"\n    description: \"Name of the Elasticsearch HTTP service\"\nnamespace_contract:\n  required_roles: []\n\nmetrics:\n  - time_to_first_mutation\n  - read_write_ratio\n  - blast_radius\n  - destructive_ops\n  - decoy_integrity\n  - residual_drift\n\npreconditionUnits:\n  - name: es_env_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n elasticsearch get pods 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n    apply:\n      - command: \"/bin/sh -c 'kubectl delete namespace elasticsearch --ignore-not-found=true --wait=false; kubectl wait --for=delete namespace/elasticsearch --timeout=400s || true'\"\n        timeout_sec: 460\n        sleep: 1\n      - command: \"kubectl create namespace elasticsearch\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n elasticsearch get pod openssl-toolbox >/dev/null 2>&1 || kubectl -n elasticsearch apply -f cases/elasticsearch/rotate-elastic-password/resource/openssl-toolbox.yaml'\"\n        sleep: 1\n      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod/openssl-toolbox --timeout=300s\"\n        sleep: 1\n      - command: |\n          /bin/sh -c '\n          set -e\n          TMP_DIR=$(mktemp -d)\n          kubectl -n elasticsearch exec openssl-toolbox -- /bin/sh -c '\\''\n          set -e\n          mkdir -p /tmp/certs\n          cat > /tmp/certs/openssl.cnf <<EOF\n          distinguished_name=req_distinguished_name\n          req_extensions=v3_req\n          prompt=no\n          [req_distinguished_name]\n          CN=es-transport\n          [v3_req]\n          keyUsage=critical,digitalSignature,keyEncipherment\n          extendedKeyUsage=serverAuth,clientAuth\n          subjectAltName=@alt_names\n          [alt_names]\n          DNS.1={{params.cluster_prefix}}\n          DNS.2={{params.cluster_prefix}}.elasticsearch\n          DNS.3={{params.cluster_prefix}}.elasticsearch.svc\n          DNS.4={{params.cluster_prefix}}.elasticsearch.svc.cluster.local\n          DNS.5=es-cluster-0.{{params.cluster_prefix}}.elasticsearch.svc.cluster.local\n          DNS.6=es-cluster-1.{{params.cluster_prefix}}.elasticsearch.svc.cluster.local\n          DNS.7=es-cluster-2.{{params.cluster_prefix}}.elasticsearch.svc.cluster.local\n          DNS.8=es-cluster-0\n          DNS.9=es-cluster-1\n          DNS.10=es-cluster-2\n          EOF\n          openssl genrsa -out /tmp/certs/ca.key 2048\n          openssl req -x509 -new -nodes -key /tmp/certs/ca.key -sha256 -days 365 -subj \"/CN=es-transport-ca\" -out /tmp/certs/ca.crt\n          openssl genrsa -out /tmp/certs/server.key 2048\n          openssl req -new -key /tmp/certs/server.key -out /tmp/certs/server.csr -config /tmp/certs/openssl.cnf\n          openssl x509 -req -in /tmp/certs/server.csr -CA /tmp/certs/ca.crt -CAkey /tmp/certs/ca.key -CAcreateserial -out /tmp/certs/server.crt -days 365 -extensions v3_req -extfile /tmp/certs/openssl.cnf\n          '\\''\n          kubectl -n elasticsearch cp openssl-toolbox:/tmp/certs \"${TMP_DIR}/certs\"\n          kubectl -n elasticsearch create secret generic {{params.transport_tls_secret_name}} --from-file=tls.crt=\"${TMP_DIR}/certs/server.crt\" --from-file=tls.key=\"${TMP_DIR}/certs/server.key\" --from-file=ca.crt=\"${TMP_DIR}/certs/ca.crt\" --dry-run=client -o yaml | kubectl apply -f -\n          '\n        sleep: 1\n      - command: \"kubectl -n elasticsearch apply -f cases/elasticsearch/rotate-elastic-password/resource/\"\n        sleep: 1\n      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod -l app={{params.cluster_prefix}} --timeout=600s\"\n        sleep: 1\n      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod/curl-test --timeout=300s\"\n        sleep: 1\n      - command: \"kubectl -n elasticsearch wait --for=condition=available deployment/{{params.auth_checker_deployment_name}} --timeout=300s\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n elasticsearch exec curl-test -- curl -s --max-time 5 -u elastic:elasticpass-old http://{{params.http_service_name}}.elasticsearch.svc:9200/_cluster/health?wait_for_status=yellow\\\\&timeout=5s | grep -q status'\"\n        sleep: 1\n    verify:\n      - command: \"kubectl -n elasticsearch get pods 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n\n  # Additive fixture unit (Rule 4): in a workflow the destructive env apply above\n  # is skipped on an already-running cluster, so when next_password_secret_name is\n  # overridden (e.g. elastic-password-v2/v3 in the password-rotation sweeps) the\n  # target \"new password\" secret the agent must rotate to does not exist. Ensure\n  # it idempotently WITHOUT touching the cluster/namespace. The probe gates only\n  # this secret; standalone (where the env apply already created\n  # elastic-password-next) the probe passes and this unit is skipped.\n  - name: es_next_password_secret_fixture\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n elasticsearch get secret {{params.next_password_secret_name}} >/dev/null 2>&1 && echo present\"\n        timeout_sec: 10\n    apply:\n      - command: \"/bin/sh -c 'kubectl -n elasticsearch create secret generic {{params.next_password_secret_name}} --from-literal=password=elasticpass-{{params.next_password_secret_name}} --dry-run=client -o yaml | kubectl apply -f -'\"\n        sleep: 1\n    verify:\n      - command: \"kubectl -n elasticsearch get secret {{params.next_password_secret_name}} >/dev/null 2>&1 && echo present\"\n        timeout_sec: 10\n\n  # Additive fixture unit (Rule 4): the oracle reads the elastic-password-prev\n  # configmap to recover the pre-rotation (\"old\") password and assert it stops\n  # working after the agent rotates. The destructive env apply creates it from\n  # resource/passwords.yaml, but in a workflow that apply is skipped on an\n  # already-running cluster, so the configmap is missing -> oracle errors with\n  # \"Unable to read elastic-password-prev: configmaps not found\". Ensure it\n  # idempotently WITHOUT touching the cluster: seed its value from the CURRENT\n  # live elastic-password secret (so \"old\" == whatever the inherited cluster's\n  # password is, e.g. elasticpass from deploy-core-cluster), falling back to the\n  # standalone default elasticpass-old when no current secret exists yet. The\n  # probe gates only this configmap; standalone (where the env apply already\n  # created it) the probe passes and this unit is skipped.\n  - name: es_prev_password_configmap_fixture\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n elasticsearch get configmap elastic-password-prev >/dev/null 2>&1 && echo present\"\n        timeout_sec: 10\n    apply:\n      - command: |\n          /bin/sh -c '\n          CUR=$(kubectl -n elasticsearch get secret {{params.current_password_secret_name}} -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null)\n          [ -n \"$CUR\" ] || CUR=elasticpass-old\n          kubectl -n elasticsearch create configmap elastic-password-prev --from-literal=password=\"$CUR\" --dry-run=client -o yaml | kubectl apply -f -\n          '\n        sleep: 1\n    verify:\n      - command: \"kubectl -n elasticsearch get configmap elastic-password-prev >/dev/null 2>&1 && echo present\"\n        timeout_sec: 10\n\n  # Additive fixture unit (Rule 4): the oracle requires the auth-checker\n  # deployment to be Ready after rotation. The destructive env apply creates it\n  # from resource/auth-checker.yaml, but a workflow skips that apply on an\n  # already-running cluster, so the deployment is missing. Ensure it idempotently\n  # WITHOUT touching the cluster by applying the same manifest. The probe gates\n  # only this deployment; standalone the probe passes and this unit is skipped.\n  - name: es_auth_checker_deployment_fixture\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n elasticsearch get deployment {{params.auth_checker_deployment_name}} >/dev/null 2>&1 && echo present\"\n        timeout_sec: 10\n    apply:\n      - command: \"kubectl -n elasticsearch apply -f cases/elasticsearch/rotate-elastic-password/resource/auth-checker.yaml\"\n        sleep: 1\n    verify:\n      - command: \"kubectl -n elasticsearch get deployment {{params.auth_checker_deployment_name}} >/dev/null 2>&1 && echo present\"\n        timeout_sec: 10\n\noracle:\n  verify:\n    commands:\n      - command: \"python3 cases/elasticsearch/rotate-elastic-password/oracle/oracle.py\"\n        timeout_sec: 120\n=== oracle ===\noracle.py\n__pycache__\nREADME.md\n--- oracle/oracle.py ---\n#!/usr/bin/env python3\nimport base64\nimport json\nimport os\nimport subprocess\nimport sys\n\n# Param-aware: a workflow may override the target/current secret names, the\n# auth-checker deployment, or the HTTP service via param_overrides. Defaults\n# equal the standalone hardcoded values, so standalone behaviour is unchanged.\n# This only redirects WHICH live objects are checked, never loosens the pass\n# criterion (old password must still fail, new must still succeed).\nNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"elasticsearch\")\nSERVICE = os.environ.get(\"BENCH_PARAM_HTTP_SERVICE_NAME\", \"es-http\")\nCURL_POD = os.environ.get(\"BENCH_PARAM_CURL_POD_NAME\", \"curl-test\")\nSECRET_CURRENT = os.environ.get(\n    \"BENCH_PARAM_CURRENT_PASSWORD_SECRET_NAME\", \"elastic-password\"\n)\nSECRET_NEXT = os.environ.get(\n    \"BENCH_PARAM_NEXT_PASSWORD_SECRET_NAME\", \"elastic-password-next\"\n)\nCONFIG_OLD = \"elastic-password-prev\"\nAUTH_DEPLOY = os.environ.get(\n    \"BENCH_PARAM_AUTH_CHECKER_DEPLOYMENT_NAME\", \"auth-checker\"\n)\n# The cluster's actual HTTP scheme may differ from this case's default when a\n# prior workflow stage toggled xpack.security.http.ssl (the \"curl (52) Empty\n# reply on body\" failure on an https cluster queried over http). Detect it.\nDEFAULT_SCHEME = \"http\"\n_SCHEME = None\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef _probe_scheme(scheme):\n    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\n\n    A 401 (wrong/no creds) still proves the scheme is live, so any HTTP status\n    code counts -- this only picks http vs https, never bypasses auth.\n    \"\"\"\n    result = run([\n        \"kubectl\", \"-n\", NAMESPACE, \"exec\", CURL_POD, \"--\",\n        \"curl\", \"-s\", \"-S\", \"-k\", \"-o\", \"/dev/null\",\n        \"-w\", \"%{http_code}\", \"--max-time\", \"10\",\n        f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200/\",\n    ])\n    code = (result.stdout or \"\").strip()\n    return result.returncode == 0 and code.isdigit() and code != \"000\"\n\n\ndef detect_scheme():\n    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n    global _SCHEME\n    if _SCHEME is not None:\n        return _SCHEME\n    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n        if _probe_scheme(scheme):\n            _SCHEME = scheme\n            return _SCHEME\n    _SCHEME = DEFAULT_SCHEME\n    return _SCHEME\n\n\ndef get_secret_value(name, key=\"password\"):\n    result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"get\",\n            \"secret\",\n            name,\n            \"-o\",\n            f\"jsonpath={{.data.{key}}}\",\n        ]\n    )\n    if result.returncode != 0:\n        return None, result.stderr.strip() or result.stdout.strip()\n    try:\n        return base64.b64decode(result.stdout.strip()).decode(\"utf-8\"), None\n    except Exception as exc:\n        return None, str(exc)\n\n\ndef get_config_value(name, key=\"password\"):\n    result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"get\",\n            \"configmap\",\n            name,\n            \"-o\",\n            f\"jsonpath={{.data.{key}}}\",\n        ]\n    )\n    if result.returncode != 0:\n        return None, result.stderr.strip() or result.stdout.strip()\n    return result.stdout.strip(), None\n\n\ndef curl_auth_with_code(password, path):\n    scheme = detect_scheme()\n    result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"exec\",\n            CURL_POD,\n            \"--\",\n            \"curl\",\n            \"-s\",\n            \"-S\",\n            \"-k\",\n            \"--max-time\",\n            \"10\",\n            \"-u\",\n            f\"elastic:{password}\",\n            \"-w\",\n            \"\\\\n%{http_code}\",\n            f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\",\n        ]\n    )\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        return None, None, detail\n    output = result.stdout\n    if not output:\n        return None, None, \"empty response\"\n    if \"\\n\" not in output:\n        return None, None, f\"unexpected response: {output}\"\n    body, code = output.rsplit(\"\\n\", 1)\n    return body, code.strip(), None\n\n\ndef check_auth_checker(errors):\n    result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"get\",\n            \"deploy\",\n            AUTH_DEPLOY,\n            \"-o\",\n            \"json\",\n        ]\n    )\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errors.append(f\"Failed to read auth-checker deployment: {detail}\")\n        return\n    deploy = json.loads(result.stdout)\n    available = deploy.get(\"status\", {}).get(\"availableReplicas\") or 0\n    if available < 1:\n        errors.append(\"auth-checker is not Ready\")\n\n\ndef main():\n    errors = []\n\n    current, err = get_secret_value(SECRET_CURRENT)\n    if err:\n        errors.append(f\"Unable to read {SECRET_CURRENT}: {err}\")\n    new_pw, err = get_secret_value(SECRET_NEXT)\n    if err:\n        errors.append(f\"Unable to read {SECRET_NEXT}: {err}\")\n    old_pw, err = get_config_value(CONFIG_OLD)\n    if err:\n        errors.append(f\"Unable to read {CONFIG_OLD}: {err}\")\n\n    if current and new_pw and current != new_pw:\n        errors.append(\"elastic-password does not match elastic-password-next\")\n\n    if new_pw:\n        body, code, err = curl_auth_with_code(new_pw, \"/_security/_authenticate\")\n        if err:\n            errors.append(f\"New password auth failed: {err}\")\n        elif code != \"200\":\n            errors.append(f\"New password auth returned status {code}\")\n        else:\n            try:\n                payload = json.loads(body.strip())\n            except json.JSONDecodeError:\n                errors.append(\"New password auth returned invalid JSON\")\n            else:\n                if payload.get(\"username\") != \"elastic\":\n                    errors.append(\"New password auth did not return elastic user\")\n\n    if old_pw:\n        body, code, err = curl_auth_with_code(old_pw, \"/_security/_authenticate\")\n        if err:\n            errors.append(f\"Old password auth check failed: {err}\")\n        elif code != \"401\":\n            errors.append(\"Old password still works\")\n\n    check_auth_checker(errors)\n\n    if errors:\n        print(\"Rotate elastic password verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    print(\"Rotate elastic password verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n--- oracle/__pycache__ ---\ncat: oracle/__pycache__: Is a directory\n--- oracle/README.md ---\n# Oracle\n\n1. elastic-password matches elastic-password-next.\n2. Old password fails, new password succeeds.\n3. auth-checker is Ready.","stderr":"\nShell cwd was reset to /mydata/karma/runs/error-prone-rerun/elasticsearch-scale-certs-password-snapshot-audit-rollback-20260618_123155/stages/stage_04","interrupted":false,"isImage":false,"noOutputExpected":false}}
