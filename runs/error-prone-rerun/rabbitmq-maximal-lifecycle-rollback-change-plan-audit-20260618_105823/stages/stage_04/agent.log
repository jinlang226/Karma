{"type":"assistant","message":{"model":"claude-opus-4-8","id":"msg_01Ld4XwTNER9bqJL7gGMQhZd","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_011m83siuiCDQH4bZf8Ls9aX","name":"Write","input":{"file_path":"/tmp/rollback.sh","content":"#!/usr/bin/env bash\n#\n# rollback.sh — REVIEW ARTIFACT (do NOT run against the live cluster yet)\n#\n# Reverts the RabbitMQ cluster in\n#   karma-rabbitmq-maximal-lifecycle-roll-af2b323e-cluster-a\n# back to a stock/default RabbitMQ configuration.\n#\n# Current (non-default) state captured for rollback:\n#   vhosts      : /  /app  /ops          (default = only \"/\")\n#   users       : admin[administrator], app-user[management], ops-user[management]\n#                 (default = only \"guest\" with [administrator])\n#   permissions : admin .*/.*/.* on / , /app , /ops\n#                 app-user .*/.*/.* on /app ; ops-user .*/.*/.* on /ops\n#   policies    : /app  ha-all  (^app-queue$, ha-mode=all, ha-sync-mode=automatic)\n#   queues      : /app  app-queue (classic, durable)\n#                 /ops  ops-queue (classic, durable)\n#\n# Running this restores defaults: a single \"/\" vhost and the stock \"guest\"\n# administrator user, removing all custom vhosts, users, permissions, policies,\n# and queues. This destroys configuration the cluster currently depends on —\n# only execute during an approved change window.\n\nset -euo pipefail\n\nNS=\"karma-rabbitmq-maximal-lifecycle-roll-af2b323e-cluster-a\"\nPOD=\"rabbitmq-0\"\n\nrmqctl() { kubectl -n \"$NS\" exec \"$POD\" -- rabbitmqctl \"$@\"; }\n\necho \">> Removing custom policies\"\nrmqctl clear_policy -p /app ha-all || true\n\necho \">> Removing custom queues\"\nrmqctl delete_queue -p /app app-queue || true\nrmqctl delete_queue -p /ops ops-queue || true\n\necho \">> Clearing custom permissions\"\nrmqctl clear_permissions -p /app admin     || true\nrmqctl clear_permissions -p /app app-user  || true\nrmqctl clear_permissions -p /ops admin     || true\nrmqctl clear_permissions -p /ops ops-user  || true\nrmqctl clear_permissions -p /   admin      || true\n\necho \">> Deleting custom vhosts\"\nrmqctl delete_vhost /app || true\nrmqctl delete_vhost /ops || true\n\necho \">> Deleting custom users\"\nrmqctl delete_user app-user || true\nrmqctl delete_user ops-user || true\nrmqctl delete_user admin    || true\n\necho \">> Restoring stock 'guest' administrator on default vhost '/'\"\nif ! rmqctl list_users | awk '{print $1}' | grep -qx guest; then\n  rmqctl add_user guest guest\nfi\nrmqctl set_user_tags guest administrator\nrmqctl set_permissions -p / guest \".*\" \".*\" \".*\"\n\necho \">> Rollback to RabbitMQ defaults complete.\"\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":903,"cache_read_input_tokens":28714,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":903},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"9f8f035a-669a-4c0e-9ead-5dcd1289e406","uuid":"470b563a-8d81-43f0-8c64-9da45210a386","request_id":"req_011CcAdD53MUvBYEyQ69DEr1"}
