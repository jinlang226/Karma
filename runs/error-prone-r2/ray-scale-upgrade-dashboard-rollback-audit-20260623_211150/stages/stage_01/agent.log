{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Qa6hwirsG7aFAPtqmVxyaV","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\t\"\"\"Oracle for ray/deploy_cluster.\n3\t\n4\tVerifies the Ray head Service exposes the GCS port, the head and worker\n5\tdeployments are ready, and the cluster reports the expected live node count.\n6\t\"\"\"\n7\tfrom __future__ import annotations\n8\t\n9\timport os\n10\timport sys\n11\timport time\n12\tfrom pathlib import Path\n13\t\n14\tsys.path.append(str(Path(__file__).resolve().parents[2]))\n15\t\n16\tfrom common.oracle_lib import (  # noqa: E402\n17\t    deployment_ready_replicas,\n18\t    ray_node_count_from_head,\n19\t    service_ports,\n20\t)\n21\t\n22\tNAMESPACE = \"ray\"\n23\tHEAD = \"ray-head\"\n24\tWORKER = \"ray-worker\"\n25\t# Param-aware: a workflow can override worker_replicas (deploy a cluster with\n26\t# 1/2/3/5 workers). Read the requested count from the env (default = the\n27\t# standalone value 2) so the oracle verifies the size the workflow asked for.\n28\tEXPECTED_WORKERS = int(os.environ.get(\"BENCH_PARAM_WORKER_REPLICAS\", \"2\") or \"2\")\n29\t\n30\tCONNECTIVITY_TOTAL_TIMEOUT_SEC = 60\n31\tCONNECTIVITY_ATTEMPT_TIMEOUT_SEC = 12\n32\t\n33\t\n34\tdef check_service() -> int:\n35\t    \"\"\"Confirm the head Service exposes the GCS port 6379.\"\"\"\n36\t    ports = service_ports(NAMESPACE, HEAD)\n37\t    if 6379 not in ports:\n38\t        print(f\"service/{HEAD} does not expose port 6379\")\n39\t        return 1\n40\t    print(f\"service/{HEAD} exposes port 6379\")\n41\t    return 0\n42\t\n43\t\n44\tdef check_head() -> int:\n45\t    \"\"\"Confirm the head deployment has at least one ready replica.\"\"\"\n46\t    ready = deployment_ready_replicas(NAMESPACE, HEAD)\n47\t    if ready < 1:\n48\t        print(f\"deployment/{HEAD} ready replicas {ready}, expected at least 1\")\n49\t        return 1\n50\t    print(f\"deployment/{HEAD} ready replicas {ready}\")\n51\t    return 0\n52\t\n53\t\n54\tdef check_workers() -> int:\n55\t    \"\"\"Confirm the worker deployment has the expected ready replicas.\"\"\"\n56\t    ready = deployment_ready_replicas(NAMESPACE, WORKER)\n57\t    if ready < EXPECTED_WORKERS:\n58\t        print(f\"deployment/{WORKER} ready replicas {ready}, expected at least {EXPECTED_WORKERS}\")\n59\t        return 1\n60\t    print(f\"deployment/{WORKER} ready replicas {ready}\")\n61\t    return 0\n62\t\n63\t\n64\tdef check_connectivity() -> int:\n65\t    \"\"\"Confirm Ray reports at least 1 head + EXPECTED_WORKERS live nodes.\"\"\"\n66\t    expected_nodes = 1 + EXPECTED_WORKERS\n67\t    deadline = time.time() + CONNECTIVITY_TOTAL_TIMEOUT_SEC\n68\t    last_count = 0\n69\t    last_error = \"\"\n70\t    while time.time() < deadline:\n71\t        try:\n72\t            node_count = ray_node_count_from_head(\n73\t                NAMESPACE, HEAD, timeout_sec=CONNECTIVITY_ATTEMPT_TIMEOUT_SEC\n74\t            )\n75\t        except Exception as exc:  # noqa: BLE001\n76\t            last_error = str(exc)\n77\t            time.sleep(3)\n78\t            continue\n79\t        last_count = node_count\n80\t        if node_count >= expected_nodes:\n81\t            print(f\"ray reports {node_count} nodes\")\n82\t            return 0\n83\t        time.sleep(3)\n84\t    if last_error:\n85\t        print(f\"ray connectivity probe failed: {last_error}\")\n86\t        return 1\n87\t    print(f\"ray reports {last_count} nodes, expected at least {expected_nodes}\")\n88\t    return 1\n89\t\n90\t\n91\tdef main() -> int:\n92\t    \"\"\"Run every deploy_cluster verification check in order.\"\"\"\n93\t    for fn in (check_service, check_head, check_workers, check_connectivity):\n94\t        rc = fn()\n95\t        if rc != 0:\n96\t            return rc\n97\t    print(\"ray deploy_cluster verified\")\n98\t    return 0\n99\t\n100\t\n101\tif __name__ == \"__main__\":\n102\t    raise SystemExit(main())\n103\t"}]},"parent_tool_use_id":null,"session_id":"9fc9f22f-1ad2-4f8c-8c0a-cb7f3b7bd390","uuid":"bc539003-e90f-40af-a883-9644aa939654","timestamp":"2026-06-23T21:17:00.918Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/ray/deploy_cluster/oracle/oracle.py","content":"#!/usr/bin/env python3\n\"\"\"Oracle for ray/deploy_cluster.\n\nVerifies the Ray head Service exposes the GCS port, the head and worker\ndeployments are ready, and the cluster reports the expected live node count.\n\"\"\"\nfrom __future__ import annotations\n\nimport os\nimport sys\nimport time\nfrom pathlib import Path\n\nsys.path.append(str(Path(__file__).resolve().parents[2]))\n\nfrom common.oracle_lib import (  # noqa: E402\n    deployment_ready_replicas,\n    ray_node_count_from_head,\n    service_ports,\n)\n\nNAMESPACE = \"ray\"\nHEAD = \"ray-head\"\nWORKER = \"ray-worker\"\n# Param-aware: a workflow can override worker_replicas (deploy a cluster with\n# 1/2/3/5 workers). Read the requested count from the env (default = the\n# standalone value 2) so the oracle verifies the size the workflow asked for.\nEXPECTED_WORKERS = int(os.environ.get(\"BENCH_PARAM_WORKER_REPLICAS\", \"2\") or \"2\")\n\nCONNECTIVITY_TOTAL_TIMEOUT_SEC = 60\nCONNECTIVITY_ATTEMPT_TIMEOUT_SEC = 12\n\n\ndef check_service() -> int:\n    \"\"\"Confirm the head Service exposes the GCS port 6379.\"\"\"\n    ports = service_ports(NAMESPACE, HEAD)\n    if 6379 not in ports:\n        print(f\"service/{HEAD} does not expose port 6379\")\n        return 1\n    print(f\"service/{HEAD} exposes port 6379\")\n    return 0\n\n\ndef check_head() -> int:\n    \"\"\"Confirm the head deployment has at least one ready replica.\"\"\"\n    ready = deployment_ready_replicas(NAMESPACE, HEAD)\n    if ready < 1:\n        print(f\"deployment/{HEAD} ready replicas {ready}, expected at least 1\")\n        return 1\n    print(f\"deployment/{HEAD} ready replicas {ready}\")\n    return 0\n\n\ndef check_workers() -> int:\n    \"\"\"Confirm the worker deployment has the expected ready replicas.\"\"\"\n    ready = deployment_ready_replicas(NAMESPACE, WORKER)\n    if ready < EXPECTED_WORKERS:\n        print(f\"deployment/{WORKER} ready replicas {ready}, expected at least {EXPECTED_WORKERS}\")\n        return 1\n    print(f\"deployment/{WORKER} ready replicas {ready}\")\n    return 0\n\n\ndef check_connectivity() -> int:\n    \"\"\"Confirm Ray reports at least 1 head + EXPECTED_WORKERS live nodes.\"\"\"\n    expected_nodes = 1 + EXPECTED_WORKERS\n    deadline = time.time() + CONNECTIVITY_TOTAL_TIMEOUT_SEC\n    last_count = 0\n    last_error = \"\"\n    while time.time() < deadline:\n        try:\n            node_count = ray_node_count_from_head(\n                NAMESPACE, HEAD, timeout_sec=CONNECTIVITY_ATTEMPT_TIMEOUT_SEC\n            )\n        except Exception as exc:  # noqa: BLE001\n            last_error = str(exc)\n            time.sleep(3)\n            continue\n        last_count = node_count\n        if node_count >= expected_nodes:\n            print(f\"ray reports {node_count} nodes\")\n            return 0\n        time.sleep(3)\n    if last_error:\n        print(f\"ray connectivity probe failed: {last_error}\")\n        return 1\n    print(f\"ray reports {last_count} nodes, expected at least {expected_nodes}\")\n    return 1\n\n\ndef main() -> int:\n    \"\"\"Run every deploy_cluster verification check in order.\"\"\"\n    for fn in (check_service, check_head, check_workers, check_connectivity):\n        rc = fn()\n        if rc != 0:\n            return rc\n    print(\"ray deploy_cluster verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n","numLines":103,"startLine":1,"totalLines":103}}}
