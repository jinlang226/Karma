{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BhVPvX9C1NPf77X4vUCvUY","type":"tool_result","content":"154\tdef ray_node_count_from_head(namespace: str, head_deployment: str, timeout_sec: float = 10.0) -> int:\n155\t    selector = deployment(namespace, head_deployment).get(\"spec\", {}).get(\"selector\", {}).get(\"matchLabels\", {})\n156\t    if not selector:\n157\t        raise RuntimeError(f\"deployment/{head_deployment} has no selector labels\")\n158\t    selector_text = \",\".join(f\"{key}={value}\" for key, value in selector.items())\n159\t    pod_items = (pods(namespace, selector_text).get(\"items\", []) or [])\n160\t    if not pod_items:\n161\t        raise RuntimeError(f\"deployment/{head_deployment} has no pods\")\n162\t    pod_name = str(pod_items[0].get(\"metadata\", {}).get(\"name\") or \"\").strip()\n163\t    if not pod_name:\n164\t        raise RuntimeError(f\"deployment/{head_deployment} pod is missing metadata.name\")\n165\t    # Pin the driver's node IP to the head pod's own IP (exported as MY_POD_IP by\n166\t    # the head manifest). Without this, ray.init(address='auto') auto-detects an\n167\t    # address that may not match any registered raylet on single-host clusters\n168\t    # (kind), failing with \"none of these match this node's IP\".\n169\t    script = (\n170\t        \"import os, ray; \"\n171\t        \"ray.init(address='auto', ignore_reinit_error=True, \"\n172\t        \"_node_ip_address=os.environ.get('MY_POD_IP') or None); \"\n173\t        \"print(sum(1 for node in ray.nodes() if node.get('Alive')))\"\n174\t    )\n175\t    # Keep this helper to a single bounded probe window. The caller should own\n176\t    # any larger retry budget so command-level timeouts remain easy to reason about.\n177\t    try:\n178\t        timeout_budget = float(timeout_sec)\n179\t    except (TypeError, ValueError):\n180\t        timeout_budget = 10.0\n181\t    if timeout_budget <= 0:\n182\t        timeout_budget = 10.0\n183\t    deadline = time.time() + timeout_budget\n184\t    last_error: str | None = None\n185\t    while True:\n186\t        proc = run(\n187\t            [\n188\t                \"kubectl\",\n189\t                \"-n\",\n190\t                namespace,\n191\t                \"exec\",\n192\t                pod_name,\n193\t                \"--\","}]},"parent_tool_use_id":null,"session_id":"9fc9f22f-1ad2-4f8c-8c0a-cb7f3b7bd390","uuid":"0f7221bb-853d-4cd6-adc4-53cf4e7622ca","timestamp":"2026-06-23T21:17:18.320Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/ray/common/oracle_lib.py","content":"def ray_node_count_from_head(namespace: str, head_deployment: str, timeout_sec: float = 10.0) -> int:\n    selector = deployment(namespace, head_deployment).get(\"spec\", {}).get(\"selector\", {}).get(\"matchLabels\", {})\n    if not selector:\n        raise RuntimeError(f\"deployment/{head_deployment} has no selector labels\")\n    selector_text = \",\".join(f\"{key}={value}\" for key, value in selector.items())\n    pod_items = (pods(namespace, selector_text).get(\"items\", []) or [])\n    if not pod_items:\n        raise RuntimeError(f\"deployment/{head_deployment} has no pods\")\n    pod_name = str(pod_items[0].get(\"metadata\", {}).get(\"name\") or \"\").strip()\n    if not pod_name:\n        raise RuntimeError(f\"deployment/{head_deployment} pod is missing metadata.name\")\n    # Pin the driver's node IP to the head pod's own IP (exported as MY_POD_IP by\n    # the head manifest). Without this, ray.init(address='auto') auto-detects an\n    # address that may not match any registered raylet on single-host clusters\n    # (kind), failing with \"none of these match this node's IP\".\n    script = (\n        \"import os, ray; \"\n        \"ray.init(address='auto', ignore_reinit_error=True, \"\n        \"_node_ip_address=os.environ.get('MY_POD_IP') or None); \"\n        \"print(sum(1 for node in ray.nodes() if node.get('Alive')))\"\n    )\n    # Keep this helper to a single bounded probe window. The caller should own\n    # any larger retry budget so command-level timeouts remain easy to reason about.\n    try:\n        timeout_budget = float(timeout_sec)\n    except (TypeError, ValueError):\n        timeout_budget = 10.0\n    if timeout_budget <= 0:\n        timeout_budget = 10.0\n    deadline = time.time() + timeout_budget\n    last_error: str | None = None\n    while True:\n        proc = run(\n            [\n                \"kubectl\",\n                \"-n\",\n                namespace,\n                \"exec\",\n                pod_name,\n                \"--\",","numLines":40,"startLine":154,"totalLines":279}}}
