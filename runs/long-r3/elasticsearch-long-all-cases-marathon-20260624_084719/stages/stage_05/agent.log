    description: \"Name of the Elasticsearch HTTP service\"\n  cluster_prefix:\n    default: \"es-cluster\"\n    description: \"StatefulSet/cluster name prefix for Elasticsearch node pods\"\n  curl_pod_name:\n    default: \"curl-test\"\n    description: \"Helper pod used to query Elasticsearch over HTTPS\"\n  elastic_password:\n    default: \"elasticpass\"\n    description: \"Password for the elastic user\"\n  elastic_username:\n    default: \"elastic\"\n    description: \"Superuser name used for authenticated cert checks\"\nnamespace_contract:\n  required_roles: []\n\nmetrics:\n  - time_to_first_mutation\n  - read_write_ratio\n  - blast_radius\n  - destructive_ops\n  - decoy_integrity\n  - residual_drift\n\npreconditionUnits:\n  - name: es_env_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n elasticsearch get pods 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n    apply:\n      - command: \"/bin/sh -c 'kubectl delete namespace elasticsearch --ignore-not-found=true --wait=false; kubectl wait --for=delete namespace/elasticsearch --timeout=400s || true'\"\n        timeout_sec: 460\n        sleep: 1\n      - command: \"kubectl create namespace elasticsearch\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n elasticsearch get pod openssl-toolbox >/dev/null 2>&1 || kubectl -n elasticsearch apply -f cases/elasticsearch/rotate-http-certs/resource/openssl-toolbox.yaml'\"\n        sleep: 1\n      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod openssl-toolbox --timeout=300s\"\n        sleep: 1\n      - command: |\n          /bin/sh -c '\n          set -e\n          TMP_DIR=$(mktemp -d)\n          kubectl -n elasticsearch exec openssl-toolbox -- /bin/sh -c '\\''\n          set -e\n          mkdir -p /tmp/certs\n          cat > /tmp/certs/openssl.cnf <<EOF\n          distinguished_name=req_distinguished_name\n          req_extensions=v3_req\n          prompt=no\n          [req_distinguished_name]\n          CN={{params.http_service_name}}\n          [v3_req]\n          keyUsage=critical,digitalSignature,keyEncipherment\n          extendedKeyUsage=serverAuth,clientAuth\n          subjectAltName=@alt_names\n          [alt_names]\n          DNS.1=localhost\n          DNS.2={{params.http_service_name}}\n          DNS.3={{params.http_service_name}}.elasticsearch\n          DNS.4={{params.http_service_name}}.elasticsearch.svc\n          DNS.5={{params.http_service_name}}.elasticsearch.svc.cluster.local\n          DNS.6={{params.cluster_prefix}}\n          DNS.7={{params.cluster_prefix}}.elasticsearch\n          DNS.8={{params.cluster_prefix}}.elasticsearch.svc\n          DNS.9={{params.cluster_prefix}}.elasticsearch.svc.cluster.local\n          DNS.10=es-cluster-0.{{params.cluster_prefix}}.elasticsearch.svc.cluster.local\n          DNS.11=es-cluster-1.{{params.cluster_prefix}}.elasticsearch.svc.cluster.local\n          DNS.12=es-cluster-2.{{params.cluster_prefix}}.elasticsearch.svc.cluster.local\n          EOF\n          openssl genrsa -out /tmp/certs/ca.key 2048\n          openssl req -x509 -new -nodes -key /tmp/certs/ca.key -sha256 -days 2 -subj \"/CN={{params.http_ca_configmap_name}}\" -out /tmp/certs/ca.crt\n          openssl genrsa -out /tmp/certs/tls.key 2048\n          openssl req -new -key /tmp/certs/tls.key -out /tmp/certs/tls.csr -config /tmp/certs/openssl.cnf\n          openssl x509 -req -in /tmp/certs/tls.csr -CA /tmp/certs/ca.crt -CAkey /tmp/certs/ca.key -CAcreateserial -out /tmp/certs/tls.crt -days 2 -extensions v3_req -extfile /tmp/certs/openssl.cnf\n          '\\''\n          kubectl -n elasticsearch cp openssl-toolbox:/tmp/certs \"${TMP_DIR}/certs\"\n          kubectl -n elasticsearch create secret generic {{params.tls_secret_name}} --from-file=tls.crt=\"${TMP_DIR}/certs/tls.crt\" --from-file=tls.key=\"${TMP_DIR}/certs/tls.key\" --from-file=ca.crt=\"${TMP_DIR}/certs/ca.crt\" --dry-run=client -o yaml | kubectl apply -f -\n          kubectl -n elasticsearch create configmap {{params.http_ca_configmap_name}} --from-file=ca.crt=\"${TMP_DIR}/certs/ca.crt\" --dry-run=client -o yaml | kubectl apply -f -\n          CA_FP=$(openssl x509 -noout -fingerprint -sha256 -in \"${TMP_DIR}/certs/ca.crt\" | cut -d= -f2)\n          LEAF_FP=$(openssl x509 -noout -fingerprint -sha256 -in \"${TMP_DIR}/certs/tls.crt\" | cut -d= -f2)\n          kubectl -n elasticsearch create configmap {{params.old_fingerprint_configmap_name}} --from-file=ca.crt=\"${TMP_DIR}/certs/ca.crt\" --from-literal=ca_fingerprint_sha256=\"${CA_FP}\" --from-literal=leaf_fingerprint_sha256=\"${LEAF_FP}\" --dry-run=client -o yaml | kubectl apply -f -\n          '\n        sleep: 1\n      - command: \"kubectl -n elasticsearch apply -f cases/elasticsearch/rotate-http-certs/resource/configmap.yaml\"\n        sleep: 1\n      - command: \"kubectl -n elasticsearch apply -f cases/elasticsearch/rotate-http-certs/resource/services.yaml\"\n        sleep: 1\n      - command: \"kubectl -n elasticsearch apply -f cases/elasticsearch/rotate-http-certs/resource/statefulset.yaml\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n elasticsearch get pod {{params.curl_pod_name}} >/dev/null 2>&1 || kubectl -n elasticsearch apply -f cases/elasticsearch/rotate-http-certs/resource/{{params.curl_pod_name}}.yaml'\"\n        sleep: 1\n      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod -l app={{params.cluster_prefix}} --timeout=600s\"\n        sleep: 1\n      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod {{params.curl_pod_name}} --timeout=300s\"\n        sleep: 1\n      - command: |\n          /bin/sh -c '\n          for i in $(seq 1 30); do\n            code=$(kubectl -n elasticsearch exec {{params.curl_pod_name}} -- curl -s --max-time 5 --cacert /etc/{{params.http_ca_configmap_name}}/ca.crt -u {{params.elastic_username}}:{{params.elastic_password}} -o /dev/null -w \"%{http_code}\" \"https://{{params.http_service_name}}.elasticsearch.svc:9200/_cluster/health?wait_for_status=yellow&timeout=5s\" 2>/dev/null || true)\n            if [ \"${code}\" = \"200\" ]; then exit 0; fi\n            sleep 2\n          done\n          exit 1\n          '\n        sleep: 1\n    verify:\n      - command: \"kubectl -n elasticsearch get pods 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n\n  - name: capture_http_cert_baseline\n    # Snapshot the cluster's CURRENT HTTP cert as the pre-rotation baseline the\n    # oracle compares the rotated cert against. es_env_ready creates es-http-old /\n    # es-http-ca, but its apply is SKIPPED when an ES cluster is inherited from a\n    # prior workflow stage (probe sees pods Running) -- leaving those ConfigMaps\n    # absent and the rotate-http-certs oracle unable to verify rotation. Capture\n    # them here additively from the live TLS secret when the baseline ConfigMap\n    # is missing. Workflow-agnostic and non-destructive: it only reads the cert\n    # and writes ConfigMaps, never mutating the cluster or the rotated secret. The\n    # fingerprint formatting matches the deploy-path capture so the oracle's\n    # old-vs-new comparison is identical on both paths.\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n elasticsearch get configmap {{params.old_fingerprint_configmap_name}}\"\n        timeout_sec: 10\n    apply:\n      - command: |\n          /bin/sh -c '\n          set -e\n          T=$(mktemp -d)\n          kubectl -n elasticsearch get secret {{params.tls_secret_name}} -o jsonpath=\"{.data.ca\\.crt}\" | base64 -d > \"$T/ca.crt\"\n          kubectl -n elasticsearch get secret {{params.tls_secret_name}} -o jsonpath=\"{.data.tls\\.crt}\" | base64 -d > \"$T/tls.crt\"\n          kubectl -n elasticsearch create configmap {{params.http_ca_configmap_name}} --from-file=ca.crt=\"$T/ca.crt\" --dry-run=client -o yaml | kubectl apply -f -\n          CA_FP=$(openssl x509 -noout -fingerprint -sha256 -in \"$T/ca.crt\" | cut -d= -f2)\n          LEAF_FP=$(openssl x509 -noout -fingerprint -sha256 -in \"$T/tls.crt\" | cut -d= -f2)\n          kubectl -n elasticsearch create configmap {{params.old_fingerprint_configmap_name}} --from-file=ca.crt=\"$T/ca.crt\" --from-literal=ca_fingerprint_sha256=\"$CA_FP\" --from-literal=leaf_fingerprint_sha256=\"$LEAF_FP\" --dry-run=client -o yaml | kubectl apply -f -\n          '\n        timeout_sec: 60\n        sleep: 1\n    verify:\n      - command: \"kubectl -n elasticsearch get configmap {{params.old_fingerprint_configmap_name}} -o jsonpath='{.data.ca_fingerprint_sha256}'\"\n        timeout_sec: 10\n\noracle:\n  verify:\n    commands:\n      - command: \"python3 cases/elasticsearch/rotate-http-certs/oracle/oracle.py\"\n        timeout_sec: 120\n","numLines":182,"startLine":1,"totalLines":182}}}
