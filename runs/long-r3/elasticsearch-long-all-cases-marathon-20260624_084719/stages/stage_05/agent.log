{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GsuJXZhMxXQM9Ln1JL3CXG","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport base64\n3\timport datetime\n4\timport os\n5\timport subprocess\n6\timport sys\n7\timport tempfile\n8\timport json\n9\t\n10\tNAMESPACE = \"elasticsearch\"\n11\tSECRET = \"es-http-tls\"\n12\tOLD_CM = \"es-http-old\"\n13\tCLIENT_CA_CM = \"es-http-ca\"\n14\tSERVICE = \"es-http\"\n15\tCURL_POD = \"curl-test\"\n16\tMIN_VALID_DAYS = 300\n17\tMAX_VALID_DAYS = 400\n18\t\n19\t\n20\tdef run(cmd):\n21\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n22\t\n23\t\n24\tdef get_secret_data(key, errors):\n25\t    json_key = key.replace(\".\", \"\\\\.\")\n26\t    cmd = [\n27\t        \"kubectl\",\n28\t        \"-n\",\n29\t        NAMESPACE,\n30\t        \"get\",\n31\t        \"secret\",\n32\t        SECRET,\n33\t        \"-o\",\n34\t        f\"jsonpath={{.data.{json_key}}}\",\n35\t    ]\n36\t    result = run(cmd)\n37\t    if result.returncode != 0:\n38\t        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n39\t        errors.append(f\"Failed to read secret {SECRET} {key}: {detail}\")\n40\t        return None\n41\t    raw = result.stdout.strip()\n42\t    if not raw:\n43\t        errors.append(f\"Secret {SECRET} missing key {key}\")\n44\t        return None\n45\t    try:\n46\t        return base64.b64decode(raw)\n47\t    except base64.binascii.Error:\n48\t        errors.append(f\"Secret {SECRET} key {key} is not valid base64\")\n49\t        return None\n50\t\n51\t\n52\tdef get_configmap_text(name, key, errors):\n53\t    json_key = key.replace(\".\", \"\\\\.\")\n54\t    cmd = [\n55\t        \"kubectl\",\n56\t        \"-n\",\n57\t        NAMESPACE,\n58\t        \"get\",\n59\t        \"configmap\",\n60\t        name,\n61\t        \"-o\",\n62\t        f\"jsonpath={{.data.{json_key}}}\",\n63\t    ]\n64\t    result = run(cmd)\n65\t    if result.returncode != 0:\n66\t        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n67\t        errors.append(f\"Failed to read configmap {name} {key}: {detail}\")\n68\t        return None\n69\t    return result.stdout.strip()\n70\t\n71\t\n72\tdef openssl_fingerprint(path, errors, label):\n73\t    result = run([\"openssl\", \"x509\", \"-noout\", \"-fingerprint\", \"-sha256\", \"-in\", path])\n74\t    if result.returncode != 0:\n75\t        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n76\t        errors.append(f\"Failed to read fingerprint for {label}: {detail}\")\n77\t        return None\n78\t    line = result.stdout.strip()\n79\t    if \"=\" not in line:\n80\t        errors.append(f\"Unexpected fingerprint output for {label}: {line}\")\n81\t        return None\n82\t    return line.split(\"=\", 1)[1].strip()\n83\t\n84\t\n85\tdef openssl_not_after(path, errors):\n86\t    result = run([\"openssl\", \"x509\", \"-noout\", \"-enddate\", \"-in\", path])\n87\t    if result.returncode != 0:\n88\t        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n89\t        errors.append(f\"Failed to read NotAfter from leaf cert: {detail}\")\n90\t        return None\n91\t    line = result.stdout.strip()\n92\t    if not line.startswith(\"notAfter=\"):\n93\t        errors.append(f\"Unexpected NotAfter output: {line}\")\n94\t        return None\n95\t    value = line.split(\"=\", 1)[1].strip()\n96\t    try:\n97\t        ts = datetime.datetime.strptime(value, \"%b %d %H:%M:%S %Y %Z\")\n98\t    except ValueError:\n99\t        errors.append(f\"Unable to parse NotAfter date: {value}\")\n100\t        return None\n101\t    return ts.replace(tzinfo=datetime.timezone.utc)\n102\t\n103\t\n104\tdef verify_cert(ca_path, cert_path):\n105\t    return run([\"openssl\", \"verify\", \"-CAfile\", ca_path, cert_path])\n106\t\n107\t\n108\t_ELASTIC_PW = None\n109\t\n110\t\n111\tdef _elastic_password():\n112\t    \"\"\"Live elastic-user password.\n113\t\n114\t    Reads the elastic-password secret (a prior rotate-elastic-password stage may\n115\t    have rotated it away from this case's default, so the env PERSISTS a new\n116\t    value), base64-decoded; falls back to the case default. Cached so the retry\n117\t    loop does not re-read the secret each attempt.\n118\t    \"\"\"\n119\t    global _ELASTIC_PW\n120\t    if _ELASTIC_PW is not None:\n121\t        return _ELASTIC_PW\n122\t    import base64\n123\t    r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", \"elastic-password\",\n124\t             \"-o\", \"jsonpath={.data.password}\"])\n125\t    pw = None\n126\t    if r.returncode == 0 and r.stdout.strip():\n127\t        try:\n128\t            pw = base64.b64decode(r.stdout.strip()).decode()\n129\t        except Exception:\n130\t            pw = None\n131\t    _ELASTIC_PW = pw or os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD\") or \"elasticpass\"\n132\t    return _ELASTIC_PW\n133\t\n134\t\n135\tdef _health_curl(scheme):\n136\t    \"\"\"Run the cluster-health curl over the given scheme.\n137\t\n138\t    https uses the rotated CA (--cacert); http (fallback for a cluster whose\n139\t    HTTP TLS a prior stage disabled) adds nothing. -k is a belt-and-suspenders\n140\t    in case the served leaf doesn't chain to the mounted CA path.\n141\t    \"\"\"\n142\t    # The client deadline (--max-time 20) must exceed the server-side\n143\t    # ``timeout`` in the path, otherwise curl aborts (exit 28) before ES can\n144\t    # answer. curl_health() retries to absorb transient flapping, so the server\n145\t    # wait stays short (5s).\n146\t    path = \"/_cluster/health?wait_for_status=yellow&timeout=5s\"\n147\t    cmd = [\n148\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", CURL_POD, \"--\",\n149\t        \"curl\", \"-s\", \"-S\", \"--max-time\", \"20\",\n150\t    ]\n151\t    if scheme == \"https\":\n152\t        cmd += [\"--cacert\", \"/etc/es-http-ca/ca.crt\", \"-k\"]\n153\t    cmd += [\"-u\", f\"elastic:{_elastic_password()}\",\n154\t            f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\"]\n155\t    return run(cmd)\n156\t\n157\t\n158\tdef _evaluate_health():\n159\t    \"\"\"Run one cluster-health snapshot; return the list of health errors.\"\"\"\n160\t    errs = []\n161\t    # The env PERSISTS across stages; the cluster's live scheme may differ from\n162\t    # this case's default (https for a cert-rotation task). Try https (with the\n163\t    # rotated CA) then fall back to http. Cert assertions above are unaffected.\n164\t    result = _health_curl(\"https\")\n165\t    if result.returncode != 0:\n166\t        result = _health_curl(\"http\")\n167\t    if result.returncode != 0:\n168\t        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n169\t        errs.append(f\"Cluster health check failed: {detail}\")\n170\t        return errs\n171\t    output = result.stdout.strip()\n172\t    if not output:\n173\t        errs.append(\"HTTPS health check returned empty response\")\n174\t        return errs\n175\t    try:\n176\t        data = json.loads(output)\n177\t    except json.JSONDecodeError:\n178\t        errs.append(\"HTTPS health check returned invalid JSON\")\n179\t        return errs\n180\t    status = data.get(\"status\")\n181\t    if status not in {\"yellow\", \"green\"}:\n182\t        errs.append(f\"Cluster health expected yellow/green, got {status}\")\n183\t    return errs\n184\t\n185\t\n186\tdef curl_health(errors):\n187\t    # A multi-node ES cluster can flap at the edge of readiness under load: it\n188\t    # briefly reports a non-green/yellow status during GC or shard recovery even\n189\t    # though it converges green. A single snapshot can catch that transient. So\n190\t    # verify the STABLE converged health: re-evaluate for up to ~75s and accept\n191\t    # the first clean snapshot. This does not loosen the green/yellow\n192\t    # requirement -- a genuinely degraded cluster fails every attempt. The cert\n193\t    # assertions above are deterministic and stay single-pass.\n194\t    import time\n195\t    deadline = time.monotonic() + 75\n196\t    health_errors = _evaluate_health()\n197\t    while health_errors and time.monotonic() < deadline:\n198\t        time.sleep(8)\n199\t        health_errors = _evaluate_health()\n200\t    errors.extend(health_errors)\n201\t\n202\t\n203\tdef main():\n204\t    errors = []\n205\t\n206\t    old_ca_fp = get_configmap_text(OLD_CM, \"ca_fingerprint_sha256\", errors)\n207\t    old_leaf_fp = get_configmap_text(OLD_CM, \"leaf_fingerprint_sha256\", errors)\n208\t    old_ca_pem = get_configmap_text(OLD_CM, \"ca.crt\", errors)\n209\t    client_ca_pem = get_configmap_text(CLIENT_CA_CM, \"ca.crt\", errors)\n210\t\n211\t    if errors:\n212\t        print(\"HTTP cert rotation verification failed:\", file=sys.stderr)\n213\t        for err in errors:\n214\t            print(f\"  - {err}\", file=sys.stderr)\n215\t        return 1\n216\t\n217\t    with tempfile.TemporaryDirectory() as tmpdir:\n218\t        ca_path = f\"{tmpdir}/ca.crt\"\n219\t        leaf_path = f\"{tmpdir}/tls.crt\"\n220\t        old_ca_path = f\"{tmpdir}/old-ca.crt\"\n221\t        client_ca_path = f\"{tmpdir}/client-ca.crt\"\n222\t\n223\t        new_ca = get_secret_data(\"ca.crt\", errors)\n224\t        new_leaf = get_secret_data(\"tls.crt\", errors)\n225\t\n226\t        if new_ca is not None:\n227\t            with open(ca_path, \"wb\") as f:\n228\t                f.write(new_ca)\n229\t        if new_leaf is not None:\n230\t            with open(leaf_path, \"wb\") as f:\n231\t                f.write(new_leaf)\n232\t        if old_ca_pem is not None:\n233\t            with open(old_ca_path, \"w\", encoding=\"utf-8\") as f:\n234\t                f.write(old_ca_pem)\n235\t        if client_ca_pem is not None:\n236\t            with open(client_ca_path, \"w\", encoding=\"utf-8\") as f:\n237\t                f.write(client_ca_pem)\n238\t\n239\t        if new_ca is None or new_leaf is None:\n240\t            errors.append(\"Missing TLS data from es-http-tls secret\")\n241\t        else:\n242\t            new_ca_fp = openssl_fingerprint(ca_path, errors, \"new CA\")\n243\t            new_leaf_fp = openssl_fingerprint(leaf_path, errors, \"new leaf\")\n244\t            if new_ca_fp and old_ca_fp and new_ca_fp == old_ca_fp:\n245\t                errors.append(\"CA fingerprint did not change\")\n246\t            if new_leaf_fp and old_leaf_fp and new_leaf_fp == old_leaf_fp:\n247\t                errors.append(\"Leaf fingerprint did not change\")\n248\t\n249\t            if new_ca_fp and client_ca_pem:\n250\t                client_fp = openssl_fingerprint(client_ca_path, errors, \"client CA\")\n251\t                if client_fp and client_fp != new_ca_fp:\n252\t                    errors.append(\"Client CA does not match new CA\")\n253\t\n254\t            not_after = openssl_not_after(leaf_path, errors)\n255\t            if not_after:\n256\t                now = datetime.datetime.now(datetime.timezone.utc)\n257\t                days_remaining = (not_after - now).days\n258\t                if days_remaining < MIN_VALID_DAYS or days_remaining > MAX_VALID_DAYS:\n259\t                    errors.append(\n260\t                        f\"Leaf validity {days_remaining} days out of expected range ({MIN_VALID_DAYS}-{MAX_VALID_DAYS})\"\n261\t                    )\n262\t\n263\t            if new_ca_fp:\n264\t                verify_new = verify_cert(ca_path, leaf_path)\n265\t                if verify_new.returncode != 0:\n266\t                    detail = verify_new.stderr.strip() or verify_new.stdout.strip()\n267\t                    errors.append(f\"Leaf does not verify with new CA: {detail}\")\n268\t\n269\t                verify_old = verify_cert(old_ca_path, leaf_path)\n270\t                if verify_old.returncode == 0:\n271\t                    errors.append(\"Leaf still verifies with old CA\")\n272\t\n273\t        curl_health(errors)\n274\t\n275\t    if errors:\n276\t        print(\"HTTP cert rotation verification failed:\", file=sys.stderr)\n277\t        for err in errors:\n278\t            print(f\"  - {err}\", file=sys.stderr)\n279\t        return 1\n280\t\n281\t    print(\"HTTP cert rotation verified\")\n282\t    return 0\n283\t\n284\t\n285\tif __name__ == \"__main__\":\n286\t    sys.exit(main())\n287\t"}]},"parent_tool_use_id":null,"session_id":"719200ff-7cd2-49d6-aba3-40f90c5cb2aa","uuid":"3001bf19-2f88-4a1f-b877-d5fab8c4266d","timestamp":"2026-06-24T09:40:40.661Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/elasticsearch/rotate-http-certs/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport base64\nimport datetime\nimport os\nimport subprocess\nimport sys\nimport tempfile\nimport json\n\nNAMESPACE = \"elasticsearch\"\nSECRET = \"es-http-tls\"\nOLD_CM = \"es-http-old\"\nCLIENT_CA_CM = \"es-http-ca\"\nSERVICE = \"es-http\"\nCURL_POD = \"curl-test\"\nMIN_VALID_DAYS = 300\nMAX_VALID_DAYS = 400\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef get_secret_data(key, errors):\n    json_key = key.replace(\".\", \"\\\\.\")\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"get\",\n        \"secret\",\n        SECRET,\n        \"-o\",\n        f\"jsonpath={{.data.{json_key}}}\",\n    ]\n    result = run(cmd)\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errors.append(f\"Failed to read secret {SECRET} {key}: {detail}\")\n        return None\n    raw = result.stdout.strip()\n    if not raw:\n        errors.append(f\"Secret {SECRET} missing key {key}\")\n        return None\n    try:\n        return base64.b64decode(raw)\n    except base64.binascii.Error:\n        errors.append(f\"Secret {SECRET} key {key} is not valid base64\")\n        return None\n\n\ndef get_configmap_text(name, key, errors):\n    json_key = key.replace(\".\", \"\\\\.\")\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"get\",\n        \"configmap\",\n        name,\n        \"-o\",\n        f\"jsonpath={{.data.{json_key}}}\",\n    ]\n    result = run(cmd)\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errors.append(f\"Failed to read configmap {name} {key}: {detail}\")\n        return None\n    return result.stdout.strip()\n\n\ndef openssl_fingerprint(path, errors, label):\n    result = run([\"openssl\", \"x509\", \"-noout\", \"-fingerprint\", \"-sha256\", \"-in\", path])\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errors.append(f\"Failed to read fingerprint for {label}: {detail}\")\n        return None\n    line = result.stdout.strip()\n    if \"=\" not in line:\n        errors.append(f\"Unexpected fingerprint output for {label}: {line}\")\n        return None\n    return line.split(\"=\", 1)[1].strip()\n\n\ndef openssl_not_after(path, errors):\n    result = run([\"openssl\", \"x509\", \"-noout\", \"-enddate\", \"-in\", path])\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errors.append(f\"Failed to read NotAfter from leaf cert: {detail}\")\n        return None\n    line = result.stdout.strip()\n    if not line.startswith(\"notAfter=\"):\n        errors.append(f\"Unexpected NotAfter output: {line}\")\n        return None\n    value = line.split(\"=\", 1)[1].strip()\n    try:\n        ts = datetime.datetime.strptime(value, \"%b %d %H:%M:%S %Y %Z\")\n    except ValueError:\n        errors.append(f\"Unable to parse NotAfter date: {value}\")\n        return None\n    return ts.replace(tzinfo=datetime.timezone.utc)\n\n\ndef verify_cert(ca_path, cert_path):\n    return run([\"openssl\", \"verify\", \"-CAfile\", ca_path, cert_path])\n\n\n_ELASTIC_PW = None\n\n\ndef _elastic_password():\n    \"\"\"Live elastic-user password.\n\n    Reads the elastic-password secret (a prior rotate-elastic-password stage may\n    have rotated it away from this case's default, so the env PERSISTS a new\n    value), base64-decoded; falls back to the case default. Cached so the retry\n    loop does not re-read the secret each attempt.\n    \"\"\"\n    global _ELASTIC_PW\n    if _ELASTIC_PW is not None:\n        return _ELASTIC_PW\n    import base64\n    r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", \"elastic-password\",\n             \"-o\", \"jsonpath={.data.password}\"])\n    pw = None\n    if r.returncode == 0 and r.stdout.strip():\n        try:\n            pw = base64.b64decode(r.stdout.strip()).decode()\n        except Exception:\n            pw = None\n    _ELASTIC_PW = pw or os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD\") or \"elasticpass\"\n    return _ELASTIC_PW\n\n\ndef _health_curl(scheme):\n    \"\"\"Run the cluster-health curl over the given scheme.\n\n    https uses the rotated CA (--cacert); http (fallback for a cluster whose\n    HTTP TLS a prior stage disabled) adds nothing. -k is a belt-and-suspenders\n    in case the served leaf doesn't chain to the mounted CA path.\n    \"\"\"\n    # The client deadline (--max-time 20) must exceed the server-side\n    # ``timeout`` in the path, otherwise curl aborts (exit 28) before ES can\n    # answer. curl_health() retries to absorb transient flapping, so the server\n    # wait stays short (5s).\n    path = \"/_cluster/health?wait_for_status=yellow&timeout=5s\"\n    cmd = [\n        \"kubectl\", \"-n\", NAMESPACE, \"exec\", CURL_POD, \"--\",\n        \"curl\", \"-s\", \"-S\", \"--max-time\", \"20\",\n    ]\n    if scheme == \"https\":\n        cmd += [\"--cacert\", \"/etc/es-http-ca/ca.crt\", \"-k\"]\n    cmd += [\"-u\", f\"elastic:{_elastic_password()}\",\n            f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\"]\n    return run(cmd)\n\n\ndef _evaluate_health():\n    \"\"\"Run one cluster-health snapshot; return the list of health errors.\"\"\"\n    errs = []\n    # The env PERSISTS across stages; the cluster's live scheme may differ from\n    # this case's default (https for a cert-rotation task). Try https (with the\n    # rotated CA) then fall back to http. Cert assertions above are unaffected.\n    result = _health_curl(\"https\")\n    if result.returncode != 0:\n        result = _health_curl(\"http\")\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errs.append(f\"Cluster health check failed: {detail}\")\n        return errs\n    output = result.stdout.strip()\n    if not output:\n        errs.append(\"HTTPS health check returned empty response\")\n        return errs\n    try:\n        data = json.loads(output)\n    except json.JSONDecodeError:\n        errs.append(\"HTTPS health check returned invalid JSON\")\n        return errs\n    status = data.get(\"status\")\n    if status not in {\"yellow\", \"green\"}:\n        errs.append(f\"Cluster health expected yellow/green, got {status}\")\n    return errs\n\n\ndef curl_health(errors):\n    # A multi-node ES cluster can flap at the edge of readiness under load: it\n    # briefly reports a non-green/yellow status during GC or shard recovery even\n    # though it converges green. A single snapshot can catch that transient. So\n    # verify the STABLE converged health: re-evaluate for up to ~75s and accept\n    # the first clean snapshot. This does not loosen the green/yellow\n    # requirement -- a genuinely degraded cluster fails every attempt. The cert\n    # assertions above are deterministic and stay single-pass.\n    import time\n    deadline = time.monotonic() + 75\n    health_errors = _evaluate_health()\n    while health_errors and time.monotonic() < deadline:\n        time.sleep(8)\n        health_errors = _evaluate_health()\n    errors.extend(health_errors)\n\n\ndef main():\n    errors = []\n\n    old_ca_fp = get_configmap_text(OLD_CM, \"ca_fingerprint_sha256\", errors)\n    old_leaf_fp = get_configmap_text(OLD_CM, \"leaf_fingerprint_sha256\", errors)\n    old_ca_pem = get_configmap_text(OLD_CM, \"ca.crt\", errors)\n    client_ca_pem = get_configmap_text(CLIENT_CA_CM, \"ca.crt\", errors)\n\n    if errors:\n        print(\"HTTP cert rotation verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    with tempfile.TemporaryDirectory() as tmpdir:\n        ca_path = f\"{tmpdir}/ca.crt\"\n        leaf_path = f\"{tmpdir}/tls.crt\"\n        old_ca_path = f\"{tmpdir}/old-ca.crt\"\n        client_ca_path = f\"{tmpdir}/client-ca.crt\"\n\n        new_ca = get_secret_data(\"ca.crt\", errors)\n        new_leaf = get_secret_data(\"tls.crt\", errors)\n\n        if new_ca is not None:\n            with open(ca_path, \"wb\") as f:\n                f.write(new_ca)\n        if new_leaf is not None:\n            with open(leaf_path, \"wb\") as f:\n                f.write(new_leaf)\n        if old_ca_pem is not None:\n            with open(old_ca_path, \"w\", encoding=\"utf-8\") as f:\n                f.write(old_ca_pem)\n        if client_ca_pem is not None:\n            with open(client_ca_path, \"w\", encoding=\"utf-8\") as f:\n                f.write(client_ca_pem)\n\n        if new_ca is None or new_leaf is None:\n            errors.append(\"Missing TLS data from es-http-tls secret\")\n        else:\n            new_ca_fp = openssl_fingerprint(ca_path, errors, \"new CA\")\n            new_leaf_fp = openssl_fingerprint(leaf_path, errors, \"new leaf\")\n            if new_ca_fp and old_ca_fp and new_ca_fp == old_ca_fp:\n                errors.append(\"CA fingerprint did not change\")\n            if new_leaf_fp and old_leaf_fp and new_leaf_fp == old_leaf_fp:\n                errors.append(\"Leaf fingerprint did not change\")\n\n            if new_ca_fp and client_ca_pem:\n                client_fp = openssl_fingerprint(client_ca_path, errors, \"client CA\")\n                if client_fp and client_fp != new_ca_fp:\n                    errors.append(\"Client CA does not match new CA\")\n\n            not_after = openssl_not_after(leaf_path, errors)\n            if not_after:\n                now = datetime.datetime.now(datetime.timezone.utc)\n                days_remaining = (not_after - now).days\n                if days_remaining < MIN_VALID_DAYS or days_remaining > MAX_VALID_DAYS:\n                    errors.append(\n                        f\"Leaf validity {days_remaining} days out of expected range ({MIN_VALID_DAYS}-{MAX_VALID_DAYS})\"\n                    )\n\n            if new_ca_fp:\n                verify_new = verify_cert(ca_path, leaf_path)\n                if verify_new.returncode != 0:\n                    detail = verify_new.stderr.strip() or verify_new.stdout.strip()\n                    errors.append(f\"Leaf does not verify with new CA: {detail}\")\n\n                verify_old = verify_cert(old_ca_path, leaf_path)\n                if verify_old.returncode == 0:\n                    errors.append(\"Leaf still verifies with old CA\")\n\n        curl_health(errors)\n\n    if errors:\n        print(\"HTTP cert rotation verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    print(\"HTTP cert rotation verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":287,"startLine":1,"totalLines":287}}}
