{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013hcBJtUdBzrX4HRGodfwqv","type":"tool_result","content":"===STS===\napiVersion: apps/v1\nkind: StatefulSet\nmetadata:\n  name: es-cluster\n  namespace: elasticsearch\nspec:\n  serviceName: es-cluster\n  podManagementPolicy: Parallel\n  replicas: 3\n  selector:\n    matchLabels:\n      app: es-cluster\n  template:\n    metadata:\n      labels:\n        app: es-cluster\n      annotations:\n        sidecar-config-hash: metricbeat-v1-filebeat-v1\n    spec:\n      containers:\n        - name: elasticsearch\n          image: docker.elastic.co/elasticsearch/elasticsearch:7.17.9\n          env:\n            - name: POD_NAME\n              valueFrom:\n                fieldRef:\n                  fieldPath: metadata.name\n            - name: ES_JAVA_OPTS\n              value: \"-Xms512m -Xmx512m\"\n            - name: ELASTIC_PASSWORD\n              valueFrom:\n                secretKeyRef:\n                  name: elastic-password\n                  key: password\n          ports:\n            - containerPort: 9200\n              name: http\n            - containerPort: 9300\n              name: transport\n          readinessProbe:\n            tcpSocket:\n              port: 9200\n            initialDelaySeconds: 10\n            periodSeconds: 5\n            timeoutSeconds: 1\n            failureThreshold: 6\n          volumeMounts:\n            - name: es-config\n              mountPath: /usr/share/elasticsearch/config/elasticsearch.yml\n              subPath: elasticsearch.yml\n            - name: data\n              mountPath: /usr/share/elasticsearch/data\n            - name: http-certs\n              mountPath: /usr/share/elasticsearch/config/http-certs\n              readOnly: true\n            - name: es-logs\n              mountPath: /var/log/es\n          resources:\n            requests:\n              cpu: \"500m\"\n              memory: \"1Gi\"\n            limits:\n              cpu: \"1\