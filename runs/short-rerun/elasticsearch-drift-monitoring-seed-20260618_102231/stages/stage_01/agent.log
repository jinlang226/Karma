elasticsearch\n  ports:\n    - name: transport\n      port: 9300\n---\napiVersion: v1\nkind: Service\nmetadata:\n  name: es-http\n  namespace: elasticsearch\nspec:\n  selector:\n    app: elasticsearch\n  ports:\n    - name: https\n      port: 9200\n      targetPort: 9200\n---\napiVersion: policy/v1\nkind: PodDisruptionBudget\nmetadata:\n  name: es-pdb\n  namespace: elasticsearch\nspec:\n  minAvailable: 2\n  selector:\n    matchLabels:\n      app: elasticsearch\n---\napiVersion: apps/v1\nkind: StatefulSet\nmetadata:\n  name: es\n  namespace: elasticsearch\nspec:\n  serviceName: es-discovery\n  replicas: 3\n  selector:\n    matchLabels:\n      app: elasticsearch\n  template:\n    metadata:\n      labels:\n        app: elasticsearch\n    spec:\n      affinity:\n        podAntiAffinity:\n          preferredDuringSchedulingIgnoredDuringExecution:\n            - weight: 100\n              podAffinityTerm:\n                labelSelector:\n                  matchLabels:\n                    app: elasticsearch\n                topologyKey: kubernetes.io/hostname\n      initContainers:\n        - name: sysctl\n          image: docker.elastic.co/elasticsearch/elasticsearch:8.11.1\n          securityContext:\n            privileged: true\n            runAsUser: 0\n          command: [\"sh\", \"-c\", \"sysctl -w vm.max_map_count=262144 || true\"]\n      containers:\n        - name: elasticsearch\n          image: docker.elastic.co/elasticsearch/elasticsearch:8.11.1\n          ports:\n            - containerPort: 9200\n              name: https\n            - containerPort: 9300\n              name: transport\n          env:\n            - name: node.name\n              valueFrom:\n                fieldRef:\n                  fieldPath: metadata.name\n            - name: ES_JAVA_OPTS\n              value: \"-Xms512m -Xmx512m\"\n            - name: ELASTIC_PASSWORD\n              valueFrom:\n                secretKeyRef:\n                  name: elastic-password\n                 