ES was still booting."}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":431,"cache_read_input_tokens":58001,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":431},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"bbb150f2-80b4-4065-a6e1-66bacfe320e3","uuid":"6b5127b7-f04b-4ec3-b10a-2d86fe9b89b4","request_id":"req_011CcAfBbmEQfne1My1hZ8Np"}
