{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KVRLJ3ChFQK7Wbtd4m2rsw","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport base64\n3\timport json\n4\timport os\n5\timport re\n6\timport shlex\n7\timport subprocess\n8\timport sys\n9\t\n10\t\n11\tNAMESPACE = \"elasticsearch\"\n12\tSERVICE = \"es-http\"\n13\t# Hint for the Elasticsearch pod app label. Used as an override when it matches a\n14\t# live StatefulSet's selector; otherwise the real selector label is detected\n15\t# live from the cluster. The env PERSISTS across stages, so a workflow's\n16\t# inherited ES cluster may label its pods differently than this case's standalone\n17\t# default of 'es-cluster'.\n18\tCLUSTER_PREFIX_HINT = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"es-cluster\")\n19\tDEFAULT_SCHEME = \"http\"\n20\t_SCHEME = None\n21\t\n22\t\n23\tdef run(cmd):\n24\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n25\t\n26\t\n27\t_ELASTIC_PW = None\n28\t\n29\t\n30\tdef _elastic_password():\n31\t    \"\"\"Live elastic-user password.\n32\t\n33\t    Reads the elastic-password secret, base64-decoded. The env PERSISTS across\n34\t    stages, so a prior rotate-elastic-password stage may have rotated the\n35\t    password away from this case's standalone default — the running curl-test\n36\t    pod's $ES_PASS env was captured at pod creation and goes stale after such a\n37\t    rotation (env from a secret does not live-update), which is why the queries\n38\t    must read the secret fresh here. Falls back to the case default. Cached so\n39\t    the retry loop does not re-read the secret each attempt.\n40\t    \"\"\"\n41\t    global _ELASTIC_PW\n42\t    if _ELASTIC_PW is not None:\n43\t        return _ELASTIC_PW\n44\t    r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", \"elastic-password\",\n45\t             \"-o\", \"jsonpath={.data.password}\"])\n46\t    pw = None\n47\t    if r.returncode == 0 and r.stdout.strip():\n48\t        try:\n49\t            pw = base64.b64decode(r.stdout.strip()).decode()\n50\t        except Exception:\n51\t            pw = None\n52\t    _ELASTIC_PW = pw or os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD\") or \"elasticpass\"\n53\t    return _ELASTIC_PW\n54\t\n55\t\n56\tdef _auth_flag():\n57\t    \"\"\"`-u elastic:<live-pw>`, shell-quoted for the curl-test pod's /bin/sh.\"\"\"\n58\t    return \"-u \" + shlex.quote(\"elastic:\" + _elastic_password())\n59\t\n60\t\n61\t_APP_LABEL = None\n62\t\n63\t\n64\tdef resolve_app_label():\n65\t    \"\"\"Resolve the 'app=<value>' selector for the live ES pods.\n66\t\n67\t    Priority: the BENCH_PARAM_CLUSTER_PREFIX hint when some live StatefulSet\n68\t    actually selects on app=<hint> (explicit override wins) -> the app label of\n69\t    the namespace's Elasticsearch StatefulSet detected live -> the hint.\n70\t    Workflow-agnostic: adapts to an inherited cluster labelled e.g.\n71\t    app=elasticsearch instead of app=es-cluster.\n72\t    \"\"\"\n73\t    global _APP_LABEL\n74\t    if _APP_LABEL is not None:\n75\t        return _APP_LABEL\n76\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n77\t    labels = []\n78\t    if res.returncode == 0:\n79\t        try:\n80\t            for sts in json.loads(res.stdout).get(\"items\", []):\n81\t                spec = sts.get(\"spec\", {})\n82\t                containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n83\t                if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n84\t                    continue\n85\t                app = (spec.get(\"selector\", {}).get(\"matchLabels\", {}) or {}).get(\"app\")\n86\t                ts = sts.get(\"metadata\", {}).get(\"creationTimestamp\", \"\")\n87\t                if app:\n88\t                    labels.append((app, ts))\n89\t        except (json.JSONDecodeError, AttributeError):\n90\t            pass\n91\t    if any(app == CLUSTER_PREFIX_HINT for app, _ in labels):\n92\t        _APP_LABEL = f\"app={CLUSTER_PREFIX_HINT}\"\n93\t        return _APP_LABEL\n94\t    if labels:\n95\t        labels.sort(key=lambda x: (x[1] or \"\"))\n96\t        _APP_LABEL = f\"app={labels[0][0]}\"\n97\t        return _APP_LABEL\n98\t    _APP_LABEL = f\"app={CLUSTER_PREFIX_HINT}\"\n99\t    return _APP_LABEL\n100\t\n101\t\n102\tAPP_LABEL = resolve_app_label()\n103\t\n104\t\n105\tdef _list_es_statefulset_replicas():\n106\t    \"\"\"Return {sts_name: spec.replicas} for the namespace's Elasticsearch\n107\t    StatefulSets (those whose pod template runs an Elasticsearch image).\"\"\"\n108\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n109\t    if res.returncode != 0:\n110\t        return {}\n111\t    try:\n112\t        items = json.loads(res.stdout).get(\"items\", [])\n113\t    except (json.JSONDecodeError, AttributeError):\n114\t        return {}\n115\t    out = {}\n116\t    for sts in items:\n117\t        spec = sts.get(\"spec\", {})\n118\t        containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n119\t        if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n120\t            continue\n121\t        name = sts.get(\"metadata\", {}).get(\"name\")\n122\t        replicas = spec.get(\"replicas\")\n123\t        if name and isinstance(replicas, int):\n124\t            out[name] = replicas\n125\t    return out\n126\t\n127\t\n128\tdef _sts_name_for_node(node_name):\n129\t    \"\"\"Map a live ES node name to its backing StatefulSet name.\n130\t\n131\t    An ES node name equals its pod name, which for a StatefulSet pod is\n132\t    ``<statefulset-name>-<ordinal>`` (e.g. ``es-cluster-0`` -> ``es-cluster``,\n133\t    ``es-data-1`` -> ``es-data``). Strip the trailing ``-<digits>`` ordinal.\n134\t    Returns the node name unchanged if it carries no ordinal suffix.\n135\t    \"\"\"\n136\t    if not node_name:\n137\t        return node_name\n138\t    return re.sub(r\"-\\d+$\", \"\", node_name)\n139\t\n140\t\n141\tdef _live_sts_names(node_names):\n142\t    \"\"\"Set of StatefulSet names actually backing the live cluster nodes.\n143\t\n144\t    Derived by stripping each live node name's ordinal. This excludes\n145\t    accumulated/stale/other ES StatefulSets in the (persisted) namespace that\n146\t    back no node in the queried cluster.\n147\t    \"\"\"\n148\t    return {_sts_name_for_node(n) for n in node_names if n}\n149\t\n150\t\n151\tdef _resolve_expected_nodes(node_names, default=3):\n152\t    \"\"\"Expected node count to enforce, derived from the LIVE cluster.\n153\t\n154\t    The expected total is the DESIRED topology of ONLY the StatefulSets that\n155\t    actually back the live cluster (the nodes returned by ``_cat/nodes``): the\n156\t    sum of spec.replicas over just those StatefulSets. The namespace PERSISTS\n157\t    across workflow stages and accumulates multiple ES clusters, so summing\n158\t    replicas across *every* ES StatefulSet overcounts versus the single cluster\n159\t    the oracle queries. Restricting to the live cluster's StatefulSets fixes that.\n160\t\n161\t    Using DESIRED spec.replicas (not the live count) keeps the check strict: a\n162\t    node that FAILED to join leaves its StatefulSet \"live\" (siblings are up) but\n163\t    absent from ``_cat/nodes``, so EXPECTED stays above the actual count -- no\n164\t    masking. The LIVE cluster is derived FIRST; the param is a FALLBACK used only\n165\t    when no live StatefulSets resolve (e.g. _cat/nodes failed or returned empty).\n166\t    \"\"\"\n167\t    # Derive from the LIVE cluster FIRST (workflow-agnostic + composition-aware):\n168\t    # sum spec.replicas over the active ES StatefulSets -- the base cluster PLUS\n169\t    # any nodeset a PRIOR stage added to the same cluster (e.g. an inherited\n170\t    # transform nodeset). A static EXPECTED_NODES param encodes a standalone\n171\t    # baseline that wrongly ignores such inherited nodesets, so it is demoted to a\n172\t    # FALLBACK below, used only when the live cluster cannot be resolved.\n173\t    # Robust count: sum spec.replicas over ES StatefulSets that are actually\n174\t    # present (status.replicas > 0). Counts the base cluster + any scaled-up\n175\t    # nodeset WITHOUT the fragile node.name -> StatefulSet string mapping (which\n176\t    # breaks when a nodeset's node.name differs from its pod name). A torn-down\n177\t    # prior cluster's StatefulSet has readyReplicas 0 and is excluded. Still\n178\t    # strict: a node that failed to join leaves its STS ready>0 but short, so the\n179\t    # spec-replica sum exceeds the live node count and the check still fails.\n180\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n181\t    if res.returncode == 0:\n182\t        try:\n183\t            items = json.loads(res.stdout).get(\"items\", [])\n184\t        except Exception:\n185\t            items = []\n186\t        desired = 0\n187\t        for sts in items:\n188\t            spec = sts.get(\"spec\", {}) or {}\n189\t            containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", []) or []\n190\t            if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n191\t                continue\n192\t            replicas = spec.get(\"replicas\")\n193\t            # Use status.replicas (pods that EXIST), not readyReplicas: a\n194\t            # scaled-up nodeset whose pods joined the cluster but lack a passing\n195\t            # STS readiness probe has readyReplicas 0 yet is genuinely live.\n196\t            # Count an ES StatefulSet's DESIRED replicas when it is an active part\n197\t            # of the cluster: spec.replicas > 0 and not being torn down. Gating on\n198\t            # status.replicas undercounts a freshly scaled-up nodeset whose status\n199\t            # lags -- its pods have joined the cluster but status.replicas is still\n200\t            # 0 -- which wrongly made EXPECTED < the live node count.\n201\t            being_deleted = (sts.get(\"metadata\", {}) or {}).get(\"deletionTimestamp\") is not None\n202\t            if isinstance(replicas, int) and replicas > 0 and not being_deleted:\n203\t                desired += replicas\n204\t        if desired > 0:\n205\t            return desired\n206\t\n207\t    # Fallbacks (live cluster unresolvable): explicit param, then the default.\n208\t    for key in (\"BENCH_PARAM_EXPECTED_NODES\", \"BENCH_PARAM_EXPECTED_NODE_COUNT\"):\n209\t        val = os.environ.get(key)\n210\t        if val is not None and str(val).strip():\n211\t            try:\n212\t                return int(val)\n213\t            except ValueError:\n214\t                pass\n215\t    return default\n216\t\n217\t\n218\tdef _probe_scheme(scheme):\n219\t    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\n220\t\n221\t    Authenticates with the same live elastic password the real queries use; a\n222\t    401 still proves the scheme is live, so any HTTP status code counts.\n223\t    \"\"\"\n224\t    result = run([\n225\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\", \"/bin/sh\", \"-c\",\n226\t        (\"curl -s -S -k -o /dev/null -w '%{http_code}' --max-time 5 \"\n227\t         f\"{_auth_flag()} \"\n228\t         f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200/\"),\n229\t    ])\n230\t    code = (result.stdout or \"\").strip().strip(\"'\")\n231\t    return result.returncode == 0 and code.isdigit() and code != \"000\"\n232\t\n233\t\n234\tdef detect_scheme():\n235\t    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n236\t    global _SCHEME\n237\t    if _SCHEME is not None:\n238\t        return _SCHEME\n239\t    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n240\t        if _probe_scheme(scheme):\n241\t            _SCHEME = scheme\n242\t            return _SCHEME\n243\t    _SCHEME = DEFAULT_SCHEME\n244\t    return _SCHEME\n245\t\n246\t\n247\tdef curl(path, errors):\n248\t    scheme = detect_scheme()\n249\t    cmd = [\n250\t        \"kubectl\",\n251\t        \"-n\",\n252\t        NAMESPACE,\n253\t        \"exec\",\n254\t        \"curl-test\",\n255\t        \"--\",\n256\t        \"/bin/sh\",\n257\t        \"-c\",\n258\t        # The client deadline (--max-time 20) must exceed any server-side\n259\t        # ``wait_for`` in `path`, otherwise curl aborts (exit 28) before ES can\n260\t        # answer. The retry loop in main() does the real waiting, so each call's\n261\t        # server wait stays short (10s).\n262\t        (\n263\t            f\"curl -s -S -k --max-time 20 {_auth_flag()} \"\n264\t            f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\"\n265\t        ),\n266\t    ]\n267\t\n268\t    result = run(cmd)\n269\t    if result.returncode != 0:\n270\t        stderr = result.stderr.strip()\n271\t        stdout = result.stdout.strip()\n272\t        detail = stderr or stdout or f\"command terminated with exit code {result.returncode}\"\n273\t        errors.append(f\"Failed to query {path}: {detail}\")\n274\t        return None\n275\t    output = result.stdout.strip()\n276\t    if not output:\n277\t        errors.append(f\"Empty response for {path}\")\n278\t        return None\n279\t    try:\n280\t        return json.loads(output)\n281\t    except json.JSONDecodeError:\n282\t        errors.append(f\"Failed to parse JSON from {path}\")\n283\t        return None\n284\t\n285\t\n286\tdef evaluate():\n287\t    \"\"\"Run one full snapshot of the transport-CA checks; return the errors.\"\"\"\n288\t    errors = []\n289\t\n290\t    cm_result = run(\n291\t        [\n292\t            \"kubectl\",\n293\t            \"-n\",\n294\t            NAMESPACE,\n295\t            \"get\",\n296\t            \"configmap\",\n297\t            \"es-transport-ca-bundle\",\n298\t            \"-o\",\n299\t            \"json\",\n300\t        ]\n301\t    )\n302\t    if cm_result.returncode != 0:\n303\t        errors.append(\n304\t            f\"Failed to read es-transport-ca-bundle ConfigMap: {cm_result.stderr.strip()}\"\n305\t        )\n306\t    else:\n307\t        try:\n308\t            cm = json.loads(cm_result.stdout)\n309\t        except json.JSONDecodeError:\n310\t            errors.append(\"Failed to parse es-transport-ca-bundle ConfigMap JSON\")\n311\t            cm = {}\n312\t        bundle = cm.get(\"data\", {}).get(\"ca.crt\", \"\")\n313\t        cert_count = bundle.count(\"BEGIN CERTIFICATE\")\n314\t        if cert_count < 2:\n315\t            errors.append(\n316\t                f\"Transport CA bundle should contain 2 certs, found {cert_count}\"\n317\t            )\n318\t\n319\t    # Resolve the live cluster's node list FIRST: the expected node count is\n320\t    # derived from only the StatefulSets that actually back these live nodes\n321\t    # (the persisted namespace accumulates several ES clusters across stages, so\n322\t    # summing every ES StatefulSet's replicas overcounts the queried cluster).\n323\t    nodes = curl(\"/_cat/nodes?format=json\", errors)\n324\t    node_names = []\n325\t    if isinstance(nodes, list):\n326\t        node_names = [n.get(\"name\") for n in nodes if n.get(\"name\")]\n327\t    expected_nodes = _resolve_expected_nodes(node_names, default=3)\n328\t\n329\t    health = curl(\n330\t        f\"/_cluster/health?wait_for_status=yellow&wait_for_nodes={expected_nodes}&timeout=10s\",\n331\t        errors,\n332\t    )\n333\t    if isinstance(health, dict):\n334\t        status = health.get(\"status\")\n335\t        if status not in {\"yellow\", \"green\"}:\n336\t            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n337\t        if health.get(\"number_of_nodes\") != expected_nodes:\n338\t            errors.append(\n339\t                f\"Expected {expected_nodes} nodes, got {health.get('number_of_nodes')}\"\n340\t            )\n341\t\n342\t    if isinstance(nodes, list):\n343\t        if len(node_names) != expected_nodes:\n344\t            errors.append(f\"Expected {expected_nodes} nodes in _cat/nodes, got {len(node_names)}\")\n345\t\n346\t    return errors\n347\t\n348\t\n349\tdef main():\n350\t    # A multi-node ES cluster can flap at the edge of readiness under load: a\n351\t    # node briefly fails its HTTP readiness probe / drops from the cluster during\n352\t    # GC or shard recovery even though it is stably green. A single snapshot can\n353\t    # catch that transient and report a false node-count miss. So verify the\n354\t    # STABLE converged state: re-evaluate for up to ~75s and pass on the first\n355\t    # clean snapshot. This does not loosen the N-node/green/CA-bundle\n356\t    # requirements -- a genuinely degraded cluster fails every attempt.\n357\t    import time\n358\t    deadline = time.monotonic() + 75\n359\t    errors = evaluate()\n360\t    while errors and time.monotonic() < deadline:\n361\t        time.sleep(8)\n362\t        errors = evaluate()\n363\t\n364\t    if errors:\n365\t        print(\"Transport CA trust verification failed:\", file=sys.stderr)\n366\t        for err in errors:\n367\t            print(f\"  - {err}\", file=sys.stderr)\n368\t        return 1\n369\t\n370\t    print(\"Transport CA trust verified\")\n371\t    return 0\n372\t\n373\t\n374\tif __name__ == \"__main__\":\n375\t    sys.exit(main())\n376\t"}]},"parent_tool_use_id":null,"session_id":"e4bcaeac-9f7e-422f-8314-aa11f386f54d","uuid":"ed2bb3ca-afb5-4325-84c7-fcfea1e9d171","timestamp":"2026-06-18T11:33:04.738Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/elasticsearch/transport-additional-ca-trust/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport base64\nimport json\nimport os\nimport re\nimport shlex\nimport subprocess\nimport sys\n\n\nNAMESPACE = \"elasticsearch\"\nSERVICE = \"es-http\"\n# Hint for the Elasticsearch pod app label. Used as an override when it matches a\n# live StatefulSet's selector; otherwise the real selector label is detected\n# live from the cluster. The env PERSISTS across stages, so a workflow's\n# inherited ES cluster may label its pods differently than this case's standalone\n# default of 'es-cluster'.\nCLUSTER_PREFIX_HINT = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"es-cluster\")\nDEFAULT_SCHEME = \"http\"\n_SCHEME = None\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\n_ELASTIC_PW = None\n\n\ndef _elastic_password():\n    \"\"\"Live elastic-user password.\n\n    Reads the elastic-password secret, base64-decoded. The env PERSISTS across\n    stages, so a prior rotate-elastic-password stage may have rotated the\n    password away from this case's standalone default — the running curl-test\n    pod's $ES_PASS env was captured at pod creation and goes stale after such a\n    rotation (env from a secret does not live-update), which is why the queries\n    must read the secret fresh here. Falls back to the case default. Cached so\n    the retry loop does not re-read the secret each attempt.\n    \"\"\"\n    global _ELASTIC_PW\n    if _ELASTIC_PW is not None:\n        return _ELASTIC_PW\n    r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", \"elastic-password\",\n             \"-o\", \"jsonpath={.data.password}\"])\n    pw = None\n    if r.returncode == 0 and r.stdout.strip():\n        try:\n            pw = base64.b64decode(r.stdout.strip()).decode()\n        except Exception:\n            pw = None\n    _ELASTIC_PW = pw or os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD\") or \"elasticpass\"\n    return _ELASTIC_PW\n\n\ndef _auth_flag():\n    \"\"\"`-u elastic:<live-pw>`, shell-quoted for the curl-test pod's /bin/sh.\"\"\"\n    return \"-u \" + shlex.quote(\"elastic:\" + _elastic_password())\n\n\n_APP_LABEL = None\n\n\ndef resolve_app_label():\n    \"\"\"Resolve the 'app=<value>' selector for the live ES pods.\n\n    Priority: the BENCH_PARAM_CLUSTER_PREFIX hint when some live StatefulSet\n    actually selects on app=<hint> (explicit override wins) -> the app label of\n    the namespace's Elasticsearch StatefulSet detected live -> the hint.\n    Workflow-agnostic: adapts to an inherited cluster labelled e.g.\n    app=elasticsearch instead of app=es-cluster.\n    \"\"\"\n    global _APP_LABEL\n    if _APP_LABEL is not None:\n        return _APP_LABEL\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n    labels = []\n    if res.returncode == 0:\n        try:\n            for sts in json.loads(res.stdout).get(\"items\", []):\n                spec = sts.get(\"spec\", {})\n                containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n                if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n                    continue\n                app = (spec.get(\"selector\", {}).get(\"matchLabels\", {}) or {}).get(\"app\")\n                ts = sts.get(\"metadata\", {}).get(\"creationTimestamp\", \"\")\n                if app:\n                    labels.append((app, ts))\n        except (json.JSONDecodeError, AttributeError):\n            pass\n    if any(app == CLUSTER_PREFIX_HINT for app, _ in labels):\n        _APP_LABEL = f\"app={CLUSTER_PREFIX_HINT}\"\n        return _APP_LABEL\n    if labels:\n        labels.sort(key=lambda x: (x[1] or \"\"))\n        _APP_LABEL = f\"app={labels[0][0]}\"\n        return _APP_LABEL\n    _APP_LABEL = f\"app={CLUSTER_PREFIX_HINT}\"\n    return _APP_LABEL\n\n\nAPP_LABEL = resolve_app_label()\n\n\ndef _list_es_statefulset_replicas():\n    \"\"\"Return {sts_name: spec.replicas} for the namespace's Elasticsearch\n    StatefulSets (those whose pod template runs an Elasticsearch image).\"\"\"\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n    if res.returncode != 0:\n        return {}\n    try:\n        items = json.loads(res.stdout).get(\"items\", [])\n    except (json.JSONDecodeError, AttributeError):\n        return {}\n    out = {}\n    for sts in items:\n        spec = sts.get(\"spec\", {})\n        containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n        if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n            continue\n        name = sts.get(\"metadata\", {}).get(\"name\")\n        replicas = spec.get(\"replicas\")\n        if name and isinstance(replicas, int):\n            out[name] = replicas\n    return out\n\n\ndef _sts_name_for_node(node_name):\n    \"\"\"Map a live ES node name to its backing StatefulSet name.\n\n    An ES node name equals its pod name, which for a StatefulSet pod is\n    ``<statefulset-name>-<ordinal>`` (e.g. ``es-cluster-0`` -> ``es-cluster``,\n    ``es-data-1`` -> ``es-data``). Strip the trailing ``-<digits>`` ordinal.\n    Returns the node name unchanged if it carries no ordinal suffix.\n    \"\"\"\n    if not node_name:\n        return node_name\n    return re.sub(r\"-\\d+$\", \"\", node_name)\n\n\ndef _live_sts_names(node_names):\n    \"\"\"Set of StatefulSet names actually backing the live cluster nodes.\n\n    Derived by stripping each live node name's ordinal. This excludes\n    accumulated/stale/other ES StatefulSets in the (persisted) namespace that\n    back no node in the queried cluster.\n    \"\"\"\n    return {_sts_name_for_node(n) for n in node_names if n}\n\n\ndef _resolve_expected_nodes(node_names, default=3):\n    \"\"\"Expected node count to enforce, derived from the LIVE cluster.\n\n    The expected total is the DESIRED topology of ONLY the StatefulSets that\n    actually back the live cluster (the nodes returned by ``_cat/nodes``): the\n    sum of spec.replicas over just those StatefulSets. The namespace PERSISTS\n    across workflow stages and accumulates multiple ES clusters, so summing\n    replicas across *every* ES StatefulSet overcounts versus the single cluster\n    the oracle queries. Restricting to the live cluster's StatefulSets fixes that.\n\n    Using DESIRED spec.replicas (not the live count) keeps the check strict: a\n    node that FAILED to join leaves its StatefulSet \"live\" (siblings are up) but\n    absent from ``_cat/nodes``, so EXPECTED stays above the actual count -- no\n    masking. The LIVE cluster is derived FIRST; the param is a FALLBACK used only\n    when no live StatefulSets resolve (e.g. _cat/nodes failed or returned empty).\n    \"\"\"\n    # Derive from the LIVE cluster FIRST (workflow-agnostic + composition-aware):\n    # sum spec.replicas over the active ES StatefulSets -- the base cluster PLUS\n    # any nodeset a PRIOR stage added to the same cluster (e.g. an inherited\n    # transform nodeset). A static EXPECTED_NODES param encodes a standalone\n    # baseline that wrongly ignores such inherited nodesets, so it is demoted to a\n    # FALLBACK below, used only when the live cluster cannot be resolved.\n    # Robust count: sum spec.replicas over ES StatefulSets that are actually\n    # present (status.replicas > 0). Counts the base cluster + any scaled-up\n    # nodeset WITHOUT the fragile node.name -> StatefulSet string mapping (which\n    # breaks when a nodeset's node.name differs from its pod name). A torn-down\n    # prior cluster's StatefulSet has readyReplicas 0 and is excluded. Still\n    # strict: a node that failed to join leaves its STS ready>0 but short, so the\n    # spec-replica sum exceeds the live node count and the check still fails.\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n    if res.returncode == 0:\n        try:\n            items = json.loads(res.stdout).get(\"items\", [])\n        except Exception:\n            items = []\n        desired = 0\n        for sts in items:\n            spec = sts.get(\"spec\", {}) or {}\n            containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", []) or []\n            if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n                continue\n            replicas = spec.get(\"replicas\")\n            # Use status.replicas (pods that EXIST), not readyReplicas: a\n            # scaled-up nodeset whose pods joined the cluster but lack a passing\n            # STS readiness probe has readyReplicas 0 yet is genuinely live.\n            # Count an ES StatefulSet's DESIRED replicas when it is an active part\n            # of the cluster: spec.replicas > 0 and not being torn down. Gating on\n            # status.replicas undercounts a freshly scaled-up nodeset whose status\n            # lags -- its pods have joined the cluster but status.replicas is still\n            # 0 -- which wrongly made EXPECTED < the live node count.\n            being_deleted = (sts.get(\"metadata\", {}) or {}).get(\"deletionTimestamp\") is not None\n            if isinstance(replicas, int) and replicas > 0 and not being_deleted:\n                desired += replicas\n        if desired > 0:\n            return desired\n\n    # Fallbacks (live cluster unresolvable): explicit param, then the default.\n    for key in (\"BENCH_PARAM_EXPECTED_NODES\", \"BENCH_PARAM_EXPECTED_NODE_COUNT\"):\n        val = os.environ.get(key)\n        if val is not None and str(val).strip():\n            try:\n                return int(val)\n            except ValueError:\n                pass\n    return default\n\n\ndef _probe_scheme(scheme):\n    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\n\n    Authenticates with the same live elastic password the real queries use; a\n    401 still proves the scheme is live, so any HTTP status code counts.\n    \"\"\"\n    result = run([\n        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\", \"/bin/sh\", \"-c\",\n        (\"curl -s -S -k -o /dev/null -w '%{http_code}' --max-time 5 \"\n         f\"{_auth_flag()} \"\n         f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200/\"),\n    ])\n    code = (result.stdout or \"\").strip().strip(\"'\")\n    return result.returncode == 0 and code.isdigit() and code != \"000\"\n\n\ndef detect_scheme():\n    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n    global _SCHEME\n    if _SCHEME is not None:\n        return _SCHEME\n    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n        if _probe_scheme(scheme):\n            _SCHEME = scheme\n            return _SCHEME\n    _SCHEME = DEFAULT_SCHEME\n    return _SCHEME\n\n\ndef curl(path, errors):\n    scheme = detect_scheme()\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"exec\",\n        \"curl-test\",\n        \"--\",\n        \"/bin/sh\",\n        \"-c\",\n        # The client deadline (--max-time 20) must exceed any server-side\n        # ``wait_for`` in `path`, otherwise curl aborts (exit 28) before ES can\n        # answer. The retry loop in main() does the real waiting, so each call's\n        # server wait stays short (10s).\n        (\n            f\"curl -s -S -k --max-time 20 {_auth_flag()} \"\n            f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\"\n        ),\n    ]\n\n    result = run(cmd)\n    if result.returncode != 0:\n        stderr = result.stderr.strip()\n        stdout = result.stdout.strip()\n        detail = stderr or stdout or f\"command terminated with exit code {result.returncode}\"\n        errors.append(f\"Failed to query {path}: {detail}\")\n        return None\n    output = result.stdout.strip()\n    if not output:\n        errors.append(f\"Empty response for {path}\")\n        return None\n    try:\n        return json.loads(output)\n    except json.JSONDecodeError:\n        errors.append(f\"Failed to parse JSON from {path}\")\n        return None\n\n\ndef evaluate():\n    \"\"\"Run one full snapshot of the transport-CA checks; return the errors.\"\"\"\n    errors = []\n\n    cm_result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"get\",\n            \"configmap\",\n            \"es-transport-ca-bundle\",\n            \"-o\",\n            \"json\",\n        ]\n    )\n    if cm_result.returncode != 0:\n        errors.append(\n            f\"Failed to read es-transport-ca-bundle ConfigMap: {cm_result.stderr.strip()}\"\n        )\n    else:\n        try:\n            cm = json.loads(cm_result.stdout)\n        except json.JSONDecodeError:\n            errors.append(\"Failed to parse es-transport-ca-bundle ConfigMap JSON\")\n            cm = {}\n        bundle = cm.get(\"data\", {}).get(\"ca.crt\", \"\")\n        cert_count = bundle.count(\"BEGIN CERTIFICATE\")\n        if cert_count < 2:\n            errors.append(\n                f\"Transport CA bundle should contain 2 certs, found {cert_count}\"\n            )\n\n    # Resolve the live cluster's node list FIRST: the expected node count is\n    # derived from only the StatefulSets that actually back these live nodes\n    # (the persisted namespace accumulates several ES clusters across stages, so\n    # summing every ES StatefulSet's replicas overcounts the queried cluster).\n    nodes = curl(\"/_cat/nodes?format=json\", errors)\n    node_names = []\n    if isinstance(nodes, list):\n        node_names = [n.get(\"name\") for n in nodes if n.get(\"name\")]\n    expected_nodes = _resolve_expected_nodes(node_names, default=3)\n\n    health = curl(\n        f\"/_cluster/health?wait_for_status=yellow&wait_for_nodes={expected_nodes}&timeout=10s\",\n        errors,\n    )\n    if isinstance(health, dict):\n        status = health.get(\"status\")\n        if status not in {\"yellow\", \"green\"}:\n            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n        if health.get(\"number_of_nodes\") != expected_nodes:\n            errors.append(\n                f\"Expected {expected_nodes} nodes, got {health.get('number_of_nodes')}\"\n            )\n\n    if isinstance(nodes, list):\n        if len(node_names) != expected_nodes:\n            errors.append(f\"Expected {expected_nodes} nodes in _cat/nodes, got {len(node_names)}\")\n\n    return errors\n\n\ndef main():\n    # A multi-node ES cluster can flap at the edge of readiness under load: a\n    # node briefly fails its HTTP readiness probe / drops from the cluster during\n    # GC or shard recovery even though it is stably green. A single snapshot can\n    # catch that transient and report a false node-count miss. So verify the\n    # STABLE converged state: re-evaluate for up to ~75s and pass on the first\n    # clean snapshot. This does not loosen the N-node/green/CA-bundle\n    # requirements -- a genuinely degraded cluster fails every attempt.\n    import time\n    deadline = time.monotonic() + 75\n    errors = evaluate()\n    while errors and time.monotonic() < deadline:\n        time.sleep(8)\n        errors = evaluate()\n\n    if errors:\n        print(\"Transport CA trust verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    print(\"Transport CA trust verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":376,"startLine":1,"totalLines":376}}}
