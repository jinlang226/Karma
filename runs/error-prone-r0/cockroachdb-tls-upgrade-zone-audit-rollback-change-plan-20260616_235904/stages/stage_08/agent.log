{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015X5UQao49zzkPVJnS1EVfe","type":"tool_result","content":"1\t#!/usr/bin/env bash\n2\t# Rollback script for spark-pi namespace.\n3\t# Reverts non-default configuration applied by the deploy_spark_pi case:\n4\t#   - Pinned image tag (apache/spark:3.5.3) -> apache/spark:latest\n5\t#   - Explicit CPU/memory requests+limits -> removed (cluster defaults)\n6\t#   - Custom serviceAccountName spark-pi -> default\n7\t#   - Worker replicas: 1 -> 2 (standard out-of-box default)\n8\t#   - Custom Role spark-pi-role, RoleBinding, and ServiceAccount spark-pi -> deleted\n9\t#\n10\t# IMPORTANT: Do NOT run this script while earlier workflow stages depend on\n11\t# the current configuration. It is stored here for review only.\n12\t\n13\tset -euo pipefail\n14\t\n15\tNS=spark-pi\n16\t\n17\techo \"=== Reverting spark-master deployment ===\"\n18\tkubectl -n \"$NS\" set image deployment/spark-master \\\n19\t  spark-master=apache/spark:latest\n20\t\n21\tkubectl -n \"$NS\" patch deployment spark-master --type=json -p='[\n22\t  {\"op\": \"replace\", \"path\": \"/spec/template/spec/serviceAccountName\", \"value\": \"default\"},\n23\t  {\"op\": \"replace\", \"path\": \"/spec/template/spec/serviceAccount\",     \"value\": \"default\"},\n24\t  {\"op\": \"remove\",  \"path\": \"/spec/template/spec/containers/0/resources\"}\n25\t]'\n26\t\n27\techo \"=== Reverting spark-worker deployment ===\"\n28\tkubectl -n \"$NS\" set image deployment/spark-worker \\\n29\t  spark-worker=apache/spark:latest\n30\t\n31\tkubectl -n \"$NS\" patch deployment spark-worker --type=json -p='[\n32\t  {\"op\": \"replace\", \"path\": \"/spec/template/spec/serviceAccountName\", \"value\": \"default\"},\n33\t  {\"op\": \"replace\", \"path\": \"/spec/template/spec/serviceAccount\",     \"value\": \"default\"},\n34\t  {\"op\": \"remove\",  \"path\": \"/spec/template/spec/containers/0/resources\"}\n35\t]'\n36\t\n37\t# Restore default worker replica count (2 is the standard Spark on k8s default)\n38\tkubectl -n \"$NS\" scale deployment/spark-worker --replicas=2\n39\t\n40\techo \"=== Waiting for rollout ===\"\n41\tkubectl -n \"$NS\" rollout status deployment/spark-master --timeout=120s\n42\tkubectl -n \"$NS\" rollout status deployment/spark-worker --timeout=120s\n43\t\n44\techo \"=== Removing custom RBAC resources ===\"\n45\tkubectl -n \"$NS\" delete rolebinding spark-pi-role-binding --ignore-not-found=true\n46\tkubectl -n \"$NS\" delete role spark-pi-role --ignore-not-found=true\n47\tkubectl -n \"$NS\" delete serviceaccount spark-pi --ignore-not-found=true\n48\t\n49\techo \"=== Rollback complete. Current state: ===\"\n50\tkubectl get deploy,role,rolebinding,serviceaccount -n \"$NS\"\n51\t"}]},"parent_tool_use_id":null,"session_id":"5c346214-d885-445d-9074-5c45feee7906","uuid":"77b79db4-4fea-4b57-aecf-5c9fcb1e4486","timestamp":"2026-06-17T00:48:12.850Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/rollback.sh","content":"#!/usr/bin/env bash\n# Rollback script for spark-pi namespace.\n# Reverts non-default configuration applied by the deploy_spark_pi case:\n#   - Pinned image tag (apache/spark:3.5.3) -> apache/spark:latest\n#   - Explicit CPU/memory requests+limits -> removed (cluster defaults)\n#   - Custom serviceAccountName spark-pi -> default\n#   - Worker replicas: 1 -> 2 (standard out-of-box default)\n#   - Custom Role spark-pi-role, RoleBinding, and ServiceAccount spark-pi -> deleted\n#\n# IMPORTANT: Do NOT run this script while earlier workflow stages depend on\n# the current configuration. It is stored here for review only.\n\nset -euo pipefail\n\nNS=spark-pi\n\necho \"=== Reverting spark-master deployment ===\"\nkubectl -n \"$NS\" set image deployment/spark-master \\\n  spark-master=apache/spark:latest\n\nkubectl -n \"$NS\" patch deployment spark-master --type=json -p='[\n  {\"op\": \"replace\", \"path\": \"/spec/template/spec/serviceAccountName\", \"value\": \"default\"},\n  {\"op\": \"replace\", \"path\": \"/spec/template/spec/serviceAccount\",     \"value\": \"default\"},\n  {\"op\": \"remove\",  \"path\": \"/spec/template/spec/containers/0/resources\"}\n]'\n\necho \"=== Reverting spark-worker deployment ===\"\nkubectl -n \"$NS\" set image deployment/spark-worker \\\n  spark-worker=apache/spark:latest\n\nkubectl -n \"$NS\" patch deployment spark-worker --type=json -p='[\n  {\"op\": \"replace\", \"path\": \"/spec/template/spec/serviceAccountName\", \"value\": \"default\"},\n  {\"op\": \"replace\", \"path\": \"/spec/template/spec/serviceAccount\",     \"value\": \"default\"},\n  {\"op\": \"remove\",  \"path\": \"/spec/template/spec/containers/0/resources\"}\n]'\n\n# Restore default worker replica count (2 is the standard Spark on k8s default)\nkubectl -n \"$NS\" scale deployment/spark-worker --replicas=2\n\necho \"=== Waiting for rollout ===\"\nkubectl -n \"$NS\" rollout status deployment/spark-master --timeout=120s\nkubectl -n \"$NS\" rollout status deployment/spark-worker --timeout=120s\n\necho \"=== Removing custom RBAC resources ===\"\nkubectl -n \"$NS\" delete rolebinding spark-pi-role-binding --ignore-not-found=true\nkubectl -n \"$NS\" delete role spark-pi-role --ignore-not-found=true\nkubectl -n \"$NS\" delete serviceaccount spark-pi --ignore-not-found=true\n\necho \"=== Rollback complete. Current state: ===\"\nkubectl get deploy,role,rolebinding,serviceaccount -n \"$NS\"\n","numLines":51,"startLine":1,"totalLines":51}}}
