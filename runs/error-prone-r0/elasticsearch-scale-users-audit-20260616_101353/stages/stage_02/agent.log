y. I'm second-guessing whether `podManagementPolicy: Parallel` affects the rolling update behavior, but to keep things simple and predictable, I'll just manually delete pods one at a time to ensure a proper rolling restart. Now let me write out the actual implementation.","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":317,"cache_read_input_tokens":35525,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":317},"output_tokens":36,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"9f19d5cb-adf2-400c-a2cf-a8445ed51696","uuid":"b195ed1c-634e-4da8-b940-9e355cc8a14a","request_id":"req_011Cc6nRSgDu1Zo1ATBWtDd4"}
