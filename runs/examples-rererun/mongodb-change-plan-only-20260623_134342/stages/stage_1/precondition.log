[precondition:mongo_env_ready:preconditionUnits[0] 'mongo_env_ready':apply] $ for i in 0 1 2; do
  for t in $(seq 1 110); do
    phase=$(kubectl -n mongodb get pod mongodb-replica-$i -o jsonpath='{.status.phase}' 2>/dev/null)
