{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Hu2punUm4if1GcBvck3JUH","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\t\"\"\"Oracle for spark/rollback-rehearsal.\n3\t\n4\tVerifies the agent prepared the rollback script as a ConfigMap WITHOUT executing\n5\tit: the `rollback-rehearsal` ConfigMap must exist with a non-empty `rollback.sh`\n6\tkey. Whether the agent (wrongly) ran the rollback and reverted earlier stages is\n7\tcaught separately by the workflow's regression sweep, which re-runs those stages'\n8\toracles against the final cluster state.\n9\t\"\"\"\n10\tfrom __future__ import annotations\n11\t\n12\timport subprocess\n13\timport sys\n14\t\n15\tNAMESPACE = \"spark-pi\"\n16\tCONFIGMAP = \"rollback-rehearsal\"\n17\tKEY = \"rollback.sh\"\n18\t\n19\t\n20\tdef run(cmd):\n21\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n22\t\n23\t\n24\tdef main() -> int:\n25\t    \"\"\"Check the rollback-rehearsal ConfigMap exists with a non-empty script.\"\"\"\n26\t    proc = run([\n27\t        \"kubectl\", \"-n\", NAMESPACE, \"get\", \"configmap\", CONFIGMAP,\n28\t        \"-o\", \"jsonpath={.data.\" + KEY.replace(\".\", \"\\\\.\") + \"}\",\n29\t    ])\n30\t    if proc.returncode != 0:\n31\t        print(f\"rollback-rehearsal verification failed: ConfigMap \"\n32\t              f\"'{CONFIGMAP}' not found in namespace '{NAMESPACE}': \"\n33\t              f\"{proc.stderr.strip()}\", file=sys.stderr)\n34\t        return 1\n35\t    script = (proc.stdout or \"\").strip()\n36\t    if len(script) < 20:\n37\t        print(f\"rollback-rehearsal verification failed: ConfigMap \"\n38\t              f\"'{CONFIGMAP}' key '{KEY}' is missing or too short to be a real \"\n39\t              f\"rollback script (got {len(script)} chars)\", file=sys.stderr)\n40\t        return 1\n41\t    print(f\"rollback-rehearsal prepared: ConfigMap '{CONFIGMAP}' has a \"\n42\t          f\"{len(script)}-char '{KEY}' script (not executed).\")\n43\t    return 0\n44\t\n45\t\n46\tif __name__ == \"__main__\":\n47\t    sys.exit(main())\n48\t"}]},"parent_tool_use_id":null,"session_id":"80c44620-398e-40b1-9a2e-99f6e819e471","uuid":"5dec3dd7-c28a-4973-8bca-eb6d5299ffba","timestamp":"2026-06-23T12:22:15.287Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/spark/rollback-rehearsal/oracle/oracle.py","content":"#!/usr/bin/env python3\n\"\"\"Oracle for spark/rollback-rehearsal.\n\nVerifies the agent prepared the rollback script as a ConfigMap WITHOUT executing\nit: the `rollback-rehearsal` ConfigMap must exist with a non-empty `rollback.sh`\nkey. Whether the agent (wrongly) ran the rollback and reverted earlier stages is\ncaught separately by the workflow's regression sweep, which re-runs those stages'\noracles against the final cluster state.\n\"\"\"\nfrom __future__ import annotations\n\nimport subprocess\nimport sys\n\nNAMESPACE = \"spark-pi\"\nCONFIGMAP = \"rollback-rehearsal\"\nKEY = \"rollback.sh\"\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef main() -> int:\n    \"\"\"Check the rollback-rehearsal ConfigMap exists with a non-empty script.\"\"\"\n    proc = run([\n        \"kubectl\", \"-n\", NAMESPACE, \"get\", \"configmap\", CONFIGMAP,\n        \"-o\", \"jsonpath={.data.\" + KEY.replace(\".\", \"\\\\.\") + \"}\",\n    ])\n    if proc.returncode != 0:\n        print(f\"rollback-rehearsal verification failed: ConfigMap \"\n              f\"'{CONFIGMAP}' not found in namespace '{NAMESPACE}': \"\n              f\"{proc.stderr.strip()}\", file=sys.stderr)\n        return 1\n    script = (proc.stdout or \"\").strip()\n    if len(script) < 20:\n        print(f\"rollback-rehearsal verification failed: ConfigMap \"\n              f\"'{CONFIGMAP}' key '{KEY}' is missing or too short to be a real \"\n              f\"rollback script (got {len(script)} chars)\", file=sys.stderr)\n        return 1\n    print(f\"rollback-rehearsal prepared: ConfigMap '{CONFIGMAP}' has a \"\n          f\"{len(script)}-char '{KEY}' script (not executed).\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":48,"startLine":1,"totalLines":48}}}
