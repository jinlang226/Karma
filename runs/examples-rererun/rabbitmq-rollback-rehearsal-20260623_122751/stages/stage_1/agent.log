{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01KQcHmbZ7oVi2MG5tu6rjon","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01TMnRoNwuGvqMarQVyJcnFY","name":"Write","input":{"file_path":"/tmp/rollback.sh","content":"#!/bin/sh\n# rollback.sh — revert non-default RabbitMQ configuration back to factory defaults.\n#\n# Non-default state found at inspection time (2026-06-23):\n#   vhosts  : /app  (non-default; default is / only)\n#   users   : app-user  (no tags; non-default)\n#   queues  : app-queue on /app  (non-default; removed implicitly by vhost deletion)\n#   perms   : admin  /app .*|.*|.*  (non-default; removed implicitly by vhost deletion)\n#             app-user /app .*|.*|.*  (non-default; removed implicitly by vhost deletion)\n#\n# Execution order:\n#   1. Delete the /app vhost — cascades removal of all queues, exchanges,\n#      bindings, policies, and permissions scoped to that vhost.\n#   2. Delete the app-user account.\n#\n# The admin user and its permissions on / are part of the Kubernetes operator\n# deployment default and are left untouched.\n#\n# DO NOT run this script while the live cluster is serving traffic.\n# Review the ConfigMap contents and obtain change-window approval first.\n\nset -e\n\nRABBITMQ_POD=\"${RABBITMQ_POD:-rabbitmq-0}\"\nNAMESPACE=\"${NAMESPACE:-karma-rabbitmq-rollback-rehearsal-202-819409b6}\"\n\nrun_ctl() {\n  kubectl -n \"$NAMESPACE\" exec \"$RABBITMQ_POD\" -- rabbitmqctl \"$@\"\n}\n\necho \"=== RabbitMQ rollback: removing non-default configuration ===\"\n\n# Step 1: delete the /app vhost.\n# This cascades: removes app-queue, all default exchanges recreated on vhost creation,\n# and all user permissions scoped to /app (admin and app-user).\necho \"[1/2] Deleting vhost /app ...\"\nrun_ctl delete_vhost /app\n\n# Step 2: delete the app-user account.\necho \"[2/2] Deleting user app-user ...\"\nrun_ctl delete_user app-user\n\necho \"=== Rollback complete. Verifying final state ===\"\necho \"--- vhosts ---\"\nrun_ctl list_vhosts\necho \"--- users ---\"\nrun_ctl list_users\necho \"--- queues on / ---\"\nrun_ctl list_queues -p /\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":332,"cache_read_input_tokens":32689,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":332},"output_tokens":11,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"27ee12d0-ad3e-437f-86c1-8a7c0d5e5c34","uuid":"15747d12-fdac-4f85-a37f-960a61f2c60b","request_id":"req_011CcLC8P9XFmg1hDGxmF4LJ"}
