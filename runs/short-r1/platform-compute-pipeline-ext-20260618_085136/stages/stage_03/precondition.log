[precondition:ray_env_ready:preconditionUnits[0] 'ray_env_ready':probe] $ kubectl -n ray get pods 2>/dev/null | grep -c Running
5

[precondition:job_script_ready:preconditionUnits[1] 'job_script_ready':probe] $ kubectl -n ray exec ray-client -- test -s /opt/job.py 2>/dev/null && echo present

[precondition:job_script_ready:preconditionUnits[1] 'job_script_ready':apply] $ kubectl -n ray apply -f cases/ray/job_submission/resource/ray-job-script.yaml
configmap/ray-job-script created

[precondition:job_script_ready:preconditionUnits[1] 'job_script_ready':apply] $ kubectl -n ray delete pod ray-client --ignore-not-found=true --wait=true
pod "ray-client" deleted from ray namespace

[precondition:job_script_ready:preconditionUnits[1] 'job_script_ready':apply] $ /bin/sh -c 'kubectl -n ray get pod ray-client >/dev/null 2>&1 || kubectl -n ray apply -f cases/ray/job_submission/resource/ray-client.yaml'
pod/ray-client created

[precondition:job_script_ready:preconditionUnits[1] 'job_script_ready':apply] $ kubectl -n ray wait --for=condition=Ready pod/ray-client --timeout=150s
pod/ray-client condition met

[precondition:job_script_ready:preconditionUnits[1] 'job_script_ready':verify] $ kubectl -n ray exec ray-client -- test -s /opt/job.py 2>/dev/null && echo present
present

