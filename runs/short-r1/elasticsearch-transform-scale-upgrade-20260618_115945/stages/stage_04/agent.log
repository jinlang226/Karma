lasticsearch scale sts/{{params.transform_cluster_prefix}} --replicas=0 || true'\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n elasticsearch wait --for=delete pod -l app={{params.transform_cluster_prefix}} --timeout=300s || true'\"\n        sleep: 1\n      - command: |\n          /bin/sh -c '\n          pw=$(kubectl -n elasticsearch get secret elastic-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); A=\"\"; [ -n \"$pw\" ] && A=\"-u elastic:$pw\"\n          kubectl -n elasticsearch exec {{params.curl_pod_name}} -- /bin/sh -c '\\''\n          cat <<EOF | curl -s -k $1 -XPOST http://{{params.http_service_name}}.elasticsearch.svc:9200/_bulk -H \"Content-Type: application/x-ndjson\" --data-binary @-\n          {\"index\":{\"_index\":\"{{params.source_index_name}}\"}}\n          {\"service\":\"api\",\"@timestamp\":\"2026-01-02T00:00:00Z\"}\n          {\"index\":{\"_index\":\"{{params.source_index_name}}\"}}\n          {\"service\":\"web\",\"@timestamp\":\"2026-01-02T00:00:01Z\"}\n          EOF\n          '\\'' sh \"$A\" || true\n          '\n        sleep: 1\n    verify:\n      - command: \"/bin/sh -c true\"\n        timeout_sec: 5\n\noracle:\n  verify:\n    commands:\n      - command: \"python3 cases/elasticsearch/transform-job-recovery/oracle/oracle.py\"\n        timeout_sec: 120","stderr":"\nShell cwd was reset to /mydata/karma/runs/short-rerun/elasticsearch-transform-scale-upgrade-20260618_115945/stages/stage_04","interrupted":false,"isImage":false,"noOutputExpected":false}}
