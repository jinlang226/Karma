val\n                - \"db.adminCommand('ping').ok\"\n            initialDelaySeconds: 10\n            periodSeconds: 10\n            failureThreshold: 6\n          livenessProbe:\n            exec:\n              command:\n                - mongosh\n                - --quiet\n                - --eval\n                - \"db.adminCommand('ping').ok\"\n            initialDelaySeconds: 30\n            periodSeconds: 20\n            failureThreshold: 3\n      volumes:\n        - name: keyfile-secret\n          secret:\n            secretName: mongodb-keyfile\n        - name: keyfile-vol\n          emptyDir: {}\n  volumeClaimTemplates:\n    - metadata:\n        name: data\n      spec:\n        accessModes: [\"ReadWriteOnce\"]\n        resources:\n          requests:\n            storage: 1Gi\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":275,"cache_read_input_tokens":29418,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":275},"output_tokens":7,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"1bb09dff-4785-4e8e-8d7c-07b052a130ef","uuid":"18b72475-16cb-4e8b-9d0c-94678cbc94b6","request_id":"req_011CcLJaZZGAEmZ9mno1yNbF"}
