[precondition:es_env_ready:preconditionUnits[0] 'es_env_ready':apply] $ /bin/sh -c '
set -e
TMP_DIR=$(mktemp -d)
kubectl -n elasticsearch exec openssl-toolbox -- /bin/sh -c '\''
set -e
mkdir -p /tmp/certs
cat > /tmp/certs/openssl.cnf <<EOF
distinguished_name=req_distinguished_name
req_extensions=v3_req
prompt=no
[req_distinguished_name]
CN=es-transport
[v3_req]
keyUsage=critical,digitalSignature,keyEncipherment
extendedKeyUsage=serverAuth,clientAuth
subjectAltName=@alt_names
[alt_names]
DNS.1=es-cluster
DNS.2=es-cluster.elasticsearch
DNS.3=es-cluster.elasticsearch.svc
DNS.4=es-cluster.elasticsearch.svc.cluster.local
DNS.5=es-cluster-0.es-cluster.elasticsearch.svc.cluster.local
DNS.6=es-cluster-1.es-cluster.elasticsearch.svc.cluster.local
DNS.7=es-cluster-2.es-cluster.elasticsearch.svc.cluster.local
DNS.8=es-cluster-0
DNS.9=es-cluster-1
DNS.10=es-cluster-2
EOF
openssl genrsa -out /tmp/certs/ca.key 2048
openssl req -x509 -new -nodes -key /tmp/certs/ca.key -sha256 -days 365 -subj "/CN=es-transport-ca" -out /tmp/certs/ca.crt
openssl genrsa -out /tmp/certs/server.key 2048
openssl req -new -key /tmp/certs/server.key -out /tmp/certs/server.csr -config /tmp/certs/openssl.cnf
openssl x509 -req -in /tmp/certs/server.csr -CA /tmp/certs/ca.crt -CAkey /tmp/certs/ca.key -CAcreateserial -out /tmp/certs/server.crt -days 365 -extensions v3_req -extfile /tmp/certs/openssl.cnf
'\''
kubectl -n elasticsearch cp openssl-toolbox:/tmp/certs "${TMP_DIR}/certs"
kubectl -n elasticsearch create secret generic es-transport-tls --from-file=tls.crt="${TMP_DIR}/certs/server.crt" --from-file=tls.key="${TMP_DIR}/certs/server.key" --from-file=ca.crt="${TMP_DIR}/certs/ca.crt" --dry-run=client -o yaml | kubectl apply -f -
'

