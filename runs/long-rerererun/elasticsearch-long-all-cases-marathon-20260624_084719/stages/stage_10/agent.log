e a pre-bundled image.","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1264,"cache_read_input_tokens":38662,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1264},"output_tokens":40,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"3e4d26ef-e625-4852-b3b0-6670cb72b7c6","uuid":"9161f28e-128c-4725-b4f3-09b396938595","request_id":"req_011CcMvfAdTM7aLXS1YxZ67o"}
