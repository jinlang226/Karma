[precondition:es_env_ready:preconditionUnits[0] 'es_env_ready':probe] $ kubectl -n elasticsearch get pods 2>/dev/null | grep -c Running
5

[precondition:transform_scenario_fixture:preconditionUnits[1] 'transform_scenario_fixture':probe] $ /bin/sh -c '
pw=$(kubectl -n elasticsearch get secret elastic-password -o jsonpath="{.data.password}" 2>/dev/null | base64 -d 2>/dev/null); A=""; [ -n "$pw" ] && A="-u elastic:$pw"
code=$(kubectl -n elasticsearch exec curl-test -- curl -sk $A -o /dev/null -w "%{http_code}" --max-time 5 "http://es-http.elasticsearch.svc:9200/_transform/events-by-service/_stats" 2>/dev/null)
[ "$code" = "200" ]
'


