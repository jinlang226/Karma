{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01PDvsuERc8Er6mtEwNFkS7E","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01XwevVEpqmFTynkC7mwr1HH","name":"Write","input":{"file_path":"/tmp/rollback.sh","content":"#!/bin/sh\n# rollback.sh — Revert karma-rabbitmq-rollback-rehearsal-202-d7f30a6f cluster\n# to RabbitMQ defaults.\n#\n# Non-default configuration found at rehearsal time:\n#   Vhosts   : /  (default, kept)  +  /app  (non-default, removed)\n#   Users    : admin [administrator]  +  app-user []  (both non-default)\n#   Missing  : guest [administrator]  (default user, restored)\n#   Queues   : app-queue (classic, durable) on /app  -> deleted with vhost\n#   Policies : none on either vhost\n#\n# WARNING: Running this script will permanently remove the /app vhost and all\n# its queues, the admin and app-user accounts, and restore the default guest\n# account.  The live cluster must be intact before execution.\n#\n# Usage (run inside rabbitmq-0 pod):\n#   rabbitmqctl --help   # confirm rabbitmqctl is available\n#   sh /path/to/rollback.sh\n#\n# Or via kubectl exec:\n#   kubectl -n karma-rabbitmq-rollback-rehearsal-202-d7f30a6f \\\n#     exec rabbitmq-0 -- sh -c \"$(cat rollback.sh)\"\n\nset -eu\n\nNS=\"karma-rabbitmq-rollback-rehearsal-202-d7f30a6f\"\n\necho \"[rollback] Starting RabbitMQ rollback to defaults in namespace: ${NS}\"\n\n# ── Step 1: Restore the default guest user ───────────────────────────────────\n# RabbitMQ ships with guest/guest as the sole administrator.  It was absent on\n# the live cluster, so we add it back before touching anything else (ensures an\n# admin account always exists during the script).\necho \"[rollback] Adding default guest user with administrator tag...\"\nrabbitmqctl add_user guest guest\nrabbitmqctl set_user_tags guest administrator\nrabbitmqctl set_permissions -p / guest \".*\" \".*\" \".*\"\necho \"[rollback] guest user restored.\"\n\n# ── Step 2: Delete the non-default app-user ──────────────────────────────────\necho \"[rollback] Deleting non-default user: app-user...\"\nrabbitmqctl delete_user app-user\necho \"[rollback] app-user deleted.\"\n\n# ── Step 3: Delete the non-default admin user ────────────────────────────────\n# Must be done after guest is restored so a valid admin account still exists.\necho \"[rollback] Deleting non-default user: admin...\"\nrabbitmqctl delete_user admin\necho \"[rollback] admin user deleted.\"\n\n# ── Step 4: Delete the non-default /app vhost ────────────────────────────────\n# Deleting a vhost removes all its queues, exchanges, bindings, and policies.\n# This covers: app-queue (classic, durable) and all permissions on /app.\necho \"[rollback] Deleting non-default vhost: /app...\"\nrabbitmqctl delete_vhost /app\necho \"[rollback] /app vhost (and app-queue) deleted.\"\n\n# ── Step 5: Verify final state ───────────────────────────────────────────────\necho \"\"\necho \"[rollback] ── Final state ──────────────────────────────────────────────\"\necho \"[rollback] Vhosts:\"\nrabbitmqctl list_vhosts\necho \"[rollback] Users:\"\nrabbitmqctl list_users\necho \"[rollback] Permissions on /:\"\nrabbitmqctl list_permissions -p /\necho \"[rollback] Queues on /:\"\nrabbitmqctl list_queues -p / name type durable\necho \"\"\necho \"[rollback] Rollback complete. Cluster is now at RabbitMQ defaults.\"\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1266,"cache_read_input_tokens":31020,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1266},"output_tokens":10,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"fa2a8a01-741e-4e28-973b-0e3be44a0717","uuid":"85c4022a-c46c-4b58-96c9-3b237d227f40","request_id":"req_011CcMUUmrBrfmnWRrqSGc5y"}
