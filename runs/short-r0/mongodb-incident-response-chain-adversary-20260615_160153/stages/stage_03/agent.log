{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01FFkAtvysDTAwMPQKahYXfN","type":"tool_result","content":"# mongodb/statefulset-customization\n# Restore a stable 3-member MongoDB replica set after StatefulSet customization breaks readiness\n\nparams:\n  cluster_prefix:\n    default: mongodb-replica\n    description: App label / StatefulSet name of the replica set members.\n  replica_set_name:\n    default: mongodb-replica\n    description: MongoDB replica set _id used when initiating the set.\n  admin_username:\n    default: admin-user\n    description: Username of the MongoDB admin user.\n  template_label_key:\n    default: monitoring\n    description: Pod template label key toggled by the customization.\n  faulty_request_memory:\n    default: 128Mi\n    description: Faulty memory request applied to break readiness.\n  faulty_limit_memory:\n    default: 256Mi\n    description: Faulty memory limit applied to break readiness.\n\nprompt: |\n  A 3-member MongoDB replica set is running in the mongodb namespace with auth enabled.\n  Pods never become Ready, and monitoring cannot see them.\n\n  Task:\n  - Restore a stable 3-member replica set without data loss.\n  - All pods must become Ready.\n  - Replica set should have 1 PRIMARY and 2 SECONDARY members.\n\n  Notes:\n  - No operators or CRDs.\n\nnamespace_contract:\n  required_roles: []\n\nmetrics:\n  - time_to_first_mutation\n\npreconditionUnits:\n  - name: mongo_env_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n mongodb get pod {{params.cluster_prefix}}-0 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n    apply:\n      - command: \"/bin/sh -c 'kubectl delete namespace mongodb --ignore-not-found=true; kubectl wait --for=delete namespace/mongodb --timeout=120s || true'\"\n        sleep: 2\n      - command: \"kubectl create namespace mongodb\"\n        sleep: 1\n      - command: \"kubectl -n mongodb apply -f cases/mongodb/statefulset-customization/resource/secrets.yaml\"\n        sleep: 1\n      - command: \"kubectl -n mongodb apply -f cases/mongodb/statefulset-customization/resource/guard-script.yaml\"\n        sleep: 1\n      - command: \"kubectl -n mongodb apply -f cases/mongodb/statefulset-customization/resource/services.yaml\"\n        sleep: 1\n      - command: \"kubectl -n mongodb apply -f cases/mongodb/statefulset-customization/resource/statefulset.yaml\"\n        sleep: 5\n      - command: \"kubectl -n mongodb wait --for=condition=ready pod -l app={{params.cluster_prefix}} --timeout=300s\"\n        sleep: 2\n      - command: |\n          /bin/sh -c 'kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\\''rs.initiate({_id:\"{{params.replica_set_name}}\",members:[{_id:0,host:\"mongodb-replica-0.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"},{_id:1,host:\"mongodb-replica-1.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"},{_id:2,host:\"mongodb-replica-2.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"}]})'\\'''\n        sleep: 5\n      - command: |\n          /bin/sh -c 'for i in $(seq 1 20); do kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\\''db.hello().isWritablePrimary'\\'' | grep true && exit 0; sleep 3; done; exit 1'\n        sleep: 2\n      - command: |\n          /bin/sh -c 'kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\\''db.getSiblingDB(\"admin\").createUser({user:\"{{params.admin_username}}\",pwd:\"admin123password\",roles:[{role:\"clusterAdmin\",db:\"admin\"},{role:\"userAdminAnyDatabase\",db:\"admin\"},{role:\"readWriteAnyDatabase\",db:\"admin\"}]})'\\'''\n        sleep: 2\n      - command: |\n          /bin/sh -c 'kubectl -n mongodb patch sts {{params.cluster_prefix}} --type=json -p='\\''[{\"op\":\"replace\",\"path\":\"/spec/template/metadata/labels/{{params.template_label_key}}\",\"value\":\"disabled\"},{\"op\":\"replace\",\"path\":\"/spec/template/spec/containers/0/cases/requests/memory\",\"value\":\"{{params.faulty_request_memory}}\"},{\"op\":\"replace\",\"path\":\"/spec/template/spec/containers/0/cases/limits/memory\",\"value\":\"{{params.faulty_limit_memory}}\"}]'\\'''\n        sleep: 2\n      - command: \"kubectl -n mongodb delete pod -l app={{params.cluster_prefix}}\"\n        sleep: 2\n    verify:\n      # The precondition deliberately breaks the statefulset (faulty memory\n      # patch + pod restart) for the agent to fix, so pods are NOT expected to\n      # be Running here -- verify the broken baseline statefulset is in place.\n      - command: \"kubectl -n mongodb get statefulset {{params.cluster_prefix}} -o name\"\n        timeout_sec: 10\n\noracle:\n  verify:\n    commands:\n      - command: \"python3 cases/mongodb/statefulset-customization/oracle/oracle.py\"\n        timeout_sec: 60","is_error":false}]},"parent_tool_use_id":null,"session_id":"e0a7f577-d323-45cc-b0d3-0883fc4c1cff","uuid":"b4d69026-396d-4185-891b-4a1599f88f70","timestamp":"2026-06-15T16:22:00.279Z","tool_use_result":{"stdout":"# mongodb/statefulset-customization\n# Restore a stable 3-member MongoDB replica set after StatefulSet customization breaks readiness\n\nparams:\n  cluster_prefix:\n    default: mongodb-replica\n    description: App label / StatefulSet name of the replica set members.\n  replica_set_name:\n    default: mongodb-replica\n    description: MongoDB replica set _id used when initiating the set.\n  admin_username:\n    default: admin-user\n    description: Username of the MongoDB admin user.\n  template_label_key:\n    default: monitoring\n    description: Pod template label key toggled by the customization.\n  faulty_request_memory:\n    default: 128Mi\n    description: Faulty memory request applied to break readiness.\n  faulty_limit_memory:\n    default: 256Mi\n    description: Faulty memory limit applied to break readiness.\n\nprompt: |\n  A 3-member MongoDB replica set is running in the mongodb namespace with auth enabled.\n  Pods never become Ready, and monitoring cannot see them