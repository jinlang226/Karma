n              memory: \"1Gi\"\n            limits:\n              cpu: \"1\"\n              memory: \"2Gi\"\n      volumes:\n        - name: es-config\n          configMap:\n            name: es-config\n            items:\n              - key: elasticsearch.yml\n                path: elasticsearch.yml\n  volumeClaimTemplates:\n    - metadata:\n        name: data\n      spec:\n        accessModes: [\"ReadWriteOnce\"]\n        resources:\n          requests:\n            storage: 5Gi\n","numLines":70,"startLine":1,"totalLines":70}}}
