{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WzMcQmvdFyv2BoZcb9BsPM","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport json\n3\timport os\n4\timport subprocess\n5\timport sys\n6\t\n7\t\n8\tNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"elasticsearch\")\n9\tSERVICE = os.environ.get(\"BENCH_PARAM_HTTP_SERVICE_NAME\", \"es-http\")\n10\tCLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"es-cluster\")\n11\t\n12\t\n13\tdef _resolve_expected_nodes(default=3):\n14\t    \"\"\"Topology size to enforce.\n15\t\n16\t    The env PERSISTS across stages, so a prior scale stage may have grown the\n17\t    cluster past this case's standalone default. Resolve from (priority):\n18\t    explicit BENCH_PARAM_EXPECTED_NODES / *_NODE_COUNT param -> the LIVE count\n19\t    of Ready es pods (label app=<prefix>) -> the standalone default. Only the\n20\t    count target adapts; a non-solving agent (missing/NotReady node) still\n21\t    mismatches the live count.\n22\t    \"\"\"\n23\t    for key in (\"BENCH_PARAM_EXPECTED_NODES\", \"BENCH_PARAM_EXPECTED_NODE_COUNT\"):\n24\t        val = os.environ.get(key)\n25\t        if val is not None and str(val).strip():\n26\t            try:\n27\t                return int(val)\n28\t            except ValueError:\n29\t                pass\n30\t    res = subprocess.run(\n31\t        [\"kubectl\", \"-n\", NAMESPACE, \"get\", \"pods\", \"-l\", f\"app={CLUSTER_PREFIX}\", \"-o\", \"json\"],\n32\t        text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE,\n33\t    )\n34\t    if res.returncode == 0:\n35\t        try:\n36\t            items = json.loads(res.stdout).get(\"items\", [])\n37\t            ready = 0\n38\t            for pod in items:\n39\t                conds = pod.get(\"status\", {}).get(\"conditions\", [])\n40\t                if any(c.get(\"type\") == \"Ready\" and c.get(\"status\") == \"True\" for c in conds):\n41\t                    ready += 1\n42\t            if ready > 0:\n43\t                return ready\n44\t        except (json.JSONDecodeError, AttributeError):\n45\t            pass\n46\t    return default\n47\t\n48\t\n49\tEXPECTED_NODES = _resolve_expected_nodes(3)\n50\t# Default scheme for the standalone case; may be flipped by _detect_scheme() when\n51\t# a prior workflow stage toggled xpack.security.http.ssl on this cluster.\n52\tDEFAULT_SCHEME = \"http\"\n53\t_SCHEME = None\n54\t\n55\t\n56\tdef run(cmd):\n57\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n58\t\n59\t\n60\tdef _probe_scheme(scheme):\n61\t    \"\"\"Return True if the ES HTTP API answers on the given scheme.\n62\t\n63\t    The env PERSISTS across stages, so the cluster's actual HTTP scheme may\n64\t    differ from this case's standalone default. A reachable endpoint answers\n65\t    even when auth is required (401/anything HTTP), so any non-empty body or a\n66\t    clean exit counts as 'this scheme is live'. -k tolerates the self-signed\n67\t    cert on https.\n68\t    \"\"\"\n69\t    result = run([\n70\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\",\n71\t        \"curl\", \"-s\", \"-S\", \"-k\", \"-o\", \"/dev/null\",\n72\t        \"-w\", \"%{http_code}\", \"--max-time\", \"5\",\n73\t        f\"{scheme}://{SERVICE}:9200/\",\n74\t    ])\n75\t    code = (result.stdout or \"\").strip()\n76\t    return result.returncode == 0 and code.isdigit() and code != \"000\"\n77\t\n78\t\n79\tdef detect_scheme():\n80\t    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n81\t    global _SCHEME\n82\t    if _SCHEME is not None:\n83\t        return _SCHEME\n84\t    order = [DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"]\n85\t    for scheme in order:\n86\t        if _probe_scheme(scheme):\n87\t            _SCHEME = scheme\n88\t            return _SCHEME\n89\t    _SCHEME = DEFAULT_SCHEME\n90\t    return _SCHEME\n91\t\n92\t\n93\tdef curl(path, errors):\n94\t    scheme = detect_scheme()\n95\t    cmd = [\n96\t        \"kubectl\",\n97\t        \"-n\",\n98\t        NAMESPACE,\n99\t        \"exec\",\n100\t        \"curl-test\",\n101\t        \"--\",\n102\t        \"curl\",\n103\t        \"-s\",\n104\t        \"-S\",\n105\t        \"-k\",\n106\t        \"--max-time\",\n107\t        \"10\",\n108\t        f\"{scheme}://{SERVICE}:9200{path}\",\n109\t    ]\n110\t    result = run(cmd)\n111\t    if result.returncode != 0:\n112\t        stderr = result.stderr.strip()\n113\t        stdout = result.stdout.strip()\n114\t        detail = stderr or stdout or f\"command terminated with exit code {result.returncode}\"\n115\t        errors.append(f\"Failed to query {path}: {detail}\")\n116\t        return None\n117\t    output = result.stdout.strip()\n118\t    if not output:\n119\t        errors.append(f\"Empty response for {path}\")\n120\t        return None\n121\t    try:\n122\t        return json.loads(output)\n123\t    except json.JSONDecodeError:\n124\t        errors.append(f\"Failed to parse JSON from {path}\")\n125\t        return None\n126\t\n127\t\n128\tdef check_cluster(errors):\n129\t    ep_result = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"endpoints\", SERVICE, \"-o\", \"json\"])\n130\t    if ep_result.returncode != 0:\n131\t        errors.append(f\"Failed to read {SERVICE} endpoints: {ep_result.stderr.strip()}\")\n132\t        return\n133\t    try:\n134\t        ep = json.loads(ep_result.stdout)\n135\t    except json.JSONDecodeError:\n136\t        errors.append(f\"Failed to parse {SERVICE} endpoints JSON\")\n137\t        return\n138\t\n139\t    addr_count = 0\n140\t    for subset in ep.get(\"subsets\", []) or []:\n141\t        addr_count += len(subset.get(\"addresses\", []) or [])\n142\t    if addr_count != EXPECTED_NODES:\n143\t        errors.append(f\"Expected {EXPECTED_NODES} endpoints, got {addr_count}\")\n144\t\n145\t    health = curl(\n146\t        f\"/_cluster/health?wait_for_status=yellow&wait_for_nodes={EXPECTED_NODES}&timeout=30s\",\n147\t        errors,\n148\t    )\n149\t    if isinstance(health, dict):\n150\t        status = health.get(\"status\")\n151\t        if status not in {\"yellow\", \"green\"}:\n152\t            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n153\t        if health.get(\"number_of_nodes\") != EXPECTED_NODES:\n154\t            errors.append(f\"Expected {EXPECTED_NODES} nodes, got {health.get('number_of_nodes')}\")\n155\t\n156\t    root = curl(\"/\", errors)\n157\t    if isinstance(root, dict):\n158\t        uuid = root.get(\"cluster_uuid\")\n159\t        if not uuid or uuid == \"_na_\":\n160\t            errors.append(\"Cluster UUID not set\")\n161\t\n162\t    nodes = curl(\"/_cat/nodes?format=json\", errors)\n163\t    if isinstance(nodes, list) and len(nodes) != EXPECTED_NODES:\n164\t        errors.append(f\"Expected {EXPECTED_NODES} nodes in _cat/nodes, got {len(nodes)}\")\n165\t\n166\t\n167\tdef main():\n168\t    errors = []\n169\t\n170\t    cm_result = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"configmap\", \"es-config\", \"-o\", \"json\"])\n171\t    if cm_result.returncode != 0:\n172\t        errors.append(f\"Failed to read es-config ConfigMap: {cm_result.stderr.strip()}\")\n173\t    else:\n174\t        try:\n175\t            cm = json.loads(cm_result.stdout)\n176\t        except json.JSONDecodeError:\n177\t            errors.append(\"Failed to parse es-config ConfigMap JSON\")\n178\t            cm = {}\n179\t        config = cm.get(\"data\", {}).get(\"elasticsearch.yml\", \"\")\n180\t        if \"cluster.initial_master_nodes\" in config:\n181\t            errors.append(\"cluster.initial_master_nodes still present in es-config\")\n182\t\n183\t    pods_result = run(\n184\t        [\"kubectl\", \"-n\", NAMESPACE, \"get\", \"pods\", \"-l\", f\"app={CLUSTER_PREFIX}\", \"-o\", \"json\"]\n185\t    )\n186\t    if pods_result.returncode != 0:\n187\t        errors.append(f\"Failed to read pods: {pods_result.stderr.strip()}\")\n188\t    else:\n189\t        try:\n190\t            pods = json.loads(pods_result.stdout)\n191\t        except json.JSONDecodeError:\n192\t            errors.append(\"Failed to parse pods JSON\")\n193\t            pods = {}\n194\t        items = pods.get(\"items\", []) if isinstance(pods, dict) else []\n195\t        if len(items) != EXPECTED_NODES:\n196\t            errors.append(f\"Expected {EXPECTED_NODES} pods, got {len(items)}\")\n197\t        for pod in items:\n198\t            name = pod.get(\"metadata\", {}).get(\"name\", \"unknown\")\n199\t            conditions = pod.get(\"status\", {}).get(\"conditions\", [])\n200\t            ready = next((c for c in conditions if c.get(\"type\") == \"Ready\"), {})\n201\t            if ready.get(\"status\") != \"True\":\n202\t                errors.append(f\"Pod {name} is not Ready\")\n203\t\n204\t    check_cluster(errors)\n205\t\n206\t    if errors:\n207\t        print(\"Bootstrap verification failed:\", file=sys.stderr)\n208\t        for err in errors:\n209\t            print(f\"  - {err}\", file=sys.stderr)\n210\t        return 1\n211\t\n212\t    print(\"Bootstrap initial master nodes verified\")\n213\t    return 0\n214\t\n215\t\n216\tif __name__ == \"__main__\":\n217\t    sys.exit(main())\n218\t"}]},"parent_tool_use_id":null,"session_id":"d216c7e5-9ae8-4792-be32-59a6bff73b34","uuid":"92a9ecc7-2f62-463c-a76c-ebddd73a30c5","timestamp":"2026-06-15T16:02:32.871Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/leo/Karma/cases/elasticsearch/bootstrap-initial-master-nodes/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport json\nimport os\nimport subprocess\nimport sys\n\n\nNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"elasticsearch\")\nSERVICE = os.environ.get(\"BENCH_PARAM_HTTP_SERVICE_NAME\", \"es-http\")\nCLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"es-cluster\")\n\n\ndef _resolve_expected_nodes(default=3):\n    \"\"\"Topology size to enforce.\n\n    The env PERSISTS across stages, so a prior scale stage may have grown the\n    cluster past this case's standalone default. Resolve from (priority):\n    explicit BENCH_PARAM_EXPECTED_NODES / *_NODE_COUNT param -> the LIVE count\n    of Ready es pods (label app=<prefix>) -> the standalone default. Only the\n    count target adapts; a non-solving agent (missing/NotReady node) still\n    mismatches the live count.\n    \"\"\"\n    for key in (\"BENCH_PARAM_EXPECTED_NODES\", \"BENCH_PARAM_EXPECTED_NODE_COUNT\"):\n        val = os.environ.get(key)\n        if val is not None and str(val).strip():\n            try:\n                return int(val)\n            except ValueError:\n                pass\n    res = subprocess.run(\n        [\"kubectl\", \"-n\", NAMESPACE, \"get\", \"pods\", \"-l\", f\"app={CLUSTER_PREFIX}\", \"-o\", \"json\"],\n        text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE,\n    )\n    if res.returncode == 0:\n        try:\n            items = json.loads(res.stdout).get(\"items\", [])\n            ready = 0\n            for pod in items:\n                conds = pod.get(\"status\", {}).get(\"conditions\", [])\n                if any(c.get(\"type\") == \"Ready\" and c.get(\"status\") == \"True\" for c in conds):\n                    ready += 1\n            if ready > 0:\n                return ready\n        except (json.JSONDecodeError, AttributeError):\n            pass\n    return default\n\n\nEXPECTED_NODES = _resolve_expected_nodes(3)\n# Default scheme for the standalone case; may be flipped by _detect_scheme() when\n# a prior workflow stage toggled xpack.security.http.ssl on this cluster.\nDEFAULT_SCHEME = \"http\"\n_SCHEME = None\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef _probe_scheme(scheme):\n    \"\"\"Return True if the ES HTTP API answers on the given scheme.\n\n    The env PERSISTS across stages, so the cluster's actual HTTP scheme may\n    differ from this case's standalone default. A reachable endpoint answers\n    even when auth is required (401/anything HTTP), so any non-empty body or a\n    clean exit counts as 'this scheme is live'. -k tolerates the self-signed\n    cert on https.\n    \"\"\"\n    result = run([\n        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\",\n        \"curl\", \"-s\", \"-S\", \"-k\", \"-o\", \"/dev/null\",\n        \"-w\", \"%{http_code}\", \"--max-time\", \"5\",\n        f\"{scheme}://{SERVICE}:9200/\",\n    ])\n    code = (result.stdout or \"\").strip()\n    return result.returncode == 0 and code.isdigit() and code != \"000\"\n\n\ndef detect_scheme():\n    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n    global _SCHEME\n    if _SCHEME is not None:\n        return _SCHEME\n    order = [DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"]\n    for scheme in order:\n        if _probe_scheme(scheme):\n            _SCHEME = scheme\n            return _SCHEME\n    _SCHEME = DEFAULT_SCHEME\n    return _SCHEME\n\n\ndef curl(path, errors):\n    scheme = detect_scheme()\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"exec\",\n        \"curl-test\",\n        \"--\",\n        \"curl\",\n        \"-s\",\n        \"-S\",\n        \"-k\",\n        \"--max-time\",\n        \"10\",\n        f\"{scheme}://{SERVICE}:9200{path}\",\n    ]\n    result = run(cmd)\n    if result.returncode != 0:\n        stderr = result.stderr.strip()\n        stdout = result.stdout.strip()\n        detail = stderr or stdout or f\"command terminated with exit code {result.returncode}\"\n        errors.append(f\"Failed to query {path}: {detail}\")\n        return None\n    output = result.stdout.strip()\n    if not output:\n        errors.append(f\"Empty response for {path}\")\n        return None\n    try:\n        return json.loads(output)\n    except json.JSONDecodeError:\n        errors.append(f\"Failed to parse JSON from {path}\")\n        return None\n\n\ndef check_cluster(errors):\n    ep_result = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"endpoints\", SERVICE, \"-o\", \"json\"])\n    if ep_result.returncode != 0:\n        errors.append(f\"Failed to read {SERVICE} endpoints: {ep_result.stderr.strip()}\")\n        return\n    try:\n        ep = json.loads(ep_result.stdout)\n    except json.JSONDecodeError:\n        errors.append(f\"Failed to parse {SERVICE} endpoints JSON\")\n        return\n\n    addr_count = 0\n    for subset in ep.get(\"subsets\", []) or []:\n        addr_count += len(subset.get(\"addresses\", []) or [])\n    if addr_count != EXPECTED_NODES:\n        errors.append(f\"Expected {EXPECTED_NODES} endpoints, got {addr_count}\")\n\n    health = curl(\n        f\"/_cluster/health?wait_for_status=yellow&wait_for_nodes={EXPECTED_NODES}&timeout=30s\",\n        errors,\n    )\n    if isinstance(health, dict):\n        status = health.get(\"status\")\n        if status not in {\"yellow\", \"green\"}:\n            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n        if health.get(\"number_of_nodes\") != EXPECTED_NODES:\n            errors.append(f\"Expected {EXPECTED_NODES} nodes, got {health.get('number_of_nodes')}\")\n\n    root = curl(\"/\", errors)\n    if isinstance(root, dict):\n        uuid = root.get(\"cluster_uuid\")\n        if not uuid or uuid == \"_na_\":\n            errors.append(\"Cluster UUID not set\")\n\n    nodes = curl(\"/_cat/nodes?format=json\", errors)\n    if isinstance(nodes, list) and len(nodes) != EXPECTED_NODES:\n        errors.append(f\"Expected {EXPECTED_NODES} nodes in _cat/nodes, got {len(nodes)}\")\n\n\ndef main():\n    errors = []\n\n    cm_result = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"configmap\", \"es-config\", \"-o\", \"json\"])\n    if cm_result.returncode != 0:\n        errors.append(f\"Failed to read es-config ConfigMap: {cm_result.stderr.strip()}\")\n    else:\n        try:\n            cm = json.loads(cm_result.stdout)\n        except json.JSONDecodeError:\n            errors.append(\"Failed to parse es-config ConfigMap JSON\")\n            cm = {}\n        config = cm.get(\"data\", {}).get(\"elasticsearch.yml\", \"\")\n        if \"cluster.initial_master_nodes\" in config:\n            errors.append(\"cluster.initial_master_nodes still present in es-config\")\n\n    pods_result = run(\n        [\"kubectl\", \"-n\", NAMESPACE, \"get\", \"pods\", \"-l\", f\"app={CLUSTER_PREFIX}\", \"-o\", \"json\"]\n    )\n    if pods_result.returncode != 0:\n        errors.append(f\"Failed to read pods: {pods_result.stderr.strip()}\")\n    else:\n        try:\n            pods = json.loads(pods_result.stdout)\n        except json.JSONDecodeError:\n            errors.append(\"Failed to parse pods JSON\")\n            pods = {}\n        items = pods.get(\"items\", []) if isinstance(pods, dict) else []\n        if len(items) != EXPECTED_NODES:\n            errors.append(f\"Expected {EXPECTED_NODES} pods, got {len(items)}\")\n        for pod in items:\n            name = pod.get(\"metadata\", {}).get(\"name\", \"unknown\")\n            conditions = pod.get(\"status\", {}).get(\"conditions\", [])\n            ready = next((c for c in conditions if c.get(\"type\") == \"Ready\"), {})\n            if ready.get(\"status\") != \"True\":\n                errors.append(f\"Pod {name} is not Ready\")\n\n    check_cluster(errors)\n\n    if errors:\n        print(\"Bootstrap verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    print(\"Bootstrap initial master nodes verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":218,"startLine":1,"totalLines":218}}}
