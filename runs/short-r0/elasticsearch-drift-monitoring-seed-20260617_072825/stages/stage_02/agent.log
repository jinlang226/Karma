a:\n  elasticsearch.yml: |\n    cluster.name: es-alpha\n    node.name: ${POD_NAME}\n    node.roles: [ master, data, ingest ]\n    network.host: 0.0.0.0\n    discovery.seed_hosts:\n      - es-alpha-0.es-alpha\n      - es-alpha-1.es-alpha\n      - es-alpha-2.es-alpha\n    cluster.initial_master_nodes:\n      - es-alpha-0\n      - es-alpha-1\n      - es-alpha-2\n    node.store.allow_mmap: false\n    xpack.security.enabled: false\n    xpack.security.http.ssl.enabled: false\n    xpack.security.transport.ssl.enabled: false\napiVersion: v1\nkind: ConfigMap\nmetadata:\n  name: es-beta-config\ndata:\n  elasticsearch.yml: |\n    cluster.name: es-beta\n    node.name: ${POD_NAME}\n    node.roles: [ master, data, ingest ]\n    network.host: 0.0.0.0\n    discovery.seed_hosts:\n      - es-beta-0.es-beta\n    cluster.initial_master_nodes:\n      - es-beta-0\n    node.store.allow_mmap: false\n    xpack.security.enabled: false\n    xpack.security.http.ssl.enabled: false\n    xpack.security.transport.ssl.enabled: false","is_error":false}]},"parent_tool_use_id":null,"session_id":"ef543063-b60d-42ee-abd3-c1bd9697a344","uuid":"d67cd831-d78e-4c77-b78b-1240e52abebc","timestamp":"2026-06-17T08:02:07.162Z","tool_use_result":{"stdout":"apiVersion: apps/v1\nkind: StatefulSet\nmetadata:\n  name: es-beta\nspec:\n  serviceName: es-beta\n  podManagementPolicy: Parallel\n  replicas: 1\n  selector:\n    matchLabels:\n      app: es-beta\n  template:\n    metadata:\n      labels:\n        app: es-beta\n    spec:\n      containers:\n        - name: elasticsearch\n          image: docker.elastic.co/elasticsearch/elasticsearch:7.17.9\n          env:\n            - name: POD_NAME\n              valueFrom:\n                fieldRef:\n                  fieldPath: metadata.name\n            - name: ES_JAVA_OPTS\n              value: \"-Xms512m -Xmx512m\"\n          ports:\n            - containerPort: 9200\n              name: http\n            - containerPort: 9300\n              name: transport\n          