{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YG594R4NxULhWrnb4khoPc","type":"tool_result","content":"160\t        result[\"error\"] = str(exc)\n161\t    return result\n162\t\n163\t\n164\tdef run_oracle(\n165\t    oracle_config: dict[str, Any],\n166\t    *,\n167\t    role_bindings: dict[str, str],\n168\t    run_dir: Path,\n169\t    stage_id: str,\n170\t    env_vars: dict[str, str] | None = None,\n171\t    timeout_sec: int | None = None,\n172\t) -> dict[str, Any]:\n173\t    \"\"\"Execute the oracle verify block for one stage and return the verdict.\n174\t\n175\t    Runs ``before_commands``, then ``verify_commands``, then\n176\t    ``after_commands`` in order. A non-zero exit code from\n177\t    ``verify_commands`` sets the verdict to ``\"fail\"``. If\n178\t    ``after_commands`` fail and ``after_failure_mode`` is ``\"fail\"``, the\n179\t    verdict is additionally marked as degraded.\n180\t\n181\t    When ``oracle_config`` contains a ``script_path``, the ``oracle.py``\n182\t    script is executed as a subprocess with ``role_bindings`` injected as\n183\t    environment variables, and its output is merged into the verdict.\n184\t\n185\t    The verdict is written to ``protocol.stage_oracle_path(run_dir, stage_id)``.\n186\t\n187\t    This function never raises. Unexpected errors are captured in the\n188\t    returned dict under the ``\"error\"`` key with a verdict of ``\"error\"``.\n189\t\n190\t    Parameters\n191\t    ----------\n192\t    oracle_config:\n193\t        Normalized oracle config dict produced by ``definitions.cases.normalize_oracle_config``.\n194\t    role_bindings:\n195\t        Map of namespace role name to physical namespace name.\n196\t    run_dir:\n197\t        Root directory of the current run.\n198\t    stage_id:\n199\t        ID of the stage being evaluated.\n200\t    env_vars:\n201\t        Additional environment variables forwarded to oracle commands.\n202\t    timeout_sec:\n203\t        Maximum wall-clock seconds allowed for the full oracle execution.\n204\t\n205\t    Returns\n206\t    -------\n207\t    dict\n208\t        Keys: ``verdict`` (``\"pass\"``, ``\"fail\"``, or ``\"error\"``),\n209\t        ``output``, ``before_output``, ``after_output``,\n210\t        ``script_output`` (``None`` if no script), ``error`` (``None``\n211\t        on success).\n212\t    \"\"\"\n213\t    from .settings import settings as _settings\n214\t    if timeout_sec is not None:\n215\t        effective_timeout = timeout_sec\n216\t    else:\n217\t        # Honor per-command timeout_sec declared in the oracle config: the outer\n218\t        # wall-clock deadline must be at least the sum of the declared per-command\n219\t        # budgets across before/verify/after, otherwise a command's own\n220\t        # timeout_sec is silently clamped by the default oracle_timeout_sec (e.g.\n221\t        # a 300s pod-restart-persistence check capped at 120s). Defaults to\n222\t        # oracle_timeout_sec when no command declares a longer timeout.\n223\t        declared = 0\n224\t        for _key in (\"before_commands\", \"verify_commands\", \"after_commands\"):\n225\t            for _entry in oracle_config.get(_key) or []:\n226\t                if _entry.get(\"command\"):\n227\t                    declared += int(_entry.get(\"timeout_sec\") or 0) + int(_entry.get(\"sleep\") or 0)\n228\t        effective_timeout = max(_settings.oracle_timeout_sec, declared)\n229\t"}]},"parent_tool_use_id":null,"session_id":"a9894363-34c2-4ba1-a8f4-f8ca4b3b113b","uuid":"6a09211c-97b6-4926-a351-afe0bf51cb59","timestamp":"2026-06-17T09:24:25.685Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/karma/oracle.py","content":"        result[\"error\"] = str(exc)\n    return result\n\n\ndef run_oracle(\n    oracle_config: dict[str, Any],\n    *,\n    role_bindings: dict[str, str],\n    run_dir: Path,\n    stage_id: str,\n    env_vars: dict[str, str] | None = None,\n    timeout_sec: int | None = None,\n) -> dict[str, Any]:\n    \"\"\"Execute the oracle verify block for one stage and return the verdict.\n\n    Runs ``before_commands``, then ``verify_commands``, then\n    ``after_commands`` in order. A non-zero exit code from\n    ``verify_commands`` sets the verdict to ``\"fail\"``. If\n    ``after_commands`` fail and ``after_failure_mode`` is ``\"fail\"``, the\n    verdict is additionally marked as degraded.\n\n    When ``oracle_config`` contains a ``script_path``, the ``oracle.py``\n    script is executed as a subprocess with ``role_bindings`` injected as\n    environment variables, and its output is merged into the verdict.\n\n    The verdict is written to ``protocol.stage_oracle_path(run_dir, stage_id)``.\n\n    This function never raises. Unexpected errors are captured in the\n    returned dict under the ``\"error\"`` key with a verdict of ``\"error\"``.\n\n    Parameters\n    ----------\n    oracle_config:\n        Normalized oracle config dict produced by ``definitions.cases.normalize_oracle_config``.\n    role_bindings:\n        Map of namespace role name to physical namespace name.\n    run_dir:\n        Root directory of the current run.\n    stage_id:\n        ID of the stage being evaluated.\n    env_vars:\n        Additional environment variables forwarded to oracle commands.\n    timeout_sec:\n        Maximum wall-clock seconds allowed for the full oracle execution.\n\n    Returns\n    -------\n    dict\n        Keys: ``verdict`` (``\"pass\"``, ``\"fail\"``, or ``\"error\"``),\n        ``output``, ``before_output``, ``after_output``,\n        ``script_output`` (``None`` if no script), ``error`` (``None``\n        on success).\n    \"\"\"\n    from .settings import settings as _settings\n    if timeout_sec is not None:\n        effective_timeout = timeout_sec\n    else:\n        # Honor per-command timeout_sec declared in the oracle config: the outer\n        # wall-clock deadline must be at least the sum of the declared per-command\n        # budgets across before/verify/after, otherwise a command's own\n        # timeout_sec is silently clamped by the default oracle_timeout_sec (e.g.\n        # a 300s pod-restart-persistence check capped at 120s). Defaults to\n        # oracle_timeout_sec when no command declares a longer timeout.\n        declared = 0\n        for _key in (\"before_commands\", \"verify_commands\", \"after_commands\"):\n            for _entry in oracle_config.get(_key) or []:\n                if _entry.get(\"command\"):\n                    declared += int(_entry.get(\"timeout_sec\") or 0) + int(_entry.get(\"sleep\") or 0)\n        effective_timeout = max(_settings.oracle_timeout_sec, declared)\n","numLines":70,"startLine":160,"totalLines":302}}}
