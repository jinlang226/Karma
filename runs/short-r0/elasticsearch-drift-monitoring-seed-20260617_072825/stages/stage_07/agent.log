{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VxeNzJehDcpG3X31X6gbDt","type":"tool_result","content":"80\t\n81\t\n82\tdef _is_transient_failure(result: dict[str, Any]) -> bool:\n83\t    \"\"\"True if a FAIL verdict looks caused by a transient API/proxy blip.\n84\t\n85\t    Such failures (kubectl momentarily cannot reach the apiserver, so the\n86\t    oracle cannot list pods or read secrets) do not reflect cluster state, so\n87\t    the caller re-runs the evaluation rather than trusting the verdict.\n88\t    \"\"\"\n89\t    blob = \" \".join(\n90\t        str(result.get(key) or \"\")\n91\t        for key in (\"output\", \"before_output\", \"after_output\", \"script_output\")\n92\t    )\n93\t    return any(sig in blob for sig in _TRANSIENT_SIGNATURES)\n94\t\n95\t\n96\tdef _evaluate_oracle(\n97\t    oracle_config: dict[str, Any],\n98\t    *,\n99\t    env: dict[str, str],\n100\t    effective_timeout: int,\n101\t) -> dict[str, Any]:\n102\t    \"\"\"Run before/verify/script/after commands once and return a verdict dict.\n103\t\n104\t    Pure evaluation with no disk writes; ``run_oracle`` wraps this in a\n105\t    transient-failure retry loop and persists the final result.\n106\t    \"\"\"\n107\t    result: dict[str, Any] = {\n108\t        \"verdict\": \"error\",\n109\t        \"output\": \"\",\n110\t        \"before_output\": \"\",\n111\t        \"after_output\": \"\",\n112\t        \"script_output\": None,\n113\t        \"error\": None,\n114\t    }\n115\t    try:\n116\t        after_failure_mode = oracle_config.get(\"after_failure_mode\") or \"warn\"\n117\t\n118\t        before_ok, before_out = _run_commands(\n119\t            oracle_config.get(\"before_commands\") or [],\n120\t            env=env, timeout_sec=effective_timeout,\n121\t        )\n122\t        result[\"before_output\"] = before_out\n123\t\n124\t        verify_ok, verify_out = _run_commands(\n125\t            oracle_config.get(\"verify_commands\") or [],\n126\t            env=env, timeout_sec=effective_timeout,\n127\t        )\n128\t        result[\"output\"] = verify_out\n129\t\n130\t        script_output: str | None = None\n131\t        script_path = oracle_config.get(\"script_path\")\n132\t        if script_path:\n133\t            try:\n134\t                proc = subprocess.run(\n135\t                    [\"python3\", script_path],\n136\t                    capture_output=True, text=True, env=env, timeout=effective_timeout,\n137\t                )\n138\t                script_output = proc.stdout + proc.stderr\n139\t                if proc.returncode != 0:\n140\t                    verify_ok = False\n141\t            except Exception as exc:\n142\t                script_output = f\"[script error: {exc}]\"\n143\t                verify_ok = False\n144\t        result[\"script_output\"] = script_output\n145\t\n146\t        after_ok, after_out = _run_commands(\n147\t            oracle_config.get(\"after_commands\") or [],\n148\t            env=env, timeout_sec=effective_timeout,\n149\t        )\n150\t        result[\"after_output\"] = after_out\n151\t\n152\t        if not verify_ok:\n153\t            result[\"verdict\"] = \"fail\"\n154\t        elif not after_ok and after_failure_mode == \"fail\":\n155\t            result[\"verdict\"] = \"fail\"\n156\t        else:\n157\t            result[\"verdict\"] = \"pass\"\n158\t    except Exception as exc:\n159\t        result[\"verdict\"] = \"error\""}]},"parent_tool_use_id":null,"session_id":"a9894363-34c2-4ba1-a8f4-f8ca4b3b113b","uuid":"da650f0a-27e6-4c3c-9f6e-b8ecd0b560fc","timestamp":"2026-06-17T09:24:22.588Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/karma/oracle.py","content":"\n\ndef _is_transient_failure(result: dict[str, Any]) -> bool:\n    \"\"\"True if a FAIL verdict looks caused by a transient API/proxy blip.\n\n    Such failures (kubectl momentarily cannot reach the apiserver, so the\n    oracle cannot list pods or read secrets) do not reflect cluster state, so\n    the caller re-runs the evaluation rather than trusting the verdict.\n    \"\"\"\n    blob = \" \".join(\n        str(result.get(key) or \"\")\n        for key in (\"output\", \"before_output\", \"after_output\", \"script_output\")\n    )\n    return any(sig in blob for sig in _TRANSIENT_SIGNATURES)\n\n\ndef _evaluate_oracle(\n    oracle_config: dict[str, Any],\n    *,\n    env: dict[str, str],\n    effective_timeout: int,\n) -> dict[str, Any]:\n    \"\"\"Run before/verify/script/after commands once and return a verdict dict.\n\n    Pure evaluation with no disk writes; ``run_oracle`` wraps this in a\n    transient-failure retry loop and persists the final result.\n    \"\"\"\n    result: dict[str, Any] = {\n        \"verdict\": \"error\",\n        \"output\": \"\",\n        \"before_output\": \"\",\n        \"after_output\": \"\",\n        \"script_output\": None,\n        \"error\": None,\n    }\n    try:\n        after_failure_mode = oracle_config.get(\"after_failure_mode\") or \"warn\"\n\n        before_ok, before_out = _run_commands(\n            oracle_config.get(\"before_commands\") or [],\n            env=env, timeout_sec=effective_timeout,\n        )\n        result[\"before_output\"] = before_out\n\n        verify_ok, verify_out = _run_commands(\n            oracle_config.get(\"verify_commands\") or [],\n            env=env, timeout_sec=effective_timeout,\n        )\n        result[\"output\"] = verify_out\n\n        script_output: str | None = None\n        script_path = oracle_config.get(\"script_path\")\n        if script_path:\n            try:\n                proc = subprocess.run(\n                    [\"python3\", script_path],\n                    capture_output=True, text=True, env=env, timeout=effective_timeout,\n                )\n                script_output = proc.stdout + proc.stderr\n                if proc.returncode != 0:\n                    verify_ok = False\n            except Exception as exc:\n                script_output = f\"[script error: {exc}]\"\n                verify_ok = False\n        result[\"script_output\"] = script_output\n\n        after_ok, after_out = _run_commands(\n            oracle_config.get(\"after_commands\") or [],\n            env=env, timeout_sec=effective_timeout,\n        )\n        result[\"after_output\"] = after_out\n\n        if not verify_ok:\n            result[\"verdict\"] = \"fail\"\n        elif not after_ok and after_failure_mode == \"fail\":\n            result[\"verdict\"] = \"fail\"\n        else:\n            result[\"verdict\"] = \"pass\"\n    except Exception as exc:\n        result[\"verdict\"] = \"error\"","numLines":80,"startLine":80,"totalLines":302}}}
