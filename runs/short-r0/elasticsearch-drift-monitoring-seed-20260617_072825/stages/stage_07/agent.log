{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JA9erqdW59aXizPPkweYWS","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport json\n3\timport os\n4\timport re\n5\timport subprocess\n6\timport sys\n7\t\n8\tNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"elasticsearch\")\n9\tSERVICE = os.environ.get(\"BENCH_PARAM_HTTP_SERVICE_NAME\", \"es-http\")\n10\t# ES 8.x runs with security enabled, so the HTTPS API requires authenticating as\n11\t# the elastic superuser. When this case inherits a secured cluster from an\n12\t# earlier workflow stage, read its password from the secret that stage created\n13\t# so the oracle's queries aren't rejected with 401. Absent secret -> None -> no\n14\t# -u, so a standalone unsecured cluster still works.\n15\tPASSWORD_SECRET = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_SECRET_NAME\", \"elastic-password\")\n16\tPASSWORD_KEY = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_KEY\", \"password\")\n17\t# Hint for the Elasticsearch pod app label. Used as an override when it matches a\n18\t# live StatefulSet's selector; otherwise the real selector label is detected\n19\t# live from the cluster. The env PERSISTS across stages, so a workflow's\n20\t# inherited ES cluster may label its pods differently than this case's standalone\n21\t# default of 'es-cluster'.\n22\tCLUSTER_PREFIX_HINT = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"es-cluster\")\n23\tINDEX = os.environ.get(\"BENCH_PARAM_INDEX_NAME\", \"app-data\")\n24\tDEFAULT_SCHEME = \"http\"\n25\t_SCHEME = None\n26\t\n27\t\n28\tdef run(cmd):\n29\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n30\t\n31\t\n32\tdef _elastic_password():\n33\t    \"\"\"Fetch the elastic-user password from its secret (base64-decoded), or None.\"\"\"\n34\t    import base64\n35\t    r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", PASSWORD_SECRET,\n36\t             \"-o\", \"jsonpath={.data.\" + PASSWORD_KEY + \"}\"])\n37\t    if r.returncode != 0 or not r.stdout.strip():\n38\t        return None\n39\t    try:\n40\t        return base64.b64decode(r.stdout.strip()).decode()\n41\t    except Exception:\n42\t        return None\n43\t\n44\t\n45\tELASTIC_PASSWORD = None  # set in main() once kubectl is reachable\n46\t\n47\t\n48\t_APP_LABEL = None\n49\t\n50\t\n51\tdef resolve_app_label():\n52\t    \"\"\"Resolve the 'app=<value>' selector for the live ES pods.\n53\t\n54\t    Priority: the BENCH_PARAM_CLUSTER_PREFIX hint when some live StatefulSet\n55\t    actually selects on app=<hint> (explicit override wins) -> the app label of\n56\t    the namespace's Elasticsearch StatefulSet detected live -> the hint.\n57\t    Workflow-agnostic: adapts to an inherited cluster labelled e.g.\n58\t    app=elasticsearch instead of app=es-cluster.\n59\t    \"\"\"\n60\t    global _APP_LABEL\n61\t    if _APP_LABEL is not None:\n62\t        return _APP_LABEL\n63\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n64\t    labels = []\n65\t    if res.returncode == 0:\n66\t        try:\n67\t            for sts in json.loads(res.stdout).get(\"items\", []):\n68\t                spec = sts.get(\"spec\", {})\n69\t                containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n70\t                if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n71\t                    continue\n72\t                app = (spec.get(\"selector\", {}).get(\"matchLabels\", {}) or {}).get(\"app\")\n73\t                ts = sts.get(\"metadata\", {}).get(\"creationTimestamp\", \"\")\n74\t                if app:\n75\t                    labels.append((app, ts))\n76\t        except (json.JSONDecodeError, AttributeError):\n77\t            pass\n78\t    if any(app == CLUSTER_PREFIX_HINT for app, _ in labels):\n79\t        _APP_LABEL = f\"app={CLUSTER_PREFIX_HINT}\"\n80\t        return _APP_LABEL\n81\t    if labels:\n82\t        labels.sort(key=lambda x: (x[1] or \"\"))\n83\t        _APP_LABEL = f\"app={labels[0][0]}\"\n84\t        return _APP_LABEL\n85\t    _APP_LABEL = f\"app={CLUSTER_PREFIX_HINT}\"\n86\t    return _APP_LABEL\n87\t\n88\t\n89\tAPP_LABEL = resolve_app_label()\n90\t\n91\t\n92\tdef _list_es_statefulset_replicas():\n93\t    \"\"\"Return {sts_name: spec.replicas} for the namespace's Elasticsearch\n94\t    StatefulSets (those whose pod template runs an Elasticsearch image).\"\"\"\n95\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n96\t    if res.returncode != 0:\n97\t        return {}\n98\t    try:\n99\t        items = json.loads(res.stdout).get(\"items\", [])\n100\t    except (json.JSONDecodeError, AttributeError):\n101\t        return {}\n102\t    out = {}\n103\t    for sts in items:\n104\t        spec = sts.get(\"spec\", {})\n105\t        containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n106\t        if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n107\t            continue\n108\t        name = sts.get(\"metadata\", {}).get(\"name\")\n109\t        replicas = spec.get(\"replicas\")\n110\t        if name and isinstance(replicas, int):\n111\t            out[name] = replicas\n112\t    return out\n113\t\n114\t\n115\tdef _sts_name_for_node(node_name):\n116\t    \"\"\"Map a live ES node name to its backing StatefulSet name.\n117\t\n118\t    An ES node name equals its pod name, which for a StatefulSet pod is\n119\t    ``<statefulset-name>-<ordinal>`` (e.g. ``es-cluster-0`` -> ``es-cluster``,\n120\t    ``es-data-1`` -> ``es-data``). Strip the trailing ``-<digits>`` ordinal.\n121\t    Returns the node name unchanged if it carries no ordinal suffix.\n122\t    \"\"\"\n123\t    if not node_name:\n124\t        return node_name\n125\t    return re.sub(r\"-\\d+$\", \"\", node_name)\n126\t\n127\t\n128\tdef _live_sts_names(node_names):\n129\t    \"\"\"Set of StatefulSet names actually backing the live cluster nodes.\n130\t\n131\t    Derived by stripping each live node name's ordinal. This excludes\n132\t    accumulated/stale/other ES StatefulSets in the (persisted) namespace that\n133\t    back no node in the queried cluster.\n134\t    \"\"\"\n135\t    return {_sts_name_for_node(n) for n in node_names if n}\n136\t\n137\t\n138\tdef _resolve_expected_nodes(node_names, default=3):\n139\t    \"\"\"Expected node count to enforce, derived from the LIVE cluster.\n140\t\n141\t    The expected total is the DESIRED topology of ONLY the StatefulSets that\n142\t    actually back the live cluster (the nodes returned by ``_cat/nodes``): the\n143\t    sum of spec.replicas over just those StatefulSets. The namespace PERSISTS\n144\t    across workflow stages and accumulates multiple ES clusters, so summing\n145\t    replicas across *every* ES StatefulSet overcounts versus the single cluster\n146\t    the oracle queries. Restricting to the live cluster's StatefulSets fixes that.\n147\t\n148\t    Using DESIRED spec.replicas (not the live count) keeps the check strict: a\n149\t    node that FAILED to join leaves its StatefulSet \"live\" (siblings are up) but\n150\t    absent from ``_cat/nodes``, so EXPECTED stays above the actual count -- no\n151\t    masking. Param override is honored FIRST; falls back to ``default`` when no\n152\t    live StatefulSets resolve (e.g. _cat/nodes failed or returned empty).\n153\t    \"\"\"\n154\t    for key in (\"BENCH_PARAM_EXPECTED_NODE_COUNT\", \"BENCH_PARAM_EXPECTED_NODES\"):\n155\t        val = os.environ.get(key)\n156\t        if val is not None and str(val).strip():\n157\t            try:\n158\t                return int(val)\n159\t            except ValueError:\n160\t                pass\n161\t    # Robust count: sum spec.replicas over ES StatefulSets that are actually\n162\t    # present (status.replicas > 0). Counts the base cluster + any scaled-up\n163\t    # nodeset WITHOUT the fragile node.name -> StatefulSet string mapping (which\n164\t    # breaks when a nodeset's node.name differs from its pod name). A torn-down\n165\t    # prior cluster's StatefulSet has readyReplicas 0 and is excluded. Still\n166\t    # strict: a node that failed to join leaves its STS ready>0 but short, so the\n167\t    # spec-replica sum exceeds the live node count and the check still fails.\n168\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n169\t    if res.returncode == 0:\n170\t        try:\n171\t            items = json.loads(res.stdout).get(\"items\", [])\n172\t        except Exception:\n173\t            items = []\n174\t        desired = 0\n175\t        for sts in items:\n176\t            spec = sts.get(\"spec\", {}) or {}\n177\t            containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", []) or []\n178\t            if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n179\t                continue\n180\t            replicas = spec.get(\"replicas\")\n181\t            # Use status.replicas (pods that EXIST), not readyReplicas: a\n182\t            # scaled-up nodeset whose pods joined the cluster but lack a passing\n183\t            # STS readiness probe has readyReplicas 0 yet is genuinely live.\n184\t            # Count an ES StatefulSet's DESIRED replicas when it is an active part\n185\t            # of the cluster: spec.replicas > 0 and not being torn down. Gating on\n186\t            # status.replicas undercounts a freshly scaled-up nodeset whose status\n187\t            # lags -- its pods have joined the cluster but status.replicas is still\n188\t            # 0 -- which wrongly made EXPECTED < the live node count.\n189\t            being_deleted = (sts.get(\"metadata\", {}) or {}).get(\"deletionTimestamp\") is not None\n190\t            if isinstance(replicas, int) and replicas > 0 and not being_deleted:\n191\t                desired += replicas\n192\t        if desired > 0:\n193\t            return desired\n194\t    return default\n195\t\n196\t\n197\tdef _probe_scheme(scheme):\n198\t    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\"\"\"\n199\t    result = run([\n200\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\",\n201\t        \"curl\", \"-s\", \"-S\", \"-k\", \"-o\", \"/dev/null\",\n202\t        \"-w\", \"%{http_code}\", \"--max-time\", \"5\", f\"{scheme}://{SERVICE}:9200/\",\n203\t    ])\n204\t    code = (result.stdout or \"\").strip()\n205\t    return result.returncode == 0 and code.isdigit() and code != \"000\"\n206\t\n207\t\n208\tdef detect_scheme():\n209\t    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n210\t    global _SCHEME\n211\t    if _SCHEME is not None:\n212\t        return _SCHEME\n213\t    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n214\t        if _probe_scheme(scheme):\n215\t            _SCHEME = scheme\n216\t            return _SCHEME\n217\t    _SCHEME = DEFAULT_SCHEME\n218\t    return _SCHEME\n219\t\n220\t\n221\tdef curl_json(path, errors):\n222\t    scheme = detect_scheme()\n223\t    # The client deadline must exceed any server-side ``wait_for`` in `path`,\n224\t    # otherwise curl aborts (exit 28) before ES can answer. The retry loop in\n225\t    # main() does the real waiting, so each call's server wait stays short (10s)\n226\t    # and --max-time (20) comfortably exceeds it.\n227\t    cmd = [\n228\t        \"kubectl\",\n229\t        \"-n\",\n230\t        NAMESPACE,\n231\t        \"exec\",\n232\t        \"curl-test\",\n233\t        \"--\",\n234\t        \"curl\",\n235\t        \"-s\",\n236\t        \"-S\",\n237\t        \"-k\",\n238\t    ]\n239\t    if ELASTIC_PASSWORD:\n240\t        cmd += [\"-u\", f\"elastic:{ELASTIC_PASSWORD}\"]\n241\t    cmd += [\n242\t        \"--max-time\",\n243\t        \"20\",\n244\t        f\"{scheme}://{SERVICE}:9200{path}\",\n245\t    ]\n246\t    result = run(cmd)\n247\t    if result.returncode != 0:\n248\t        detail = result.stderr.strip() or result.stdout.strip() or f\"command terminated with exit code {result.returncode}\"\n249\t        errors.append(f\"Failed to query {path}: {detail}\")\n250\t        return None\n251\t    output = result.stdout.strip()\n252\t    if not output:\n253\t        errors.append(f\"Empty response for {path}\")\n254\t        return None\n255\t    try:\n256\t        return json.loads(output)\n257\t    except json.JSONDecodeError:\n258\t        errors.append(f\"Failed to parse JSON from {path}\")\n259\t        return None\n260\t\n261\t\n262\tdef evaluate():\n263\t    \"\"\"Run one full snapshot of the seed-hosts checks; return the list of errors.\"\"\"\n264\t    errors = []\n265\t\n266\t    # Resolve the live cluster's node list FIRST: the expected node count is\n267\t    # derived from only the StatefulSets that actually back these live nodes\n268\t    # (the persisted namespace accumulates several ES clusters across stages, so\n269\t    # summing every ES StatefulSet's replicas overcounts the queried cluster).\n270\t    nodes = curl_json(\"/_cat/nodes?format=json\", errors)\n271\t    node_names = []\n272\t    if isinstance(nodes, list):\n273\t        node_names = [n.get(\"name\") for n in nodes if n.get(\"name\")]\n274\t    expected_nodes = _resolve_expected_nodes(node_names, default=3)\n275\t\n276\t    health = curl_json(\n277\t        f\"/_cluster/health?wait_for_status=yellow&wait_for_nodes={expected_nodes}&timeout=10s\",\n278\t        errors,\n279\t    )\n280\t    if isinstance(health, dict):\n281\t        status = health.get(\"status\")\n282\t        if status not in {\"yellow\", \"green\"}:\n283\t            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n284\t        if health.get(\"number_of_nodes\") != expected_nodes:\n285\t            errors.append(\n286\t                f\"Expected {expected_nodes} nodes, got {health.get('number_of_nodes')}\"\n287\t            )\n288\t\n289\t    if isinstance(nodes, list):\n290\t        if len(node_names) != expected_nodes:\n291\t            errors.append(f\"Expected {expected_nodes} nodes in _cat/nodes, got {len(node_names)}\")\n292\t\n293\t    count = curl_json(f\"/{INDEX}/_count\", errors)\n294\t    if isinstance(count, dict):\n295\t        if \"count\" not in count:\n296\t            errors.append(\"Unable to verify app-data count\")\n297\t\n298\t    return errors\n299\t\n300\t\n301\tdef main():\n302\t    global ELASTIC_PASSWORD\n303\t    ELASTIC_PASSWORD = _elastic_password()\n304\t\n305\t    # A multi-node ES cluster can flap at the edge of readiness under load: a\n306\t    # node briefly drops from the cluster during GC or shard recovery even though\n307\t    # it is stably green. A single snapshot can catch that transient and report a\n308\t    # false node-count miss. So verify the STABLE converged state: re-evaluate for\n309\t    # up to ~75s and pass on the first clean snapshot. This does not loosen the\n310\t    # N-node/green requirement -- a genuinely degraded cluster fails every attempt.\n311\t    import time\n312\t    deadline = time.monotonic() + 75\n313\t    errors = evaluate()\n314\t    while errors and time.monotonic() < deadline:\n315\t        time.sleep(8)\n316\t        errors = evaluate()\n317\t\n318\t    if errors:\n319\t        print(\"Seed hosts repair verification failed:\", file=sys.stderr)\n320\t        for err in errors:\n321\t            print(f\"  - {err}\", file=sys.stderr)\n322\t        return 1\n323\t\n324\t    print(\"Seed hosts repair verified\")\n325\t    return 0\n326\t\n327\t\n328\tif __name__ == \"__main__\":\n329\t    sys.exit(main())\n330\t"}]},"parent_tool_use_id":null,"session_id":"a9894363-34c2-4ba1-a8f4-f8ca4b3b113b","uuid":"5d585cf1-0009-46c3-b590-7ed0c24749ed","timestamp":"2026-06-17T09:12:39.723Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/elasticsearch/seed-hosts-repair/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport json\nimport os\nimport re\nimport subprocess\nimport sys\n\nNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"elasticsearch\")\nSERVICE = os.environ.get(\"BENCH_PARAM_HTTP_SERVICE_NAME\", \"es-http\")\n# ES 8.x runs with security enabled, so the HTTPS API requires authenticating as\n# the elastic superuser. When this case inherits a secured cluster from an\n# earlier workflow stage, read its password from the secret that stage created\n# so the oracle's queries aren't rejected with 401. Absent secret -> None -> no\n# -u, so a standalone unsecured cluster still works.\nPASSWORD_SECRET = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_SECRET_NAME\", \"elastic-password\")\nPASSWORD_KEY = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_KEY\", \"password\")\n# Hint for the Elasticsearch pod app label. Used as an override when it matches a\n# live StatefulSet's selector; otherwise the real selector label is detected\n# live from the cluster. The env PERSISTS across stages, so a workflow's\n# inherited ES cluster may label its pods differently than this case's standalone\n# default of 'es-cluster'.\nCLUSTER_PREFIX_HINT = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"es-cluster\")\nINDEX = os.environ.get(\"BENCH_PARAM_INDEX_NAME\", \"app-data\")\nDEFAULT_SCHEME = \"http\"\n_SCHEME = None\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef _elastic_password():\n    \"\"\"Fetch the elastic-user password from its secret (base64-decoded), or None.\"\"\"\n    import base64\n    r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", PASSWORD_SECRET,\n             \"-o\", \"jsonpath={.data.\" + PASSWORD_KEY + \"}\"])\n    if r.returncode != 0 or not r.stdout.strip():\n        return None\n    try:\n        return base64.b64decode(r.stdout.strip()).decode()\n    except Exception:\n        return None\n\n\nELASTIC_PASSWORD = None  # set in main() once kubectl is reachable\n\n\n_APP_LABEL = None\n\n\ndef resolve_app_label():\n    \"\"\"Resolve the 'app=<value>' selector for the live ES pods.\n\n    Priority: the BENCH_PARAM_CLUSTER_PREFIX hint when some live StatefulSet\n    actually selects on app=<hint> (explicit override wins) -> the app label of\n    the namespace's Elasticsearch StatefulSet detected live -> the hint.\n    Workflow-agnostic: adapts to an inherited cluster labelled e.g.\n    app=elasticsearch instead of app=es-cluster.\n    \"\"\"\n    global _APP_LABEL\n    if _APP_LABEL is not None:\n        return _APP_LABEL\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n    labels = []\n    if res.returncode == 0:\n        try:\n            for sts in json.loads(res.stdout).get(\"items\", []):\n                spec = sts.get(\"spec\", {})\n                containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n                if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n                    continue\n                app = (spec.get(\"selector\", {}).get(\"matchLabels\", {}) or {}).get(\"app\")\n                ts = sts.get(\"metadata\", {}).get(\"creationTimestamp\", \"\")\n                if app:\n                    labels.append((app, ts))\n        except (json.JSONDecodeError, AttributeError):\n            pass\n    if any(app == CLUSTER_PREFIX_HINT for app, _ in labels):\n        _APP_LABEL = f\"app={CLUSTER_PREFIX_HINT}\"\n        return _APP_LABEL\n    if labels:\n        labels.sort(key=lambda x: (x[1] or \"\"))\n        _APP_LABEL = f\"app={labels[0][0]}\"\n        return _APP_LABEL\n    _APP_LABEL = f\"app={CLUSTER_PREFIX_HINT}\"\n    return _APP_LABEL\n\n\nAPP_LABEL = resolve_app_label()\n\n\ndef _list_es_statefulset_replicas():\n    \"\"\"Return {sts_name: spec.replicas} for the namespace's Elasticsearch\n    StatefulSets (those whose pod template runs an Elasticsearch image).\"\"\"\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n    if res.returncode != 0:\n        return {}\n    try:\n        items = json.loads(res.stdout).get(\"items\", [])\n    except (json.JSONDecodeError, AttributeError):\n        return {}\n    out = {}\n    for sts in items:\n        spec = sts.get(\"spec\", {})\n        containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n        if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n            continue\n        name = sts.get(\"metadata\", {}).get(\"name\")\n        replicas = spec.get(\"replicas\")\n        if name and isinstance(replicas, int):\n            out[name] = replicas\n    return out\n\n\ndef _sts_name_for_node(node_name):\n    \"\"\"Map a live ES node name to its backing StatefulSet name.\n\n    An ES node name equals its pod name, which for a StatefulSet pod is\n    ``<statefulset-name>-<ordinal>`` (e.g. ``es-cluster-0`` -> ``es-cluster``,\n    ``es-data-1`` -> ``es-data``). Strip the trailing ``-<digits>`` ordinal.\n    Returns the node name unchanged if it carries no ordinal suffix.\n    \"\"\"\n    if not node_name:\n        return node_name\n    return re.sub(r\"-\\d+$\", \"\", node_name)\n\n\ndef _live_sts_names(node_names):\n    \"\"\"Set of StatefulSet names actually backing the live cluster nodes.\n\n    Derived by stripping each live node name's ordinal. This excludes\n    accumulated/stale/other ES StatefulSets in the (persisted) namespace that\n    back no node in the queried cluster.\n    \"\"\"\n    return {_sts_name_for_node(n) for n in node_names if n}\n\n\ndef _resolve_expected_nodes(node_names, default=3):\n    \"\"\"Expected node count to enforce, derived from the LIVE cluster.\n\n    The expected total is the DESIRED topology of ONLY the StatefulSets that\n    actually back the live cluster (the nodes returned by ``_cat/nodes``): the\n    sum of spec.replicas over just those StatefulSets. The namespace PERSISTS\n    across workflow stages and accumulates multiple ES clusters, so summing\n    replicas across *every* ES StatefulSet overcounts versus the single cluster\n    the oracle queries. Restricting to the live cluster's StatefulSets fixes that.\n\n    Using DESIRED spec.replicas (not the live count) keeps the check strict: a\n    node that FAILED to join leaves its StatefulSet \"live\" (siblings are up) but\n    absent from ``_cat/nodes``, so EXPECTED stays above the actual count -- no\n    masking. Param override is honored FIRST; falls back to ``default`` when no\n    live StatefulSets resolve (e.g. _cat/nodes failed or returned empty).\n    \"\"\"\n    for key in (\"BENCH_PARAM_EXPECTED_NODE_COUNT\", \"BENCH_PARAM_EXPECTED_NODES\"):\n        val = os.environ.get(key)\n        if val is not None and str(val).strip():\n            try:\n                return int(val)\n            except ValueError:\n                pass\n    # Robust count: sum spec.replicas over ES StatefulSets that are actually\n    # present (status.replicas > 0). Counts the base cluster + any scaled-up\n    # nodeset WITHOUT the fragile node.name -> StatefulSet string mapping (which\n    # breaks when a nodeset's node.name differs from its pod name). A torn-down\n    # prior cluster's StatefulSet has readyReplicas 0 and is excluded. Still\n    # strict: a node that failed to join leaves its STS ready>0 but short, so the\n    # spec-replica sum exceeds the live node count and the check still fails.\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n    if res.returncode == 0:\n        try:\n            items = json.loads(res.stdout).get(\"items\", [])\n        except Exception:\n            items = []\n        desired = 0\n        for sts in items:\n            spec = sts.get(\"spec\", {}) or {}\n            containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", []) or []\n            if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n                continue\n            replicas = spec.get(\"replicas\")\n            # Use status.replicas (pods that EXIST), not readyReplicas: a\n            # scaled-up nodeset whose pods joined the cluster but lack a passing\n            # STS readiness probe has readyReplicas 0 yet is genuinely live.\n            # Count an ES StatefulSet's DESIRED replicas when it is an active part\n            # of the cluster: spec.replicas > 0 and not being torn down. Gating on\n            # status.replicas undercounts a freshly scaled-up nodeset whose status\n            # lags -- its pods have joined the cluster but status.replicas is still\n            # 0 -- which wrongly made EXPECTED < the live node count.\n            being_deleted = (sts.get(\"metadata\", {}) or {}).get(\"deletionTimestamp\") is not None\n            if isinstance(replicas, int) and replicas > 0 and not being_deleted:\n                desired += replicas\n        if desired > 0:\n            return desired\n    return default\n\n\ndef _probe_scheme(scheme):\n    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\"\"\"\n    result = run([\n        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\",\n        \"curl\", \"-s\", \"-S\", \"-k\", \"-o\", \"/dev/null\",\n        \"-w\", \"%{http_code}\", \"--max-time\", \"5\", f\"{scheme}://{SERVICE}:9200/\",\n    ])\n    code = (result.stdout or \"\").strip()\n    return result.returncode == 0 and code.isdigit() and code != \"000\"\n\n\ndef detect_scheme():\n    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n    global _SCHEME\n    if _SCHEME is not None:\n        return _SCHEME\n    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n        if _probe_scheme(scheme):\n            _SCHEME = scheme\n            return _SCHEME\n    _SCHEME = DEFAULT_SCHEME\n    return _SCHEME\n\n\ndef curl_json(path, errors):\n    scheme = detect_scheme()\n    # The client deadline must exceed any server-side ``wait_for`` in `path`,\n    # otherwise curl aborts (exit 28) before ES can answer. The retry loop in\n    # main() does the real waiting, so each call's server wait stays short (10s)\n    # and --max-time (20) comfortably exceeds it.\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"exec\",\n        \"curl-test\",\n        \"--\",\n        \"curl\",\n        \"-s\",\n        \"-S\",\n        \"-k\",\n    ]\n    if ELASTIC_PASSWORD:\n        cmd += [\"-u\", f\"elastic:{ELASTIC_PASSWORD}\"]\n    cmd += [\n        \"--max-time\",\n        \"20\",\n        f\"{scheme}://{SERVICE}:9200{path}\",\n    ]\n    result = run(cmd)\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"command terminated with exit code {result.returncode}\"\n        errors.append(f\"Failed to query {path}: {detail}\")\n        return None\n    output = result.stdout.strip()\n    if not output:\n        errors.append(f\"Empty response for {path}\")\n        return None\n    try:\n        return json.loads(output)\n    except json.JSONDecodeError:\n        errors.append(f\"Failed to parse JSON from {path}\")\n        return None\n\n\ndef evaluate():\n    \"\"\"Run one full snapshot of the seed-hosts checks; return the list of errors.\"\"\"\n    errors = []\n\n    # Resolve the live cluster's node list FIRST: the expected node count is\n    # derived from only the StatefulSets that actually back these live nodes\n    # (the persisted namespace accumulates several ES clusters across stages, so\n    # summing every ES StatefulSet's replicas overcounts the queried cluster).\n    nodes = curl_json(\"/_cat/nodes?format=json\", errors)\n    node_names = []\n    if isinstance(nodes, list):\n        node_names = [n.get(\"name\") for n in nodes if n.get(\"name\")]\n    expected_nodes = _resolve_expected_nodes(node_names, default=3)\n\n    health = curl_json(\n        f\"/_cluster/health?wait_for_status=yellow&wait_for_nodes={expected_nodes}&timeout=10s\",\n        errors,\n    )\n    if isinstance(health, dict):\n        status = health.get(\"status\")\n        if status not in {\"yellow\", \"green\"}:\n            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n        if health.get(\"number_of_nodes\") != expected_nodes:\n            errors.append(\n                f\"Expected {expected_nodes} nodes, got {health.get('number_of_nodes')}\"\n            )\n\n    if isinstance(nodes, list):\n        if len(node_names) != expected_nodes:\n            errors.append(f\"Expected {expected_nodes} nodes in _cat/nodes, got {len(node_names)}\")\n\n    count = curl_json(f\"/{INDEX}/_count\", errors)\n    if isinstance(count, dict):\n        if \"count\" not in count:\n            errors.append(\"Unable to verify app-data count\")\n\n    return errors\n\n\ndef main():\n    global ELASTIC_PASSWORD\n    ELASTIC_PASSWORD = _elastic_password()\n\n    # A multi-node ES cluster can flap at the edge of readiness under load: a\n    # node briefly drops from the cluster during GC or shard recovery even though\n    # it is stably green. A single snapshot can catch that transient and report a\n    # false node-count miss. So verify the STABLE converged state: re-evaluate for\n    # up to ~75s and pass on the first clean snapshot. This does not loosen the\n    # N-node/green requirement -- a genuinely degraded cluster fails every attempt.\n    import time\n    deadline = time.monotonic() + 75\n    errors = evaluate()\n    while errors and time.monotonic() < deadline:\n        time.sleep(8)\n        errors = evaluate()\n\n    if errors:\n        print(\"Seed hosts repair verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    print(\"Seed hosts repair verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":330,"startLine":1,"totalLines":330}}}
