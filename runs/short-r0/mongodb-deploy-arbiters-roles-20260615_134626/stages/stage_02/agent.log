{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HNWK8G82VjxvuR21rYceCq","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport argparse\n3\timport json\n4\timport os\n5\timport subprocess\n6\timport sys\n7\t\n8\t\n9\tNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"mongodb\")\n10\tDATA_CLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_DATA_CLUSTER_PREFIX\", \"mongo-rs\")\n11\tDATA_SERVICE = os.environ.get(\"BENCH_PARAM_DATA_SERVICE_NAME\", \"mongo\")\n12\tARBITER_CLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_ARBITER_CLUSTER_PREFIX\", \"mongo-arb\")\n13\tARBITER_SERVICE = os.environ.get(\"BENCH_PARAM_ARBITER_SERVICE_NAME\", \"mongo-arb\")\n14\tDATA_REPLICAS = int(os.environ.get(\"BENCH_PARAM_DATA_REPLICAS\", \"2\"))\n15\tARBITER_REPLICAS = int(os.environ.get(\"BENCH_PARAM_ARBITER_REPLICAS\", \"1\"))\n16\tAPP_DATABASE = os.environ.get(\"BENCH_PARAM_APP_DATABASE\", \"app\")\n17\tAPP_COLLECTION = os.environ.get(\"BENCH_PARAM_APP_COLLECTION\", \"test\")\n18\tSEED_DOCS = int(os.environ.get(\"BENCH_PARAM_SEED_DOCS\", \"3\"))\n19\t\n20\t\n21\tdef run(cmd):\n22\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n23\t\n24\t\n25\t_TLS_FLAGS_CACHE = None\n26\t\n27\t\n28\tdef _mongo_tls_flags(probe_pod=None):\n29\t    \"\"\"mongosh transport flags that adapt to the cluster's LIVE TLS mode.\n30\t\n31\t    The environment PERSISTS across workflow stages, so an earlier stage\n32\t    (mongodb/tls-setup or mongodb/certificate-rotation) may have turned TLS on,\n33\t    after which a plain mongosh connection is refused. Detect TLS by probing the\n34\t    running mongo pod for a CA cert mounted at the paths the TLS stages use; if\n35\t    present, connect with --tls --tlsCAFile (and a client cert for mutual TLS\n36\t    when one is mounted), else connect plain. Standalone (no CA mounted) this\n37\t    returns [] -> identical plain behaviour. It only adds transport flags; every\n38\t    real check still runs and still fails when its condition is unmet.\n39\t    \"\"\"\n40\t    global _TLS_FLAGS_CACHE\n41\t    if _TLS_FLAGS_CACHE is not None:\n42\t        return list(_TLS_FLAGS_CACHE)\n43\t    flags = []\n44\t    pod = probe_pod or f\"{DATA_CLUSTER_PREFIX}-0\"\n45\t    ca_path = None\n46\t    for cand in (\n47\t        \"/etc/tls/ca.crt\",\n48\t        \"/etc/mongo-ca/ca.crt\",\n49\t        \"/etc/mongodb/tls/ca.crt\",\n50\t        \"/etc/ssl/mongodb/ca.crt\",\n51\t    ):\n52\t        probe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + cand])\n53\t        if probe.returncode == 0:\n54\t            ca_path = cand\n55\t            break\n56\t    if ca_path:\n57\t        flags = [\"--tls\", \"--tlsAllowInvalidHostnames\", \"--tlsCAFile\", ca_path]\n58\t        for client_pem in (\"/etc/tls/client.pem\", \"/etc/mongo-ca/client.pem\"):\n59\t            cprobe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + client_pem])\n60\t            if cprobe.returncode == 0:\n61\t                flags += [\"--tlsCertificateKeyFile\", client_pem]\n62\t                break\n63\t    _TLS_FLAGS_CACHE = flags\n64\t    return list(flags)\n65\t\n66\tdef fail(prefix, errors):\n67\t    if errors:\n68\t        print(prefix, file=sys.stderr)\n69\t        for err in errors:\n70\t            print(f\"  - {err}\", file=sys.stderr)\n71\t        return 1\n72\t    return 0\n73\t\n74\t\n75\tdef mongo_eval(pod, script):\n76\t    return run(\n77\t        [\n78\t            \"kubectl\",\n79\t            \"-n\",\n80\t            NAMESPACE,\n81\t            \"exec\",\n82\t            pod,\n83\t            \"--\",\n84\t            \"mongosh\",\n85\t            \"--quiet\",\n86\t            *_mongo_tls_flags(),\n87\t            \"--eval\",\n88\t            script,\n89\t        ]\n90\t    )\n91\t\n92\t\n93\tdef mongo_json(pod, script, label, errors):\n94\t    res = mongo_eval(pod, script)\n95\t    if res.returncode != 0:\n96\t        detail = res.stderr.strip() or res.stdout.strip() or f\"exit {res.returncode}\"\n97\t        errors.append(f\"{label} failed on {pod}: {detail}\")\n98\t        return None\n99\t    raw = (res.stdout or \"\").strip()\n100\t    if not raw:\n101\t        errors.append(f\"{label} returned empty output on {pod}\")\n102\t        return None\n103\t    try:\n104\t        return json.loads(raw)\n105\t    except json.JSONDecodeError:\n106\t        errors.append(f\"Unable to parse {label} JSON output on {pod}\")\n107\t        return None\n108\t\n109\t\n110\tdef check_workload():\n111\t    errors = []\n112\t    data_sts = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", DATA_CLUSTER_PREFIX, \"-o\", \"json\"])\n113\t    arb_sts = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", ARBITER_CLUSTER_PREFIX, \"-o\", \"json\"])\n114\t    if data_sts.returncode != 0:\n115\t        detail = data_sts.stderr.strip() or data_sts.stdout.strip() or f\"exit {data_sts.returncode}\"\n116\t        errors.append(f\"Failed to read data statefulset: {detail}\")\n117\t    else:\n118\t        try:\n119\t            data_obj = json.loads(data_sts.stdout)\n120\t        except json.JSONDecodeError:\n121\t            errors.append(\"Failed to parse data statefulset JSON\")\n122\t            data_obj = {}\n123\t        if data_obj.get(\"spec\", {}).get(\"replicas\") != DATA_REPLICAS:\n124\t            errors.append(f\"Data StatefulSet replicas expected {DATA_REPLICAS}\")\n125\t        if data_obj.get(\"status\", {}).get(\"readyReplicas\", 0) != DATA_REPLICAS:\n126\t            errors.append(f\"Data StatefulSet ready replicas expected {DATA_REPLICAS}\")\n127\t\n128\t    if arb_sts.returncode != 0:\n129\t        detail = arb_sts.stderr.strip() or arb_sts.stdout.strip() or f\"exit {arb_sts.returncode}\"\n130\t        errors.append(f\"Failed to read arbiter statefulset: {detail}\")\n131\t    else:\n132\t        try:\n133\t            arb_obj = json.loads(arb_sts.stdout)\n134\t        except json.JSONDecodeError:\n135\t            errors.append(\"Failed to parse arbiter statefulset JSON\")\n136\t            arb_obj = {}\n137\t        if arb_obj.get(\"spec\", {}).get(\"replicas\") != ARBITER_REPLICAS:\n138\t            errors.append(f\"Arbiter StatefulSet replicas expected {ARBITER_REPLICAS}\")\n139\t        if arb_obj.get(\"status\", {}).get(\"readyReplicas\", 0) != ARBITER_REPLICAS:\n140\t            errors.append(f\"Arbiter StatefulSet ready replicas expected {ARBITER_REPLICAS}\")\n141\t\n142\t    return fail(\"MongoDB arbiters workload check failed:\", errors)\n143\t\n144\t\n145\tdef check_topology():\n146\t    errors = []\n147\t    pod = f\"{DATA_CLUSTER_PREFIX}-0\"\n148\t    conf = mongo_json(pod, \"JSON.stringify(rs.conf())\", \"rs.conf()\", errors)\n149\t    if isinstance(conf, dict):\n150\t        members = conf.get(\"members\", [])\n151\t        if len(members) != DATA_REPLICAS + ARBITER_REPLICAS:\n152\t            errors.append(f\"Expected {DATA_REPLICAS + ARBITER_REPLICAS} members, got {len(members)}\")\n153\t        arbiters = [m for m in members if m.get(\"arbiterOnly\") is True]\n154\t        data_members = [m for m in members if m.get(\"arbiterOnly\") is not True]\n155\t        if len(arbiters) != ARBITER_REPLICAS:\n156\t            errors.append(f\"Expected {ARBITER_REPLICAS} arbiter member, got {len(arbiters)}\")\n157\t        if len(data_members) != DATA_REPLICAS:\n158\t            errors.append(f\"Expected {DATA_REPLICAS} data members, got {len(data_members)}\")\n159\t        expected_arb_host = f\"{ARBITER_CLUSTER_PREFIX}-0.{ARBITER_SERVICE}.{NAMESPACE}.svc.cluster.local:27017\"\n160\t        arb_hosts = {m.get(\"host\") for m in arbiters if m.get(\"host\")}\n161\t        if expected_arb_host not in arb_hosts:\n162\t            errors.append(f\"Arbiter host missing from rs.conf(): {expected_arb_host}\")\n163\t\n164\t    status = mongo_json(pod, \"JSON.stringify(rs.status())\", \"rs.status()\", errors)\n165\t    if isinstance(status, dict):\n166\t        members = status.get(\"members\", [])\n167\t        primary = sum(1 for m in members if m.get(\"stateStr\") == \"PRIMARY\")\n168\t        secondary = sum(1 for m in members if m.get(\"stateStr\") == \"SECONDARY\")\n169\t        arbiters = sum(1 for m in members if m.get(\"stateStr\") == \"ARBITER\")\n170\t        if primary != 1:\n171\t            errors.append(f\"Expected 1 PRIMARY, got {primary}\")\n172\t        if secondary != DATA_REPLICAS - 1:\n173\t            errors.append(f\"Expected {DATA_REPLICAS - 1} SECONDARY, got {secondary}\")\n174\t        if arbiters != ARBITER_REPLICAS:\n175\t            errors.append(f\"Expected {ARBITER_REPLICAS} ARBITER, got {arbiters}\")\n176\t\n177\t    expected_data_hosts = {\n178\t        f\"{DATA_CLUSTER_PREFIX}-{i}.{DATA_SERVICE}.{NAMESPACE}.svc.cluster.local:27017\"\n179\t        for i in range(DATA_REPLICAS)\n180\t    }\n181\t    if isinstance(conf, dict):\n182\t        data_hosts = {m.get(\"host\") for m in conf.get(\"members\", []) if m.get(\"arbiterOnly\") is not True}\n183\t        if data_hosts != expected_data_hosts:\n184\t            errors.append(f\"Data member hosts mismatch: expected={sorted(expected_data_hosts)} actual={sorted(data_hosts)}\")\n185\t\n186\t    return fail(\"MongoDB arbiters topology check failed:\", errors)\n187\t\n188\t\n189\tdef check_data():\n190\t    errors = []\n191\t    pod = f\"{DATA_CLUSTER_PREFIX}-0\"\n192\t    res = mongo_eval(\n193\t        pod,\n194\t        f\"db.getSiblingDB('{APP_DATABASE}').{APP_COLLECTION}.countDocuments({{}})\",\n195\t    )\n196\t    if res.returncode != 0:\n197\t        detail = res.stderr.strip() or res.stdout.strip() or f\"exit {res.returncode}\"\n198\t        errors.append(f\"Failed to read {APP_DATABASE}.{APP_COLLECTION}: {detail}\")\n199\t    else:\n200\t        raw = (res.stdout or \"\").strip()\n201\t        if not raw.isdigit() or int(raw) < SEED_DOCS:\n202\t            errors.append(f\"Expected >= {SEED_DOCS} docs in {APP_DATABASE}.{APP_COLLECTION}, got {raw}\")\n203\t\n204\t    return fail(\"MongoDB arbiters data check failed:\", errors)\n205\t\n206\t\n207\tdef main():\n208\t    parser = argparse.ArgumentParser()\n209\t    parser.add_argument(\"--check\", default=\"all\", choices=[\"all\", \"workload\", \"topology\", \"data\"])\n210\t    args = parser.parse_args()\n211\t\n212\t    if args.check == \"workload\":\n213\t        return check_workload()\n214\t    if args.check == \"topology\":\n215\t        return check_topology()\n216\t    if args.check == \"data\":\n217\t        return check_data()\n218\t\n219\t    for fn in (check_workload, check_topology, check_data):\n220\t        rc = fn()\n221\t        if rc != 0:\n222\t            return rc\n223\t    print(\"MongoDB arbiter addition verified\")\n224\t    return 0\n225\t\n226\t\n227\tif __name__ == \"__main__\":\n228\t    sys.exit(main())\n229\t"}]},"parent_tool_use_id":null,"session_id":"2c158b58-6e10-45bb-bf94-040297c49e79","uuid":"c34f3cc3-c21a-467c-990b-e05a324d01bc","timestamp":"2026-06-15T13:51:05.045Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/leo/Karma/cases/mongodb/arbiters/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport argparse\nimport json\nimport os\nimport subprocess\nimport sys\n\n\nNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"mongodb\")\nDATA_CLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_DATA_CLUSTER_PREFIX\", \"mongo-rs\")\nDATA_SERVICE = os.environ.get(\"BENCH_PARAM_DATA_SERVICE_NAME\", \"mongo\")\nARBITER_CLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_ARBITER_CLUSTER_PREFIX\", \"mongo-arb\")\nARBITER_SERVICE = os.environ.get(\"BENCH_PARAM_ARBITER_SERVICE_NAME\", \"mongo-arb\")\nDATA_REPLICAS = int(os.environ.get(\"BENCH_PARAM_DATA_REPLICAS\", \"2\"))\nARBITER_REPLICAS = int(os.environ.get(\"BENCH_PARAM_ARBITER_REPLICAS\", \"1\"))\nAPP_DATABASE = os.environ.get(\"BENCH_PARAM_APP_DATABASE\", \"app\")\nAPP_COLLECTION = os.environ.get(\"BENCH_PARAM_APP_COLLECTION\", \"test\")\nSEED_DOCS = int(os.environ.get(\"BENCH_PARAM_SEED_DOCS\", \"3\"))\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\n_TLS_FLAGS_CACHE = None\n\n\ndef _mongo_tls_flags(probe_pod=None):\n    \"\"\"mongosh transport flags that adapt to the cluster's LIVE TLS mode.\n\n    The environment PERSISTS across workflow stages, so an earlier stage\n    (mongodb/tls-setup or mongodb/certificate-rotation) may have turned TLS on,\n    after which a plain mongosh connection is refused. Detect TLS by probing the\n    running mongo pod for a CA cert mounted at the paths the TLS stages use; if\n    present, connect with --tls --tlsCAFile (and a client cert for mutual TLS\n    when one is mounted), else connect plain. Standalone (no CA mounted) this\n    returns [] -> identical plain behaviour. It only adds transport flags; every\n    real check still runs and still fails when its condition is unmet.\n    \"\"\"\n    global _TLS_FLAGS_CACHE\n    if _TLS_FLAGS_CACHE is not None:\n        return list(_TLS_FLAGS_CACHE)\n    flags = []\n    pod = probe_pod or f\"{DATA_CLUSTER_PREFIX}-0\"\n    ca_path = None\n    for cand in (\n        \"/etc/tls/ca.crt\",\n        \"/etc/mongo-ca/ca.crt\",\n        \"/etc/mongodb/tls/ca.crt\",\n        \"/etc/ssl/mongodb/ca.crt\",\n    ):\n        probe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + cand])\n        if probe.returncode == 0:\n            ca_path = cand\n            break\n    if ca_path:\n        flags = [\"--tls\", \"--tlsAllowInvalidHostnames\", \"--tlsCAFile\", ca_path]\n        for client_pem in (\"/etc/tls/client.pem\", \"/etc/mongo-ca/client.pem\"):\n            cprobe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + client_pem])\n            if cprobe.returncode == 0:\n                flags += [\"--tlsCertificateKeyFile\", client_pem]\n                break\n    _TLS_FLAGS_CACHE = flags\n    return list(flags)\n\ndef fail(prefix, errors):\n    if errors:\n        print(prefix, file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n    return 0\n\n\ndef mongo_eval(pod, script):\n    return run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"exec\",\n            pod,\n            \"--\",\n            \"mongosh\",\n            \"--quiet\",\n            *_mongo_tls_flags(),\n            \"--eval\",\n            script,\n        ]\n    )\n\n\ndef mongo_json(pod, script, label, errors):\n    res = mongo_eval(pod, script)\n    if res.returncode != 0:\n        detail = res.stderr.strip() or res.stdout.strip() or f\"exit {res.returncode}\"\n        errors.append(f\"{label} failed on {pod}: {detail}\")\n        return None\n    raw = (res.stdout or \"\").strip()\n    if not raw:\n        errors.append(f\"{label} returned empty output on {pod}\")\n        return None\n    try:\n        return json.loads(raw)\n    except json.JSONDecodeError:\n        errors.append(f\"Unable to parse {label} JSON output on {pod}\")\n        return None\n\n\ndef check_workload():\n    errors = []\n    data_sts = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", DATA_CLUSTER_PREFIX, \"-o\", \"json\"])\n    arb_sts = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", ARBITER_CLUSTER_PREFIX, \"-o\", \"json\"])\n    if data_sts.returncode != 0:\n        detail = data_sts.stderr.strip() or data_sts.stdout.strip() or f\"exit {data_sts.returncode}\"\n        errors.append(f\"Failed to read data statefulset: {detail}\")\n    else:\n        try:\n            data_obj = json.loads(data_sts.stdout)\n        except json.JSONDecodeError:\n            errors.append(\"Failed to parse data statefulset JSON\")\n            data_obj = {}\n        if data_obj.get(\"spec\", {}).get(\"replicas\") != DATA_REPLICAS:\n            errors.append(f\"Data StatefulSet replicas expected {DATA_REPLICAS}\")\n        if data_obj.get(\"status\", {}).get(\"readyReplicas\", 0) != DATA_REPLICAS:\n            errors.append(f\"Data StatefulSet ready replicas expected {DATA_REPLICAS}\")\n\n    if arb_sts.returncode != 0:\n        detail = arb_sts.stderr.strip() or arb_sts.stdout.strip() or f\"exit {arb_sts.returncode}\"\n        errors.append(f\"Failed to read arbiter statefulset: {detail}\")\n    else:\n        try:\n            arb_obj = json.loads(arb_sts.stdout)\n        except json.JSONDecodeError:\n            errors.append(\"Failed to parse arbiter statefulset JSON\")\n            arb_obj = {}\n        if arb_obj.get(\"spec\", {}).get(\"replicas\") != ARBITER_REPLICAS:\n            errors.append(f\"Arbiter StatefulSet replicas expected {ARBITER_REPLICAS}\")\n        if arb_obj.get(\"status\", {}).get(\"readyReplicas\", 0) != ARBITER_REPLICAS:\n            errors.append(f\"Arbiter StatefulSet ready replicas expected {ARBITER_REPLICAS}\")\n\n    return fail(\"MongoDB arbiters workload check failed:\", errors)\n\n\ndef check_topology():\n    errors = []\n    pod = f\"{DATA_CLUSTER_PREFIX}-0\"\n    conf = mongo_json(pod, \"JSON.stringify(rs.conf())\", \"rs.conf()\", errors)\n    if isinstance(conf, dict):\n        members = conf.get(\"members\", [])\n        if len(members) != DATA_REPLICAS + ARBITER_REPLICAS:\n            errors.append(f\"Expected {DATA_REPLICAS + ARBITER_REPLICAS} members, got {len(members)}\")\n        arbiters = [m for m in members if m.get(\"arbiterOnly\") is True]\n        data_members = [m for m in members if m.get(\"arbiterOnly\") is not True]\n        if len(arbiters) != ARBITER_REPLICAS:\n            errors.append(f\"Expected {ARBITER_REPLICAS} arbiter member, got {len(arbiters)}\")\n        if len(data_members) != DATA_REPLICAS:\n            errors.append(f\"Expected {DATA_REPLICAS} data members, got {len(data_members)}\")\n        expected_arb_host = f\"{ARBITER_CLUSTER_PREFIX}-0.{ARBITER_SERVICE}.{NAMESPACE}.svc.cluster.local:27017\"\n        arb_hosts = {m.get(\"host\") for m in arbiters if m.get(\"host\")}\n        if expected_arb_host not in arb_hosts:\n            errors.append(f\"Arbiter host missing from rs.conf(): {expected_arb_host}\")\n\n    status = mongo_json(pod, \"JSON.stringify(rs.status())\", \"rs.status()\", errors)\n    if isinstance(status, dict):\n        members = status.get(\"members\", [])\n        primary = sum(1 for m in members if m.get(\"stateStr\") == \"PRIMARY\")\n        secondary = sum(1 for m in members if m.get(\"stateStr\") == \"SECONDARY\")\n        arbiters = sum(1 for m in members if m.get(\"stateStr\") == \"ARBITER\")\n        if primary != 1:\n            errors.append(f\"Expected 1 PRIMARY, got {primary}\")\n        if secondary != DATA_REPLICAS - 1:\n            errors.append(f\"Expected {DATA_REPLICAS - 1} SECONDARY, got {secondary}\")\n        if arbiters != ARBITER_REPLICAS:\n            errors.append(f\"Expected {ARBITER_REPLICAS} ARBITER, got {arbiters}\")\n\n    expected_data_hosts = {\n        f\"{DATA_CLUSTER_PREFIX}-{i}.{DATA_SERVICE}.{NAMESPACE}.svc.cluster.local:27017\"\n        for i in range(DATA_REPLICAS)\n    }\n    if isinstance(conf, dict):\n        data_hosts = {m.get(\"host\") for m in conf.get(\"members\", []) if m.get(\"arbiterOnly\") is not True}\n        if data_hosts != expected_data_hosts:\n            errors.append(f\"Data member hosts mismatch: expected={sorted(expected_data_hosts)} actual={sorted(data_hosts)}\")\n\n    return fail(\"MongoDB arbiters topology check failed:\", errors)\n\n\ndef check_data():\n    errors = []\n    pod = f\"{DATA_CLUSTER_PREFIX}-0\"\n    res = mongo_eval(\n        pod,\n        f\"db.getSiblingDB('{APP_DATABASE}').{APP_COLLECTION}.countDocuments({{}})\",\n    )\n    if res.returncode != 0:\n        detail = res.stderr.strip() or res.stdout.strip() or f\"exit {res.returncode}\"\n        errors.append(f\"Failed to read {APP_DATABASE}.{APP_COLLECTION}: {detail}\")\n    else:\n        raw = (res.stdout or \"\").strip()\n        if not raw.isdigit() or int(raw) < SEED_DOCS:\n            errors.append(f\"Expected >= {SEED_DOCS} docs in {APP_DATABASE}.{APP_COLLECTION}, got {raw}\")\n\n    return fail(\"MongoDB arbiters data check failed:\", errors)\n\n\ndef main():\n    parser = argparse.ArgumentParser()\n    parser.add_argument(\"--check\", default=\"all\", choices=[\"all\", \"workload\", \"topology\", \"data\"])\n    args = parser.parse_args()\n\n    if args.check == \"workload\":\n        return check_workload()\n    if args.check == \"topology\":\n        return check_topology()\n    if args.check == \"data\":\n        return check_data()\n\n    for fn in (check_workload, check_topology, check_data):\n        rc = fn()\n        if rc != 0:\n            return rc\n    print(\"MongoDB arbiter addition verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":229,"startLine":1,"totalLines":229}}}
