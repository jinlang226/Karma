17/admin\" \\\n          --eval 'db.getSiblingDB(\"{{params.app_database}}\").createRole({\n            role: \"{{params.bad_role_name}}\",\n            privileges: [\n              { resource: { db: \"{{params.app_database}}\", collection: \"{{params.raw_collection}}\" }, actions: [\"find\"] }\n            ],\n            roles: []\n          })'\n        sleep: 2\n      - command: |\n          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet \\\n          \"mongodb://{{params.admin_username}}:admin123password@localhost:27017/admin\" \\\n          --eval 'db.getSiblingDB(\"admin\").createUser({\n            user: \"{{params.reporting_username}}\",\n            pwd: \"reporting123password\",\n            roles: [{role: \"{{params.bad_role_name}}\", db: \"{{params.app_database}}\"}]\n          })'\n        sleep: 2\n      - command: |\n          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet \\\n          \"mongodb://{{params.admin_username}}:admin123password@localhost:27017/admin\" \\\n          --eval 'db.getSiblingDB(\"{{params.app_database}}\").{{params.reports_collection}}.insertMany([{x:1},{x:2},{x:3}], {writeConcern:{w:1}})'\n        sleep: 2\n      - command: |\n          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet \\\n          \"mongodb://{{params.admin_username}}:admin123password@localhost:27017/admin\" \\\n          --eval 'db.getSiblingDB(\"{{params.app_database}}\").{{params.raw_collection}}.insertMany([{x:10},{x:11}], {writeConcern:{w:1}})'\n        sleep: 2\n    verify:\n      - command: \"kubectl -n mongodb get pods 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n\noracle:\n  verify:\n    commands:\n      - command: \"python3 cases/mongodb/custom-roles/oracle/oracle.py\"\n        timeout_sec: 60\n","numLines":151,"startLine":1,"totalLines":151}}}
