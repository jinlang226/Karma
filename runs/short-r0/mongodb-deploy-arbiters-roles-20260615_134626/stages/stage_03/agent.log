{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UZ7oet3JMRHZEkJKuZQFvi","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport argparse\n3\timport base64\n4\timport json\n5\timport os\n6\timport subprocess\n7\timport sys\n8\t\n9\t\n10\tNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"mongodb\")\n11\tCLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"mongodb-replica\")\n12\tPOD = f\"{CLUSTER_PREFIX}-0\"\n13\tADMIN_SECRET = os.environ.get(\"BENCH_PARAM_ADMIN_SECRET_NAME\", \"admin-user-password\")\n14\tREPORTING_SECRET = os.environ.get(\"BENCH_PARAM_REPORTING_SECRET_NAME\", \"reporting-user-password\")\n15\tADMIN_USER = os.environ.get(\"BENCH_PARAM_ADMIN_USERNAME\", \"admin-user\")\n16\tREPORTING_USER = os.environ.get(\"BENCH_PARAM_REPORTING_USERNAME\", \"reporting-user\")\n17\tAPP_DB = os.environ.get(\"BENCH_PARAM_APP_DATABASE\", \"appdb\")\n18\tREPORTS_COLLECTION = os.environ.get(\"BENCH_PARAM_REPORTS_COLLECTION\", \"reports\")\n19\tRAW_COLLECTION = os.environ.get(\"BENCH_PARAM_RAW_COLLECTION\", \"raw\")\n20\tBAD_ROLE = os.environ.get(\"BENCH_PARAM_BAD_ROLE_NAME\", \"rawRead\")\n21\tREPORTING_ROLE = os.environ.get(\"BENCH_PARAM_REPORTING_ROLE_NAME\", \"reportingRole\")\n22\t\n23\t\n24\tdef run(cmd):\n25\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n26\t\n27\t\n28\t_TLS_FLAGS_CACHE = None\n29\t\n30\t\n31\tdef _mongo_tls_flags(probe_pod=None):\n32\t    \"\"\"mongosh transport flags that adapt to the cluster's LIVE TLS mode.\n33\t\n34\t    The environment PERSISTS across workflow stages, so an earlier stage\n35\t    (mongodb/tls-setup or mongodb/certificate-rotation) may have turned TLS on,\n36\t    after which a plain mongosh connection is refused. Detect TLS by probing the\n37\t    running mongo pod for a CA cert mounted at the paths the TLS stages use; if\n38\t    present, connect with --tls --tlsCAFile (and a client cert for mutual TLS\n39\t    when one is mounted), else connect plain. Standalone (no CA mounted) this\n40\t    returns [] -> identical plain behaviour. It only adds transport flags; every\n41\t    real check still runs and still fails when its condition is unmet.\n42\t    \"\"\"\n43\t    global _TLS_FLAGS_CACHE\n44\t    if _TLS_FLAGS_CACHE is not None:\n45\t        return list(_TLS_FLAGS_CACHE)\n46\t    flags = []\n47\t    pod = probe_pod or f\"{CLUSTER_PREFIX}-0\"\n48\t    ca_path = None\n49\t    for cand in (\n50\t        \"/etc/tls/ca.crt\",\n51\t        \"/etc/mongo-ca/ca.crt\",\n52\t        \"/etc/mongodb/tls/ca.crt\",\n53\t        \"/etc/ssl/mongodb/ca.crt\",\n54\t    ):\n55\t        probe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + cand])\n56\t        if probe.returncode == 0:\n57\t            ca_path = cand\n58\t            break\n59\t    if ca_path:\n60\t        flags = [\"--tls\", \"--tlsAllowInvalidHostnames\", \"--tlsCAFile\", ca_path]\n61\t        for client_pem in (\"/etc/tls/client.pem\", \"/etc/mongo-ca/client.pem\"):\n62\t            cprobe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + client_pem])\n63\t            if cprobe.returncode == 0:\n64\t                flags += [\"--tlsCertificateKeyFile\", client_pem]\n65\t                break\n66\t    _TLS_FLAGS_CACHE = flags\n67\t    return list(flags)\n68\t\n69\tdef fail(prefix, errors):\n70\t    if errors:\n71\t        print(prefix, file=sys.stderr)\n72\t        for err in errors:\n73\t            print(f\"  - {err}\", file=sys.stderr)\n74\t        return 1\n75\t    return 0\n76\t\n77\t\n78\tdef get_secret(secret_name, errors):\n79\t    res = run([\n80\t        \"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", secret_name, \"-o\", \"jsonpath={.data.password}\"\n81\t    ])\n82\t    if res.returncode != 0:\n83\t        errors.append(f\"Failed to read secret {secret_name}: {res.stderr.strip() or res.stdout.strip()}\")\n84\t        return None\n85\t    try:\n86\t        return base64.b64decode((res.stdout or \"\").strip()).decode(\"utf-8\")\n87\t    except Exception:\n88\t        errors.append(f\"Failed to decode secret {secret_name}.password\")\n89\t        return None\n90\t\n91\t\n92\tdef run_mongo(uri, eval_str):\n93\t    return run([\n94\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", POD, \"--\", \"mongosh\", \"--quiet\", *_mongo_tls_flags(), uri, \"--eval\", eval_str\n95\t    ])\n96\t\n97\t\n98\tdef load_json(uri, eval_str, label, errors):\n99\t    res = run_mongo(uri, eval_str)\n100\t    if res.returncode != 0:\n101\t        errors.append(f\"{label} failed: {res.stderr.strip() or res.stdout.strip()}\")\n102\t        return None\n103\t    raw = (res.stdout or \"\").strip()\n104\t    if not raw:\n105\t        errors.append(f\"{label} returned empty output\")\n106\t        return None\n107\t    try:\n108\t        return json.loads(raw)\n109\t    except json.JSONDecodeError:\n110\t        errors.append(f\"Unable to parse {label} JSON output\")\n111\t        return None\n112\t\n113\t\n114\tdef role_has_reports_privileges(role):\n115\t    for priv in role.get(\"privileges\", []):\n116\t        resource = priv.get(\"resource\", {})\n117\t        if resource.get(\"db\") != APP_DB or resource.get(\"collection\") != REPORTS_COLLECTION:\n118\t            continue\n119\t        actions = set(priv.get(\"actions\", []))\n120\t        if \"find\" in actions:\n121\t            return True\n122\t    return False\n123\t\n124\t\n125\tdef role_touches_raw(role):\n126\t    for priv in role.get(\"privileges\", []):\n127\t        resource = priv.get(\"resource\", {})\n128\t        if resource.get(\"db\") == APP_DB and resource.get(\"collection\") == RAW_COLLECTION:\n129\t            return True\n130\t    return False\n131\t\n132\t\n133\tdef user_has_role(user, role_name, role_db=None):\n134\t    for role in user.get(\"roles\", []):\n135\t        if role.get(\"role\") != role_name:\n136\t            continue\n137\t        if role_db is None or role.get(\"db\") == role_db:\n138\t            return True\n139\t    return False\n140\t\n141\t\n142\tdef credentials(errors):\n143\t    admin_pw = get_secret(ADMIN_SECRET, errors)\n144\t    reporting_pw = get_secret(REPORTING_SECRET, errors)\n145\t    if errors:\n146\t        return None\n147\t    return {\n148\t        \"admin_uri\": f\"mongodb://{ADMIN_USER}:{admin_pw}@localhost:27017/admin\",\n149\t        \"reporting_uri\": f\"mongodb://{REPORTING_USER}:{reporting_pw}@localhost:27017/{APP_DB}?authSource=admin\",\n150\t    }\n151\t\n152\t\n153\tdef check_role():\n154\t    errors = []\n155\t    c = credentials(errors)\n156\t    if c is None:\n157\t        return fail(\"Custom roles role check failed:\", errors)\n158\t\n159\t    role = load_json(\n160\t        c[\"admin_uri\"],\n161\t        f'JSON.stringify(db.getSiblingDB(\"admin\").getRole(\"{REPORTING_ROLE}\",{{showPrivileges:true}}))',\n162\t        f\"{REPORTING_ROLE} (admin)\",\n163\t        errors,\n164\t    )\n165\t    if role is None:\n166\t        role = load_json(\n167\t            c[\"admin_uri\"],\n168\t            f'JSON.stringify(db.getSiblingDB(\"{APP_DB}\").getRole(\"{REPORTING_ROLE}\",{{showPrivileges:true}}))',\n169\t            f\"{REPORTING_ROLE} ({APP_DB})\",\n170\t            errors,\n171\t        )\n172\t\n173\t    if role is None:\n174\t        errors.append(f\"{REPORTING_ROLE} not found\")\n175\t    else:\n176\t        if not role_has_reports_privileges(role):\n177\t            errors.append(f\"{REPORTING_ROLE} missing find on {APP_DB}.{REPORTS_COLLECTION}\")\n178\t        if role_touches_raw(role):\n179\t            errors.append(f\"{REPORTING_ROLE} must not grant access to {APP_DB}.{RAW_COLLECTION}\")\n180\t\n181\t    return fail(\"Custom roles role check failed:\", errors)\n182\t\n183\t\n184\tdef check_bindings():\n185\t    errors = []\n186\t    c = credentials(errors)\n187\t    if c is None:\n188\t        return fail(\"Custom roles bindings check failed:\", errors)\n189\t\n190\t    user = load_json(c[\"admin_uri\"], f'JSON.stringify(db.getUser(\"{REPORTING_USER}\"))', REPORTING_USER, errors)\n191\t    if isinstance(user, dict):\n192\t        if not user_has_role(user, REPORTING_ROLE):\n193\t            errors.append(f\"{REPORTING_USER} missing {REPORTING_ROLE}\")\n194\t        if user_has_role(user, BAD_ROLE, APP_DB):\n195\t            errors.append(f\"{REPORTING_USER} still has deprecated role {BAD_ROLE}\")\n196\t\n197\t    return fail(\"Custom roles bindings check failed:\", errors)\n198\t\n199\t\n200\tdef check_access():\n201\t    errors = []\n202\t    c = credentials(errors)\n203\t    if c is None:\n204\t        return fail(\"Custom roles access check failed:\", errors)\n205\t\n206\t    reports_read = run_mongo(c[\"reporting_uri\"], f'db.{REPORTS_COLLECTION}.findOne({{}})')\n207\t    if reports_read.returncode != 0:\n208\t        errors.append(f\"{REPORTING_USER} read on reports failed: {reports_read.stderr.strip() or reports_read.stdout.strip()}\")\n209\t\n210\t    reports_agg = run_mongo(c[\"reporting_uri\"], f'db.{REPORTS_COLLECTION}.aggregate([{{$match:{{}}}}]).toArray().length')\n211\t    if reports_agg.returncode != 0:\n212\t        errors.append(f\"{REPORTING_USER} aggregate on reports failed: {reports_agg.stderr.strip() or reports_agg.stdout.strip()}\")\n213\t\n214\t    raw_read = run_mongo(c[\"reporting_uri\"], f'db.{RAW_COLLECTION}.findOne({{}})')\n215\t    raw_combined = (raw_read.stdout + raw_read.stderr).lower()\n216\t    if raw_read.returncode == 0 and \"not authorized\" not in raw_combined:\n217\t        errors.append(f\"{REPORTING_USER} can read {RAW_COLLECTION} unexpectedly\")\n218\t\n219\t    reports_write = run_mongo(c[\"reporting_uri\"], f'db.{REPORTS_COLLECTION}.insertOne({{bad:\"write\"}})')\n220\t    write_combined = (reports_write.stdout + reports_write.stderr).lower()\n221\t    if reports_write.returncode == 0 and \"not authorized\" not in write_combined:\n222\t        errors.append(f\"{REPORTING_USER} can write {REPORTS_COLLECTION} unexpectedly\")\n223\t\n224\t    return fail(\"Custom roles access check failed:\", errors)\n225\t\n226\t\n227\tdef main():\n228\t    parser = argparse.ArgumentParser()\n229\t    parser.add_argument(\"--check\", default=\"all\", choices=[\"all\", \"role\", \"bindings\", \"access\"])\n230\t    args = parser.parse_args()\n231\t\n232\t    if args.check == \"role\":\n233\t        return check_role()\n234\t    if args.check == \"bindings\":\n235\t        return check_bindings()\n236\t    if args.check == \"access\":\n237\t        return check_access()\n238\t\n239\t    for fn in (check_role, check_bindings, check_access):\n240\t        rc = fn()\n241\t        if rc != 0:\n242\t            return rc\n243\t    print(\"Custom roles verified\")\n244\t    return 0\n245\t\n246\t\n247\tif __name__ == \"__main__\":\n248\t    sys.exit(main())\n249\t"}]},"parent_tool_use_id":null,"session_id":"fae12352-edc9-4f08-919a-d4682acebeb9","uuid":"e35f5cc2-6be8-4f72-bb85-3b38d1a35910","timestamp":"2026-06-15T13:54:24.153Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/leo/Karma/cases/mongodb/custom-roles/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport argparse\nimport base64\nimport json\nimport os\nimport subprocess\nimport sys\n\n\nNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"mongodb\")\nCLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"mongodb-replica\")\nPOD = f\"{CLUSTER_PREFIX}-0\"\nADMIN_SECRET = os.environ.get(\"BENCH_PARAM_ADMIN_SECRET_NAME\", \"admin-user-password\")\nREPORTING_SECRET = os.environ.get(\"BENCH_PARAM_REPORTING_SECRET_NAME\", \"reporting-user-password\")\nADMIN_USER = os.environ.get(\"BENCH_PARAM_ADMIN_USERNAME\", \"admin-user\")\nREPORTING_USER = os.environ.get(\"BENCH_PARAM_REPORTING_USERNAME\", \"reporting-user\")\nAPP_DB = os.environ.get(\"BENCH_PARAM_APP_DATABASE\", \"appdb\")\nREPORTS_COLLECTION = os.environ.get(\"BENCH_PARAM_REPORTS_COLLECTION\", \"reports\")\nRAW_COLLECTION = os.environ.get(\"BENCH_PARAM_RAW_COLLECTION\", \"raw\")\nBAD_ROLE = os.environ.get(\"BENCH_PARAM_BAD_ROLE_NAME\", \"rawRead\")\nREPORTING_ROLE = os.environ.get(\"BENCH_PARAM_REPORTING_ROLE_NAME\", \"reportingRole\")\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\n_TLS_FLAGS_CACHE = None\n\n\ndef _mongo_tls_flags(probe_pod=None):\n    \"\"\"mongosh transport flags that adapt to the cluster's LIVE TLS mode.\n\n    The environment PERSISTS across workflow stages, so an earlier stage\n    (mongodb/tls-setup or mongodb/certificate-rotation) may have turned TLS on,\n    after which a plain mongosh connection is refused. Detect TLS by probing the\n    running mongo pod for a CA cert mounted at the paths the TLS stages use; if\n    present, connect with --tls --tlsCAFile (and a client cert for mutual TLS\n    when one is mounted), else connect plain. Standalone (no CA mounted) this\n    returns [] -> identical plain behaviour. It only adds transport flags; every\n    real check still runs and still fails when its condition is unmet.\n    \"\"\"\n    global _TLS_FLAGS_CACHE\n    if _TLS_FLAGS_CACHE is not None:\n        return list(_TLS_FLAGS_CACHE)\n    flags = []\n    pod = probe_pod or f\"{CLUSTER_PREFIX}-0\"\n    ca_path = None\n    for cand in (\n        \"/etc/tls/ca.crt\",\n        \"/etc/mongo-ca/ca.crt\",\n        \"/etc/mongodb/tls/ca.crt\",\n        \"/etc/ssl/mongodb/ca.crt\",\n    ):\n        probe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + cand])\n        if probe.returncode == 0:\n            ca_path = cand\n            break\n    if ca_path:\n        flags = [\"--tls\", \"--tlsAllowInvalidHostnames\", \"--tlsCAFile\", ca_path]\n        for client_pem in (\"/etc/tls/client.pem\", \"/etc/mongo-ca/client.pem\"):\n            cprobe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + client_pem])\n            if cprobe.returncode == 0:\n                flags += [\"--tlsCertificateKeyFile\", client_pem]\n                break\n    _TLS_FLAGS_CACHE = flags\n    return list(flags)\n\ndef fail(prefix, errors):\n    if errors:\n        print(prefix, file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n    return 0\n\n\ndef get_secret(secret_name, errors):\n    res = run([\n        \"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", secret_name, \"-o\", \"jsonpath={.data.password}\"\n    ])\n    if res.returncode != 0:\n        errors.append(f\"Failed to read secret {secret_name}: {res.stderr.strip() or res.stdout.strip()}\")\n        return None\n    try:\n        return base64.b64decode((res.stdout or \"\").strip()).decode(\"utf-8\")\n    except Exception:\n        errors.append(f\"Failed to decode secret {secret_name}.password\")\n        return None\n\n\ndef run_mongo(uri, eval_str):\n    return run([\n        \"kubectl\", \"-n\", NAMESPACE, \"exec\", POD, \"--\", \"mongosh\", \"--quiet\", *_mongo_tls_flags(), uri, \"--eval\", eval_str\n    ])\n\n\ndef load_json(uri, eval_str, label, errors):\n    res = run_mongo(uri, eval_str)\n    if res.returncode != 0:\n        errors.append(f\"{label} failed: {res.stderr.strip() or res.stdout.strip()}\")\n        return None\n    raw = (res.stdout or \"\").strip()\n    if not raw:\n        errors.append(f\"{label} returned empty output\")\n        return None\n    try:\n        return json.loads(raw)\n    except json.JSONDecodeError:\n        errors.append(f\"Unable to parse {label} JSON output\")\n        return None\n\n\ndef role_has_reports_privileges(role):\n    for priv in role.get(\"privileges\", []):\n        resource = priv.get(\"resource\", {})\n        if resource.get(\"db\") != APP_DB or resource.get(\"collection\") != REPORTS_COLLECTION:\n            continue\n        actions = set(priv.get(\"actions\", []))\n        if \"find\" in actions:\n            return True\n    return False\n\n\ndef role_touches_raw(role):\n    for priv in role.get(\"privileges\", []):\n        resource = priv.get(\"resource\", {})\n        if resource.get(\"db\") == APP_DB and resource.get(\"collection\") == RAW_COLLECTION:\n            return True\n    return False\n\n\ndef user_has_role(user, role_name, role_db=None):\n    for role in user.get(\"roles\", []):\n        if role.get(\"role\") != role_name:\n            continue\n        if role_db is None or role.get(\"db\") == role_db:\n            return True\n    return False\n\n\ndef credentials(errors):\n    admin_pw = get_secret(ADMIN_SECRET, errors)\n    reporting_pw = get_secret(REPORTING_SECRET, errors)\n    if errors:\n        return None\n    return {\n        \"admin_uri\": f\"mongodb://{ADMIN_USER}:{admin_pw}@localhost:27017/admin\",\n        \"reporting_uri\": f\"mongodb://{REPORTING_USER}:{reporting_pw}@localhost:27017/{APP_DB}?authSource=admin\",\n    }\n\n\ndef check_role():\n    errors = []\n    c = credentials(errors)\n    if c is None:\n        return fail(\"Custom roles role check failed:\", errors)\n\n    role = load_json(\n        c[\"admin_uri\"],\n        f'JSON.stringify(db.getSiblingDB(\"admin\").getRole(\"{REPORTING_ROLE}\",{{showPrivileges:true}}))',\n        f\"{REPORTING_ROLE} (admin)\",\n        errors,\n    )\n    if role is None:\n        role = load_json(\n            c[\"admin_uri\"],\n            f'JSON.stringify(db.getSiblingDB(\"{APP_DB}\").getRole(\"{REPORTING_ROLE}\",{{showPrivileges:true}}))',\n            f\"{REPORTING_ROLE} ({APP_DB})\",\n            errors,\n        )\n\n    if role is None:\n        errors.append(f\"{REPORTING_ROLE} not found\")\n    else:\n        if not role_has_reports_privileges(role):\n            errors.append(f\"{REPORTING_ROLE} missing find on {APP_DB}.{REPORTS_COLLECTION}\")\n        if role_touches_raw(role):\n            errors.append(f\"{REPORTING_ROLE} must not grant access to {APP_DB}.{RAW_COLLECTION}\")\n\n    return fail(\"Custom roles role check failed:\", errors)\n\n\ndef check_bindings():\n    errors = []\n    c = credentials(errors)\n    if c is None:\n        return fail(\"Custom roles bindings check failed:\", errors)\n\n    user = load_json(c[\"admin_uri\"], f'JSON.stringify(db.getUser(\"{REPORTING_USER}\"))', REPORTING_USER, errors)\n    if isinstance(user, dict):\n        if not user_has_role(user, REPORTING_ROLE):\n            errors.append(f\"{REPORTING_USER} missing {REPORTING_ROLE}\")\n        if user_has_role(user, BAD_ROLE, APP_DB):\n            errors.append(f\"{REPORTING_USER} still has deprecated role {BAD_ROLE}\")\n\n    return fail(\"Custom roles bindings check failed:\", errors)\n\n\ndef check_access():\n    errors = []\n    c = credentials(errors)\n    if c is None:\n        return fail(\"Custom roles access check failed:\", errors)\n\n    reports_read = run_mongo(c[\"reporting_uri\"], f'db.{REPORTS_COLLECTION}.findOne({{}})')\n    if reports_read.returncode != 0:\n        errors.append(f\"{REPORTING_USER} read on reports failed: {reports_read.stderr.strip() or reports_read.stdout.strip()}\")\n\n    reports_agg = run_mongo(c[\"reporting_uri\"], f'db.{REPORTS_COLLECTION}.aggregate([{{$match:{{}}}}]).toArray().length')\n    if reports_agg.returncode != 0:\n        errors.append(f\"{REPORTING_USER} aggregate on reports failed: {reports_agg.stderr.strip() or reports_agg.stdout.strip()}\")\n\n    raw_read = run_mongo(c[\"reporting_uri\"], f'db.{RAW_COLLECTION}.findOne({{}})')\n    raw_combined = (raw_read.stdout + raw_read.stderr).lower()\n    if raw_read.returncode == 0 and \"not authorized\" not in raw_combined:\n        errors.append(f\"{REPORTING_USER} can read {RAW_COLLECTION} unexpectedly\")\n\n    reports_write = run_mongo(c[\"reporting_uri\"], f'db.{REPORTS_COLLECTION}.insertOne({{bad:\"write\"}})')\n    write_combined = (reports_write.stdout + reports_write.stderr).lower()\n    if reports_write.returncode == 0 and \"not authorized\" not in write_combined:\n        errors.append(f\"{REPORTING_USER} can write {REPORTS_COLLECTION} unexpectedly\")\n\n    return fail(\"Custom roles access check failed:\", errors)\n\n\ndef main():\n    parser = argparse.ArgumentParser()\n    parser.add_argument(\"--check\", default=\"all\", choices=[\"all\", \"role\", \"bindings\", \"access\"])\n    args = parser.parse_args()\n\n    if args.check == \"role\":\n        return check_role()\n    if args.check == \"bindings\":\n        return check_bindings()\n    if args.check == \"access\":\n        return check_access()\n\n    for fn in (check_role, check_bindings, check_access):\n        rc = fn()\n        if rc != 0:\n            return rc\n    print(\"Custom roles verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":249,"startLine":1,"totalLines":249}}}
