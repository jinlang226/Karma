ing...\"\nkubectl -n \"${NAMESPACE}\" patch deployment \"${DEPLOY}\" \\\n  --type=json \\\n  -p \"[{\\\"op\\\":\\\"remove\\\",\\\"path\\\":\\\"/spec/template/spec/containers/0/args/${EXTRA_IDX}\\\"}]\"\n\necho \"[rollback] Waiting for rollout to complete...\"\nkubectl -n \"${NAMESPACE}\" rollout status \"deploy/${DEPLOY}\" --timeout=120s\n\necho \"[rollback] Done. Remaining watch-ingress args:\"\nkubectl -n \"${NAMESPACE}\" get deploy \"${DEPLOY}\" \\\n  -o jsonpath='{.spec.template.spec.containers[0].args}' \\\n  | python3 -c \"\nimport sys, json\nargs = json.loads(sys.stdin.read())\nmatches = [a for a in args if 'watch-ingress' in a]\nprint('  ' + '\\n  '.join(matches) if matches else '  (none)')\n\"\n\necho \"[rollback] Rollback complete. ConfigMap and Ingress resources were already at vanilla defaults.\"\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1434,"cache_read_input_tokens":45928,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1434},"output_tokens":47,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"b83d15a2-3e84-432b-a5e7-c4154e5d6f57","uuid":"cdfc4cd7-44db-42f2-a6b4-7506d0e39833","request_id":"req_011CcQ2FFb9J1vVKufWdnC4y"}
