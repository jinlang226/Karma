emo\n      # to be Active so the destructive rebuild (which delete+waits the namespace)\n      # runs instead of being skipped into a terminating namespace.\n      - command: \"/bin/sh -c '[ \\\"$(kubectl get ns demo -o jsonpath={.status.phase} 2>/dev/null)\\\" = Active ]'\"\n        timeout_sec: 10\n      - command: \"kubectl -n demo wait --for=condition=ready pod/curl-test --timeout=5s\"\n        timeout_sec: 10\n    apply:\n      - command: \"/bin/sh -c 'kubectl delete namespace ingress-nginx --ignore-not-found=true; kubectl delete namespace demo --ignore-not-found=true; kubectl wait --for=delete namespace/ingress-nginx --timeout=120s || true; kubectl wait --for=delete namespace/demo --timeout=120s || true'\"\n        sleep: 1\n      - command: \"kubectl create namespace ingress-nginx\"\n        sleep: 0\n      # P26: deploy.yaml ships cluster-scoped objects (IngressClass nginx,\n      # ValidatingWebhookConfiguration, ClusterRole/Binding) with immutable\n      # fields; tolerate (|| true) so a sibling case that already owns them on\n      # a reused cluster can't abort this precondition. The controller-ready\n      # rollout below is the real gate.\n      - command: \"/bin/sh -c 'kubectl apply -f cases/nginx-ingress/create_ingress/resource/deploy.yaml || true'\"\n        sleep: 90\n      - command: \"kubectl -n ingress-nginx rollout status deploy/ingress-nginx-controller --timeout=120s\"\n        sleep: 2\n      - command: \"kubectl -n ingress-nginx patch deployment ingress-nginx-controller --type=json -p '[{\\\"op\\\":\\\"add\\\",\\\"path\\\":\\\"/spec/template/spec/containers/0/args/-\\\",\\\"value\\\":\\\"--watch-ingress-without-class=false\\\"}]'\"\n        sleep: 1\n      - command: \"kubectl -n ingress-nginx rollout status deploy/ingress-nginx-controller --timeout=120s\"\n        sleep: 2\n      - command: \"kubectl create namespace demo\"\n        sleep: 0\n      - command: \"kubectl -n demo apply -f cases/nginx-ingress/create_ingress/resource/demo-app.yaml\"\n        sleep: 2\n      - command: \"kubectl -n demo rollout status deploy/demo-app --timeout=60s\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n demo get pod curl-test >/dev/null 2>&1 || kubectl -n demo apply -f cases/nginx-ingress/create_ingress/resource/curl-test.yaml'\"\n        sleep: 1\n      - command: \"kubectl -n demo wait --for=condition=Ready pod/curl-test --timeout=180s\"\n        sleep: 1\n    verify:\n      - command: \"kubectl -n demo wait --for=condition=ready pod/curl-test --timeout=5s\"\n        timeout_sec: 30\n\noracle:\n  verify:\n    commands:\n      - command: \"python3 cases/nginx-ingress/rollback-rehearsal/oracle/oracle.py\"\n        timeout_sec: 60\n","numLines":97,"startLine":1,"totalLines":97}}}
