ace: ${BENCH_NS_SOURCE} (blue/source cluster)\n  - target namespace: ${BENCH_NS_TARGET} (green/target cluster)\n\n  The blue cluster has continuous traffic on /app/app-queue with monotonic\n  message IDs. The green cluster starts empty.\n\n  Migrate messages from blue to green without gaps in the ID sequence\n  (duplicates are acceptable), and cut application traffic to green.\n\n  Use only native Kubernetes resources and RabbitMQ tools (CLI/API). Do not\n  install CRDs or operators.\n\n  Requirements:\n  - The green /app/app-queue contains the initial seed range (IDs 1..N)\n    with no gaps.\n  - At least N messages are available on green.\n  - Blue-to-green migration is complete enough for consumers to proceed.\n\n  Cluster context:\n    kubectl -n ${BENCH_NS_SOURCE} get pods\n    kubectl -n ${BENCH_NS_TARGET} get pods\n    kubectl -n ${BENCH_NS_SOURCE} exec {{params.blue_cluster_prefix}}-0 -- rabbitmqctl list_queues -p /app name messages\n    kubectl -n ${BENCH_NS_TARGET} exec {{params.green_cluster_prefix}}-0 -- rabbitmqctl list_queues -p /app name messages\n\nparams:\n  blue_cluster_prefix:\n    default: rabbitmq-blue\n  green_cluster_prefix:\n    default: rabbitmq-green\n\nnamespace_contract:\n  required_roles:\n    - source\n    - target\n\nmetrics:\n  - time_to_first_mutation\n  - read_write_ratio\n  - blast_radius\n  - destructive_ops\n  - decoy_integrity\n  - residual_drift\n\npreconditionUnits:\n  - name: cluster_secrets_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"/bin/sh -c 'set -e; kubectl -n ${BENCH_NS_SOURCE} get secret {{params.blue_cluster_prefix}}-erlang-cookie >/dev/null; kubectl -n ${BENCH_NS_TARGET} get secret {{params.green_cluster_prefix}}-erlang-cookie >/dev/null; kubectl -n ${BENCH_NS_SOURCE} get secret {{params.blue_cluster_prefix}}-admin >/dev/null; kubectl -n ${BENCH_NS_TARGET} get secret {{params.green_cluster_prefix}}-admin >/dev/null'\"\n        timeout_sec: 20\n    apply:\n      - command: \"/bin/sh -c 'kubectl -n ${BENCH_NS_SOURCE} create secret generic {{params.blue_cluster_prefix}}-erlang-cookie --from-literal=cookie=supersecretcookie --dry-run=client -o yaml | kubectl apply -f -'\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n ${BENCH_NS_TARGET} create secret generic {{params.green_cluster_prefix}}-erlang-cookie --from-literal=cookie=supersecretcookie --dry-run=client -o yaml | kubectl apply -f -'\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n ${BENCH_NS_SOURCE} create secret generic {{params.blue_cluster_prefix}}-admin --from-literal=username=admin --from-literal=password=adminpass --dry-run=client -o yaml | kubectl apply -f -'\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n ${BENCH_NS_TARGET} create secret generic {{params.green_cluster_prefix}}-admin --from-literal=username=admin --from-literal=password=adminpass --dry-run=client -o yaml | kubectl apply -f -'\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n ${BENCH_NS_SOURCE} create secret generic {{params.blue_cluster_prefix}}-app --from-literal=username=app --from-literal=password=apppass --dry-run=client -o yaml | kubectl apply -f -'\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n ${BENCH_NS_TARGET} create secret generic {{params.green_cluster_prefix}}-app --from-literal=username=app --from-literal=password=apppass --dry-run=client -o yaml | kubectl apply -f -'\"\n        sleep: 1\n    verify:\n      - command: \"/bin/sh -c 'set -e; kubectl -n ${BENCH_NS_SOURCE} get secret {{params.blue_cluster_prefix}}-erlang-cookie >/dev/null; kubectl -n ${BENCH_NS_TARGET} get secret {{params.green_cluster_prefix}}-erlang-cookie >/dev/null'\"\n        timeout_sec: 20\n\n  - name: rbac_source_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"/bin/sh -c 'kubectl -n ${BENCH_NS_SOURCE} get sa rabbitmq >/dev/null'\"\n        timeout_sec: 10\n    apply:\n      - command: \"envsubst '$BENCH_NAMESPACE $BENCH_NS_SOURCE $BENCH_NS_TARGET $BENCH_PARAM_CLUSTER_PREFIX $BENCH_PARAM_BLUE_CLUSTER_PREFIX $BENCH_PARAM_GREEN_CLUSTER_PREFIX $BENCH_PARAM_FROM_VERSION' < cases/rabbitmq/blue_green_migration/resource/rbac-source.yaml | kubectl -n ${BENCH_NS_SOURCE} apply -f -\"\n        sleep: 1\n    verify:\n      - command: \"kubectl -n ${BENCH_NS_SOURCE} get sa rabbitmq\"\n        timeout_sec: 10\n\n  - name: rbac_target_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"/bin/sh -c 'kubectl -n ${BENCH_NS_TARGET} get sa rabbitmq >/dev/null'\"\n        timeout_sec: 10\n    apply:\n      - command: \"envsubst '$BENCH_NAMESPACE $BENCH_NS_SOURCE $BENCH_NS_TARGET $BENCH_PARAM_CLUSTER_PREFIX $BENCH_PARAM_BLUE_CLUSTER_PREFIX $BENCH_PARAM_GREEN_CLUSTER_PREFIX $BENCH_PARAM_FROM_VERSION' < cases/rabbitmq/blue_green_migration/resource/rbac-target.yaml | kubectl -n ${BENCH_NS_TARGET} apply -f -\"\n        sleep: 1\n    verify:\n      - command: \"kubectl -n ${BENCH_NS_TARGET} get sa rabbitmq\"\n        timeout_sec: 10\n\n  - name: configmaps_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"/bin/sh -c 'set -e; kubectl -n ${BENCH_NS_SOURCE} get configmap {{params.blue_cluster_prefix}}-config >/dev/null; kubectl -n ${BENCH_NS_TARGET} get configmap {{params.green_cluster_prefix}}-config >/dev/null'\"\n        timeout_sec: 10\n    apply:\n      - command: \"envsubst '$BENCH_NAMESPACE $BENCH_NS_SOURCE $BENCH_NS_TARGET $BENCH_PARAM_CLUSTER_PREFIX $BENCH_PARAM_BLUE_CLUSTER_PREFIX $BENCH_PARAM_GREEN_CLUSTER_PREFIX $BENCH_PARAM_FROM_VERSION' < cases/rabbitmq/blue_green_migration/resource/configmap-source.yaml | kubectl -n ${BENCH_NS_SOURCE} apply -f -\"\n        sleep: 1\n      - command: \"envsubst '$BENCH_NAMESPACE $BENCH_NS_SOURCE $BENCH_NS_TARGET $BENCH_PARAM_CLUSTER_PREFIX $BENCH_PARAM_BLUE_CLUSTER_PREFIX $BENCH_PARAM_GREEN_CLUSTER_PREFIX $BENCH_PARAM_FROM_VERSION' < cases/rabbitmq/blue_green_migration/resource/configmap-target.yaml | kubectl -n ${BENCH_NS_TARGET} apply -f -\"\n        sleep: 1\n    verify:\n      - command: \"/bin/sh -c 'set -e; kubectl -n ${BENCH_NS_SOURCE} get configmap {{params.blue_cluster_prefix}}-config >/dev/null; kubectl -n ${BENCH_NS_TARGET} get configmap {{params.green_cluster_prefix}}-config >/dev/null'\"\n        timeout_sec: 10\n\n  - name: services_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"/bin/sh -c 'set -e; kubectl -n ${BENCH_NS_SOURCE} get svc {{params.blue_cluster_prefix}} >/dev/null; kubectl -n ${BENCH_NS_TARGET} get svc {{params.green_cluster_prefix}} >/dev/null'\"\n        timeout_sec: 20\n    apply:\n      - command: \"envsubst '$BENCH_NAMESPACE $BENCH_NS_SOURCE $BENCH_NS_TARGET $BENCH_PARAM_CLUSTER_PREFIX $BENCH_PARAM_BLUE_CLUSTER_PREFIX $BENCH_PARAM_GREEN_CLUSTER_PREFIX $BENCH_PARAM_FROM_VERSION' < cases/rabbitmq/blue_green_migration/resource/services-source.yaml | kubectl -n ${BENCH_NS_SOURCE} apply -f -\"\n        sleep: 1\n      - command: \"envsubst '$BENCH_NAMESPACE $BENCH_NS_SOURCE $BENCH_NS_TARGET $BENCH_PARAM_CLUSTER_PREFIX $BENCH_PARAM_BLUE_CLUSTER_PREFIX $BENCH_PARAM_GREEN_CLUSTER_PREFIX $BENCH_PARAM_FROM_VERSION' < cases/rabbitmq/blue_green_migration/resource/services-target.yaml | kubectl -n ${BENCH_NS_TARGET} apply -f -\"\n        sleep: 1\n    verify:\n      - command: \"/bin/sh -c 'set -e; kubectl -n ${BENCH_NS_SOURCE} get svc {{params.blue_cluster_prefix}} >/dev/null; kubectl -n ${BENCH_NS_TARGET} get svc {{params.green_cluster_prefix}} >/dev/null'\"\n        timeout_sec: 20\n\n  - name: rabbitmq_blue_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"/bin/sh -c 'set -e; [ \\\"$(kubectl -n ${BENCH_NS_SOURCE} get sts {{params.blue_cluster_prefix}} -o jsonpath=\\\"{.status.readyReplicas}\\\")\\\" = \\\"3\\\" ]'\"\n        timeout_sec: 20\n    apply:\n      # Composition-tolerance: an inherited StatefulSet from an earlier workflow stage\n      # may differ in immutable fields (serviceName/selector/volumeClaimTemplates), which\n      # makes `kubectl apply` fail with \"Forbidden: updates to statefulset spec ... are\n      # forbidden\". Orphan-delete the existing STS first so it can be recreated --\n      # --cascade=orphan PRESERVES the running pods and the data-* PVCs (and their data),\n      # so this is additive and never wipes inherited broker state.\n      - command: \"kubectl -n ${BENCH_NS_SOURCE} delete statefulset {{params.blue_cluster_prefix}} --cascade=orphan --ignore-not-found=true\"\n        sleep: 1\n      - command: \"envsubst '$BENCH_NAMESPACE $BENCH_NS_SOURCE $BENCH_NS_TARGET $BENCH_PARAM_CLUSTER_PREFIX $BENCH_PARAM_BLUE_CLUSTER_PREFIX $BENCH_PARAM_GREEN_CLUSTER_PREFIX $BENCH_PARAM_FROM_VERSION' < cases/rabbitmq/blue_green_migration/resource/statefulset-source.yaml | kubectl -n ${BENCH_NS_SOURCE} apply -f -\"\n        sleep: 1\n      - command: \"kubectl -n ${BENCH_NS_SOURCE} rollout status statefulset/{{params.blue_cluster_prefix}} --timeout=600s\"\n        sleep: 1\n    verify:\n      - command: \"/bin/sh -c 'set -e; [ \\\"$(kubectl -n ${BENCH_NS_SOURCE} get sts {{params.blue_cluster_prefix}} -o jsonpath=\\\"{.status.readyReplicas}\\\")\\\" = \\\"3\\\" ]'\"\n        timeout_sec: 20\n\n  - name: rabbitmq_green_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"/bin/sh -c 'set -e; [ \\\"$(kubectl -n ${BENCH_NS_TARGET} get sts {{params.green_cluster_prefix}} -o jsonpath=\\\"{.status.readyReplicas}\\\")\\\" = \\\"3\\\" ]'\"\n        timeout_sec: 20\n    apply:\n      # Composition-tolerance: orphan-delete an inherited StatefulSet (immutable-field\n      # mismatch) before re-apply; --cascade=orphan preserves running pods + data-* PVCs.\n      - command: \"kubectl -n ${BENCH_NS_TARGET} delete statefulset {{params.green_cluster_prefix}} --cascade=orphan --ignore-not-found=true\"\n        sleep: 1\n      - command: \"envsubst '$BENCH_NAMESPACE $BENCH_NS_SOURCE $BENCH_NS_TARGET $BENCH_PARAM_CLUSTER_PREFIX $BENCH_PARAM_BLUE_CLUSTER_PREFIX $BENCH_PARAM_GREEN_CLUSTER_PREFIX $BENCH_PARAM_FROM_VERSION' < cases/rabbitmq/blue_green_migration/resource/statefulset-target.yaml | kubectl -n ${BENCH_NS_TARGET} apply -f -\"\n        sleep: 1\n      - command: \"kubectl -n ${BENCH_NS_TARGET} rollout status statefulset/{{params.green_cluster_prefix}} --timeout=600s\"\n        sleep: 1\n    verify:\n      - command: \"/bin/sh -c 'set -e; [ \\\"$(kubectl -n ${BENCH_NS_TARGET} get sts {{params.green_cluster_prefix}} -o jsonpath=\\\"{.status.readyReplicas}\\\")\\\" = \\\"3\\\" ]'\"\n        timeout_sec: 20\n\n  - name: cluster_setup_jobs_completed\n    on_probe_fail: skip\n    probe:\n      - command: \"python3 cases/rabbitmq/blue_green_migration/setup_precondition_check.py --source-namespace ${BENCH_NS_SOURCE} --target-namespace ${BENCH_NS_TARGET} --bootstrap-only\"\n        timeout_sec: 60\n    apply:\n      - command: \"kubectl -n ${BENCH_NS_SOURCE} delete job rabbitmq-blue-setup --ignore-not-found=true\"\n        sleep: 1\n      - command: \"kubectl -n ${BENCH_NS_TARGET} delete job rabbitmq-green-setup --ignore-not-found=true\"\n        sleep: 1\n      - command: \"envsubst '$BENCH_NAMESPACE $BENCH_NS_SOURCE $BENCH_NS_TARGET $BENCH_PARAM_CLUSTER_PREFIX $BENCH_PARAM_BLUE_CLUSTER_PREFIX $BENCH_PARAM_GREEN_CLUSTER_PREFIX $BENCH_PARAM_FROM_VERSION' < cases/rabbitmq/blue_green_migration/resource/setup-job-source.yaml | kubectl -n ${BENCH_NS_SOURCE} apply -f -\"\n        sleep: 1\n      - command: \"envsubst '$BENCH_NAMESPACE $BENCH_NS_SOURCE $BENCH_NS_TARGET $BENCH_PARAM_CLUSTER_PREFIX $BENCH_PARAM_BLUE_CLUSTER_PREFIX $BENCH_PARAM_GREEN_CLUSTER_PREFIX $BENCH_PARAM_FROM_VERSION' < cases/rabbitmq/blue_green_migration/resource/setup-job-target.yaml | kubectl -n ${BENCH_NS_TARGET} apply -f -\"\n        sleep: 1\n      # Wait for the setup jobs to finish creating the /app vhost + app-queue\n      # before seeding -- the seed job only publishes to an existing queue.\n      - command: \"kubectl -n ${BENCH_NS_SOURCE} wait --for=condition=complete job/${BENCH_PARAM_BLUE_CLUSTER_PREFIX}-setup --timeout=150s\"\n        timeout_sec: 160\n      - command: \"kubectl -n ${BENCH_NS_TARGET} wait --for=condition=complete job/${BENCH_PARAM_GREEN_CLUSTER_PREFIX}-setup --timeout=150s\"\n        timeout_sec: 160\n    verify:\n      - command: \"python3 cases/rabbitmq/blue_green_migration/setup_precondition_check.py --source-namespace ${BENCH_NS_SOURCE} --target-namespace ${BENCH_NS_TARGET} --bootstrap-only\"\n        timeout_sec: 60\n\n  - name: seed_data_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"python3 cases/rabbitmq/blue_green_migration/setup_precondition_check.py --source-namespace ${BENCH_NS_SOURCE} --target-namespace ${BENCH_NS_TARGET} --seed-only\"\n        timeout_sec: 40\n    apply:\n      # Seed the source cluster: the migration-seed configmap (seed_count) in\n      # both namespaces, then the seed job that publishes that many messages to\n      # the source app-queue via the management API. (The check script only\n      # verifies -- it never seeded; the prior `--apply` arg did not exist.)\n      - command: \"kubectl -n ${BENCH_NS_SOURCE} apply -f cases/rabbitmq/blue_green_migration/resource/seed-configmap.yaml\"\n        timeout_sec: 30\n      - command: \"kubectl -n ${BENCH_NS_TARGET} apply -f cases/rabbitmq/blue_green_migration/resource/seed-configmap.yaml\"\n        timeout_sec: 30\n      - command: \"kubectl -n ${BENCH_NS_SOURCE} delete job ${BENCH_PARAM_BLUE_CLUSTER_PREFIX}-seed --ignore-not-found\"\n        timeout_sec: 30\n      - command: \"envsubst '$BENCH_PARAM_BLUE_CLUSTER_PREFIX' < cases/rabbitmq/blue_green_migration/resource/seed-job.yaml | kubectl -n ${BENCH_NS_SOURCE} apply -f -\"\n        timeout_sec: 30\n      - command: \"kubectl -n ${BENCH_NS_SOURCE} wait --for=condition=complete job/${BENCH_PARAM_BLUE_CLUSTER_PREFIX}-seed --timeout=150s\"\n        timeout_sec: 160\n    verify:\n      - command: \"python3 cases/rabbitmq/blue_green_migration/setup_precondition_check.py --source-namespace ${BENCH_NS_SOURCE} --target-namespace ${BENCH_NS_TARGET} --