ster is unchanged.\n\n  Cluster context:\n  ```bash\n  kubectl -n ray get deploy ray-worker -o jsonpath='{.spec.replicas}'\n  kubectl -n ray get deploy ray-head ray-worker \\\n    -o jsonpath='{range .items[*]}{.metadata.name}{\"=\"}{.spec.template.spec.containers[0].image}{\"\\n\"}{end}'\n  kubectl -n ray get deploy ray-head ray-worker -o yaml | grep -A4 resources\n  kubectl -n ray get svc ray-head -o yaml\n  ```\n\nparams: {}\n\nnamespace_contract:\n  required_roles: []\n\nmetrics:\n  - time_to_first_mutation\n\npreconditionUnits:\n  - name: ray_env_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n ray get pods 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n    apply:\n      - command: \"/bin/sh -c 'kubectl delete namespace ray --ignore-not-found=true --wait=false; kubectl wait --for=delete namespace/ray --timeout=300s 2>/dev/null || true'\"\n        timeout_sec: 360\n        sleep: 2\n      - command: \"kubectl create namespace ray\"\n        sleep: 0\n      - command: \"kubectl -n ray apply -f cases/ray/scale_workers/resource/ray-head-service.yaml\"\n        sleep: 1\n      - command: \"kubectl -n ray apply -f cases/ray/scale_workers/resource/ray-head.yaml\"\n        sleep: 2\n      - command: \"kubectl -n ray rollout status deploy/ray-head --timeout=600s\"\n        sleep: 2\n      - command: \"kubectl -n ray apply -f cases/ray/scale_workers/resource/ray-worker.yaml\"\n        sleep: 2\n      - command: \"kubectl -n ray rollout status deploy/ray-worker --timeout=600s\"\n        sleep: 2\n      - command: \"/bin/sh -c 'kubectl -n ray get pod ray-client >/dev/null 2>&1 || kubectl -n ray apply -f cases/ray/scale_workers/resource/ray-client.yaml'\"\n        sleep: 1\n      - command: \"kubectl -n ray wait --for=condition=Ready pod/ray-client --timeout=600s\"\n        timeout_sec: 660\n        sleep: 1\n      - command: \"kubectl -n ray exec ray-client -- ray start --address=ray-head:6379 || true\"\n        sleep: 2\n    verify:\n      - command: \"kubectl -n ray get pods 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n\noracle:\n  verify:\n    commands:\n      - command: \"python3 cases/ray/rollback-rehearsal/oracle/oracle.py\"\n        timeout_sec: 180\n","numLines":87,"startLine":1,"totalLines":87}}}
