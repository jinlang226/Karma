ev/null 2>&1 || kubectl -n cockroachdb get pods 2>/dev/null | grep -q Running'\"\n        timeout_sec: 10\n    apply:\n      - command: \"/bin/sh -c 'kubectl delete namespace cockroachdb --ignore-not-found=true --wait=false; kubectl wait --for=delete namespace/cockroachdb --timeout=400s || true'\"\n        timeout_sec: 460\n        sleep: 2\n      - command: \"kubectl create namespace cockroachdb\"\n        sleep: 1\n      - command: \"kubectl -n cockroachdb apply -f cases/cockroachdb/partitioned-update/resource/\"\n        sleep: 5\n      - command: \"/bin/sh -c 'for i in $(seq 1 30); do count=$(kubectl -n cockroachdb get pod -l app.kubernetes.io/name=cockroachdb --no-headers 2>/dev/null | wc -l | tr -d \\\" \\\"); if [ \\\"${count}\\\" -ge 1 ]; then exit 0; fi; sleep 2; done; exit 1'\"\n        sleep: 1\n      - command: \"kubectl -n cockroachdb wait --for=jsonpath={.status.phase}=Running pod -l app.kubernetes.io/name=cockroachdb --timeout=300s\"\n        sleep: 5\n      - command: \"/bin/sh -c 'for i in $(seq 1 30); do kubectl -n cockroachdb exec crdb-cluster-0 -- ./cockroach init --insecure --host=crdb-cluster-0.crdb-cluster.cockroachdb.svc.cluster.local && exit 0; sleep 3; done; exit 1'\"\n        sleep: 2\n      - command: \"kubectl -n cockroachdb wait --for=condition=ready pod -l app.kubernetes.io/name=cockroachdb --timeout=600s\"\n        timeout_sec: 640\n        sleep: 10\n    verify:\n      - command: \"/bin/sh -c 'flag=--insecure; kubectl -n cockroachdb exec crdb-cluster-0 -- ls /cockroach/cockroach-certs/ca.crt >/dev/null 2>&1 && flag=--certs-dir=/cockroach/cockroach-certs; kubectl -n cockroachdb exec crdb-cluster-0 -- ./cockroach sql $flag -e \\\"SELECT 1;\\\" 2>/dev/null'\"\n        timeout_sec: 15\n\noracle:\n  verify:\n    commands:\n      - command: \"python3 cases/cockroachdb/partitioned-update/oracle/oracle.py\"\n        timeout_sec: 120","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
