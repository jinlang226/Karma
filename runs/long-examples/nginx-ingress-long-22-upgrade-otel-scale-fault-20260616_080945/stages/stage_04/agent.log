{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01KAehpiPot7CHBpnBYJ8GmQ","type":"tool_result","content":"\tlua_shared_dict balancer_ewma 10M;\n\tlua_shared_dict balancer_ewma_last_touched_at 10M;\n\tlua_shared_dict balancer_ewma_locks 1M;\n\tserver_names_hash_max_size      1024;\n\tserver_names_hash_bucket_size   64;\n\tlog_format upstreaminfo '$remote_addr - $remote_user [$time_local] \"$request\" $status $body_bytes_sent \"$http_referer\" \"$http_user_agent\" otel_trace_id=$opentelemetry_trace_id otel_span_id=$opentelemetry_span_id';\n\taccess_log /var/log/nginx/access.log upstreaminfo  if=$loggable;\n\t\t# See https://nginx.org/en/docs/http/ngx_http_upstream_module.html#keepalive\n\tserver_name_in_redirect off;\n\tupstream upstream_balancer {\n\t\t# We no longer create \"upstream\" section for every backend.\n\t\tbalancer_by_lua_file /etc/nginx/lua/nginx/ngx_conf_balancer.lua;\n\t\tserver_name _ ;\n\t\tset $proxy_upstream_name \"-\";\n\t\t\tset $balancer_ewma_score -1;\n\t\t\tset $proxy_upstream_name \"upstream-default-backend\";\n\t\t\tset $proxy_host          $proxy_upstream_name;\n\t\t\tset $proxy_alternative_upstream_name \"\";\n\t\t\t# In case of errors try the next upstream server before returning an error\n\t\t\tproxy_next_upstream                     error timeout;\n\t\t\tproxy_next_upstream_timeout             0;\n\t\t\tproxy_next_upstream_tries               3;\n\t\t\tproxy_pass http://upstream_balancer;\n\t\tserver_name canary.example.com ;\n\t\tset $proxy_upstream_name \"-\";\n\t\t\tset $balancer_ewma_score -1;\n\t\t\tset $proxy_upstream_name \"upstream-default-backend\";\n\t\t\tset $proxy_host          $proxy_upstream_name;\n\t\t\tset $proxy_alternative_upstream_name \"\";\n\t\t\t# In case of errors try the next upstream server before returning an error","is_error":false}]},"parent_tool_use_id":null,"session_id":"e2fd028f-f289-4ccb-a409-2b47e5cd3f27","uuid":"a5339416-db86-4c96-b4aa-ec506fc17d61","timestamp":"2026-06-16T08:28