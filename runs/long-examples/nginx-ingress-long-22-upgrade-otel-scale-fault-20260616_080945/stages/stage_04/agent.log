{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VqWpD1w3VTy2kfd8M6q2Lo","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport os\n3\timport subprocess\n4\timport sys\n5\t\n6\t# Param-aware: a workflow can override host/header/body values via\n7\t# param_overrides; read BENCH_PARAM_* (default = the standalone value) so the\n8\t# oracle verifies the header-based routing this stage configured on the live,\n9\t# accumulated cluster. Pass criterion (stable without header, canary with\n10\t# header) is unchanged.\n11\tHOST = os.environ.get(\"BENCH_PARAM_HOST\") or \"canary.example.com\"\n12\tHEADER_NAME = os.environ.get(\"BENCH_PARAM_HEADER_NAME\") or \"X-Canary\"\n13\tHEADER_VALUE = os.environ.get(\"BENCH_PARAM_HEADER_VALUE\") or \"always\"\n14\tSTABLE_BODY = os.environ.get(\"BENCH_PARAM_STABLE_BODY\") or \"stable\"\n15\tCANARY_BODY = os.environ.get(\"BENCH_PARAM_CANARY_BODY\") or \"canary\"\n16\t\n17\t\n18\tdef run(cmd):\n19\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n20\t\n21\t\n22\tdef require_body(label, cmd, expected):\n23\t    result = run(cmd)\n24\t    if result.returncode != 0:\n25\t        print(f\"{label} request failed\", file=sys.stderr)\n26\t        if result.stderr:\n27\t            print(result.stderr.strip(), file=sys.stderr)\n28\t        return False\n29\t    body = result.stdout.strip()\n30\t    if body != expected:\n31\t        print(f\"{label} unexpected body: {body}\", file=sys.stderr)\n32\t        return False\n33\t    return True\n34\t\n35\t\n36\tdef main():\n37\t    base = [\n38\t        \"kubectl\",\n39\t        \"-n\",\n40\t        \"demo\",\n41\t        \"exec\",\n42\t        \"curl-test\",\n43\t        \"--\",\n44\t        \"curl\",\n45\t        \"-sS\",\n46\t        \"-H\",\n47\t        f\"Host: {HOST}\",\n48\t    ]\n49\t\n50\t    checks = [\n51\t        (\n52\t            \"stable root\",\n53\t            base + [\"http://ingress-nginx-controller.ingress-nginx.svc/\"],\n54\t            STABLE_BODY,\n55\t        ),\n56\t        (\n57\t            \"canary root\",\n58\t            base\n59\t            + [\n60\t                \"-H\",\n61\t                f\"{HEADER_NAME}: {HEADER_VALUE}\",\n62\t                \"http://ingress-nginx-controller.ingress-nginx.svc/\",\n63\t            ],\n64\t            CANARY_BODY,\n65\t        ),\n66\t    ]\n67\t\n68\t    ok = True\n69\t    for label, cmd, expected in checks:\n70\t        if not require_body(label, cmd, expected):\n71\t            ok = False\n72\t\n73\t    return 0 if ok else 1\n74\t\n75\t\n76\tif __name__ == \"__main__\":\n77\t    sys.exit(main())\n78\t"}]},"parent_tool_use_id":null,"session_id":"e2fd028f-f289-4ccb-a409-2b47e5cd3f27","uuid":"313a29d2-483b-4c52-9ff0-4d78556badd2","timestamp":"2026-06-16T08:23:20.111Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/nginx-ingress/ingress_canary/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport os\nimport subprocess\nimport sys\n\n# Param-aware: a workflow can override host/header/body values via\n# param_overrides; read BENCH_PARAM_* (default = the standalone value) so the\n# oracle verifies the header-based routing this stage configured on the live,\n# accumulated cluster. Pass criterion (stable without header, canary with\n# header) is unchanged.\nHOST = os.environ.get(\"BENCH_PARAM_HOST\") or \"canary.example.com\"\nHEADER_NAME = os.environ.get(\"BENCH_PARAM_HEADER_NAME\") or \"X-Canary\"\nHEADER_VALUE = os.environ.get(\"BENCH_PARAM_HEADER_VALUE\") or \"always\"\nSTABLE_BODY = os.environ.get(\"BENCH_PARAM_STABLE_BODY\") or \"stable\"\nCANARY_BODY = os.environ.get(\"BENCH_PARAM_CANARY_BODY\") or \"canary\"\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef require_body(label, cmd, expected):\n    result = run(cmd)\n    if result.returncode != 0:\n        print(f\"{label} request failed\", file=sys.stderr)\n        if result.stderr:\n            print(result.stderr.strip(), file=sys.stderr)\n        return False\n    body = result.stdout.strip()\n    if body != expected:\n        print(f\"{label} unexpected body: {body}\", file=sys.stderr)\n        return False\n    return True\n\n\ndef main():\n    base = [\n        \"kubectl\",\n        \"-n\",\n        \"demo\",\n        \"exec\",\n        \"curl-test\",\n        \"--\",\n        \"curl\",\n        \"-sS\",\n        \"-H\",\n        f\"Host: {HOST}\",\n    ]\n\n    checks = [\n        (\n            \"stable root\",\n            base + [\"http://ingress-nginx-controller.ingress-nginx.svc/\"],\n            STABLE_BODY,\n        ),\n        (\n            \"canary root\",\n            base\n            + [\n                \"-H\",\n                f\"{HEADER_NAME}: {HEADER_VALUE}\",\n                \"http://ingress-nginx-controller.ingress-nginx.svc/\",\n            ],\n            CANARY_BODY,\n        ),\n    ]\n\n    ok = True\n    for label, cmd, expected in checks:\n        if not require_body(label, cmd, expected):\n            ok = False\n\n    return 0 if ok else 1\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":78,"startLine":1,"totalLines":78}}}
