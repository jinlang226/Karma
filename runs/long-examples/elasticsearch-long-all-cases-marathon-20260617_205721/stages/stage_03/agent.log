rom-file=users=\"${TMP_DIR}/report/users\" --from-file=users_roles=\"${TMP_DIR}/report/users_roles\" --from-file=roles.yml=\"${TMP_DIR}/report/roles.yml\" --dry-run=client -o yaml | kubectl apply -f - || true\n200\t          '\n201\t        sleep: 1\n202\t      # Seed the app-data index that report-user reads (composition safety): the\n203\t      # standalone es_env_ready apply seeds it (via curl-test + ops_user), but on an\n204\t      # INHERITED cluster that apply is probe-skipped, so app-data is absent and the\n205\t      # oracle's report-user read fails even after a correct merge. Recreate it\n206\t      # ADDITIVELY here: deploy the curl helper if missing, wait for ops_user to go\n207\t      # live (the file realm reloads the aggregate secret created just above), then\n208\t      # PUT the index + a doc. Idempotent and data-only -- it never touches cluster\n209\t      # or security state, so it is workflow-agnostic.\n210\t      - command: \"/bin/sh -c 'kubectl -n elasticsearch get pod curl-test >/dev/null 2>&1 || kubectl -n elasticsearch apply -f cases/elasticsearch/file-realm-user-roles-merge/resource/curl-test.yaml'\"\n211\t        sleep: 1\n212\t      - command: \"/bin/sh -c 'kubectl -n elasticsearch wait --for=condition=ready pod/curl-test --timeout=300s || true'\"\n213\t        sleep: 1\n214\t      - command: |\n215\t          /bin/sh -c '\n216\t          for i in $(seq 1 60); do\n217\t            code=$(kubectl -n elasticsearch exec curl-test -- curl -s -k -o /dev/null -w \"%{http_code}\" -u {{params.ops_user}}:{{params.ops_password}} --max-time 5 \"https://{{params.http_service_name}}.elasticsearch.svc:9200/_cluster/health\" 2>/dev/null || echo 000)\n218\t            if [ \"$code\" = \"200\" ]; then\n219\t              kubectl -n elasticsearch exec curl-test -- curl -s -k -u {{params.ops_user}}:{{params.ops_password}} -XPUT \"https://{{params.http_service_name}}.elasticsearch.svc:9200/{{params.seed_index_name}}\" -H \"Content-Type: application/json\" -d