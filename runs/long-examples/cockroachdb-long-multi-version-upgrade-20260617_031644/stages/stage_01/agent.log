luster-2.crdb-cluster.cockroachdb.svc.cluster.local\n        - --cache=25%\n        - --max-sql-memory=25%\n        env:\n        - name: POD_NAME\n          valueFrom:\n            fieldRef:\n              fieldPath: metadata.name\n        volumeMounts:\n        - name: datadir\n          mountPath: /cockroach/cockroach-data\n        livenessProbe:\n          httpGet:\n            path: /health\n            port: 8080\n          initialDelaySeconds: 30\n          periodSeconds: 5\n        readinessProbe:\n          httpGet:\n            path: /health?ready=1\n            port: 8080\n          initialDelaySeconds: 10\n          periodSeconds: 5\n          failureThreshold: 2\n  volumeClaimTemplates:\n  - metadata:\n      name: datadir\n    spec:\n      accessModes: [ReadWriteOnce]\n      resources:\n        requests:\n          storage: 10Gi\nEOF","description":"Deploy headless service, public service, PDB, and StatefulSet for CockroachDB"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":317,"cache_read_input_tokens":28380,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":317},"output_tokens":4,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"01312bd2-5a74-4040-b24e-a9fadc515307","uuid":"1551ed1c-6f3a-45c4-b05b-bfa2360178c6","request_id":"req_011Cc87BpZC4vSkE2bw1efbs"}
