{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012QwhbmM9UPkqu8tLMz9JRe","type":"tool_result","content":"1\t# mongodb/initialize\n2\t# MongoDB initialize task\n3\t\n4\tparams:\n5\t  cluster_prefix:\n6\t    default: mongodb-replica\n7\t    description: StatefulSet name of the replica set members.\n8\t  replica_set_name:\n9\t    default: mongodb-replica\n10\t    description: MongoDB replica set _id used when initiating the set.\n11\t  fault_host_suffix:\n12\t    default: mongo-wrong\n13\t    description: Bad host suffix injected to break a member's configuration.\n14\t  app_database:\n15\t    default: app\n16\t    description: Application database seeded with data.\n17\t  app_collection:\n18\t    default: test\n19\t    description: Application collection seeded with data.\n20\t\n21\tprompt: |\n22\t  Replica set is not healthy. Restore a stable 3-member replica set without data loss.\n23\t\n24\tnamespace_contract:\n25\t  required_roles: []\n26\t\n27\tmetrics:\n28\t  - time_to_first_mutation\n29\t\n30\tpreconditionUnits:\n31\t  - name: mongo_env_ready\n32\t    on_probe_fail: skip\n33\t    probe:\n34\t      - command: \"kubectl -n mongodb get pod {{params.cluster_prefix}}-0 2>/dev/null | grep -c Running\"\n35\t        timeout_sec: 10\n36\t    apply:\n37\t      - command: |\n38\t          /bin/sh -c '\n39\t          kubectl delete namespace mongodb --ignore-not-found=true; kubectl wait --for=delete namespace/mongodb --timeout=120s || true\n40\t          '\n41\t        sleep: 2\n42\t      - command: \"kubectl create namespace mongodb\"\n43\t        sleep: 1\n44\t      - command: \"kubectl -n mongodb apply -f cases/mongodb/initialize/resource/services.yaml\"\n45\t        sleep: 2\n46\t      - command: \"kubectl -n mongodb apply -f cases/mongodb/initialize/resource/statefulset.yaml\"\n47\t        sleep: 5\n48\t      - command: |\n49\t          for i in $(seq 1 120); do\n50\t            ready=$(kubectl -n mongodb get sts {{params.cluster_prefix}} -o jsonpath='{.status.readyReplicas}' 2>/dev/null)\n51\t            if [ \"${ready:-0}\" -ge 3 ]; then\n52\t              exit 0\n53\t            fi\n54\t            sleep 5\n55\t          done\n56\t          exit 1\n57\t        sleep: 2\n58\t      - command: |\n59\t          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\n60\t          rs.initiate({_id:\"{{params.replica_set_name}}\",members:[\n61\t            {_id:0,host:\"mongodb-replica-0.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"},\n62\t            {_id:1,host:\"mongodb-replica-1.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"},\n63\t            {_id:2,host:\"mongodb-replica-2.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"}\n64\t          ]})'\n65\t        sleep: 5\n66\t      - command: |\n67\t          for i in $(seq 1 20); do\n68\t            kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval 'db.hello().isWritablePrimary' | grep true && exit 0\n69\t            sleep 3\n70\t          done\n71\t          exit 1\n72\t        sleep: 2\n73\t      - command: |\n74\t          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\n75\t          cfg = rs.conf();\n76\t          cfg.members[1].host = \"mongodb-replica-1.{{params.fault_host_suffix}}.svc.cluster.local:27017\";\n77\t          cfg.version += 1;\n78\t          rs.reconfig(cfg);\n79\t          '\n80\t        sleep: 5\n81\t      - command: \"kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval 'db.getSiblingDB(\\\"{{params.app_database}}\\\").{{params.app_collection}}.insertMany([{x:1},{x:2},{x:3}], {writeConcern:{w:1}});'\"\n82\t        sleep: 2\n83\t    verify:\n84\t      - command: \"kubectl -n mongodb get pods 2>/dev/null | grep -c Running\"\n85\t        timeout_sec: 10\n86\t\n87\t  # Additive data fixture (composition safety): the oracle requires >= 3 docs in\n88\t  # {{params.app_database}}.{{params.app_collection}}. When this case runs chained on an inherited cl