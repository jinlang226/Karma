'root', db: 'admin'}]\n          });\n          print('[mongo] admin-user created');\n        \"\n\n        # Create app user — auth required now (admin user was just created)\n        echo \"[mongo] pod-0: Creating app user...\"\n        mongosh \"mongodb://admin-user:${ADMIN_PASSWORD}@localhost:27017/?authSource=admin\" --eval \"\n          db.getSiblingDB('appdb').createUser({\n            user: 'app-user',\n            pwd: '${APP_PASSWORD}',\n            roles: [{role: 'readWrite', db: 'appdb'}]\n          });\n          print('[mongo] app-user created');\n        \"\n\n        touch \"$MARKER\"\n        echo \"[mongo] pod-0: Initialization complete!\"\n      else\n        echo \"[mongo] pod-0: Already initialized, skipping\"\n      fi\n    fi\n\n    echo \"[mongo] $POD_NAME: Running — waiting on mongod PID $MONGOD_PID\"\n    wait $MONGOD_PID\n---\napiVersion: v1\nkind: Service\nmetadata:\n  name: mongodb-replica-svc\n  namespace: mongodb\n  labels:\n    app: mongodb-replica\nspec:\n  clusterIP: None\n  selector:\n    app: mongodb-replica\n  ports:\n  - name: mongodb\n    port: 27017\n    targetPort: 27017\n---\napiVersion: apps/v1\nkind: StatefulSet\nmetadata:\n  name: mongodb-replica\n  namespace: mongodb\nspec:\n  serviceName: mongodb-replica-svc\n  replicas: 3\n  selector:\n    matchLabels:\n      app: mongodb-replica\n  template:\n    metadata:\n      labels:\n        app: mongodb-replica\n    spec:\n      terminationGracePeriodSeconds: 30\n      initContainers:\n      - name: init-keyfile\n        image: busybox:1.36\n        command:\n        - sh\n        - -c\n        - |\n          cp /keyfile-src/keyfile /keyfile/keyfile\n          chmod 400 /keyfile/keyfile\n        volumeMounts:\n        - name: keyfile-src\n          mountPath: /keyfile-src\n          readOnly: true\n        - name: keyfile\n          mountPath: /keyfile\n      containers:\n      - name: mongodb\n        image: mongo:7.0\n        command: [\"/bin/bash\", \"/scripts/init.sh\"]\n        env:\n        - name: ADMIN_PASSWORD\n          valueFrom:\n            secretKeyRef:\n              name: admin-user-password\n              key: password\n        - name: APP_PASSWORD\n          valueFrom:\n            secretKeyRef:\n              name: app-user-password\n              key: password\n        ports:\n        - containerPort: 27017\n          name: mongodb\n        volumeMounts:\n        - name: data\n          mountPath: /data/db\n        - name: keyfile\n          mountPath: /etc/mongodb/keyfile\n        - name: scripts\n          mountPath: /scripts\n        readinessProbe:\n          exec:\n            command:\n            - mongosh\n            - --quiet\n            - --eval\n            - \"db.adminCommand({ping:1}).ok\"\n          initialDelaySeconds: 15\n          periodSeconds: 10\n          failureThreshold: 6\n          timeoutSeconds: 5\n        livenessProbe:\n          exec:\n            command:\n            - mongosh\n            - --quiet\n            - --eval\n            - \"db.adminCommand({ping:1}).ok\"\n          initialDelaySeconds: 30\n          periodSeconds: 15\n          failureThreshold: 6\n          timeoutSeconds: 5\n        resources:\n          requests:\n            memory: 256Mi\n            cpu: 100m\n          limits:\n            memory: 1Gi\n            cpu: 1000m\n      volumes:\n      - name: keyfile-src\n        secret:\n          secretName: mongodb-keyfile\n      - name: keyfile\n        emptyDir: {}\n      - name: scripts\n        configMap:\n          name: mongodb-init-scripts\n          defaultMode: 0755\n  volumeClaimTemplates:\n  - metadata:\n      name: data\n    spec:\n      accessModes: [\"ReadWriteOnce\"]\n      resources:\n        requests:\n          storage: 1Gi\n","structuredPatch":[{"oldStart":1,"oldLines":4,"newStart":1,"newLines":124,"lines":["+---"," apiVersion: v1","+kind: ConfigMap","+metadata:","+  name: mongodb-init-scripts","+  namespace: mongodb","+data:","+  init.sh: |","+    #!/bin/bash","+    set -eo pipefail","+","+    KEYFILE=/etc/mongodb/keyfile/keyfile","+    REPLSET=\"mongodb-replica\"","+    POD_NAME=$(hostname)","+    DATA_DIR=/data/db","+","+    echo \"[mongo] Starting on pod: $POD_NAME\"","+","+    # Launch mongod in the background","+    mongod \\","+      --port 27017 \\","+      --bind_ip_all \\","+      --replSet \"$REPLSET\" \\","+      --auth \\","+      --keyFile \"$KEYFILE\" \\","+      --dbpath \"$DATA_DIR\" &","+    MONGOD_PID=$!","+","+    # Forward signals to mongod for clean shutdown","+    trap 'kill $MONGOD_PID 2>/dev/null; wait $MONGOD_PID 2>/dev/null; exit 0' SIGTERM SIGINT","+","+    # Wait for mongod to accept connections","+    echo \"[mongo] Waiting for mongod to be ready...\"","+    until mongosh --quiet --eval \"db.adminCommand({ping:1}).ok\" 2>/dev/null | grep -q \"1\"; do","+      kill -0 $MONGOD_PID 2>/dev/null || { echo \"[mongo] mongod exited unexpectedly\"; exit 1; }","+      sleep 2","+    done","+    echo \"[mongo] $POD_NAME: mongod ready\"","+","+    # Only pod-0 initializes the replica set and creates users","+    if [[ \"$POD_NAME\" == \"mongodb-replica-0\" ]]; then","+      MARKER=\"$DATA_DIR/.cluster_initialized\"","+","+      if [[ ! -f \"$MARKER\" ]]; then","+        echo \"[mongo] pod-0: Running first-time initialization...\"","+","+        # Retry rs.initiate until all 3 members are reachable (they auth via keyfile)","+        INIT_OK=0","+        for i in $(seq 1 50); do","+          RESULT=$(mongosh --quiet --eval \"","+            try {","+              var r = rs.initiate({","+                _id: 'mongodb-replica',","+                members: [","+                  {_id:0, host:'mongodb-replica-0.mongodb-replica-svc.mongodb.svc.cluster.local:27017'},","+                  {_id:1, host:'mongodb-replica-1.mongodb-replica-svc.mongodb.svc.cluster.local:27017'},","+                  {_id:2, host:'mongodb-replica-2.mongodb-replica-svc.mongodb.svc.cluster.local:27017'}","+                ]