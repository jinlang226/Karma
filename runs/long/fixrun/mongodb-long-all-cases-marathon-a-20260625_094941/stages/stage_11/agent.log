alth check to pass. Pod 0 doesn't actually need a readiness probe since it was running before this was introduced, but pods 1 and 2 are failing because the `health-user` account doesn't exist in MongoDB and the configmap override for `mongodb-replica-1` has the wrong credentials. I need to verify whether the health-user was created on the original instance or if I need to create it fresh.","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1562,"cache_read_input_tokens":36379,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1562},"output_tokens":29,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"9731a3ed-bba7-4ccc-9e46-12984eb1330e","uuid":"945d7a17-a9fc-4e74-83e6-1330c236a5be","request_id":"req_011CcPrWuddXBohcQQUX5rrm"}
