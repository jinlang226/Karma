{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01BKfQvuBRiGR4zbokKy5SJo","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport base64\n3\timport json\n4\timport os\n5\timport subprocess\n6\timport sys\n7\t\n8\t# Param-aware: a workflow may override the file-realm users/passwords, the\n9\t# aggregate secret name, the HTTP service, or the seed index via param_overrides\n10\t# (e.g. custom-users-password-audit renames the users). Defaults equal the\n11\t# standalone hardcoded values, so standalone behaviour is unchanged; this only\n12\t# redirects WHICH live users/secret/index are verified, never loosens the check.\n13\tNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"elasticsearch\")\n14\tSERVICE = os.environ.get(\"BENCH_PARAM_HTTP_SERVICE_NAME\", \"es-http\")\n15\tSECRET = os.environ.get(\"BENCH_PARAM_AGGREGATE_SECRET_NAME\", \"es-file-realm-aggregate\")\n16\tOPS_USER = os.environ.get(\"BENCH_PARAM_OPS_USER\", \"ops-user\")\n17\tOPS_PASS = os.environ.get(\"BENCH_PARAM_OPS_PASSWORD\", \"opspass\")\n18\tREPORT_USER = os.environ.get(\"BENCH_PARAM_REPORT_USER\", \"report-user\")\n19\tREPORT_PASS = os.environ.get(\"BENCH_PARAM_REPORT_PASSWORD\", \"reportpass\")\n20\tINDEX = os.environ.get(\"BENCH_PARAM_SEED_INDEX_NAME\", \"app-data\")\n21\t# Standalone this case runs ES with HTTP TLS on, so https is the default; a\n22\t# prior stage could have disabled it, so _detect_scheme() flips to http. Auth\n23\t# (-u user:pass) is always kept, so wrong credentials still fail.\n24\tDEFAULT_SCHEME = \"https\"\n25\t_SCHEME = None\n26\t\n27\t\n28\tdef run(cmd):\n29\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n30\t\n31\t\n32\tdef _probe_scheme(scheme):\n33\t    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\n34\t\n35\t    A 401 still proves the scheme is live, so this only picks http vs https and\n36\t    never bypasses the per-user auth the real checks perform.\n37\t    \"\"\"\n38\t    result = run([\n39\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\",\n40\t        \"curl\", \"-s\", \"-S\", \"-k\", \"-o\", \"/dev/null\",\n41\t        \"-w\", \"%{http_code}\", \"--max-time\", \"10\",\n42\t        f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200/\",\n43\t    ])\n44\t    code = (result.stdout or \"\").strip()\n45\t    return result.returncode == 0 and code.isdigit() and code != \"000\"\n46\t\n47\t\n48\tdef detect_scheme():\n49\t    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n50\t    global _SCHEME\n51\t    if _SCHEME is not None:\n52\t        return _SCHEME\n53\t    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n54\t        if _probe_scheme(scheme):\n55\t            _SCHEME = scheme\n56\t            return _SCHEME\n57\t    _SCHEME = DEFAULT_SCHEME\n58\t    return _SCHEME\n59\t\n60\t\n61\tdef curl_json(path, user, password, errors):\n62\t    scheme = detect_scheme()\n63\t    cmd = [\n64\t        \"kubectl\",\n65\t        \"-n\",\n66\t        NAMESPACE,\n67\t        \"exec\",\n68\t        \"curl-test\",\n69\t        \"--\",\n70\t        \"curl\",\n71\t        \"-s\",\n72\t        \"-S\",\n73\t        \"--max-time\",\n74\t        \"10\",\n75\t        \"-k\",\n76\t        \"-u\",\n77\t        f\"{user}:{password}\",\n78\t        f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\",\n79\t    ]\n80\t    result = run(cmd)\n81\t    if result.returncode != 0:\n82\t        detail = result.stderr.strip() or result.stdout.strip() or f\"command terminated with exit code {result.returncode}\"\n83\t        errors.append(f\"Failed to query {path} as {user}: {detail}\")\n84\t        return None\n85\t    output = result.stdout.strip()\n86\t    if not output:\n87\t        errors.append(f\"Empty response for {path} as {user}\")\n88\t        return None\n89\t    try:\n90\t        return json.loads(output)\n91\t    except json.JSONDecodeError:\n92\t        errors.append(f\"Failed to parse JSON from {path} as {user}\")\n93\t        return None\n94\t\n95\t\n96\tdef get_secret(errors):\n97\t    result = run(\n98\t        [\n99\t            \"kubectl\",\n100\t            \"-n\",\n101\t            NAMESPACE,\n102\t            \"get\",\n103\t            \"secret\",\n104\t            SECRET,\n105\t            \"-o\",\n106\t            \"json\",\n107\t        ]\n108\t    )\n109\t    if result.returncode != 0:\n110\t        errors.append(f\"Failed to read {SECRET} secret: {result.stderr.strip()}\")\n111\t        return None\n112\t    try:\n113\t        return json.loads(result.stdout)\n114\t    except json.JSONDecodeError:\n115\t        errors.append(f\"Failed to parse {SECRET} secret JSON\")\n116\t        return None\n117\t\n118\t\n119\tdef decode_field(data, key, errors):\n120\t    value = data.get(key)\n121\t    if value is None:\n122\t        errors.append(f\"Missing {key} in {SECRET} secret\")\n123\t        return \"\"\n124\t    try:\n125\t        return base64.b64decode(value).decode(\"utf-8\", \"replace\")\n126\t    except Exception as exc:\n127\t        errors.append(f\"Failed to decode {key} in {SECRET} secret: {exc}\")\n128\t        return \"\"\n129\t\n130\t\n131\tdef parse_users(text):\n132\t    users = set()\n133\t    for line in text.splitlines():\n134\t        line = line.strip()\n135\t        if not line or line.startswith(\"#\"):\n136\t            continue\n137\t        parts = line.split(\":\", 1)\n138\t        if parts:\n139\t            users.add(parts[0].strip())\n140\t    return users\n141\t\n142\t\n143\tdef parse_users_roles(text):\n144\t    users = set()\n145\t    for line in text.splitlines():\n146\t        line = line.strip()\n147\t        if not line or line.startswith(\"#\"):\n148\t            continue\n149\t        parts = line.split(\":\", 1)\n150\t        if len(parts) != 2:\n151\t            continue\n152\t        for user in parts[1].split(\",\"):\n153\t            user = user.strip()\n154\t            if user:\n155\t                users.add(user)\n156\t    return users\n157\t\n158\t\n159\tdef evaluate():\n160\t    \"\"\"One full snapshot of the file-realm merge checks; returns the error list.\"\"\"\n161\t    errors = []\n162\t\n163\t    secret = get_secret(errors)\n164\t    if secret is None:\n165\t        return errors\n166\t\n167\t    data = secret.get(\"data\", {})\n168\t    users_text = decode_field(data, \"users\", errors)\n169\t    users_roles_text = decode_field(data, \"users_roles\", errors)\n170\t\n171\t    expected = {OPS_USER, REPORT_USER}\n172\t    users = parse_users(users_text)\n173\t    missing_users = sorted(expected - users)\n174\t    if missing_users:\n175\t        errors.append(f\"Missing users in {SECRET}: {', '.join(missing_users)}\")\n176\t\n177\t    users_roles = parse_users_roles(users_roles_text)\n178\t    missing_roles = sorted(expected - users_roles)\n179\t    if missing_roles:\n180\t        errors.append(\n181\t            f\"Missing users in {SECRET} users_roles: {', '.join(missing_roles)}\"\n182\t        )\n183\t\n184\t    health = curl_json(\"/_cluster/health\", OPS_USER, OPS_PASS, errors)\n185\t    if isinstance(health, dict):\n186\t        status = health.get(\"status\")\n187\t        if status not in {\"yellow\", \"green\"}:\n188\t            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n189\t\n190\t    count = curl_json(f\"/{INDEX}/_count\", REPORT_USER, REPORT_PASS, errors)\n191\t    if isinstance(count, dict):\n192\t        if \"count\" not in count:\n193\t            errors.append(\"report-user failed to read app-data count\")\n194\t\n195\t    return errors\n196\t\n197\t\n198\tdef main():\n199\t    # The agent enables the file realm by patching the StatefulSet + ConfigMap,\n200\t    # which triggers a rolling restart; the merged users (report-user/ops-user)\n201\t    # only become authenticatable AFTER that restart reloads the realm. A single\n202\t    # snapshot can run before that convergence and see \"report-user failed to\n203\t    # read app-data count\" on a correctly-configured cluster. Re-evaluate for up\n204\t    # to ~120s and pass on the first clean snapshot. A genuinely missing\n205\t    # user/role/permission never authenticates, so the oracle still fails after\n206\t    # the deadline.\n207\t    import time\n208\t    deadline = time.monotonic() + 120\n209\t    errors = evaluate()\n210\t    while errors and time.monotonic() < deadline:\n211\t        time.sleep(8)\n212\t        errors = evaluate()\n213\t\n214\t    if errors:\n215\t        print_errors(errors)\n216\t        return 1\n217\t\n218\t    print(\"File realm merge verified\")\n219\t    return 0\n220\t\n221\t\n222\tdef print_errors(errors):\n223\t    print(\"File realm merge verification failed:\", file=sys.stderr)\n224\t    for err in errors:\n225\t        print(f\"  - {err}\", file=sys.stderr)\n226\t\n227\t\n228\tif __name__ == \"__main__\":\n229\t    sys.exit(main())\n230\t"}]},"parent_tool_use_id":null,"session_id":"7e179615-5b60-4d30-9419-ea104fd0d74c","uuid":"78363e58-6a62-401b-a171-ffb67539b096","timestamp":"2026-06-25T00:53:07.078Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/elasticsearch/file-realm-user-roles-merge/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport base64\nimport json\nimport os\nimport subprocess\nimport sys\n\n# Param-aware: a workflow may override the file-realm users/passwords, the\n# aggregate secret name, the HTTP service, or the seed index via param_overrides\n# (e.g. custom-users-password-audit renames the users). Defaults equal the\n# standalone hardcoded values, so standalone behaviour is unchanged; this only\n# redirects WHICH live users/secret/index are verified, never loosens the check.\nNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"elasticsearch\")\nSERVICE = os.environ.get(\"BENCH_PARAM_HTTP_SERVICE_NAME\", \"es-http\")\nSECRET = os.environ.get(\"BENCH_PARAM_AGGREGATE_SECRET_NAME\", \"es-file-realm-aggregate\")\nOPS_USER = os.environ.get(\"BENCH_PARAM_OPS_USER\", \"ops-user\")\nOPS_PASS = os.environ.get(\"BENCH_PARAM_OPS_PASSWORD\", \"opspass\")\nREPORT_USER = os.environ.get(\"BENCH_PARAM_REPORT_USER\", \"report-user\")\nREPORT_PASS = os.environ.get(\"BENCH_PARAM_REPORT_PASSWORD\", \"reportpass\")\nINDEX = os.environ.get(\"BENCH_PARAM_SEED_INDEX_NAME\", \"app-data\")\n# Standalone this case runs ES with HTTP TLS on, so https is the default; a\n# prior stage could have disabled it, so _detect_scheme() flips to http. Auth\n# (-u user:pass) is always kept, so wrong credentials still fail.\nDEFAULT_SCHEME = \"https\"\n_SCHEME = None\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef _probe_scheme(scheme):\n    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\n\n    A 401 still proves the scheme is live, so this only picks http vs https and\n    never bypasses the per-user auth the real checks perform.\n    \"\"\"\n    result = run([\n        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\",\n        \"curl\", \"-s\", \"-S\", \"-k\", \"-o\", \"/dev/null\",\n        \"-w\", \"%{http_code}\", \"--max-time\", \"10\",\n        f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200/\",\n    ])\n    code = (result.stdout or \"\").strip()\n    return result.returncode == 0 and code.isdigit() and code != \"000\"\n\n\ndef detect_scheme():\n    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n    global _SCHEME\n    if _SCHEME is not None:\n        return _SCHEME\n    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n        if _probe_scheme(scheme):\n            _SCHEME = scheme\n            return _SCHEME\n    _SCHEME = DEFAULT_SCHEME\n    return _SCHEME\n\n\ndef curl_json(path, user, password, errors):\n    scheme = detect_scheme()\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"exec\",\n        \"curl-test\",\n        \"--\",\n        \"curl\",\n        \"-s\",\n        \"-S\",\n        \"--max-time\",\n        \"10\",\n        \"-k\",\n        \"-u\",\n        f\"{user}:{password}\",\n        f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\",\n    ]\n    result = run(cmd)\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"command terminated with exit code {result.returncode}\"\n        errors.append(f\"Failed to query {path} as {user}: {detail}\")\n        return None\n    output = result.stdout.strip()\n    if not output:\n        errors.append(f\"Empty response for {path} as {user}\")\n        return None\n    try:\n        return json.loads(output)\n    except json.JSONDecodeError:\n        errors.append(f\"Failed to parse JSON from {path} as {user}\")\n        return None\n\n\ndef get_secret(errors):\n    result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"get\",\n            \"secret\",\n            SECRET,\n            \"-o\",\n            \"json\",\n        ]\n    )\n    if result.returncode != 0:\n        errors.append(f\"Failed to read {SECRET} secret: {result.stderr.strip()}\")\n        return None\n    try:\n        return json.loads(result.stdout)\n    except json.JSONDecodeError:\n        errors.append(f\"Failed to parse {SECRET} secret JSON\")\n        return None\n\n\ndef decode_field(data, key, errors):\n    value = data.get(key)\n    if value is None:\n        errors.append(f\"Missing {key} in {SECRET} secret\")\n        return \"\"\n    try:\n        return base64.b64decode(value).decode(\"utf-8\", \"replace\")\n    except Exception as exc:\n        errors.append(f\"Failed to decode {key} in {SECRET} secret: {exc}\")\n        return \"\"\n\n\ndef parse_users(text):\n    users = set()\n    for line in text.splitlines():\n        line = line.strip()\n        if not line or line.startswith(\"#\"):\n            continue\n        parts = line.split(\":\", 1)\n        if parts:\n            users.add(parts[0].strip())\n    return users\n\n\ndef parse_users_roles(text):\n    users = set()\n    for line in text.splitlines():\n        line = line.strip()\n        if not line or line.startswith(\"#\"):\n            continue\n        parts = line.split(\":\", 1)\n        if len(parts) != 2:\n            continue\n        for user in parts[1].split(\",\"):\n            user = user.strip()\n            if user:\n                users.add(user)\n    return users\n\n\ndef evaluate():\n    \"\"\"One full snapshot of the file-realm merge checks; returns the error list.\"\"\"\n    errors = []\n\n    secret = get_secret(errors)\n    if secret is None:\n        return errors\n\n    data = secret.get(\"data\", {})\n    users_text = decode_field(data, \"users\", errors)\n    users_roles_text = decode_field(data, \"users_roles\", errors)\n\n    expected = {OPS_USER, REPORT_USER}\n    users = parse_users(users_text)\n    missing_users = sorted(expected - users)\n    if missing_users:\n        errors.append(f\"Missing users in {SECRET}: {', '.join(missing_users)}\")\n\n    users_roles = parse_users_roles(users_roles_text)\n    missing_roles = sorted(expected - users_roles)\n    if missing_roles:\n        errors.append(\n            f\"Missing users in {SECRET} users_roles: {', '.join(missing_roles)}\"\n        )\n\n    health = curl_json(\"/_cluster/health\", OPS_USER, OPS_PASS, errors)\n    if isinstance(health, dict):\n        status = health.get(\"status\")\n        if status not in {\"yellow\", \"green\"}:\n            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n\n    count = curl_json(f\"/{INDEX}/_count\", REPORT_USER, REPORT_PASS, errors)\n    if isinstance(count, dict):\n        if \"count\" not in count:\n            errors.append(\"report-user failed to read app-data count\")\n\n    return errors\n\n\ndef main():\n    # The agent enables the file realm by patching the StatefulSet + ConfigMap,\n    # which triggers a rolling restart; the merged users (report-user/ops-user)\n    # only become authenticatable AFTER that restart reloads the realm. A single\n    # snapshot can run before that convergence and see \"report-user failed to\n    # read app-data count\" on a correctly-configured cluster. Re-evaluate for up\n    # to ~120s and pass on the first clean snapshot. A genuinely missing\n    # user/role/permission never authenticates, so the oracle still fails after\n    # the deadline.\n    import time\n    deadline = time.monotonic() + 120\n    errors = evaluate()\n    while errors and time.monotonic() < deadline:\n        time.sleep(8)\n        errors = evaluate()\n\n    if errors:\n        print_errors(errors)\n        return 1\n\n    print(\"File realm merge verified\")\n    return 0\n\n\ndef print_errors(errors):\n    print(\"File realm merge verification failed:\", file=sys.stderr)\n    for err in errors:\n        print(f\"  - {err}\", file=sys.stderr)\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":230,"startLine":1,"totalLines":230}}}
