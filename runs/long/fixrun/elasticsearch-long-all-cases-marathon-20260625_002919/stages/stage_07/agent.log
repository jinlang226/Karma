opriate annotations and TLS configuration.","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":6043,"cache_read_input_tokens":30493,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":6043},"output_tokens":21,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"2d9d93cf-0463-4f1c-8674-d960aa69c1d1","uuid":"5662bde3-55d9-43c4-8316-f9a12a90dec9","request_id":"req_011CcP6y4cinWk6mbCG7icoG"}
