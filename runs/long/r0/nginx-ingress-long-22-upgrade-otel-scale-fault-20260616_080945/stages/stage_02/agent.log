ot-found=true; kubectl delete namespace ingress-nginx-2 --ignore-not-found=true; kubectl delete namespace demo --ignore-not-found=true; kubectl wait --for=delete namespace/ingress-nginx --timeout=120s || true; kubectl wait --for=delete namespace/ingress-nginx-2 --timeout=120s || true; kubectl wait --for=delete namespace/demo --timeout=120s || true'\"\n        sleep: 1\n      - command: \"kubectl create namespace ingress-nginx\"\n        sleep: 0\n      - command: \"kubectl apply -f cases/nginx-ingress/class_only_upgrade/resource/deploy.yaml\"\n        sleep: 90\n      - command: \"kubectl -n ingress-nginx rollout status deploy/ingress-nginx-controller --timeout=120s\"\n        sleep: 2\n      - command: \"kubectl -n ingress-nginx patch deployment ingress-nginx-controller --type=json -p '[{\\\"op\\\":\\\"add\\\",\\\"path\\\":\\\"/spec/template/spec/containers/0/args/-\\\",\\\"value\\\":\\\"--controller-class=k8s.io/ingress-nginx-1\\\"},{\\\"op\\\":\\\"add\\\",\\\"path\\\":\\\"/spec/template/spec/containers/0/args/-\\\",\\\"value\\\":\\\"--ingress-class=ingress-1\\\"},{\\\"op\\\":\\\"add\\\",\\\"path\\\":\\\"/spec/template/spec/containers/0/args/-\\\",\\\"value\\\":\\\"--watch-ingress-without-class=false\\\"}]'\"\n        sleep: 1\n      - command: \"kubectl -n ingress-nginx rollout status deploy/ingress-nginx-controller --timeout=120s\"\n        sleep: 2\n      - command: \"kubectl delete ingressclass ingress-1 ingress-2 --ignore-not-found\"\n        sleep: 0\n      - command: \"kubectl apply -f cases/nginx-ingress/class_only_upgrade/resource/ingress-classes.yaml\"\n        sleep: 1\n      - command: \"bash -c 'IMAGE=$(kubectl -n ingress-nginx get deploy ingress-nginx-controller -o jsonpath=\\\"{.spec.template.spec.containers[0].image}\\\"); sed \\\"s|{{INGRESS_NGINX_IMAGE}}|$IMAGE|g\\\" cases/nginx-ingress/class_only_upgrade/resource/ingress-nginx-2.yaml | kubectl apply -f -'\"\n        sleep: 2\n      - command: \"kubectl -n ingress-nginx-2 rollout status deploy/ingress-nginx-controller --timeout=120s\"\n        sleep: 2\n      - command: \"kubectl create namespace demo\"\n        sleep: 0\n      - command: \"kubectl -n demo apply -f cases/nginx-ingress/class_only_upgrade/resource/ingress-gateway.yaml\"\n        sleep: 1\n      - command: \"kubectl -n demo apply -f cases/nginx-ingress/class_only_upgrade/resource/demo-app.yaml\"\n        sleep: 2\n      - command: \"kubectl -n demo rollout status deploy/demo-app --timeout=60s\"\n        sleep: 1\n      - command: \"kubectl -n demo apply -f cases/nginx-ingress/class_only_upgrade/resource/demo-ingress.yaml\"\n        sleep: 1\n      - command: \"kubectl -n demo apply -f cases/nginx-ingress/class_only_upgrade/resource/curl-test.yaml\"\n        sleep: 1\n      - command: \"kubectl -n demo wait --for=condition=Ready pod/{{params.curl_pod_name}} --timeout=180s\"\n        sleep: 1\n    verify:\n      - command: \"kubectl -n demo wait --for=condition=ready pod/{{params.curl_pod_name}} --timeout=5s\"\n        timeout_sec: 30\n\noracle:\n  verify:\n    commands:\n      - command: \"python3 cases/nginx-ingress/class_only_upgrade/oracle/oracle.py\"\n        timeout_sec: 60\n","numLines":105,"startLine":1,"totalLines":105}}}
