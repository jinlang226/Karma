robe:\n      - command: \"kubectl -n demo wait --for=condition=ready pod/{{params.curl_pod_name}} --timeout=5s\"\n        timeout_sec: 10\n    apply:\n      - command: \"/bin/sh -c 'kubectl delete namespace ingress-nginx --ignore-not-found=true; kubectl delete namespace demo --ignore-not-found=true; kubectl wait --for=delete namespace/ingress-nginx --timeout=120s || true; kubectl wait --for=delete namespace/demo --timeout=120s || true'\"\n        sleep: 1\n      - command: \"kubectl create namespace ingress-nginx\"\n        sleep: 0\n      - command: \"kubectl apply -f cases/nginx-ingress/ingress_canary/resource/deploy.yaml\"\n        sleep: 90\n      - command: \"kubectl -n ingress-nginx rollout status deploy/ingress-nginx-controller --timeout=120s\"\n        sleep: 2\n      - command: \"kubectl create namespace demo\"\n        sleep: 0\n      - command: \"kubectl -n demo apply -f cases/nginx-ingress/ingress_canary/resource/stable-echo.yaml\"\n        sleep: 2\n      - command: \"kubectl -n demo apply -f cases/nginx-ingress/ingress_canary/resource/canary-echo.yaml\"\n        sleep: 2\n      - command: \"kubectl -n demo rollout status deploy/stable-echo --timeout=60s\"\n        sleep: 1\n      - command: \"kubectl -n demo rollout status deploy/canary-echo --timeout=60s\"\n        sleep: 1\n      - command: \"kubectl -n demo apply -f cases/nginx-ingress/ingress_canary/resource/ingress-stable.yaml\"\n        sleep: 1\n      - command: \"kubectl -n demo apply -f cases/nginx-ingress/ingress_canary/resource/ingress-canary.yaml\"\n        sleep: 1\n      - command: \"kubectl -n demo apply -f cases/nginx-ingress/ingress_canary/resource/curl-test.yaml\"\n        sleep: 1\n      - command: \"kubectl -n demo wait --for=condition=Ready pod/{{params.curl_pod_name}} --timeout=180s\"\n        sleep: 1\n    verify:\n      - command: \"kubectl -n demo wait --for=condition=ready pod/{{params.curl_pod_name}} --timeout=5s\"\n        timeout_sec: 30\n\noracle:\n  verify:\n    commands: