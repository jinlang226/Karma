─────────────────────────────────────────────────────\n# Remove every non-default user.  Their permissions on \"/\" are removed with them.\necho \"[4/5] Deleting non-default users\"\n$RC delete_user admin\n$RC delete_user app-user\n$RC delete_user ops-user\n\n# ── Restore default guest user ────────────────────────────────────────────────\n# Default RabbitMQ ships with guest:guest (administrator) + full perms on \"/\".\n# Re-create it only if it was removed.\necho \"[5/5] Restoring default guest user (if absent)\"\nif ! $RC list_users 2>/dev/null | awk 'NR>1{print $1}' | grep -qx \"guest\"; then\n    $RC add_user guest guest\n    $RC set_user_tags guest administrator\n    $RC set_permissions -p / guest \".*\" \".*\" \".*\"\n    echo \"  guest user restored.\"\nelse\n    echo \"  guest user already present, skipping.\"\nfi\n\necho \"=== Rollback complete. Cluster is at RabbitMQ factory defaults. ===\"\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":434,"cache_read_input_tokens":33061,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":434},"output_tokens":11,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"f7b0dae4-dd1f-41a4-b0d2-cbbf9b9d9efd","uuid":"0ee77395-fa17-4737-9589-a6d28a186cf1","request_id":"req_011CcMUF1GwhBRpjYUSuWMDo"}
