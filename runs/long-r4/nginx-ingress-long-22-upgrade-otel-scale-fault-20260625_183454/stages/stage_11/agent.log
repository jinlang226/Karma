_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":143,"cache_read_input_tokens":37085,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":143},"output_tokens":30,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"13363abc-cd1f-4d00-b35e-9308d96f7e1f","uuid":"0e91981f-4318-4795-bbf0-91bb198684c1","request_id":"req_011CcQWCU4AmhNGPywqYFrEe"}
