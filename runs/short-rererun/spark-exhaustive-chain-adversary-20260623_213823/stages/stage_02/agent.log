{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_0115teEuohKBGUg3wrSKqHh8","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\t\"\"\"Oracle for spark/spark_data_skew.\n3\t\n4\tVerifies the data-skew benchmark was fixed and at least one optimization ran:\n5\t  - the baseline job (spark-skew-baseline) completed successfully after the\n6\t    planted configuration bug was fixed, and\n7\t  - at least one optimization strategy job (broadcast or AQE) was applied and\n8\t    also completed successfully.\n9\t\"\"\"\n10\tfrom __future__ import annotations\n11\t\n12\timport sys\n13\tfrom pathlib import Path\n14\t\n15\tCOMMON = Path(__file__).resolve().parents[2] / \"common\"\n16\tsys.path.insert(0, str(COMMON))\n17\t\n18\tfrom oracle_lib import bench_namespace, run  # noqa: E402\n19\t\n20\tNAMESPACE = bench_namespace(\"spark-skew\")\n21\tBASELINE_JOB = \"spark-skew-baseline\"\n22\tOPTIMIZATION_JOBS = (\"spark-skew-broadcast\", \"spark-skew-aqe\")\n23\t\n24\t\n25\tdef fail(message: str) -> int:\n26\t    print(f\"spark_data_skew oracle failed: {message}\")\n27\t    return 1\n28\t\n29\t\n30\tdef job_exists(name: str) -> bool:\n31\t    proc = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"job\", name], check=False)\n32\t    return proc.returncode == 0\n33\t\n34\t\n35\tdef job_completed(name: str) -> bool:\n36\t    \"\"\"True when the Job reports >= 1 succeeded completion.\"\"\"\n37\t    proc = run(\n38\t        [\"kubectl\", \"-n\", NAMESPACE, \"get\", \"job\", name, \"-o\", \"jsonpath={.status.succeeded}\"],\n39\t        check=False,\n40\t    )\n41\t    if proc.returncode != 0:\n42\t        return False\n43\t    raw = (proc.stdout or \"\").strip()\n44\t    try:\n45\t        return int(raw or \"0\") >= 1\n46\t    except ValueError:\n47\t        return False\n48\t\n49\t\n50\tdef main() -> int:\n51\t    if not job_exists(BASELINE_JOB):\n52\t        return fail(f\"baseline job/{BASELINE_JOB} does not exist\")\n53\t    if not job_completed(BASELINE_JOB):\n54\t        return fail(f\"baseline job/{BASELINE_JOB} did not complete successfully\")\n55\t\n56\t    applied = [name for name in OPTIMIZATION_JOBS if job_exists(name)]\n57\t    if not applied:\n58\t        return fail(\"no optimization strategy applied (expected broadcast or aqe job)\")\n59\t\n60\t    completed = [name for name in applied if job_completed(name)]\n61\t    if not completed:\n62\t        return fail(\n63\t            f\"optimization job(s) {applied} applied but none completed successfully\"\n64\t        )\n65\t\n66\t    print(\n67\t        f\"spark_data_skew verified: baseline + {', '.join(completed)} completed successfully\"\n68\t    )\n69\t    return 0\n70\t\n71\t\n72\tif __name__ == \"__main__\":\n73\t    raise SystemExit(main())\n74\t"}]},"parent_tool_use_id":null,"session_id":"30dcc2a3-aec5-4898-a4c0-cec958228604","uuid":"ef1a81be-5ad5-4f1e-8c8c-33535447cea9","timestamp":"2026-06-23T21:43:14.607Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/spark/spark_data_skew/oracle/oracle.py","content":"#!/usr/bin/env python3\n\"\"\"Oracle for spark/spark_data_skew.\n\nVerifies the data-skew benchmark was fixed and at least one optimization ran:\n  - the baseline job (spark-skew-baseline) completed successfully after the\n    planted configuration bug was fixed, and\n  - at least one optimization strategy job (broadcast or AQE) was applied and\n    also completed successfully.\n\"\"\"\nfrom __future__ import annotations\n\nimport sys\nfrom pathlib import Path\n\nCOMMON = Path(__file__).resolve().parents[2] / \"common\"\nsys.path.insert(0, str(COMMON))\n\nfrom oracle_lib import bench_namespace, run  # noqa: E402\n\nNAMESPACE = bench_namespace(\"spark-skew\")\nBASELINE_JOB = \"spark-skew-baseline\"\nOPTIMIZATION_JOBS = (\"spark-skew-broadcast\", \"spark-skew-aqe\")\n\n\ndef fail(message: str) -> int:\n    print(f\"spark_data_skew oracle failed: {message}\")\n    return 1\n\n\ndef job_exists(name: str) -> bool:\n    proc = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"job\", name], check=False)\n    return proc.returncode == 0\n\n\ndef job_completed(name: str) -> bool:\n    \"\"\"True when the Job reports >= 1 succeeded completion.\"\"\"\n    proc = run(\n        [\"kubectl\", \"-n\", NAMESPACE, \"get\", \"job\", name, \"-o\", \"jsonpath={.status.succeeded}\"],\n        check=False,\n    )\n    if proc.returncode != 0:\n        return False\n    raw = (proc.stdout or \"\").strip()\n    try:\n        return int(raw or \"0\") >= 1\n    except ValueError:\n        return False\n\n\ndef main() -> int:\n    if not job_exists(BASELINE_JOB):\n        return fail(f\"baseline job/{BASELINE_JOB} does not exist\")\n    if not job_completed(BASELINE_JOB):\n        return fail(f\"baseline job/{BASELINE_JOB} did not complete successfully\")\n\n    applied = [name for name in OPTIMIZATION_JOBS if job_exists(name)]\n    if not applied:\n        return fail(\"no optimization strategy applied (expected broadcast or aqe job)\")\n\n    completed = [name for name in applied if job_completed(name)]\n    if not completed:\n        return fail(\n            f\"optimization job(s) {applied} applied but none completed successfully\"\n        )\n\n    print(\n        f\"spark_data_skew verified: baseline + {', '.join(completed)} completed successfully\"\n    )\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n","numLines":74,"startLine":1,"totalLines":74}}}
