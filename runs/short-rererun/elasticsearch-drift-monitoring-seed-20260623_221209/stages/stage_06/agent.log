{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016iiwNRBzVQNU92p1kDTQMy","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport json\n3\timport os\n4\timport re\n5\timport subprocess\n6\timport sys\n7\t\n8\tNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"elasticsearch\")\n9\tSERVICE = os.environ.get(\"BENCH_PARAM_HTTP_SERVICE_NAME\", \"es-http\")\n10\t# ES 8.x runs with security enabled, so the HTTPS API requires authenticating as\n11\t# the elastic superuser. When this case inherits a secured cluster from an\n12\t# earlier workflow stage, read its password from the secret that stage created\n13\t# so the oracle's queries aren't rejected with 401. Absent secret -> None -> no\n14\t# -u, so a standalone unsecured cluster still works.\n15\tPASSWORD_SECRET = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_SECRET_NAME\", \"elastic-password\")\n16\tPASSWORD_KEY = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_KEY\", \"password\")\n17\t# Hint for the Elasticsearch pod app label. Used as an override when it matches a\n18\t# live StatefulSet's selector; otherwise the real selector label is detected\n19\t# live from the cluster. The env PERSISTS across stages, so a workflow's\n20\t# inherited ES cluster may label its pods differently than this case's standalone\n21\t# default of 'es-cluster'.\n22\tCLUSTER_PREFIX_HINT = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"es-cluster\")\n23\tINDEX = os.environ.get(\"BENCH_PARAM_INDEX_NAME\", \"app-data\")\n24\tDEFAULT_SCHEME = \"http\"\n25\t_SCHEME = None\n26\t\n27\t\n28\tdef run(cmd):\n29\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n30\t\n31\t\n32\tdef _elastic_password():\n33\t    \"\"\"Fetch the elastic-user password from its secret (base64-decoded), or None.\"\"\"\n34\t    import base64\n35\t    r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", PASSWORD_SECRET,\n36\t             \"-o\", \"jsonpath={.data.\" + PASSWORD_KEY + \"}\"])\n37\t    if r.returncode != 0 or not r.stdout.strip():\n38\t        return None\n39\t    try:\n40\t        return base64.b64decode(r.stdout.strip()).decode()\n41\t    except Exception:\n42\t        return None\n43\t\n44\t\n45\tELASTIC_PASSWORD = None  # set in main() once kubectl is reachable\n46\t\n47\t\n48\t_APP_LABEL = None\n49\t\n50\t\n51\tdef resolve_app_label():\n52\t    \"\"\"Resolve the 'app=<value>' selector for the live ES pods.\n53\t\n54\t    Priority: the BENCH_PARAM_CLUSTER_PREFIX hint when some live StatefulSet\n55\t    actually selects on app=<hint> (explicit override wins) -> the app label of\n56\t    the namespace's Elasticsearch StatefulSet detected live -> the hint.\n57\t    Workflow-agnostic: adapts to an inherited cluster labelled e.g.\n58\t    app=elasticsearch instead of app=es-cluster.\n59\t    \"\"\"\n60\t    global _APP_LABEL\n61\t    if _APP_LABEL is not None:\n62\t        return _APP_LABEL\n63\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n64\t    labels = []\n65\t    if res.returncode == 0:\n66\t        try:\n67\t            for sts in json.loads(res.stdout).get(\"items\", []):\n68\t                spec = sts.get(\"spec\", {})\n69\t                containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n70\t                if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n71\t                    continue\n72\t                app = (spec.get(\"selector\", {}).get(\"matchLabels\", {}) or {}).get(\"app\")\n73\t                ts = sts.get(\"metadata\", {}).get(\"creationTimestamp\", \"\")\n74\t                if app:\n75\t                    labels.append((app, ts))\n76\t        except (json.JSONDecodeError, AttributeError):\n77\t            pass\n78\t    if any(app == CLUSTER_PREFIX_HINT for app, _ in labels):\n79\t        _APP_LABEL = f\"app={CLUSTER_PREFIX_HINT}\"\n80\t        return _APP_LABEL\n81\t    if labels:\n82\t        labels.sort(key=lambda x: (x[1] or \"\"))\n83\t        _APP_LABEL = f\"app={labels[0][0]}\"\n84\t        return _APP_LABEL\n85\t    _APP_LABEL = f\"app={CLUSTER_PREFIX_HINT}\"\n86\t    return _APP_LABEL\n87\t\n88\t\n89\tAPP_LABEL = resolve_app_label()\n90\t\n91\t\n92\tdef _list_es_statefulset_replicas():\n93\t    \"\"\"Return {sts_name: spec.replicas} for the namespace's Elasticsearch\n94\t    StatefulSets (those whose pod template runs an Elasticsearch image).\"\"\"\n95\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n96\t    if res.returncode != 0:\n97\t        return {}\n98\t    try:\n99\t        items = json.loads(res.stdout).get(\"items\", [])\n100\t    except (json.JSONDecodeError, AttributeError):\n101\t        return {}\n102\t    out = {}\n103\t    for sts in items:\n104\t        spec = sts.get(\"spec\", {})\n105\t        containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n106\t        if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n107\t            continue\n108\t        name = sts.get(\"metadata\", {}).get(\"name\")\n109\t        replicas = spec.get(\"replicas\")\n110\t        if name and isinstance(replicas, int):\n111\t            out[name] = replicas\n112\t    return out\n113\t\n114\t\n115\tdef _sts_name_for_node(node_name):\n116\t    \"\"\"Map a live ES node name to its backing StatefulSet name.\n117\t\n118\t    An ES node name equals its pod name, which for a StatefulSet pod is\n119\t    ``<statefulset-name>-<ordinal>`` (e.g. ``es-cluster-0`` -> ``es-cluster``,\n120\t    ``es-data-1`` -> ``es-data``). Strip the trailing ``-<digits>`` ordinal.\n121\t    Returns the node name unchanged if it carries no ordinal suffix.\n122\t    \"\"\"\n123\t    if not node_name:\n124\t        return node_name\n125\t    return re.sub(r\"-\\d+$\", \"\", node_name)\n126\t\n127\t\n128\tdef _live_sts_names(node_names):\n129\t    \"\"\"Set of StatefulSet names actually backing the live cluster nodes.\n130\t\n131\t    Derived by stripping each live node name's ordinal. This excludes\n132\t    accumulated/stale/other ES StatefulSets in the (persisted) namespace that\n133\t    back no node in the queried cluster.\n134\t    \"\"\"\n135\t    return {_sts_name_for_node(n) for n in node_names if n}\n136\t\n137\t\n138\tdef _resolve_expected_nodes(node_names, default=3):\n139\t    \"\"\"Expected node count to enforce, derived from the LIVE cluster.\n140\t\n141\t    The expected total is the DESIRED topology of ONLY the StatefulSets that\n142\t    actually back the live cluster (the nodes returned by ``_cat/nodes``): the\n143\t    sum of spec.replicas over just those StatefulSets. The namespace PERSISTS\n144\t    across workflow stages and accumulates multiple ES clusters, so summing\n145\t    replicas across *every* ES StatefulSet overcounts versus the single cluster\n146\t    the oracle queries. Restricting to the live cluster's StatefulSets fixes that.\n147\t\n148\t    Using DESIRED spec.replicas (not the live count) keeps the check strict: a\n149\t    node that FAILED to join leaves its StatefulSet \"live\" (siblings are up) but\n150\t    absent from ``_cat/nodes``, so EXPECTED stays above the actual count -- no\n151\t    masking. The LIVE cluster is derived FIRST; the param is a FALLBACK used only\n152\t    when no live StatefulSets resolve (e.g. _cat/nodes failed or returned empty).\n153\t    \"\"\"\n154\t    # Derive from the LIVE cluster FIRST (workflow-agnostic + composition-aware):\n155\t    # sum spec.replicas over the active ES StatefulSets -- the base cluster PLUS\n156\t    # any nodeset a PRIOR stage added to the same cluster (e.g. an inherited\n157\t    # transform nodeset). A static EXPECTED_NODES param encodes a standalone\n158\t    # baseline that wrongly ignores such inherited nodesets, so it is demoted to a\n159\t    # FALLBACK below, used only when the live cluster cannot be resolved.\n160\t    # Robust count: sum spec.replicas over ES StatefulSets that are actually\n161\t    # present (status.replicas > 0). Counts the base cluster + any scaled-up\n162\t    # nodeset WITHOUT the fragile node.name -> StatefulSet string mapping (which\n163\t    # breaks when a nodeset's node.name differs from its pod name). A torn-down\n164\t    # prior cluster's StatefulSet has readyReplicas 0 and is excluded. Still\n165\t    # strict: a node that failed to join leaves its STS ready>0 but short, so the\n166\t    # spec-replica sum exceeds the live node count and the check still fails.\n167\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n168\t    if res.returncode == 0:\n169\t        try:\n170\t            items = json.loads(res.stdout).get(\"items\", [])\n171\t        except Exception:\n172\t            items = []\n173\t        desired = 0\n174\t        for sts in items:\n175\t            spec = sts.get(\"spec\", {}) or {}\n176\t            containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", []) or []\n177\t            if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n178\t                continue\n179\t            replicas = spec.get(\"replicas\")\n180\t            # Use status.replicas (pods that EXIST), not readyReplicas: a\n181\t            # scaled-up nodeset whose pods joined the cluster but lack a passing\n182\t            # STS readiness probe has readyReplicas 0 yet is genuinely live.\n183\t            # Count an ES StatefulSet's DESIRED replicas when it is an active part\n184\t            # of the cluster: spec.replicas > 0 and not being torn down. Gating on\n185\t            # status.replicas undercounts a freshly scaled-up nodeset whose status\n186\t            # lags -- its pods have joined the cluster but status.replicas is still\n187\t            # 0 -- which wrongly made EXPECTED < the live node count.\n188\t            being_deleted = (sts.get(\"metadata\", {}) or {}).get(\"deletionTimestamp\") is not None\n189\t            if isinstance(replicas, int) and replicas > 0 and not being_deleted:\n190\t                desired += replicas\n191\t        if desired > 0:\n192\t            return desired\n193\t\n194\t    # Fallbacks (live cluster unresolvable): explicit param, then the default.\n195\t    for key in (\"BENCH_PARAM_EXPECTED_NODE_COUNT\", \"BENCH_PARAM_EXPECTED_NODES\"):\n196\t        val = os.environ.get(key)\n197\t        if val is not None and str(val).strip():\n198\t            try:\n199\t                return int(val)\n200\t            except ValueError:\n201\t                pass\n202\t    return default\n203\t\n204\t\n205\tdef _probe_scheme(scheme):\n206\t    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\"\"\"\n207\t    result = run([\n208\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\",\n209\t        \"curl\", \"-s\", \"-S\", \"-k\", \"-o\", \"/dev/null\",\n210\t        \"-w\", \"%{http_code}\", \"--max-time\", \"5\", f\"{scheme}://{SERVICE}:9200/\",\n211\t    ])\n212\t    code = (result.stdout or \"\").strip()\n213\t    return result.returncode == 0 and code.isdigit() and code != \"000\"\n214\t\n215\t\n216\tdef detect_scheme():\n217\t    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n218\t    global _SCHEME\n219\t    if _SCHEME is not None:\n220\t        return _SCHEME\n221\t    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n222\t        if _probe_scheme(scheme):\n223\t            _SCHEME = scheme\n224\t            return _SCHEME\n225\t    _SCHEME = DEFAULT_SCHEME\n226\t    return _SCHEME\n227\t\n228\t\n229\tdef curl_json(path, errors):\n230\t    scheme = detect_scheme()\n231\t    # The client deadline must exceed any server-side ``wait_for`` in `path`,\n232\t    # otherwise curl aborts (exit 28) before ES can answer. The retry loop in\n233\t    # main() does the real waiting, so each call's server wait stays short (10s)\n234\t    # and --max-time (20) comfortably exceeds it.\n235\t    cmd = [\n236\t        \"kubectl\",\n237\t        \"-n\",\n238\t        NAMESPACE,\n239\t        \"exec\",\n240\t        \"curl-test\",\n241\t        \"--\",\n242\t        \"curl\",\n243\t        \"-s\",\n244\t        \"-S\",\n245\t        \"-k\",\n246\t    ]\n247\t    if ELASTIC_PASSWORD:\n248\t        cmd += [\"-u\", f\"elastic:{ELASTIC_PASSWORD}\"]\n249\t    cmd += [\n250\t        \"--max-time\",\n251\t        \"20\",\n252\t        f\"{scheme}://{SERVICE}:9200{path}\",\n253\t    ]\n254\t    result = run(cmd)\n255\t    if result.returncode != 0:\n256\t        detail = result.stderr.strip() or result.stdout.strip() or f\"command terminated with exit code {result.returncode}\"\n257\t        errors.append(f\"Failed to query {path}: {detail}\")\n258\t        return None\n259\t    output = result.stdout.strip()\n260\t    if not output:\n261\t        errors.append(f\"Empty response for {path}\")\n262\t        return None\n263\t    try:\n264\t        return json.loads(output)\n265\t    except json.JSONDecodeError:\n266\t        errors.append(f\"Failed to parse JSON from {path}\")\n267\t        return None\n268\t\n269\t\n270\tdef evaluate():\n271\t    \"\"\"Run one full snapshot of the seed-hosts checks; return the list of errors.\"\"\"\n272\t    errors = []\n273\t\n274\t    # Resolve the live cluster's node list FIRST: the expected node count is\n275\t    # derived from only the StatefulSets that actually back these live nodes\n276\t    # (the persisted namespace accumulates several ES clusters across stages, so\n277\t    # summing every ES StatefulSet's replicas overcounts the queried cluster).\n278\t    nodes = curl_json(\"/_cat/nodes?format=json\", errors)\n279\t    node_names = []\n280\t    if isinstance(nodes, list):\n281\t        node_names = [n.get(\"name\") for n in nodes if n.get(\"name\")]\n282\t    expected_nodes = _resolve_expected_nodes(node_names, default=3)\n283\t\n284\t    health = curl_json(\n285\t        f\"/_cluster/health?wait_for_status=yellow&wait_for_nodes={expected_nodes}&timeout=10s\",\n286\t        errors,\n287\t    )\n288\t    if isinstance(health, dict):\n289\t        status = health.get(\"status\")\n290\t        if status not in {\"yellow\", \"green\"}:\n291\t            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n292\t        if health.get(\"number_of_nodes\") != expected_nodes:\n293\t            errors.append(\n294\t                f\"Expected {expected_nodes} nodes, got {health.get('number_of_nodes')}\"\n295\t            )\n296\t\n297\t    if isinstance(nodes, list):\n298\t        if len(node_names) != expected_nodes:\n299\t            errors.append(f\"Expected {expected_nodes} nodes in _cat/nodes, got {len(node_names)}\")\n300\t\n301\t    count = curl_json(f\"/{INDEX}/_count\", errors)\n302\t    if isinstance(count, dict):\n303\t        if \"count\" not in count:\n304\t            errors.append(\"Unable to verify app-data count\")\n305\t\n306\t    return errors\n307\t\n308\t\n309\tdef main():\n310\t    global ELASTIC_PASSWORD\n311\t    ELASTIC_PASSWORD = _elastic_password()\n312\t\n313\t    # A multi-node ES cluster can flap at the edge of readiness under load: a\n314\t    # node briefly drops from the cluster during GC or shard recovery even though\n315\t    # it is stably green. A single snapshot can catch that transient and report a\n316\t    # false node-count miss. So verify the STABLE converged state: re-evaluate for\n317\t    # up to ~75s and pass on the first clean snapshot. This does not loosen the\n318\t    # N-node/green requirement -- a genuinely degraded cluster fails every attempt.\n319\t    import time\n320\t    deadline = time.monotonic() + 75\n321\t    errors = evaluate()\n322\t    while errors and time.monotonic() < deadline:\n323\t        time.sleep(8)\n324\t        errors = evaluate()\n325\t\n326\t    if errors:\n327\t        print(\"Seed hosts repair verification failed:\", file=sys.stderr)\n328\t        for err in errors:\n329\t            print(f\"  - {err}\", file=sys.stderr)\n330\t        return 1\n331\t\n332\t    print(\"Seed hosts repair verified\")\n333\t    return 0\n334\t\n335\t\n336\tif __name__ == \"__main__\":\n337\t    sys.exit(main())\n338\t"}]},"parent_tool_use_id":null,"session_id":"53445d29-5501-4b22-8dc9-92ad7ffaa7de","uuid":"f43a588f-7d8e-4816-bdca-88a5ad0803d0","timestamp":"2026-06-23T23:28:33.798Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/elasticsearch/seed-hosts-repair/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport json\nimport os\nimport re\nimport subprocess\nimport sys\n\nNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"elasticsearch\")\nSERVICE = os.environ.get(\"BENCH_PARAM_HTTP_SERVICE_NAME\", \"es-http\")\n# ES 8.x runs with security enabled, so the HTTPS API requires authenticating as\n# the elastic superuser. When this case inherits a secured cluster from an\n# earlier workflow stage, read its password from the secret that stage created\n# so the oracle's queries aren't rejected with 401. Absent secret -> None -> no\n# -u, so a standalone unsecured cluster still works.\nPASSWORD_SECRET = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_SECRET_NAME\", \"elastic-password\")\nPASSWORD_KEY = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_KEY\", \"password\")\n# Hint for the Elasticsearch pod app label. Used as an override when it matches a\n# live StatefulSet's selector; otherwise the real selector label is detected\n# live from the cluster. The env PERSISTS across stages, so a workflow's\n# inherited ES cluster may label its pods differently than this case's standalone\n# default of 'es-cluster'.\nCLUSTER_PREFIX_HINT = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"es-cluster\")\nINDEX = os.environ.get(\"BENCH_PARAM_INDEX_NAME\", \"app-data\")\nDEFAULT_SCHEME = \"http\"\n_SCHEME = None\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef _elastic_password():\n    \"\"\"Fetch the elastic-user password from its secret (base64-decoded), or None.\"\"\"\n    import base64\n    r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", PASSWORD_SECRET,\n             \"-o\", \"jsonpath={.data.\" + PASSWORD_KEY + \"}\"])\n    if r.returncode != 0 or not r.stdout.strip():\n        return None\n    try:\n        return base64.b64decode(r.stdout.strip()).decode()\n    except Exception:\n        return None\n\n\nELASTIC_PASSWORD = None  # set in main() once kubectl is reachable\n\n\n_APP_LABEL = None\n\n\ndef resolve_app_label():\n    \"\"\"Resolve the 'app=<value>' selector for the live ES pods.\n\n    Priority: the BENCH_PARAM_CLUSTER_PREFIX hint when some live StatefulSet\n    actually selects on app=<hint> (explicit override wins) -> the app label of\n    the namespace's Elasticsearch StatefulSet detected live -> the hint.\n    Workflow-agnostic: adapts to an inherited cluster labelled e.g.\n    app=elasticsearch instead of app=es-cluster.\n    \"\"\"\n    global _APP_LABEL\n    if _APP_LABEL is not None:\n        return _APP_LABEL\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n    labels = []\n    if res.returncode == 0:\n        try:\n            for sts in json.loads(res.stdout).get(\"items\", []):\n                spec = sts.get(\"spec\", {})\n                containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n                if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n                    continue\n                app = (spec.get(\"selector\", {}).get(\"matchLabels\", {}) or {}).get(\"app\")\n                ts = sts.get(\"metadata\", {}).get(\"creationTimestamp\", \"\")\n                if app:\n                    labels.append((app, ts))\n        except (json.JSONDecodeError, AttributeError):\n            pass\n    if any(app == CLUSTER_PREFIX_HINT for app, _ in labels):\n        _APP_LABEL = f\"app={CLUSTER_PREFIX_HINT}\"\n        return _APP_LABEL\n    if labels:\n        labels.sort(key=lambda x: (x[1] or \"\"))\n        _APP_LABEL = f\"app={labels[0][0]}\"\n        return _APP_LABEL\n    _APP_LABEL = f\"app={CLUSTER_PREFIX_HINT}\"\n    return _APP_LABEL\n\n\nAPP_LABEL = resolve_app_label()\n\n\ndef _list_es_statefulset_replicas():\n    \"\"\"Return {sts_name: spec.replicas} for the namespace's Elasticsearch\n    StatefulSets (those whose pod template runs an Elasticsearch image).\"\"\"\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n    if res.returncode != 0:\n        return {}\n    try:\n        items = json.loads(res.stdout).get(\"items\", [])\n    except (json.JSONDecodeError, AttributeError):\n        return {}\n    out = {}\n    for sts in items:\n        spec = sts.get(\"spec\", {})\n        containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n        if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n            continue\n        name = sts.get(\"metadata\", {}).get(\"name\")\n        replicas = spec.get(\"replicas\")\n        if name and isinstance(replicas, int):\n            out[name] = replicas\n    return out\n\n\ndef _sts_name_for_node(node_name):\n    \"\"\"Map a live ES node name to its backing StatefulSet name.\n\n    An ES node name equals its pod name, which for a StatefulSet pod is\n    ``<statefulset-name>-<ordinal>`` (e.g. ``es-cluster-0`` -> ``es-cluster``,\n    ``es-data-1`` -> ``es-data``). Strip the trailing ``-<digits>`` ordinal.\n    Returns the node name unchanged if it carries no ordinal suffix.\n    \"\"\"\n    if not node_name:\n        return node_name\n    return re.sub(r\"-\\d+$\", \"\", node_name)\n\n\ndef _live_sts_names(node_names):\n    \"\"\"Set of StatefulSet names actually backing the live cluster nodes.\n\n    Derived by stripping each live node name's ordinal. This excludes\n    accumulated/stale/other ES StatefulSets in the (persisted) namespace that\n    back no node in the queried cluster.\n    \"\"\"\n    return {_sts_name_for_node(n) for n in node_names if n}\n\n\ndef _resolve_expected_nodes(node_names, default=3):\n    \"\"\"Expected node count to enforce, derived from the LIVE cluster.\n\n    The expected total is the DESIRED topology of ONLY the StatefulSets that\n    actually back the live cluster (the nodes returned by ``_cat/nodes``): the\n    sum of spec.replicas over just those StatefulSets. The namespace PERSISTS\n    across workflow stages and accumulates multiple ES clusters, so summing\n    replicas across *every* ES StatefulSet overcounts versus the single cluster\n    the oracle queries. Restricting to the live cluster's StatefulSets fixes that.\n\n    Using DESIRED spec.replicas (not the live count) keeps the check strict: a\n    node that FAILED to join leaves its StatefulSet \"live\" (siblings are up) but\n    absent from ``_cat/nodes``, so EXPECTED stays above the actual count -- no\n    masking. The LIVE cluster is derived FIRST; the param is a FALLBACK used only\n    when no live StatefulSets resolve (e.g. _cat/nodes failed or returned empty).\n    \"\"\"\n    # Derive from the LIVE cluster FIRST (workflow-agnostic + composition-aware):\n    # sum spec.replicas over the active ES StatefulSets -- the base cluster PLUS\n    # any nodeset a PRIOR stage added to the same cluster (e.g. an inherited\n    # transform nodeset). A static EXPECTED_NODES param encodes a standalone\n    # baseline that wrongly ignores such inherited nodesets, so it is demoted to a\n    # FALLBACK below, used only when the live cluster cannot be resolved.\n    # Robust count: sum spec.replicas over ES StatefulSets that are actually\n    # present (status.replicas > 0). Counts the base cluster + any scaled-up\n    # nodeset WITHOUT the fragile node.name -> StatefulSet string mapping (which\n    # breaks when a nodeset's node.name differs from its pod name). A torn-down\n    # prior cluster's StatefulSet has readyReplicas 0 and is excluded. Still\n    # strict: a node that failed to join leaves its STS ready>0 but short, so the\n    # spec-replica sum exceeds the live node count and the check still fails.\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n    if res.returncode == 0:\n        try:\n            items = json.loads(res.stdout).get(\"items\", [])\n        except Exception:\n            items = []\n        desired = 0\n        for sts in items:\n            spec = sts.get(\"spec\", {}) or {}\n            containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", []) or []\n            if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n                continue\n            replicas = spec.get(\"replicas\")\n            # Use status.replicas (pods that EXIST), not readyReplicas: a\n            # scaled-up nodeset whose pods joined the cluster but lack a passing\n            # STS readiness probe has readyReplicas 0 yet is genuinely live.\n            # Count an ES StatefulSet's DESIRED replicas when it is an active part\n            # of the cluster: spec.replicas > 0 and not being torn down. Gating on\n            # status.replicas undercounts a freshly scaled-up nodeset whose status\n            # lags -- its pods have joined the cluster but status.replicas is still\n            # 0 -- which wrongly made EXPECTED < the live node count.\n            being_deleted = (sts.get(\"metadata\", {}) or {}).get(\"deletionTimestamp\") is not None\n            if isinstance(replicas, int) and replicas > 0 and not being_deleted:\n                desired += replicas\n        if desired > 0:\n            return desired\n\n    # Fallbacks (live cluster unresolvable): explicit param, then the default.\n    for key in (\"BENCH_PARAM_EXPECTED_NODE_COUNT\", \"BENCH_PARAM_EXPECTED_NODES\"):\n        val = os.environ.get(key)\n        if val is not None and str(val).strip():\n            try:\n                return int(val)\n            except ValueError:\n                pass\n    return default\n\n\ndef _probe_scheme(scheme):\n    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\"\"\"\n    result = run([\n        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\",\n        \"curl\", \"-s\", \"-S\", \"-k\", \"-o\", \"/dev/null\",\n        \"-w\", \"%{http_code}\", \"--max-time\", \"5\", f\"{scheme}://{SERVICE}:9200/\",\n    ])\n    code = (result.stdout or \"\").strip()\n    return result.returncode == 0 and code.isdigit() and code != \"000\"\n\n\ndef detect_scheme():\n    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n    global _SCHEME\n    if _SCHEME is not None:\n        return _SCHEME\n    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n        if _probe_scheme(scheme):\n            _SCHEME = scheme\n            return _SCHEME\n    _SCHEME = DEFAULT_SCHEME\n    return _SCHEME\n\n\ndef curl_json(path, errors):\n    scheme = detect_scheme()\n    # The client deadline must exceed any server-side ``wait_for`` in `path`,\n    # otherwise curl aborts (exit 28) before ES can answer. The retry loop in\n    # main() does the real waiting, so each call's server wait stays short (10s)\n    # and --max-time (20) comfortably exceeds it.\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"exec\",\n        \"curl-test\",\n        \"--\",\n        \"curl\",\n        \"-s\",\n        \"-S\",\n        \"-k\",\n    ]\n    if ELASTIC_PASSWORD:\n        cmd += [\"-u\", f\"elastic:{ELASTIC_PASSWORD}\"]\n    cmd += [\n        \"--max-time\",\n        \"20\",\n        f\"{scheme}://{SERVICE}:9200{path}\",\n    ]\n    result = run(cmd)\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"command terminated with exit code {result.returncode}\"\n        errors.append(f\"Failed to query {path}: {detail}\")\n        return None\n    output = result.stdout.strip()\n    if not output:\n        errors.append(f\"Empty response for {path}\")\n        return None\n    try:\n        return json.loads(output)\n    except json.JSONDecodeError:\n        errors.append(f\"Failed to parse JSON from {path}\")\n        return None\n\n\ndef evaluate():\n    \"\"\"Run one full snapshot of the seed-hosts checks; return the list of errors.\"\"\"\n    errors = []\n\n    # Resolve the live cluster's node list FIRST: the expected node count is\n    # derived from only the StatefulSets that actually back these live nodes\n    # (the persisted namespace accumulates several ES clusters across stages, so\n    # summing every ES StatefulSet's replicas overcounts the queried cluster).\n    nodes = curl_json(\"/_cat/nodes?format=json\", errors)\n    node_names = []\n    if isinstance(nodes, list):\n        node_names = [n.get(\"name\") for n in nodes if n.get(\"name\")]\n    expected_nodes = _resolve_expected_nodes(node_names, default=3)\n\n    health = curl_json(\n        f\"/_cluster/health?wait_for_status=yellow&wait_for_nodes={expected_nodes}&timeout=10s\",\n        errors,\n    )\n    if isinstance(health, dict):\n        status = health.get(\"status\")\n        if status not in {\"yellow\", \"green\"}:\n            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n        if health.get(\"number_of_nodes\") != expected_nodes:\n            errors.append(\n                f\"Expected {expected_nodes} nodes, got {health.get('number_of_nodes')}\"\n            )\n\n    if isinstance(nodes, list):\n        if len(node_names) != expected_nodes:\n            errors.append(f\"Expected {expected_nodes} nodes in _cat/nodes, got {len(node_names)}\")\n\n    count = curl_json(f\"/{INDEX}/_count\", errors)\n    if isinstance(count, dict):\n        if \"count\" not in count:\n            errors.append(\"Unable to verify app-data count\")\n\n    return errors\n\n\ndef main():\n    global ELASTIC_PASSWORD\n    ELASTIC_PASSWORD = _elastic_password()\n\n    # A multi-node ES cluster can flap at the edge of readiness under load: a\n    # node briefly drops from the cluster during GC or shard recovery even though\n    # it is stably green. A single snapshot can catch that transient and report a\n    # false node-count miss. So verify the STABLE converged state: re-evaluate for\n    # up to ~75s and pass on the first clean snapshot. This does not loosen the\n    # N-node/green requirement -- a genuinely degraded cluster fails every attempt.\n    import time\n    deadline = time.monotonic() + 75\n    errors = evaluate()\n    while errors and time.monotonic() < deadline:\n        time.sleep(8)\n        errors = evaluate()\n\n    if errors:\n        print(\"Seed hosts repair verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    print(\"Seed hosts repair verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":338,"startLine":1,"totalLines":338}}}
