r --timeout=300s\"\n        sleep: 2\n      - command: \"kubectl create namespace demo\"\n        sleep: 0\n      - command: \"kubectl -n demo apply -f cases/nginx-ingress/rate_limit_replica_hard/resource/rate-echo.yaml\"\n        sleep: 2\n      - command: \"kubectl -n demo rollout status deploy/rate-echo --timeout=60s\"\n        sleep: 1\n      - command: \"kubectl -n demo apply -f cases/nginx-ingress/rate_limit_replica_hard/resource/ingress-api.yaml\"\n        sleep: 1\n      - command: \"kubectl -n demo apply -f cases/nginx-ingress/rate_limit_replica_hard/resource/ingress-health.yaml\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n demo get pod curl-test >/dev/null 2>&1 || kubectl -n demo apply -f cases/nginx-ingress/rate_limit_replica_hard/resource/curl-test.yaml'\"\n        sleep: 1\n      - command: \"kubectl -n demo wait --for=condition=Ready pod/{{params.curl_pod_name}} --timeout=180s\"\n        sleep: 1\n    verify:\n      - command: \"kubectl -n demo wait --for=condition=ready pod/{{params.curl_pod_name}} --timeout=5s\"\n        timeout_sec: 30\n\n  # Additive scenario fixture (composition safety): the scenario backend (the\n  # rate-echo deployment) and the two pre-existing Ingresses ({{params.api_path}}\n  # and {{params.health_path}}) are fixtures the agent does NOT create -- the task\n  # is only to add a rate limit to {{params.api_path}}. nginx_env_ready seeds them\n  # on its destructive fresh-build path, which is SKIPPED on an inherited cluster\n  # (the probe sees the curl-test pod from a prior nginx stage with DIFFERENT\n  # scenario resources), so rate-echo + the two Ingresses are absent and the\n  # oracle has nothing to test. Re-establish them additively when rate-echo is\n  # missing, reusing the build's resource files; also ensures curl-test. It never\n  # deletes a namespace or touches the shared ingress-nginx controller. Standalone\n  # rate-echo already exists so the probe matches and this unit skips ->\n  # byte-identical standalone behaviour.\n  - name: rate_limit_scenario_fixture\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n demo get deploy rate-echo\"\n        timeout_sec: 10\n    apply:\n      - command: \"kubectl -n demo apply -f cases/nginx-ingress/rate_limit_replica_hard/resource/rate-echo.yaml\"\n        sleep: 2\n      - command: \"/bin/sh -c 'kubectl -n demo rollout status deploy/rate-echo --timeout=60s || true'\"\n        sleep: 1\n      - command: \"kubectl -n demo apply -f cases/nginx-ingress/rate_limit_replica_hard/resource/ingress-api.yaml\"\n        sleep: 1\n      - command: \"kubectl -n demo apply -f cases/nginx-ingress/rate_limit_replica_hard/resource/ingress-health.yaml\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n demo get pod {{params.curl_pod_name}} >/dev/null 2>&1 || kubectl -n demo apply -f cases/nginx-ingress/rate_limit_replica_hard/resource/curl-test.yaml'\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n demo wait --for=condition=Ready pod/{{params.curl_pod_name}} --timeout=120s || true'\"\n        sleep: 1\n    verify:\n      - command: \"/bin/sh -c 'kubectl -n demo get deploy rate-echo >/dev/null 2>&1; true'\"\n        timeout_sec: 10\n\noracle:\n  verify:\n    commands:\n      # 150s: the oracle retries a transiently-failing burst exec for up to 120s\n      # (controller / curl-test warm-up); keep the command budget above that loop.\n      - command: \"python3 cases/nginx-ingress/rate_limit_replica_hard/oracle/oracle.py\"\n        timeout_sec: 150","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
