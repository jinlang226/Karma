licas\\\",                             \\\"value\\\": 2},","+  {\\\"op\\\": \\\"replace\\\", \\\"path\\\": \\\"/spec/template/spec/serviceAccountName\\\",    \\\"value\\\": \\\"default\\\"},","+  {\\\"op\\\": \\\"replace\\\", \\\"path\\\": \\\"/spec/template/spec/containers/0/image\\\",    \\\"value\\\": \\\"${DEFAULT_IMAGE}\\\"},","+  {\\\"op\\\": \\\"remove\\\",  \\\"path\\\": \\\"/spec/template/spec/containers/0/resources\\\"}","+]\"","+echo \"  spark-worker patched.\""," ","-# ── 3. Remove dashboard port from ray-head Service ──────────────────────────","-# The baseline Service spec contained only the gcs port (6379).","-# stage_04 added dashboard:8265; this patch restores the original port list.","-echo \"[3/3] Patch ray-head Service: remove dashboard port 8265...\"","-run kubectl -n \"$NS\" patch svc ray-head --type=json -p '[","-  {","-    \"op\": \"replace\",","-    \"path\": \"/spec/ports\",","-    \"value\": [","-      {\"name\": \"gcs\", \"port\": 6379, \"protocol\": \"TCP\", \"targetPort\": 6379}","-    ]","-  }","-]'","+# ── 3. Remove custom RBAC binding and role ──","+echo \"[3/4] Removing custom RBAC...\"","+kubectl -n \"$NS\" delete rolebinding spark-pi-role-binding --ignore-not-found","+kubectl -n \"$NS\" delete role         spark-pi-role         --ignore-not-found","+echo \"  RoleBinding and Role removed.\""," ","-# ── 4. Wait for rollouts to stabilise ───────────────────────────────────────","-if [[ \"$DRY_RUN\" != \"1\" ]]; then","-  echo \"\"","-  echo \"[wait] Waiting for ray-head rollout...\"","-  kubectl -n \"$NS\" rollout status deploy/ray-head  --timeout=180s","-  echo \"[wait] Waiting for ray-worker rollout...\"","-  kubectl -n \"$NS\" rollout status deploy/ray-worker --timeout=180s","+# ── 4. Remove custom ServiceAccount (deployments already switched to 'default') ──","+echo \"[4/4] Removing custom ServiceAccount spark-pi...\"","+kubectl -n \"$NS\" delete serviceaccount spark-pi --ignore-not-found","+echo \"  ServiceAccount removed.\""," ","-  echo \"\"","-  echo \"=== Post-rollback state ===\"","-  kubectl -n \"$NS\" get deploy -o wide","-  echo \"\"","-  kubectl -n \"$NS\" get svc ray-head -o \\","-    jsonpath='ray-head ports: {range .spec.ports[*]}{.name}:{.port}  {end}{\"\\n\"}'","-fi","-"," echo \"\"","-echo \"Rollback complete.\"","+echo \"=== Rollback complete ===\"","+echo \"Verify rollout with:\"","+echo \"  kubectl rollout status deployment/spark-master deployment/spark-worker -n $NS\"","+echo \"  kubectl get deploy,sa,role,rolebinding -n $NS\""]}],"originalFile":"#!/usr/bin/env bash\n# rollback.sh — revert ray namespace to the pre-change baseline.\n#\n# Changes applied by stages 02-04 of the\n# ray-scale-upgrade-dashboard-rollback-audit workflow:\n#\n#   stage_02 scale_workers:       ray-worker replicas  2 → 3\n#   stage_03 upgrade_version:     image  rayproject/ray:2.8.0 → rayproject/ray:2.9.0\n#   stage_04 dashboard_exposure:  ray-head Service gained port dashboard:8265\n#\n# This script undoes those three changes; resource limits were not\n# modified (both deployments have resources: {}) so no action is needed there.\n#\n# Usage (review only — do NOT run in production without team sign-off):\n#   bash rollback.sh\n#   # dry-run: inspect commands without executing:\n#   DRY_RUN=1 bash rollback.sh\n\nset -euo pipefail\n\nNS=ray\nBASELINE_IMAGE=\"rayproject/ray:2.8.0\"\nBASELINE_WORKER_REPLICAS=2\n\nDRY_RUN=\"${DRY_RUN:-0}\"\n\nrun() {\n  if [[ \"$DRY_RUN\" == \"1\" ]]; then\n    echo \"[DRY-RUN] $*\"\n  else\n    echo \"+ $*\"\n    \"$@\"\n  fi\n}\n\necho \"=== Ray rollback: reverting to baseline ===\"\necho \"  namespace : $NS\"\necho \"  image     : $BASELINE_IMAGE\"\necho \"  workers   : $BASELINE_WORKER_REPLICAS replicas\"\necho \"  svc ports : gcs:6379 only (dashboard:8265 removed)\"\necho \"\"\n\n# ── 1. Scale ray-worker replicas back to baseline ──────────────────────────\necho \"[1/3] Scale ray-worker to ${BASELINE_WORKER_REPLICAS} replicas (was 3)...\"\nrun kubectl -n \"$NS\" scale deploy ray-worker \\\n  --replicas=\"$BASELINE_WORKER_REPLICAS\"\n\n# ── 2. Roll back container images to baseline ───────────────────────────────\necho \"[2/3] Set image rayproject/ray:2.8.0 on ray-head and ray-worker...\"\nrun kubectl -n \"$NS\" set image deploy/ray-head  ray-head=rayproject/ray:2.8.0\nrun kubectl -n \"$NS\" set image deploy/ray-worker ray-worker=rayproject/ray:2.8.0\n\n# ── 3. Remove dashboard port from ray-head Service ──────────────────────────\n# The baseline Service spec contained only the gcs port (6379).\n# stage_04 added dashboard:8265; this patch restores the original port list.\necho \"[3/3] Patch ray-head Service: remove dashboard port 8265...\"\nrun kubectl -n \"$NS\" patch svc ray-head --type=json -p '[\n  {\n    \"op\": \"replace\",\n    \"path\": \"/spec/ports\",\n    \"value\": [\n      {\"name\": \"gcs\", \"port\": 6379, \"protocol\": \"TCP\", \"targetPort\": 6379}\n    ]\n  }\n]'\n\n# ── 4. Wait for rollouts to stabilise ───────────────────────────────────────\nif [[ \"$DRY_RUN\" != \"1\" ]]; then\n  echo \"\"\n  echo \"[wait] Waiting for ray-head rollout...\"\n  kubectl -n \"$NS\" rollout status deploy/ray-head  --timeout=180s\n  echo \"[wait] Waiting for ray-worker rollout...\"\n  kubectl -n \"$NS\" rollout status deploy/ray-worker --timeout=180s\n\n  echo \"\"\n  echo \"=== Post-rollback state ===\"\n  kubectl -n \"$NS\" get deploy -o wide\n  echo \"\"\n  kubectl -n \"$NS\" get svc ray-head -o \\\n    jsonpath='ray-head ports: {range .spec.ports[*]}{.name}:{.port}  {end}{\"\\n\"}'\nfi\n\necho \"\"\necho \"Rollback complete.\"\n","userModified":false}}
