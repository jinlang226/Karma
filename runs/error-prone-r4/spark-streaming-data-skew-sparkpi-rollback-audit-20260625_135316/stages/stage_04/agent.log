{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01JxaFkRYnCBDDCBSWt2pbcr","type":"tool_result","content":"1\t#!/usr/bin/env bash\n2\t# rollback.sh — revert ray namespace to the pre-change baseline.\n3\t#\n4\t# Changes applied by stages 02-04 of the\n5\t# ray-scale-upgrade-dashboard-rollback-audit workflow:\n6\t#\n7\t#   stage_02 scale_workers:       ray-worker replicas  2 → 3\n8\t#   stage_03 upgrade_version:     image  rayproject/ray:2.8.0 → rayproject/ray:2.9.0\n9\t#   stage_04 dashboard_exposure:  ray-head Service gained port dashboard:8265\n10\t#\n11\t# This script undoes those three changes; resource limits were not\n12\t# modified (both deployments have resources: {}) so no action is needed there.\n13\t#\n14\t# Usage (review only — do NOT run in production without team sign-off):\n15\t#   bash rollback.sh\n16\t#   # dry-run: inspect commands without executing:\n17\t#   DRY_RUN=1 bash rollback.sh\n18\t\n19\tset -euo pipefail\n20\t\n21\tNS=ray\n22\tBASELINE_IMAGE=\"rayproject/ray:2.8.0\"\n23\tBASELINE_WORKER_REPLICAS=2\n24\t\n25\tDRY_RUN=\"${DRY_RUN:-0}\"\n26\t\n27\trun() {\n28\t  if [[ \"$DRY_RUN\" == \"1\" ]]; then\n29\t    echo \"[DRY-RUN] $*\"\n30\t  else\n31\t    echo \"+ $*\"\n32\t    \"$@\"\n33\t  fi\n34\t}\n35\t\n36\techo \"=== Ray rollback: reverting to baseline ===\"\n37\techo \"  namespace : $NS\"\n38\techo \"  image     : $BASELINE_IMAGE\"\n39\techo \"  workers   : $BASELINE_WORKER_REPLICAS replicas\"\n40\techo \"  svc ports : gcs:6379 only (dashboard:8265 removed)\"\n41\techo \"\"\n42\t\n43\t# ── 1. Scale ray-worker replicas back to baseline ──────────────────────────\n44\techo \"[1/3] Scale ray-worker to ${BASELINE_WORKER_REPLICAS} replicas (was 3)...\"\n45\trun kubectl -n \"$NS\" scale deploy ray-worker \\\n46\t  --replicas=\"$BASELINE_WORKER_REPLICAS\"\n47\t\n48\t# ── 2. Roll back container images to baseline ───────────────────────────────\n49\techo \"[2/3] Set image rayproject/ray:2.8.0 on ray-head and ray-worker...\"\n50\trun kubectl -n \"$NS\" set image deploy/ray-head  ray-head=rayproject/ray:2.8.0\n51\trun kubectl -n \"$NS\" set image deploy/ray-worker ray-worker=rayproject/ray:2.8.0\n52\t\n53\t# ── 3. Remove dashboard port from ray-head Service ──────────────────────────\n54\t# The baseline Service spec contained only the gcs port (6379).\n55\t# stage_04 added dashboard:8265; this patch restores the original port list.\n56\techo \"[3/3] Patch ray-head Service: remove dashboard port 8265...\"\n57\trun kubectl -n \"$NS\" patch svc ray-head --type=json -p '[\n58\t  {\n59\t    \"op\": \"replace\",\n60\t    \"path\": \"/spec/ports\",\n61\t    \"value\": [\n62\t      {\"name\": \"gcs\", \"port\": 6379, \"protocol\": \"TCP\", \"targetPort\": 6379}\n63\t    ]\n64\t  }\n65\t]'\n66\t\n67\t# ── 4. Wait for rollouts to stabilise ───────────────────────────────────────\n68\tif [[ \"$DRY_RUN\" != \"1\" ]]; then\n69\t  echo \"\"\n70\t  echo \"[wait] Waiting for ray-head rollout...\"\n71\t  kubectl -n \"$NS\" rollout status deploy/ray-head  --timeout=180s\n72\t  echo \"[wait] Waiting for ray-worker rollout...\"\n73\t  kubectl -n \"$NS\" rollout status deploy/ray-worker --timeout=180s\n74\t\n75\t  echo \"\"\n76\t  echo \"=== Post-rollback state ===\"\n77\t  kubectl -n \"$NS\" get deploy -o wide\n78\t  echo \"\"\n79\t  kubectl -n \"$NS\" get svc ray-head -o \\\n80\t    jsonpath='ray-head ports: {range .spec.ports[*]}{.name}:{.port}  {end}{\"\\n\"}'\n81\tfi\n82\t\n83\techo \"\"\n84\techo \"Rollback complete.\"\n85\t"}]},"parent_tool_use_id":null,"session_id":"f9c573b3-a78d-4e75-8e9b-2013ef30191d","uuid":"d244982f-3083-4687-ba9b-a37f11fd0096","timestamp":"2026-06-25T14:09:44.509Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/rollback.sh","content":"#!/usr/bin/env bash\n# rollback.sh — revert ray namespace to the pre-change baseline.\n#\n# Changes applied by stages 02-04 of the\n# ray-scale-upgrade-dashboard-rollback-audit workflow:\n#\n#   stage_02 scale_workers:       ray-worker replicas  2 → 3\n#   stage_03 upgrade_version:     image  rayproject/ray:2.8.0 → rayproject/ray:2.9.0\n#   stage_04 dashboard_exposure:  ray-head Service gained port dashboard:8265\n#\n# This script undoes those three changes; resource limits were not\n# modified (both deployments have resources: {}) so no action is needed there.\n#\n# Usage (review only — do NOT run in production without team sign-off):\n#   bash rollback.sh\n#   # dry-run: inspect commands without executing:\n#   DRY_RUN=1 bash rollback.sh\n\nset -euo pipefail\n\nNS=ray\nBASELINE_IMAGE=\"rayproject/ray:2.8.0\"\nBASELINE_WORKER_REPLICAS=2\n\nDRY_RUN=\"${DRY_RUN:-0}\"\n\nrun() {\n  if [[ \"$DRY_RUN\" == \"1\" ]]; then\n    echo \"[DRY-RUN] $*\"\n  else\n    echo \"+ $*\"\n    \"$@\"\n  fi\n}\n\necho \"=== Ray rollback: reverting to baseline ===\"\necho \"  namespace : $NS\"\necho \"  image     : $BASELINE_IMAGE\"\necho \"  workers   : $BASELINE_WORKER_REPLICAS replicas\"\necho \"  svc ports : gcs:6379 only (dashboard:8265 removed)\"\necho \"\"\n\n# ── 1. Scale ray-worker replicas back to baseline ──────────────────────────\necho \"[1/3] Scale ray-worker to ${BASELINE_WORKER_REPLICAS} replicas (was 3)...\"\nrun kubectl -n \"$NS\" scale deploy ray-worker \\\n  --replicas=\"$BASELINE_WORKER_REPLICAS\"\n\n# ── 2. Roll back container images to baseline ───────────────────────────────\necho \"[2/3] Set image rayproject/ray:2.8.0 on ray-head and ray-worker...\"\nrun kubectl -n \"$NS\" set image deploy/ray-head  ray-head=rayproject/ray:2.8.0\nrun kubectl -n \"$NS\" set image deploy/ray-worker ray-worker=rayproject/ray:2.8.0\n\n# ── 3. Remove dashboard port from ray-head Service ──────────────────────────\n# The baseline Service spec contained only the gcs port (6379).\n# stage_04 added dashboard:8265; this patch restores the original port list.\necho \"[3/3] Patch ray-head Service: remove dashboard port 8265...\"\nrun kubectl -n \"$NS\" patch svc ray-head --type=json -p '[\n  {\n    \"op\": \"replace\",\n    \"path\": \"/spec/ports\",\n    \"value\": [\n      {\"name\": \"gcs\", \"port\": 6379, \"protocol\": \"TCP\", \"targetPort\": 6379}\n    ]\n  }\n]'\n\n# ── 4. Wait for rollouts to stabilise ───────────────────────────────────────\nif [[ \"$DRY_RUN\" != \"1\" ]]; then\n  echo \"\"\n  echo \"[wait] Waiting for ray-head rollout...\"\n  kubectl -n \"$NS\" rollout status deploy/ray-head  --timeout=180s\n  echo \"[wait] Waiting for ray-worker rollout...\"\n  kubectl -n \"$NS\" rollout status deploy/ray-worker --timeout=180s\n\n  echo \"\"\n  echo \"=== Post-rollback state ===\"\n  kubectl -n \"$NS\" get deploy -o wide\n  echo \"\"\n  kubectl -n \"$NS\" get svc ray-head -o \\\n    jsonpath='ray-head ports: {range .spec.ports[*]}{.name}:{.port}  {end}{\"\\n\"}'\nfi\n\necho \"\"\necho \"Rollback complete.\"\n","numLines":85,"startLine":1,"totalLines":85}}}
