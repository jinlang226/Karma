{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_011bCXkzmU6JjetuL67kXX3q","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_013nQ6WJr4ekhacLP38W1Lkf","name":"Write","input":{"file_path":"/tmp/rollback.sh","content":"#!/bin/bash\n# rollback.sh\n#\n# Reverts spark-pi namespace Spark deployments and RBAC to their original\n# defaults, undoing the following non-default customisations:\n#\n#   spark-master deployment\n#     image     : apache/spark:3.5.3  ->  apache/spark:latest\n#     resources : cpu 200m/500m, mem 512Mi/1Gi  ->  (none — cluster defaults)\n#     SA        : spark-pi  ->  default\n#\n#   spark-worker deployment\n#     replicas  : 1  ->  2\n#     image     : apache/spark:3.5.3  ->  apache/spark:latest\n#     resources : cpu 200m/500m, mem 512Mi/1Gi  ->  (none — cluster defaults)\n#     SA        : spark-pi  ->  default\n#\n#   RBAC (all removed)\n#     RoleBinding  spark-pi-role-binding\n#     Role         spark-pi-role\n#     ServiceAccount spark-pi\n#\n# WARNING: Do NOT execute this on the live cluster during normal operations.\n#          The current settings are load-bearing for the running workload.\n#          This script exists solely for pre-change-window review.\n\nset -euo pipefail\n\nNS=\"spark-pi\"\nDEFAULT_IMAGE=\"apache/spark:latest\"\n\necho \"=== spark-pi rollback — restoring original defaults ===\"\necho \"Namespace : $NS\"\necho \"Target image : $DEFAULT_IMAGE\"\necho \"\"\n\n# ── 1. spark-master: reset image, remove resource constraints, restore default SA ──\necho \"[1/4] Patching spark-master...\"\nkubectl -n \"$NS\" patch deployment spark-master --type='json' -p=\"[\n  {\\\"op\\\": \\\"replace\\\", \\\"path\\\": \\\"/spec/template/spec/serviceAccountName\\\",    \\\"value\\\": \\\"default\\\"},\n  {\\\"op\\\": \\\"replace\\\", \\\"path\\\": \\\"/spec/template/spec/containers/0/image\\\",    \\\"value\\\": \\\"${DEFAULT_IMAGE}\\\"},\n  {\\\"op\\\": \\\"remove\\\",  \\\"path\\\": \\\"/spec/template/spec/containers/0/resources\\\"}\n]\"\necho \"  spark-master patched.\"\n\n# ── 2. spark-worker: restore replicas to 2, reset image, remove resources, default SA ──\necho \"[2/4] Patching spark-worker...\"\nkubectl -n \"$NS\" patch deployment spark-worker --type='json' -p=\"[\n  {\\\"op\\\": \\\"replace\\\", \\\"path\\\": \\\"/spec/replicas\\\",                             \\\"value\\\": 2},\n  {\\\"op\\\": \\\"replace\\\", \\\"path\\\": \\\"/spec/template/spec/serviceAccountName\\\",    \\\"value\\\": \\\"default\\\"},\n  {\\\"op\\\": \\\"replace\\\", \\\"path\\\": \\\"/spec/template/spec/containers/0/image\\\",    \\\"value\\\": \\\"${DEFAULT_IMAGE}\\\"},\n  {\\\"op\\\": \\\"remove\\\",  \\\"path\\\": \\\"/spec/template/spec/containers/0/resources\\\"}\n]\"\necho \"  spark-worker patched.\"\n\n# ── 3. Remove custom RBAC bindings and role ──\necho \"[3/4] Removing custom RBAC...\"\nkubectl -n \"$NS\" delete rolebinding spark-pi-role-binding --ignore-not-found\nkubectl -n \"$NS\" delete role         spark-pi-role         --ignore-not-found\necho \"  RoleBinding and Role removed.\"\n\n# ── 4. Remove custom ServiceAccount (deployments already switched to 'default') ──\necho \"[4/4] Removing custom ServiceAccount spark-pi...\"\nkubectl -n \"$NS\" delete serviceaccount spark-pi --ignore-not-found\necho \"  ServiceAccount removed.\"\n\necho \"\"\necho \"=== Rollback complete ===\"\necho \"To verify rollout:\"\necho \"  kubectl rollout status deployment/spark-master deployment/spark-worker -n $NS\"\necho \"  kubectl get deploy,sa,role,rolebinding -n $NS\"\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":7358,"cache_read_input_tokens":33084,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":7358},"output_tokens":13,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id"