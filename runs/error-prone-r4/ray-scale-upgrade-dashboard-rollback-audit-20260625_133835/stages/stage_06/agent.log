{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NTps9bqTtJx8oCrWkE6tRs","type":"tool_result","content":"apiVersion: v1\ndata:\n  rollback.sh: |\n    #!/usr/bin/env bash\n    # rollback.sh — revert ray namespace to the pre-change baseline.\n    #\n    # Changes applied by stages 02-04 of the\n    # ray-scale-upgrade-dashboard-rollback-audit workflow:\n    #\n    #   stage_02 scale_workers:       ray-worker replicas  2 → 3\n    #   stage_03 upgrade_version:     image  rayproject/ray:2.8.0 → rayproject/ray:2.9.0\n    #   stage_04 dashboard_exposure:  ray-head Service gained port dashboard:8265\n    #\n    # This script undoes those three changes; resource limits were not\n    # modified (both deployments have resources: {}) so no action is needed there.\n    #\n    # Usage (review only — do NOT run in production without team sign-off):\n    #   bash rollback.sh\n    #   # dry-run: inspect commands without executing:\n    #   DRY_RUN=1 bash rollback.sh\n\n    set -euo pipefail\n\n    NS=ray\n    BASELINE_IMAGE=\"rayproject/ray:2.8.0\"\n    BASELINE_WORKER_REPLICAS=2\n\n    DRY_RUN=\"${DRY_RUN:-0}\"\n\n    run() {\n      if [[ \"$DRY_RUN\" == \"1\" ]]; then\n        echo \"[DRY-RUN] $*\"\n      else\n        echo \"+ $*\"\n        \"$@\"\n      fi\n    }\n\n    echo \"=== Ray rollback: reverting to baseline ===\"\n    echo \"  namespace : $NS\"\n    echo \"  image     : $BASELINE_IMAGE\"\n    echo \"  workers   : $BASELINE_WORKER_REPLICAS replicas\"\n    echo \"  svc ports : gcs:6379 only (dashboard:8265 removed)\"\n    echo \"\"\n\n    # ── 1. Scale ray-worker replicas back to baseline ──────────────────────────\n    echo \"[1/3] Scale ray-worker to ${BASELINE_WORKER_REPLICAS} replicas (was 3)...\"\n    run kubectl -n \"$NS\" scale deploy ray-worker \\\n      --replicas=\"$BASELINE_WORKER_REPLICAS\"\n\n    # ── 2. Roll back container images to baseline ───────────────────────────────\n    echo \"[2/3] Set image rayproject/ray:2.8.0 on ray-head and ray-worker...\"\n    run kubectl -n \"$NS\" set image deploy/ray-head  ray-head=rayproject/ray:2.8.0\n    run kubectl -n \"$NS\" set image deploy/ray-worker ray-worker=rayproject/ray:2.8.0\n\n    # ── 3. Remove dashboard port from ray-head Service ──────────────────────────\n    # The baseline Service spec contained only the gcs port (6379).\n    # stage_04 added dashboard:8265; this patch restores the original port list.\n    echo \"[3/3] Patch ray-head Service: remove dashboard port 8265...\"\n    run kubectl -n \"$NS\" patch svc ray-head --type=json -p '[\n      {\n        \"op\": \"replace\",\n        \"path\": \"/spec/ports\",\n        \"value\": [\n          {\"name\": \"gcs\", \"port\": 6379, \"protocol\": \"TCP\", \"targetPort\": 6379}\n        ]\n      }\n    ]'\n\n    # ── 4. Wait for rollouts to stabilise ───────────────────────────────────────\n    if [[ \"$DRY_RUN\" != \"1\" ]]; then\n      echo \"\"\n      echo \"[wait] Waiting for ray-head rollout...\"\n      kubectl -n \"$NS\" rollout status deploy/ray-head  --timeout=180s\n      echo \"[wait] Waiting for ray-worker rollout...\"\n      kubectl -n \"$NS\" rollout status deploy/ray-worker --timeout=180s\n\n      echo \"\"\n      echo \"=== Post-rollback state ===\"\n      kubectl -n \"$NS\" get deploy -o wide\n      echo \"\"\n      kubectl -n \"$NS\" get svc ray-head -o \\\n        jsonpath='ray-head ports: {range .spec.ports[*]}{.name}:{.port}  {end}{\"\\n\"}'\n    fi\n\n    echo \"\"\n    echo \"Rollback complete.\"\nkind: ConfigMap\nmetadata:\n  creationTimestamp: \"2026-06-25T13:50:44Z\"\n  name: rollback-rehearsal\n  namespace: ray\n  resourceVersion: \"187275\"\n  uid: 49481e61-164f-4d13-ae27-e12a1ec74947","is_error":false}]},"parent_tool_use_id":null,"session_id":"cefff69b-1ff8-440f-bc56-ec783d01a0ba","uuid":"7b782708-2720-4fe3-9af9-f6bd5ca0f889","timestamp":"2026-06-25T13:51:21.893Z","tool_use_result":{"stdout":"apiVersion: v1\ndata:\n  rollback.sh: |\n    #!/usr/bin/env bash\n    # rollback.sh — revert ray namespace to the pre-change baseline.\n    #\n    # Changes applied by stages 02-04 of the\n    # ray-scale-upgrade-dashboard-rollback-audit workflow:\n    #\n    #   stage_02 scale_workers:       ray-worker replicas  2 → 3\n    #   stage_03 upgrade_version:     image  rayproject/ray:2.8.0 → rayproject/ray:2.9.0\n    #   stage_04 dashboard_exposure:  ray-head Service gained port dashboard:8265\n    #\n    # This script undoes those three changes; resource limits were not\n    # modified (both deployments have resources: {}) so no action is needed there.\n    #\n    # Usage (review only — do NOT run in production without team sign-off):\n    #   bash rollback.sh\n    #   # dry-run: inspect commands without executing:\n    #   DRY_RUN=1 bash rollback.sh\n\n    set -euo pipefail\n\n    NS=ray\n    BASELINE_IMAGE=\"rayproject/ray:2.8.0\"\n    BASELINE_WORKER_REPLICAS=2\n\n    DRY_RUN=\"${DRY_RUN:-0}\"\n\n    run() {\n      if [[ \"$DRY_RUN\" == \"1\" ]]; then\n        echo \"[DRY-RUN] $*\"\n      else\n        echo \"+ $*\"\n        \"$@\"\n      fi\n    }\n\n    echo \"=== Ray rollback: reverting to baseline ===\"\n    echo \"  namespace : $NS\"\n    echo \"  image     : $BASELINE_IMAGE\"\n    echo \"  workers   : $BASELINE_WORKER_REPLICAS replicas\"\n    echo \"  svc ports : gcs:6379 only (dashboard:8265 removed)\"\n    echo \"\"\n\n    # ── 1. Scale ray-worker replicas back to baseline ──────────────────────────\n    echo \"[1/3] Scale ray-worker to ${BASELINE_WORKER_REPLICAS} replicas (was 3)...\"\n    run kubectl -n \"$NS\" scale deploy ray-worker \\\n      --replicas=\"$BASELINE_WORKER_REPLICAS\"\n\n    # ── 2. Roll back container images to baseline ───────────────────────────────\n    echo \"[2/3] Set image rayproject/ray:2.8.0 on ray-head and ray-worker...\"\n    run kubectl -n \"$NS\" set image deploy/ray-head  ray-head=rayproject/ray:2.8.0\n    run kubectl -n \"$NS\" set image deploy/ray-worker ray-worker=rayproject/ray:2.8.0\n\n    # ── 3. Remove dashboard port from ray-head Service ──────────────────────────\n    # The baseline Service spec contained only the gcs port (6379).\n    # stage_04 added dashboard:8265; this patch restores the original port list.\n    echo \"[3/3] Patch ray-head Service: remove dashboard port 8265...\"\n    run kubectl -n \"$NS\" patch svc ray-head --type=json -p '[\n      {\n        \"op\": \"replace\",\n        \"path\": \"/spec/ports\",\n        \"value\": [\n          {\"name\": \"gcs\", \"port\": 6379, \"protocol\": \"TCP\", \"targetPort\": 6379}\n        ]\n      }\n    ]'\n\n    # ── 4. Wait for rollouts to stabilise ───────────────────────────────────────\n    if [[ \"$DRY_RUN\" != \"1\" ]]; then\n      echo \"\"\n      echo \"[wait] Waiting for ray-head rollout...\"\n      kubectl -n \"$NS\" rollout status deploy/ray-head  --timeout=180s\n      echo \"[wait] Waiting for ray-worker rollout...\"\n      kubectl -n \"$NS\" rollout status deploy/ray-worker --timeout=180s\n\n      echo \"\"\n      echo \"=== Post-rollback state ===\"\n      kubectl -n \"$NS\" get deploy -o wide\n      echo \"\"\n      kubectl -n \"$NS\" get svc ray-head -o \\\n        jsonpath='ray-head ports: {range .spec.ports[*]}{.name}:{.port}  {end}{\"\\n\"}'\n    fi\n\n    echo \"\"\n    echo \"Rollback complete.\"\nkind: ConfigMap\nmetadata:\n  creationTimestamp: \"2026-06-25T13:50:44Z\"\n  name: rollback-rehearsal\n  namespace: ray\n  resourceVersion: \"187275\"\n  uid: 49481e61-164f-4d13-ae27-e12a1ec74947","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
