{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01B9A3Y6DppGvdvpqCBM2aLE","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01V7tMfYA8ayKj22mp62JYuD","name":"Write","input":{"file_path":"/tmp/rollback.sh","content":"#!/usr/bin/env bash\n# rollback.sh — revert ray namespace to the pre-change baseline.\n#\n# Changes applied by stages 02-04 of the\n# ray-scale-upgrade-dashboard-rollback-audit workflow:\n#\n#   stage_02 scale_workers:       ray-worker replicas  2 → 3\n#   stage_03 upgrade_version:     image  rayproject/ray:2.8.0 → rayproject/ray:2.9.0\n#   stage_04 dashboard_exposure:  ray-head Service gained port dashboard:8265\n#\n# This script undoes those three changes; resources limits were not\n# modified (both deployments have resources: {}) so no action is needed there.\n#\n# Usage (review only — do NOT run in production without team sign-off):\n#   bash rollback.sh\n#   # or dry-run to inspect the commands without executing:\n#   DRY_RUN=1 bash rollback.sh\n\nset -euo pipefail\n\nNS=ray\nBASELINE_IMAGE=\"rayproject/ray:2.8.0\"\nBASELINE_WORKER_REPLICAS=2\n\nDRY_RUN=\"${DRY_RUN:-0}\"\n\nrun() {\n  if [[ \"$DRY_RUN\" == \"1\" ]]; then\n    echo \"[DRY-RUN] $*\"\n  else\n    echo \"+ $*\"\n    \"$@\"\n  fi\n}\n\necho \"=== Ray rollback: reverting to baseline ===\"\necho \"  namespace : $NS\"\necho \"  image     : $BASELINE_IMAGE\"\necho \"  workers   : $BASELINE_WORKER_REPLICAS replicas\"\necho \"  svc ports : gcs:6379 only (dashboard:8265 removed)\"\necho \"\"\n\n# ── 1. Scale ray-worker replicas back to baseline ──────────────────────────\necho \"[1/3] Scale ray-worker to ${BASELINE_WORKER_REPLICAS} replicas (was 3)...\"\nrun kubectl -n \"$NS\" scale deploy ray-worker \\\n  --replicas=\"$BASELINE_WORKER_REPLICAS\"\n\n# ── 2. Roll back container images to baseline ───────────────────────────────\necho \"[2/3] Set image rayproject/ray:2.8.0 on ray-head and ray-worker...\"\nrun kubectl -n \"$NS\" set image deploy/ray-head  ray-head=rayproject/ray:2.8.0\nrun kubectl -n \"$NS\" set image deploy/ray-worker ray-worker=rayproject/ray:2.8.0\n\n# ── 3. Remove dashboard port from ray-head Service ──────────────────────────\n# The baseline Service spec contained only the gcs port (6379).\n# stage_04 added dashboard:8265; this patch restores the original port list.\necho \"[3/3] Patch ray-head Service: remove dashboard port 8265...\"\nrun kubectl -n \"$NS\" patch svc ray-head --type=json -p '[\n  {\n    \"op\": \"replace\",\n    \"path\": \"/spec/ports\",\n    \"value\": [\n      {\"name\": \"gcs\", \"port\": 6379, \"protocol\": \"TCP\", \"targetPort\": 6379}\n    ]\n  }\n]'\n\n# ── 4. Wait for rollouts to stabilise ───────────────────────────────────────\nif [[ \"$DRY_RUN\" != \"1\" ]]; then\n  echo \"\"\n  echo \"[wait] Waiting for ray-head rollout...\"\n  kubectl -n \"$NS\" rollout status deploy/ray-head  --timeout=180s\n  echo \"[wait] Waiting for ray-worker rollout...\"\n  kubectl -n \"$NS\" rollout status deploy/ray-worker --timeout=180s\n\n  echo \"\"\n  echo \"=== Post-rollback state ===\"\n  kubectl -n \"$NS\" get deploy -o wide\n  echo \"\"\n  kubectl -n \"$NS\" get svc ray-head -o \\\n    jsonpath='ray-head ports: {range .spec.ports[*]}{.name}:{.port}  {end}{\"\\n\"}'\nfi\n\necho \"\"\necho \"Rollback complete.\"\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":651,"cache_read_input_tokens":35471,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":651},"output_tokens":33,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"ba887eef-8aee-47cc-8483-3445d6ebd337","uuid":"32e4c728-376d-4859-b2b3-28712dcd2ac2","request_id":"req_011CcQ5twqxhcGWLmygaXMBT"}
