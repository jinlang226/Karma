lue: always\n#\n#   [E] Ingress canary-alt (demo namespace)\n#       — 3 canary routing annotations (non-vanilla nginx behavior):\n#           nginx.ingress.kubernetes.io/canary: \"true\"\n#           nginx.ingress.kubernetes.io/canary-by-header: X-Canary\n#           nginx.ingress.kubernetes.io/canary-by-header-value: beta\n#\n# Resources intentionally NOT touched by this script:\n#   - ingress-nginx-controller-extra ConfigMap (labeled benchmark.decoy:true)\n#   - IngressClass ingress-1 / ingress-2 (decoy classes, no active controller)\n#   - demo-ingress TLS configuration (app-level concern)\n#   - RBAC, Services, Pods, or any other non-nginx-config resources\n#\n# PREREQUISITE: kubectl must be on PATH and pointed at the target cluster.\n# DO NOT run this on the live cluster without change-window approval.\n\nset -euo pipefail\n\necho \"=== ingress-nginx rollback to vanilla defaults ===\"\necho\n\n# -------------------------------------------------------------------------\n# [A] Clear OTel settings from ingress-nginx-controller ConfigMap\n# -------------------------------------------------------------------------\necho \"[A] Clearing OpenTelemetry keys from ingress-nginx-controller ConfigMap...\"\nkubectl -n ingress-nginx patch configmap ingress-nginx-controller \\\n  --type=json \\\n  -p='[\n    {\"op\":\"remove\",\"path\":\"/data/enable-opentelemetry\"},\n    {\"op\":\"remove\",\"path\":\"/data/log-format-upstream\"},\n    {\"op\":\"remove\",\"path\":\"/data/opentelemetry-collector-host\"},\n    {\"op\":\"remove\",\"path\":\"/data/opentelemetry-collector-port\"},\n    {\"op\":\"remove\",\"path\":\"/data/otel-sampler\"},\n    {\"op\":\"remove\",\"path\":\"/data/otel-sampler-parent-based\"},\n    {\"op\":\"remove\",\"path\":\"/data/otel-sampler-ratio\"},\n    {\"op\":\"remove\",\"path\":\"/data/otlp-collector-host\"},\n    {\"op\":\"remove\",\"path\":\"/data/otlp-collector-port\"}\n  ]'\necho \"    ConfigMap data is now empty (vanilla default).\"\necho\n\n# -------------------------------------------------------------------------\n# [B] Restore --watch-ingress-without-class=true in the controller Deployment\n#\n# The live Deployment was patched to =false after the initial kubectl apply\n# (which had =true). Index 8 (0-based) in the args array is the flag.\n# Verified from: kubectl -n ingress-nginx get deploy ingress-nginx-controller\n#   -o jsonpath='{.spec.template.spec.containers[0].args[8]}'\n# -------------------------------------------------------------------------\necho \"[B] Restoring --watch-ingress-without-class=true in controller Deployment...\"\nkubectl -n ingress-nginx patch deployment ingress-nginx-controller \\\n  --type=json \\\n  -p='[{\n    \"op\":    \"replace\",\n    \"path\":  \"/spec/template/spec/containers/0/args/8\",\n    \"value\": \"--watch-ingress-without-class=true\"\n  }]'\necho \"    Deployment args restored.\"\necho\n\n# -------------------------------------------------------------------------\n# [C] Remove rate-limiting annotations from Ingress rate-api\n#\n# These three annotations were added after the initial apply\n# (last-applied-configuration had annotations: {}).\n# Appending '-' to an annotation name removes it via kubectl annotate.\n# -------------------------------------------------------------------------\necho \"[C] Removing rate-limiting annotations from Ingress rate-api...\"\nkubectl -n demo annotate ingress rate-api \\\n  nginx.ingress.kubernetes.io/limit-rps- \\\n  nginx.ingress.kubernetes.io/limit-burst-multiplier- \\\n  nginx.ingress.kubernetes.io/limit-req-status-code-\necho \"    Rate-limiting annotations removed from rate-api.\"\necho\n\n# -------------------------------------------------------------------------\n# [D] Restore Ingress canary-canary\n#\n# Two changes to undo:\n#   1. ingressClassName was patched from nginx -> ingress-1 after initial\n#      apply. Restore to nginx so it is handled by the running controller.\n#   2. Remove the three canary routing annotations