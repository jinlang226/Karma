{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P5rwzyJg7Ad7FRaymFwZHa","type":"tool_result","content":"#!/bin/sh\n# RabbitMQ rollback script — reverts non-default configuration to RabbitMQ defaults.\n#\n# Inspected state (2026-06-25):\n#   vhosts:      /app, /ops  (non-default; default is / only)\n#   users:       app-user [management], ops-user [management]  (non-default; default is guest)\n#   policies:    /app: ha-all  (ha-mode=all, ha-sync-mode=automatic, pattern=.*, apply-to=queues)\n#   permissions: app-user -> /app (.*,.*,.*); ops-user -> /ops (.*,.*,.*)\n#   queues:      app-queue in /app (classic, durable); ops-queue in /ops (classic, durable)\n#\n# Run inside the rabbitmq-0 pod:\n#   kubectl -n <namespace> exec rabbitmq-0 -- sh /path/to/rollback.sh\n#\n# WARNING: executing this script will irreversibly remove the above configuration\n# from the live cluster.  It is stored here for REVIEW ONLY.\n\nset -e\n\necho \"=== RabbitMQ rollback: reverting non-default configuration ===\"\n\n# 1. Remove the HA policy from /app\necho \"[1/7] Clearing policy 'ha-all' from vhost /app ...\"\nrabbitmqctl clear_policy -p /app ha-all\n\n# 2. Delete queues before removing vhosts (clean shutdown)\necho \"[2/7] Deleting queue 'app-queue' from vhost /app ...\"\nrabbitmqctl delete_queue -p /app app-queue\n\necho \"[3/7] Deleting queue 'ops-queue' from vhost /ops ...\"\nrabbitmqctl delete_queue -p /ops ops-queue\n\n# 3. Clear per-user permissions before deleting users and vhosts\necho \"[4/7] Clearing permissions for app-user on /app ...\"\nrabbitmqctl clear_permissions -p /app app-user\n\necho \"[5/7] Clearing permissions for ops-user on /ops ...\"\nrabbitmqctl clear_permissions -p /ops ops-user\n\n# 4. Delete non-default users\necho \"[6/7] Deleting users app-user and ops-user ...\"\nrabbitmqctl delete_user app-user\nrabbitmqctl delete_user ops-user\n\n# 5. Delete non-default vhosts (also removes their remaining bindings/exchanges)\necho \"[7/7] Deleting vhosts /app and /ops ...\"\nrabbitmqctl delete_vhost /app\nrabbitmqctl delete_vhost /ops\n\necho \"=== Rollback complete. Remaining state: vhost '/', user 'admin' (administrator) ===\"","is_error":false}]},"parent_tool_use_id":null,"session_id":"7a6cfeaf-183c-404f-becb-3d450ca2f2c2","uuid":"fd22521e-65a8-4f0f-86df-15e59446f671","timestamp":"2026-06-25T13:52:28.493Z","tool_use_result":{"stdout":"#!/bin/sh\n# RabbitMQ rollback script — reverts non-default configuration to RabbitMQ defaults.\n#\n# Inspected state (2026-06-25):\n#   vhosts:      /app, /ops  (non-default; default is / only)\n#   users:       app-user [management], ops-user [management]  (non-default; default is guest)\n#   policies:    /app: ha-all  (ha-mode=all, ha-sync-mode=automatic, pattern=.*, apply-to=queues)\n#   permissions: app-user -> /app (.*,.*,.*); ops-user -> /ops (.*,.*,.*)\n#   queues:      app-queue in /app (classic, durable); ops-queue in /ops (classic, durable)\n#\n# Run inside the rabbitmq-0 pod:\n#   kubectl -n <namespace> exec rabbitmq-0 -- sh /path/to/rollback.sh\n#\n# WARNING: executing this script will irreversibly remove the above configuration\n# from the live cluster.  It is stored here for REVIEW ONLY.\n\nset -e\n\necho \"=== RabbitMQ rollback: reverting non-default configuration ===\"\n\n# 1. Remove the HA policy from /app\necho \"[1/7] Clearing policy 'ha-all' from vhost /app ...\"\nrabbitmqctl clear_policy -p /app ha-all\n\n# 2. Delete queues before removing vhosts (clean shutdown)\necho \"[2/7] Deleting queue 'app-queue' from vhost /app ...\"\nrabbitmqctl delete_queue -p /app app-queue\n\necho \"[3/7] Deleting queue 'ops-queue' from vhost /ops ...\"\nrabbitmqctl delete_queue -p /ops ops-queue\n\n# 3. Clear per-user permissions before deleting users and vhosts\necho \"[4/7] Clearing permissions for app-user on /app ...\"\nrabbitmqctl clear_permissions -p /app app-user\n\necho \"[5/7] Clearing permissions for ops-user on /ops ...\"\nrabbitmqctl clear_permissions -p /ops ops-user\n\n# 4. Delete non-default users\necho \"[6/7] Deleting users app-user and ops-user ...\"\nrabbitmqctl delete_user app-user\nrabbitmqctl delete_user ops-user\n\n# 5. Delete non-default vhosts (also removes their remaining bindings/exchanges)\necho \"[7/7] Deleting vhosts /app and /ops ...\"\nrabbitmqctl delete_vhost /app\nrabbitmqctl delete_vhost /ops\n\necho \"=== Rollback complete. Remaining state: vhost '/', user 'admin' (administrator) ===\"","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
