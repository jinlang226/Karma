abbitmqctl delete_user ops-user\n\n# 5. Delete non-default vhosts (also removes their remaining bindings/exchanges)\necho \"[7/7] Deleting vhosts /app and /ops ...\"\nrabbitmqctl delete_vhost /app\nrabbitmqctl delete_vhost /ops\n\necho \"=== Rollback complete. Remaining state: vhost '/', user 'admin' (administrator) ===\"\nEOF\necho \"Script written. Lines: $(wc -l < /tmp/rollback.sh)\"","description":"Write rollback.sh to /tmp"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1986,"cache_read_input_tokens":33787,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1986},"output_tokens":73,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"285223cd-7b47-46d3-be15-81d04e6a6a04","uuid":"ad3b8c14-1f91-4755-a499-71e040e07b7c","request_id":"req_011CcQ5JZSNaaf6eMTWMRy6M"}
