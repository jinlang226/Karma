changes)\necho \"[7/7] Deleting vhosts /app and /ops ...\"\nrabbitmqctl delete_vhost /app\nrabbitmqctl delete_vhost /ops\n\necho \"=== Rollback complete. Remaining state: vhost '/', user 'admin' (administrator) ===\"\n\n=== Cluster state unchanged — quick verification ===\nListing vhosts ...\nname\n/ops\n/\n/app\n---\nListing users ...\nuser\ttags\nadmin\t[administrator]\napp-user\t[management]\nops-user\t[management]\n---\nListing policies for vhost \"/app\" ...\nvhost\tname\tpattern\tapply-to\tdefinition\tpriority\n/app\tha-all\t.*\tqueues\t{\"ha-mode\":\"all\",\"ha-sync-mode\":\"automatic\"}\t0","is_error":false}]},"parent_tool_use_id":null,"session_id":"285223cd-7b47-46d3-be15-81d04e6a6a04","uuid":"b7c7146c-b51e-44f0-8353-3997d0c6fb16","timestamp":"2026-06-25T13:42:24.942Z","tool_use_result":{"stdout":"=== ConfigMap contents ===\n#!/bin/sh\n# RabbitMQ rollback script — reverts non-default configuration to RabbitMQ defaults.\n#\n# Inspected state (2026-06-25):\n#   vhosts:      /app, /ops  (non-default; default is / only)\n#   users:       app-user [management], ops-user [management]  (non-default; default is guest)\n#   policies:    /app: ha-all  (ha-mode=all, ha-sync-mode=automatic, pattern=.*, apply-to=queues)\n#   permissions: app-user -> /app (.*,.*,.*); ops-user -> /ops (.*,.*,.*)\n#   queues:      app-queue in /app (classic, durable); ops-queue in /ops (classic, durable)\n#\n# Run inside the rabbitmq-0 pod:\n#   kubectl -n <namespace> exec rabbitmq-0 -- sh /path/to/rollback.sh\n#\n# WARNING: executing this script will irreversibly remove the above configuration\n# from the live cluster.  It is stored here for REVIEW ONLY.\n\nset -e\n\necho \"=== RabbitMQ rollback: reverting non-default configuration ===\"\n\n# 1. Remove the HA policy from /app\necho \"[1/7] Clearing policy 'ha-all' from vhost /app ...\"\nrabbitmqctl clear_policy -p /app ha-all\n\n# 2. Delete queues before removing vhosts (clean shutdown)\necho \"[2/7] Deleting queue 'app-queue' from vhost 