gure RabbitMQ to enable TLS listeners in its config, and perform a rolling restart to apply the changes.\n\nI'm checking the current certificate's Subject Alternative Names to ensure the new cert covers all the necessary DNS entries for the RabbitMQ service and headless service across the cluster domain.\n\nNow I need to generate a new private key and certificate signing request in the openssl-toolbox pod, have the CA sign it, then update the secret and configmap with the new certificate and TLS configuration before rolling out the StatefulSet changes.","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":735,"cache_read_input_tokens":38226,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":735},"output_tokens":36,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"558f2b9d-fffe-4e04-86b8-fcf7c796867d","uuid":"81c01395-dee3-43ea-b435-0883dad3f4a0","request_id":"req_011Cc75e9cuCyaPybDtwr9kv"}
