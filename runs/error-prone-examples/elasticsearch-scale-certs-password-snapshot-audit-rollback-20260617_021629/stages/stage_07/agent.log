{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WQivz6Ld4gjESq2MMCRhs7","type":"tool_result","content":"1\t#!/bin/bash\n2\t# Rollback script: reverts non-default CockroachDB configuration to factory defaults.\n3\t#\n4\t# Observed non-defaults (captured 2026-06-16):\n5\t#   diagnostics.reporting.enabled  = true        (default: false)\n6\t#   kv.range_merge.queue.enabled   = false       (default: true)\n7\t#   kv.snapshot_rebalance.max_rate = 208 MiB     (default: 32 MiB)\n8\t#   zone config: defaultdb.tenant_b.table_c      (custom override)\n9\t#   zone config: defaultdb.tenant_b.table_d      (custom override)\n10\t#\n11\t# DO NOT RUN until the scheduled change window. This script will modify live\n12\t# cluster behaviour and remove explicit zone overrides from tenant_b tables.\n13\t#\n14\t# Prerequisites:\n15\t#   - kubectl on PATH, pointed at the target cluster\n16\t#   - Namespace cockroachdb accessible\n17\t#   - TLS certs mounted at /cockroach/cockroach-certs inside crdb-cluster-0\n18\t#     (the cockroachdb-node-certs secret, already mounted by the StatefulSet)\n19\t\n20\tset -euo pipefail\n21\t\n22\tNAMESPACE=cockroachdb\n23\tPOD=crdb-cluster-0\n24\tCRDB_CMD=\"./cockroach sql --certs-dir=/cockroach/cockroach-certs --host=localhost\"\n25\t\n26\trun_sql() {\n27\t    kubectl -n \"${NAMESPACE}\" exec \"${POD}\" -- ${CRDB_CMD} -e \"$1\"\n28\t}\n29\t\n30\techo \"=== CockroachDB rollback: $(date -u '+%Y-%m-%dT%H:%M:%SZ') ===\"\n31\techo \"Target: namespace=${NAMESPACE}  pod=${POD}\"\n32\techo \"\"\n33\t\n34\t# ── 1. Cluster settings ────────────────────────────────────────────────────────\n35\techo \"--- Resetting cluster settings to factory defaults ---\"\n36\t\n37\trun_sql \"RESET CLUSTER SETTING diagnostics.reporting.enabled;\"\n38\techo \"  diagnostics.reporting.enabled  -> false (default)\"\n39\t\n40\trun_sql \"RESET CLUSTER SETTING kv.range_merge.queue.enabled;\"\n41\techo \"  kv.range_merge.queue.enabled   -> true (default)\"\n42\t\n43\trun_sql \"RESET CLUSTER SETTING kv.snapshot_rebalance.max_rate;\"\n44\techo \"  kv.snapshot_rebalance.max_rate -> 32 MiB (default)\"\n45\t\n46\techo \"\"\n47\t\n48\t# ── 2. Zone configs ────────────────────────────────────────────────────────────\n49\t# DISCARDing removes the explicit override so these tables inherit from the\n50\t# default zone. System-range zones (meta, liveness, system, lease tables, etc.)\n51\t# are CockroachDB 24.1 factory defaults and are left untouched.\n52\techo \"--- Discarding custom zone config overrides ---\"\n53\t\n54\trun_sql \"ALTER TABLE defaultdb.tenant_b.table_c CONFIGURE ZONE DISCARD;\"\n55\techo \"  defaultdb.tenant_b.table_c zone config discarded (inherits default)\"\n56\t\n57\trun_sql \"ALTER TABLE defaultdb.tenant_b.table_d CONFIGURE ZONE DISCARD;\"\n58\techo \"  defaultdb.tenant_b.table_d zone config discarded (inherits default)\"\n59\t\n60\techo \"\"\n61\t\n62\t# ── 3. Verification ────────────────────────────────────────────────────────────\n63\techo \"--- Post-rollback verification ---\"\n64\t\n65\techo \"\"\n66\techo \"Cluster settings (should now equal default_value):\"\n67\trun_sql \"\n68\tSELECT variable, value, default_value\n69\t  FROM crdb_internal.cluster_settings\n70\t WHERE variable IN (\n71\t   'diagnostics.reporting.enabled',\n72\t   'kv.range_merge.queue.enabled',\n73\t   'kv.snapshot_rebalance.max_rate'\n74\t );\n75\t\"\n76\t\n77\techo \"\"\n78\techo \"Remaining non-default cluster settings (expect: only cluster.secret and version):\"\n79\trun_sql \"SELECT variable, value FROM crdb_internal.cluster_settings WHERE value != default_value;\"\n80\t\n81\techo \"\"\n82\techo \"Zone configs for tenant_b tables (expect: no rows after DISCARD):\"\n83\trun_sql \"\n84\tSELECT target, raw_config_sql\n85\t  FROM crdb_internal.zones\n86\t WHERE target LIKE '%tenant_b%';\n87\t\"\n88\t\n89\techo \"\"\n90\techo \"=== Rollback complete ===\"\n91\t"}]},"parent_tool_use_id":null,"session_id":"b356380b-6b3a-4b7d-b38a-6facbb026947","uuid":"35beb4dd-59fc-4306-8967-8c690011940d","timestamp":"2026-06-17T03:07:37.550Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/rollback.sh","content":"#!/bin/bash\n# Rollback script: reverts non-default CockroachDB configuration to factory defaults.\n#\n# Observed non-defaults (captured 2026-06-16):\n#   diagnostics.reporting.enabled  = true        (default: false)\n#   kv.range_merge.queue.enabled   = false       (default: true)\n#   kv.snapshot_rebalance.max_rate = 208 MiB     (default: 32 MiB)\n#   zone config: defaultdb.tenant_b.table_c      (custom override)\n#   zone config: defaultdb.tenant_b.table_d      (custom override)\n#\n# DO NOT RUN until the scheduled change window. This script will modify live\n# cluster behaviour and remove explicit zone overrides from tenant_b tables.\n#\n# Prerequisites:\n#   - kubectl on PATH, pointed at the target cluster\n#   - Namespace cockroachdb accessible\n#   - TLS certs mounted at /cockroach/cockroach-certs inside crdb-cluster-0\n#     (the cockroachdb-node-certs secret, already mounted by the StatefulSet)\n\nset -euo pipefail\n\nNAMESPACE=cockroachdb\nPOD=crdb-cluster-0\nCRDB_CMD=\"./cockroach sql --certs-dir=/cockroach/cockroach-certs --host=localhost\"\n\nrun_sql() {\n    kubectl -n \"${NAMESPACE}\" exec \"${POD}\" -- ${CRDB_CMD} -e \"$1\"\n}\n\necho \"=== CockroachDB rollback: $(date -u '+%Y-%m-%dT%H:%M:%SZ') ===\"\necho \"Target: namespace=${NAMESPACE}  pod=${POD}\"\necho \"\"\n\n# ── 1. Cluster settings ────────────────────────────────────────────────────────\necho \"--- Resetting cluster settings to factory defaults ---\"\n\nrun_sql \"RESET CLUSTER SETTING diagnostics.reporting.enabled;\"\necho \"  diagnostics.reporting.enabled  -> false (default)\"\n\nrun_sql \"RESET CLUSTER SETTING kv.range_merge.queue.enabled;\"\necho \"  kv.range_merge.queue.enabled   -> true (default)\"\n\nrun_sql \"RESET CLUSTER SETTING kv.snapshot_rebalance.max_rate;\"\necho \"  kv.snapshot_rebalance.max_rate -> 32 MiB (default)\"\n\necho \"\"\n\n# ── 2. Zone configs ────────────────────────────────────────────────────────────\n# DISCARDing removes the explicit override so these tables inherit from the\n# default zone. System-range zones (meta, liveness, system, lease tables, etc.)\n# are CockroachDB 24.1 factory defaults and are left untouched.\necho \"--- Discarding custom zone config overrides ---\"\n\nrun_sql \"ALTER TABLE defaultdb.tenant_b.table_c CONFIGURE ZONE DISCARD;\"\necho \"  defaultdb.tenant_b.table_c zone config discarded (inherits default)\"\n\nrun_sql \"ALTER TABLE defaultdb.tenant_b.table_d CONFIGURE ZONE DISCARD;\"\necho \"  defaultdb.tenant_b.table_d zone config discarded (inherits default)\"\n\necho \"\"\n\n# ── 3. Verification ────────────────────────────────────────────────────────────\necho \"--- Post-rollback verification ---\"\n\necho \"\"\necho \"Cluster settings (should now equal default_value):\"\nrun_sql \"\nSELECT variable, value, default_value\n  FROM crdb_internal.cluster_settings\n WHERE variable IN (\n   'diagnostics.reporting.enabled',\n   'kv.range_merge.queue.enabled',\n   'kv.snapshot_rebalance.max_rate'\n );\n\"\n\necho \"\"\necho \"Remaining non-default cluster settings (expect: only cluster.secret and version):\"\nrun_sql \"SELECT variable, value FROM crdb_internal.cluster_settings WHERE value != default_value;\"\n\necho \"\"\necho \"Zone configs for tenant_b tables (expect: no rows after DISCARD):\"\nrun_sql \"\nSELECT target, raw_config_sql\n  FROM crdb_internal.zones\n WHERE target LIKE '%tenant_b%';\n\"\n\necho \"\"\necho \"=== Rollback complete ===\"\n","numLines":91,"startLine":1,"totalLines":91}}}
