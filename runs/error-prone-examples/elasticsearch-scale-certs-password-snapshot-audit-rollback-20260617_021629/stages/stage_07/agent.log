nning in the elasticsearch namespace\n#   - Operator with cluster-admin (or equivalent) RBAC\n#\n# WARNING: This script makes permanent, irreversible changes. The live cluster\n# MUST remain as-found until this script is reviewed and change-window approved.\n#\n\nset -euo pipefail\n\nNAMESPACE=\"elasticsearch\"\nES_URL=\"https://es-http.elasticsearch.svc:9200\"\nES_USER=\"elastic\"\n# Current active password (rotated from original 'elasticpass')\nES_PASS=\"elasticpass-elastic-password-next\"\nORIG_PASS=\"elasticpass\"\nEXEC_POD=\"curl-test\"\n\n# Run an Elasticsearch REST call from inside the cluster\nes() {\n    local method=\"$1\"\n    local path=\"$2\"\n    local body=\"${3:-}\"\n    local curl_args=(-sk -u \"${ES_USER}:${ES_PASS}\" -X \"${method}\" \"${ES_URL}${path}\")\n    if [ -n \"${body}\" ]; then\n        curl_args+=(-H 'Content-Type: application/json' -d \"${body}\")\n    fi\n    kubectl -n \"${NAMESPACE}\" exec \"${EXEC_POD}\" -- curl \"${curl_args[@]}\"\n    echo   # newline after each JSON response\n}\n\nlog() { echo \"\"; echo \"==> $*\"; }\n\n# ============================================================\n# PRE-FLIGHT: confirm cluster is reachable\n# ============================================================\nlog \"Pre-flight: verifying cluster connectivity...\"\nes GET \"/_cluster/health?pretty\" \"\"\n\n# ============================================================\n# SECTION 1: Dynamic cluster settings — reset all to defaults\n# ============================================================\nlog \"[1/6] Resetting persistent and transient cluster settings to defaults...\"\n#\n# Observed state: persistent={}, transient={} — already at defaults.\n# We null out the specific keys that the scale/snapshot/routing configuration\n# would typically apply so the rollback is safe even if settings were later\n# added between the observation snapshot and this execution.\n#\nes PUT \"/_cluster/settings\" '{\n  \"persistent\": {\n    \"cluster.routing.allocation.awareness.attributes\": null,\n    \"cluster.routing.allocation.awareness.force.zone.values\": null,\n    \"cluster.routing.allocation.enable\": null,\n    \"cluster.routing.allocation.disk.watermark.low\": null,\n    \"cluster.routing.allocation.disk.watermark.high\": null,\n    \"cluster.routing.allocation.disk.watermark.flood_stage\": null,\n    \"cluster.routing.rebalance.enable\": null,\n    \"action.auto_create_index\": null,\n    \"action.destructive_requires_name\": null,\n    \"indices.recovery.max_bytes_per_sec\": null\n  },\n  \"transient\": {\n    \"cluster.routing.allocation.awareness.attributes\": null,\n    \"cluster.routing.allocation.enable\": null,\n    \"cluster.routing.rebalance.enable\": null\n  }\n}'\n\n# ============================================================\n# SECTION 2: Snapshot — delete snapshot-1, then deregister repo\n# ============================================================\nlog \"[2/6] Removing snapshot-1 and repository minio-repo...\"\n#\n# Observed:\n#   Repository: minio-repo (type=s3, bucket=es-backups, path_style_access=true,\n#               endpoint=minio.elasticsearch.svc.cluster.local:9000, protocol=http)\n#   Snapshot  : snapshot-1 (state=SUCCESS, includes .security-7 + global_state)\n# Default: no snapshot repositories exist in a fresh cluster.\n#\n# NOTE: snapshot-1 contains the .security-7 index (credentials/roles/API keys).\n# Deleting it from ES removes the ES reference; MinIO bucket data is removed\n# separately in Section 6 when the MinIO Deployment is torn down.\n#\necho \"  Deleting snapshot snapshot-1 from minio-repo...\"\nes DELETE \"/_snapshot/minio-repo/snapshot-1\" \"\" || \\\n    echo \"  (snapshot-1 not found — may have already been removed)\"\n\necho \"  Deregistering repository minio-repo...\"\nes DELETE \"/_snapshot/minio-repo\" \"\" || \\\n    echo \"  (minio-repo not found — may have already been removed)\"\n\n# ============================================================\n# SECTION 3: Keystore — remove S3 client credentials on each node\n# ============================================================\nlog \"[3/6] Removing S3 keystore entries from all Elasticsearch nodes...\"\n#\n# Observed: s3.client.default.access_key = minioadmin\n#           s3.client.default.secret_key  = minioadmin\n# These were loaded via the es-secure-settings Secret mounted as a keystore file\n# on each node. The Secret is deleted in Section 6; we also remove the entries\n# from the live keystore so they take effect without a pod restart.\n# Default: empty keystore (no S3 client credentials).\n#\nfor NODE in elasticsearch-0 elasticsearch-1 elasticsearch-2; do\n    echo \"  Node ${NODE}:\"\n    kubectl -n \"${NAMESPACE}\" exec \"${NODE}\" -c elasticsearch -- \\\n        /usr/share/elasticsearch/bin/elasticsearch-keystore remove s3.client.default.access_key \\\n        2>/dev/null && echo \"    removed s3.client.default.access_key\" || \\\n        echo \"    s3.client.default.access_key not in keystore (skipping)\"\n\n    kubectl -n \"${NAMESPACE}\" exec \"${NODE}\" -c elasticsearch -- \\\n        /usr/share/elasticsearch/bin/elasticsearch-keystore remove s3.client.default.secret_key \\\n        2>/dev/null && echo \"    removed s3.client.default.secret_key\" || \\\n        echo \"    s3.client.default.secret_key not in keystore (skipping)\"\ndone\n\necho \"  Reloading secure settings on all nodes...\"\nes POST \"/_nodes/reload_secure_settings\" '{\"secure_settings_password\": \"\"}' || \\\n    echo \"  (reload_secure_settings failed — nodes may need manual restart if S3 plugin still active)\"\n\n# ============================================================\n# SECTION 4: Password — revert elastic user to original credential\n# ============================================================\nlog \"[4/6] Reverting elastic user password to original value...\"\n#\n# Observed: password rotated from 'elasticpass' to 'elasticpass-elastic-password-next'.\n#   elastic-password Secret   → current active password (elasticpass-elastic-password-next)\n#   elastic-password-next Secret → same value (rotation staged but never completed cleanly)\n#   elastic-password-prev ConfigMap → original value ('elasticpass')\n# Rollback: restore 'elasticpass' as the active password and clean up rotation artifacts.\n#\necho \"  Changing elastic user password back to original...\"\nes POST \"/_security/user/elastic/_password\" \\\n    \"{\\\"password\\\": \\\"${ORIG_PASS}\\\"}\"\n\necho \"  Patching elastic-password Secret to original value...\"\nkubectl -n \"${NAMESPACE}\" patch secret elastic-password \\\n    -p \"{\\\"data\\\": {\\\"password\\\": \\\"$(printf '%s' \"${ORIG_PASS}\" | base64)\\\"}}\"\n\necho \"  Removing elastic-password-next Secret (rotation artifact)...\"\nkubectl -n \"${NAMESPACE}\" delete secret elastic-password-next --ignore-not-found\n\necho \"  Removing elastic-password-prev ConfigMap (rotation artifact)...\"\nkubectl -n \"${NAMESPACE}\" delete configmap elastic-password-prev --ignore-not-found\n\n# Update runtime variable so remaining API calls still work\nES_PASS=\"${ORIG_PASS}\"\n\n# ============================================================\n# SECTION 5: es-data-new tier — remove all Kubernetes resources\n# ============================================================\nlog \"[5/6] Removing es-data-new expansion tier...\"\n#\n# Observed: StatefulSet es-data-new (2 replicas: es-data-new-0, es-data-new-1)\n#   node.attr.zone=new (custom zone attribute for shard-allocation awareness routing)\n#   node.roles=[data,data_content,data_hot,data_warm,data_cold,ingest,remote_cluster_client]\n#   (master role intentionally excluded — data-only expansion nodes)\n# Both pods are running but continuously failing to join the cluster.\n# Removing them restores the original 3-node all-role topology.\n# Default: no es-data-new StatefulSet, ConfigMap, or headless Service.\n#\necho \"  Scaling down es-data-new to 0 replicas...\"\nkubectl -n \"${NAMESPACE}\" scale statefulset es-data-new --replicas=0 2>/dev/null || \\\n    echo \"  (es-data-new StatefulSet not found — skipping scale-down)\"\n\necho \"  Deleting es-data-new StatefulSet...\"\nkubectl -n \"${NAMESPACE}\" delete statefulset es-data-new --ignore-not-found\n\necho \"  Deleting es-data-new-nodes headless Service...\"\nkubectl -n \"${NAMESPACE}\" delete service es-data-new-nodes --ignore-not-found\n\necho \"  Deleting es-config-new ConfigMap...\"\nkubectl -n \"${NAMESPACE}\" delete configmap es-config-new --ignore-not-found\n\n# ============================================================\n# SECTION 6: MinIO and supporting resources — remove\n# ============================================================\nlog \"[6/6] Removing MinIO deployment and credential Secrets...\"\n#\n# MinIO was deployed as the S3 backend for snapshot storage.\n# Default: no MinIO resources exist in the elasticsearch namespace.\n# Observed resources:\n#   Deployment  minio         (MinIO object store — stores snapshot data)\n#   Service     minio         (ClusterIP, ports 9000/9001)\n#   Job         minio-init    (created es-backups bucket + uploaded seed data)\n#   Secret      minio-root    (minioadmin credentials)\n#   Secret      es-secure-settings  (S3 client credentials for ES keystore)\n#   ConfigMap   es-http-ca    (CA cert used during CA rotation setup)\n#   ConfigMap   es-http-old   (TLS artifacts from prior cert state)\n#\necho \"  Deleting MinIO Deployment...\"\nkubectl -n \"${NAMESPACE}\" delete deployment minio --ignore-not-found\n\necho \"  Deleting MinIO Service...\"\nkubectl -n \"${NAMESPACE}\" delete service minio --ignore-not-found\n\necho \"  Deleting minio-init Job...\"\nkubectl -n \"${NAMESPACE}\" delete job minio-init --ignore-not-found\n\necho \"  Deleting minio-root Secret...\"\nkubectl -n \"${NAMESPACE}\" delete secret minio-root --ignore-not-found\n\necho \"  Deleting es-secure-settings Secret (S3 keystore source)...\"\nkubectl -n \"${NAMESPACE}\" delete secret es-secure-settings --ignore-not-found\n\necho \"  Deleting es-http-ca ConfigMap (CA rotation artifact)...\"\nkubectl -n \"${NAMESPACE}\" delete configmap es-http-ca --ignore-not-found\n\necho \"  Deleting es-http-old ConfigMap (old TLS cert artifact)...\"\nkubectl -n \"${NAMESPACE}\" delete configmap es-http-old --ignore-not-found\n\n# ============================================================\n# POST-ROLLBACK VERIFICATION\n# ============================================================\necho \"\"\necho \"============================================================\"\necho \"  ROLLBACK COMPLETE — run these checks after execution\"\necho \"============================================================\"\necho \"\"\necho \"  1. Cluster health (should be green, 3 nodes):\"\necho \"     kubectl -n ${NAMESPACE} exec ${EXEC_POD} -- \\\\\"\necho \"       curl -sk -u elastic:${ORIG_PASS} ${ES_URL}/_cluster/health?pretty\"\necho \"\"\necho \"  2. No snapshot repositories (should return {}):\"\necho \"     kubectl -n ${NAMESPACE} exec ${EXEC_POD} -- \\\\\"\necho \"       curl -sk -u elastic:${ORIG_PASS} ${ES_URL}/_snapshot\"\necho \"\"\necho \"  3. Cluster settings are empty (persistent={}, transient={}):\"\necho \"     kubectl -n ${NAMESPACE} exec ${EXEC_POD} -- \\\\\"\necho \"       curl -sk -u elastic:${ORIG_PASS} ${ES_URL}/_cluster/settings?flat_settings=true\"\necho \"\"\necho \"  4. Only original 3-node topology:\"\necho \"     kubectl -n ${NAMESPACE} get pods,statefulset,svc\"\necho \"\"\necho \"  5. No custom node attributes (only ml.* built-in attrs):\"\necho \"     kubectl -n ${NAMESPACE} exec ${EXEC_POD} -- \\\\\"\necho \"       curl -sk -u elastic:${ORIG_PASS} ${ES_URL}/_cat/nodeattrs?v\"\necho \"\"\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":3077,"cache_read_input_tokens":59576,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3077},"output_tok