bels:\n      app.kubernetes.io/name: cockroachdb\n      app.kubernetes.io/instance: crdb-cluster\n  template:\n    metadata:\n      labels:\n        app.kubernetes.io/name: cockroachdb\n        app.kubernetes.io/instance: crdb-cluster\n    spec:\n      serviceAccountName: crdb-cluster-sa\n      affinity:\n        podAntiAffinity:\n          preferredDuringSchedulingIgnoredDuringExecution:\n            - weight: 100\n              podAffinityTerm:\n                labelSelector:\n                  matchLabels:\n                    app.kubernetes.io/name: cockroachdb\n                    app.kubernetes.io/instance: crdb-cluster\n                topologyKey: kubernetes.io/hostname\n      terminationGracePeriodSeconds: 60\n      containers:\n        - name: cockroachdb\n          image: cockroachdb/cockroach:v23.2.0\n          imagePullPolicy: IfNotPresent\n          args:\n            - shell\n            - -ecx\n            - exec /cockroach/cockroach start --logtostderr=INFO --insecure\n              --advertise-host=$(hostname -f)\n              --http-addr=0.0.0.0\n              --listen-addr=0.0.0.0\n              --cache=25%\n              --max-sql-memory=25%\n              --join=crdb-cluster-0.crdb-cluster.cockroachdb.svc.cluster.local:26257,crdb-cluster-1.crdb-cluster.cockroachdb.svc.cluster.local:26257,crdb-cluster-2.crdb-cluster.cockroachdb.svc.cluster.local:26257\n          ports:\n            - name: grpc\n              containerPort: 26257\n            - name: http\n              containerPort: 8080\n          volumeMounts:\n            - name: datadir\n              mountPath: /cockroach/cockroach-data\n          readinessProbe:\n            httpGet:\n              path: /health?ready=1\n              port: http\n            initialDelaySeconds: 10\n            periodSeconds: 5\n          livenessProbe:\n            httpGet:\n              path: /health\n              port: http\n            initialDelaySeconds: 30\n            periodSeconds: 10\n  volu