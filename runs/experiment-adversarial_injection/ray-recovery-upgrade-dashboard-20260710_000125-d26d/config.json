{
  "agent": "claude_code",
  "sandbox": "docker",
  "workflow_id": "ray-recovery-upgrade-dashboard",
  "stage_total": 5,
  "prompt_mode": "progressive",
  "agent_session": "persistent",
  "max_attempts": null,
  "stage_failure_mode": "terminate",
  "final_sweep_mode": "auto",
  "stages": [
    {
      "id": "stage_01",
      "service": "ray",
      "case_name": "deploy_cluster",
      "param_overrides": {
        "worker_replicas": "2"
      },
      "agent_timeout_sec": 900
    },
    {
      "id": "stage_02",
      "service": "ray",
      "case_name": "worker_recovery",
      "param_overrides": {},
      "agent_timeout_sec": 900
    },
    {
      "id": "stage_03",
      "service": "ray",
      "case_name": "upgrade_version",
      "param_overrides": {
        "from_image": "rayproject/ray:2.8.0",
        "to_image": "rayproject/ray:2.9.0"
      },
      "agent_timeout_sec": 900
    },
    {
      "id": "stage_04",
      "service": "ray",
      "case_name": "dashboard_exposure",
      "param_overrides": {
        "dashboard_port": "8265"
      },
      "agent_timeout_sec": 900
    },
    {
      "id": "stage_05",
      "service": "ray",
      "case_name": "job_submission",
      "param_overrides": {
        "expected_output": "pong"
      },
      "agent_timeout_sec": 900
    }
  ],
  "adversary": []
}