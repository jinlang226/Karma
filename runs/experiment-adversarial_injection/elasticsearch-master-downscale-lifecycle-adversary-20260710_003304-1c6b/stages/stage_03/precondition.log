[precondition:es_env_ready:preconditionUnits[0] 'es_env_ready':probe] $ /bin/sh -c 'kubectl -n elasticsearch get sts es-cluster >/dev/null 2>&1 || kubectl -n elasticsearch get pods --field-selector=status.phase=Running -o name 2>/dev/null | grep -q .'

[precondition:voting_drift_ready:preconditionUnits[1] 'voting_drift_ready':probe] $ /bin/sh -c 'r=$(kubectl -n elasticsearch get sts es-cluster -o jsonpath="{.spec.replicas}" 2>/dev/null); [ "$r" = "1" ] || exit 1; pw=$(kubectl -n elasticsearch get secret elastic-password -o jsonpath="{.data.password}" 2>/dev/null | base64 -d 2>/dev/null); A=""; [ -n "$pw" ] && A="-u elastic:$pw"; S=https; kubectl -n elasticsearch exec curl-test -- curl -sk $A --max-time 5 "https://es-http.elasticsearch.svc:9200/" >/dev/null 2>&1 || S=http; H=$(kubectl -n elasticsearch exec curl-test -- curl -sk $A --max-time 5 "$S://es-http.elasticsearch.svc:9200/_cluster/health" 2>/dev/null); echo "$H" | grep -q "\"status\"" || exit 0; kubectl -n elasticsearch exec curl-test -- curl -sk $A --max-time 5 "$S://es-http.elasticsearch.svc:9200/_cluster/settings" 2>/dev/null | grep -q "\"auto_shrink_voting_configuration\":\"false\""'

[precondition:voting_drift_ready:preconditionUnits[1] 'voting_drift_ready':apply] $ /bin/sh -c 'pw=$(kubectl -n elasticsearch get secret elastic-password -o jsonpath="{.data.password}" 2>/dev/null | base64 -d 2>/dev/null); A=""; [ -n "$pw" ] && A="-u elastic:$pw"; S=https; kubectl -n elasticsearch exec curl-test -- curl -sk $A --max-time 5 "https://es-http.elasticsearch.svc:9200/" >/dev/null 2>&1 || S=http; kubectl -n elasticsearch exec curl-test -- curl -sk $A --max-time 5 "$S://es-http.elasticsearch.svc:9200/_cluster/health" 2>/dev/null | grep -q "\"status\"" || exit 0; kubectl -n elasticsearch exec curl-test -- curl -sk $A -XPUT "$S://es-http.elasticsearch.svc:9200/_cluster/settings" -H "Content-Type: application/json" -d "{\"persistent\":{\"cluster.auto_shrink_voting_configuration\":false}}" >/dev/null 2>&1; true'

[precondition:voting_drift_ready:preconditionUnits[1] 'voting_drift_ready':apply] $ /bin/sh -c 'kubectl -n elasticsearch get sts es-cluster >/dev/null 2>&1 && kubectl -n elasticsearch scale sts/es-cluster --replicas=1 || true'
statefulset.apps/es-cluster scaled

[precondition:voting_drift_ready:preconditionUnits[1] 'voting_drift_ready':apply] $ /bin/sh -c 'kubectl -n elasticsearch rollout status sts/es-cluster --timeout=180s || true'
partitioned roll out complete: 1 new pods have been updated...

[precondition:voting_drift_ready:preconditionUnits[1] 'voting_drift_ready':verify] $ /bin/sh -c 'pw=$(kubectl -n elasticsearch get secret elastic-password -o jsonpath="{.data.password}" 2>/dev/null | base64 -d 2>/dev/null); A=""; [ -n "$pw" ] && A="-u elastic:$pw"; S=https; kubectl -n elasticsearch exec curl-test -- curl -sk $A --max-time 5 "https://es-http.elasticsearch.svc:9200/" >/dev/null 2>&1 || S=http; kubectl -n elasticsearch exec curl-test -- curl -sk $A --max-time 5 "$S://es-http.elasticsearch.svc:9200/_cluster/health" 2>/dev/null | grep -q "\"status\"" || exit 0; kubectl -n elasticsearch exec curl-test -- curl -sk $A --max-time 5 "$S://es-http.elasticsearch.svc:9200/_cluster/settings" 2>/dev/null | grep -q "\"auto_shrink_voting_configuration\":\"false\""'

