\n      labels:\n        app: elasticsearch\n    spec:\n      initContainers:\n        - name: fix-permissions\n          image: docker.elastic.co/elasticsearch/elasticsearch:8.11.0\n          command: [\"sh\", \"-c\", \"chown -R 1000:1000 /usr/share/elasticsearch/data\"]\n          securityContext:\n            runAsUser: 0\n          volumeMounts:\n            - name: data\n              mountPath: /usr/share/elasticsearch/data\n        - name: increase-vm-max-map-count\n          image: docker.elastic.co/elasticsearch/elasticsearch:8.11.0\n          command: [\"sysctl\", \"-w\", \"vm.max_map_count=262144\"]\n          securityContext:\n            privileged: true\n            runAsUser: 0\n      containers:\n        - name: elasticsearch\n          image: docker.elastic.co/elasticsearch/elasticsearch:8.11.0\n          resources:\n            requests:\n              cpu: \"500m\"\n              memory: \"2Gi\"\n            limits:\n              cpu: \"2\"\n              memory: \"2Gi\"\n          env:\n            - name: node.name\n              valueFrom:\n                fieldRef:\n                  fieldPath: metadata.name\n            - name: ELASTIC_PASSWORD\n              valueFrom:\n                secretKeyRef:\n                  name: elastic-password\n                  key: password\n            - name: ES_JAVA_OPTS\n              value: \"-Xms1g -Xmx1g\"\n          ports:\n            - name: http\n              containerPort: 9200\n            - name: transport\n              containerPort: 9300\n          volumeMounts:\n            - name: data\n              mountPath: /usr/share/elasticsearch/data\n            - name: es-config\n              mountPath: /usr/share/elasticsearch/config/elasticsearch.yml\n              subPath: elasticsearch.yml\n            - name: http-certs\n              mountPath: /usr/share/elasticsearch/config/http-certs\n              readOnly: true\n            - name: transport-certs\n              mountPath: /usr/share/elasticsearch/config/transport-certs\n              readOnly: true\n          readinessProbe:\n            exec:\n              command:\n                - bash\n                - -c\n                - >\n                  curl -s -k -u elastic:${ELASTIC_PASSWORD}\n                  https://127.0.0.1:9200/_cluster/health?local=true\n                  -o /dev/null -w '%{http_code}' | grep -qE '200|503'\n            initialDelaySeconds: 20\n            periodSeconds: 10\n            timeoutSeconds: 5\n            failureThreshold: 10\n      volumes:\n        - name: es-config\n          configMap:\n            name: es-config\n        - name: http-certs\n          secret:\n            secretName: es-http-tls\n        - name: transport-certs\n          secret:\n            secretName: es-transport-certs\n  volumeClaimTemplates:\n    - metadata:\n        name: data\n      spec:\n        accessModes: [\"ReadWriteOnce\"]\n        storageClassName: standard\n        resources:\n          requests:\n            storage: 5Gi\n","structuredPatch":[{"oldStart":19,"oldLines":7,"newStart":19,"newLines":7,"lines":["     spec:","       initContainers:","         - name: fix-permissions","-          image: docker.elastic.co/elasticsearch/elasticsearch:8.11.0","+          image: busybox:1.36","           command: [\"sh\", \"-c\", \"chown -R 1000:1000 /usr/share/elasticsearch/data\"]","           securityContext:","             runAsUser: 0"]},{"oldStart":27,"oldLines":7,"newStart":27,"newLines":7,"lines":["             - name: data","               mountPath: /usr/share/elasticsearch/data","         - name: increase-vm-max-map-count","-          image: docker.elastic.co/elasticsearch/elasticsearch:8.11.0","+          image: busybox:1.36","           command: [\"sysctl\", \"-w\", \"vm.max_map_count=262144\"]","           securityContext:","             privileged: true"]}],"userModified":false,"replaceAll":false}}
