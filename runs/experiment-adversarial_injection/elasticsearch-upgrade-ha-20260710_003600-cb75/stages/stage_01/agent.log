: http\n              containerPort: 9200\n            - name: transport\n              containerPort: 9300\n          volumeMounts:\n            - name: data\n              mountPath: /usr/share/elasticsearch/data\n            - name: es-config\n              mountPath: /usr/share/elasticsearch/config/elasticsearch.yml\n              subPath: elasticsearch.yml\n            - name: http-certs\n              mountPath: /usr/share/elasticsearch/config/http-certs\n              readOnly: true\n            - name: transport-certs\n              mountPath: /usr/share/elasticsearch/config/transport-certs\n              readOnly: true\n          readinessProbe:\n            exec:\n              command:\n                - bash\n                - -c\n                - >\n                  curl -s -k -u elastic:${ELASTIC_PASSWORD}\n                  https://127.0.0.1:9200/_cluster/health?local=true\n                  -o /dev/null -w '%{http_code}' | grep -qE '200|503'\n            initialDelaySeconds: 20\n            periodSeconds: 10\n            timeoutSeconds: 5\n            failureThreshold: 10\n      volumes:\n        - name: es-config\n          configMap:\n            name: es-config\n        - name: http-certs\n          secret:\n            secretName: es-http-tls\n        - name: transport-certs\n          secret:\n            secretName: es-transport-certs\n  volumeClaimTemplates:\n    - metadata:\n        name: data\n      spec:\n        accessModes: [\"ReadWriteOnce\"]\n        storageClassName: standard\n        resources:\n          requests:\n            storage: 5Gi\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":603,"cache_read_input_tokens":41292,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":603},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_to