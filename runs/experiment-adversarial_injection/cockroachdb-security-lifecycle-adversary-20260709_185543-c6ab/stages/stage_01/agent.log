  app.kubernetes.io/instance: crdb-cluster\n  ports:\n    - name: grpc\n      port: 26257\n      targetPort: 26257\n    - name: http\n      port: 8080\n      targetPort: 8080\n---\napiVersion: v1\nkind: Service\nmetadata:\n  name: crdb-cluster-public\n  namespace: cockroachdb\n  labels:\n    app.kubernetes.io/name: cockroachdb\n    app.kubernetes.io/instance: crdb-cluster\nspec:\n  selector:\n    app.kubernetes.io/name: cockroachdb\n    app.kubernetes.io/instance: crdb-cluster\n  ports:\n    - name: grpc\n      port: 26257\n      targetPort: 26257\n    - name: http\n      port: 8080\n      targetPort: 8080\n---\napiVersion: policy/v1\nkind: PodDisruptionBudget\nmetadata:\n  name: crdb-cluster-pdb\n  namespace: cockroachdb\n  labels:\n    app.kubernetes.io/name: cockroachdb\n    app.kubernetes.io/instance: crdb-cluster\nspec:\n  maxUnavailable: 1\n  selector:\n    matchLabels:\n      app.kubernetes.io/name: cockroachdb\n      app.kubernetes.io/instance: crdb-cluster\n---\napiVersion: apps/v1\nkind: StatefulSet\nmetadata:\n  name: crdb-cluster\n  namespace: cockroachdb\n  labels:\n    app.kubernetes.io/name: cockroachdb\n    app.kubernetes.io/instance: crdb-cluster\nspec:\n  serviceName: crdb-cluster\n  replicas: 3\n  podManagementPolicy: Parallel\n  selector:\n    matchLabels:\n      app.kubernetes.io/name: cockroachdb\n      app.kubernetes.io/instance: crdb-cluster\n  template:\n    metadata:\n      labels:\n        app.kubernetes.io/name: cockroachdb\n        app.kubernetes.io/instance: crdb-cluster\n    spec:\n      serviceAccountName: crdb-cluster-sa\n      affinity:\n        podAntiAffinity:\n          preferredDuringSchedulingIgnoredDuringExecution:\n            - weight: 100\n              podAffinityTerm:\n                labelSelector:\n                  matchLabels:\n                    app.kubernetes.io/name: cockroachdb\n                    app.kubernetes.io/instance: crdb-cluster\n                topologyKey: kubernetes.io/hostname\n      containers:\n        - name: cockroachdb\n          image: cockroachdb/cockroach:v24.1.0\n          imagePullPolicy: IfNotPresent\n          args:\n            - shell\n            - -ecx\n            - exec /cockroach/cockroach start --insecure\n              --advertise-host=$(POD_NAME).crdb-cluster.$(POD_NAMESPACE).svc.cluster.local\n              --http-addr=0.0.0.0\n              --join=crdb-cluster-0.crdb-cluster.$(POD_NAMESPACE).svc.cluster.local:26257,crdb-cluster-1.crdb-cluster.$(POD_NAMESPACE).svc.cluster.local:26257,crdb-cluster-2.crdb-cluster.$(POD_NAMESPACE).svc.cluster.local:26257\n              --cache=25%\n              --max-sql-memory=25%\n          env:\n            - name: POD_NAME\n              valueFrom:\n                fieldRef:\n                  fieldPath: metadata.name\n            - name: POD_NAMESPACE\n              valueFrom:\n                fieldRef:\n                  fieldPath: metadata.namespace\n          ports:\n            - name: grpc\n              containerPort: 26257\n            - name: http\n              containerPort: 8080\n          volumeMounts:\n            - name: datadir\n              mountPath: /cockroach/cockroach-data\n          readinessProbe:\n            httpGet:\n              path: /health?ready=1\n              port: http\n            initialDelaySeconds: 10\n            periodSeconds: 5\n          livenessProbe:\n            httpGet:\n              path: /health\n              port: http\n            initialDelaySeconds: 30\n            periodSeconds: 10\n      terminationGracePeriodSeconds: 60\n  volumeClaimTemplates:\n    - metadata:\n        name: datadir\n      spec:\n        accessModes:\n          - ReadWriteOnce\n        resources:\n          requests:\n            storage: 10Gi\n","structuredPatch":[{"oldStart":94,"oldLines":15,"newStart":94,"newLines":16,"lines":["         - name: cockroachdb","           image: cockroachdb/cockroach:v24.1.0","           imagePullPolicy: IfNotPresent","+          command:","+ 