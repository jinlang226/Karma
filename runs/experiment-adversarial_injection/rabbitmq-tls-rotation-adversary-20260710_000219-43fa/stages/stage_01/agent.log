{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01PoyPrsU5MS42aaUJ8HCs6u","type":"tool_result","content":"=== SETUP JOB LOGS ===\n=== ALL POLICIES (all vhosts) ===\nListing policies for vhost \"/\" ...\n\n=== CONFIGMAPS ===\nNAME               DATA   AGE\nkube-root-ca.crt   1      5m55s\nrabbitmq-config    2      5m46s\n=== JOBS ===\n          batch.kubernetes.io/job-name: rabbitmq-setup\n          controller-uid: 99efd321-ee4f-4322-b02a-74311614b6f9\n          job-name: rabbitmq-setup\n      spec:\n        containers:\n        - command:\n          - /bin/sh\n          - -c\n          - |\n            set -e\n            base=\"http://rabbitmq:15672/api\"\n            auth=\"${RABBITMQ_ADMIN_USER}:${RABBITMQ_ADMIN_PASS}\"\n            for i in $(seq 1 60); do\n              if curl -s -u \"$auth\" \"$base/overview\" >/dev/null; then\n                break\n              fi\n              sleep 2\n            done\n            if ! curl -s -u \"$auth\" \"$base/overview\" >/dev/null; then\n              echo \"rabbitmq-setup: management API not ready\"\n              exit 1\n            fi\n            curl -s -u \"$auth\" -H \"content-type: application/json\" \\\n              -XPUT \"$base/vhosts/%2Fapp\" -d '{}' >/dev/null\n            curl -s -u \"$auth\" -H \"content-type: application/json\" \\\n              -XPUT \"$base/users/${APP_USER}\" \\\n              -d \"{\\\"password\\\":\\\"${APP_PASS}\\\",\\\"tags\\\":\\\"management\\\"}\" >/dev/null\n            curl -s -u \"$auth\" -H \"content-type: application/json\" \\\n              -XPUT \"$base/permissions/%2Fapp/${APP_USER}\" \\\n              -d '{\"configure\":\"\",\"write\":\".*\",\"read\":\".*\"}' >/dev/null\n            curl -s -u \"$auth\" -H \"content-type: application/json\" \\\n              -XPUT \"$base/policies/%2Fapp/force-quorum\" \\\n              -d '{\"pattern\":\".*\",\"definition\":{\"queue-type\":\"quorum\"},\"priority\":0,\"apply-to\":\"queues\"}' >/dev/null\n            curl -s -u \"$auth\" -H \"content-type: application/json\" \\\n              -XPUT \"$base/policies/%2F/force-quorum\" \\\n              -d '{\"pattern\":\".*\",\"definition\":{\"queue-type\":\"quorum\"},\"priority\":0,\"apply-to\":\"queues\"}' >/dev/null\n          env:\n          - name: RABBITMQ_ADMIN_USER\n            valueFrom:\n              secretKeyRef:\n                key: username\n                name: rabbitmq-admin\n          - name: RABBITMQ_ADMIN_PASS\n            valueFrom:\n              secretKeyRef:\n                key: password\n                name: rabbitmq-admin\n          - name: APP_USER\n            valueFrom:\n              secretKeyRef:\n                key: username\n                name: rabbitmq-app\n          - name: APP_PASS\n            valueFrom:\n              secretKeyRef:\n                key: password\n                name: rabbitmq-app\n          image: curlimages/curl:8.6.0\n          imagePullPolicy: IfNotPresent\n          name: setup\n          resources: {}\n          terminationMessagePath: /dev/termination-log\n          terminationMessagePolicy: File\n        dnsPolicy: ClusterFirst\n        restartPolicy: OnFailure\n        schedulerName: default-scheduler","is_error":false}]},"parent_tool_use_id":null,"session_id":"eac9f0e3-952d-4d9f-bdcc-9e2c94fc14f7","uuid":"84c2698d-9f47-4854-b766-eb891f6b2b75","timestamp":"2026-07-10T00:08:15.296Z","tool_use_result":{"stdout":"=== SETUP JOB LOGS ===\n=== ALL POLICIES (all vhosts) ===\nListing policies for vhost \"/\" ...\n\n=== CONFIGMAPS ===\nNAME               DATA   AGE\nkube-root-ca.crt   1      5m55s\nrabbitmq-config    2      5m46s\n=== JOBS ===\n          batch.kubernetes.io/job-name: rabbitmq-setup\n          controller-uid: 99efd321-ee4f-4322-b02a-74311614b6f9\n          job-name: rabbitmq-setup\n      spec:\n        containers:\n        - command:\n          - /bin/sh\n          - -c\n          - |\n            set -e\n            base=\"http://rabbitmq:156