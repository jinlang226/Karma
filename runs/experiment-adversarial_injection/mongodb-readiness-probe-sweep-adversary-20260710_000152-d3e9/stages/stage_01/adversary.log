$ kubectl -n mongodb get statefulset mongodb-replica
NAME              READY   AGE
mongodb-replica   0/3     3m32s

$ kubectl -n mongodb patch statefulset mongodb-replica --type=json -p='[{"op":"replace","path":"/spec/template/spec/containers/0/readinessProbe/timeoutSeconds","value":1},{"op":"replace","path":"/spec/template/spec/containers/0/readinessProbe/failureThreshold","value":1}]'
statefulset.apps/mongodb-replica patched

$ kubectl -n mongodb delete pod -l app=mongodb-replica --ignore-not-found
pod "mongodb-replica-0" deleted
pod "mongodb-replica-1" deleted
pod "mongodb-replica-2" deleted

$ /bin/sh -c "test \"$(kubectl -n mongodb get statefulset mongodb-replica -o jsonpath='{.spec.template.spec.containers[0].readinessProbe.timeoutSeconds}')\" = '1'"

