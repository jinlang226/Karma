{
  "agent": "claude_code",
  "sandbox": "docker",
  "workflow_id": "cockroachdb-incident-then-upgrade",
  "stage_total": 5,
  "prompt_mode": "progressive",
  "agent_session": "persistent",
  "max_attempts": null,
  "stage_failure_mode": "terminate",
  "final_sweep_mode": "auto",
  "stages": [
    {
      "id": "stage_01",
      "service": "cockroachdb",
      "case_name": "health-check-recovery",
      "param_overrides": {},
      "agent_timeout_sec": 900
    },
    {
      "id": "stage_02",
      "service": "cockroachdb",
      "case_name": "partitioned-update",
      "param_overrides": {
        "to_version": "24.1.1"
      },
      "agent_timeout_sec": 900
    },
    {
      "id": "stage_03",
      "service": "cockroachdb",
      "case_name": "major-upgrade-finalize",
      "param_overrides": {
        "from_version": "24.1",
        "to_version": "24.2.0"
      },
      "agent_timeout_sec": 900
    },
    {
      "id": "stage_04",
      "service": "cockroachdb",
      "case_name": "version-check",
      "param_overrides": {
        "from_version": "24.1",
        "to_version": "24.2.0"
      },
      "agent_timeout_sec": 900
    },
    {
      "id": "stage_05",
      "service": "cockroachdb",
      "case_name": "cluster-settings",
      "param_overrides": {
        "setting_name": "kv.snapshot_rebalance.max_rate",
        "setting_value": "128MiB"
      },
      "agent_timeout_sec": 900
    }
  ],
  "adversary": []
}