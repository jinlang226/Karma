s were lost (observed a drop from ~210 to a low count with no error logged — likely related to the classic queue's v1→v2 store conversion racing with continuous publishes). The queue itself, its data directory, and vhost were never destroyed and message flow resumed immediately, satisfying \"queue still exists with messages,\" but it wasn't a lossless transition for every message in flight at that exact moment.","stop_reason":"end_turn","session_id":"3fb2359b-9b20-4640-bc08-db4382155585","total_cost_usd":7.052986799999999,"usage":{"input_tokens":7952,"cache_creation_input_tokens":116657,"cache_read_input_tokens":17978346,"output_tokens":62379,"server_tool_use":{"web_search_requests":0,"web_fetch_requests":0},"service_tier":"standard","cache_creation":{"ephemeral_1h_input_tokens":116657,"ephemeral_5m_input_tokens":0},"inference_geo":"not_available","iterations":[{"input_tokens":2,"output_tokens":823,"cache_read_input_tokens":210116,"cache_creation_input_tokens":88,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":88},"type":"message"}],"speed":"standard"},"modelUsage":{"claude-sonnet-5":{"inputTokens":7952,"outputTokens":62379,"cacheReadInputTokens":17978346,"cacheCreationInputTokens":116657,"webSearchRequests":0,"costUSD":7.052986799999999,"contextWindow":1000000,"maxOutputTokens":64000}},"permission_denials":[],"terminal_reason":"completed","fast_mode_state":"off","uuid":"e6ebe84b-e00a-4a90-9e57-92e9722cf956"}
