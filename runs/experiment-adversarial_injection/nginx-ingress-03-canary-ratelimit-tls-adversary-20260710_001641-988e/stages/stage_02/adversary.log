$ kubectl -n demo get ingress rate-api
NAME       CLASS   HOSTS              ADDRESS   PORTS   AGE
rate-api   nginx   rate.example.com             80      5s

$ kubectl -n demo annotate ingress rate-api nginx.ingress.kubernetes.io/limit-rps- --overwrite
ingress.networking.k8s.io/rate-api annotated

$ /bin/sh -c 'key=$(printf "%s" "nginx.ingress.kubernetes.io/limit-rps" | sed "s/\./\\\\./g"); [ -z "$(kubectl -n demo get ingress rate-api -o jsonpath="{.metadata.annotations.$key}")" ]'


