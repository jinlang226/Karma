e: spark\n      restartPolicy: Never\n      containers:\n        - name: spark-skew\n          image: apache/spark:3.5.3\n          env:\n            - name: STRATEGY\n              value: aqe\n          command:\n            - /bin/bash\n            - -c\n            - |\n              set -e\n              export SPARK_LOCAL_IP=\\$(hostname -i)\n              echo \"STRATEGY=aqe (Adaptive Query Execution auto-handles skew)\"\n              echo \"$AQE_B64\" | base64 -d > /tmp/skew_aqe.py\n              /opt/spark/bin/spark-submit \\\\\n                --master local[2] \\\\\n                --conf spark.sql.adaptive.enabled=true \\\\\n                --conf spark.sql.adaptive.skewJoin.enabled=true \\\\\n                --conf spark.sql.adaptive.coalescePartitions.enabled=true \\\\\n                --conf spark.sql.adaptive.skewJoin.skewedPartitionFactor=2 \\\\\n                --conf spark.sql.adaptive.skewJoin.skewedPartitionThresholdInBytes=1MB \\\\\n                /tmp/skew_aqe.py\n              echo \"spark_skew_aqe_complete\"\n          resources:\n            requests:\n              cpu: \"200m\"\n              memory: \"256Mi\"\n            limits:\n              cpu: \"500m\"\n              memory: \"512Mi\"\nEOF\necho \"written\"\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":1869,"cache_read_input_tokens":84524,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1869},"output_tokens":5,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"0b99a0aa-7e5e-4a53-a504-46378f5cf2ed","uuid":"37a71dcb-4f4c-42a0-b032-3c90b5b0ca39","request_id":"req_011CcsYCXzt8xsk3DekDc6W8"}
