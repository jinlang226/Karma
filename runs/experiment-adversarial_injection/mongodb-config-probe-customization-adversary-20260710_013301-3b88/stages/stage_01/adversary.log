$ kubectl -n mongodb get configmap mongod-config
NAME            DATA   AGE
mongod-config   1      5m49s

$ /bin/sh -c '
conf=$(kubectl -n mongodb get configmap mongod-config -o jsonpath="{.data.mongod\.conf}" 2>/dev/null)
if [ -n "$conf" ]; then
  f=$(mktemp)
  printf "%s" "$conf" > "$f"
  kubectl -n mongodb create configmap mongod-config-adv-backup \
    --from-file=mongod.conf="$f" \
    --dry-run=client -o yaml | kubectl -n mongodb apply -f -
  rm -f "$f"
fi
'

configmap/mongod-config-adv-backup created

$ kubectl -n mongodb patch configmap mongod-config --type=json -p='[{"op":"remove","path":"/data/mongod.conf"}]'
configmap/mongod-config patched

$ /bin/sh -c "! kubectl -n mongodb get configmap mongod-config -o jsonpath='{.data.mongod\.conf}' 2>/dev/null | grep -q systemLog"

