$ /bin/sh -c 'NS=elasticsearch; POD=curl-test; H=es-http.elasticsearch.svc:9200; PW=$(kubectl -n "$NS" get secret elastic-password -o jsonpath="{.data.password}" | base64 -d); A=""; [ -n "$PW" ] && A="-u elastic:$PW"; S=https; kubectl -n "$NS" exec "$POD" -- curl -s -k -o /dev/null $A "https://$H/" || S=http; kubectl -n "$NS" exec "$POD" -- curl -s -k $A "$S://$H/_cluster/settings" | grep -q "\"enable\":\"none\""'

