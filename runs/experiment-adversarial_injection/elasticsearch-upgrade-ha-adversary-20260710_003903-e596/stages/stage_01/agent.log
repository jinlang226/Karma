r:\n    app: elasticsearch\n  ports:\n    - name: https\n      port: 9200\n      targetPort: 9200\n---\napiVersion: policy/v1\nkind: PodDisruptionBudget\nmetadata:\n  name: es-pdb\n  namespace: elasticsearch\nspec:\n  minAvailable: 2\n  selector:\n    matchLabels:\n      app: elasticsearch\n---\napiVersion: apps/v1\nkind: StatefulSet\nmetadata:\n  name: es\n  namespace: elasticsearch\n  labels:\n    app: elasticsearch\nspec:\n  serviceName: es-transport\n  replicas: 3\n  podManagementPolicy: Parallel\n  selector:\n    matchLabels:\n      app: elasticsearch\n  template:\n    metadata:\n      labels:\n        app: elasticsearch\n    spec:\n      initContainers:\n        - name: set-max-map-count\n          image: docker.elastic.co/elasticsearch/elasticsearch:8.11.0\n          command: [\"sysctl\", \"-w\", \"vm.max_map_count=262144\"]\n          securityContext:\n            privileged: true\n            runAsUser: 0\n        - name: copy-config\n          image: docker.elastic.co/elasticsearch/elasticsearch:8.11.0\n          command:\n            - sh\n            - -c\n            - \"cp -a /usr/share/elasticsearch/config/. /es-config/ && chown -R 1000:0 /es-config\"\n          volumeMounts:\n            - name: es-config-dir\n              mountPath: /es-config\n        - name: init-keystore\n          image: docker.elastic.co/elasticsearch/elasticsearch:8.11.0\n          command:\n            - sh\n            - -c\n            - |\n              set -e\n              export ES_PATH_CONF=/usr/share/elasticsearch/config\n              if [ ! -f \"$ES_PATH_CONF/elasticsearch.keystore\" ]; then\n                elasticsearch-keystore create\n              fi\n              elasticsearch-keystore add -f -x bootstrap.password --stdin < /mnt/elastic-password/password\n              chown -R 1000:0 \"$ES_PATH_CONF\"\n          volumeMounts:\n            - name: es-config-dir\n              mountPath: /usr/share/elasticsearch/config\n            - name: elastic-password\n              mountPath: /mnt/elastic-password\n              readOnly: true\n      containers:\n        - name: elasticsearch\n          image: docker.elastic.co/elasticsearch/elasticsearch:8.11.0\n          env:\n            - name: ES_JAVA_OPTS\n              value: \"-Xms1g -Xmx1g\"\n          ports:\n            - name: http\n              containerPort: 9200\n            - name: transport\n              containerPort: 9300\n          resources:\n            requests:\n              cpu: \"500m\"\n              memory: \"2Gi\"\n            limits:\n              cpu: \"2\"\n              memory: \"2Gi\"\n          volumeMounts:\n            - name: es-config-dir\n              mountPath: /usr/share/elasticsearch/config\n            - name: es-config-file\n              mountPath: /usr/share/elasticsearch/config/elasticsearch.yml\n              subPath: elasticsearch.yml\n            - name: es-certs\n              mountPath: /usr/share/elasticsearch/config/certs\n              readOnly: true\n            - name: es-data\n              mountPath: /usr/share/elasticsearch/data\n          readinessProbe:\n            tcpSocket:\n              port: 9200\n            initialDelaySeconds: 20\n            periodSeconds: 10\n            failureThreshold: 12\n          livenessProbe:\n            tcpSocket:\n              port: 9200\n            initialDelaySeconds: 60\n            periodSeconds: 20\n            failureThreshold: 6\n      volumes:\n        - name: es-config-dir\n          emptyDir: {}\n        - name: es-config-file\n          configMap:\n            name: es-config\n        - name: es-certs\n          secret:\n            secretName: es-http-tls\n        - name: elastic-password\n          secret:\n            secretName: elastic-password\n  volumeClaimTemplates:\n    - metadata:\n        name: es-data\n      spec:\n        accessModes: [\"ReadWriteOnce\"]\n        storageClassName: standard\n        resources:\n          requests:\n            storage: 5Gi\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":3562,"cache_read_input_tokens":43278,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":3562},"output_tokens":3,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"a34340d1-dcae-4c45-9625-2e89b82d9d75","uuid":"c80df9ba-6c20-4e64-b431-9a94948bf35d","request_id":"req_011CcsSt1D8bDs3YMnaCbWcz"}
