/elastic-password/password\n              chown -R 1000:0 \"$ES_PATH_CONF\"\n          volumeMounts:\n            - name: es-config-dir\n              mountPath: /usr/share/elasticsearch/config\n            - name: elastic-password\n              mountPath: /mnt/elastic-password\n              readOnly: true\n      containers:\n        - name: elasticsearch\n          image: docker.elastic.co/elasticsearch/elasticsearch:8.11.0\n          env:\n            - name: ES_JAVA_OPTS\n              value: \"-Xms1g -Xmx1g\"\n          ports:\n            - name: http\n              containerPort: 9200\n            - name: transport\n              containerPort: 9300\n          resources:\n            requests:\n              cpu: \"500m\"\n              memory: \"2Gi\"\n            limits:\n              cpu: \"2\"\n              memory: \"2Gi\"\n          volumeMounts:\n            - name: es-config-dir\n              mountPath: /usr/share/elasticsearch/config\n            - name: es-config-file\n              mountPath: /usr/share/elasticsearch/config/elasticsearch.yml\n              subPath: elasticsearch.yml\n            - name: es-certs\n              mountPath: /usr/share/elasticsearch/config/certs\n              readOnly: true\n            - name: es-data\n              mountPath: /usr/share/elasticsearch/data\n          readinessProbe:\n            tcpSocket:\n              port: 9200\n            initialDelaySeconds: 20\n            periodSeconds: 10\n            failureThreshold: 12\n          livenessProbe:\n            tcpSocket:\n              port: 9200\n            initialDelaySeconds: 60\n            periodSeconds: 20\n            failureThreshold: 6\n      volumes:\n        - name: es-config-dir\n          emptyDir: {}\n        - name: es-config-file\n          configMap:\n            name: es-config\n        - name: es-certs\n          secret:\n            secretName: es-http-tls\n        - name: elastic-password\n          secret:\n            secretName: elastic-password\n  volumeClaimTemplates:\n    - metadata:\n        name: es-data\n      spec:\n        accessModes: [\"ReadWriteOnce\"]\n        storageClassName: standard\n        resources:\n          requests:\n            storage: 5Gi\n","structuredPatch":[],"originalFile":null,"userModified":false}}
