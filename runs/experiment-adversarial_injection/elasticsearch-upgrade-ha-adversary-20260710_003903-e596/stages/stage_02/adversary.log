$ kubectl -n elasticsearch get pod curl-test
NAME        READY   STATUS    RESTARTS   AGE
curl-test   1/1     Running   0          12m

$ /bin/sh -c 'NS=elasticsearch; POD=curl-test; H=es-http.elasticsearch.svc:9200; PW=$(kubectl -n "$NS" get secret elastic-password -o jsonpath="{.data.password}" | base64 -d); A=""; [ -n "$PW" ] && A="-u elastic:$PW"; S=https; kubectl -n "$NS" exec "$POD" -- curl -s -k -o /dev/null $A "https://$H/" || S=http; kubectl -n "$NS" exec "$POD" -- curl -s -k $A -XPUT "$S://$H/_cluster/settings" -H "Content-Type: application/json" -d "{\"persistent\":{\"cluster.routing.allocation.enable\":\"none\"}}"'
{"acknowledged":true,"persistent":{"cluster":{"routing":{"allocation":{"enable":"none"}}}},"transient":{}}
$ /bin/sh -c 'NS=elasticsearch; POD=curl-test; H=es-http.elasticsearch.svc:9200; PW=$(kubectl -n "$NS" get secret elastic-password -o jsonpath="{.data.password}" | base64 -d); A=""; [ -n "$PW" ] && A="-u elastic:$PW"; S=https; kubectl -n "$NS" exec "$POD" -- curl -s -k -o /dev/null $A "https://$H/" || S=http; kubectl -n "$NS" exec "$POD" -- curl -s -k $A "$S://$H/_cluster/settings" | grep -q "\"enable\":\"none\""'

