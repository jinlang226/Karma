$ kubectl -n elasticsearch get secret elastic-password
NAME               TYPE     DATA   AGE
elastic-password   Opaque   1      1s

$ test "$(kubectl -n elasticsearch get secret elastic-password -o jsonpath='{.data.password}' | base64 -d)" = 'CORRUPTED_BY_ADVERSARY' || kubectl -n elasticsearch create secret generic elastic-password-adv-backup --from-literal=password="$(kubectl -n elasticsearch get secret elastic-password -o jsonpath='{.data.password}' | base64 -d)" --dry-run=client -o yaml | kubectl -n elasticsearch apply -f -
secret/elastic-password-adv-backup created

$ kubectl -n elasticsearch patch secret elastic-password --type=json -p '[{"op":"replace","path":"/stringData","value":{"password":"CORRUPTED_BY_ADVERSARY"}}]'
secret/elastic-password patched

$ test "$(kubectl -n elasticsearch get secret elastic-password -o jsonpath='{.data.password}' | base64 -d)" = 'CORRUPTED_BY_ADVERSARY'

