{
  "agent": "claude_code",
  "sandbox": "docker",
  "workflow_id": "ray-deploy-dashboard-adversary",
  "stage_total": 3,
  "prompt_mode": "progressive",
  "agent_session": "persistent",
  "max_attempts": null,
  "stage_failure_mode": "terminate",
  "final_sweep_mode": "auto",
  "stages": [
    {
      "id": "stage_01",
      "service": "ray",
      "case_name": "deploy_cluster",
      "param_overrides": {
        "worker_replicas": "2"
      },
      "agent_timeout_sec": 900
    },
    {
      "id": "stage_02",
      "service": "ray",
      "case_name": "dashboard_exposure",
      "param_overrides": {
        "dashboard_port": "8265"
      },
      "agent_timeout_sec": 900
    },
    {
      "id": "stage_03",
      "service": "ray",
      "case_name": "scale_workers",
      "param_overrides": {
        "source_worker_replicas": "2",
        "target_worker_replicas": "3"
      },
      "agent_timeout_sec": 900
    }
  ],
  "adversary": [
    {
      "scenario": "delete_head_service",
      "inject_at_stage": "stage_02",
      "lift_at_stage": "stage_03",
      "param_overrides": {}
    }
  ]
}