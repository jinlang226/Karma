{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017c62z9wAvD7eU1nXbYfawp","type":"tool_result","content":"1\t\"\"\"\n2\tAdversary injection lifecycle: deploy, lift, and report.\n3\t\n4\tOwns the runtime-facing adversary API called by ``runtime.case`` at two\n5\tpoints in the stage execution lifecycle:\n6\t\n7\t- After preconditions complete: :func:`deploy` runs the deploy unit to\n8\t  plant the fault condition in the cluster.\n9\t- During cleanup (before namespace teardown): :func:`lift` runs the lift\n10\t  unit to remove the fault condition.\n11\t- After lift: :func:`report` writes a structured result to disk.\n12\t\n13\tDependency rule: this module must not import from ``runtime.*``. It\n14\taccepts ``role_bindings``, ``log_path``, and ``run_dir`` as arguments so\n15\tthat ``runtime.case`` retains full control over I/O paths and namespace\n16\tcontext.\n17\t\"\"\"\n18\t\n19\tfrom __future__ import annotations\n20\t\n21\timport json\n22\timport os\n23\timport subprocess\n24\timport time\n25\tfrom pathlib import Path\n26\tfrom typing import Any\n27\t\n28\t\n29\tdef _exec_command(\n30\t    cmd: str,\n31\t    *,\n32\t    env_vars: dict[str, str] | None,\n33\t    timeout: int,\n34\t    log_path: Path,\n35\t) -> tuple[bool, str]:\n36\t    \"\"\"Run *cmd* in a shell, appending output to *log_path*.\n37\t\n38\t    Returns ``(success, combined_output)``.\n39\t    \"\"\"\n40\t    env = {**os.environ, **(env_vars or {})}\n41\t    try:\n42\t        proc = subprocess.run(\n43\t            cmd, shell=True, capture_output=True, text=True, env=env, timeout=timeout\n44\t        )\n45\t        out = proc.stdout + proc.stderr\n46\t        with log_path.open(\"a\") as fh:\n47\t            fh.write(f\"$ {cmd}\\n{out}\\n\")\n48\t        return proc.returncode == 0, out\n49\t    except subprocess.TimeoutExpired:\n50\t        msg = f\"command timed out after {timeout}s: {cmd}\\n\"\n51\t        with log_path.open(\"a\") as fh:\n52\t            fh.write(msg)\n53\t        return False, msg\n54\t    except Exception as exc:\n55\t        msg = f\"command error: {exc}\\n\"\n56\t        with log_path.open(\"a\") as fh:\n57\t            fh.write(msg)\n58\t        return False, msg\n59\t\n60\t\n61\tdef _run_units(\n62\t    units: list[dict[str, Any]],\n63\t    *,\n64\t    role_bindings: dict[str, str],\n65\t    log_path: Path,\n66\t    env_vars: dict[str, str] | None,\n67\t    result_id_key: str,\n68\t) -> dict[str, Any]:\n69\t    \"\"\"Run probe/apply/verify for each unit, respecting on_probe_fail.\n70\t\n71\t    Probe semantics are the INVERSE of precondition units: here a probe that\n72\t    *passes* means the target condition is reachable, so apply runs (planting\n73\t    the fault for deploy, removing it for lift). A probe that *fails* triggers\n74\t    ``on_probe_fail``: ``skip`` (the lift default) treats it as a no-op success\n75\t    -- e.g. the agent already resolved the condition -- while ``error`` (the\n76\t    deploy default) means the cluster is not in the expected state for injection\n77\t    and the unit fails.\n78\t\n79\t    Returns a dict with ``ok``, *result_id_key* (list of IDs that ran), and\n80\t    ``output`` (concatenated log lines).\n81\t    \"\"\"\n82\t    log_path.parent.mkdir(parents=True, exist_ok=True)\n83\t    all_output: list[str] = []\n84\t    success_ids: list[str] = []\n85\t    overall_ok = True\n86\t    env = {**role_bindings, **(env_vars or {})}\n87\t\n88\t    for unit in units or []:\n89\t        unit_id = unit.get(\"id\", \"unknown\")\n90\t        on_fail = unit.get(\"on_probe_fail\", \"error\")\n91\t\n92\t        # Probe\n93\t        probe_ok = True\n94\t        for cmd_entry in unit.get(\"probe_commands\") or []:\n95\t            cmd = cmd_entry[\"command\"]\n96\t            to = cmd_entry.get(\"timeout_sec\") or 30\n97\t            ok, out = _exec_command(cmd, env_vars=env, timeout=to, log_path=log_path)\n98\t            all_output.append(out)\n99\t            if cmd_entry.get(\"sleep\"):\n100\t                time.sleep(cmd_entry[\"sleep\"])\n101\t            if not ok:\n102\t                probe_ok = False\n103\t                break\n104\t\n105\t        if not probe_ok:\n106\t            if on_fail == \"skip\":\n107\t                # Lift default: probe failure means the condition is already\n108\t                # resolved (e.g. the agent fixed it) -> no-op success.\n109\t                continue\n110\t            # Deploy default (on_probe_fail=\"error\"): the cluster is not in the\n111\t            # expected state for injection -- a test design bug -- so fail.\n112\t            overall_ok = False\n113\t            continue\n114\t\n115\t        # Probe passed -> the target condition is reachable, so apply it\n116\t        # (plant the fault for deploy, remove it for lift), then verify.\n117\t        apply_ok = True\n118\t        for cmd_entry in unit.get(\"apply_commands\") or []:\n119\t            cmd = cmd_entry[\"command\"]\n120\t            to = cmd_entry.get(\"timeout_sec\") or 120\n121\t            ok, out = _exec_command(cmd, env_vars=env, timeout=to, log_path=log_path)\n122\t            all_output.append(out)\n123\t            if cmd_entry.get(\"sleep\"):\n124\t                time.sleep(cmd_entry[\"sleep\"])\n125\t            if not ok:\n126\t                apply_ok = False\n127\t                break\n128\t        if not apply_ok:\n129\t            overall_ok = False\n130\t            continue\n131\t\n132\t        # Verify\n133\t        verify_ok = True\n134\t        for cmd_entry in unit.get(\"verify_commands\") or []:\n135\t            cmd = cmd_entry[\"command\"]\n136\t            to = cmd_entry.get(\"timeout_sec\") or 30\n137\t            ok, out = _exec_command(cmd, env_vars=env, timeout=to, log_path=log_path)\n138\t            all_output.append(out)\n139\t            if not ok:\n140\t                verify_ok = False\n141\t                break\n142\t        if verify_ok:\n143\t            success_ids.append(unit_id)\n144\t        else:\n145\t            overall_ok = False\n146\t\n147\t    return {\n148\t        \"ok\": overall_ok,\n149\t        result_id_key: success_ids,\n150\t        \"output\": \"\".join(all_output),\n151\t    }\n152\t\n153\t\n154\tdef deploy(\n155\t    units: list[dict[str, Any]],\n156\t    *,\n157\t    role_bindings: dict[str, str],\n158\t    log_path: Path,\n159\t    env_vars: dict[str, str] | None = None,\n160\t) -> dict[str, Any]:\n161\t    \"\"\"Execute adversary deploy units and return a deploy result dict.\n162\t\n163\t    Called by ``runtime.case.run_stage`` after preconditions complete and\n164\t    before the agent is launched. Each unit follows the canonical\n165\t    probe/apply/verify shape. When the probe passes the fault is already\n166\t    active and apply is skipped; when the probe fails apply is run to\n167\t    plant the fault, then verify confirms it is active.\n168\t\n169\t    Parameters\n170\t    ----------\n171\t    units:\n172\t        Deploy operation units from\n173\t        ``adversary.definitions.collect_stage_operations``.\n174\t    role_bindings:\n175\t        Map of namespace role name to physical namespace name, forwarded\n176\t        to every kubectl command.\n177\t    log_path:\n178\t        Path to the adversary log file where all command output is appended.\n179\t    env_vars:\n180\t        Additional environment variables forwarded to commands.\n181\t\n182\t    Returns\n183\t    -------\n184\t    dict\n185\t        Keys: ``ok`` (bool), ``deployed_ids`` (list[str] of unit IDs that\n186\t        activated successfully), ``output`` (str).\n187\t    \"\"\"\n188\t    return _run_units(units, role_bindings=role_bindings, log_path=log_path, env_vars=env_vars,\n189\t                      result_id_key=\"deployed_ids\")\n190\t\n191\t\n192\tdef lift(\n193\t    units: list[dict[str, Any]],\n194\t    *,\n195\t    role_bindings: dict[str, str],\n196\t    log_path: Path,\n197\t    env_vars: dict[str, str] | None = None,\n198\t) -> dict[str, Any]:\n199\t    \"\"\"Execute adversary lift units and return a lift result dict.\n200\t\n201\t    Called by ``runtime.case.run_stage`` during cleanup, after evidence\n202\t    collection and oracle execution. When the probe confirms the fault is\n203\t    still active, apply removes it and verify confirms it is gone. When\n204\t    the probe shows the fault is already gone (``on_probe_fail: skip``),\n205\t    the lift is considered a no-op success.\n206\t\n207\t    Parameters\n208\t    ----------\n209\t    units:\n210\t        Lift operation units from\n211\t        ``adversary.definitions.collect_stage_operations``.\n212\t    role_bindings:\n213\t        Map of namespace role name to physical namespace name.\n214\t    log_path:\n215\t        Path to the adversary log file where all command output is appended.\n216\t    env_vars:\n217\t        Additional environment variables forwarded to commands.\n218\t\n219\t    Returns\n220\t    -------\n221\t    dict\n222\t        Keys: ``ok`` (bool), ``lifted_ids`` (list[str] of unit IDs that\n223\t        were successfully removed), ``output`` (str).\n224\t    \"\"\"\n225\t    return _run_units(units, role_bindings=role_bindings, log_path=log_path, env_vars=env_vars,\n226\t                      result_id_key=\"lifted_ids\")\n227\t\n228\t\n229\tdef report(\n230\t    scenario_id: str,\n231\t    deploy_result: dict[str, Any],\n232\t    lift_result: dict[str, Any] | None,\n233\t    *,\n234\t    run_dir: Path,\n235\t    stage_id: str,\n236\t) -> dict[str, Any]:\n237\t    \"\"\"Write a structured adversary result to disk and return it.\n238\t\n239\t    Written to ``{run_dir}/stages/{stage_id}/adversary.json``. When\n240\t    *lift_result* is ``None`` the scenario had no lift stage or the lift\n241\t    was handled by the final cleanup sweep in ``runtime.workflow``.\n242\t\n243\t    Parameters\n244\t    ----------\n245\t    scenario_id:\n246\t        Identifier of the adversary scenario.\n247\t    deploy_result:\n248\t        Result dict from :func:`deploy`.\n249\t    lift_result:\n250\t        Result dict from :func:`lift`, or ``None``.\n251\t    run_dir:\n252\t        Root directory of the current run.\n253\t    stage_id:\n254\t        ID of the stage this adversary was active in.\n255\t\n256\t    Returns\n257\t    -------\n258\t    dict\n259\t        Keys: ``scenario_id`` (str), ``deploy`` (dict), ``lift`` (dict or\n260\t        ``None``), ``ok`` (bool).\n261\t    \"\"\"\n262\t    result: dict[str, Any] = {\n263\t        \"scenario_id\": scenario_id,\n264\t        \"deploy\": deploy_result,\n265\t        \"lift\": lift_result,\n266\t        \"ok\": deploy_result.get(\"ok\", False) and (lift_result is None or lift_result.get(\"ok\", False)),\n267\t    }\n268\t    out_dir = run_dir / \"stages\" / stage_id\n269\t    out_dir.mkdir(parents=True, exist_ok=True)\n270\t    (out_dir / \"adversary.json\").write_text(json.dumps(result, indent=2))\n271\t    return result\n272\t"}]},"parent_tool_use_id":null,"session_id":"df254869-6326-4314-8a88-6d3c82cf9641","uuid":"57351c20-80cf-4dbc-a119-c65b063b0e76","timestamp":"2026-06-24T07:12:27.687Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/karma/adversary/runtime.py","content":"\"\"\"\nAdversary injection lifecycle: deploy, lift, and report.\n\nOwns the runtime-facing adversary API called by ``runtime.case`` at two\npoints in the stage execution lifecycle:\n\n- After preconditions complete: :func:`deploy` runs the deploy unit to\n  plant the fault condition in the cluster.\n- During cleanup (before namespace teardown): :func:`lift` runs the lift\n  unit to remove the fault condition.\n- After lift: :func:`report` writes a structured result to disk.\n\nDependency rule: this module must not import from ``runtime.*``. It\naccepts ``role_bindings``, ``log_path``, and ``run_dir`` as arguments so\nthat ``runtime.case`` retains full control over I/O paths and namespace\ncontext.\n\"\"\"\n\nfrom __future__ import annotations\n\nimport json\nimport os\nimport subprocess\nimport time\nfrom pathlib import Path\nfrom typing import Any\n\n\ndef _exec_command(\n    cmd: str,\n    *,\n    env_vars: dict[str, str] | None,\n    timeout: int,\n    log_path: Path,\n) -> tuple[bool, str]:\n    \"\"\"Run *cmd* in a shell, appending output to *log_path*.\n\n    Returns ``(success, combined_output)``.\n    \"\"\"\n    env = {**os.environ, **(env_vars or {})}\n    try:\n        proc = subprocess.run(\n            cmd, shell=True, capture_output=True, text=True, env=env, timeout=timeout\n        )\n        out = proc.stdout + proc.stderr\n        with log_path.open(\"a\") as fh:\n            fh.write(f\"$ {cmd}\\n{out}\\n\")\n        return proc.returncode == 0, out\n    except subprocess.TimeoutExpired:\n        msg = f\"command timed out after {timeout}s: {cmd}\\n\"\n        with log_path.open(\"a\") as fh:\n            fh.write(msg)\n        return False, msg\n    except Exception as exc:\n        msg = f\"command error: {exc}\\n\"\n        with log_path.open(\"a\") as fh:\n            fh.write(msg)\n        return False, msg\n\n\ndef _run_units(\n    units: list[dict[str, Any]],\n    *,\n    role_bindings: dict[str, str],\n    log_path: Path,\n    env_vars: dict[str, str] | None,\n    result_id_key: str,\n) -> dict[str, Any]:\n    \"\"\"Run probe/apply/verify for each unit, respecting on_probe_fail.\n\n    Probe semantics are the INVERSE of precondition units: here a probe that\n    *passes* means the target condition is reachable, so apply runs (planting\n    the fault for deploy, removing it for lift). A probe that *fails* triggers\n    ``on_probe_fail``: ``skip`` (the lift default) treats it as a no-op success\n    -- e.g. the agent already resolved the condition -- while ``error`` (the\n    deploy default) means the cluster is not in the expected state for injection\n    and the unit fails.\n\n    Returns a dict with ``ok``, *result_id_key* (list of IDs that ran), and\n    ``output`` (concatenated log lines).\n    \"\"\"\n    log_path.parent.mkdir(parents=True, exist_ok=True)\n    all_output: list[str] = []\n    success_ids: list[str] = []\n    overall_ok = True\n    env = {**role_bindings, **(env_vars or {})}\n\n    for unit in units or []:\n        unit_id = unit.get(\"id\", \"unknown\")\n        on_fail = unit.get(\"on_probe_fail\", \"error\")\n\n        # Probe\n        probe_ok = True\n        for cmd_entry in unit.get(\"probe_commands\") or []:\n            cmd = cmd_entry[\"command\"]\n            to = cmd_entry.get(\"timeout_sec\") or 30\n            ok, out = _exec_command(cmd, env_vars=env, timeout=to, log_path=log_path)\n            all_output.append(out)\n            if cmd_entry.get(\"sleep\"):\n                time.sleep(cmd_entry[\"sleep\"])\n            if not ok:\n                probe_ok = False\n                break\n\n        if not probe_ok:\n            if on_fail == \"skip\":\n                # Lift default: probe failure means the condition is already\n                # resolved (e.g. the agent fixed it) -> no-op success.\n                continue\n            # Deploy default (on_probe_fail=\"error\"): the cluster is not in the\n            # expected state for injection -- a test design bug -- so fail.\n            overall_ok = False\n            continue\n\n        # Probe passed -> the target condition is reachable, so apply it\n        # (plant the fault for deploy, remove it for lift), then verify.\n        apply_ok = True\n        for cmd_entry in unit.get(\"apply_commands\") or []:\n            cmd = cmd_entry[\"command\"]\n            to = cmd_entry.get(\"timeout_sec\") or 120\n            ok, out = _exec_command(cmd, env_vars=env, timeout=to, log_path=log_path)\n            all_output.append(out)\n            if cmd_entry.get(\"sleep\"):\n                time.sleep(cmd_entry[\"sleep\"])\n            if not ok:\n                apply_ok = False\n                break\n        if not apply_ok:\n            overall_ok = False\n            continue\n\n        # Verify\n        verify_ok = True\n        for cmd_entry in unit.get(\"verify_commands\") or []:\n            cmd = cmd_entry[\"command\"]\n            to = cmd_entry.get(\"timeout_sec\") or 30\n            ok, out = _exec_command(cmd, env_vars=env, timeout=to, log_path=log_path)\n            all_output.append(out)\n            if not ok:\n                verify_ok = False\n                break\n        if verify_ok:\n            success_ids.append(unit_id)\n        else:\n            overall_ok = False\n\n    return {\n        \"ok\": overall_ok,\n        result_id_key: success_ids,\n        \"output\": \"\".join(all_output),\n    }\n\n\ndef deploy(\n    units: list[dict[str, Any]],\n    *,\n    role_bindings: dict[str, str],\n    log_path: Path,\n    env_vars: dict[str, str] | None = None,\n) -> dict[str, Any]:\n    \"\"\"Execute adversary deploy units and return a deploy result dict.\n\n    Called by ``runtime.case.run_stage`` after preconditions complete and\n    before the agent is launched. Each unit follows the canonical\n    probe/apply/verify shape. When the probe passes the fault is already\n    active and apply is skipped; when the probe fails apply is run to\n    plant the fault, then verify confirms it is active.\n\n    Parameters\n    ----------\n    units:\n        Deploy operation units from\n        ``adversary.definitions.collect_stage_operations``.\n    role_bindings:\n        Map of namespace role name to physical namespace name, forwarded\n        to every kubectl command.\n    log_path:\n        Path to the adversary log file where all command output is appended.\n    env_vars:\n        Additional environment variables forwarded to commands.\n\n    Returns\n    -------\n    dict\n        Keys: ``ok`` (bool), ``deployed_ids`` (list[str] of unit IDs that\n        activated successfully), ``output`` (str).\n    \"\"\"\n    return _run_units(units, role_bindings=role_bindings, log_path=log_path, env_vars=env_vars,\n                      result_id_key=\"deployed_ids\")\n\n\ndef lift(\n    units: list[dict[str, Any]],\n    *,\n    role_bindings: dict[str, str],\n    log_path: Path,\n    env_vars: dict[str, str] | None = None,\n) -> dict[str, Any]:\n    \"\"\"Execute adversary lift units and return a lift result dict.\n\n    Called by ``runtime.case.run_stage`` during cleanup, after evidence\n    collection and oracle execution. When the probe confirms the fault is\n    still active, apply removes it and verify confirms it is gone. When\n    the probe shows the fault is already gone (``on_probe_fail: skip``),\n    the lift is considered a no-op success.\n\n    Parameters\n    ----------\n    units:\n        Lift operation units from\n        ``adversary.definitions.collect_stage_operations``.\n    role_bindings:\n        Map of namespace role name to physical namespace name.\n    log_path:\n        Path to the adversary log file where all command output is appended.\n    env_vars:\n        Additional environment variables forwarded to commands.\n\n    Returns\n    -------\n    dict\n        Keys: ``ok`` (bool), ``lifted_ids`` (list[str] of unit IDs that\n        were successfully removed), ``output`` (str).\n    \"\"\"\n    return _run_units(units, role_bindings=role_bindings, log_path=log_path, env_vars=env_vars,\n                      result_id_key=\"lifted_ids\")\n\n\ndef report(\n    scenario_id: str,\n    deploy_result: dict[str, Any],\n    lift_result: dict[str, Any] | None,\n    *,\n    run_dir: Path,\n    stage_id: str,\n) -> dict[str, Any]:\n    \"\"\"Write a structured adversary result to disk and return it.\n\n    Written to ``{run_dir}/stages/{stage_id}/adversary.json``. When\n    *lift_result* is ``None`` the scenario had no lift stage or the lift\n    was handled by the final cleanup sweep in ``runtime.workflow``.\n\n    Parameters\n    ----------\n    scenario_id:\n        Identifier of the adversary scenario.\n    deploy_result:\n        Result dict from :func:`deploy`.\n    lift_result:\n        Result dict from :func:`lift`, or ``None``.\n    run_dir:\n        Root directory of the current run.\n    stage_id:\n        ID of the stage this adversary was active in.\n\n    Returns\n    -------\n    dict\n        Keys: ``scenario_id`` (str), ``deploy`` (dict), ``lift`` (dict or\n        ``None``), ``ok`` (bool).\n    \"\"\"\n    result: dict[str, Any] = {\n        \"scenario_id\": scenario_id,\n        \"deploy\": deploy_result,\n        \"lift\": lift_result,\n        \"ok\": deploy_result.get(\"ok\", False) and (lift_result is None or lift_result.get(\"ok\", False)),\n    }\n    out_dir = run_dir / \"stages\" / stage_id\n    out_dir.mkdir(parents=True, exist_ok=True)\n    (out_dir / \"adversary.json\").write_text(json.dumps(result, indent=2))\n    return result\n","numLines":272,"startLine":1,"totalLines":272}}}
