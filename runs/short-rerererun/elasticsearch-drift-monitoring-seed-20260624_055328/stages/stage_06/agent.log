g the oracle's hardcoded SERVICE=es-http unresolvable\n    # (\"Could not resolve host\"). Probing for the specific required objects makes\n    # the case self-sufficient: it rebuilds when its own objects are absent and\n    # only skips when a compatible es-cluster/es-http cluster is already present.\n    probe:\n      - command: \"/bin/sh -c 'kubectl -n elasticsearch get sts {{params.cluster_prefix}} >/dev/null 2>&1 && kubectl -n elasticsearch get svc {{params.http_service_name}} >/dev/null 2>&1 && [ \\\"$(kubectl -n elasticsearch get pods -l app={{params.cluster_prefix}} --field-selector=status.phase=Running 2>/dev/null | grep -c Running)\\\" -ge 1 ]'\"\n        timeout_sec: 15\n    apply:\n      - command: \"/bin/sh -c 'kubectl delete namespace elasticsearch --ignore-not-found=true --wait=false; kubectl wait --for=delete namespace/elasticsearch --timeout=400s || true'\"\n        timeout_sec: 460\n        sleep: 1\n      - command: \"kubectl create namespace elasticsearch\"\n        sleep: 1\n      - command: \"kubectl -n elasticsearch apply -f cases/elasticsearch/seed-hosts-repair/resource/\"\n        sleep: 1\n      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod -l app={{params.cluster_prefix}} --timeout=600s\"\n        sleep: 1\n      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod/{{params.curl_pod_name}} --timeout=300s\"\n        sleep: 1\n      - command: \"/bin/sh -c 'for i in $(seq 1 30); do kubectl -n elasticsearch exec {{params.curl_pod_name}} -- curl -s --max-time 5 \\\"http://{{params.http_service_name}}.elasticsearch.svc:9200/_cluster/health?wait_for_status=yellow&timeout=5s\\\" | grep -q \\\"\\\\\\\"status\\\\\\\"\\\" && exit 0; sleep 2; done; exit 1'\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n elasticsearch exec {{params.curl_pod_name}} -- curl -s -XPUT \\\"http://{{params.http_service_name}}.elasticsearch.svc:9200/{{params.index_name}}\\\" -H \\\"Content-Type: application/json\\\" -d \\