usters don't work with Raft consensus. So I'll delete pods 0 and 1 to force them to restart with the TLS configuration, and once all three pods are running with TLS enabled, they should form a healthy cluster.","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1084,"cache_read_input_tokens":39797,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1084},"output_tokens":28,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"e0010d32-1f85-4bc2-b107-cef79e3449ea","uuid":"92dd6b85-d245-4bd7-8dc9-0a2212823347","request_id":"req_011CcMaXduyzAC1wmnqJ8gdA"}
