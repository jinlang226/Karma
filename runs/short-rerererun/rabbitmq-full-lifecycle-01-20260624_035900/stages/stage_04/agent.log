s:\n  - time_to_first_mutation\n  - read_write_ratio\n  - blast_radius\n  - destructive_ops\n  - decoy_integrity\n  - residual_drift\n\npreconditionUnits:\n  - name: rabbitmq_secrets_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"/bin/sh -c 'set -e; kubectl -n ${BENCH_NAMESPACE} get secret {{params.cluster_prefix}}-erlang-cookie >/dev/null; kubectl -n ${BENCH_NAMESPACE} get secret {{params.cluster_prefix}}-admin >/dev/null'\"\n        timeout_sec: 20\n    apply:\n      - command: \"/bin/sh -c 'kubectl -n ${BENCH_NAMESPACE} create secret generic {{params.cluster_prefix}}-erlang-cookie --from-literal=cookie=supersecretcookie --dry-run=client -o yaml | kubectl apply -f -'\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n ${BENCH_NAMESPACE} create secret generic {{params.cluster_prefix}}-admin --from-literal=username=admin --from-literal=password=adminpass --dry-run=client -o yaml | kubectl apply -f -'\"\n        sleep: 1\n    verify:\n      - command: \"/bin/sh -c 'set -e; kubectl -n ${BENCH_NAMESPACE} get secret {{params.cluster_prefix}}-erlang-cookie >/dev/null; kubectl -n ${BENCH_NAMESPACE} get secret {{params.cluster_prefix}}-admin >/dev/null'\"\n        timeout_sec: 20\n\n  - name: rbac_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n ${BENCH_NAMESPACE} get sa {{params.cluster_prefix}}\"\n        timeout_sec: 10\n    apply:\n      - command: \"envsubst '$BENCH_NAMESPACE $BENCH_NS_SOURCE $BENCH_NS_TARGET $BENCH_PARAM_CLUSTER_PREFIX $BENCH_PARAM_BLUE_CLUSTER_PREFIX $BENCH_PARAM_GREEN_CLUSTER_PREFIX $BENCH_PARAM_FROM_VERSION' < cases/rabbitmq/manual_monitoring/resource/rbac.yaml | kubectl -n ${BENCH_NAMESPACE} apply -f -\"\n        sleep: 1\n    verify:\n      - command: \"kubectl -n ${BENCH_NAMESPACE} get sa {{params.cluster_prefix}}\"\n        timeout_sec: 10\n\n  - name: infra_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"/bin/sh -c 'set -e; kubectl -n ${BENCH_NAMESPACE} get svc {{params.cluste