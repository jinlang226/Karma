{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016zJ7GDRLncuTVBXZ2AQE4m","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport json\n3\timport os\n4\timport subprocess\n5\timport sys\n6\t\n7\tNAMESPACE = \"elasticsearch\"\n8\tSERVICE = \"es-http\"\n9\tCURL_POD = \"curl-test\"\n10\tTRANSFORM_ID = \"events-by-service\"\n11\tCHECKPOINT_CM = \"transform-checkpoint\"\n12\tDEST_INDEX = \"app-events-rollup\"\n13\t# ES 8.x runs with security enabled, so the HTTP API requires authenticating as\n14\t# the elastic superuser. When this case inherits a secured cluster from an\n15\t# earlier workflow stage, read its password from the secret that stage created\n16\t# so the oracle's queries aren't rejected with 401. Absent secret -> None -> no\n17\t# -u, so a standalone unsecured cluster still works.\n18\tPASSWORD_SECRET = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_SECRET_NAME\", \"elastic-password\")\n19\tPASSWORD_KEY = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_KEY\", \"password\")\n20\tDEFAULT_SCHEME = \"http\"\n21\t_SCHEME = None\n22\t\n23\t\n24\tdef run(cmd):\n25\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n26\t\n27\t\n28\tdef _elastic_password():\n29\t    \"\"\"Fetch the elastic-user password from its secret (base64-decoded), or None.\"\"\"\n30\t    import base64\n31\t    r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", PASSWORD_SECRET,\n32\t             \"-o\", \"jsonpath={.data.\" + PASSWORD_KEY + \"}\"])\n33\t    if r.returncode != 0 or not r.stdout.strip():\n34\t        return None\n35\t    try:\n36\t        return base64.b64decode(r.stdout.strip()).decode()\n37\t    except Exception:\n38\t        return None\n39\t\n40\t\n41\tELASTIC_PASSWORD = None  # set in main() once kubectl is reachable\n42\t\n43\t\n44\tdef _probe_scheme(scheme):\n45\t    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\n46\t\n47\t    The env PERSISTS across stages, so the cluster's live scheme may differ\n48\t    from this case's default; a 401 still proves the scheme is reachable.\n49\t    \"\"\"\n50\t    result = run([\n51\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", CURL_POD, \"--\",\n52\t        \"curl\", \"-s\", \"-S\", \"-k\", \"-o\", \"/dev/null\",\n53\t        \"-w\", \"%{http_code}\", \"--max-time\", \"5\",\n54\t        f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200/\",\n55\t    ])\n56\t    code = (result.stdout or \"\").strip()\n57\t    return result.returncode == 0 and code.isdigit() and code != \"000\"\n58\t\n59\t\n60\tdef detect_scheme():\n61\t    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n62\t    global _SCHEME\n63\t    if _SCHEME is not None:\n64\t        return _SCHEME\n65\t    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n66\t        if _probe_scheme(scheme):\n67\t            _SCHEME = scheme\n68\t            return _SCHEME\n69\t    _SCHEME = DEFAULT_SCHEME\n70\t    return _SCHEME\n71\t\n72\t\n73\tdef curl_json(path, errors):\n74\t    scheme = detect_scheme()\n75\t    result = run(\n76\t        [\n77\t            \"kubectl\",\n78\t            \"-n\",\n79\t            NAMESPACE,\n80\t            \"exec\",\n81\t            CURL_POD,\n82\t            \"--\",\n83\t            \"curl\",\n84\t            \"-s\",\n85\t            \"-S\",\n86\t            \"-k\",\n87\t        ]\n88\t        + ([\"-u\", f\"elastic:{ELASTIC_PASSWORD}\"] if ELASTIC_PASSWORD else [])\n89\t        + [\n90\t            \"--max-time\",\n91\t            \"5\",\n92\t            f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\",\n93\t        ]\n94\t    )\n95\t    if result.returncode != 0:\n96\t        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n97\t        errors.append(f\"Failed to query {path}: {detail}\")\n98\t        return None\n99\t    output = result.stdout.strip()\n100\t    if not output:\n101\t        errors.append(f\"Empty response for {path}\")\n102\t        return None\n103\t    try:\n104\t        return json.loads(output)\n105\t    except json.JSONDecodeError:\n106\t        errors.append(f\"Failed to parse JSON from {path}\")\n107\t        return None\n108\t\n109\t\n110\tdef get_checkpoint_before(errors):\n111\t    result = run(\n112\t        [\n113\t            \"kubectl\",\n114\t            \"-n\",\n115\t            NAMESPACE,\n116\t            \"get\",\n117\t            \"configmap\",\n118\t            CHECKPOINT_CM,\n119\t            \"-o\",\n120\t            \"jsonpath={.data.checkpoint_before}\",\n121\t        ]\n122\t    )\n123\t    if result.returncode != 0:\n124\t        errors.append(\"Unable to read checkpoint_before from configmap\")\n125\t        return None\n126\t    value = (result.stdout or \"\").strip()\n127\t    try:\n128\t        return int(value)\n129\t    except (TypeError, ValueError):\n130\t        errors.append(f\"Invalid checkpoint_before value: {value!r}\")\n131\t        return None\n132\t\n133\t\n134\tdef get_transform(errors):\n135\t    stats = curl_json(f\"/_transform/{TRANSFORM_ID}/_stats\", errors)\n136\t    if not isinstance(stats, dict):\n137\t        return None\n138\t    transforms = stats.get(\"transforms\") or []\n139\t    if not transforms:\n140\t        errors.append(\"Transform stats missing\")\n141\t        return None\n142\t    return transforms[0]\n143\t\n144\t\n145\tdef extract_checkpoint(transform):\n146\t    checkpoint = (\n147\t        transform.get(\"checkpointing\", {})\n148\t        .get(\"last\", {})\n149\t        .get(\"checkpoint\")\n150\t    )\n151\t    if checkpoint is None:\n152\t        checkpoint = (\n153\t            transform.get(\"stats\", {})\n154\t            .get(\"checkpointing\", {})\n155\t            .get(\"last\", {})\n156\t            .get(\"checkpoint\")\n157\t        )\n158\t    return checkpoint\n159\t\n160\t\n161\tdef evaluate(checkpoint_before):\n162\t    \"\"\"Run one full snapshot of the transform-recovery checks; return errors.\"\"\"\n163\t    errors = []\n164\t\n165\t    transform = get_transform(errors)\n166\t    if transform:\n167\t        state = transform.get(\"state\") or transform.get(\"stats\", {}).get(\"state\")\n168\t        if state != \"started\":\n169\t            errors.append(f\"Transform state expected started, got {state}\")\n170\t\n171\t        checkpoint_now = extract_checkpoint(transform)\n172\t        if checkpoint_before is not None:\n173\t            if checkpoint_now is None:\n174\t                errors.append(\"Unable to read current checkpoint\")\n175\t            elif checkpoint_now <= checkpoint_before:\n176\t                errors.append(\n177\t                    f\"Checkpoint did not advance (before={checkpoint_before}, now={checkpoint_now})\"\n178\t                )\n179\t\n180\t    count = curl_json(f\"/{DEST_INDEX}/_count\", errors)\n181\t    if isinstance(count, dict):\n182\t        if count.get(\"count\", 0) <= 0:\n183\t            errors.append(\"Destination index has no documents\")\n184\t\n185\t    return errors\n186\t\n187\t\n188\tdef main():\n189\t    global ELASTIC_PASSWORD\n190\t    ELASTIC_PASSWORD = _elastic_password()\n191\t\n192\t    # After the agent restarts the transform, its next checkpoint and the\n193\t    # destination index's documents only materialize once a transform sync cycle\n194\t    # runs (seconds to a sync interval later), and a curl can flake during that\n195\t    # window. A single immediate snapshot catches the not-yet-advanced state and\n196\t    # falsely reports \"Checkpoint did not advance\" / \"no documents\". So verify the\n197\t    # STABLE converged state: re-evaluate for up to ~120s and pass on the first\n198\t    # clean snapshot. The checkpoint_before baseline is read ONCE up front so the\n199\t    # advance check stays strict across retries.\n200\t    import time\n201\t    config_errors = []\n202\t    checkpoint_before = get_checkpoint_before(config_errors)\n203\t    deadline = time.monotonic() + 120\n204\t    live_errors = evaluate(checkpoint_before)\n205\t    while live_errors and time.monotonic() < deadline:\n206\t        time.sleep(8)\n207\t        live_errors = evaluate(checkpoint_before)\n208\t    errors = config_errors + live_errors\n209\t\n210\t    if errors:\n211\t        print(\"Transform recovery verification failed:\", file=sys.stderr)\n212\t        for err in errors:\n213\t            print(f\"  - {err}\", file=sys.stderr)\n214\t        return 1\n215\t\n216\t    print(\"Transform recovery verified\")\n217\t    return 0\n218\t\n219\t\n220\tif __name__ == \"__main__\":\n221\t    sys.exit(main())\n222\t"}]},"parent_tool_use_id":null,"session_id":"ac06b237-4d22-4c28-be56-46293709e537","uuid":"732b8f04-6435-4441-b00f-5e3565374009","timestamp":"2026-06-24T11:19:22.891Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/elasticsearch/transform-job-recovery/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport json\nimport os\nimport subprocess\nimport sys\n\nNAMESPACE = \"elasticsearch\"\nSERVICE = \"es-http\"\nCURL_POD = \"curl-test\"\nTRANSFORM_ID = \"events-by-service\"\nCHECKPOINT_CM = \"transform-checkpoint\"\nDEST_INDEX = \"app-events-rollup\"\n# ES 8.x runs with security enabled, so the HTTP API requires authenticating as\n# the elastic superuser. When this case inherits a secured cluster from an\n# earlier workflow stage, read its password from the secret that stage created\n# so the oracle's queries aren't rejected with 401. Absent secret -> None -> no\n# -u, so a standalone unsecured cluster still works.\nPASSWORD_SECRET = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_SECRET_NAME\", \"elastic-password\")\nPASSWORD_KEY = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_KEY\", \"password\")\nDEFAULT_SCHEME = \"http\"\n_SCHEME = None\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef _elastic_password():\n    \"\"\"Fetch the elastic-user password from its secret (base64-decoded), or None.\"\"\"\n    import base64\n    r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", PASSWORD_SECRET,\n             \"-o\", \"jsonpath={.data.\" + PASSWORD_KEY + \"}\"])\n    if r.returncode != 0 or not r.stdout.strip():\n        return None\n    try:\n        return base64.b64decode(r.stdout.strip()).decode()\n    except Exception:\n        return None\n\n\nELASTIC_PASSWORD = None  # set in main() once kubectl is reachable\n\n\ndef _probe_scheme(scheme):\n    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\n\n    The env PERSISTS across stages, so the cluster's live scheme may differ\n    from this case's default; a 401 still proves the scheme is reachable.\n    \"\"\"\n    result = run([\n        \"kubectl\", \"-n\", NAMESPACE, \"exec\", CURL_POD, \"--\",\n        \"curl\", \"-s\", \"-S\", \"-k\", \"-o\", \"/dev/null\",\n        \"-w\", \"%{http_code}\", \"--max-time\", \"5\",\n        f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200/\",\n    ])\n    code = (result.stdout or \"\").strip()\n    return result.returncode == 0 and code.isdigit() and code != \"000\"\n\n\ndef detect_scheme():\n    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n    global _SCHEME\n    if _SCHEME is not None:\n        return _SCHEME\n    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n        if _probe_scheme(scheme):\n            _SCHEME = scheme\n            return _SCHEME\n    _SCHEME = DEFAULT_SCHEME\n    return _SCHEME\n\n\ndef curl_json(path, errors):\n    scheme = detect_scheme()\n    result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"exec\",\n            CURL_POD,\n            \"--\",\n            \"curl\",\n            \"-s\",\n            \"-S\",\n            \"-k\",\n        ]\n        + ([\"-u\", f\"elastic:{ELASTIC_PASSWORD}\"] if ELASTIC_PASSWORD else [])\n        + [\n            \"--max-time\",\n            \"5\",\n            f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\",\n        ]\n    )\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errors.append(f\"Failed to query {path}: {detail}\")\n        return None\n    output = result.stdout.strip()\n    if not output:\n        errors.append(f\"Empty response for {path}\")\n        return None\n    try:\n        return json.loads(output)\n    except json.JSONDecodeError:\n        errors.append(f\"Failed to parse JSON from {path}\")\n        return None\n\n\ndef get_checkpoint_before(errors):\n    result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"get\",\n            \"configmap\",\n            CHECKPOINT_CM,\n            \"-o\",\n            \"jsonpath={.data.checkpoint_before}\",\n        ]\n    )\n    if result.returncode != 0:\n        errors.append(\"Unable to read checkpoint_before from configmap\")\n        return None\n    value = (result.stdout or \"\").strip()\n    try:\n        return int(value)\n    except (TypeError, ValueError):\n        errors.append(f\"Invalid checkpoint_before value: {value!r}\")\n        return None\n\n\ndef get_transform(errors):\n    stats = curl_json(f\"/_transform/{TRANSFORM_ID}/_stats\", errors)\n    if not isinstance(stats, dict):\n        return None\n    transforms = stats.get(\"transforms\") or []\n    if not transforms:\n        errors.append(\"Transform stats missing\")\n        return None\n    return transforms[0]\n\n\ndef extract_checkpoint(transform):\n    checkpoint = (\n        transform.get(\"checkpointing\", {})\n        .get(\"last\", {})\n        .get(\"checkpoint\")\n    )\n    if checkpoint is None:\n        checkpoint = (\n            transform.get(\"stats\", {})\n            .get(\"checkpointing\", {})\n            .get(\"last\", {})\n            .get(\"checkpoint\")\n        )\n    return checkpoint\n\n\ndef evaluate(checkpoint_before):\n    \"\"\"Run one full snapshot of the transform-recovery checks; return errors.\"\"\"\n    errors = []\n\n    transform = get_transform(errors)\n    if transform:\n        state = transform.get(\"state\") or transform.get(\"stats\", {}).get(\"state\")\n        if state != \"started\":\n            errors.append(f\"Transform state expected started, got {state}\")\n\n        checkpoint_now = extract_checkpoint(transform)\n        if checkpoint_before is not None:\n            if checkpoint_now is None:\n                errors.append(\"Unable to read current checkpoint\")\n            elif checkpoint_now <= checkpoint_before:\n                errors.append(\n                    f\"Checkpoint did not advance (before={checkpoint_before}, now={checkpoint_now})\"\n                )\n\n    count = curl_json(f\"/{DEST_INDEX}/_count\", errors)\n    if isinstance(count, dict):\n        if count.get(\"count\", 0) <= 0:\n            errors.append(\"Destination index has no documents\")\n\n    return errors\n\n\ndef main():\n    global ELASTIC_PASSWORD\n    ELASTIC_PASSWORD = _elastic_password()\n\n    # After the agent restarts the transform, its next checkpoint and the\n    # destination index's documents only materialize once a transform sync cycle\n    # runs (seconds to a sync interval later), and a curl can flake during that\n    # window. A single immediate snapshot catches the not-yet-advanced state and\n    # falsely reports \"Checkpoint did not advance\" / \"no documents\". So verify the\n    # STABLE converged state: re-evaluate for up to ~120s and pass on the first\n    # clean snapshot. The checkpoint_before baseline is read ONCE up front so the\n    # advance check stays strict across retries.\n    import time\n    config_errors = []\n    checkpoint_before = get_checkpoint_before(config_errors)\n    deadline = time.monotonic() + 120\n    live_errors = evaluate(checkpoint_before)\n    while live_errors and time.monotonic() < deadline:\n        time.sleep(8)\n        live_errors = evaluate(checkpoint_before)\n    errors = config_errors + live_errors\n\n    if errors:\n        print(\"Transform recovery verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    print(\"Transform recovery verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":222,"startLine":1,"totalLines":222}}}
