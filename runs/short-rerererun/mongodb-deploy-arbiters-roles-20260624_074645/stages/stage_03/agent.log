{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011Unnak5GzwgJpedJrPQSaJ","type":"tool_result","content":"# mongodb/custom-roles\n# MongoDB custom-roles task\n\nparams:\n  cluster_prefix:\n    default: mongodb-replica\n    description: StatefulSet name of the replica set members.\n  replica_set_name:\n    default: mongodb-replica\n    description: MongoDB replica set _id used when initiating the set.\n  admin_secret_name:\n    default: admin-user-password\n    description: Kubernetes Secret holding the admin user's password.\n  reporting_secret_name:\n    default: reporting-user-password\n    description: Kubernetes Secret holding the reporting user's password.\n  admin_username:\n    default: admin-user\n    description: Username of the MongoDB admin user.\n  reporting_username:\n    default: reporting-user\n    description: Username of the reporting user.\n  app_database:\n    default: appdb\n    description: Application database holding the reporting collections.\n  reports_collection:\n    default: reports\n    description: Collection backing the reporting dashboards.\n  raw_collection:\n    default: raw\n    description: Collection with ingestion data that must not be exposed.\n  bad_role_name:\n    default: rawRead\n    description: Overly-permissive role initially granted to the reporting user.\n\nprompt: |\n  A 3-member MongoDB replica set is running in the mongodb namespace.\n  Authentication is enabled. Passwords are stored in these Secrets:\n  - {{params.admin_secret_name}}\n  - {{params.reporting_secret_name}}\n\n  Reporting dashboards are failing for {{params.reporting_username}} after a permissions change.\n  Dashboards are built from {{params.app_database}}.{{params.reports_collection}}. {{params.app_database}}.{{params.raw_collection}} contains ingestion data and\n  must not be exposed. Restore the minimum access needed for reporting dashboards.\n\n  Notes:\n  - Do not use operators or CRDs.\n\nnamespace_contract:\n  required_roles: []\n\nmetrics:\n  - time_to_first_mutation\n\npreconditionUnits:\n  - name: mongo_env_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n mongodb get pod {{params.cluster_prefix}}-0 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n    apply:\n      - command: |\n          /bin/sh -c '\n          kubectl delete namespace mongodb --ignore-not-found=true; kubectl wait --for=delete namespace/mongodb --timeout=120s || true\n          '\n        sleep: 2\n      - command: \"kubectl create namespace mongodb\"\n        sleep: 1\n      - command: \"kubectl -n mongodb apply -f cases/mongodb/custom-roles/resource/secrets.yaml\"\n        sleep: 1\n      - command: \"kubectl -n mongodb apply -f cases/mongodb/custom-roles/resource/services.yaml\"\n        sleep: 1\n      - command: \"kubectl -n mongodb apply -f cases/mongodb/custom-roles/resource/statefulset.yaml\"\n        sleep: 5\n      - command: |\n          for i in $(seq 1 120); do\n            ready=$(kubectl -n mongodb get sts {{params.cluster_prefix}} -o jsonpath='{.status.readyReplicas}' 2>/dev/null)\n            if [ \"${ready:-0}\" -ge 3 ]; then\n              exit 0\n            fi\n            sleep 5\n          done\n          exit 1\n        sleep: 2\n      # Pod-Ready != mongod accepting TCP (§1.10): ping-until-ok before rs.initiate.\n      - command: |\n          for i in $(seq 1 30); do\n            kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval 'db.runCommand({ping:1}).ok' 2>/dev/null | grep -q 1 && exit 0\n            sleep 3\n          done\n          exit 1\n        sleep: 2\n      - command: |\n          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\n          rs.initiate({_id:\"{{params.replica_set_name}}\",members:[\n            {_id:0,host:\"mongodb-replica-0.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"},\n            {_id:1,host:\"mongodb-replica-1.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"},\n            {_id:2,host:\"mongodb-replica-2.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"}\n          ]})'\n        sleep: 5\n      - command: |\n          for i in $(seq 1 20); do\n            kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval 'db.hello().isWritablePrimary' | grep true && exit 0\n            sleep 3\n          done\n          exit 1\n        sleep: 2\n      - command: |\n          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\n          db.getSiblingDB(\"admin\").createUser({\n            user: \"{{params.admin_username}}\",\n            pwd: \"admin123password\",\n            roles: [\n              {role: \"clusterAdmin\", db: \"admin\"},\n              {role: \"userAdminAnyDatabase\", db: \"admin\"},\n              {role: \"readWriteAnyDatabase\", db: \"admin\"}\n            ]\n          })'\n        sleep: 2\n      - command: |\n          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet \\\n          \"mongodb://{{params.admin_username}}:admin123password@localhost:27017/admin\" \\\n          --eval 'db.getSiblingDB(\"{{params.app_database}}\").createRole({\n            role: \"{{params.bad_role_name}}\",\n            privileges: [\n              { resource: { db: \"{{params.app_database}}\", collection: \"{{params.raw_collection}}\" }, actions: [\"find\"] }\n            ],\n            roles: []\n          })'\n        sleep: 2\n      - command: |\n          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet \\\n          \"mongodb://{{params.admin_username}}:admin123password@localhost:27017/admin\" \\\n          --eval 'db.getSiblingDB(\"admin\").createUser({\n            user: \"{{params.reporting_username}}\",\n            pwd: \"reporting123password\",\n            roles: [{role: \"{{params.bad_role_name}}\", db: \"{{params.app_database}}\"}]\n          })'\n        sleep: 2\n      - command: |\n          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet \\\n          \"mongodb://{{params.admin_username}}:admin123password@localhost:27017/admin\" \\\n          --eval 'db.getSiblingDB(\"{{params.app_database}}\").{{params.reports_collection}}.insertMany([{x:1},{x:2},{x:3}], {writeConcern:{w:1}})'\n        sleep: 2\n      - command: |\n          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet \\\n          \"mongodb://{{params.admin_username}}:admin123password@localhost:27017/admin\" \\\n          --eval 'db.getSiblingDB(\"{{params.app_database}}\").{{params.raw_collection}}.insertMany([{x:10},{x:11}], {writeConcern:{w:1}})'\n        sleep: 2\n    verify:\n      - command: \"kubectl -n mongodb get pods 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n\n  - name: admin_user_fixture\n    # Composition self-sufficiency: this case authenticates as the `admin-user`\n    # created at deploy. On an inherited cluster a no-auth/other predecessor may\n    # not have created it, and a live user's password is unrecoverable -> the\n    # oracle's (and the user fixtures') admin auth fails through no agent fault.\n    # Bring our own additively: if admin-user already authenticates, skip; else\n    # ensure the secret and create the user. No restart, no data touched,\n    # idempotent -> never regresses a cluster where admin already works.\n    on_probe_fail: skip\n    probe:\n      - command: |\n          /bin/sh -c '\n          t=\"\"; for cca in /etc/tls/ca.crt /etc/mongo-ca/ca.crt; do kubectl -n mongodb exec mongodb-replica-0 -- ls $cca >/dev/null 2>&1 && { t=\"--tls --tlsAllowInvalidHostnames --tlsAllowInvalidCertificates --tlsCAFile $cca\"; break; }; done\n          pw=$(kubectl -n mongodb get secret admin-user-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null)\n          [ -n \"$pw\" ] || exit 1\n          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet $t \"mongodb://{{params.admin_username}}:$pw@localhost:27017/admin\" --eval \"db.runCommand({ping:1}).ok\" 2>/dev/null | grep -q 1\n          '\n        timeout_sec: 30\n    apply:\n      # Ensure the admin secret (idempotent: create only if missing).\n      - command: \"/bin/sh -c 'kubectl -n mongodb get secret admin-user-password >/dev/null 2>&1 || kubectl -n mongodb create secret generic admin-user-password --from-literal=password=admin123password'\"\n        sleep: 1\n      # Ensure the admin-user MongoDB user. On a no-auth inherited cluster this\n      # runs unauthenticated and succeeds; where it already exists it errors and\n      # the `|| true` keeps it a no-op. Never drops or alters existing users/data.\n      - command: |\n          /bin/sh -c '\n          t=\"\"; for cca in /etc/tls/ca.crt /etc/mongo-ca/ca.crt; do kubectl -n mongodb exec mongodb-replica-0 -- ls $cca >/dev/null 2>&1 && { t=\"--tls --tlsAllowInvalidHostnames --tlsAllowInvalidCertificates --tlsCAFile $cca\"; break; }; done\n          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet $t --eval \"db.getSiblingDB(\\\"admin\\\").createUser({user:\\\"{{params.admin_username}}\\\",pwd:\\\"admin123password\\\",roles:[{role:\\\"root\\\",db:\\\"admin\\\"}]})\" 2>/dev/null || true\n          '\n        sleep: 2\n    verify:\n      - command: \"/bin/sh -c 'kubectl -n mongodb get secret admin-user-password >/dev/null 2>&1 && echo ok'\"\n        timeout_sec: 15\n\n  # Additive credential+role+seed fixture (composition safety): standalone the\n  # build above creates the reporting-user, its rawRead role, the\n  # reporting-user-password secret, and the reports/raw seed data. Chained on an\n  # INHERITED cluster that build is skipped, so the oracle fails with\n  # \"reporting-user-password not found\". Ensure each artifact additively when\n  # missing, authenticating as the LIVE admin user (a prior rotation respected)\n  # and writing on the current primary. Never drops/alters existing users/data;\n  # standalone the probe finds everything present and skips -> identical behaviour.\n  - name: reporting_user_fixture\n    on_probe_fail: skip\n    probe:\n      - command: |\n          /bin/sh -c 't=\"\"; for cca in /etc/tls/ca.crt /etc/mongo-ca/ca.crt; do kubectl -n mongodb exec mongodb-replica-0 -- ls $cca >/dev/null 2>&1 && { t=\"--tls --tlsAllowInvalidHostnames --tlsAllowInvalidCertificates --tlsCAFile $cca\"; break; }; done; kubectl -n mongodb get secret {{params.reporting_secret_name}} >/dev/null 2>&1 || exit 1; pw=$(kubectl -n mongodb get secret {{params.admin_secret_name}} -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); pw=${pw:-admin123password}; P=\"\"; for _pi in $(seq 1 30); do P=$(kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet $t \"mongodb://{{params.admin_username}}:$pw@localhost:27017/admin?directConnection=true\" --eval '\\''rs.hello().primary'\\'' 2>/dev/null | cut -d. -f1); [ -n \"$P\" ] && break; sleep 2; done; P=${P:-mongodb-replica-0}; kubectl -n mongodb exec \"$P\" -- mongosh --quiet $t \"mongodb://{{params.admin_username}}:$pw@localhost:27017/admin\" --eval '\\''db.getSiblingDB(\"admin\").getUser(\"{{params.reporting_username}}\")?quit(0):quit(1)'\\'' >/dev/null 2>&1'\n        timeout_sec: 30\n    apply:\n      - command: \"kubectl -n mongodb apply -f cases/mongodb/custom-roles/resource/secrets.yaml\"\n        sleep: 1\n      - command: |\n          /bin/sh -c 'pw=$(kubectl -n mongodb get secret {{params.admin_secret_name}} -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); pw=${pw:-admin123password}; P=\"\"; for _pi in $(seq 1 30); do P=$(kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet \"mongodb://{{params.admin_username}}:$pw@localhost:27017/admin?directConnection=true\" --eval '\\''rs.hello().primary'\\'' 2>/dev/null | cut -d. -f1); [ -n \"$P\" ] && break; sleep 2; done; P=${P:-mongodb-replica-0}; kubectl -n mongodb exec \"$P\" -- mongosh --quiet \"mongodb://{{params.admin_username}}:$pw@localhost:27017/admin\" --eval '\\''var a=db.getSiblingDB(\"{{params.app_database}}\"); if(!a.getRole