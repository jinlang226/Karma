t_prefix}}-1\n              - {{params.external_host_prefix}}-2\n              - {{params.external_host_prefix}}-3\n            containers:\n            - name: mongosh\n              image: {{params.mongo_client_image}}\n              command: [\"sleep\", \"3600\"]\n          EOF\n        sleep: 2\n      - command: \"kubectl -n mongodb wait --for=condition=ready pod {{params.client_pod_name}} --timeout=300s\"\n        sleep: 2\n    verify:\n      - command: \"kubectl -n mongodb get pods 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n\noracle:\n  verify:\n    commands:\n      - command: \"python3 resources/mongodb/external-access-horizons/oracle/oracle.py\"\n        timeout_sec: 60\n","numLines":127,"startLine":1,"totalLines":127}}}
