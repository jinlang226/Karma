{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_012d9Z8B4CWCGfzdrUYXA6fL","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport argparse\n3\timport json\n4\timport os\n5\timport subprocess\n6\timport sys\n7\t\n8\t\n9\tNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"mongodb\")\n10\tCLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"mongo-rs\")\n11\tSERVICE_NAME = os.environ.get(\"BENCH_PARAM_SERVICE_NAME\", \"mongo\")\n12\tREPLICA_SET_NAME = os.environ.get(\"BENCH_PARAM_REPLICA_SET_NAME\", \"rs0\")\n13\tCLIENT_POD_NAME = os.environ.get(\"BENCH_PARAM_CLIENT_POD_NAME\", \"mongo-client\")\n14\tEXTERNAL_HOST_PREFIX = os.environ.get(\"BENCH_PARAM_EXTERNAL_HOST_PREFIX\", \"domain-rs\")\n15\tNODEPORT_START = int(os.environ.get(\"BENCH_PARAM_NODEPORT_START\", \"31181\"))\n16\tEXPECTED_REPLICAS = int(os.environ.get(\"BENCH_PARAM_EXPECTED_REPLICAS\", \"3\"))\n17\t\n18\t\n19\tdef run(cmd):\n20\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n21\t\n22\t\n23\tdef fail(prefix, errors):\n24\t    if errors:\n25\t        print(prefix, file=sys.stderr)\n26\t        for err in errors:\n27\t            print(f\"  - {err}\", file=sys.stderr)\n28\t        return 1\n29\t    return 0\n30\t\n31\t\n32\tdef mongo_json(pod, eval_str, label, errors, uri=None):\n33\t    cmd = [\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"mongosh\", \"--quiet\"]\n34\t    if uri:\n35\t        cmd.append(uri)\n36\t    cmd.extend([\"--eval\", eval_str])\n37\t    res = run(cmd)\n38\t    if res.returncode != 0:\n39\t        detail = res.stderr.strip() or res.stdout.strip() or f\"exit {res.returncode}\"\n40\t        errors.append(f\"{label} failed: {detail}\")\n41\t        return None\n42\t    raw = (res.stdout or \"\").strip()\n43\t    if not raw:\n44\t        errors.append(f\"{label} returned empty output\")\n45\t        return None\n46\t    try:\n47\t        return json.loads(raw)\n48\t    except json.JSONDecodeError:\n49\t        errors.append(f\"Unable to parse {label} JSON output\")\n50\t        return None\n51\t\n52\t\n53\tdef check_topology():\n54\t    errors = []\n55\t    pod = f\"{CLUSTER_PREFIX}-0\"\n56\t    conf = mongo_json(pod, \"JSON.stringify(rs.conf())\", \"rs.conf()\", errors)\n57\t    if isinstance(conf, dict):\n58\t        members = conf.get(\"members\", [])\n59\t        if len(members) != EXPECTED_REPLICAS:\n60\t            errors.append(f\"Expected {EXPECTED_REPLICAS} members in rs.conf(), got {len(members)}\")\n61\t\n62\t        expected_hosts = {\n63\t            f\"{CLUSTER_PREFIX}-{idx}.{SERVICE_NAME}.{NAMESPACE}.svc.cluster.local:27017\": idx\n64\t            for idx in range(EXPECTED_REPLICAS)\n65\t        }\n66\t        for member in members:\n67\t            host = member.get(\"host\")\n68\t            if host not in expected_hosts:\n69\t                errors.append(f\"Unexpected member host: {host}\")\n70\t                continue\n71\t            idx = expected_hosts[host]\n72\t            expected_horizon = f\"{EXTERNAL_HOST_PREFIX}-{idx + 1}:{NODEPORT_START + idx}\"\n73\t            horizons = member.get(\"horizons\") or {}\n74\t            actual_horizon = horizons.get(\"horizon1\")\n75\t            if actual_horizon != expected_horizon:\n76\t                errors.append(f\"{host} horizon1 expected {expected_horizon}, got {actual_horizon}\")\n77\t\n78\t    return fail(\"External access horizons topology check failed:\", errors)\n79\t\n80\t\n81\tdef check_services():\n82\t    errors = []\n83\t    for idx in range(EXPECTED_REPLICAS):\n84\t        svc_name = f\"mongo-external-{idx}\"\n85\t        res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"svc\", svc_name, \"-o\", \"json\"])\n86\t        if res.returncode != 0:\n87\t            detail = res.stderr.strip() or res.stdout.strip() or f\"exit {res.returncode}\"\n88\t            errors.append(f\"Failed to read service/{svc_name}: {detail}\")\n89\t            continue\n90\t        try:\n91\t            svc = json.loads(res.stdout)\n92\t        except json.JSONDecodeError:\n93\t            errors.append(f\"Failed to parse service/{svc_name} JSON\")\n94\t            continue\n95\t\n96\t        ports = svc.get(\"spec\", {}).get(\"ports\", [])\n97\t        node_port = ports[0].get(\"nodePort\") if ports else None\n98\t        expected_node_port = NODEPORT_START + idx\n99\t        if node_port != expected_node_port:\n100\t            errors.append(f\"{svc_name} nodePort expected {expected_node_port}, got {node_port}\")\n101\t\n102\t        selector = svc.get(\"spec\", {}).get(\"selector\", {})\n103\t        expected_selector = {\"statefulset.kubernetes.io/pod-name\": f\"{CLUSTER_PREFIX}-{idx}\"}\n104\t        if selector != expected_selector:\n105\t            errors.append(f\"{svc_name} selector mismatch: expected={expected_selector} actual={selector}\")\n106\t\n107\t    return fail(\"External access horizons service check failed:\", errors)\n108\t\n109\t\n110\tdef check_connectivity():\n111\t    errors = []\n112\t    hosts = \",\".join(\n113\t        f\"{EXTERNAL_HOST_PREFIX}-{idx + 1}:{NODEPORT_START + idx}\" for idx in range(EXPECTED_REPLICAS)\n114\t    )\n115\t    uri = f\"mongodb://{hosts}/admin?replicaSet={REPLICA_SET_NAME}\"\n116\t\n117\t    res = run(\n118\t        [\n119\t            \"kubectl\",\n120\t            \"-n\",\n121\t            NAMESPACE,\n122\t            \"exec\",\n123\t            CLIENT_POD_NAME,\n124\t            \"--\",\n125\t            \"mongosh\",\n126\t            \"--quiet\",\n127\t            uri,\n128\t            \"--eval\",\n129\t            \"JSON.stringify(db.hello())\",\n130\t        ]\n131\t    )\n132\t    if res.returncode != 0:\n133\t        detail = res.stderr.strip() or res.stdout.strip() or f\"exit {res.returncode}\"\n134\t        errors.append(f\"mongo-client connectivity failed: {detail}\")\n135\t        return fail(\"External access horizons connectivity check failed:\", errors)\n136\t\n137\t    try:\n138\t        hello = json.loads((res.stdout or \"\").strip())\n139\t    except json.JSONDecodeError:\n140\t        errors.append(\"Unable to parse mongo-client db.hello() output\")\n141\t        return fail(\"External access horizons connectivity check failed:\", errors)\n142\t\n143\t    if hello.get(\"ok\") != 1:\n144\t        errors.append(\"db.hello().ok != 1\")\n145\t    if hello.get(\"setName\") != REPLICA_SET_NAME:\n146\t        errors.append(f\"Connected replica set expected {REPLICA_SET_NAME}, got {hello.get('setName')}\")\n147\t\n148\t    return fail(\"External access horizons connectivity check failed:\", errors)\n149\t\n150\t\n151\tdef main():\n152\t    parser = argparse.ArgumentParser()\n153\t    parser.add_argument(\"--check\", default=\"all\", choices=[\"all\", \"topology\", \"services\", \"connectivity\"])\n154\t    args = parser.parse_args()\n155\t\n156\t    if args.check == \"topology\":\n157\t        return check_topology()\n158\t    if args.check == \"services\":\n159\t        return check_services()\n160\t    if args.check == \"connectivity\":\n161\t        return check_connectivity()\n162\t\n163\t    for fn in (check_topology, check_services, check_connectivity):\n164\t        rc = fn()\n165\t        if rc != 0:\n166\t            return rc\n167\t    print(\"External access horizons verified\")\n168\t    return 0\n169\t\n170\t\n171\tif __name__ == \"__main__\":\n172\t    sys.exit(main())\n173\t"}]},"parent_tool_use_id":null,"session_id":"2e59d176-7ae0-4d8f-8b75-eacd31b6c404","uuid":"7601e20c-cb99-4b3c-be4c-61e02eb3d240","timestamp":"2026-06-11T23:00:10.579Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/leo/Karma/resources/mongodb/external-access-horizons/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport argparse\nimport json\nimport os\nimport subprocess\nimport sys\n\n\nNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"mongodb\")\nCLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"mongo-rs\")\nSERVICE_NAME = os.environ.get(\"BENCH_PARAM_SERVICE_NAME\", \"mongo\")\nREPLICA_SET_NAME = os.environ.get(\"BENCH_PARAM_REPLICA_SET_NAME\", \"rs0\")\nCLIENT_POD_NAME = os.environ.get(\"BENCH_PARAM_CLIENT_POD_NAME\", \"mongo-client\")\nEXTERNAL_HOST_PREFIX = os.environ.get(\"BENCH_PARAM_EXTERNAL_HOST_PREFIX\", \"domain-rs\")\nNODEPORT_START = int(os.environ.get(\"BENCH_PARAM_NODEPORT_START\", \"31181\"))\nEXPECTED_REPLICAS = int(os.environ.get(\"BENCH_PARAM_EXPECTED_REPLICAS\", \"3\"))\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef fail(prefix, errors):\n    if errors:\n        print(prefix, file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n    return 0\n\n\ndef mongo_json(pod, eval_str, label, errors, uri=None):\n    cmd = [\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"mongosh\", \"--quiet\"]\n    if uri:\n        cmd.append(uri)\n    cmd.extend([\"--eval\", eval_str])\n    res = run(cmd)\n    if res.returncode != 0:\n        detail = res.stderr.strip() or res.stdout.strip() or f\"exit {res.returncode}\"\n        errors.append(f\"{label} failed: {detail}\")\n        return None\n    raw = (res.stdout or \"\").strip()\n    if not raw:\n        errors.append(f\"{label} returned empty output\")\n        return None\n    try:\n        return json.loads(raw)\n    except json.JSONDecodeError:\n        errors.append(f\"Unable to parse {label} JSON output\")\n        return None\n\n\ndef check_topology():\n    errors = []\n    pod = f\"{CLUSTER_PREFIX}-0\"\n    conf = mongo_json(pod, \"JSON.stringify(rs.conf())\", \"rs.conf()\", errors)\n    if isinstance(conf, dict):\n        members = conf.get(\"members\", [])\n        if len(members) != EXPECTED_REPLICAS:\n            errors.append(f\"Expected {EXPECTED_REPLICAS} members in rs.conf(), got {len(members)}\")\n\n        expected_hosts = {\n            f\"{CLUSTER_PREFIX}-{idx}.{SERVICE_NAME}.{NAMESPACE}.svc.cluster.local:27017\": idx\n            for idx in range(EXPECTED_REPLICAS)\n        }\n        for member in members:\n            host = member.get(\"host\")\n            if host not in expected_hosts:\n                errors.append(f\"Unexpected member host: {host}\")\n                continue\n            idx = expected_hosts[host]\n            expected_horizon = f\"{EXTERNAL_HOST_PREFIX}-{idx + 1}:{NODEPORT_START + idx}\"\n            horizons = member.get(\"horizons\") or {}\n            actual_horizon = horizons.get(\"horizon1\")\n            if actual_horizon != expected_horizon:\n                errors.append(f\"{host} horizon1 expected {expected_horizon}, got {actual_horizon}\")\n\n    return fail(\"External access horizons topology check failed:\", errors)\n\n\ndef check_services():\n    errors = []\n    for idx in range(EXPECTED_REPLICAS):\n        svc_name = f\"mongo-external-{idx}\"\n        res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"svc\", svc_name, \"-o\", \"json\"])\n        if res.returncode != 0:\n            detail = res.stderr.strip() or res.stdout.strip() or f\"exit {res.returncode}\"\n            errors.append(f\"Failed to read service/{svc_name}: {detail}\")\n            continue\n        try:\n            svc = json.loads(res.stdout)\n        except json.JSONDecodeError:\n            errors.append(f\"Failed to parse service/{svc_name} JSON\")\n            continue\n\n        ports = svc.get(\"spec\", {}).get(\"ports\", [])\n        node_port = ports[0].get(\"nodePort\") if ports else None\n        expected_node_port = NODEPORT_START + idx\n        if node_port != expected_node_port:\n            errors.append(f\"{svc_name} nodePort expected {expected_node_port}, got {node_port}\")\n\n        selector = svc.get(\"spec\", {}).get(\"selector\", {})\n        expected_selector = {\"statefulset.kubernetes.io/pod-name\": f\"{CLUSTER_PREFIX}-{idx}\"}\n        if selector != expected_selector:\n            errors.append(f\"{svc_name} selector mismatch: expected={expected_selector} actual={selector}\")\n\n    return fail(\"External access horizons service check failed:\", errors)\n\n\ndef check_connectivity():\n    errors = []\n    hosts = \",\".join(\n        f\"{EXTERNAL_HOST_PREFIX}-{idx + 1}:{NODEPORT_START + idx}\" for idx in range(EXPECTED_REPLICAS)\n    )\n    uri = f\"mongodb://{hosts}/admin?replicaSet={REPLICA_SET_NAME}\"\n\n    res = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"exec\",\n            CLIENT_POD_NAME,\n            \"--\",\n            \"mongosh\",\n            \"--quiet\",\n            uri,\n            \"--eval\",\n            \"JSON.stringify(db.hello())\",\n        ]\n    )\n    if res.returncode != 0:\n        detail = res.stderr.strip() or res.stdout.strip() or f\"exit {res.returncode}\"\n        errors.append(f\"mongo-client connectivity failed: {detail}\")\n        return fail(\"External access horizons connectivity check failed:\", errors)\n\n    try:\n        hello = json.loads((res.stdout or \"\").strip())\n    except json.JSONDecodeError:\n        errors.append(\"Unable to parse mongo-client db.hello() output\")\n        return fail(\"External access horizons connectivity check failed:\", errors)\n\n    if hello.get(\"ok\") != 1:\n        errors.append(\"db.hello().ok != 1\")\n    if hello.get(\"setName\") != REPLICA_SET_NAME:\n        errors.append(f\"Connected replica set expected {REPLICA_SET_NAME}, got {hello.get('setName')}\")\n\n    return fail(\"External access horizons connectivity check failed:\", errors)\n\n\ndef main():\n    parser = argparse.ArgumentParser()\n    parser.add_argument(\"--check\", default=\"all\", choices=[\"all\", \"topology\", \"services\", \"connectivity\"])\n    args = parser.parse_args()\n\n    if args.check == \"topology\":\n        return check_topology()\n    if args.check == \"services\":\n        return check_services()\n    if args.check == \"connectivity\":\n        return check_connectivity()\n\n    for fn in (check_topology, check_services, check_connectivity):\n        rc = fn()\n        if rc != 0:\n            return rc\n    print(\"External access horizons verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":173,"startLine":1,"totalLines":173}}}
