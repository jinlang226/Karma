{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01A71UGuCEkWb4w753L8rmMH","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport base64\n3\timport json\n4\timport os\n5\timport subprocess\n6\timport sys\n7\t\n8\t# Param-aware: a workflow may override the file-realm users/passwords, the\n9\t# aggregate secret name, the HTTP service, or the seed index via param_overrides\n10\t# (e.g. custom-users-password-audit renames the users). Defaults equal the\n11\t# standalone hardcoded values, so standalone behaviour is unchanged; this only\n12\t# redirects WHICH live users/secret/index are verified, never loosens the check.\n13\tNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"elasticsearch\")\n14\tSERVICE = os.environ.get(\"BENCH_PARAM_HTTP_SERVICE_NAME\", \"es-http\")\n15\tSECRET = os.environ.get(\"BENCH_PARAM_AGGREGATE_SECRET_NAME\", \"es-file-realm-aggregate\")\n16\tOPS_USER = os.environ.get(\"BENCH_PARAM_OPS_USER\", \"ops-user\")\n17\tOPS_PASS = os.environ.get(\"BENCH_PARAM_OPS_PASSWORD\", \"opspass\")\n18\tREPORT_USER = os.environ.get(\"BENCH_PARAM_REPORT_USER\", \"report-user\")\n19\tREPORT_PASS = os.environ.get(\"BENCH_PARAM_REPORT_PASSWORD\", \"reportpass\")\n20\tINDEX = os.environ.get(\"BENCH_PARAM_SEED_INDEX_NAME\", \"app-data\")\n21\t\n22\t\n23\tdef run(cmd):\n24\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n25\t\n26\t\n27\tdef curl_json(path, user, password, errors):\n28\t    cmd = [\n29\t        \"kubectl\",\n30\t        \"-n\",\n31\t        NAMESPACE,\n32\t        \"exec\",\n33\t        \"curl-test\",\n34\t        \"--\",\n35\t        \"curl\",\n36\t        \"-s\",\n37\t        \"-S\",\n38\t        \"--max-time\",\n39\t        \"10\",\n40\t        \"-k\",\n41\t        \"-u\",\n42\t        f\"{user}:{password}\",\n43\t        f\"https://{SERVICE}.{NAMESPACE}.svc:9200{path}\",\n44\t    ]\n45\t    result = run(cmd)\n46\t    if result.returncode != 0:\n47\t        detail = result.stderr.strip() or result.stdout.strip() or f\"command terminated with exit code {result.returncode}\"\n48\t        errors.append(f\"Failed to query {path} as {user}: {detail}\")\n49\t        return None\n50\t    output = result.stdout.strip()\n51\t    if not output:\n52\t        errors.append(f\"Empty response for {path} as {user}\")\n53\t        return None\n54\t    try:\n55\t        return json.loads(output)\n56\t    except json.JSONDecodeError:\n57\t        errors.append(f\"Failed to parse JSON from {path} as {user}\")\n58\t        return None\n59\t\n60\t\n61\tdef get_secret(errors):\n62\t    result = run(\n63\t        [\n64\t            \"kubectl\",\n65\t            \"-n\",\n66\t            NAMESPACE,\n67\t            \"get\",\n68\t            \"secret\",\n69\t            SECRET,\n70\t            \"-o\",\n71\t            \"json\",\n72\t        ]\n73\t    )\n74\t    if result.returncode != 0:\n75\t        errors.append(f\"Failed to read {SECRET} secret: {result.stderr.strip()}\")\n76\t        return None\n77\t    try:\n78\t        return json.loads(result.stdout)\n79\t    except json.JSONDecodeError:\n80\t        errors.append(f\"Failed to parse {SECRET} secret JSON\")\n81\t        return None\n82\t\n83\t\n84\tdef decode_field(data, key, errors):\n85\t    value = data.get(key)\n86\t    if value is None:\n87\t        errors.append(f\"Missing {key} in {SECRET} secret\")\n88\t        return \"\"\n89\t    try:\n90\t        return base64.b64decode(value).decode(\"utf-8\", \"replace\")\n91\t    except Exception as exc:\n92\t        errors.append(f\"Failed to decode {key} in {SECRET} secret: {exc}\")\n93\t        return \"\"\n94\t\n95\t\n96\tdef parse_users(text):\n97\t    users = set()\n98\t    for line in text.splitlines():\n99\t        line = line.strip()\n100\t        if not line or line.startswith(\"#\"):\n101\t            continue\n102\t        parts = line.split(\":\", 1)\n103\t        if parts:\n104\t            users.add(parts[0].strip())\n105\t    return users\n106\t\n107\t\n108\tdef parse_users_roles(text):\n109\t    users = set()\n110\t    for line in text.splitlines():\n111\t        line = line.strip()\n112\t        if not line or line.startswith(\"#\"):\n113\t            continue\n114\t        parts = line.split(\":\", 1)\n115\t        if len(parts) != 2:\n116\t            continue\n117\t        for user in parts[1].split(\",\"):\n118\t            user = user.strip()\n119\t            if user:\n120\t                users.add(user)\n121\t    return users\n122\t\n123\t\n124\tdef main():\n125\t    errors = []\n126\t\n127\t    secret = get_secret(errors)\n128\t    if secret is None:\n129\t        print_errors(errors)\n130\t        return 1\n131\t\n132\t    data = secret.get(\"data\", {})\n133\t    users_text = decode_field(data, \"users\", errors)\n134\t    users_roles_text = decode_field(data, \"users_roles\", errors)\n135\t\n136\t    expected = {OPS_USER, REPORT_USER}\n137\t    users = parse_users(users_text)\n138\t    missing_users = sorted(expected - users)\n139\t    if missing_users:\n140\t        errors.append(f\"Missing users in {SECRET}: {', '.join(missing_users)}\")\n141\t\n142\t    users_roles = parse_users_roles(users_roles_text)\n143\t    missing_roles = sorted(expected - users_roles)\n144\t    if missing_roles:\n145\t        errors.append(\n146\t            f\"Missing users in {SECRET} users_roles: {', '.join(missing_roles)}\"\n147\t        )\n148\t\n149\t    health = curl_json(\"/_cluster/health\", OPS_USER, OPS_PASS, errors)\n150\t    if isinstance(health, dict):\n151\t        status = health.get(\"status\")\n152\t        if status not in {\"yellow\", \"green\"}:\n153\t            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n154\t\n155\t    count = curl_json(f\"/{INDEX}/_count\", REPORT_USER, REPORT_PASS, errors)\n156\t    if isinstance(count, dict):\n157\t        if \"count\" not in count:\n158\t            errors.append(\"report-user failed to read app-data count\")\n159\t\n160\t    if errors:\n161\t        print_errors(errors)\n162\t        return 1\n163\t\n164\t    print(\"File realm merge verified\")\n165\t    return 0\n166\t\n167\t\n168\tdef print_errors(errors):\n169\t    print(\"File realm merge verification failed:\", file=sys.stderr)\n170\t    for err in errors:\n171\t        print(f\"  - {err}\", file=sys.stderr)\n172\t\n173\t\n174\tif __name__ == \"__main__\":\n175\t    sys.exit(main())\n176\t"}]},"parent_tool_use_id":null,"session_id":"1f65fe4f-c207-4ded-b85e-3b3711f38e9c","uuid":"5d45d68e-2fd8-4325-b24e-c5d75c83e506","timestamp":"2026-06-15T01:15:17.184Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/leo/Karma/cases/elasticsearch/file-realm-user-roles-merge/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport base64\nimport json\nimport os\nimport subprocess\nimport sys\n\n# Param-aware: a workflow may override the file-realm users/passwords, the\n# aggregate secret name, the HTTP service, or the seed index via param_overrides\n# (e.g. custom-users-password-audit renames the users). Defaults equal the\n# standalone hardcoded values, so standalone behaviour is unchanged; this only\n# redirects WHICH live users/secret/index are verified, never loosens the check.\nNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"elasticsearch\")\nSERVICE = os.environ.get(\"BENCH_PARAM_HTTP_SERVICE_NAME\", \"es-http\")\nSECRET = os.environ.get(\"BENCH_PARAM_AGGREGATE_SECRET_NAME\", \"es-file-realm-aggregate\")\nOPS_USER = os.environ.get(\"BENCH_PARAM_OPS_USER\", \"ops-user\")\nOPS_PASS = os.environ.get(\"BENCH_PARAM_OPS_PASSWORD\", \"opspass\")\nREPORT_USER = os.environ.get(\"BENCH_PARAM_REPORT_USER\", \"report-user\")\nREPORT_PASS = os.environ.get(\"BENCH_PARAM_REPORT_PASSWORD\", \"reportpass\")\nINDEX = os.environ.get(\"BENCH_PARAM_SEED_INDEX_NAME\", \"app-data\")\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef curl_json(path, user, password, errors):\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"exec\",\n        \"curl-test\",\n        \"--\",\n        \"curl\",\n        \"-s\",\n        \"-S\",\n        \"--max-time\",\n        \"10\",\n        \"-k\",\n        \"-u\",\n        f\"{user}:{password}\",\n        f\"https://{SERVICE}.{NAMESPACE}.svc:9200{path}\",\n    ]\n    result = run(cmd)\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"command terminated with exit code {result.returncode}\"\n        errors.append(f\"Failed to query {path} as {user}: {detail}\")\n        return None\n    output = result.stdout.strip()\n    if not output:\n        errors.append(f\"Empty response for {path} as {user}\")\n        return None\n    try:\n        return json.loads(output)\n    except json.JSONDecodeError:\n        errors.append(f\"Failed to parse JSON from {path} as {user}\")\n        return None\n\n\ndef get_secret(errors):\n    result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"get\",\n            \"secret\",\n            SECRET,\n            \"-o\",\n            \"json\",\n        ]\n    )\n    if result.returncode != 0:\n        errors.append(f\"Failed to read {SECRET} secret: {result.stderr.strip()}\")\n        return None\n    try:\n        return json.loads(result.stdout)\n    except json.JSONDecodeError:\n        errors.append(f\"Failed to parse {SECRET} secret JSON\")\n        return None\n\n\ndef decode_field(data, key, errors):\n    value = data.get(key)\n    if value is None:\n        errors.append(f\"Missing {key} in {SECRET} secret\")\n        return \"\"\n    try:\n        return base64.b64decode(value).decode(\"utf-8\", \"replace\")\n    except Exception as exc:\n        errors.append(f\"Failed to decode {key} in {SECRET} secret: {exc}\")\n        return \"\"\n\n\ndef parse_users(text):\n    users = set()\n    for line in text.splitlines():\n        line = line.strip()\n        if not line or line.startswith(\"#\"):\n            continue\n        parts = line.split(\":\", 1)\n        if parts:\n            users.add(parts[0].strip())\n    return users\n\n\ndef parse_users_roles(text):\n    users = set()\n    for line in text.splitlines():\n        line = line.strip()\n        if not line or line.startswith(\"#\"):\n            continue\n        parts = line.split(\":\", 1)\n        if len(parts) != 2:\n            continue\n        for user in parts[1].split(\",\"):\n            user = user.strip()\n            if user:\n                users.add(user)\n    return users\n\n\ndef main():\n    errors = []\n\n    secret = get_secret(errors)\n    if secret is None:\n        print_errors(errors)\n        return 1\n\n    data = secret.get(\"data\", {})\n    users_text = decode_field(data, \"users\", errors)\n    users_roles_text = decode_field(data, \"users_roles\", errors)\n\n    expected = {OPS_USER, REPORT_USER}\n    users = parse_users(users_text)\n    missing_users = sorted(expected - users)\n    if missing_users:\n        errors.append(f\"Missing users in {SECRET}: {', '.join(missing_users)}\")\n\n    users_roles = parse_users_roles(users_roles_text)\n    missing_roles = sorted(expected - users_roles)\n    if missing_roles:\n        errors.append(\n            f\"Missing users in {SECRET} users_roles: {', '.join(missing_roles)}\"\n        )\n\n    health = curl_json(\"/_cluster/health\", OPS_USER, OPS_PASS, errors)\n    if isinstance(health, dict):\n        status = health.get(\"status\")\n        if status not in {\"yellow\", \"green\"}:\n            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n\n    count = curl_json(f\"/{INDEX}/_count\", REPORT_USER, REPORT_PASS, errors)\n    if isinstance(count, dict):\n        if \"count\" not in count:\n            errors.append(\"report-user failed to read app-data count\")\n\n    if errors:\n        print_errors(errors)\n        return 1\n\n    print(\"File realm merge verified\")\n    return 0\n\n\ndef print_errors(errors):\n    print(\"File realm merge verification failed:\", file=sys.stderr)\n    for err in errors:\n        print(f\"  - {err}\", file=sys.stderr)\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":176,"startLine":1,"totalLines":176}}}
