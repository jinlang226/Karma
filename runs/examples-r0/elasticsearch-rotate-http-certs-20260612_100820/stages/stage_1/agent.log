{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01G8GghP84d14swgA3fDnjm1","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport base64\n3\timport datetime\n4\timport subprocess\n5\timport sys\n6\timport tempfile\n7\timport json\n8\t\n9\tNAMESPACE = \"elasticsearch\"\n10\tSECRET = \"es-http-tls\"\n11\tOLD_CM = \"es-http-old\"\n12\tCLIENT_CA_CM = \"es-http-ca\"\n13\tSERVICE = \"es-http\"\n14\tCURL_POD = \"curl-test\"\n15\tMIN_VALID_DAYS = 300\n16\tMAX_VALID_DAYS = 400\n17\t\n18\t\n19\tdef run(cmd):\n20\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n21\t\n22\t\n23\tdef get_secret_data(key, errors):\n24\t    json_key = key.replace(\".\", \"\\\\.\")\n25\t    cmd = [\n26\t        \"kubectl\",\n27\t        \"-n\",\n28\t        NAMESPACE,\n29\t        \"get\",\n30\t        \"secret\",\n31\t        SECRET,\n32\t        \"-o\",\n33\t        f\"jsonpath={{.data.{json_key}}}\",\n34\t    ]\n35\t    result = run(cmd)\n36\t    if result.returncode != 0:\n37\t        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n38\t        errors.append(f\"Failed to read secret {SECRET} {key}: {detail}\")\n39\t        return None\n40\t    raw = result.stdout.strip()\n41\t    if not raw:\n42\t        errors.append(f\"Secret {SECRET} missing key {key}\")\n43\t        return None\n44\t    try:\n45\t        return base64.b64decode(raw)\n46\t    except base64.binascii.Error:\n47\t        errors.append(f\"Secret {SECRET} key {key} is not valid base64\")\n48\t        return None\n49\t\n50\t\n51\tdef get_configmap_text(name, key, errors):\n52\t    json_key = key.replace(\".\", \"\\\\.\")\n53\t    cmd = [\n54\t        \"kubectl\",\n55\t        \"-n\",\n56\t        NAMESPACE,\n57\t        \"get\",\n58\t        \"configmap\",\n59\t        name,\n60\t        \"-o\",\n61\t        f\"jsonpath={{.data.{json_key}}}\",\n62\t    ]\n63\t    result = run(cmd)\n64\t    if result.returncode != 0:\n65\t        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n66\t        errors.append(f\"Failed to read configmap {name} {key}: {detail}\")\n67\t        return None\n68\t    return result.stdout.strip()\n69\t\n70\t\n71\tdef openssl_fingerprint(path, errors, label):\n72\t    result = run([\"openssl\", \"x509\", \"-noout\", \"-fingerprint\", \"-sha256\", \"-in\", path])\n73\t    if result.returncode != 0:\n74\t        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n75\t        errors.append(f\"Failed to read fingerprint for {label}: {detail}\")\n76\t        return None\n77\t    line = result.stdout.strip()\n78\t    if \"=\" not in line:\n79\t        errors.append(f\"Unexpected fingerprint output for {label}: {line}\")\n80\t        return None\n81\t    return line.split(\"=\", 1)[1].strip()\n82\t\n83\t\n84\tdef openssl_not_after(path, errors):\n85\t    result = run([\"openssl\", \"x509\", \"-noout\", \"-enddate\", \"-in\", path])\n86\t    if result.returncode != 0:\n87\t        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n88\t        errors.append(f\"Failed to read NotAfter from leaf cert: {detail}\")\n89\t        return None\n90\t    line = result.stdout.strip()\n91\t    if not line.startswith(\"notAfter=\"):\n92\t        errors.append(f\"Unexpected NotAfter output: {line}\")\n93\t        return None\n94\t    value = line.split(\"=\", 1)[1].strip()\n95\t    try:\n96\t        ts = datetime.datetime.strptime(value, \"%b %d %H:%M:%S %Y %Z\")\n97\t    except ValueError:\n98\t        errors.append(f\"Unable to parse NotAfter date: {value}\")\n99\t        return None\n100\t    return ts.replace(tzinfo=datetime.timezone.utc)\n101\t\n102\t\n103\tdef verify_cert(ca_path, cert_path):\n104\t    return run([\"openssl\", \"verify\", \"-CAfile\", ca_path, cert_path])\n105\t\n106\t\n107\tdef curl_health(errors):\n108\t    result = run(\n109\t        [\n110\t            \"kubectl\",\n111\t            \"-n\",\n112\t            NAMESPACE,\n113\t            \"exec\",\n114\t            CURL_POD,\n115\t            \"--\",\n116\t            \"curl\",\n117\t            \"-s\",\n118\t            \"-S\",\n119\t            \"--max-time\",\n120\t            \"5\",\n121\t            \"--cacert\",\n122\t            \"/etc/es-http-ca/ca.crt\",\n123\t            \"-u\",\n124\t            \"elastic:elasticpass\",\n125\t            f\"https://{SERVICE}.{NAMESPACE}.svc:9200/_cluster/health?wait_for_status=yellow&timeout=5s\",\n126\t        ]\n127\t    )\n128\t    if result.returncode != 0:\n129\t        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n130\t        errors.append(f\"HTTPS health check failed: {detail}\")\n131\t        return\n132\t    output = result.stdout.strip()\n133\t    if not output:\n134\t        errors.append(\"HTTPS health check returned empty response\")\n135\t        return\n136\t    try:\n137\t        data = json.loads(output)\n138\t    except json.JSONDecodeError:\n139\t        errors.append(\"HTTPS health check returned invalid JSON\")\n140\t        return\n141\t    status = data.get(\"status\")\n142\t    if status not in {\"yellow\", \"green\"}:\n143\t        errors.append(f\"Cluster health expected yellow/green, got {status}\")\n144\t\n145\t\n146\tdef main():\n147\t    errors = []\n148\t\n149\t    old_ca_fp = get_configmap_text(OLD_CM, \"ca_fingerprint_sha256\", errors)\n150\t    old_leaf_fp = get_configmap_text(OLD_CM, \"leaf_fingerprint_sha256\", errors)\n151\t    old_ca_pem = get_configmap_text(OLD_CM, \"ca.crt\", errors)\n152\t    client_ca_pem = get_configmap_text(CLIENT_CA_CM, \"ca.crt\", errors)\n153\t\n154\t    if errors:\n155\t        print(\"HTTP cert rotation verification failed:\", file=sys.stderr)\n156\t        for err in errors:\n157\t            print(f\"  - {err}\", file=sys.stderr)\n158\t        return 1\n159\t\n160\t    with tempfile.TemporaryDirectory() as tmpdir:\n161\t        ca_path = f\"{tmpdir}/ca.crt\"\n162\t        leaf_path = f\"{tmpdir}/tls.crt\"\n163\t        old_ca_path = f\"{tmpdir}/old-ca.crt\"\n164\t        client_ca_path = f\"{tmpdir}/client-ca.crt\"\n165\t\n166\t        new_ca = get_secret_data(\"ca.crt\", errors)\n167\t        new_leaf = get_secret_data(\"tls.crt\", errors)\n168\t\n169\t        if new_ca is not None:\n170\t            with open(ca_path, \"wb\") as f:\n171\t                f.write(new_ca)\n172\t        if new_leaf is not None:\n173\t            with open(leaf_path, \"wb\") as f:\n174\t                f.write(new_leaf)\n175\t        if old_ca_pem is not None:\n176\t            with open(old_ca_path, \"w\", encoding=\"utf-8\") as f:\n177\t                f.write(old_ca_pem)\n178\t        if client_ca_pem is not None:\n179\t            with open(client_ca_path, \"w\", encoding=\"utf-8\") as f:\n180\t                f.write(client_ca_pem)\n181\t\n182\t        if new_ca is None or new_leaf is None:\n183\t            errors.append(\"Missing TLS data from es-http-tls secret\")\n184\t        else:\n185\t            new_ca_fp = openssl_fingerprint(ca_path, errors, \"new CA\")\n186\t            new_leaf_fp = openssl_fingerprint(leaf_path, errors, \"new leaf\")\n187\t            if new_ca_fp and old_ca_fp and new_ca_fp == old_ca_fp:\n188\t                errors.append(\"CA fingerprint did not change\")\n189\t            if new_leaf_fp and old_leaf_fp and new_leaf_fp == old_leaf_fp:\n190\t                errors.append(\"Leaf fingerprint did not change\")\n191\t\n192\t            if new_ca_fp and client_ca_pem:\n193\t                client_fp = openssl_fingerprint(client_ca_path, errors, \"client CA\")\n194\t                if client_fp and client_fp != new_ca_fp:\n195\t                    errors.append(\"Client CA does not match new CA\")\n196\t\n197\t            not_after = openssl_not_after(leaf_path, errors)\n198\t            if not_after:\n199\t                now = datetime.datetime.now(datetime.timezone.utc)\n200\t                days_remaining = (not_after - now).days\n201\t                if days_remaining < MIN_VALID_DAYS or days_remaining > MAX_VALID_DAYS:\n202\t                    errors.append(\n203\t                        f\"Leaf validity {days_remaining} days out of expected range ({MIN_VALID_DAYS}-{MAX_VALID_DAYS})\"\n204\t                    )\n205\t\n206\t            if new_ca_fp:\n207\t                verify_new = verify_cert(ca_path, leaf_path)\n208\t                if verify_new.returncode != 0:\n209\t                    detail = verify_new.stderr.strip() or verify_new.stdout.strip()\n210\t                    errors.append(f\"Leaf does not verify with new CA: {detail}\")\n211\t\n212\t                verify_old = verify_cert(old_ca_path, leaf_path)\n213\t                if verify_old.returncode == 0:\n214\t                    errors.append(\"Leaf still verifies with old CA\")\n215\t\n216\t        curl_health(errors)\n217\t\n218\t    if errors:\n219\t        print(\"HTTP cert rotation verification failed:\", file=sys.stderr)\n220\t        for err in errors:\n221\t            print(f\"  - {err}\", file=sys.stderr)\n222\t        return 1\n223\t\n224\t    print(\"HTTP cert rotation verified\")\n225\t    return 0\n226\t\n227\t\n228\tif __name__ == \"__main__\":\n229\t    sys.exit(main())\n230\t"}]},"parent_tool_use_id":null,"session_id":"9eb29c50-c508-4f87-8a38-36ea9575a99e","uuid":"7d54ae06-408d-4763-a6d2-70055c7c331c","timestamp":"2026-06-12T10:10:10.570Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/leo/Karma/resources/elasticsearch/rotate-http-certs/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport base64\nimport datetime\nimport subprocess\nimport sys\nimport tempfile\nimport json\n\nNAMESPACE = \"elasticsearch\"\nSECRET = \"es-http-tls\"\nOLD_CM = \"es-http-old\"\nCLIENT_CA_CM = \"es-http-ca\"\nSERVICE = \"es-http\"\nCURL_POD = \"curl-test\"\nMIN_VALID_DAYS = 300\nMAX_VALID_DAYS = 400\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef get_secret_data(key, errors):\n    json_key = key.replace(\".\", \"\\\\.\")\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"get\",\n        \"secret\",\n        SECRET,\n        \"-o\",\n        f\"jsonpath={{.data.{json_key}}}\",\n    ]\n    result = run(cmd)\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errors.append(f\"Failed to read secret {SECRET} {key}: {detail}\")\n        return None\n    raw = result.stdout.strip()\n    if not raw:\n        errors.append(f\"Secret {SECRET} missing key {key}\")\n        return None\n    try:\n        return base64.b64decode(raw)\n    except base64.binascii.Error:\n        errors.append(f\"Secret {SECRET} key {key} is not valid base64\")\n        return None\n\n\ndef get_configmap_text(name, key, errors):\n    json_key = key.replace(\".\", \"\\\\.\")\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"get\",\n        \"configmap\",\n        name,\n        \"-o\",\n        f\"jsonpath={{.data.{json_key}}}\",\n    ]\n    result = run(cmd)\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errors.append(f\"Failed to read configmap {name} {key}: {detail}\")\n        return None\n    return result.stdout.strip()\n\n\ndef openssl_fingerprint(path, errors, label):\n    result = run([\"openssl\", \"x509\", \"-noout\", \"-fingerprint\", \"-sha256\", \"-in\", path])\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errors.append(f\"Failed to read fingerprint for {label}: {detail}\")\n        return None\n    line = result.stdout.strip()\n    if \"=\" not in line:\n        errors.append(f\"Unexpected fingerprint output for {label}: {line}\")\n        return None\n    return line.split(\"=\", 1)[1].strip()\n\n\ndef openssl_not_after(path, errors):\n    result = run([\"openssl\", \"x509\", \"-noout\", \"-enddate\", \"-in\", path])\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errors.append(f\"Failed to read NotAfter from leaf cert: {detail}\")\n        return None\n    line = result.stdout.strip()\n    if not line.startswith(\"notAfter=\"):\n        errors.append(f\"Unexpected NotAfter output: {line}\")\n        return None\n    value = line.split(\"=\", 1)[1].strip()\n    try:\n        ts = datetime.datetime.strptime(value, \"%b %d %H:%M:%S %Y %Z\")\n    except ValueError:\n        errors.append(f\"Unable to parse NotAfter date: {value}\")\n        return None\n    return ts.replace(tzinfo=datetime.timezone.utc)\n\n\ndef verify_cert(ca_path, cert_path):\n    return run([\"openssl\", \"verify\", \"-CAfile\", ca_path, cert_path])\n\n\ndef curl_health(errors):\n    result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"exec\",\n            CURL_POD,\n            \"--\",\n            \"curl\",\n            \"-s\",\n            \"-S\",\n            \"--max-time\",\n            \"5\",\n            \"--cacert\",\n            \"/etc/es-http-ca/ca.crt\",\n            \"-u\",\n            \"elastic:elasticpass\",\n            f\"https://{SERVICE}.{NAMESPACE}.svc:9200/_cluster/health?wait_for_status=yellow&timeout=5s\",\n        ]\n    )\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errors.append(f\"HTTPS health check failed: {detail}\")\n        return\n    output = result.stdout.strip()\n    if not output:\n        errors.append(\"HTTPS health check returned empty response\")\n        return\n    try:\n        data = json.loads(output)\n    except json.JSONDecodeError:\n        errors.append(\"HTTPS health check returned invalid JSON\")\n        return\n    status = data.get(\"status\")\n    if status not in {\"yellow\", \"green\"}:\n        errors.append(f\"Cluster health expected yellow/green, got {status}\")\n\n\ndef main():\n    errors = []\n\n    old_ca_fp = get_configmap_text(OLD_CM, \"ca_fingerprint_sha256\", errors)\n    old_leaf_fp = get_configmap_text(OLD_CM, \"leaf_fingerprint_sha256\", errors)\n    old_ca_pem = get_configmap_text(OLD_CM, \"ca.crt\", errors)\n    client_ca_pem = get_configmap_text(CLIENT_CA_CM, \"ca.crt\", errors)\n\n    if errors:\n        print(\"HTTP cert rotation verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    with tempfile.TemporaryDirectory() as tmpdir:\n        ca_path = f\"{tmpdir}/ca.crt\"\n        leaf_path = f\"{tmpdir}/tls.crt\"\n        old_ca_path = f\"{tmpdir}/old-ca.crt\"\n        client_ca_path = f\"{tmpdir}/client-ca.crt\"\n\n        new_ca = get_secret_data(\"ca.crt\", errors)\n        new_leaf = get_secret_data(\"tls.crt\", errors)\n\n        if new_ca is not None:\n            with open(ca_path, \"wb\") as f:\n                f.write(new_ca)\n        if new_leaf is not None:\n            with open(leaf_path, \"wb\") as f:\n                f.write(new_leaf)\n        if old_ca_pem is not None:\n            with open(old_ca_path, \"w\", encoding=\"utf-8\") as f:\n                f.write(old_ca_pem)\n        if client_ca_pem is not None:\n            with open(client_ca_path, \"w\", encoding=\"utf-8\") as f:\n                f.write(client_ca_pem)\n\n        if new_ca is None or new_leaf is None:\n            errors.append(\"Missing TLS data from es-http-tls secret\")\n        else:\n            new_ca_fp = openssl_fingerprint(ca_path, errors, \"new CA\")\n            new_leaf_fp = openssl_fingerprint(leaf_path, errors, \"new leaf\")\n            if new_ca_fp and old_ca_fp and new_ca_fp == old_ca_fp:\n                errors.append(\"CA fingerprint did not change\")\n            if new_leaf_fp and old_leaf_fp and new_leaf_fp == old_leaf_fp:\n                errors.append(\"Leaf fingerprint did not change\")\n\n            if new_ca_fp and client_ca_pem:\n                client_fp = openssl_fingerprint(client_ca_path, errors, \"client CA\")\n                if client_fp and client_fp != new_ca_fp:\n                    errors.append(\"Client CA does not match new CA\")\n\n            not_after = openssl_not_after(leaf_path, errors)\n            if not_after:\n                now = datetime.datetime.now(datetime.timezone.utc)\n                days_remaining = (not_after - now).days\n                if days_remaining < MIN_VALID_DAYS or days_remaining > MAX_VALID_DAYS:\n                    errors.append(\n                        f\"Leaf validity {days_remaining} days out of expected range ({MIN_VALID_DAYS}-{MAX_VALID_DAYS})\"\n                    )\n\n            if new_ca_fp:\n                verify_new = verify_cert(ca_path, leaf_path)\n                if verify_new.returncode != 0:\n                    detail = verify_new.stderr.strip() or verify_new.stdout.strip()\n                    errors.append(f\"Leaf does not verify with new CA: {detail}\")\n\n                verify_old = verify_cert(old_ca_path, leaf_path)\n                if verify_old.returncode == 0:\n                    errors.append(\"Leaf still verifies with old CA\")\n\n        curl_health(errors)\n\n    if errors:\n        print(\"HTTP cert rotation verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    print(\"HTTP cert rotation verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":230,"startLine":1,"totalLines":230}}}
