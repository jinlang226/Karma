{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01C6vqHEDJpAScFSEKGLsdbF","type":"tool_result","content":"# cockroachdb/certificate-rotation\n# Rotate TLS certificates for a running CockroachDB cluster with ~1 year validity\n\nprompt: |\n  Rotate the TLS certificates for the running CockroachDB cluster.\n  The new certificates should be valid for about 1 year.\n  The existing CA key and cert are available in the openssl-toolbox pod at\n  /tmp/certs/ca.key and /tmp/certs/ca.crt.\n\n  Verification:\n  1. Secure SQL works:\n     kubectl -n cockroachdb exec crdb-cluster-0 -- \\\n       ./cockroach sql --certs-dir=/cockroach/cockroach-certs -e \"SELECT 1;\"\n\n  2. Node cert rotated:\n     kubectl -n cockroachdb get secret {{params.cert_secret_name}} -o jsonpath='{.data.node\\.crt}' | base64 -d | \\\n       openssl x509 -noout -fingerprint -sha256\n\n  3. New cert validity about 1 year:\n     kubectl -n cockroachdb get secret {{params.cert_secret_name}} -o jsonpath='{.data.node\\.crt}' | base64 -d | \\\n       openssl x509 -noout -enddate\n\nparams:\n  cert_secret_name:\n    default: crdb-cluster-certs\n    description: Kubernetes secret holding the cluster TLS certificates\n  old_cert_configmap_name:\n    default: crdb-old-cert\n    description: ConfigMap recording the pre-rotation certificate fingerprints\n\nnamespace_contract:\n  required_roles: []\n\nmetrics:\n  - time_to_first_mutation\n  - destructive_ops\n\npreconditionUnits:\n  - name: crdb_env_ready\n    on_probe_fail: skip\n    probe:\n      # Non-destructive skip-if-running probe. The env PERSISTS across workflow\n      # stages: when a cockroachdb cluster is already present (inherited from a\n      # prior stage), skip the destructive apply so accumulated state is\n      # preserved. The apply (which deletes+recreates the namespace) runs ONLY on\n      # an empty namespace.\n      - command: \"kubectl -n cockroachdb get pods 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n    apply:\n      - command: \"/bin/sh -c 'kubectl delete namespace cockroachdb --ignore-not-found=true; kubectl wait --for=delete namespace/cockroachdb --timeout=120s || true'\"\n        sleep: 2\n      - command: \"kubectl create namespace cockroachdb\"\n        sleep: 1\n      - command: \"kubectl -n cockroachdb apply -f cases/cockroachdb/certificate-rotation/resource/rbac.yaml\"\n        sleep: 2\n      - command: \"kubectl -n cockroachdb apply -f cases/cockroachdb/certificate-rotation/resource/services.yaml\"\n        sleep: 2\n      - command: \"kubectl -n cockroachdb apply -f cases/cockroachdb/certificate-rotation/resource/openssl-toolbox.yaml\"\n        sleep: 2\n      - command: \"kubectl -n cockroachdb wait --for=condition=ready pod/openssl-toolbox --timeout=120s\"\n        timeout_sec: 600\n        sleep: 2\n      - command: \"kubectl -n cockroachdb exec -i openssl-toolbox -- sh -s < cases/cockroachdb/certificate-rotation/resource/gen-old-certs.sh\"\n        timeout_sec: 120\n        sleep: 2\n      - command: \"/bin/sh -c 'rm -rf /tmp/crdb-old-certs; kubectl -n cockroachdb cp openssl-toolbox:/tmp/certs /tmp/crdb-old-certs'\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n cockroachdb create secret generic {{params.cert_secret_name}} --from-file=ca.crt=/tmp/crdb-old-certs/ca.crt --from-file=node.crt=/tmp/crdb-old-certs/node.crt --from-file=node.key=/tmp/crdb-old-certs/node.key --from-file=client.root.crt=/tmp/crdb-old-certs/client.root.crt --from-file=client.root.key=/tmp/crdb-old-certs/client.root.key --dry-run=client -o yaml | kubectl apply -f -'\"\n        sleep: 1\n      - command: \"/bin/sh -c 'fingerprint=$(openssl x509 -noout -fingerprint -sha256 -in /tmp/crdb-old-certs/node.crt | sed \\\"s/.*=//\\\"); ca_fingerprint=$(openssl x509 -noout -fingerprint -sha256 -in /tmp/crdb-old-certs/ca.crt | sed \\\"s/.*=//\\\"); not_after=$(openssl x509 -noout -enddate -in /tmp/crdb-old-certs/node.crt | sed \\\"s/notAfter=//\\\"); kubectl -n cockroachdb create configmap {{params.old_cert_configmap_name}} --from-literal=fingerprint=\\\"$fingerprint\\\" --from-literal=ca_fingerprint=\\\"$ca_fingerprint\\\" --from-literal=not_after=\\\"$not_after\\\" --dry-run=client -o yaml | kubectl apply -f -'\"\n        sleep: 1\n      - command: \"kubectl -n cockroachdb apply -f cases/cockroachdb/certificate-rotation/resource/statefulset.yaml\"\n        sleep: 5\n      - command: \"/bin/sh -c 'for i in $(seq 1 30); do count=$(kubectl -n cockroachdb get pod -l app.kubernetes.io/name=cockroachdb --no-headers 2>/dev/null | wc -l | tr -d \\\" \\\"); if [ \\\"${count}\\\" -ge 1 ]; then exit 0; fi; sleep 2; done; exit 1'\"\n        sleep: 1\n      - command: \"kubectl -n cockroachdb wait --for=jsonpath={.status.phase}=Running pod -l app.kubernetes.io/name=cockroachdb --timeout=300s\"\n        timeout_sec: 600\n        sleep: 5\n      - command: \"/bin/sh -c 'for i in $(seq 1 30); do kubectl -n cockroachdb exec crdb-cluster-0 -- ./cockroach init --certs-dir=/cockroach/cockroach-certs --host=crdb-cluster-0.crdb-cluster.cockroachdb.svc.cluster.local && exit 0; sleep 3; done; exit 1'\"\n        timeout_sec: 600\n        sleep: 2\n      - command: \"kubectl -n cockroachdb rollout status statefulset/crdb-cluster --timeout=300s\"\n        timeout_sec: 600\n        sleep: 10\n    verify:\n      - command: \"kubectl -n cockroachdb get pods 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n\noracle:\n  verify:\n    commands:\n      - command: \"python3 cases/cockroachdb/certificate-rotation/oracle/oracle.py\"\n        timeout_sec: 60","is_error":false}]},"parent_tool_use_id":null,"session_id":"e62857f4-6357-41ec-bc3e-884756180d33","uuid":"2cbf6838-2bd9-4ea8-865c-95bea73f342e","timestamp":"2026-06-15T00:48:58.610Z","tool_use_result":{"stdout":"# cockroachdb/certificate-rotation\n# Rotate TLS certificates for a running CockroachDB cluster with ~1 year validity\n\nprompt: |\n  Rotate the TLS certificates for the running CockroachDB cluster