s must be valid for about 1 year.\n- Ensure clients can trust the new CA.\n\nGOAL:\n- Cluster remains available and new certs are served.\n\nReminder: the elastic-password Secret may have been corrupted. Re-check the Secret value\nand confirm Elasticsearch accepts the credential before finishing.---\n[precondition:es_env_ready:preconditionUnits[0] 'es_env_ready':probe] $ kubectl -n elasticsearch get pods 2>/dev/null | grep -c Running\n6\n\n[precondition:capture_http_cert_baseline:preconditionUnits[1] 'capture_http_cert_baseline':probe] $ kubectl -n elasticsearch get configmap es-http-old\nError from server (NotFound): configmaps \"es-http-old\" not found\n\n[precondition:capture_http_cert_baseline:preconditionUnits[1] 'capture_http_cert_baseline':apply] $ /bin/sh -c '\nset -e\nT=$(mktemp -d)\nkubectl -n elasticsearch get secret es-http-tls -o jsonpath=\"{.data.ca\\.crt}\" | base64 -d > \"$T/ca.crt\"\nkubectl -n elasticsearch get secret es-http-tls -o jsonpath=\"{.data.tls\\.crt}\" | base64 -d > \"$T/tls.crt\"\nkubectl -n elasticsearch create configmap es-http-ca --from-file=ca.crt=\"$T/ca.crt\" --dry-run=client -o yaml | kubectl apply -f -\nCA_FP=$(openssl x509 -noout -fingerprint -sha256 -in \"$T/ca.crt\" | cut -d= -f2)\nLEAF_FP=$(openssl x509 -noout -fingerprint -sha256 -in \"$T/tls.crt\" | cut -d= -f2)\nkubectl -n elasticsearch create configmap es-http-old --from-file=ca.crt=\"$T/ca.crt\" --from-literal=ca_fingerprint_sha256=\"$CA_FP\" --from-literal=leaf_fingerprint_sha256=\"$LEAF_FP\" --dry-run=client -o yaml | kubectl apply -f -\n'\n\nconfigmap/es-http-ca created\nconfigmap/es-http-old created\n\n[precondition:capture_http_cert_baseline:preconditionUnits[1] 'capture_http_cert_baseline':verify] $ kubectl -n elasticsearch get configmap es-http-old -o jsonpath='{.data.ca_fingerprint_sha256}'\nB7:35:AA:13:C6:8C:69:7B:EF:56:5A:83:B0:80:6D:79:C9:75:AD:6B:05:F5:84:02:D2:C0:E4:70:D6:A2:10:0B\n---AGENT---\n{\"type\":\"system\",\"subtype\":\"init\",\"cwd\":\"/mydata/kar