{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_018VdfL1koPM8eXqjcupJ68s","type":"tool_result","content":"1\t#!/usr/bin/env bash\n2\t# Rollback script: reverts non-default CockroachDB configuration to factory defaults.\n3\t# Configuration snapshot taken 2026-06-14 from namespace cockroachdb, pod crdb-cluster-0.\n4\t#\n5\t# NON-DEFAULT STATE FOUND:\n6\t#   cluster setting  kv.snapshot_rebalance.max_rate  = 1.0 MiB  (default: 32 MiB)\n7\t#   cluster setting  diagnostics.reporting.enabled   = true     (default: false)\n8\t#   zone config      RANGE default  gc.ttlseconds    = 14400 s  (default: 90000 s / 25 h)\n9\t#\n10\t# EXCLUDED (intentionally not reverted):\n11\t#   cluster.secret  — cluster identity UUID; resetting breaks replication\n12\t#   version         — cluster upgrade level; CockroachDB does not support downgrade\n13\t#\n14\t# Do NOT run until a change window is open. All three changes take effect immediately\n15\t# and alter live cluster behaviour (GC cadence, rebalance throughput, telemetry).\n16\t\n17\tset -euo pipefail\n18\t\n19\tNAMESPACE=\"${NAMESPACE:-cockroachdb}\"\n20\tPOD=\"${POD:-crdb-cluster-0}\"\n21\tCOCKROACH=\"./cockroach\"\n22\t\n23\tsql() {\n24\t  kubectl -n \"$NAMESPACE\" exec \"$POD\" -- \"$COCKROACH\" sql --insecure -e \"$1\"\n25\t}\n26\t\n27\techo \"=== [1/3] Resetting kv.snapshot_rebalance.max_rate to default (32 MiB) ===\"\n28\tsql \"RESET CLUSTER SETTING kv.snapshot_rebalance.max_rate;\"\n29\t\n30\techo \"=== [2/3] Resetting diagnostics.reporting.enabled to default (false) ===\"\n31\tsql \"RESET CLUSTER SETTING diagnostics.reporting.enabled;\"\n32\t\n33\techo \"=== [3/3] Resetting RANGE default gc.ttlseconds to default (90000 s) ===\"\n34\tsql \"ALTER RANGE default CONFIGURE ZONE USING gc.ttlseconds = 90000;\"\n35\t\n36\techo \"\"\n37\techo \"=== Post-rollback verification: remaining non-default cluster settings ===\"\n38\tsql \"SELECT variable, value, default_value\n39\t     FROM crdb_internal.cluster_settings\n40\t     WHERE value != default_value\n41\t     ORDER BY variable;\"\n42\t\n43\techo \"\"\n44\techo \"=== Post-rollback verification: RANGE default zone config ===\"\n45\tsql \"SELECT target, raw_config_sql\n46\t     FROM crdb_internal.zones\n47\t     WHERE target = 'RANGE default';\"\n48\t\n49\techo \"Rollback complete.\"\n50\t"}]},"parent_tool_use_id":null,"session_id":"8a5b4a78-ed46-4e06-8aac-06a06e5ca78c","uuid":"dbc4cb46-8aa5-4110-a950-8c50b52c3c4e","timestamp":"2026-06-14T06:12:15.893Z","tool_use_result":{"type":"text","file":{"filePath":"/tmp/rollback.sh","content":"#!/usr/bin/env bash\n# Rollback script: reverts non-default CockroachDB configuration to factory defaults.\n# Configuration snapshot taken 2026-06-14 from namespace cockroachdb, pod crdb-cluster-0.\n#\n# NON-DEFAULT STATE FOUND:\n#   cluster setting  kv.snapshot_rebalance.max_rate  = 1.0 MiB  (default: 32 MiB)\n#   cluster setting  diagnostics.reporting.enabled   = true     (default: false)\n#   zone config      RANGE default  gc.ttlseconds    = 14400 s  (default: 90000 s / 25 h)\n#\n# EXCLUDED (intentionally not reverted):\n#   cluster.secret  — cluster identity UUID; resetting breaks replication\n#   version         — cluster upgrade level; CockroachDB does not support downgrade\n#\n# Do NOT run until a change window is open. All three changes take effect immediately\n# and alter live cluster behaviour (GC cadence, rebalance throughput, telemetry).\n\nset -euo pipefail\n\nNAMESPACE=\"${NAMESPACE:-cockroachdb}\"\nPOD=\"${POD:-crdb-cluster-0}\"\nCOCKROACH=\"./cockroach\"\n\nsql() {\n  kubectl -n \"$NAMESPACE\" exec \"$POD\" -- \"$COCKROACH\" sql --insecure -e \"$1\"\n}\n\necho \"=== [1/3] Resetting kv.snapshot_rebalance.max_rate to default (32 MiB) ===\"\nsql \"RESET CLUSTER SETTING kv.snapshot_rebalance.max_rate;\"\n\necho \"=== [2/3] Resetting diagnostics.reporting.enabled to default (false) ===\"\nsql \"RESET CLUSTER SETTING diagnostics.reporting.enabled;\"\n\necho \"=== [3/3] Resetting RANGE default gc.ttlseconds to default (90000 s) ===\"\nsql \"ALTER RANGE default CONFIGURE ZONE USING gc.ttlseconds = 90000;\"\n\necho \"\"\necho \"=== Post-rollback verification: remaining non-default cluster settings ===\"\nsql \"SELECT variable, value, default_value\n     FROM crdb_internal.cluster_settings\n     WHERE value != default_value\n     ORDER BY variable;\"\n\necho \"\"\necho \"=== Post-rollback verification: RANGE default zone config ===\"\nsql \"SELECT target, raw_config_sql\n     FROM crdb_internal.zones\n     WHERE target = 'RANGE default';\"\n\necho \"Rollback complete.\"\n","numLines":50,"startLine":1,"totalLines":50}}}
