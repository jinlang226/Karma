   # Backdated/EXPIRED leaf (the agent must renew it). A forward-counting `-days`\n      # cannot express a past validity window, so use the portable `openssl ca`\n      # path (-startdate/-enddate exist back to OpenSSL 1.x/LibreSSL) with a\n      # throwaway CA db. SAN (req_ext) is preserved so curl validation still keys\n      # on demo.example.com; the result is an in-the-past cert signed by the CA.\n      - command: \"/bin/sh -c 'D=$(mktemp -d); mkdir -p \\\"$D/newcerts\\\"; : > \\\"$D/index.txt\\\"; echo 1000 > \\\"$D/serial\\\"; printf \\\"[ca]\\\\ndefault_ca=CA_default\\\\n[CA_default]\\\\ndir=%s\\\\ndatabase=%s/index.txt\\\\nnew_certs_dir=%s/newcerts\\\\nserial=%s/serial\\\\ncertificate=/tmp/test-ca.crt\\\\nprivate_key=/tmp/test-ca.key\\\\ndefault_md=sha256\\\\npolicy=pol\\\\n[pol]\\\\ncommonName=supplied\\\\n\\\" \\\"$D\\\" \\\"$D\\\" \\\"$D\\\" \\\"$D\\\" > \\\"$D/ca.cnf\\\"; openssl ca -batch -config \\\"$D/ca.cnf\\\" -startdate 20200101000000Z -enddate 20200102000000Z -extfile cases/nginx-ingress/renew_tls_secret/resource/leaf.cnf -extensions req_ext -in /tmp/expired-tls.csr -out /tmp/expired-tls.crt; rm -rf \\\"$D\\\"'\"\n        sleep: 1\n      - command: \"kubectl -n demo create secret tls expired-tls-secret --cert=/tmp/expired-tls.crt --key=/tmp/expired-tls.key\"\n        sleep: 1\n      - command: \"kubectl -n demo create configmap test-ca --from-file=ca.crt=/tmp/test-ca.crt\"\n        sleep: 1\n      - command: \"kubectl -n demo apply -f cases/nginx-ingress/renew_tls_secret/resource/demo-ingress-expired.yaml\"\n        sleep: 10\n      - command: \"/bin/sh -c 'kubectl -n demo get pod curl-test >/dev/null 2>&1 || kubectl -n demo apply -f cases/nginx-ingress/renew_tls_secret/resource/curl-test.yaml'\"\n        sleep: 3\n      - command: \"kubectl -n demo wait --for=condition=Ready pod/{{params.curl_pod_name}} --timeout=180s\"\n        sleep: 1\n    verify:\n      - command: \"kubectl -n demo wait --for=condition=ready pod/{{params.curl_pod_name}} --t