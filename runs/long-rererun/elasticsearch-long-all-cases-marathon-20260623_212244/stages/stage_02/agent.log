  - name: certs\n              mountPath: /usr/share/elasticsearch/config/certs\n              readOnly: true\n          readinessProbe:\n            exec:\n              command:\n                - sh\n                - -c\n                - |\n                  curl -sk -u \"elastic:${ELASTIC_PASSWORD}\" \\\n                    https://localhost:9200/_cluster/health \\\n                    | grep -qE '\"status\":\"(green|yellow)\"'\n            initialDelaySeconds: 30\n            periodSeconds: 10\n            timeoutSeconds: 5\n            failureThreshold: 12\n      volumes:\n        - name: config\n          configMap:\n            name: es-config\n        - name: certs\n          secret:\n            secretName: es-http-tls\n  volumeClaimTemplates:\n    - metadata:\n        name: data\n      spec:\n        accessModes: [\"ReadWriteOnce\"]\n        resources:\n          requests:\n            storage: 5Gi\nEOF","description":"Deploy ES 8.11.1 StatefulSet with TLS and security"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":273,"cache_read_input_tokens":36487,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":273},"output_tokens":61,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"04b80efa-7cc4-4368-9677-082eed58964b","uuid":"5f77a22b-b6cc-46c7-bc59-e80ab5e58fb7","request_id":"req_011CcLuiDRbMY59Zkh4W7KHu"}
