{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01HHWT5zha1gQxMMvHpFJRxd","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01NufytWwpnYcTtPBhBxetSR","name":"Write","input":{"file_path":"/tmp/rollback.sh","content":"#!/bin/bash\n# Rollback script: reverts non-default CockroachDB cluster settings and zone\n# configs captured on 2026-06-23 back to CockroachDB factory defaults.\n#\n# CAPTURED NON-DEFAULT STATE:\n#   Cluster settings:\n#     diagnostics.reporting.enabled = true        (default: false)\n#     kv.range_merge.queue.enabled   = false       (default: true)\n#     kv.snapshot_rebalance.max_rate = 208 MiB    (default: 32 MiB)\n#   Zone configs:\n#     RANGE default  gc.ttlseconds = 14400        (default: 90000)\n#     TABLE defaultdb.tenant_b.table_c  custom zone (discard to remove)\n#     TABLE defaultdb.tenant_b.table_d  custom zone (discard to remove)\n#   StatefulSet replicas: 3 (already at default — no change needed)\n#\n# Excluded from reset (must not be touched):\n#   cluster.secret  — cluster identity token, generated at init\n#   version         — cluster version, cannot be downgraded via RESET\n#\n# USAGE:\n#   COCKROACH_POD=crdb-cluster-0 NAMESPACE=cockroachdb bash rollback.sh\n#\n# DO NOT execute outside an approved change window. Running this script\n# on the live cluster will immediately alter replication and GC behaviour.\n\nset -euo pipefail\n\nCOCKROACH_POD=\"${COCKROACH_POD:-crdb-cluster-0}\"\nNAMESPACE=\"${NAMESPACE:-cockroachdb}\"\nCERTS_DIR=\"${CERTS_DIR:-/cockroach/cockroach-certs}\"\nKUBECTL=\"${KUBECTL:-kubectl}\"\n\nsql() {\n  local stmt=\"$1\"\n  \"$KUBECTL\" -n \"$NAMESPACE\" exec \"$COCKROACH_POD\" -- \\\n    ./cockroach sql --certs-dir=\"$CERTS_DIR\" -e \"$stmt\"\n}\n\necho \"=== CockroachDB Rollback: reverting to factory defaults ===\"\necho \"  Namespace : $NAMESPACE\"\necho \"  Pod       : $COCKROACH_POD\"\necho \"  Certs dir : $CERTS_DIR\"\necho \"\"\n\n# ---------------------------------------------------------------------------\n# 1. Cluster settings\n# ---------------------------------------------------------------------------\necho \"--- [1/2] Resetting cluster settings ---\"\n\necho \"  diagnostics.reporting.enabled -> false (default)\"\nsql \"RESET CLUSTER SETTING diagnostics.reporting.enabled;\"\n\necho \"  kv.range_merge.queue.enabled -> true (default)\"\nsql \"RESET CLUSTER SETTING kv.range_merge.queue.enabled;\"\n\necho \"  kv.snapshot_rebalance.max_rate -> 32 MiB (default)\"\nsql \"RESET CLUSTER SETTING kv.snapshot_rebalance.max_rate;\"\n\n# ---------------------------------------------------------------------------\n# 2. Zone configurations\n# ---------------------------------------------------------------------------\necho \"\"\necho \"--- [2/2] Resetting zone configurations ---\"\n\n# RANGE default: only gc.ttlseconds was changed; reset it explicitly so the\n# other fields (num_replicas=3, range_min/max_bytes) remain untouched.\necho \"  RANGE default: gc.ttlseconds 14400 -> 90000 (default)\"\nsql \"ALTER RANGE default CONFIGURE ZONE USING gc.ttlseconds = 90000;\"\n\n# User-table custom zones: discard removes the override entirely so the\n# table falls back to RANGE default.\necho \"  TABLE defaultdb.tenant_b.table_c: discarding custom zone\"\nsql \"ALTER TABLE defaultdb.tenant_b.table_c CONFIGURE ZONE DISCARD;\"\n\necho \"  TABLE defaultdb.tenant_b.table_d: discarding custom zone\"\nsql \"ALTER TABLE defaultdb.tenant_b.table_d CONFIGURE ZONE DISCARD;\"\n\n# ---------------------------------------------------------------------------\n# 3. Post-rollback verification\n# ---------------------------------------------------------------------------\necho \"\"\necho \"--- Verification ---\"\necho \"Non-default cluster settings (expect only cluster.secret and version):\"\nsql \"SELECT variable, value FROM crdb_internal.cluster_settings WHERE value != default_value;\"\n\necho \"\"\necho \"Remaining zone overrides (expect no tenant_b entries):\"\nsql \"SELECT target FROM crdb_internal.zones ORDER BY target;\"\n\necho \"\"\necho \"=== Rollback complete ===\"\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1429,"cache_read_input_tokens":30096,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1429},"output_tokens":33,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"c78dc99f-634b-484b-8867-88551dd1e9bb","uuid":"522f15f2-6812-4303-8dc1-906b61ff64cd","request_id":"req_011CcLbpNnjKoiRg1eW7gH1o"}
