{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01GPrU69BcRnegnQycJduHZX","type":"tool_result","content":"1\t\"\"\"rate_limit_strategy metric plugin.\"\"\"\n2\t\n3\tfrom __future__ import annotations\n4\tfrom typing import Any\n5\t\n6\t\n7\tdef compute(\n8\t    kubectl_snapshot: list[dict[str, Any]],\n9\t    case: dict[str, Any],\n10\t    role_bindings: dict[str, str],\n11\t) -> float | dict[str, Any]:\n12\t    \"\"\"Compute the rate_limit_strategy score for one stage run.\n13\t\n14\t    Parameters\n15\t    ----------\n16\t    kubectl_snapshot:\n17\t        Parsed kubectl call list produced by evidence.collect_kubectl_snapshot.\n18\t    case:\n19\t        Normalized case descriptor from definitions.cases.normalize_case.\n20\t    role_bindings:\n21\t        Map of namespace role name to physical namespace name.\n22\t\n23\t    Returns\n24\t    -------\n25\t    float\n26\t        Score in [0.0, 1.0].\n27\t    dict\n28\t        {\"error\": \"<message>\"} when scoring cannot be completed.\n29\t    \"\"\"\n30\t    # Only applicable to nginx-ingress rate-limit cases.\n31\t    case_name = str(case.get(\"case_name\") or \"\")\n32\t    if \"rate_limit\" not in case_name:\n33\t        return 1.0\n34\t\n35\t    # Score is 1.0 if rate-limit annotations were applied via patch/apply,\n36\t    # 0.0 if no relevant mutation was found.\n37\t    _RATE_LIMIT_RESOURCES = frozenset({\"ingresses\", \"ingress\", \"configmaps\", \"configmap\"})\n38\t    _MUTATION_VERBS = frozenset({\"apply\", \"create\", \"patch\", \"replace\"})\n39\t\n40\t    relevant = [\n41\t        e for e in kubectl_snapshot\n42\t        if str(e.get(\"verb\") or \"\").lower() in _MUTATION_VERBS\n43\t        and str(e.get(\"resource\") or \"\").lower() in _RATE_LIMIT_RESOURCES\n44\t    ]\n45\t    return 1.0 if relevant else 0.0\n46\t"}]},"parent_tool_use_id":null,"session_id":"a8cd1c1a-a01d-41e8-9132-726291ea0e35","uuid":"be68e7de-6217-4029-990d-cc1e1ba55044","timestamp":"2026-06-23T22:03:24.033Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/leo/Karma/karma/metrics/rate_limit_strategy.py","content":"\"\"\"rate_limit_strategy metric plugin.\"\"\"\n\nfrom __future__ import annotations\nfrom typing import Any\n\n\ndef compute(\n    kubectl_snapshot: list[dict[str, Any]],\n    case: dict[str, Any],\n    role_bindings: dict[str, str],\n) -> float | dict[str, Any]:\n    \"\"\"Compute the rate_limit_strategy score for one stage run.\n\n    Parameters\n    ----------\n    kubectl_snapshot:\n        Parsed kubectl call list produced by evidence.collect_kubectl_snapshot.\n    case:\n        Normalized case descriptor from definitions.cases.normalize_case.\n    role_bindings:\n        Map of namespace role name to physical namespace name.\n\n    Returns\n    -------\n    float\n        Score in [0.0, 1.0].\n    dict\n        {\"error\": \"<message>\"} when scoring cannot be completed.\n    \"\"\"\n    # Only applicable to nginx-ingress rate-limit cases.\n    case_name = str(case.get(\"case_name\") or \"\")\n    if \"rate_limit\" not in case_name:\n        return 1.0\n\n    # Score is 1.0 if rate-limit annotations were applied via patch/apply,\n    # 0.0 if no relevant mutation was found.\n    _RATE_LIMIT_RESOURCES = frozenset({\"ingresses\", \"ingress\", \"configmaps\", \"configmap\"})\n    _MUTATION_VERBS = frozenset({\"apply\", \"create\", \"patch\", \"replace\"})\n\n    relevant = [\n        e for e in kubectl_snapshot\n        if str(e.get(\"verb\") or \"\").lower() in _MUTATION_VERBS\n        and str(e.get(\"resource\") or \"\").lower() in _RATE_LIMIT_RESOURCES\n    ]\n    return 1.0 if relevant else 0.0\n","numLines":46,"startLine":1,"totalLines":46}}}
