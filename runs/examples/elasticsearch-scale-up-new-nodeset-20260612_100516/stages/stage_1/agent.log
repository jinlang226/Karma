et:\n            path: /_cluster/health?local=true\n            port: http\n          initialDelaySeconds: 10\n          periodSeconds: 5\n          timeoutSeconds: 2\n          failureThreshold: 6\n        resources:\n          requests:\n            cpu: 500m\n            memory: 1Gi\n          limits:\n            cpu: \"1\"\n            memory: 2Gi\n        volumeMounts:\n        - name: es-config\n          mountPath: /usr/share/elasticsearch/config/elasticsearch.yml\n          subPath: elasticsearch.yml\n        - name: data\n          mountPath: /usr/share/elasticsearch/data\n      volumes:\n      - name: es-config\n        configMap:\n          name: es-config-warm\n          items:\n          - key: elasticsearch.yml\n            path: elasticsearch.yml\n  updateStrategy:\n    type: OnDelete\n  volumeClaimTemplates:\n  - metadata:\n      name: data\n    spec:\n      accessModes: [ \"ReadWriteOnce\" ]\n      resources:\n        requests:\n          storage: 5Gi\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":515,"cache_read_input_tokens":37467,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":515},"output_tokens":23,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"23d15f3e-77f0-4961-be94-59e5c24bbeaf","uuid":"14c98770-c285-47c5-8057-2057ebf4bb6a","request_id":"req_011CbyBTQDLziA7ttuMkMyma"}
