  if not isinstance(live, int) or live <= 0:\n50\t            live = spec.get(\"replicas\")\n51\t        if isinstance(live, int) and live > 0:\n52\t            return live\n53\t    except Exception:\n54\t        pass\n55\t    return 3\n56\t\n57\t\n58\tdef get_pod_version(pod):\n59\t    out = run([\n60\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\",\n61\t        \"rabbitmqctl\", \"status\"\n62\t    ], timeout_sec=60)\n63\t    match = re.search(r\"RabbitMQ\\s*version\\s*[:=]\\s*([0-9]+\\.[0-9]+\\.[0-9]+)\", out)\n64\t    if match:\n65\t        return match.group(1)\n66\t    match = re.search(r'\\\"RabbitMQ\\\"\\s*,\\s*\\\"([0-9]+\\.[0-9]+\\.[0-9]+)\\\"', out)\n67\t    if match:\n68\t        return match.group(1)\n69\t    return None\n70\t\n71\t\n72\tdef main():\n73\t    parser = argparse.ArgumentParser()\n74\t    parser.add_argument(\"--namespace\", default=os.environ.get(\"BENCH_NAMESPACE\", \"rabbitmq\"))\n75\t    parser.add_argument(\n76\t        \"--cluster-prefix\",\n77\t        default=os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"rabbitmq\"),\n78\t    )\n79\t    parser.add_argument(\n80\t        \"--to-version\",\n81\t        default=os.environ.get(\"BENCH_PARAM_TO_VERSION\", \"4.1\"),\n82\t    )\n83\t    args = parser.parse_args()\n84\t\n85\t    global NAMESPACE\n86\t    NAMESPACE = args.namespace\n87\t    cluster_prefix = args.cluster_prefix\n88\t    errors = []\n89\t    expected_nodes = _resolve_expected_nodes(NAMESPACE, cluster_prefix)\n90\t\n91\t    try:\n92\t        pods = run_json([\n93\t            \"kubectl\", \"-n\", NAMESPACE, \"get\", \"pods\", \"-l\", f\"app={cluster_prefix}\", \"-o\", \"json\"\n94\t        ])\n95\t    except subprocess.CalledProcessError as exc:\n96\t        print(f\"Failed to list RabbitMQ pods: {exc.output.decode().strip()}\")\n97\t        sys.exit(1)\n98\t\n99\t    ready_pods = []\n100\t    for item in pods.get(\"items\", []):\n101\t        name = item.get(\"metadata\", {}).get(\"name\", \"unknown\")\n102\t 