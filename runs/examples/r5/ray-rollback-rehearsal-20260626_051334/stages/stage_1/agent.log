{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01Bupx8dnapwJEupMEqs4GtR","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_015FZcx8L3SosefkQp9Xq3KE","name":"Write","input":{"file_path":"/tmp/rollback.sh","content":"#!/usr/bin/env bash\n# rollback.sh — revert Ray cluster (namespace: ray) to original baseline values.\n#\n# Non-default settings detected at 2026-06-26 (pre-rollback state):\n#   ray-worker replicas:  1   (may have been scaled up to 3)\n#   ray-head  image:      rayproject/ray:2.9.0  (upgraded from 2.8.0)\n#   ray-worker image:     rayproject/ray:2.9.0  (upgraded from 2.8.0)\n#   ray-head  service:    port 6379 + possibly port 8265 (dashboard)\n#\n# Baseline to restore:\n#   ray-worker replicas:  1\n#   ray-head  image:      rayproject/ray:2.8.0\n#   ray-worker image:     rayproject/ray:2.8.0\n#   ray-head  service:    port 6379 (gcs) only — no dashboard port\n#   resource limits:      none (both deployments had resources: {})\n#\n# DO NOT run this script until the change window is approved.\n# Running it will revert configuration the live cluster currently depends on.\n\nset -euo pipefail\n\nNAMESPACE=ray\nBASELINE_IMAGE=rayproject/ray:2.8.0\nBASELINE_WORKER_REPLICAS=1\n\necho \"[rollback] Starting Ray cluster rollback in namespace '${NAMESPACE}'\"\n\n# ── 1. Scale ray-worker to baseline replica count ─────────────────────────────\nCURRENT_REPLICAS=$(kubectl -n \"${NAMESPACE}\" get deploy ray-worker \\\n  -o jsonpath='{.spec.replicas}')\necho \"[rollback] ray-worker replicas: ${CURRENT_REPLICAS} → ${BASELINE_WORKER_REPLICAS}\"\nkubectl -n \"${NAMESPACE}\" scale deploy/ray-worker \\\n  --replicas=\"${BASELINE_WORKER_REPLICAS}\"\nkubectl -n \"${NAMESPACE}\" rollout status deploy/ray-worker --timeout=120s\n\n# ── 2. Downgrade ray-head image to baseline ───────────────────────────────────\nCURRENT_HEAD_IMAGE=$(kubectl -n \"${NAMESPACE}\" get deploy ray-head \\\n  -o jsonpath='{.spec.template.spec.containers[0].image}')\necho \"[rollback] ray-head image: ${CURRENT_HEAD_IMAGE} → ${BASELINE_IMAGE}\"\nkubectl -n \"${NAMESPACE}\" set image deploy/ray-head \\\n  \"ray-head=${BASELINE_IMAGE}\"\nkubectl -n \"${NAMESPACE}\" rollout status deploy/ray-head --timeout=120s\n\n# ── 3. Downgrade ray-worker image to baseline ─────────────────────────────────\nCURRENT_WORKER_IMAGE=$(kubectl -n \"${NAMESPACE}\" get deploy ray-worker \\\n  -o jsonpath='{.spec.template.spec.containers[0].image}')\necho \"[rollback] ray-worker image: ${CURRENT_WORKER_IMAGE} → ${BASELINE_IMAGE}\"\nkubectl -n \"${NAMESPACE}\" set image deploy/ray-worker \\\n  \"ray-worker=${BASELINE_IMAGE}\"\nkubectl -n \"${NAMESPACE}\" rollout status deploy/ray-worker --timeout=120s\n\n# ── 4. Remove resource limits/requests if any were set ────────────────────────\n# Baseline had resources: {} on both deployments. Patch restores that.\necho \"[rollback] Clearing resource limits/requests on ray-head...\"\nkubectl -n \"${NAMESPACE}\" patch deploy ray-head --type=json \\\n  -p='[{\"op\":\"replace\",\"path\":\"/spec/template/spec/containers/0/resources\",\"value\":{}}]'\necho \"[rollback] Clearing resource limits/requests on ray-worker...\"\nkubectl -n \"${NAMESPACE}\" patch deploy ray-worker --type=json \\\n  -p='[{\"op\":\"replace\",\"path\":\"/spec/template/spec/containers/0/resources\",\"value\":{}}]'\n\n# ── 5. Restore ray-head Service to baseline (gcs only, no dashboard port) ─────\necho \"[rollback] Patching ray-head Service to restore baseline ports (gcs:6379 only)...\"\nkubectl -n \"${NAMESPACE}\" patch svc ray-head --type=json \\\n  -p='[{\"op\":\"replace\",\"path\":\"/spec/ports\",\"value\":[{\"name\":\"gcs\",\"port\":6379,\"protocol\":\"TCP\",\"targetPort\":6379}]}]'\n\n# ── 6. Verify final state ─────────────────────────────────────────────────────\necho \"\"\necho \"[rollback] Done. Final state:\"\nkubectl -n \"${NAMESPACE}\" get deploy ray-head ray-worker \\\n  -o custom-columns=\"NAME:.metadata.name,REPLICAS:.spec.replicas,IMAGE:.spec.template.spec.containers[0].image\"\nkubectl -n \"${NAMESPACE}\" get svc ray-head \\\n  -o custom-columns=\"NAME:.metadata.name,PORTS:.spec.ports[*].port\"\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1042,"cache_read_input_tokens":49767,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1042},"output_tokens":20,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"c1e8bedf-f5ad-4053-89b1-0392388ebd2b","uuid":"2df25022-433e-4984-b3be-ec91afc12dd9","request_id":"req_011CcRJfWJTgwJCwNxbf7xch"}
