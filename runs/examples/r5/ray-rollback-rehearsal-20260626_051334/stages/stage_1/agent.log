   curl -X POST \"$ES_URL/_aliases\" \\\n#         -H 'Content-Type: application/json' \\\n#         -d '{\n#               \"actions\": [\n#                 {\"add\":    {\"index\": \"audit-index-rollback\", \"alias\": \"audit-index-alias\"}},\n#                 {\"remove\": {\"index\": \"audit-index\",          \"alias\": \"audit-index-alias\"}}\n#               ]\n#             }'\n#\n#   2e. After confirming alias traffic, delete the original:\n#       curl -X DELETE \"$ES_URL/audit-index\"\n#\necho \"[2/4] WARNING: index.number_of_shards=3 is STATIC — reindex required.\"\necho \"      Elasticsearch default is 1. See commented procedure in this script.\"\necho \"      No automated action taken for this step.\"\necho \"\"\n\n# ── Step 3: Cluster-level settings ──────────────────────────────────────────\n#\n# Verified that persistent and transient cluster settings are both empty ({}).\n# No cluster-level rollback is required.\necho \"[3/4] Cluster settings: persistent={}, transient={} — no rollback needed.\"\necho \"\"\n\n# ── Step 4: Node attributes (tier=hot) ──────────────────────────────────────\n#\n# All three nodes (es-cluster-0/1/2) carry the custom attribute tier=hot.\n# This is a static node-level attribute set in elasticsearch.yml (or via the\n# ES_SETTING_NODE_ATTR_TIER env var on each StatefulSet pod).\n# It cannot be removed via the cluster API — it requires editing node\n# configuration and performing a rolling restart.\n#\n# MANUAL PROCEDURE:\n#   For each node, remove or comment out the line:\n#     node.attr.tier: hot\n#   from elasticsearch.yml (or unset the corresponding env var in the\n#   StatefulSet pod template), then restart the node in a rolling fashion:\n#     kubectl -n elasticsearch rollout restart statefulset/es-cluster\n#\necho \"[4/4] Node attribute 'tier=hot': static config, not API-settable.\"\necho \"      To remove: edit node.attr.tier in elasticsearch.yml on each node\"\necho \"      and perform a rolling restart of statefulset/es-cluster.\"\necho \"\"\n\n# ── Final verification ───────────────────────────────────────────────────────\necho \"================================================================\"\necho \"Post-rollback index settings (dynamic changes only):\"\ncurl -s \"$ES_URL/$INDEX/_settings\" | \\\n  python3 -c \"import json,sys; print(json.dumps(json.load(sys.stdin), indent=2))\"\necho \"\"\necho \"Post-rollback cluster settings:\"\ncurl -s \"$ES_URL/_cluster/settings?flat_settings=true\" | \\\n  python3 -c \"import json,sys; print(json.dumps(json.load(sys.stdin), indent=2))\"\necho \"\"\necho \"================================================================\"\necho \"Rollback complete.\"\necho \"Dynamic allocation settings cleared. Static shard count and node\"\necho \"attributes require the manual procedures described above.\"\necho \"================================================================\"","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
