all records (skew ratio > 10x)\n\n  3. FIX THE PROBLEM\n     Choose ONE of these approaches:\n\n     Option A: Increase worker memory and scale workers\n     ```bash\n     # Delete failed job\n     kubectl delete job etl-job -n spark-etl\n\n     # Scale workers for more parallelism\n     kubectl scale deployment spark-worker -n spark-etl --replicas=4\n\n     # Patch worker deployment for more memory\n     kubectl set env deployment/spark-worker -n spark-etl SPARK_WORKER_MEMORY=2G\n\n     # Wait for workers to restart\n     kubectl rollout status deployment/spark-worker -n spark-etl\n     ```\n\n     Option B: Modify ETL job with increased executor memory\n     ```bash\n     # Delete failed job\n     kubectl delete job etl-job -n spark-etl\n\n     # Create a new job with increased memory (edit and apply)\n     # Change --executor-memory from 256m to 1g in etl-job.yaml\n     kubectl apply -f cases/spark/spark_etl_skew_oom/resource/etl-job.yaml\n     ```\n\n     Option C: Enable AQE (Adaptive Query Execution)\n     ```bash\n     # Delete failed job\n     kubectl delete job etl-job -n spark-etl\n\n     # Modify etl-job.yaml to add AQE config:\n     # --conf spark.sql.adaptive.enabled=true\n     # --conf spark.sql.adaptive.skewJoin.enabled=true\n     kubectl apply -f cases/spark/spark_etl_skew_oom/resource/etl-job.yaml\n     ```\n\n  4. RE-RUN THE PIPELINE\n     After applying the fix:\n     ```bash\n     # Re-apply the ETL job\n     kubectl apply -f cases/spark/spark_etl_skew_oom/resource/etl-job.yaml\n\n     # Watch job status\n     kubectl get job etl-job -n spark-etl -w\n     ```\n\n  5. VERIFY SUCCESS\n     ```bash\n     # Check job completed\n     kubectl get job etl-job -n spark-etl\n\n     # Check job logs\n     kubectl logs -n spark-etl -l app=etl-job --tail=50\n     ```\n\n  SUCCESS CRITERIA:\n  - Identified OOM error in Stage 3\n  - Diagnosed data skew (user_id 999 with >10x ratio)\n  - Applied a fix (more workers, more memory, or AQE)\n  - ETL job completed successfully\n\nparams:\n  data_mount:\n    default: /data\n    description: Mount path where the ETL input data is staged\n\nnamespace_contract:\n  required_roles: []\n\nmetrics:\n  - time_to_first_mutation\n  - read_write_ratio\n  - blast_radius\n  - destructive_ops\n  - decoy_integrity\n  - residual_drift\n  - spark_resource_tuning\n\npreconditionUnits:\n  - name: spark_env_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n spark-etl get pods 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n    apply:\n      - command: \"kubectl delete namespace spark-etl --ignore-not-found=true --wait=false\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl wait --for=delete namespace/spark-etl --timeout=300s 2>/dev/null || true'\"\n        sleep: 1\n      - command: \"kubectl apply -f cases/spark/spark_etl_skew_oom/resource/namespace.yaml\"\n        sleep: 1\n      - command: \"kubectl apply -f cases/spark/spark_etl_skew_oom/resource/rbac.yaml\"\n        sleep: 1\n      - command: \"kubectl apply -f cases/spark/spark_etl_skew_oom/resource/data-generator.yaml\"\n        sleep: 30\n      - command: \"kubectl apply -f cases/spark/spark_etl_skew_oom/resource/etl-scripts-configmap.yaml\"\n        sleep: 1\n      - command: \"kubectl apply -f cases/spark/spark_etl_skew_oom/resource/spark-cluster.yaml\"\n        sleep: 15\n      - command: \"kubectl apply -f cases/spark/spark_etl_skew_oom/resource/diagnostic-tools.yaml\"\n        sleep: 3\n      - command: \"kubectl apply -f cases/spark/spark_etl_skew_oom/resource/etl-job.yaml\"\n        sleep: 5\n    verify:\n      - command: \"kubectl -n spark-etl get pods 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n\noracle:\n  verify:\n    commands:\n      - command: \"python3 cases/spark/spark_etl_skew_oom/oracle/oracle.py\"\n        timeout_sec: 60\n","numLines":164,"startLine":1,"totalLines":164}}}
