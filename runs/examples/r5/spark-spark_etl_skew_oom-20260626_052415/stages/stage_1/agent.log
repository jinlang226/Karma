{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Jkp5hU2ntzpnt1DVCcWUxw","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\t\"\"\"Oracle for spark/spark_etl_skew_oom.\n3\t\n4\tVerifies the data-skew OOM in Stage 3 was diagnosed and remediated:\n5\t  - the etl-job Job completed successfully, and\n6\t  - at least one valid fix is in place: executor memory was raised above the\n7\t    failing 256m baseline, the worker deployment was scaled out / given more\n8\t    memory, or Adaptive Query Execution (skew handling) was enabled on the job.\n9\t\"\"\"\n10\tfrom __future__ import annotations\n11\t\n12\timport sys\n13\tfrom pathlib import Path\n14\t\n15\tCOMMON = Path(__file__).resolve().parents[2] / \"common\"\n16\tsys.path.insert(0, str(COMMON))\n17\t\n18\tfrom oracle_lib import (  # noqa: E402\n19\t    bench_namespace,\n20\t    deployment_env,\n21\t    deployment_spec_replicas,\n22\t    job,\n23\t    job_logs,\n24\t    job_succeeded,\n25\t)\n26\t\n27\tNAMESPACE = bench_namespace(\"spark-etl\")\n28\tJOB_NAME = \"etl-job\"\n29\tWORKER_DEPLOYMENT = \"spark-worker\"\n30\t\n31\t\n32\tdef fail(message: str) -> int:\n33\t    print(f\"spark_etl_skew_oom oracle failed: {message}\")\n34\t    return 1\n35\t\n36\t\n37\tdef job_command_text() -> str:\n38\t    payload = job(NAMESPACE, JOB_NAME)\n39\t    containers = payload.get(\"spec\", {}).get(\"template\", {}).get(\"spec\", {}).get(\"containers\", []) or []\n40\t    if not containers:\n41\t        return \"\"\n42\t    return \" \".join(str(part) for part in (containers[0].get(\"command\") or []))\n43\t\n44\t\n45\tdef fix_applied() -> bool:\n46\t    \"\"\"True if any of the documented remediations is detectable in cluster state.\"\"\"\n47\t    command = job_command_text().lower()\n48\t\n49\t    # Option B: executor memory raised above the failing 256m baseline.\n50\t    if \"spark.executor.memory=256m\" not in command and \"--executor-memory 256m\" not in command:\n51\t        if \"executor.memory\" in command or \"--executor-memory\" in command:\n52\t            return True\n53\t\n54\t    # Option C: Adaptive Query Execution / skew join enabled on the job.\n55\t    if \"spark.sql.adaptive.enabled=true\" in command or \"skewjoin.enabled=true\" in command:\n56\t        return True\n57\t\n58\t    # Option A: workers scaled out and/or given more memory.\n59\t    try:\n60\t        if deployment_spec_replicas(NAMESPACE, WORKER_DEPLOYMENT) > 1:\n61\t            return True\n62\t        worker_memory = deployment_env(NAMESPACE, WORKER_DEPLOYMENT, \"SPARK_WORKER_MEMORY\")\n63\t        if worker_memory and worker_memory not in (\"1G\", \"1g\"):\n64\t            return True\n65\t    except Exception:\n66\t        pass\n67\t    return False\n68\t\n69\t\n70\tdef main() -> int:\n71\t    if not job_succeeded(NAMESPACE, JOB_NAME):\n72\t        return fail(f\"job/{JOB_NAME} did not complete successfully\")\n73\t\n74\t    logs = job_logs(NAMESPACE, JOB_NAME)\n75\t    if \"spark_etl_pipeline_verified\" not in logs:\n76\t        return fail(f\"job/{JOB_NAME} logs do not confirm pipeline completion\")\n77\t\n78\t    if not fix_applied():\n79\t        return fail(\n80\t            \"no remediation detected (expected raised executor memory, scaled/upsized \"\n81\t            \"workers, or enabled AQE skew handling)\"\n82\t        )\n83\t\n84\t    print(\"spark_etl_skew_oom verified: Stage 3 OOM remediated and ETL job completed\")\n85\t    return 0\n86\t\n87\t\n88\tif __name__ == \"__main__\":\n89\t    raise SystemExit(main())\n90\t"}]},"parent_tool_use_id":null,"session_id":"75313730-765a-4842-9416-0d177bb2366b","uuid":"041f4fa2-5b34-4737-9efd-25cafc6ec0ba","timestamp":"2026-06-26T05:28:32.520Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/spark/spark_etl_skew_oom/oracle/oracle.py","content":"#!/usr/bin/env python3\n\"\"\"Oracle for spark/spark_etl_skew_oom.\n\nVerifies the data-skew OOM in Stage 3 was diagnosed and remediated:\n  - the etl-job Job completed successfully, and\n  - at least one valid fix is in place: executor memory was raised above the\n    failing 256m baseline, the worker deployment was scaled out / given more\n    memory, or Adaptive Query Execution (skew handling) was enabled on the job.\n\"\"\"\nfrom __future__ import annotations\n\nimport sys\nfrom pathlib import Path\n\nCOMMON = Path(__file__).resolve().parents[2] / \"common\"\nsys.path.insert(0, str(COMMON))\n\nfrom oracle_lib import (  # noqa: E402\n    bench_namespace,\n    deployment_env,\n    deployment_spec_replicas,\n    job,\n    job_logs,\n    job_succeeded,\n)\n\nNAMESPACE = bench_namespace(\"spark-etl\")\nJOB_NAME = \"etl-job\"\nWORKER_DEPLOYMENT = \"spark-worker\"\n\n\ndef fail(message: str) -> int:\n    print(f\"spark_etl_skew_oom oracle failed: {message}\")\n    return 1\n\n\ndef job_command_text() -> str:\n    payload = job(NAMESPACE, JOB_NAME)\n    containers = payload.get(\"spec\", {}).get(\"template\", {}).get(\"spec\", {}).get(\"containers\", []) or []\n    if not containers:\n        return \"\"\n    return \" \".join(str(part) for part in (containers[0].get(\"command\") or []))\n\n\ndef fix_applied() -> bool:\n    \"\"\"True if any of the documented remediations is detectable in cluster state.\"\"\"\n    command = job_command_text().lower()\n\n    # Option B: executor memory raised above the failing 256m baseline.\n    if \"spark.executor.memory=256m\" not in command and \"--executor-memory 256m\" not in command:\n        if \"executor.memory\" in command or \"--executor-memory\" in command:\n            return True\n\n    # Option C: Adaptive Query Execution / skew join enabled on the job.\n    if \"spark.sql.adaptive.enabled=true\" in command or \"skewjoin.enabled=true\" in command:\n        return True\n\n    # Option A: workers scaled out and/or given more memory.\n    try:\n        if deployment_spec_replicas(NAMESPACE, WORKER_DEPLOYMENT) > 1:\n            return True\n        worker_memory = deployment_env(NAMESPACE, WORKER_DEPLOYMENT, \"SPARK_WORKER_MEMORY\")\n        if worker_memory and worker_memory not in (\"1G\", \"1g\"):\n            return True\n    except Exception:\n        pass\n    return False\n\n\ndef main() -> int:\n    if not job_succeeded(NAMESPACE, JOB_NAME):\n        return fail(f\"job/{JOB_NAME} did not complete successfully\")\n\n    logs = job_logs(NAMESPACE, JOB_NAME)\n    if \"spark_etl_pipeline_verified\" not in logs:\n        return fail(f\"job/{JOB_NAME} logs do not confirm pipeline completion\")\n\n    if not fix_applied():\n        return fail(\n            \"no remediation detected (expected raised executor memory, scaled/upsized \"\n            \"workers, or enabled AQE skew handling)\"\n        )\n\n    print(\"spark_etl_skew_oom verified: Stage 3 OOM remediated and ETL job completed\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    raise SystemExit(main())\n","numLines":90,"startLine":1,"totalLines":90}}}
