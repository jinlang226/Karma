           {_id:2,host:\"mongodb-replica-2.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"}\n91\t          ]})'\n92\t        sleep: 5\n93\t      - command: |\n94\t          for i in $(seq 1 20); do\n95\t            kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval 'db.hello().isWritablePrimary' | grep true && exit 0\n96\t            sleep 3\n97\t          done\n98\t          exit 1\n99\t        sleep: 2\n100\t      - command: |\n101\t          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\n102\t          db.getSiblingDB(\"admin\").createUser({\n103\t            user: \"{{params.admin_username}}\",\n104\t            pwd: \"admin123password\",\n105\t            roles: [\n106\t              {role: \"clusterAdmin\", db: \"admin\"},\n107\t              {role: \"userAdminAnyDatabase\", db: \"admin\"},\n108\t              {role: \"readWriteAnyDatabase\", db: \"admin\"}\n109\t            ]\n110\t          })'\n111\t        sleep: 2\n112\t      - command: |\n113\t          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet \\\n114\t          \"mongodb://{{params.admin_username}}:admin123password@localhost:27017/admin\" \\\n115\t          --eval 'db.getSiblingDB(\"{{params.app_database}}\").createRole({\n116\t            role: \"{{params.bad_role_name}}\",\n117\t            privileges: [\n118\t              { resource: { db: \"{{params.app_database}}\", collection: \"{{params.raw_collection}}\" }, actions: [\"find\"] }\n119\t            ],\n120\t            roles: []\n121\t          })'\n122\t        sleep: 2\n123\t      - command: |\n124\t          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet \\\n125\t          \"mongodb://{{params.admin_username}}:admin123password@localhost:27017/admin\" \\\n126\t          --eval 'db.getSiblingDB(\"admin\").createUser({\n127\t            user: \"{{params.reporting_username}}\",\n128\t            pwd: \"reporting123password\",\n129\t            roles: [{role: \"{{params.bad_role_name}}\", db: \"{{params.app_database}}\"}]\n130\t          })'\n131\t        sleep: 2\n132\t      - command: |\n133\t          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet \\\n134\t          \"mongodb://{{params.admin_username}}:admin123password@localhost:27017/admin\" \\\n135\t          --eval 'db.getSiblingDB(\"{{params.app_database}}\").{{params.reports_collection}}.insertMany([{x:1},{x:2},{x:3}], {writeConcern:{w:1}})'\n136\t        sleep: 2\n137\t      - command: |\n138\t          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet \\\n139\t          \"mongodb://{{params.admin_username}}:admin123password@localhost:27017/admin\" \\\n140\t          --eval 'db.getSiblingDB(\"{{params.app_database}}\").{{params.raw_collection}}.insertMany([{x:10},{x:11}], {writeConcern:{w:1}})'\n141\t        sleep: 2\n142\t    verify:\n143\t      - command: \"kubectl -n mongodb get pods 2>/dev/null | grep -c Running\"\n144\t        timeout_sec: 10\n145\t\n146\toracle:\n147\t  verify:\n148\t    commands:\n149\t      - command: \"python3 resources/mongodb/custom-roles/oracle/oracle.py\"\n150\t        timeout_sec: 60\n151\t"}]},"parent_tool_use_id":null,"session_id":"14c0a40c-26f1-42f4-a0c7-09b7d5d15cab","uuid":"c6b23964-19a4-452c-a3d4-0f109dc4790d","timestamp":"2026-06-13T07:43:17.395Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/leo/Karma/resources/mongodb/custom-roles/test.yaml","content":"# mongodb/custom-roles\n# MongoDB custom-roles task\n\nparams:\n  cluster_prefix:\n    default: mongodb-replica\n    description: StatefulSet name of the replica set members.\n  replica_set_name:\n    default: mongodb-replica\n    description: MongoDB replica set _id used when initiating the set.\n  admin_secret_name:\n    default: admin-user-password\n    description: Kubernetes Secret holding the admin user's password.\n  reporting_secret_name:\n    default: reporting-user-password\n    description: Kubernetes Secret holding the reporting user's password.\n  admin_username:\n    default: admin-user\n    description: Username of the MongoDB admin user.\n  reporting_username:\n    default: reporting-user\n    description: Username of the reporting user.\n  app_database:\n    default: appdb\n    description: Application database holding the reporting collections.\n  reports_collection:\n    default: reports\n    description: Collection backing the reporting dashboards.\n  raw_collection:\n    default: raw\n    description: Collection with ingestion data that must not be exposed.\n  bad_role_name:\n    default: rawRead\n    description: Overly-permissive role initially granted to the reporting user.\n\nprompt: |\n  A 3-member MongoDB replica set is running in the mongodb namespace.\n  Authentication is enabled. Passwords are stored in these Secrets:\n  - {{params.admin_secret_name}}\n  - {{params.reporting_secret_name}}\n\n  Reporting dashboards are failing for {{params.reporting_username}} after a permissions change.\n  Dashboards are built from {{params.app_database}}.{{params.reports_collection}}. {{params.app_database}}.{{params.raw_collection}} contains ingestion data and\n  must not be exposed. Restore the minimum access needed for reporting dashboards.\n\n  Notes:\n  - Do not use operators or CRDs.\n\nnamespace_contract:\n  required_roles: []\n\nmetrics:\n  - time_to_first_mutation\n\npreconditionUnits:\n  - name: mongo_env_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n mongodb get pod {{params.cluster_prefix}}-0 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n    apply:\n      - command: |\n          /bin/sh -c '\n          kubectl delete namespace mongodb --ignore-not-found=true; kubectl wait --for=delete namespace/mongodb --timeout=120s || true\n          '\n        sleep: 2\n      - command: \"kubectl create namespace mongodb\"\n        sleep: 1\n      - command: \"kubectl -n mongodb apply -f resources/mongodb/custom-roles/resource/secrets.yaml\"\n        sleep: 1\n      - command: \"kubectl -n mongodb apply -f resources/mongodb/custom-roles/resource/services.yaml\"\n        sleep: 1\n      - command: \"kubectl -n mongodb apply -f resources/mongodb/custom-roles/resource/statefulset.yaml\"\n        sleep: 5\n      - command: |\n          for i in $(seq 1 120); do\n            ready=$(kubectl -n mongodb get sts {{params.cluster_prefix}} -o jsonpath='{.status.readyReplicas}' 2>/dev/null)\n            if [ \"${ready:-0}\" -ge 3 ]; then\n              exit 0\n            fi\n            sleep 5\n          done\n          exit 1\n        sleep: 2\n      - command: |\n          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\n          rs.initiate({_id:\"{{params.replica_set_name}}\",members:[\n            {_id:0,host:\"mongodb-replica-0.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"},\n            {_id:1,host:\"mongodb-replica-1.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"},\n            {_id:2,host:\"mongodb-replica-2.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"}\n          ]})'\n        sleep: 5\n      - command: |\n          for i in $(seq 1 20); do\n            kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval 'db.hello().isWritablePrimary' | grep true && exit 0\n            sleep 3\n          done\n          exit 1\n        sleep: 2\n      - command: |\n          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\n          db.getSiblingDB(\"admin\").createUser({\n            user: \"{{params.admin_username}}\",\n            pwd: \"admin123password\",\n            roles: [\n              {role: \"clusterAdmin\", db: \"admin\"},\n              {role: \"userAdminAnyDatabase\", db: \"admin\"},\n              {role: \"readWriteAnyDatabase\", db: \"admin\"}\n            ]\n          })'\n        sleep: 2\n      - command: |\n          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet \\\n          \"mongodb://{{params.admin_username}