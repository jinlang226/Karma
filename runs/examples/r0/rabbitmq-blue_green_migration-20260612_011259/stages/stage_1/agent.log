{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01HitdaCeGJoojV3WjD44Xy9","type":"tool_result","content":"apiVersion: batch/v1\nkind: Job\nmetadata:\n  name: ${BENCH_PARAM_BLUE_CLUSTER_PREFIX}-setup\nspec:\n  backoffLimit: 2\n  template:\n    spec:\n      restartPolicy: OnFailure\n      containers:\n        - name: setup\n          image: curlimages/curl:8.6.0\n          env:\n            - name: RABBITMQ_ADMIN_USER\n              valueFrom:\n                secretKeyRef:\n                  name: ${BENCH_PARAM_BLUE_CLUSTER_PREFIX}-admin\n                  key: username\n            - name: RABBITMQ_ADMIN_PASS\n              valueFrom:\n                secretKeyRef:\n                  name: ${BENCH_PARAM_BLUE_CLUSTER_PREFIX}-admin\n                  key: password\n            - name: RABBITMQ_APP_USER\n              valueFrom:\n                secretKeyRef:\n                  name: ${BENCH_PARAM_BLUE_CLUSTER_PREFIX}-app\n                  key: username\n            - name: RABBITMQ_APP_PASS\n              valueFrom:\n                secretKeyRef:\n                  name: ${BENCH_PARAM_BLUE_CLUSTER_PREFIX}-app\n                  key: password\n          command:\n            - /bin/sh\n            - -c\n            - |\n              set -e\n              base=\"http://${BENCH_PARAM_BLUE_CLUSTER_PREFIX}:15672/api\"\n              auth=\"${RABBITMQ_ADMIN_USER}:${RABBITMQ_ADMIN_PASS}\"\n              curl -s -u \"$auth\" -XPUT \"$base/vhosts/%2Fapp\" >/dev/null\n              curl -s -u \"$auth\" -H \"content-type: application/json\" \\\n                -XPUT \"$base/users/${RABBITMQ_APP_USER}\" \\\n                -d '{\"password\":\"'\"${RABBITMQ_APP_PASS}\"'\",\"tags\":\"\"}' >/dev/null\n              curl -s -u \"$auth\" -H \"content-type: application/json\" \\\n                -XPUT \"$base/permissions/%2Fapp/${RABBITMQ_APP_USER}\" \\\n                -d '{\"configure\":\".*\",\"write\":\".*\",\"read\":\".*\"}' >/dev/null\n              curl -s -u \"$auth\" -H \"content-type: application/json\" \\\n                -XPUT \"$base/permissions/%2Fapp/${RABBITMQ_ADMIN_USER}\" \\\n                -d '{\"configure\":\".*\",\"write\":\".*\",\"read\":\".*\"}' >/dev/null\n              curl -s -u \"$auth\" -H \"content-type: application/json\" \\\n                -XPUT \"$base/queues/%2Fapp/app-queue\" \\\n                -d '{\"durable\":true,\"auto_delete\":false,\"arguments\":{}}' >/dev/null","is_error":false}]},"parent_tool_use_id":null,"session_id":"972f2e5d-1f65-49de-bc8b-cfff6a704196","uuid":"76766800-0504-473a-8a62-f6c21120f8a4","timestamp":"2026-06-12T01:21:13.149Z","tool_use_result":{"stdout":"apiVersion: batch/v1\nkind: Job\nmetadata:\n  name: ${BENCH_PARAM_BLUE_CLUSTER_PREFIX}-setup\nspec:\n  backoffLimit: 2\n  template:\n    spec:\n      restartPolicy: OnFailure\n      containers:\n        - name: setup\n          image: curlimages/curl:8.6.0\n          env:\n            - name: RABBITMQ_ADMIN_USER\n              valueFrom:\n                secretKeyRef:\n                  name: ${BENCH_PARAM_BLUE_CLUSTER_PREFIX}-admin\n                  key: username\n            - name: RABBITMQ_ADMIN_PASS\n              valueFrom:\n                secretKeyRef:\n                  name: ${BENCH_PARAM_BLUE_CLUSTER_PREFIX}-admin\n                  key: password\n            - name: RABBITMQ_APP_USER\n              valueFrom:\n                secretKeyRef:\n                  name: ${BENCH_PARAM_BLUE_CLUSTER_PREFIX}-app\n                  key: username\n            - name: RABBITMQ_APP_PASS\n              valueFrom:\n                secretKeyRef:\n                  name: ${BENCH_PARAM_BLUE_CLUSTER_PREFIX}-app\n                  key: password\n          command:\n            - /bin/sh\n            - -c\n            - |\n              set -e\n              base=\"http://${BENCH_PARAM_BLUE_CLUSTER_PREFIX}:15672/api\"\n              auth=\"${RABBITMQ_ADMIN_USER}:${RABBITMQ_ADMIN_PASS}\"\n              curl -s -u \"$auth\" -XPUT \"$base/vhosts/%2Fapp\" >/dev/null\n              curl -s -u \"$auth\" -H \"content-type: application/json\" \\\n                -XPUT \"$base/users/${RABBITMQ_APP_USER}\" \\\n                -d '{\"password\":\"'\"${RABBITMQ_APP_PASS}\"'\",\"tags\":\"\"}' >/dev/null\n              curl -s -u \"$auth\" -H \"content-type: application/json\" \\\n                -XPUT \"$base/permissions/%2Fapp/${RABBITMQ_APP_USER}\" \\\n                -d '{\"configure\":\".*\",\"write\":\".*\",\"read\":\".*\"}' >/dev/null\n              curl -s -u \"$auth\" -H \"content-type: application/json\" \\\n                -XPUT \"$base/permissions/%2Fapp/${RABBITMQ_ADMIN_USER}\" \\\n                -d '{\"configure\":\".*\",\"write\":\".*\",\"read\":\".*\"}' >/dev/null\n              curl -s -u \"$auth\" -H \"content-type: application/json\" \\\n                -XPUT \"$base/queues/%2Fapp/app-queue\" \\\n                -d '{\"durable\":true,\"auto_delete\":false,\"arguments\":{}}' >/dev/null","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
