e\",\n                      \"encoding\": \"auto\", \"truncate\": 50000},\n            )\n            print(f\"Fetched {len(batch)} messages for ID check\")\n\n            found = set()\n            for msg in batch:\n                try:\n                    payload = json.loads(msg[\"payload\"])\n                    mid = int(payload[\"id\"])\n                    if 1 <= mid <= SEED:\n                        found.add(mid)\n                except Exception:\n                    pass\n\n            missing = [i for i in range(1, SEED + 1) if i not in found]\n            print(f\"Seed IDs 1..{SEED}: {len(found)}/{SEED} present\")\n            if missing:\n                print(f\"MISSING: {missing}\")\n            else:\n                print(\"ALL SEED IDs PRESENT - migration verified!\")\n            print(f\"Total messages >= {SEED}: {'YES' if total >= SEED else 'NO'}\")\n            PY\n","structuredPatch":[],"originalFile":null,"userModified":false}}
