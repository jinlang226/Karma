{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019zgikMUjXW9BgTGYNFkuoU","type":"tool_result","content":"1\timport base64\n2\timport datetime as dt\n3\timport json\n4\timport subprocess\n5\timport sys\n6\timport os\n7\timport argparse\n8\t\n9\tNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"rabbitmq\")\n10\tCLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"rabbitmq\")\n11\t\n12\t\n13\tdef run(cmd, input_data=None):\n14\t    return subprocess.check_output(cmd, stderr=subprocess.STDOUT, input=input_data).decode()\n15\t\n16\t\n17\tdef run_json(cmd):\n18\t    return json.loads(run(cmd))\n19\t\n20\t\n21\tdef decode_secret(name, key):\n22\t    data = run_json([\n23\t        \"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", name, \"-o\", \"json\"\n24\t    ])\n25\t    return base64.b64decode(data[\"data\"][key])\n26\t\n27\t\n28\tdef openssl_fingerprint(pem_bytes):\n29\t    out = run([\"openssl\", \"x509\", \"-noout\", \"-fingerprint\", \"-sha256\"], input_data=pem_bytes)\n30\t    return out.strip().split(\"=\")[-1]\n31\t\n32\t\n33\tdef openssl_enddate(pem_bytes):\n34\t    out = run([\"openssl\", \"x509\", \"-noout\", \"-enddate\"], input_data=pem_bytes)\n35\t    # format: notAfter=Jan 27 01:21:20 2026 GMT\n36\t    value = out.strip().split(\"=\", 1)[1]\n37\t    return dt.datetime.strptime(value, \"%b %d %H:%M:%S %Y %Z\")\n38\t\n39\t\n40\tdef main():\n41\t    parser = argparse.ArgumentParser()\n42\t    parser.add_argument(\"--namespace\", default=os.environ.get(\"BENCH_NAMESPACE\", \"rabbitmq\"))\n43\t    parser.add_argument(\n44\t        \"--min-rotated-leaf-validity-days\",\n45\t        type=int,\n46\t        default=int(os.environ.get(\"BENCH_PARAM_MIN_ROTATED_LEAF_VALIDITY_DAYS\", \"300\")),\n47\t    )\n48\t    args = parser.parse_args()\n49\t\n50\t    global NAMESPACE, CLUSTER_PREFIX\n51\t    NAMESPACE = args.namespace\n52\t    CLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", CLUSTER_PREFIX)\n53\t    errors = []\n54\t\n55\t    # pods ready\n56\t    pods = run_json([\n57\t        \"kubectl\", \"-n\", NAMESPACE, \"get\", \"pods\", \"-l\", f\"app={CLUSTER_PREFIX}\", \"-o\", \"json\"\n58\t    ])\n59\t    ready = []\n60\t    for item in pods.get(\"items\", []):\n61\t        name = item.get(\"metadata\", {}).get(\"name\", \"unknown\")\n62\t        phase = item.get(\"status\", {}).get(\"phase\")\n63\t        statuses = item.get(\"status\", {}).get(\"containerStatuses\", [])\n64\t        if phase != \"Running\" or not statuses or not all(s.get(\"ready\") for s in statuses):\n65\t            errors.append(f\"Pod not ready: {name}\")\n66\t        else:\n67\t            ready.append(name)\n68\t    if len(ready) < 3:\n69\t        errors.append(f\"Expected 3 RabbitMQ pods ready, got {len(ready)}\")\n70\t\n71\t    # cluster status\n72\t    if ready:\n73\t        try:\n74\t            out = run([\n75\t                \"kubectl\", \"-n\", NAMESPACE, \"exec\", ready[0], \"--\",\n76\t                \"rabbitmqctl\", \"cluster_status\"\n77\t            ])\n78\t            if out.count(\"Running Nodes\") == 0:\n79\t                errors.append(\"Unable to read cluster status\")\n80\t            else:\n81\t                if f\"rabbit@{CLUSTER_PREFIX}-0\" not in out or f\"rabbit@{CLUSTER_PREFIX}-1\" not in out or f\"rabbit@{CLUSTER_PREFIX}-2\" not in out:\n82\t                    errors.append(\"Cluster does not report 3 running nodes\")\n83\t        except subprocess.CalledProcessError as exc:\n84\t            errors.append(f\"Failed to read cluster status: {exc.output.decode().strip()}\")\n85\t\n86\t    # old fingerprints\n87\t    old_cm = run_json([\n88\t        \"kubectl\", \"-n\", NAMESPACE, \"get\", \"configmap\", f\"{CLUSTER_PREFIX}-tls-old\", \"-o\", \"json\"\n89\t    ])\n90\t    old_ca_fp = old_cm.get(\"data\", {}).get(\"ca_fingerprint_sha256\")\n91\t    old_leaf_fp = old_cm.get(\"data\", {}).get(\"leaf_fingerprint_sha256\")\n92\t    if not old_ca_fp or not old_leaf_fp:\n93\t        errors.append(\"Missing old TLS fingerprints\")\n94\t\n95\t    # current certs\n96\t    ca_pem = decode_secret(f\"{CLUSTER_PREFIX}-tls\", \"ca.crt\")\n97\t    leaf_pem = decode_secret(f\"{CLUSTER_PREFIX}-tls\", \"tls.crt\")\n98\t    new_ca_fp = openssl_fingerprint(ca_pem)\n99\t    new_leaf_fp = openssl_fingerprint(leaf_pem)\n100\t\n101\t    if old_ca_fp and new_ca_fp != old_ca_fp:\n102\t        errors.append(\"CA fingerprint changed\")\n103\t    if old_leaf_fp and new_leaf_fp == old_leaf_fp:\n104\t        errors.append(\"Leaf certificate was not rotated\")\n105\t\n106\t    # validity check: configurable minimum remaining days\n107\t    not_after = openssl_enddate(leaf_pem)\n108\t    if (not_after - dt.datetime.utcnow()).days < args.min_rotated_leaf_validity_days:\n109\t        errors.append(\n110\t            \"New leaf certificate validity is too short \"\n111\t            f\"(min_days={args.min_rotated_leaf_validity_days})\"\n112\t        )\n113\t\n114\t    # ensure live TLS uses new leaf\n115\t    try:\n116\t        live_fp = run([\n117\t            \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"oracle-client\", \"--\",\n118\t            \"/bin/sh\", \"-c\",\n119\t            f\"echo | openssl s_client -connect {CLUSTER_PREFIX}.{NAMESPACE}.svc.cluster.local:5671 -servername {CLUSTER_PREFIX} 2>/dev/null | openssl x509 -noout -fingerprint -sha256\"\n120\t        ]).strip().split(\"=\")[-1]\n121\t        if live_fp != new_leaf_fp:\n122\t            errors.append(\"Live TLS certificate does not match rotated leaf\")\n123\t    except subprocess.CalledProcessError as exc:\n124\t        errors.append(f\"Failed to check live TLS certificate: {exc.output.decode().strip()}\")\n125\t\n126\t    if errors:\n127\t        print(\"Manual TLS rotation verification failed:\")\n128\t        for err in errors:\n129\t            print(f\"  - {err}\")\n130\t        sys.exit(1)\n131\t\n132\t    print(\"Manual TLS rotation verified.\")\n133\t\n134\t\n135\tif __name__ == \"__main__\":\n136\t    main()\n137\t"}]},"parent_tool_use_id":null,"session_id":"39940153-e5ca-4fe1-9181-d838cb7cc5b5","uuid":"27b72cf9-9714-4127-95d5-4158a342f4ad","timestamp":"2026-06-12T01:10:50.709Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/leo/Karma/resources/rabbitmq/manual_tls_rotation/oracle/oracle.py","content":"import base64\nimport datetime as dt\nimport json\nimport subprocess\nimport sys\nimport os\nimport argparse\n\nNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"rabbitmq\")\nCLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"rabbitmq\")\n\n\ndef run(cmd, input_data=None):\n    return subprocess.check_output(cmd, stderr=subprocess.STDOUT, input=input_data).decode()\n\n\ndef run_json(cmd):\n    return json.loads(run(cmd))\n\n\ndef decode_secret(name, key):\n    data = run_json([\n        \"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", name, \"-o\", \"json\"\n    ])\n    return base64.b64decode(data[\"data\"][key])\n\n\ndef openssl_fingerprint(pem_bytes):\n    out = run([\"openssl\", \"x509\", \"-noout\", \"-fingerprint\", \"-sha256\"], input_data=pem_bytes)\n    return out.strip().split(\"=\")[-1]\n\n\ndef openssl_enddate(pem_bytes):\n    out = run([\"openssl\", \"x509\", \"-noout\", \"-enddate\"], input_data=pem_bytes)\n    # format: notAfter=Jan 27 01:21:20 2026 GMT\n    value = out.strip().split(\"=\", 1)[1]\n    return dt.datetime.strptime(value, \"%b %d %H:%M:%S %Y %Z\")\n\n\ndef main():\n    parser = argparse.ArgumentParser()\n    parser.add_argument(\"--namespace\", default=os.environ.get(\"BENCH_NAMESPACE\", \"rabbitmq\"))\n    parser.add_argument(\n        \"--min-rotated-leaf-validity-days\",\n        type=int,\n        default=int(os.environ.get(\"BENCH_PARAM_MIN_ROTATED_LEAF_VALIDITY_DAYS\", \"300\")),\n    )\n    args = parser.parse_args()\n\n    global NAMESPACE, CLUSTER_PREFIX\n    NAMESPACE = args.namespace\n    CLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", CLUSTER_PREFIX)\n    errors = []\n\n    # pods ready\n    pods = run_json([\n        \"kubectl\", \"-n\", NAMESPACE, \"get\", \"pods\", \"-l\", f\"app={CLUSTER_PREFIX}\", \"-o\", \"json\"\n    ])\n    ready = []\n    for item in pods.get(\"items\", []):\n        name = item.get(\"metadata\", {}).get(\"name\", \"unknown\")\n        phase = item.get(\"status\", {}).get(\"phase\")\n        statuses = item.get(\"status\", {}).get(\"containerStatuses\", [])\n        if phase != \"Running\" or not statuses or not all(s.get(\"ready\") for s in statuses):\n            errors.append(f\"Pod not ready: {name}\")\n        else:\n            ready.append(name)\n    if len(ready) < 3:\n        errors.append(f\"Expected 3 RabbitMQ pods ready, got {len(ready)}\")\n\n    # cluster status\n    if ready:\n        try:\n            out = run([\n                \"kubectl\", \"-n\", NAMESPACE, \"exec\", ready[0], \"--\",\n                \"rabbitmqctl\", \"cluster_status\"\n            ])\n            if out.count(\"Running Nodes\") == 0:\n                errors.append(\"Unable to read cluster status\")\n            else:\n                if f\"rabbit@{CLUSTER_PREFIX}-0\" not in out or f\"rabbit@{CLUSTER_PREFIX}-1\" not in out or f\"rabbit@{CLUSTER_PREFIX}-2\" not in out:\n                    errors.append(\"Cluster does not report 3 running nodes\")\n        except subprocess.CalledProcessError as exc:\n            errors.append(f\"Failed to read cluster status: {exc.output.decode().strip()}\")\n\n    # old fingerprints\n    old_cm = run_json([\n        \"kubectl\", \"-n\", NAMESPACE, \"get\", \"configmap\", f\"{CLUSTER_PREFIX}-tls-old\", \"-o\", \"json\"\n    ])\n    old_ca_fp = old_cm.get(\"data\", {}).get(\"ca_fingerprint_sha256\")\n    old_leaf_fp = old_cm.get(\"data\", {}).get(\"leaf_fingerprint_sha256\")\n    if not old_ca_fp or not old_leaf_fp:\n        errors.append(\"Missing old TLS fingerprints\")\n\n    # current certs\n    ca_pem = decode_secret(f\"{CLUSTER_PREFIX}-tls\", \"ca.crt\")\n    leaf_pem = decode_secret(f\"{CLUSTER_PREFIX}-tls\", \"tls.crt\")\n    new_ca_fp = openssl_fingerprint(ca_pem)\n    new_leaf_fp = openssl_fingerprint(leaf_pem)\n\n    if old_ca_fp and new_ca_fp != old_ca_fp:\n        errors.append(\"CA fingerprint changed\")\n    if old_leaf_fp and new_leaf_fp == old_leaf_fp:\n        errors.append(\"Leaf certificate was not rotated\")\n\n    # validity check: configurable minimum remaining days\n    not_after = openssl_enddate(leaf_pem)\n    if (not_after - dt.datetime.utcnow()).days < args.min_rotated_leaf_validity_days:\n        errors.append(\n            \"New leaf certificate validity is too short \"\n            f\"(min_days={args.min_rotated_leaf_validity_days})\"\n        )\n\n    # ensure live TLS uses new leaf\n    try:\n        live_fp = run([\n            \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"oracle-client\", \"--\",\n            \"/bin/sh\", \"-c\",\n            f\"echo | openssl s_client -connect {CLUSTER_PREFIX}.{NAMESPACE}.svc.cluster.local:5671 -servername {CLUSTER_PREFIX} 2>/dev/null | openssl x509 -noout -fingerprint -sha256\"\n        ]).strip().split(\"=\")[-1]\n        if live_fp != new_leaf_fp:\n            errors.append(\"Live TLS certificate does not match rotated leaf\")\n    except subprocess.CalledProcessError as exc:\n        errors.append(f\"Failed to check live TLS certificate: {exc.output.decode().strip()}\")\n\n    if errors:\n        print(\"Manual TLS rotation verification failed:\")\n        for err in errors:\n            print(f\"  - {err}\")\n        sys.exit(1)\n\n    print(\"Manual TLS rotation verified.\")\n\n\nif __name__ == \"__main__\":\n    main()\n","numLines":137,"startLine":1,"totalLines":137}}}
