me: ray-head\n        image: rayproject/ray:2.9.0\n        env:\n          - name: MY_POD_IP\n            valueFrom:\n              fieldRef:\n                fieldPath: status.podIP\n          - name: RAY_NODE_ID\n            valueFrom:\n              fieldRef:\n                fieldPath: metadata.uid\n          - name: RAY_RAYLET_PID\n            value: \"1\"\n        command:\n          - sh\n          - -c\n          - |\n            ray start --head --node-ip-address=\"${MY_POD_IP}\" --port=6379 --include-dashboard=false --num-cpus=0 --block\n        ports:\n          - containerPort: 6379\n            name: gcs\n        resources: {}\nYAML\n\n# ── 3. ray-worker deployment (image, replicas, resources) ────────────────────\necho \"[rollback] (3/5) Restoring ray-worker deployment to baseline spec...\"\nkubectl -n \"${NS}\" apply -f - <<'YAML'\napiVersion: apps/v1\nkind: Deployment\nmetadata:\n  name: ray-worker\n  namespace: ray\n  labels:\n    app.kubernetes.io/name: ray\n    app.kubernetes.io/component: worker\n    bench.ray.cluster: ray\nspec:\n  replicas: 1\n  selector:\n    matchLabels:\n      app.kubernetes.io/name: ray\n      app.kubernetes.io/component: worker\n      bench.ray.cluster: ray\n  template:\n    metadata:\n      labels:\n        app.kubernetes.io/name: ray\n        app.kubernetes.io/component: worker\n        bench.ray.cluster: ray\n    spec:\n      containers:\n      - name: ray-worker\n        image: rayproject/ray:2.9.0\n        env:\n          - name: MY_POD_IP\n            valueFrom:\n              fieldRef:\n                fieldPath: status.podIP\n          - name: RAY_NODE_ID\n            valueFrom:\n              fieldRef:\n                fieldPath: metadata.uid\n          - name: RAY_RAYLET_PID\n            value: \"1\"\n        command:\n          - sh\n          - -c\n          - |\n            ray start --address=ray-head:6379 --node-ip-address=\"${MY_POD_IP}\" --num-cpus=1 --block\n        resources: {}\nYAML\n\n# ── 4. ray-head