{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Gbzt1DsndqvTNRXLxovdig","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport argparse\n3\timport base64\n4\timport json\n5\timport os\n6\timport subprocess\n7\timport sys\n8\t\n9\t\n10\tNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"mongodb\")\n11\tCLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"mongodb-replica\")\n12\tADMIN_SECRET = os.environ.get(\"BENCH_PARAM_ADMIN_SECRET_NAME\", \"admin-user-password\")\n13\tADMIN_USER = os.environ.get(\"BENCH_PARAM_ADMIN_USERNAME\", \"admin-user\")\n14\tLABEL_KEY = os.environ.get(\"BENCH_PARAM_TEMPLATE_LABEL_KEY\", \"monitoring\")\n15\tLABEL_VALUE = os.environ.get(\"BENCH_PARAM_TEMPLATE_LABEL_VALUE\", \"enabled\")\n16\tMIN_REQUEST_MEM_MIB = int(os.environ.get(\"BENCH_PARAM_MIN_REQUEST_MEMORY_MI\", \"512\"))\n17\tMIN_LIMIT_MEM_MIB = int(os.environ.get(\"BENCH_PARAM_MIN_LIMIT_MEMORY_MI\", \"1024\"))\n18\tPOD_PREFIX = f\"{CLUSTER_PREFIX}-\"\n19\t\n20\t\n21\tdef run(cmd):\n22\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n23\t\n24\t\n25\t_TLS_FLAGS_CACHE = None\n26\t\n27\t\n28\tdef _mongo_tls_flags(probe_pod=None):\n29\t    \"\"\"mongosh transport flags that adapt to the cluster's LIVE TLS mode.\n30\t\n31\t    The environment PERSISTS across workflow stages, so an earlier stage\n32\t    (mongodb/tls-setup or mongodb/certificate-rotation) may have turned TLS on,\n33\t    after which a plain mongosh connection is refused. Detect TLS by probing the\n34\t    running mongo pod for a CA cert mounted at the paths the TLS stages use; if\n35\t    present, connect with --tls --tlsCAFile (and a client cert for mutual TLS\n36\t    when one is mounted), else connect plain. Standalone (no CA mounted) this\n37\t    returns [] -> identical plain behaviour. It only adds transport flags; every\n38\t    real check still runs and still fails when its condition is unmet.\n39\t    \"\"\"\n40\t    global _TLS_FLAGS_CACHE\n41\t    if _TLS_FLAGS_CACHE is not None:\n42\t        return list(_TLS_FLAGS_CACHE)\n43\t    flags = []\n44\t    pod = probe_pod or f\"{CLUSTER_PREFIX}-0\"\n45\t    ca_path = None\n46\t    for cand in (\n47\t        \"/etc/tls/ca.crt\",\n48\t        \"/etc/mongo-ca/ca.crt\",\n49\t        \"/etc/mongodb/tls/ca.crt\",\n50\t        \"/etc/ssl/mongodb/ca.crt\",\n51\t    ):\n52\t        probe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + cand])\n53\t        if probe.returncode == 0:\n54\t            ca_path = cand\n55\t            break\n56\t    if ca_path:\n57\t        flags = [\"--tls\", \"--tlsAllowInvalidHostnames\", \"--tlsAllowInvalidCertificates\", \"--tlsCAFile\", ca_path]\n58\t        for client_pem in (\"/etc/tls/client.pem\", \"/etc/mongo-ca/client.pem\"):\n59\t            cprobe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + client_pem])\n60\t            if cprobe.returncode == 0:\n61\t                flags += [\"--tlsCertificateKeyFile\", client_pem]\n62\t                break\n63\t    _TLS_FLAGS_CACHE = flags\n64\t    return list(flags)\n65\t\n66\tdef _resolve_expected_replicas():\n67\t    \"\"\"Topology size to enforce.\n68\t\n69\t    The environment PERSISTS across workflow stages, so an earlier\n70\t    replica-scaling stage may have grown the replica set past the standalone\n71\t    default of 3. Resolve the expected count from (in priority order): an\n72\t    explicit ``expected_replicas``/``target_replicas`` param override, else the\n73\t    LIVE StatefulSet (ready, else spec'd replicas), else the standalone default\n74\t    of 3. This adapts the topology/count check to whatever the workflow\n75\t    accumulated without loosening it -- a non-solving agent that drops or fails\n76\t    a member still mismatches the live ready/spec count.\n77\t    \"\"\"\n78\t    for key in (\"BENCH_PARAM_EXPECTED_REPLICAS\", \"BENCH_PARAM_TARGET_REPLICAS\"):\n79\t        val = os.environ.get(key)\n80\t        if val is not None and str(val).strip():\n81\t            try:\n82\t                return int(val)\n83\t            except ValueError:\n84\t                pass\n85\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", CLUSTER_PREFIX, \"-o\", \"json\"])\n86\t    if res.returncode == 0:\n87\t        try:\n88\t            sts = json.loads(res.stdout)\n89\t            status = sts.get(\"status\", {}) or {}\n90\t            spec = sts.get(\"spec\", {}) or {}\n91\t            live = status.get(\"readyReplicas\")\n92\t            if not isinstance(live, int) or live <= 0:\n93\t                live = spec.get(\"replicas\")\n94\t            if isinstance(live, int) and live > 0:\n95\t                return live\n96\t        except (json.JSONDecodeError, AttributeError):\n97\t            pass\n98\t    return 3\n99\t\n100\t\n101\tEXPECTED_REPLICAS = _resolve_expected_replicas()\n102\t\n103\t\n104\tdef fail(prefix, errors):\n105\t    if errors:\n106\t        print(prefix, file=sys.stderr)\n107\t        for err in errors:\n108\t            print(f\"  - {err}\", file=sys.stderr)\n109\t        return 1\n110\t    return 0\n111\t\n112\t\n113\tdef get_secret_value(secret_name, key, errors):\n114\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", secret_name, \"-o\", f\"jsonpath={{.data.{key}}}\"])\n115\t    if res.returncode != 0:\n116\t        errors.append(f\"failed to read secret {secret_name}: {res.stderr.strip() or res.stdout.strip()}\")\n117\t        return None\n118\t    raw = (res.stdout or \"\").strip()\n119\t    if not raw:\n120\t        errors.append(f\"secret {secret_name}.{key} empty\")\n121\t        return None\n122\t    try:\n123\t        return base64.b64decode(raw).decode(\"utf-8\")\n124\t    except Exception:\n125\t        errors.append(f\"failed to decode secret {secret_name}.{key}\")\n126\t        return None\n127\t\n128\t\n129\tdef run_mongo(pod, uri, eval_str):\n130\t    return run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"mongosh\", \"--quiet\", *_mongo_tls_flags(), uri, \"--eval\", eval_str])\n131\t\n132\t\n133\tdef load_json(pod, uri, eval_str, label, errors):\n134\t    res = run_mongo(pod, uri, eval_str)\n135\t    if res.returncode != 0:\n136\t        errors.append(f\"{label} failed on {pod}: {res.stderr.strip() or res.stdout.strip()}\")\n137\t        return None\n138\t    raw = (res.stdout or \"\").strip()\n139\t    if not raw:\n140\t        errors.append(f\"{label} returned empty output on {pod}\")\n141\t        return None\n142\t    try:\n143\t        return json.loads(raw)\n144\t    except json.JSONDecodeError:\n145\t        errors.append(f\"unable to parse {label} JSON output on {pod}\")\n146\t        return None\n147\t\n148\t\n149\tdef _parse_mib(value):\n150\t    if value is None:\n151\t        return None\n152\t    text = str(value).strip().lower()\n153\t    if not text:\n154\t        return None\n155\t    try:\n156\t        return int(float(text))\n157\t    except ValueError:\n158\t        pass\n159\t    if text.endswith(\"mi\"):\n160\t        try:\n161\t            return int(float(text[:-2]))\n162\t        except ValueError:\n163\t            return None\n164\t    if text.endswith(\"gi\"):\n165\t        try:\n166\t            return int(float(text[:-2]) * 1024)\n167\t        except ValueError:\n168\t            return None\n169\t    return None\n170\t\n171\t\n172\tdef _find_primary(admin_uri, errors):\n173\t    for i in range(EXPECTED_REPLICAS):\n174\t        pod = f\"{POD_PREFIX}{i}\"\n175\t        res = run_mongo(pod, admin_uri, \"db.hello().isWritablePrimary\")\n176\t        if res.returncode == 0 and \"true\" in (res.stdout or \"\"):\n177\t            return pod\n178\t    errors.append(\"unable to locate primary pod\")\n179\t    return f\"{POD_PREFIX}0\"\n180\t\n181\t\n182\tdef _load_sts(errors):\n183\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", CLUSTER_PREFIX, \"-o\", \"json\"])\n184\t    if res.returncode != 0:\n185\t        errors.append(f\"failed to read statefulset {CLUSTER_PREFIX}: {res.stderr.strip() or res.stdout.strip()}\")\n186\t        return {}\n187\t    try:\n188\t        return json.loads(res.stdout)\n189\t    except json.JSONDecodeError:\n190\t        errors.append(\"failed to parse statefulset JSON\")\n191\t        return {}\n192\t\n193\t\n194\tdef check_template():\n195\t    errors = []\n196\t    sts = _load_sts(errors)\n197\t    if not sts:\n198\t        return fail(\"StatefulSet customization template check failed:\", errors)\n199\t\n200\t    template = sts.get(\"spec\", {}).get(\"template\", {})\n201\t    labels = template.get(\"metadata\", {}).get(\"labels\", {})\n202\t    if labels.get(LABEL_KEY) != LABEL_VALUE:\n203\t        errors.append(f\"template label {LABEL_KEY} expected {LABEL_VALUE}, got {labels.get(LABEL_KEY)}\")\n204\t\n205\t    containers = template.get(\"spec\", {}).get(\"containers\", [])\n206\t    if not containers:\n207\t        errors.append(\"statefulset has no containers\")\n208\t    else:\n209\t        resources = containers[0].get(\"resources\", {})\n210\t        req_mem = _parse_mib(resources.get(\"requests\", {}).get(\"memory\"))\n211\t        lim_mem = _parse_mib(resources.get(\"limits\", {}).get(\"memory\"))\n212\t        if req_mem is None or req_mem < MIN_REQUEST_MEM_MIB:\n213\t            errors.append(f\"requests.memory below minimum {MIN_REQUEST_MEM_MIB}Mi\")\n214\t        if lim_mem is None or lim_mem < MIN_LIMIT_MEM_MIB:\n215\t            errors.append(f\"limits.memory below minimum {MIN_LIMIT_MEM_MIB}Mi\")\n216\t\n217\t    return fail(\"StatefulSet customization template check failed:\", errors)\n218\t\n219\t\n220\tdef check_workload():\n221\t    errors = []\n222\t    sts = _load_sts(errors)\n223\t    if sts:\n224\t        if sts.get(\"spec\", {}).get(\"replicas\") != EXPECTED_REPLICAS:\n225\t            errors.append(\"statefulset replicas mismatch\")\n226\t        if sts.get(\"status\", {}).get(\"readyReplicas\") != EXPECTED_REPLICAS:\n227\t            errors.append(\"ready replicas mismatch\")\n228\t\n229\t    pods_res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"pods\", \"-l\", f\"app={CLUSTER_PREFIX}\", \"-o\", \"json\"])\n230\t    if pods_res.returncode != 0:\n231\t        errors.append(f\"failed to read pods: {pods_res.stderr.strip() or pods_res.stdout.strip()}\")\n232\t        return fail(\"StatefulSet customization workload check failed:\", errors)\n233\t    try:\n234\t        pods = json.loads(pods_res.stdout)\n235\t    except json.JSONDecodeError:\n236\t        errors.append(\"failed to parse pods JSON\")\n237\t        return fail(\"StatefulSet customization workload check failed:\", errors)\n238\t\n239\t    items = pods.get(\"items\", [])\n240\t    if len(items) != EXPECTED_REPLICAS:\n241\t        errors.append(f\"expected {EXPECTED_REPLICAS} pods, got {len(items)}\")\n242\t    for pod in items:\n243\t        name = pod.get(\"metadata\", {}).get(\"name\", \"unknown\")\n244\t        ready = next((c for c in pod.get(\"status\", {}).get(\"conditions\", []) if c.get(\"type\") == \"Ready\"), {})\n245\t        if ready.get(\"status\") != \"True\":\n246\t            errors.append(f\"pod {name} is not Ready\")\n247\t\n248\t    return fail(\"StatefulSet customization workload check failed:\", errors)\n249\t\n250\t\n251\tdef check_topology():\n252\t    errors = []\n253\t    admin_pw = get_secret_value(ADMIN_SECRET, \"password\", errors)\n254\t    if errors:\n255\t        return fail(\"StatefulSet customization topology check failed:\", errors)\n256\t    # directConnection skips SDAM topology monitoring, which a localhost\n257\t    # connection would start and which fails under a persisted requireTLS mode.\n258\t    admin_uri = f\"mongodb://{ADMIN_USER}:{admin_pw}@localhost:27017/admin?directConnection=true\"\n259\t    primary = _find_primary(admin_uri, errors)\n260\t    status = load_json(primary, admin_uri, \"JSON.stringify(rs.status())\", \"rs.status()\", errors)\n261\t    if isinstance(status, dict):\n262\t        members = status.get(\"members\", [])\n263\t        p = sum(1 for m in members if m.get(\"stateStr\") == \"PRIMARY\")\n264\t        s = sum(1 for m in members if m.get(\"stateStr\") == \"SECONDARY\")\n265\t        if len(members) != EXPECTED_REPLICAS:\n266\t            errors.append(f\"replica set members expected {EXPECTED_REPLICAS}, got {len(members)}\")\n267\t        if p != 1:\n268\t            errors.append(f\"expected 1 PRIMARY, got {p}\")\n269\t        if s != EXPECTED_REPLICAS - 1:\n270\t            errors.append(f\"expected {EXPECTED_REPLICAS - 1} SECONDARY, got {s}\")\n271\t    else:\n272\t        errors.append(\"unable to read replica set status\")\n273\t\n274\t    return fail(\"StatefulSet customization topology check failed:\", errors)\n275\t\n276\t\n277\tdef main():\n278\t    parser = argparse.ArgumentParser()\n279\t    parser.add_argument(\"--check\", default=\"all\", choices=[\"all\", \"template\", \"workload\", \"topology\"])\n280\t    args = parser.parse_args()\n281\t\n282\t    if args.check == \"template\":\n283\t        return check_template()\n284\t    if args.check == \"workload\":\n285\t        return check_workload()\n286\t    if args.check == \"topology\":\n287\t        return check_topology()\n288\t\n289\t    for fn in (check_template, check_workload, check_topology):\n290\t        rc = fn()\n291\t        if rc != 0:\n292\t            return rc\n293\t    print(\"StatefulSet customization verified\")\n294\t    return 0\n295\t\n296\t\n297\tif __name__ == \"__main__\":\n298\t    sys.exit(main())\n299\t"}]},"parent_tool_use_id":null,"session_id":"51099fc9-f5ed-4260-80ad-92cedb39ef33","uuid":"8962e55c-3faf-4e5f-a15d-8856a5c404ff","timestamp":"2026-06-24T05:41:07.487Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/mongodb/statefulset-customization/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport argparse\nimport base64\nimport json\nimport os\nimport subprocess\nimport sys\n\n\nNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"mongodb\")\nCLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"mongodb-replica\")\nADMIN_SECRET = os.environ.get(\"BENCH_PARAM_ADMIN_SECRET_NAME\", \"admin-user-password\")\nADMIN_USER = os.environ.get(\"BENCH_PARAM_ADMIN_USERNAME\", \"admin-user\")\nLABEL_KEY = os.environ.get(\"BENCH_PARAM_TEMPLATE_LABEL_KEY\", \"monitoring\")\nLABEL_VALUE = os.environ.get(\"BENCH_PARAM_TEMPLATE_LABEL_VALUE\", \"enabled\")\nMIN_REQUEST_MEM_MIB = int(os.environ.get(\"BENCH_PARAM_MIN_REQUEST_MEMORY_MI\", \"512\"))\nMIN_LIMIT_MEM_MIB = int(os.environ.get(\"BENCH_PARAM_MIN_LIMIT_MEMORY_MI\", \"1024\"))\nPOD_PREFIX = f\"{CLUSTER_PREFIX}-\"\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\n_TLS_FLAGS_CACHE = None\n\n\ndef _mongo_tls_flags(probe_pod=None):\n    \"\"\"mongosh transport flags that adapt to the cluster's LIVE TLS mode.\n\n    The environment PERSISTS across workflow stages, so an earlier stage\n    (mongodb/tls-setup or mongodb/certificate-rotation) may have turned TLS on,\n    after which a plain mongosh connection is refused. Detect TLS by probing the\n    running mongo pod for a CA cert mounted at the paths the TLS stages use; if\n    present, connect with --tls --tlsCAFile (and a client cert for mutual TLS\n    when one is mounted), else connect plain. Standalone (no CA mounted) this\n    returns [] -> identical plain behaviour. It only adds transport flags; every\n    real check still runs and still fails when its condition is unmet.\n    \"\"\"\n    global _TLS_FLAGS_CACHE\n    if _TLS_FLAGS_CACHE is not None:\n        return list(_TLS_FLAGS_CACHE)\n    flags = []\n    pod = probe_pod or f\"{CLUSTER_PREFIX}-0\"\n    ca_path = None\n    for cand in (\n        \"/etc/tls/ca.crt\",\n        \"/etc/mongo-ca/ca.crt\",\n        \"/etc/mongodb/tls/ca.crt\",\n        \"/etc/ssl/mongodb/ca.crt\",\n    ):\n        probe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + cand])\n        if probe.returncode == 0:\n            ca_path = cand\n            break\n    if ca_path:\n        flags = [\"--tls\", \"--tlsAllowInvalidHostnames\", \"--tlsAllowInvalidCertificates\", \"--tlsCAFile\", ca_path]\n        for client_pem in (\"/etc/tls/client.pem\", \"/etc/mongo-ca/client.pem\"):\n            cprobe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + client_pem])\n            if cprobe.returncode == 0:\n                flags += [\"--tlsCertificateKeyFile\", client_pem]\n                break\n    _TLS_FLAGS_CACHE = flags\n    return list(flags)\n\ndef _resolve_expected_replicas():\n    \"\"\"Topology size to enforce.\n\n    The environment PERSISTS across workflow stages, so an earlier\n    replica-scaling stage may have grown the replica set past the standalone\n    default of 3. Resolve the expected count from (in priority order): an\n    explicit ``expected_replicas``/``target_replicas`` param override, else the\n    LIVE StatefulSet (ready, else spec'd replicas), else the standalone default\n    of 3. This adapts the topology/count check to whatever the workflow\n    accumulated without loosening it -- a non-solving agent that drops or fails\n    a member still mismatches the live ready/spec count.\n    \"\"\"\n    for key in (\"BENCH_PARAM_EXPECTED_REPLICAS\", \"BENCH_PARAM_TARGET_REPLICAS\"):\n        val = os.environ.get(key)\n        if val is not None and str(val).strip():\n            try:\n                return int(val)\n            except ValueError:\n                pass\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", CLUSTER_PREFIX, \"-o\", \"json\"])\n    if res.returncode == 0:\n        try:\n            sts = json.loads(res.stdout)\n            status = sts.get(\"status\", {}) or {}\n            spec = sts.get(\"spec\", {}) or {}\n            live = status.get(\"readyReplicas\")\n            if not isinstance(live, int) or live <= 0:\n                live = spec.get(\"replicas\")\n            if isinstance(live, int) and live > 0:\n                return live\n        except (json.JSONDecodeError, AttributeError):\n            pass\n    return 3\n\n\nEXPECTED_REPLICAS = _resolve_expected_replicas()\n\n\ndef fail(prefix, errors):\n    if errors:\n        print(prefix, file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n    return 0\n\n\ndef get_secret_value(secret_name, key, errors):\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", secret_name, \"-o\", f\"jsonpath={{.data.{key}}}\"])\n    if res.returncode != 0:\n        errors.append(f\"failed to read secret {secret_name}: {res.stderr.strip() or res.stdout.strip()}\")\n        return None\n    raw = (res.stdout or \"\").strip()\n    if not raw:\n        errors.append(f\"secret {secret_name}.{key} empty\")\n        return None\n    try:\n        return base64.b64decode(raw).decode(\"utf-8\")\n    except Exception:\n        errors.append(f\"failed to decode secret {secret_name}.{key}\")\n        return None\n\n\ndef run_mongo(pod, uri, eval_str):\n    return run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"mongosh\", \"--quiet\", *_mongo_tls_flags(), uri, \"--eval\", eval_str])\n\n\ndef load_json(pod, uri, eval_str, label, errors):\n    res = run_mongo(pod, uri, eval_str)\n    if res.returncode != 0:\n        errors.append(f\"{label} failed on {pod}: {res.stderr.strip() or res.stdout.strip()}\")\n        return None\n    raw = (res.stdout or \"\").strip()\n    if not raw:\n        errors.append(f\"{label} returned empty output on {pod}\")\n        return None\n    try:\n        return json.loads(raw)\n    except json.JSONDecodeError:\n        errors.append(f\"unable to parse {label} JSON output on {pod}\")\n        return None\n\n\ndef _parse_mib(value):\n    if value is None:\n        return None\n    text = str(value).strip().lower()\n    if not text:\n        return None\n    try:\n        return int(float(text))\n    except ValueError:\n        pass\n    if text.endswith(\"mi\"):\n        try:\n            return int(float(text[:-2]))\n        except ValueError:\n            return None\n    if text.endswith(\"gi\"):\n        try:\n            return int(float(text[:-2]) * 1024)\n        except ValueError:\n            return None\n    return None\n\n\ndef _find_primary(admin_uri, errors):\n    for i in range(EXPECTED_REPLICAS):\n        pod = f\"{POD_PREFIX}{i}\"\n        res = run_mongo(pod, admin_uri, \"db.hello().isWritablePrimary\")\n        if res.returncode == 0 and \"true\" in (res.stdout or \"\"):\n            return pod\n    errors.append(\"unable to locate primary pod\")\n    return f\"{POD_PREFIX}0\"\n\n\ndef _load_sts(errors):\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", CLUSTER_PREFIX, \"-o\", \"json\"])\n    if res.returncode != 0:\n        errors.append(f\"failed to read statefulset {CLUSTER_PREFIX}: {res.stderr.strip() or res.stdout.strip()}\")\n        return {}\n    try:\n        return json.loads(res.stdout)\n    except json.JSONDecodeError:\n        errors.append(\"failed to parse statefulset JSON\")\n        return {}\n\n\ndef check_template():\n    errors = []\n    sts = _load_sts(errors)\n    if not sts:\n        return fail(\"StatefulSet customization template check failed:\", errors)\n\n    template = sts.get(\"spec\", {}).get(\"template\", {})\n    labels = template.get(\"metadata\", {}).get(\"labels\", {})\n    if labels.get(LABEL_KEY) != LABEL_VALUE:\n        errors.append(f\"template label {LABEL_KEY} expected {LABEL_VALUE}, got {labels.get(LABEL_KEY)}\")\n\n    containers = template.get(\"spec\", {}).get(\"containers\", [])\n    if not containers:\n        errors.append(\"statefulset has no containers\")\n    else:\n        resources = containers[0].get(\"resources\", {})\n        req_mem = _parse_mib(resources.get(\"requests\", {}).get(\"memory\"))\n        lim_mem = _parse_mib(resources.get(\"limits\", {}).get(\"memory\"))\n        if req_mem is None or req_mem < MIN_REQUEST_MEM_MIB:\n            errors.append(f\"requests.memory below minimum {MIN_REQUEST_MEM_MIB}Mi\")\n        if lim_mem is None or lim_mem < MIN_LIMIT_MEM_MIB:\n            errors.append(f\"limits.memory below minimum {MIN_LIMIT_MEM_MIB}Mi\")\n\n    return fail(\"StatefulSet customization template check failed:\", errors)\n\n\ndef check_workload():\n    errors = []\n    sts = _load_sts(errors)\n    if sts:\n        if sts.get(\"spec\", {}).get(\"replicas\") != EXPECTED_REPLICAS:\n            errors.append(\"statefulset replicas mismatch\")\n        if sts.get(\"status\", {}).get(\"readyReplicas\") != EXPECTED_REPLICAS:\n            errors.append(\"ready replicas mismatch\")\n\n    pods_res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"pods\", \"-l\", f\"app={CLUSTER_PREFIX}\", \"-o\", \"json\"])\n    if pods_res.returncode != 0:\n        errors.append(f\"failed to read pods: {pods_res.stderr.strip() or pods_res.stdout.strip()}\")\n        return fail(\"StatefulSet customization workload check failed:\", errors)\n    try:\n        pods = json.loads(pods_res.stdout)\n    except json.JSONDecodeError:\n        errors.append(\"failed to parse pods JSON\")\n        return fail(\"StatefulSet customization workload check failed:\", errors)\n\n    items = pods.get(\"items\", [])\n    if len(items) != EXPECTED_REPLICAS:\n        errors.append(f\"expected {EXPECTED_REPLICAS} pods, got {len(items)}\")\n    for pod in items:\n        name = pod.get(\"metadata\", {}).get(\"name\", \"unknown\")\n        ready = next((c for c in pod.get(\"status\", {}).get(\"conditions\", []) if c.get(\"type\") == \"Ready\"), {})\n        if ready.get(\"status\") != \"True\":\n            errors.append(f\"pod {name} is not Ready\")\n\n    return fail(\"StatefulSet customization workload check failed:\", errors)\n\n\ndef check_topology():\n    errors = []\n    admin_pw = get_secret_value(ADMIN_SECRET, \"password\", errors)\n    if errors:\n        return fail(\"StatefulSet customization topology check failed:\", errors)\n    # directConnection skips SDAM topology monitoring, which a localhost\n    # connection would start and which fails under a persisted requireTLS mode.\n    admin_uri = f\"mongodb://{ADMIN_USER}:{admin_pw}@localhost:27017/admin?directConnection=true\"\n    primary = _find_primary(admin_uri, errors)\n    status = load_json(primary, admin_uri, \"JSON.stringify(rs.status())\", \"rs.status()\", errors)\n    if isinstance(status, dict):\n        members = status.get(\"members\", [])\n        p = sum(1 for m in members if m.get(\"stateStr\") == \"PRIMARY\")\n        s = sum(1 for m in members if m.get(\"stateStr\") == \"SECONDARY\")\n        if len(members) != EXPECTED_REPLICAS:\n            errors.append(f\"replica set members expected {EXPECTED_REPLICAS}, got {len(members)}\")\n        if p != 1:\n            errors.append(f\"expected 1 PRIMARY, got {p}\")\n        if s != EXPECTED_REPLICAS - 1:\n            errors.append(f\"expected {EXPECTED_REPLICAS - 1} SECONDARY, got {s}\")\n    else:\n        errors.append(\"unable to read replica set status\")\n\n    return fail(\"StatefulSet customization topology check failed:\", errors)\n\n\ndef main():\n    parser = argparse.ArgumentParser()\n    parser.add_argument(\"--check\", default=\"all\", choices=[\"all\", \"template\", \"workload\", \"topology\"])\n    args = parser.parse_args()\n\n    if args.check == \"template\":\n        return check_template()\n    if args.check == \"workload\":\n        return check_workload()\n    if args.check == \"topology\":\n        return check_topology()\n\n    for fn in (check_template, check_workload, check_topology):\n        rc = fn()\n        if rc != 0:\n            return rc\n    print(\"StatefulSet customization verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":299,"startLine":1,"totalLines":299}}}
