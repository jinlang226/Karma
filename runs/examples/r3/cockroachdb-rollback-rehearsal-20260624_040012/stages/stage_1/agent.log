tting zone configurations ---\"\n\necho \"  RANGE default gc.ttlseconds: 14400 s → 90000 s (factory default)\"\nsql \"ALTER RANGE default CONFIGURE ZONE USING gc.ttlseconds = 90000;\"\n\n# ── 3. Verification ──────────────────────────────────────────────────────────\n\necho \"\"\necho \"--- Verification ---\"\n\necho \"  Cluster settings (should show no rows — all back to default):\"\nsql \"SELECT variable, value, default_value\n     FROM crdb_internal.cluster_settings\n     WHERE variable IN (\n       'diagnostics.reporting.enabled',\n       'kv.snapshot_rebalance.max_rate'\n     );\"\n\necho \"  RANGE default zone config:\"\nsql \"SHOW ZONE CONFIGURATION FOR RANGE default;\"\n\necho \"\"\necho \"=== Rollback complete ===\"\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":5729,"cache_read_input_tokens":31328,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":5729},"output_tokens":32,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"fe48a56f-50f3-4cfd-b4cf-0e28611d90da","uuid":"e428aac5-5951-4a8f-9ce7-8c378e1d73dc","request_id":"req_011CcMRi5iVSoyT2nrsE2X7F"}
