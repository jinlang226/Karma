rd port 8265,\n#      restoring the original single-port spec (gcs/6379 only).\n#      The original spec is confirmed by the service's own\n#      kubectl.kubernetes.io/last-applied-configuration annotation.\n#\n# Images (rayproject/ray:2.9.0) and resource limits ({}) are unchanged\n# from baseline — no action required for those fields.\n#\n# DO NOT run this script while the cluster is serving production traffic\n# without scheduling the change window first.\n\nset -euo pipefail\n\nNAMESPACE=ray\n\necho \"=== Ray cluster rollback — $(date -u '+%Y-%m-%dT%H:%M:%SZ') ===\"\n\n# ── 1. Worker replica count ───────────────────────────────────────────────────\necho \"[1/2] Reverting ray-worker replicas: 3 → 2\"\nkubectl -n \"${NAMESPACE}\" scale deploy ray-worker --replicas=2\necho \"      Done. Current replicas: $(kubectl -n \"${NAMESPACE}\" get deploy ray-worker -o jsonpath='{.spec.replicas}')\"\n\n# ── 2. ray-head Service — remove dashboard port 8265 ─────────────────────────\n# Baseline spec (from last-applied-configuration) contained only:\n#   - name: gcs  port: 6379  targetPort: 6379\n# The dashboard port was added after initial deployment and must be removed.\necho \"[2/2] Removing dashboard port (8265) from ray-head Service\"\nkubectl -n \"${NAMESPACE}\" patch svc ray-head --type=json \\\n  -p='[{\"op\":\"replace\",\"path\":\"/spec/ports\",\"value\":[{\"name\":\"gcs\",\"port\":6379,\"protocol\":\"TCP\",\"targetPort\":6379}]}]'\necho \"      Done. Active ports: $(kubectl -n \"${NAMESPACE}\" get svc ray-head -o jsonpath='{range .spec.ports[*]}{.name}={.port} {end}')\"\n\necho \"=== Rollback complete ===\"\n","userModified":false}}
