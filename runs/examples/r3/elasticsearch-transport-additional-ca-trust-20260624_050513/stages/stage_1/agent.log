2.key -sha256 -days 3650 -subj \"/CN=es-ca-2\" -out /tmp/certs/ca2.crt\n87\t          openssl genrsa -out /tmp/certs/server1.key 2048\n88\t          openssl req -new -key /tmp/certs/server1.key -out /tmp/certs/server1.csr -config /tmp/certs/openssl.cnf\n89\t          openssl x509 -req -in /tmp/certs/server1.csr -CA /tmp/certs/ca1.crt -CAkey /tmp/certs/ca1.key -CAcreateserial -out /tmp/certs/server1.crt -days 365 -extensions v3_req -extfile /tmp/certs/openssl.cnf\n90\t          openssl genrsa -out /tmp/certs/server2.key 2048\n91\t          openssl req -new -key /tmp/certs/server2.key -out /tmp/certs/server2.csr -config /tmp/certs/openssl.cnf\n92\t          openssl x509 -req -in /tmp/certs/server2.csr -CA /tmp/certs/ca2.crt -CAkey /tmp/certs/ca2.key -CAcreateserial -out /tmp/certs/server2.crt -days 365 -extensions v3_req -extfile /tmp/certs/openssl.cnf\n93\t          '\\''\n94\t          kubectl -n elasticsearch cp openssl-toolbox:/tmp/certs \"${TMP_DIR}/certs\"\n95\t          kubectl -n elasticsearch create secret generic {{params.ca1_secret_name}} --from-file=ca.crt=\"${TMP_DIR}/certs/ca1.crt\" --from-file=node.crt=\"${TMP_DIR}/certs/server1.crt\" --from-file=node.key=\"${TMP_DIR}/certs/server1.key\" --dry-run=client -o yaml | kubectl apply -f -\n96\t          kubectl -n elasticsearch create secret generic {{params.ca2_secret_name}} --from-file=ca.crt=\"${TMP_DIR}/certs/ca2.crt\" --from-file=node.crt=\"${TMP_DIR}/certs/server2.crt\" --from-file=node.key=\"${TMP_DIR}/certs/server2.key\" --dry-run=client -o yaml | kubectl apply -f -\n97\t          cat \"${TMP_DIR}/certs/ca1.crt\" \"${TMP_DIR}/certs/ca2.crt\" > \"${TMP_DIR}/certs/transport-bundle.crt\"\n98\t          kubectl -n elasticsearch create configmap {{params.transport_bundle_configmap}} --from-file=ca.crt=\"${TMP_DIR}/certs/transport-bundle.crt\" --dry-run=client -o yaml | kubectl apply -f -\n99\t          '\n100\t        sleep: 1\n101\t      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod -l app={{params.cluster_prefix}} --timeout=600s\"\n102\t        sleep: 1\n103\t      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod/curl-test --timeout=300s\"\n104\t        sleep: 1\n105\t    verify:\n106\t      - command: \"kubectl -n elasticsearch get pods 2>/dev/null | grep -c Running\"\n107\t        timeout_sec: 10\n108\t\n109\t  # Self-contained transport CA bundle (composition safety): the oracle requires the\n110\t  # {{params.transport_bundle_configmap}} ConfigMap to trust 2 CA certs. es_env_ready\n111\t  # seeds it on its destructive fresh-build path, which is SKIPPED on an inherited\n112\t  # cluster (the probe sees pods Running), so the ConfigMap is absent and the oracle\n113\t  # fails \"configmap not found\". Establish it additively when missing: generate two\n114\t  # self-signed CA certs in the openssl helper and create the 2-cert bundle. It never\n115\t  # deletes the namespace or touches the running nodes -- the inherited cluster keeps\n116\t  # its own transport config; this bundle satisfies the trust invariant the oracle\n117\t  # checks (the agent's task per the prompt is node-restore, not CA work). Standalone\n118\t  # the ConfigMap already exists so the probe matches and this unit skips.\n119\t  - name: transport_ca_bundle_fixture\n120\t    on_probe_fail: skip\n121\t    probe:\n122\t      - command: \"kubectl -n elasticsearch get configmap {{params.transport_bundle_configmap}}\"\n123\t        timeout_sec: 10\n124\t    apply:\n125\t      - command: \"/bin/sh -c 'kubectl -n elasticsearch get pod openssl-toolbox >/dev/null 2>&1 || kubectl -n elasticsearch apply -f cases/elasticsearch/transport-additional-ca-trust/resource/openssl-toolbox.yaml'\"\n126\t        sleep: 2\n127\t      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod/openssl-toolbox --timeout=300s\"\n128\t        sleep: 1\n129\t      - command: |\n130\t          /bin/sh -c '\n131\t          set -e\n132\t          TMP_DIR=$(mktemp -d)\n133\t    