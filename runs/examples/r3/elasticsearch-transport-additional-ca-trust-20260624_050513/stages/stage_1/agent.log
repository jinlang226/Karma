{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01VUHc8LMJw53UmkbkzuuFjR","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport base64\n3\timport json\n4\timport os\n5\timport re\n6\timport shlex\n7\timport subprocess\n8\timport sys\n9\t\n10\t\n11\tNAMESPACE = \"elasticsearch\"\n12\tSERVICE = \"es-http\"\n13\t# Hint for the Elasticsearch pod app label. Used as an override when it matches a\n14\t# live StatefulSet's selector; otherwise the real selector label is detected\n15\t# live from the cluster. The env PERSISTS across stages, so a workflow's\n16\t# inherited ES cluster may label its pods differently than this case's standalone\n17\t# default of 'es-cluster'.\n18\tCLUSTER_PREFIX_HINT = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"es-cluster\")\n19\tDEFAULT_SCHEME = \"http\"\n20\t_SCHEME = None\n21\t\n22\t\n23\tdef run(cmd):\n24\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n25\t\n26\t\n27\t_ELASTIC_PW = None\n28\t\n29\t\n30\tdef _elastic_password():\n31\t    \"\"\"Live elastic-user password.\n32\t\n33\t    Reads the elastic-password secret, base64-decoded. The env PERSISTS across\n34\t    stages, so a prior rotate-elastic-password stage may have rotated the\n35\t    password away from this case's standalone default — the running curl-test\n36\t    pod's $ES_PASS env was captured at pod creation and goes stale after such a\n37\t    rotation (env from a secret does not live-update), which is why the queries\n38\t    must read the secret fresh here. Falls back to the case default. Cached so\n39\t    the retry loop does not re-read the secret each attempt.\n40\t    \"\"\"\n41\t    global _ELASTIC_PW\n42\t    if _ELASTIC_PW is not None:\n43\t        return _ELASTIC_PW\n44\t    r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", \"elastic-password\",\n45\t             \"-o\", \"jsonpath={.data.password}\"])\n46\t    pw = None\n47\t    if r.returncode == 0 and r.stdout.strip():\n48\t        try:\n49\t            pw = base64.b64decode(r.stdout.strip()).decode()\n50\t        except Exception:\n51\t            pw = None\n52\t    _ELASTIC_PW = pw or os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD\") or \"elasticpass\"\n53\t    return _ELASTIC_PW\n54\t\n55\t\n56\tdef _auth_flag():\n57\t    \"\"\"`-u elastic:<live-pw>`, shell-quoted for the curl-test pod's /bin/sh.\"\"\"\n58\t    return \"-u \" + shlex.quote(\"elastic:\" + _elastic_password())\n59\t\n60\t\n61\t_APP_LABEL = None\n62\t\n63\t\n64\tdef resolve_app_label():\n65\t    \"\"\"Resolve the 'app=<value>' selector for the live ES pods.\n66\t\n67\t    Priority: the BENCH_PARAM_CLUSTER_PREFIX hint when some live StatefulSet\n68\t    actually selects on app=<hint> (explicit override wins) -> the app label of\n69\t    the namespace's Elasticsearch StatefulSet detected live -> the hint.\n70\t    Workflow-agnostic: adapts to an inherited cluster labelled e.g.\n71\t    app=elasticsearch instead of app=es-cluster.\n72\t    \"\"\"\n73\t    global _APP_LABEL\n74\t    if _APP_LABEL is not None:\n75\t        return _APP_LABEL\n76\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n77\t    labels = []\n78\t    if res.returncode == 0:\n79\t        try:\n80\t            for sts in json.loads(res.stdout).get(\"items\", []):\n81\t                spec = sts.get(\"spec\", {})\n82\t                containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n83\t                if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n84\t                    continue\n85\t                app = (spec.get(\"selector\", {}).get(\"matchLabels\", {}) or {}).get(\"app\")\n86\t                ts = sts.get(\"metadata\", {}).get(\"creationTimestamp\", \"\")\n87\t                if app:\n88\t                    labels.append((app, ts))\n89\t        except (json.JSONDecodeError, AttributeError):\n90\t            pass\n91\t    if any(app == CLUSTER_PREFIX_HINT for app, _ in labels):\n92\t        _APP_LABEL = f\"app={CLUSTER_PREFIX_HINT}\"\n93\t        return _APP_LABEL\n94\t    if labels:\n95\t        labels.sort(key=lambda x: (x[1] or \"\"))\n96\t        _APP_LABEL = f\"app={labels[0][0]}\"\n97\t        return _APP_LABEL\n98\t    _APP_LABEL = f\"app={CLUSTER_PREFIX_HINT}\"\n99\t    return _APP_LABEL\n100\t\n101\t\n102\tAPP_LABEL = resolve_app_label()\n103\t\n104\t\n105\tdef _list_es_statefulset_replicas():\n106\t    \"\"\"Return {sts_name: spec.replicas} for the namespace's Elasticsearch\n107\t    StatefulSets (those whose pod template runs an Elasticsearch image).\"\"\"\n108\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n109\t    if res.returncode != 0:\n110\t        return {}\n111\t    try:\n112\t        items = json.loads(res.stdout).get(\"items\", [])\n113\t    except (json.JSONDecodeError, AttributeError):\n114\t        return {}\n115\t    out = {}\n116\t    for sts in items:\n117\t        spec = sts.get(\"spec\", {})\n118\t        containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n119\t        if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n120\t            continue\n121\t        name = sts.get(\"metadata\", {}).get(\"name\")\n122\t        replicas = spec.get(\"replicas\")\n123\t        if name and isinstance(replicas, int):\n124\t            out[name] = replicas\n125\t    return out\n126\t\n127\t\n128\tdef _sts_name_for_node(node_name):\n129\t    \"\"\"Map a live ES node name to its backing StatefulSet name.\n130\t\n131\t    An ES node name equals its pod name, which for a StatefulSet pod is\n132\t    ``<statefulset-name>-<ordinal>`` (e.g. ``es-cluster-0`` -> ``es-cluster``,\n133\t    ``es-data-1`` -> ``es-data``). Strip the trailing ``-<digits>`` ordinal.\n134\t    Returns the node name unchanged if it carries no ordinal suffix.\n135\t    \"\"\"\n136\t    if not node_name:\n137\t        return node_name\n138\t    return re.sub(r\"-\\d+$\", \"\", node_name)\n139\t\n140\t\n141\tdef _live_sts_names(node_names):\n142\t    \"\"\"Set of StatefulSet names actually backing the live cluster nodes.\n143\t\n144\t    Derived by stripping each live node name's ordinal. This excludes\n145\t    accumulated/stale/other ES StatefulSets in the (persisted) namespace that\n146\t    back no node in the queried cluster.\n147\t    \"\"\"\n148\t    return {_sts_name_for_node(n) for n in node_names if n}\n149\t\n150\t\n151\tdef _resolve_expected_nodes(node_names, default=3):\n152\t    \"\"\"Expected node count to enforce, derived from the LIVE cluster.\n153\t\n154\t    The expected total is the DESIRED topology of ONLY the StatefulSets that\n155\t    actually back the live cluster (the nodes returned by ``_cat/nodes``): the\n156\t    sum of spec.replicas over just those StatefulSets. The namespace PERSISTS\n157\t    across workflow stages and accumulates multiple ES clusters, so summing\n158\t    replicas across *every* ES StatefulSet overcounts versus the single cluster\n159\t    the oracle queries. Restricting to the live cluster's StatefulSets fixes that.\n160\t\n161\t    Using DESIRED spec.replicas (not the live count) keeps the check strict: a\n162\t    node that FAILED to join leaves its StatefulSet \"live\" (siblings are up) but\n163\t    absent from ``_cat/nodes``, so EXPECTED stays above the actual count -- no\n164\t    masking. The LIVE cluster is derived FIRST; the param is a FALLBACK used only\n165\t    when no live StatefulSets resolve (e.g. _cat/nodes failed or returned empty).\n166\t    \"\"\"\n167\t    # Derive from the LIVE cluster FIRST (workflow-agnostic + composition-aware):\n168\t    # sum spec.replicas over ONLY the ES StatefulSets that actually back a live\n169\t    # node returned by ``_cat/nodes`` (the queried cluster). The namespace\n170\t    # PERSISTS across workflow stages and ACCUMULATES several ES clusters/nodesets;\n171\t    # summing spec.replicas across *every* ES StatefulSet overcounts the single\n172\t    # cluster the oracle queries. Mapping each live node name -> its StatefulSet\n173\t    # (strip the pod ordinal) scopes the sum to the cluster under test. A static\n174\t    # EXPECTED_NODES param encodes a standalone baseline that ignores inherited\n175\t    # nodesets, so it is demoted to a FALLBACK below.\n176\t    #\n177\t    # Using DESIRED spec.replicas (not the raw live count) keeps the check strict:\n178\t    # a node that FAILED to join leaves its StatefulSet \"live\" (siblings appear in\n179\t    # _cat/nodes) but absent itself, so the spec sum stays above the actual count.\n180\t    live_sts = _live_sts_names(node_names)\n181\t    if live_sts:\n182\t        res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n183\t        if res.returncode == 0:\n184\t            try:\n185\t                items = json.loads(res.stdout).get(\"items\", [])\n186\t            except Exception:\n187\t                items = []\n188\t            desired = 0\n189\t            for sts in items:\n190\t                spec = sts.get(\"spec\", {}) or {}\n191\t                name = (sts.get(\"metadata\", {}) or {}).get(\"name\")\n192\t                if name not in live_sts:\n193\t                    continue\n194\t                containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", []) or []\n195\t                if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n196\t                    continue\n197\t                replicas = spec.get(\"replicas\")\n198\t                being_deleted = (sts.get(\"metadata\", {}) or {}).get(\"deletionTimestamp\") is not None\n199\t                if isinstance(replicas, int) and replicas > 0 and not being_deleted:\n200\t                    desired += replicas\n201\t            if desired > 0:\n202\t                return desired\n203\t\n204\t    # Fallbacks (live cluster unresolvable): explicit param, then the default.\n205\t    for key in (\"BENCH_PARAM_EXPECTED_NODES\", \"BENCH_PARAM_EXPECTED_NODE_COUNT\"):\n206\t        val = os.environ.get(key)\n207\t        if val is not None and str(val).strip():\n208\t            try:\n209\t                return int(val)\n210\t            except ValueError:\n211\t                pass\n212\t    return default\n213\t\n214\t\n215\tdef _probe_scheme(scheme):\n216\t    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\n217\t\n218\t    Authenticates with the same live elastic password the real queries use; a\n219\t    401 still proves the scheme is live, so any HTTP status code counts.\n220\t    \"\"\"\n221\t    result = run([\n222\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\", \"/bin/sh\", \"-c\",\n223\t        (\"curl -s -S -k -o /dev/null -w '%{http_code}' --max-time 5 \"\n224\t         f\"{_auth_flag()} \"\n225\t         f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200/\"),\n226\t    ])\n227\t    code = (result.stdout or \"\").strip().strip(\"'\")\n228\t    return result.returncode == 0 and code.isdigit() and code != \"000\"\n229\t\n230\t\n231\tdef detect_scheme():\n232\t    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n233\t    global _SCHEME\n234\t    if _SCHEME is not None:\n235\t        return _SCHEME\n236\t    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n237\t        if _probe_scheme(scheme):\n238\t            _SCHEME = scheme\n239\t            return _SCHEME\n240\t    _SCHEME = DEFAULT_SCHEME\n241\t    return _SCHEME\n242\t\n243\t\n244\tdef curl(path, errors):\n245\t    scheme = detect_scheme()\n246\t    cmd = [\n247\t        \"kubectl\",\n248\t        \"-n\",\n249\t        NAMESPACE,\n250\t        \"exec\",\n251\t        \"curl-test\",\n252\t        \"--\",\n253\t        \"/bin/sh\",\n254\t        \"-c\",\n255\t        # The client deadline (--max-time 20) must exceed any server-side\n256\t        # ``wait_for`` in `path`, otherwise curl aborts (exit 28) before ES can\n257\t        # answer. The retry loop in main() does the real waiting, so each call's\n258\t        # server wait stays short (10s).\n259\t        (\n260\t            f\"curl -s -S -k --max-time 20 {_auth_flag()} \"\n261\t            f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\"\n262\t        ),\n263\t    ]\n264\t\n265\t    result = run(cmd)\n266\t    if result.returncode != 0:\n267\t        stderr = result.stderr.strip()\n268\t        stdout = result.stdout.strip()\n269\t        detail = stderr or stdout or f\"command terminated with exit code {result.returncode}\"\n270\t        errors.append(f\"Failed to query {path}: {detail}\")\n271\t        return None\n272\t    output = result.stdout.strip()\n273\t    if not output:\n274\t        errors.append(f\"Empty response for {path}\")\n275\t        return None\n276\t    try:\n277\t        return json.loads(output)\n278\t    except json.JSONDecodeError:\n279\t        errors.append(f\"Failed to parse JSON from {path}\")\n280\t        return None\n281\t\n282\t\n283\tdef evaluate():\n284\t    \"\"\"Run one full snapshot of the transport-CA checks; return the errors.\"\"\"\n285\t    errors = []\n286\t\n287\t    cm_result = run(\n288\t        [\n289\t            \"kubectl\",\n290\t            \"-n\",\n291\t            NAMESPACE,\n292\t            \"get\",\n293\t            \"configmap\",\n294\t            \"es-transport-ca-bundle\",\n295\t            \"-o\",\n296\t            \"json\",\n297\t        ]\n298\t    )\n299\t    if cm_result.returncode != 0:\n300\t        errors.append(\n301\t            f\"Failed to read es-transport-ca-bundle ConfigMap: {cm_result.stderr.strip()}\"\n302\t        )\n303\t    else:\n304\t        try:\n305\t            cm = json.loads(cm_result.stdout)\n306\t        except json.JSONDecodeError:\n307\t            errors.append(\"Failed to parse es-transport-ca-bundle ConfigMap JSON\")\n308\t            cm = {}\n309\t        bundle = cm.get(\"data\", {}).get(\"ca.crt\", \"\")\n310\t        cert_count = bundle.count(\"BEGIN CERTIFICATE\")\n311\t        if cert_count < 2:\n312\t            errors.append(\n313\t                f\"Transport CA bundle should contain 2 certs, found {cert_count}\"\n314\t            )\n315\t\n316\t    # Resolve the live cluster's node list FIRST: the expected node count is\n317\t    # derived from only the StatefulSets that actually back these live nodes\n318\t    # (the persisted namespace accumulates several ES clusters across stages, so\n319\t    # summing every ES StatefulSet's replicas overcounts the queried cluster).\n320\t    nodes = curl(\"/_cat/nodes?format=json\", errors)\n321\t    node_names = []\n322\t    if isinstance(nodes, list):\n323\t        node_names = [n.get(\"name\") for n in nodes if n.get(\"name\")]\n324\t    expected_nodes = _resolve_expected_nodes(node_names, default=3)\n325\t\n326\t    health = curl(\n327\t        f\"/_cluster/health?wait_for_status=yellow&wait_for_nodes={expected_nodes}&timeout=10s\",\n328\t        errors,\n329\t    )\n330\t    if isinstance(health, dict):\n331\t        status = health.get(\"status\")\n332\t        if status not in {\"yellow\", \"green\"}:\n333\t            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n334\t        if health.get(\"number_of_nodes\") != expected_nodes:\n335\t            errors.append(\n336\t                f\"Expected {expected_nodes} nodes, got {health.get('number_of_nodes')}\"\n337\t            )\n338\t\n339\t    if isinstance(nodes, list):\n340\t        if len(node_names) != expected_nodes:\n341\t            errors.append(f\"Expected {expected_nodes} nodes in _cat/nodes, got {len(node_names)}\")\n342\t\n343\t    return errors\n344\t\n345\t\n346\tdef main():\n347\t    # A multi-node ES cluster can flap at the edge of readiness under load: a\n348\t    # node briefly fails its HTTP readiness probe / drops from the cluster during\n349\t    # GC or shard recovery even though it is stably green. A single snapshot can\n350\t    # catch that transient and report a false node-count miss. So verify the\n351\t    # STABLE converged state: re-evaluate for up to ~75s and pass on the first\n352\t    # clean snapshot. This does not loosen the N-node/green/CA-bundle\n353\t    # requirements -- a genuinely degraded cluster fails every attempt.\n354\t    import time\n355\t    deadline = time.monotonic() + 75\n356\t    errors = evaluate()\n357\t    while errors and time.monotonic() < deadline:\n358\t        time.sleep(8)\n359\t        errors = evaluate()\n360\t\n361\t    if errors:\n362\t        print(\"Transport CA trust verification failed:\", file=sys.stderr)\n363\t        for err in errors:\n364\t            print(f\"  - {err}\", file=sys.stderr)\n365\t        return 1\n366\t\n367\t    print(\"Transport CA trust verified\")\n368\t    return 0\n369\t\n370\t\n371\tif __name__ == \"__main__\":\n372\t    sys.exit(main())\n373\t"}]},"parent_tool_use_id":null,"session_id":"0c965969-72b1-42a7-a03e-f366caf2b51f","uuid":"cb54fc1e-698a-44ec-a649-47b92fbff6ef","timestamp":"2026-06-24T05:09:34.329Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/elasticsearch/transport-additional-ca-trust/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport base64\nimport json\nimport os\nimport re\nimport shlex\nimport subprocess\nimport sys\n\n\nNAMESPACE = \"elasticsearch\"\nSERVICE = \"es-http\"\n# Hint for the Elasticsearch pod app label. Used as an override when it matches a\n# live StatefulSet's selector; otherwise the real selector label is detected\n# live from the cluster. The env PERSISTS across stages, so a workflow's\n# inherited ES cluster may label its pods differently than this case's standalone\n# default of 'es-cluster'.\nCLUSTER_PREFIX_HINT = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"es-cluster\")\nDEFAULT_SCHEME = \"http\"\n_SCHEME = None\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\n_ELASTIC_PW = None\n\n\ndef _elastic_password():\n    \"\"\"Live elastic-user password.\n\n    Reads the elastic-password secret, base64-decoded. The env PERSISTS across\n    stages, so a prior rotate-elastic-password stage may have rotated the\n    password away from this case's standalone default — the running curl-test\n    pod's $ES_PASS env was captured at pod creation and goes stale after such a\n    rotation (env from a secret does not live-update), which is why the queries\n    must read the secret fresh here. Falls back to the case default. Cached so\n    the retry loop does not re-read the secret each attempt.\n    \"\"\"\n    global _ELASTIC_PW\n    if _ELASTIC_PW is not None:\n        return _ELASTIC_PW\n    r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", \"elastic-password\",\n             \"-o\", \"jsonpath={.data.password}\"])\n    pw = None\n    if r.returncode == 0 and r.stdout.strip():\n        try:\n            pw = base64.b64decode(r.stdout.strip()).decode()\n        except Exception:\n            pw = None\n    _ELASTIC_PW = pw or os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD\") or \"elasticpass\"\n    return _ELASTIC_PW\n\n\ndef _auth_flag():\n    \"\"\"`-u elastic:<live-pw>`, shell-quoted for the curl-test pod's /bin/sh.\"\"\"\n    return \"-u \" + shlex.quote(\"elastic:\" + _elastic_password())\n\n\n_APP_LABEL = None\n\n\ndef resolve_app_label():\n    \"\"\"Resolve the 'app=<value>' selector for the live ES pods.\n\n    Priority: the BENCH_PARAM_CLUSTER_PREFIX hint when some live StatefulSet\n    actually selects on app=<hint> (explicit override wins) -> the app label of\n    the namespace's Elasticsearch StatefulSet detected live -> the hint.\n    Workflow-agnostic: adapts to an inherited cluster labelled e.g.\n    app=elasticsearch instead of app=es-cluster.\n    \"\"\"\n    global _APP_LABEL\n    if _APP_LABEL is not None:\n        return _APP_LABEL\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n    labels = []\n    if res.returncode == 0:\n        try:\n            for sts in json.loads(res.stdout).get(\"items\", []):\n                spec = sts.get(\"spec\", {})\n                containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n                if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n                    continue\n                app = (spec.get(\"selector\", {}).get(\"matchLabels\", {}) or {}).get(\"app\")\n                ts = sts.get(\"metadata\", {}).get(\"creationTimestamp\", \"\")\n                if app:\n                    labels.append((app, ts))\n        except (json.JSONDecodeError, AttributeError):\n            pass\n    if any(app == CLUSTER_PREFIX_HINT for app, _ in labels):\n        _APP_LABEL = f\"app={CLUSTER_PREFIX_HINT}\"\n        return _APP_LABEL\n    if labels:\n        labels.sort(key=lambda x: (x[1] or \"\"))\n        _APP_LABEL = f\"app={labels[0][0]}\"\n        return _APP_LABEL\n    _APP_LABEL = f\"app={CLUSTER_PREFIX_HINT}\"\n    return _APP_LABEL\n\n\nAPP_LABEL = resolve_app_label()\n\n\ndef _list_es_statefulset_replicas():\n    \"\"\"Return {sts_name: spec.replicas} for the namespace's Elasticsearch\n    StatefulSets (those whose pod template runs an Elasticsearch image).\"\"\"\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n    if res.returncode != 0:\n        return {}\n    try:\n        items = json.loads(res.stdout).get(\"items\", [])\n    except (json.JSONDecodeError, AttributeError):\n        return {}\n    out = {}\n    for sts in items:\n        spec = sts.get(\"spec\", {})\n        containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n        if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n            continue\n        name = sts.get(\"metadata\", {}).get(\"name\")\n        replicas = spec.get(\"replicas\")\n        if name and isinstance(replicas, int):\n            out[name] = replicas\n    return out\n\n\ndef _sts_name_for_node(node_name):\n    \"\"\"Map a live ES node name to its backing StatefulSet name.\n\n    An ES node name equals its pod name, which for a StatefulSet pod is\n    ``<statefulset-name>-<ordinal>`` (e.g. ``es-cluster-0`` -> ``es-cluster``,\n    ``es-data-1`` -> ``es-data``). Strip the trailing ``-<digits>`` ordinal.\n    Returns the node name unchanged if it carries no ordinal suffix.\n    \"\"\"\n    if not node_name:\n        return node_name\n    return re.sub(r\"-\\d+$\", \"\", node_name)\n\n\ndef _live_sts_names(node_names):\n    \"\"\"Set of StatefulSet names actually backing the live cluster nodes.\n\n    Derived by stripping each live node name's ordinal. This excludes\n    accumulated/stale/other ES StatefulSets in the (persisted) namespace that\n    back no node in the queried cluster.\n    \"\"\"\n    return {_sts_name_for_node(n) for n in node_names if n}\n\n\ndef _resolve_expected_nodes(node_names, default=3):\n    \"\"\"Expected node count to enforce, derived from the LIVE cluster.\n\n    The expected total is the DESIRED topology of ONLY the StatefulSets that\n    actually back the live cluster (the nodes returned by ``_cat/nodes``): the\n    sum of spec.replicas over just those StatefulSets. The namespace PERSISTS\n    across workflow stages and accumulates multiple ES clusters, so summing\n    replicas across *every* ES StatefulSet overcounts versus the single cluster\n    the oracle queries. Restricting to the live cluster's StatefulSets fixes that.\n\n    Using DESIRED spec.replicas (not the live count) keeps the check strict: a\n    node that FAILED to join leaves its StatefulSet \"live\" (siblings are up) but\n    absent from ``_cat/nodes``, so EXPECTED stays above the actual count -- no\n    masking. The LIVE cluster is derived FIRST; the param is a FALLBACK used only\n    when no live StatefulSets resolve (e.g. _cat/nodes failed or returned empty).\n    \"\"\"\n    # Derive from the LIVE cluster FIRST (workflow-agnostic + composition-aware):\n    # sum spec.replicas over ONLY the ES StatefulSets that actually back a live\n    # node returned by ``_cat/nodes`` (the queried cluster). The namespace\n    # PERSISTS across workflow stages and ACCUMULATES several ES clusters/nodesets;\n    # summing spec.replicas across *every* ES StatefulSet overcounts the single\n    # cluster the oracle queries. Mapping each live node name -> its StatefulSet\n    # (strip the pod ordinal) scopes the sum to the cluster under test. A static\n    # EXPECTED_NODES param encodes a standalone baseline that ignores inherited\n    # nodesets, so it is demoted to a FALLBACK below.\n    #\n    # Using DESIRED spec.replicas (not the raw live count) keeps the check strict:\n    # a node that FAILED to join leaves its StatefulSet \"live\" (siblings appear in\n    # _cat/nodes) but absent itself, so the spec sum stays above the actual count.\n    live_sts = _live_sts_names(node_names)\n    if live_sts:\n        res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n        if res.returncode == 0:\n            try:\n                items = json.loads(res.stdout).get(\"items\", [])\n            except Exception:\n                items = []\n            desired = 0\n            for sts in items:\n                spec = sts.get(\"spec\", {}) or {}\n                name = (sts.get(\"metadata\", {}) or {}).get(\"name\")\n                if name not in live_sts:\n                    continue\n                containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", []) or []\n                if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n                    continue\n                replicas = spec.get(\"replicas\")\n                being_deleted = (sts.get(\"metadata\", {}) or {}).get(\"deletionTimestamp\") is not None\n                if isinstance(replicas, int) and replicas > 0 and not being_deleted:\n                    desired += replicas\n            if desired > 0:\n                return desired\n\n    # Fallbacks (live cluster unresolvable): explicit param, then the default.\n    for key in (\"BENCH_PARAM_EXPECTED_NODES\", \"BENCH_PARAM_EXPECTED_NODE_COUNT\"):\n        val = os.environ.get(key)\n        if val is not None and str(val).strip():\n            try:\n                return int(val)\n            except ValueError:\n                pass\n    return default\n\n\ndef _probe_scheme(scheme):\n    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\n\n    Authenticates with the same live elastic password the real queries use; a\n    401 still proves the scheme is live, so any HTTP status code counts.\n    \"\"\"\n    result = run([\n        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\", \"/bin/sh\", \"-c\",\n        (\"curl -s -S -k -o /dev/null -w '%{http_code}' --max-time 5 \"\n         f\"{_auth_flag()} \"\n         f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200/\"),\n    ])\n    code = (result.stdout or \"\").strip().strip(\"'\")\n    return result.returncode == 0 and code.isdigit() and code != \"000\"\n\n\ndef detect_scheme():\n    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n    global _SCHEME\n    if _SCHEME is not None:\n        return _SCHEME\n    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n        if _probe_scheme(scheme):\n            _SCHEME = scheme\n            return _SCHEME\n    _SCHEME = DEFAULT_SCHEME\n    return _SCHEME\n\n\ndef curl(path, errors):\n    scheme = detect_scheme()\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"exec\",\n        \"curl-test\",\n        \"--\",\n        \"/bin/sh\",\n        \"-c\",\n        # The client deadline (--max-time 20) must exceed any server-side\n        # ``wait_for`` in `path`, otherwise curl aborts (exit 28) before ES can\n        # answer. The retry loop in main() does the real waiting, so each call's\n        # server wait stays short (10s).\n        (\n            f\"curl -s -S -k --max-time 20 {_auth_flag()} \"\n            f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\"\n        ),\n    ]\n\n    result = run(cmd)\n    if result.returncode != 0:\n        stderr = result.stderr.strip()\n        stdout = result.stdout.strip()\n        detail = stderr or stdout or f\"command terminated with exit code {result.returncode}\"\n        errors.append(f\"Failed to query {path}: {detail}\")\n        return None\n    output = result.stdout.strip()\n    if not output:\n        errors.append(f\"Empty response for {path}\")\n        return None\n    try:\n        return json.loads(output)\n    except json.JSONDecodeError:\n        errors.append(f\"Failed to parse JSON from {path}\")\n        return None\n\n\ndef evaluate():\n    \"\"\"Run one full snapshot of the transport-CA checks; return the errors.\"\"\"\n    errors = []\n\n    cm_result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"get\",\n            \"configmap\",\n            \"es-transport-ca-bundle\",\n            \"-o\",\n            \"json\",\n        ]\n    )\n    if cm_result.returncode != 0:\n        errors.append(\n            f\"Failed to read es-transport-ca-bundle ConfigMap: {cm_result.stderr.strip()}\"\n        )\n    else:\n        try:\n            cm = json.loads(cm_result.stdout)\n        except json.JSONDecodeError:\n            errors.append(\"Failed to parse es-transport-ca-bundle ConfigMap JSON\")\n            cm = {}\n        bundle = cm.get(\"data\", {}).get(\"ca.crt\", \"\")\n        cert_count = bundle.count(\"BEGIN CERTIFICATE\")\n        if cert_count < 2:\n            errors.append(\n                f\"Transport CA bundle should contain 2 certs, found {cert_count}\"\n            )\n\n    # Resolve the live cluster's node list FIRST: the expected node count is\n    # derived from only the StatefulSets that actually back these live nodes\n    # (the persisted namespace accumulates several ES clusters across stages, so\n    # summing every ES StatefulSet's replicas overcounts the queried cluster).\n    nodes = curl(\"/_cat/nodes?format=json\", errors)\n    node_names = []\n    if isinstance(nodes, list):\n        node_names = [n.get(\"name\") for n in nodes if n.get(\"name\")]\n    expected_nodes = _resolve_expected_nodes(node_names, default=3)\n\n    health = curl(\n        f\"/_cluster/health?wait_for_status=yellow&wait_for_nodes={expected_nodes}&timeout=10s\",\n        errors,\n    )\n    if isinstance(health, dict):\n        status = health.get(\"status\")\n        if status not in {\"yellow\", \"green\"}:\n            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n        if health.get(\"number_of_nodes\") != expected_nodes:\n            errors.append(\n                f\"Expected {expected_nodes} nodes, got {health.get('number_of_nodes')}\"\n            )\n\n    if isinstance(nodes, list):\n        if len(node_names) != expected_nodes:\n            errors.append(f\"Expected {expected_nodes} nodes in _cat/nodes, got {len(node_names)}\")\n\n    return errors\n\n\ndef main():\n    # A multi-node ES cluster can flap at the edge of readiness under load: a\n    # node briefly fails its HTTP readiness probe / drops from the cluster during\n    # GC or shard recovery even though it is stably green. A single snapshot can\n    # catch that transient and report a false node-count miss. So verify the\n    # STABLE converged state: re-evaluate for up to ~75s and pass on the first\n    # clean snapshot. This does not loosen the N-node/green/CA-bundle\n    # requirements -- a genuinely degraded cluster fails every attempt.\n    import time\n    deadline = time.monotonic() + 75\n    errors = evaluate()\n    while errors and time.monotonic() < deadline:\n        time.sleep(8)\n        errors = evaluate()\n\n    if errors:\n        print(\"Transport CA trust verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    print(\"Transport CA trust verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":373,"startLine":1,"totalLines":373}}}
