list so that the spurious --watch-ingress-without-class=false\n#    entry (added by a later patch) is removed.\n#    Note: $(POD_NAMESPACE) is a Kubernetes env-var substitution token, not a shell\n#    variable -- it must be passed as a literal string in the JSON patch.\n# ---------------------------------------------------------------------------\necho \"[1/3] Patching ingress-nginx-controller deployment to restore original args ...\"\nkubectl -n ingress-nginx patch deployment ingress-nginx-controller \\\n  --type=json \\\n  -p='[\n    {\n      \"op\": \"replace\",\n      \"path\": \"/spec/template/spec/containers/0/args\",\n      \"value\": [\n        \"/nginx-ingress-controller\",\n        \"--election-id=ingress-nginx-leader\",\n        \"--controller-class=k8s.io/ingress-nginx\",\n        \"--ingress-class=nginx\",\n        \"--configmap=$(POD_NAMESPACE)/ingress-nginx-controller\",\n        \"--validating-webhook=:8443\",\n        \"--validating-webhook-certificate=/usr/local/certificates/cert\",\n        \"--validating-webhook-key=/usr/local/certificates/key\",\n        \"--watch-ingress-without-class=true\",\n        \"--publish-status-address=localhost\"\n      ]\n    }\n  ]'\n\necho \"    Waiting for rollout ...\"\nkubectl -n ingress-nginx rollout status deployment/ingress-nginx-controller --timeout=120s\necho \"    Deployment rollout complete.\"\necho \"\"\n\n# ---------------------------------------------------------------------------\n# 2. Reset the ingress-nginx-controller ConfigMap to empty data.\n#    The ConfigMap currently has no custom data (data: null), so this is a\n#    no-op in the current state but is included for idempotency in case data\n#    keys were added between inspection and execution.\n# ---------------------------------------------------------------------------\necho \"[2/3] Resetting ingress-nginx-controller ConfigMap to empty data (vanilla) ...\"\nkubectl -n ingress-nginx patch configmap ingress-nginx-controller \\\n  --type=merge \\\n  -p='{\"data\": null}'\necho \"    ConfigMap reset.\"\necho \"\"\n\n# ---------------------------------------------------------------------------\n# 3. Remove the two non-standard IngressClass resources.\n#    The standard ingress-nginx install ships only the 'nginx' IngressClass.\n#    ingress-1 and ingress-2 are additional classes that are not part of the\n#    default manifests.\n# ---------------------------------------------------------------------------\necho \"[3/3] Deleting non-standard IngressClass resources (ingress-1, ingress-2) ...\"\nkubectl delete ingressclass ingress-1 ingress-2 --ignore-not-found\necho \"    IngressClass cleanup done.\"\necho \"\"\n\necho \"=== Rollback complete. ===\"\necho \"\"\necho \"Verify with:\"\necho \"  kubectl -n ingress-nginx get deployment ingress-nginx-controller -o jsonpath='{.spec.template.spec.containers[0].args}'\"\necho \"  kubectl get ingressclass\"\necho \"  kubectl -n ingress-nginx get configmap ingress-nginx-controller -o yaml\"\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2603,"cache_read_input_tokens":42810,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2603},"output_tokens":20,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"ace6c5d9-53c9-4d26-8fa0-a61722a38cdd","uuid":"dc283588-2472-43ee-a837-1133b309a42e","request_id":"req_011Cc2g9Z5XsLTAmvvFtifRP"}
