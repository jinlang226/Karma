ockroachdb/monitoring-integration/oracle/oracle.py\"\n124\t        timeout_sec: 60\n125\t"}]},"parent_tool_use_id":null,"session_id":"968d89f3-ee23-41c1-b518-bf9af8be1b67","uuid":"a8156e98-d50b-4700-bf7e-d0b3d017b535","timestamp":"2026-06-15T04:04:48.591Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/leo/Karma/cases/cockroachdb/monitoring-integration/test.yaml","content":"# cockroachdb/monitoring-integration\n# Enable Prometheus scraping for CockroachDB metrics using the Prometheus Operator\n\nprompt: |\n  Prometheus is running in the monitoring namespace.\n  Enable Prometheus scraping for CockroachDB metrics from {{params.metrics_path}} on port {{params.metrics_port}}.\n  You may use any Prometheus Operator-compatible approach.\n\n  Verification:\n  1. Prometheus has an active target for CockroachDB metrics.\n  2. Metrics endpoint is reachable inside the cluster.\n\nparams:\n  metrics_path:\n    default: /_status/vars\n    description: HTTP path exposing CockroachDB Prometheus metrics\n  metrics_port:\n    default: 8080\n    description: Port on which the CockroachDB metrics endpoint is served\n\nnamespace_contract:\n  required_roles: []\n\nmetrics:\n  - time_to_first_mutation\n\npreconditionUnits:\n  - name: crdb_env_ready\n    on_probe_fail: skip\n    probe:\n      # Non-destructive skip-if-running probe. The env PERSISTS across workflow\n      # stages: when a cockroachdb cluster is already present (inherited from a\n      # prior stage), skip this destructive apply so accumulated state is\n      # preserved. The apply (which deletes+recreates the cockroachdb AND\n      # monitoring namespaces) runs ONLY on an empty namespace. The monitoring\n      # stack + curl-test helper this case's oracle needs are ensured ADDITIVELY\n      # by the crdb_monitoring_stack unit below, so an inherited cluster does not\n      # have to be wiped to get them.\n      - command: \"kubectl -n cockroachdb get pods 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n    apply:\n      - command: \"/bin/sh -c 'kubectl delete namespace cockroachdb --ignore-not-found=true; kubectl wait --for=delete namespace/cockroachdb --timeout=120s || true; kubectl delete namespace monitoring --ignore-not-found=true; kubectl wait --for=delete namespace/monitoring --timeout=120s || true'\"\n        sleep: 2\n      - command: \"kubectl create namespace monitoring\"\n        sleep: 1\n      - command: \"kubectl apply -f cases/cockroachdb/monitoring-integration/resource/monitoring-crds.yaml\"\n        sleep: 2\n      - command: \"kubectl create namespace cockroachdb\"\n        sleep: 1\n      - command: \"kubectl -n monitoring apply -f cases/cockroachdb/monitoring-integration/resource/prometheus-operator.yaml\"\n        sleep: 3\n      - command: \"kubectl -n monitoring apply -f cases/cockroachdb/monitoring-integration/resource/prometheus-rbac.yaml\"\n        sleep: 2\n      - command: \"kubectl -n monitoring apply -f cases/cockroachdb/monitoring-integration/resource/prometheus.yaml\"\n        sleep: 2\n      - command: \"kubectl -n monitoring wait --for=condition=ready pod -l app=prometheus-operator --timeout=300s\"\n        sleep: 2\n      - command: \"/bin/sh -c 'for i in $(seq 1 60); do count=$(kubectl -n monitoring get pod -l prometheus=crdb --no-headers 2>/dev/null | wc -l | tr -d \\\" \\\"); if [ \\\"${count}\\\" -ge 1 ]; then kubectl -n monitoring wait --for=condition=ready pod -l prometheus=crdb --timeout=300s && exit 0; fi; sleep 2; done; exit 1'\"\n        sleep: 2\n      - command: \"kubectl -n cockroachdb apply -f cases/cockroachdb/monitoring-integration/resource/rbac.yaml\"\n        sleep: 2\n      - command: \"kubectl -n cockroachdb apply -f cases/cockroachdb/monitoring-integration/resource/services.yaml\"\n        sleep: 2\n      - command: \"kubectl -n cockroachdb apply -f cases/cockroachdb/monitoring-integration/resource/statefulset.yaml\"\n        sleep: 5\n      - command: \"kubectl -n cockroachdb wait --for=jsonpath={.status.phase}=Running pod -l app.kubernetes.io/name=cockroachdb --timeout=300s\"\n        sleep: 5\n      - command: \"/bin/sh -c 'for i in $(seq 1 30); do kubectl -n cockroachdb exec crdb-cluster-0 -- ./cockroach init --insecure --host=crdb-cluster-0.crdb-cluster.cockroachdb.svc.cluster.local && exit 0; sleep 3; done; exit 1'\"\n        sleep: 2\n      - command: \"kubectl -n cockroachdb wait --for=condition=ready pod -l app.kubernetes.io/name=cockroachdb --timeout=300s\"\n        sleep: 10\n      - command: \"kubectl -n cockroachdb apply -f cases/cockroachdb/monitoring-integration/resource/curl-test.yaml\"\n        sleep: 2\n      - command: \"kubectl -n cockroachdb wait --for=condition=ready pod/curl-test --timeout=120s\"\n        sleep: 2\n    verify:\n      - command: \"kubectl -n cockroachdb exec crdb-cluster-0 -- ./cockroach sql --insecure -e 'SELECT 1;' 2>/dev/null\"\n        timeout_sec: 15\n\n  # Additive fixture-ensure unit (Rule 4): the oracle execs into the curl-test\n  # helper pod and queries Prometheus in the monitoring namespace. Standalone,\n  # crdb_env_ready's apply creates them. In a workflow crdb_env_ready's\n  # destructive apply is skipped (cluster inherited), so this unit ensures JUST\n  # the monitoring stack + curl-test helper + the crdb monitoring RBAC/services\n  # idempotently and ADDITIVELY — it never deletes the cockroachdb namespace or\n  # the inherited cluster. Its probe gates only on the curl-test pod being Ready;\n  # if it is already there the whole ensure is skipped.\n  - name: crdb_monitoring_stack\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n cockroachdb get pod curl-test -o jsonpath='{.status.conditions[?(@.type==\\\"Ready\\\")].status}' 2>/dev/null | grep -q True\"\n        timeout_sec: 10\n    apply:\n      - command: \"/bin/sh -c 'kubectl create namespace monitoring --dry-run=client -o yaml | kubectl apply -f -'\"\n        sleep: 1\n      - command: \"kubectl apply -f cases/cockroachdb/monitoring-integration/resource/monitoring-crds.yaml\"\n        sleep: 2\n      - command: \"kubectl -n monitoring apply -f cases/cockroachdb/monitoring-integration/resource/prometheus-operator.yaml\"\n        sleep: 3\n      - command: \"kubectl -n monitoring apply -f cases/cockroachdb/monitoring-integration/resource/prometheus-rbac.yaml\"\n        sleep: 2\n      - command: \"kubectl -n monitoring apply -f cases/cockroachdb/monitoring-integration/resource/prometheus.yaml\"\n        sleep: 2\n      - command: \"kubectl -n monitoring wait --for=condition=ready pod -l app=prometheus-operator --timeout=300s\"\n        sleep: 2\n      - command: \"/bin/sh -c 'for i in $(seq 1 60); do count=$(kubectl -n monitoring get pod -l prometheus=crdb --no-headers 2>/dev/null | wc -l | tr -d \\\" \\\"); if [ \\\"${count}\\\" -ge 1 ]; then kubectl -n monitoring wait --for=condition=ready pod -l prometheus=crdb --timeout=300s && exit 0; fi; sleep 2; done; exit 1'\"\n        sleep: 2\n      - command: \"kubectl -n cockroachdb apply -f cases/cockroachdb/monitoring-integration/resource/rbac.yaml\"\n        sleep: 2\n      - command: \"kubectl -n cockroachdb apply -f cases/cockroachdb/monitoring-integration/resource/services.yaml\"\n        sleep: 2\n      - command: \"kubectl -n cockroachdb apply -f cases/cockroachdb/monitoring-integration/resource/curl-test.yaml\"\n        sleep: 2\n      - command: \"kubectl -n cockroachdb wait --for=condition=ready pod/curl-test --timeout=120s\"\n        sleep: 2\n    verify:\n      - command: \"kubectl -n cockroachdb get pod curl-test -o jsonpath='{.status.conditions[?(@.type==\\\"Ready\\\")].status}' 2>/dev/null | grep -q True\"\n        timeout_sec: 15\n\noracle:\n  verify:\n    commands:\n      - command: \"python3 cases/cockroachdb/monitoring-integration/oracle/oracle.py\"\n        timeout_sec: 60\n","numLines":125,"startLine":1,"totalLines":125}}}
