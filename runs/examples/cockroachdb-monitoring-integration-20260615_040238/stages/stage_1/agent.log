{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WY6kPriJKN8cVM3eC21pJG","type":"tool_result","content":"1\t# cockroachdb/monitoring-integration\n2\t# Enable Prometheus scraping for CockroachDB metrics using the Prometheus Operator\n3\t\n4\tprompt: |\n5\t  Prometheus is running in the monitoring namespace.\n6\t  Enable Prometheus scraping for CockroachDB metrics from {{params.metrics_path}} on port {{params.metrics_port}}.\n7\t  You may use any Prometheus Operator-compatible approach.\n8\t\n9\t  Verification:\n10\t  1. Prometheus has an active target for CockroachDB metrics.\n11\t  2. Metrics endpoint is reachable inside the cluster.\n12\t\n13\tparams:\n14\t  metrics_path:\n15\t    default: /_status/vars\n16\t    description: HTTP path exposing CockroachDB Prometheus metrics\n17\t  metrics_port:\n18\t    default: 8080\n19\t    description: Port on which the CockroachDB metrics endpoint is served\n20\t\n21\tnamespace_contract:\n22\t  required_roles: []\n23\t\n24\tmetrics:\n25\t  - time_to_first_mutation\n26\t\n27\tpreconditionUnits:\n28\t  - name: crdb_env_ready\n29\t    on_probe_fail: skip\n30\t    probe:\n31\t      # Non-destructive skip-if-running probe. The env PERSISTS across workflow\n32\t      # stages: when a cockroachdb cluster is already present (inherited from a\n33\t      # prior stage), skip this destructive apply so accumulated state is\n34\t      # preserved. The apply (which deletes+recreates the cockroachdb AND\n35\t      # monitoring namespaces) runs ONLY on an empty namespace. The monitoring\n36\t      # stack + curl-test helper this case's oracle needs are ensured ADDITIVELY\n37\t      # by the crdb_monitoring_stack unit below, so an inherited cluster does not\n38\t      # have to be wiped to get them.\n39\t      - command: \"kubectl -n cockroachdb get pods 2>/dev/null | grep -c Running\"\n40\t        timeout_sec: 10\n41\t    apply:\n42\t      - command: \"/bin/sh -c 'kubectl delete namespace cockroachdb --ignore-not-found=true; kubectl wait --for=delete namespace/cockroachdb --timeout=120s || true; kubectl delete namespace monitoring --ignore-not-found=true; kubectl wait --for=delete namespace/monitoring --timeout=120s || true'\"\n43\t        sleep: 2\n44\t      - command: \"kubectl create namespace monitoring\"\n45\t        sleep: 1\n46\t      - command: \"kubectl apply -f cases/cockroachdb/monitoring-integration/resource/monitoring-crds.yaml\"\n47\t        sleep: 2\n48\t      - command: \"kubectl create namespace cockroachdb\"\n49\t        sleep: 1\n50\t      - command: \"kubectl -n monitoring apply -f cases/cockroachdb/monitoring-integration/resource/prometheus-operator.yaml\"\n51\t        sleep: 3\n52\t      - command: \"kubectl -n monitoring apply -f cases/cockroachdb/monitoring-integration/resource/prometheus-rbac.yaml\"\n53\t        sleep: 2\n54\t      - command: \"kubectl -n monitoring apply -f cases/cockroachdb/monitoring-integration/resource/prometheus.yaml\"\n55\t        sleep: 2\n56\t      - command: \"kubectl -n monitoring wait --for=condition=ready pod -l app=prometheus-operator --timeout=300s\"\n57\t        sleep: 2\n58\t      - command: \"/bin/sh -c 'for i in $(seq 1 60); do count=$(kubectl -n monitoring get pod -l prometheus=crdb --no-headers 2>/dev/null | wc -l | tr -d \\\" \\\"); if [ \\\"${count}\\\" -ge 1 ]; then kubectl -n monitoring wait --for=condition=ready pod -l prometheus=crdb --timeout=300s && exit 0; fi; sleep 2; done; exit 1'\"\n59\t        sleep: 2\n60\t      - command: \"kubectl -n cockroachdb apply -f cases/cockroachdb/monitoring-integration/resource/rbac.yaml\"\n61\t        sleep: 2\n62\t      - command: \"kubectl -n cockroachdb apply -f cases/cockroachdb/monitoring-integration/resource/services.yaml\"\n63\t        sleep: 2\n64\t      - command: \"kubectl -n cockroachdb apply -f cases/cockroachdb/monitoring-integration/resource/statefulset.yaml\"\n65\t        sleep: 5\n66\t      - command: \"kubectl -n cockroachdb wait --for=jsonpath={.status.phase}=Running pod -l app.kubernetes.io/name=cockroachdb --timeout=300s\"\n67\t        sleep: 5\n68\t      - command: \"/bin/sh -c 'for i in $(seq 1 30); do kubectl -n cockroachdb exec crdb-cluster-0 -- ./cockroach init --insecure --host=crdb-cluster-0.crdb-cluster.cockroachdb.svc.cluster.local && exit 0; sleep 3; done; exit 1'\"\n69\t        sleep: 2\n70\t      - command: \"kubectl -n cockroachdb wait --for=condition=ready pod -l app.kubernetes.io/name=cockroachdb --timeout=300s\"\n71\t        sleep: 10\n72\t      - command: \"kubectl -n cockroachdb apply -f cases/cockroachdb/monitoring-integration/resource/curl-test.yaml\"\n73\t        sleep: 2\n74\t      - command: \"kubectl -n cockroachdb wait --for=condition=ready pod/curl-test --timeout=120s\"\n75\t        sleep: 2\n76\t    verify:\n77\t      - command: \"kubectl -n cockroachdb exec crdb-cluster-0 -- ./cockroach sql --insecure -e 'SELECT 1;' 2>/dev/null\"\n78\t        timeout_sec: 15\n79\t\n80\t  # Additive fixture-ensure unit (Rule 4): the oracle execs into the curl-test\n81\t  # helper pod and queries Prometheus in the monitoring namespace. Standalone,\n82\t  # crdb_env_ready's apply creates them. In a workflow crdb_env_ready's\n83\t  # destructive apply is skipped (cluster inherited), so this unit ensures JUST\n84\t  # the monitoring stack + curl-test helper + the crdb monitoring RBAC/services\n85\t  # idempotently and ADDITIVELY — it never deletes the cockroachdb namespace or\n86\t  # the inherited cluster. Its probe gates only on the curl-test pod being Ready;\n87\t  # if it is already there the whole ensure is skipped.\n88\t  - name: crdb_monitoring_stack\n89\t    on_probe_fail: skip\n90\t    probe:\n91\t      - command: \"kubectl -n cockroachdb get pod curl-test -o jsonpath='{.status.conditions[?(@.type==\\\"Ready\\\")].status}' 2>/dev/null | grep -q True\"\n92\t        timeout_sec: 10\n93\t    apply:\n94\t      - command: \"/bin/sh -c 'kubectl create namespace monitoring --dry-run=client -o yaml | kubectl 