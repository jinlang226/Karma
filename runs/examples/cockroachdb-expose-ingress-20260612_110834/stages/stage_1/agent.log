{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_011YY9rcrnDF4oqspt5BtK6q","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport subprocess\n3\timport sys\n4\t\n5\t\n6\tUI_HOST = \"crdb-ui.example.com\"\n7\tINGRESS_HTTP_URL = \"http://ingress-nginx-controller.ingress-nginx.svc/\"\n8\tSQL_HOST = \"ingress-nginx-controller.ingress-nginx.svc\"\n9\tSQL_PORT = \"26257\"\n10\t\n11\t\n12\tdef run(cmd):\n13\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n14\t\n15\t\n16\tdef check_ui(errors):\n17\t    cmd = [\n18\t        \"kubectl\",\n19\t        \"-n\",\n20\t        \"cockroachdb\",\n21\t        \"exec\",\n22\t        \"curl-test\",\n23\t        \"--\",\n24\t        \"curl\",\n25\t        \"-sS\",\n26\t        \"-o\",\n27\t        \"/dev/null\",\n28\t        \"-w\",\n29\t        \"%{http_code}\",\n30\t        \"-H\",\n31\t        f\"Host: {UI_HOST}\",\n32\t        INGRESS_HTTP_URL,\n33\t    ]\n34\t    result = run(cmd)\n35\t    if result.returncode != 0:\n36\t        errors.append(result.stderr.strip() or \"Failed to curl UI through ingress\")\n37\t        return\n38\t    code = result.stdout.strip()\n39\t    if not code.isdigit():\n40\t        errors.append(f\"Unexpected HTTP status output: {code}\")\n41\t        return\n42\t    status = int(code)\n43\t    if status < 200 or status >= 400:\n44\t        errors.append(f\"UI ingress returned HTTP {status}\")\n45\t\n46\t\n47\tdef check_sql(errors):\n48\t    cmd = [\n49\t        \"kubectl\",\n50\t        \"-n\",\n51\t        \"cockroachdb\",\n52\t        \"exec\",\n53\t        \"crdb-cluster-0\",\n54\t        \"--\",\n55\t        \"./cockroach\",\n56\t        \"sql\",\n57\t        \"--insecure\",\n58\t        \"--host\",\n59\t        SQL_HOST,\n60\t        \"--port\",\n61\t        SQL_PORT,\n62\t        \"-e\",\n63\t        \"SELECT 1;\",\n64\t    ]\n65\t    result = run(cmd)\n66\t    if result.returncode != 0:\n67\t        msg = result.stderr.strip() or result.stdout.strip()\n68\t        errors.append(msg or \"SQL query through ingress failed\")\n69\t\n70\t\n71\tdef main():\n72\t    errors = []\n73\t\n74\t    check_ui(errors)\n75\t    check_sql(errors)\n76\t\n77\t    if errors:\n78\t        print(\"Expose ingress verification failed:\", file=sys.stderr)\n79\t        for error in errors:\n80\t            print(f\"  - {error}\", file=sys.stderr)\n81\t        return 1\n82\t\n83\t    print(\"UI and SQL traffic verified through ingress-nginx\")\n84\t    return 0\n85\t\n86\t\n87\tif __name__ == \"__main__\":\n88\t    sys.exit(main())\n89\t"}]},"parent_tool_use_id":null,"session_id":"eb566f54-c78f-4de5-a1f2-b99d1b95a953","uuid":"507f7e47-2664-4925-a7f8-16487e5a1631","timestamp":"2026-06-12T11:11:42.537Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/leo/Karma/resources/cockroachdb/expose-ingress/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport subprocess\nimport sys\n\n\nUI_HOST = \"crdb-ui.example.com\"\nINGRESS_HTTP_URL = \"http://ingress-nginx-controller.ingress-nginx.svc/\"\nSQL_HOST = \"ingress-nginx-controller.ingress-nginx.svc\"\nSQL_PORT = \"26257\"\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef check_ui(errors):\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        \"cockroachdb\",\n        \"exec\",\n        \"curl-test\",\n        \"--\",\n        \"curl\",\n        \"-sS\",\n        \"-o\",\n        \"/dev/null\",\n        \"-w\",\n        \"%{http_code}\",\n        \"-H\",\n        f\"Host: {UI_HOST}\",\n        INGRESS_HTTP_URL,\n    ]\n    result = run(cmd)\n    if result.returncode != 0:\n        errors.append(result.stderr.strip() or \"Failed to curl UI through ingress\")\n        return\n    code = result.stdout.strip()\n    if not code.isdigit():\n        errors.append(f\"Unexpected HTTP status output: {code}\")\n        return\n    status = int(code)\n    if status < 200 or status >= 400:\n        errors.append(f\"UI ingress returned HTTP {status}\")\n\n\ndef check_sql(errors):\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        \"cockroachdb\",\n        \"exec\",\n        \"crdb-cluster-0\",\n        \"--\",\n        \"./cockroach\",\n        \"sql\",\n        \"--insecure\",\n        \"--host\",\n        SQL_HOST,\n        \"--port\",\n        SQL_PORT,\n        \"-e\",\n        \"SELECT 1;\",\n    ]\n    result = run(cmd)\n    if result.returncode != 0:\n        msg = result.stderr.strip() or result.stdout.strip()\n        errors.append(msg or \"SQL query through ingress failed\")\n\n\ndef main():\n    errors = []\n\n    check_ui(errors)\n    check_sql(errors)\n\n    if errors:\n        print(\"Expose ingress verification failed:\", file=sys.stderr)\n        for error in errors:\n            print(f\"  - {error}\", file=sys.stderr)\n        return 1\n\n    print(\"UI and SQL traffic verified through ingress-nginx\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":89,"startLine":1,"totalLines":89}}}
