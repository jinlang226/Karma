{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017R7w4kAwDjRvqMTpNbvgwf","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\t# Verify the agent recorded the active feature version in the configured\n3\t# ConfigMap and that the cluster is in the expected upgraded-but-pinned state.\n4\t# The ConfigMap name/key (BENCH_PARAM_REPORT_CONFIGMAP_NAME / _REPORT_KEY), the\n5\t# pre-upgrade logical version (BENCH_PARAM_FROM_VERSION) and the binary/image\n6\t# version (BENCH_PARAM_TO_VERSION) all come from the case params, so a workflow\n7\t# that overrides them is honored. Standalone (default params) this behaves\n8\t# identically to the old hardcoded check.\n9\timport os\n10\timport subprocess\n11\timport sys\n12\t\n13\t\n14\tREPORT_CM = os.environ.get(\"BENCH_PARAM_REPORT_CONFIGMAP_NAME\", \"crdb-version-report\")\n15\tREPORT_KEY = os.environ.get(\"BENCH_PARAM_REPORT_KEY\", \"db_version\")\n16\tFROM_VERSION = os.environ.get(\"BENCH_PARAM_FROM_VERSION\", \"23.2\")\n17\tTO_VERSION = os.environ.get(\"BENCH_PARAM_TO_VERSION\", \"24.1.0\")\n18\t# Logical major.minor of the binary (e.g. \"24.1\" for \"24.1.0\").\n19\tTO_MAJOR_MINOR = \".\".join(TO_VERSION.split(\".\")[:2])\n20\t\n21\t\n22\tdef run(cmd):\n23\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n24\t\n25\t\n26\tdef tsv_last_value(output):\n27\t    lines = [line.strip() for line in output.splitlines() if line.strip()]\n28\t    if not lines:\n29\t        return \"\"\n30\t    if len(lines) == 1:\n31\t        return lines[0]\n32\t    return lines[-1].split(\"\\t\")[-1]\n33\t\n34\t\n35\tdef main():\n36\t    errors = []\n37\t\n38\t    cm_cmd = [\n39\t        \"kubectl\",\n40\t        \"-n\",\n41\t        \"cockroachdb\",\n42\t        \"get\",\n43\t        \"configmap\",\n44\t        REPORT_CM,\n45\t        \"-o\",\n46\t        \"jsonpath={.data.\" + REPORT_KEY.replace(\".\", \"\\\\.\") + \"}\",\n47\t    ]\n48\t    cm_result = run(cm_cmd)\n49\t    if cm_result.returncode != 0:\n50\t        errors.append(f\"Missing ConfigMap {REPORT_CM}\")\n51\t        errors.append(f\"Error: {cm_result.stderr.strip()}\")\n52\t        cm_version = \"\"\n53\t    else:\n54\t        cm_version = cm_result.stdout.strip()\n55\t        if not cm_version:\n56\t            errors.append(f\"ConfigMap {REPORT_KEY} is empty\")\n57\t\n58\t    cluster_cmd = [\n59\t        \"kubectl\",\n60\t        \"-n\",\n61\t        \"cockroachdb\",\n62\t        \"exec\",\n63\t        \"crdb-cluster-0\",\n64\t        \"--\",\n65\t        \"./cockroach\",\n66\t        \"sql\",\n67\t        \"--insecure\",\n68\t        \"--format=tsv\",\n69\t        \"-e\",\n70\t        \"SHOW CLUSTER SETTING version;\",\n71\t    ]\n72\t    cluster_result = run(cluster_cmd)\n73\t    cluster_version = \"\"\n74\t    if cluster_result.returncode != 0:\n75\t        errors.append(\"Failed to read cluster version\")\n76\t        errors.append(f\"Error: {cluster_result.stderr.strip()}\")\n77\t    else:\n78\t        cluster_version = tsv_last_value(cluster_result.stdout)\n79\t        if FROM_VERSION not in cluster_version:\n80\t            errors.append(f\"Cluster version mismatch: {cluster_version or 'empty'}\")\n81\t\n82\t    preserve_cmd = [\n83\t        \"kubectl\",\n84\t        \"-n\",\n85\t        \"cockroachdb\",\n86\t        \"exec\",\n87\t        \"crdb-cluster-0\",\n88\t        \"--\",\n89\t        \"./cockroach\",\n90\t        \"sql\",\n91\t        \"--insecure\",\n92\t        \"--format=tsv\",\n93\t        \"-e\",\n94\t        \"SHOW CLUSTER SETTING cluster.preserve_downgrade_option;\",\n95\t    ]\n96\t    preserve_result = run(preserve_cmd)\n97\t    if preserve_result.returncode != 0:\n98\t        errors.append(\"Failed to read preserve_downgrade_option\")\n99\t        errors.append(f\"Error: {preserve_result.stderr.strip()}\")\n100\t    else:\n101\t        preserve_value = tsv_last_value(preserve_result.stdout)\n102\t        if not preserve_value:\n103\t            errors.append(\"preserve_downgrade_option is empty\")\n104\t\n105\t    binary_cmd = [\n106\t        \"kubectl\",\n107\t        \"-n\",\n108\t        \"cockroachdb\",\n109\t        \"exec\",\n110\t        \"crdb-cluster-0\",\n111\t        \"--\",\n112\t        \"./cockroach\",\n113\t        \"sql\",\n114\t        \"--insecure\",\n115\t        \"--format=tsv\",\n116\t        \"-e\",\n117\t        \"SELECT version();\",\n118\t    ]\n119\t    binary_result = run(binary_cmd)\n120\t    if binary_result.returncode != 0:\n121\t        errors.append(\"Failed to read binary version\")\n122\t        errors.append(f\"Error: {binary_result.stderr.strip()}\")\n123\t    else:\n124\t        if f\"v{TO_MAJOR_MINOR}\" not in binary_result.stdout and TO_MAJOR_MINOR not in binary_result.stdout:\n125\t            errors.append(f\"Binary version does not look like v{TO_MAJOR_MINOR}\")\n126\t\n127\t    images_cmd = [\n128\t        \"kubectl\",\n129\t        \"-n\",\n130\t        \"cockroachdb\",\n131\t        \"get\",\n132\t        \"pods\",\n133\t        \"-l\",\n134\t        \"app.kubernetes.io/name=cockroachdb\",\n135\t        \"-o\",\n136\t        \"jsonpath={.items[*].spec.containers[0].image}\",\n137\t    ]\n138\t    images_result = run(images_cmd)\n139\t    if images_result.returncode != 0:\n140\t        errors.append(\"Failed to read pod images\")\n141\t        errors.append(f\"Error: {images_result.stderr.strip()}\")\n142\t    else:\n143\t        images = [image.strip() for image in images_result.stdout.split() if image.strip()]\n144\t        if not images:\n145\t            errors.append(\"No pod images reported\")\n146\t        elif any(f\"cockroachdb/cockroach:v{TO_VERSION}\" not in image for image in images):\n147\t            errors.append(f\"Unexpected pod images: {' '.join(images)}\")\n148\t\n149\t    if cm_version and cluster_version and cm_version != cluster_version:\n150\t        errors.append(f\"ConfigMap db_version does not match cluster version ({cluster_version})\")\n151\t\n152\t    if errors:\n153\t        print(\"Version check verification failed:\", file=sys.stderr)\n154\t        for error in errors:\n155\t            print(f\"  - {error}\", file=sys.stderr)\n156\t        return 1\n157\t\n158\t    print(\"Version check completed successfully\")\n159\t    return 0\n160\t\n161\t\n162\tif __name__ == \"__main__\":\n163\t    sys.exit(main())\n164\t"}]},"parent_tool_use_id":null,"session_id":"9c487012-2830-4f84-8755-f1d502dac7a3","uuid":"507880b6-3996-42d8-9018-4eb208df20ca","timestamp":"2026-06-15T01:06:11.271Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/leo/Karma/cases/cockroachdb/version-check/oracle/oracle.py","content":"#!/usr/bin/env python3\n# Verify the agent recorded the active feature version in the configured\n# ConfigMap and that the cluster is in the expected upgraded-but-pinned state.\n# The ConfigMap name/key (BENCH_PARAM_REPORT_CONFIGMAP_NAME / _REPORT_KEY), the\n# pre-upgrade logical version (BENCH_PARAM_FROM_VERSION) and the binary/image\n# version (BENCH_PARAM_TO_VERSION) all come from the case params, so a workflow\n# that overrides them is honored. Standalone (default params) this behaves\n# identically to the old hardcoded check.\nimport os\nimport subprocess\nimport sys\n\n\nREPORT_CM = os.environ.get(\"BENCH_PARAM_REPORT_CONFIGMAP_NAME\", \"crdb-version-report\")\nREPORT_KEY = os.environ.get(\"BENCH_PARAM_REPORT_KEY\", \"db_version\")\nFROM_VERSION = os.environ.get(\"BENCH_PARAM_FROM_VERSION\", \"23.2\")\nTO_VERSION = os.environ.get(\"BENCH_PARAM_TO_VERSION\", \"24.1.0\")\n# Logical major.minor of the binary (e.g. \"24.1\" for \"24.1.0\").\nTO_MAJOR_MINOR = \".\".join(TO_VERSION.split(\".\")[:2])\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef tsv_last_value(output):\n    lines = [line.strip() for line in output.splitlines() if line.strip()]\n    if not lines:\n        return \"\"\n    if len(lines) == 1:\n        return lines[0]\n    return lines[-1].split(\"\\t\")[-1]\n\n\ndef main():\n    errors = []\n\n    cm_cmd = [\n        \"kubectl\",\n        \"-n\",\n        \"cockroachdb\",\n        \"get\",\n        \"configmap\",\n        REPORT_CM,\n        \"-o\",\n        \"jsonpath={.data.\" + REPORT_KEY.replace(\".\", \"\\\\.\") + \"}\",\n    ]\n    cm_result = run(cm_cmd)\n    if cm_result.returncode != 0:\n        errors.append(f\"Missing ConfigMap {REPORT_CM}\")\n        errors.append(f\"Error: {cm_result.stderr.strip()}\")\n        cm_version = \"\"\n    else:\n        cm_version = cm_result.stdout.strip()\n        if not cm_version:\n            errors.append(f\"ConfigMap {REPORT_KEY} is empty\")\n\n    cluster_cmd = [\n        \"kubectl\",\n        \"-n\",\n        \"cockroachdb\",\n        \"exec\",\n        \"crdb-cluster-0\",\n        \"--\",\n        \"./cockroach\",\n        \"sql\",\n        \"--insecure\",\n        \"--format=tsv\",\n        \"-e\",\n        \"SHOW CLUSTER SETTING version;\",\n    ]\n    cluster_result = run(cluster_cmd)\n    cluster_version = \"\"\n    if cluster_result.returncode != 0:\n        errors.append(\"Failed to read cluster version\")\n        errors.append(f\"Error: {cluster_result.stderr.strip()}\")\n    else:\n        cluster_version = tsv_last_value(cluster_result.stdout)\n        if FROM_VERSION not in cluster_version:\n            errors.append(f\"Cluster version mismatch: {cluster_version or 'empty'}\")\n\n    preserve_cmd = [\n        \"kubectl\",\n        \"-n\",\n        \"cockroachdb\",\n        \"exec\",\n        \"crdb-cluster-0\",\n        \"--\",\n        \"./cockroach\",\n        \"sql\",\n        \"--insecure\",\n        \"--format=tsv\",\n        \"-e\",\n        \"SHOW CLUSTER SETTING cluster.preserve_downgrade_option;\",\n    ]\n    preserve_result = run(preserve_cmd)\n    if preserve_result.returncode != 0:\n        errors.append(\"Failed to read preserve_downgrade_option\")\n        errors.append(f\"Error: {preserve_result.stderr.strip()}\")\n    else:\n        preserve_value = tsv_last_value(preserve_result.stdout)\n        if not preserve_value:\n            errors.append(\"preserve_downgrade_option is empty\")\n\n    binary_cmd = [\n        \"kubectl\",\n        \"-n\",\n        \"cockroachdb\",\n        \"exec\",\n        \"crdb-cluster-0\",\n        \"--\",\n        \"./cockroach\",\n        \"sql\",\n        \"--insecure\",\n        \"--format=tsv\",\n        \"-e\",\n        \"SELECT version();\",\n    ]\n    binary_result = run(binary_cmd)\n    if binary_result.returncode != 0:\n        errors.append(\"Failed to read binary version\")\n        errors.append(f\"Error: {binary_result.stderr.strip()}\")\n    else:\n        if f\"v{TO_MAJOR_MINOR}\" not in binary_result.stdout and TO_MAJOR_MINOR not in binary_result.stdout:\n            errors.append(f\"Binary version does not look like v{TO_MAJOR_MINOR}\")\n\n    images_cmd = [\n        \"kubectl\",\n        \"-n\",\n        \"cockroachdb\",\n        \"get\",\n        \"pods\",\n        \"-l\",\n        \"app.kubernetes.io/name=cockroachdb\",\n        \"-o\",\n        \"jsonpath={.items[*].spec.containers[0].image}\",\n    ]\n    images_result = run(images_cmd)\n    if images_result.returncode != 0:\n        errors.append(\"Failed to read pod images\")\n        errors.append(f\"Error: {images_result.stderr.strip()}\")\n    else:\n        images = [image.strip() for image in images_result.stdout.split() if image.strip()]\n        if not images:\n            errors.append(\"No pod images reported\")\n        elif any(f\"cockroachdb/cockroach:v{TO_VERSION}\" not in image for image in images):\n            errors.append(f\"Unexpected pod images: {' '.join(images)}\")\n\n    if cm_version and cluster_version and cm_version != cluster_version:\n        errors.append(f\"ConfigMap db_version does not match cluster version ({cluster_version})\")\n\n    if errors:\n        print(\"Version check verification failed:\", file=sys.stderr)\n        for error in errors:\n            print(f\"  - {error}\", file=sys.stderr)\n        return 1\n\n    print(\"Version check completed successfully\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":164,"startLine":1,"totalLines":164}}}
