namespace ingress-nginx --for=condition=ready pod --selector=app.kubernetes.io/component=controller --timeout=90s\"\n85\t        sleep: 5\n86\t      - command: \"bash -c 'while [ -z \\\"$(kubectl get svc ingress-nginx-controller -n ingress-nginx -o jsonpath={.status.loadBalancer.ingress[0].ip} 2>/dev/null)\\\" ] && [ -z \\\"$(kubectl get svc ingress-nginx-controller -n ingress-nginx -o jsonpath=\\\"{.spec.ports[?(@.port==443)].nodePort}\\\" 2>/dev/null)\\\" ]; do echo \\\"Waiting for ingress-nginx LoadBalancer...\\\"; sleep 5; done; NODEPORT=$(kubectl get svc ingress-nginx-controller -n ingress-nginx -o jsonpath=\\\"{.spec.ports[?(@.port==443)].nodePort}\\\"); NODE_IP=$(kubectl get nodes -o jsonpath=\\\"{.items[0].status.addresses[?(@.type==InternalIP)].address}\\\"); echo \\\"INGRESS_NODE_IP=$NODE_IP\\\" > /tmp/ingress_env; echo \\\"INGRESS_HTTPS_PORT=$NODEPORT\\\" >> /tmp/ingress_env; echo \\\"export INGRESS_NODE_IP=$NODE_IP\\\" >> /tmp/ingress_env; echo \\\"export INGRESS_HTTPS_PORT=$NODEPORT\\\" >> /tmp/ingress_env'\"\n87\t        sleep: 10\n88\t      - command: \"kubectl create namespace demo\"\n89\t        sleep: 0\n90\t      - command: \"/bin/sh -c 'kubectl -n demo get pod openssl-toolbox >/dev/null 2>&1 || kubectl -n demo apply -f cases/nginx-ingress/renew_tls_secret/resource/openssl-toolbox.yaml'\"\n91\t        sleep: 2\n92\t      - command: \"kubectl -n demo wait --for=condition=Ready pod/openssl-toolbox --timeout=180s\"\n93\t        sleep: 1\n94\t      - command: \"kubectl -n demo cp cases/nginx-ingress/renew_tls_secret/resource/leaf.cnf openssl-toolbox:/tmp/leaf.cnf\"\n95\t        sleep: 1\n96\t      - command: \"kubectl -n demo cp cases/nginx-ingress/renew_tls_secret/resource/ca-ext.conf openssl-toolbox:/tmp/ca-ext.conf\"\n97\t        sleep: 1\n98\t      - command: \"kubectl -n demo apply -f cases/nginx-ingress/renew_tls_secret/resource/echo-server.yaml\"\n99\t        sleep: 3\n100\t      - command: \"openssl genrsa -out /tmp/test-ca.key 2048\"\n101\t  