NEW="'$(kubectl -n elasticsearch get secret elastic-password-next -o jsonpath='"'{.data.password}' | base64 -d)
for label in old new; do
  if [ \""'$label" = old ]; then PW="$OLD"; else PW="$NEW"; fi
  code=$(kubectl -n elasticsearch exec elasticsearch-0 -- bash -c '"'curl -sS -o /dev/null -w \"%{http_code}\" --cacert /usr/share/elasticsearch/config/certs/ca.crt --user \"elastic:"'$1" https://localhost:9200/_security/_authenticate'"' -- \""'$PW")
  printf '"'%s=%s\\n' \""'$label" "$code"
done' in /Users/jinyige/Karma/runs/new-added-workflows/elasticsearch-certs-password-users-20260625_213837/stages/stage_03
