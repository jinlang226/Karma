codex
I’m applying temporary dual-password readiness probes now. This keeps the old credential valid before rotation and the new credential valid immediately after rotation, so Kubernetes does not drop healthy pods just because the Secret handoff is in progress.
exec
/bin/zsh -lc 'kubectl -n elasticsearch patch deployment auth-checker --type=strategic -p "$(cat <<'"'EOF'
spec:
  template:
    spec:
      volumes:
      - name: es-http-ca
        configMap:
          name: es-http-ca
      containers:
      - name: checker
        env:
        - name: ELASTIC_PASSWORD_NEXT
          valueFrom:
            secretKeyRef:
              name: elastic-password-next
              key: password
        volumeMounts:
        - name: es-http-ca
          mountPath: /etc/elasticsearch-ca
          readOnly: true
        readinessProbe:
          exec:
            command:
            - /bin/sh
            - -c
            - |
              for password in \""'$ELASTIC_PASSWORD" "$ELASTIC_PASSWORD_NEXT"; do
                [ -n "$password" ] || continue
                curl -s --fail --max-time 5 '"\\
                  --cacert /etc/elasticsearch-ca/ca.crt \\
                  -u \"elastic:"'${password}" '"\\
                  https://es-http.elasticsearch.svc:9200/_security/_authenticate \\
                  | grep -q '\"username\":\"elastic\"' && exit 0
              done
              exit 1
EOF
)\"" in /Users/jinyige/Karma/runs/new-added-workflows/elasticsearch-certs-password-users-20260625_213837/stages/stage_03
