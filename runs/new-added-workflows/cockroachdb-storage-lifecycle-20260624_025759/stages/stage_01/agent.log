+apiVersion: v1
+kind: Service
+metadata:
+  name: crdb-cluster
+  namespace: cockroachdb
+  labels:
+    app.kubernetes.io/name: cockroachdb
+    app.kubernetes.io/instance: crdb-cluster
+    app.kubernetes.io/component: database
+spec:
+  clusterIP: None
+  publishNotReadyAddresses: true
+  selector:
+    app.kubernetes.io/name: cockroachdb
+    app.kubernetes.io/instance: crdb-cluster
+  ports:
+    - name: grpc
+      port: 26257
+      targetPort: grpc
+    - name: http
+      port: 8080
+      targetPort: http
+---
+apiVersion: v1
+kind: Service
+metadata:
+  name: crdb-cluster-public
+  namespace: cockroachdb
+  labels:
+    app.kubernetes.io/name: cockroachdb
+    app.kubernetes.io/instance: crdb-cluster
+    app.kubernetes.io/component: database
+spec:
+  type: ClusterIP
+  selector:
+    app.kubernetes.io/name: cockroachdb
+    app.kubernetes.io/instance: crdb-cluster
+  ports:
+    - name: grpc
+      port: 26257
+      targetPort: grpc
+    - name: http
+      port: 8080
+      targetPort: http
+---
+apiVersion: policy/v1
+kind: PodDisruptionBudget
+metadata:
+  name: crdb-cluster
+  namespace: cockroachdb
+  labels:
+    app.kubernetes.io/name: cockroachdb
+    app.kubernetes.io/instance: crdb-cluster
+spec:
+  minAvailable: 2
+  selector:
+    matchLabels:
+      app.kubernetes.io/name: cockroachdb
+      app.kubernetes.io/instance: crdb-cluster
+---
+apiVersion: apps/v1
+kind: StatefulSet
+metadata:
+  name: crdb-cluster
+  namespace: cockroachdb
+  labels:
+    app.kubernetes.io/name: cockroachdb
+    app.kubernetes.io/instance: crdb-cluster
+spec:
+  serviceName: crdb-cluster
+  replicas: 3
+  podManagementPolicy: Parallel
+  selector:
+    matchLabels:
+      app.kubernetes.io/name: cockroachdb
+      app.kubernetes.io/instance: crdb-cluster
+  template:
+    metadata:
