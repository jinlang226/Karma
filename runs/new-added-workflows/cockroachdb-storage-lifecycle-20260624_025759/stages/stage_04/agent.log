exec
/bin/zsh -lc 'for i in $(seq 1 18); do
  json=$(kubectl exec -n cockroachdb curl-test -- curl -fsS -m 5 '"'http://prometheus.monitoring.svc:9090/api/v1/targets?state=active' 2>/dev/null) || true
  target_status="'$(python3 -c '"'import json,sys
try:
    data=json.load(sys.stdin)[\"data\"][\"activeTargets\"]
except Exception:
    print(\"parse_error\")
    raise SystemExit(1)
items=[t for t in data if t.get(\"labels\",{}).get(\"job\")==\"cockroachdb/crdb-cluster-metrics\"]
for t in sorted(items, key=lambda x: x.get(\"labels\",{}).get(\"pod\",\"\")):
    labels=t.get(\"labels\",{})
    print(\"{}: {} {} {}\".format(labels.get(\"pod\"), t.get(\"health\"), t.get(\"scrapeUrl\"), t.get(\"lastError\") or \"\"))
print(\"summary up={}/{}\".format(sum(1 for t in items if t.get(\"health\")==\"up\"), len(items)))
if len(items)==3 and all(t.get(\"health\")==\"up\" for t in items):
    raise SystemExit(0)
raise SystemExit(2)' <<< \""'$json")
  rc=$?
  printf '"'%s\\n' \""'$target_status"
  [ $rc -eq 0 ] && exit 0
  sleep 10
done
