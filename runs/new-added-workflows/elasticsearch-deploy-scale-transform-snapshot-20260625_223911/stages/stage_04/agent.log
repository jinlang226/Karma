+  kubectl -n "$NAMESPACE" exec -i "$RUNNER_POD" -- curl -fsS "$@"
+}
+
+wait_green() {
+  es "$ES_URL/_cluster/health?wait_for_status=green&timeout=120s" >/dev/null
+}
+
+count_docs() {
+  es "$ES_URL/$1/_count" | sed -E 's/.*"count":([0-9]+).*/\1/'
