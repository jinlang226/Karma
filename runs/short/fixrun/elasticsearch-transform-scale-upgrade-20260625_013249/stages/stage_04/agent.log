{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AKPTp4NXSaX3KETJkdvMg4","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport json\n3\timport os\n4\timport subprocess\n5\timport sys\n6\t\n7\tNAMESPACE = \"elasticsearch\"\n8\tSERVICE = \"es-http\"\n9\tCURL_POD = \"curl-test\"\n10\tTRANSFORM_ID = \"events-by-service\"\n11\tCHECKPOINT_CM = \"transform-checkpoint\"\n12\tDEST_INDEX = \"app-events-rollup\"\n13\t# ES 8.x runs with security enabled, so the HTTP API requires authenticating as\n14\t# the elastic superuser. When this case inherits a secured cluster from an\n15\t# earlier workflow stage, read its password from the secret that stage created\n16\t# so the oracle's queries aren't rejected with 401. Absent secret -> None -> no\n17\t# -u, so a standalone unsecured cluster still works.\n18\tPASSWORD_SECRET = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_SECRET_NAME\", \"elastic-password\")\n19\tPASSWORD_KEY = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_KEY\", \"password\")\n20\tDEFAULT_SCHEME = \"http\"\n21\t_SCHEME = None\n22\t\n23\t\n24\tdef run(cmd):\n25\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n26\t\n27\t\n28\tdef _elastic_password():\n29\t    \"\"\"Fetch the elastic-user password from its secret (base64-decoded), or None.\"\"\"\n30\t    import base64\n31\t    r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", PASSWORD_SECRET,\n32\t             \"-o\", \"jsonpath={.data.\" + PASSWORD_KEY + \"}\"])\n33\t    if r.returncode != 0 or not r.stdout.strip():\n34\t        return None\n35\t    try:\n36\t        return base64.b64decode(r.stdout.strip()).decode()\n37\t    except Exception:\n38\t        return None\n39\t\n40\t\n41\tELASTIC_PASSWORD = None  # set in main() once kubectl is reachable\n42\t\n43\t\n44\tdef _probe_scheme(scheme):\n45\t    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\n46\t\n47\t    The env PERSISTS across stages, so the cluster's live scheme may differ\n48\t    from this case's default; a 401 still proves the scheme is reachable.\n49\t    \"\"\"\n50\t    result = run([\n51\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", CURL_POD, \"--\",\n52\t        \"curl\", \"-s\", \"-S\", \"-k\", \"-o\", \"/dev/null\",\n53\t        \"-w\", \"%{http_code}\", \"--max-time\", \"5\",\n54\t        f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200/\",\n55\t    ])\n56\t    code = (result.stdout or \"\").strip()\n57\t    return result.returncode == 0 and code.isdigit() and code != \"000\"\n58\t\n59\t\n60\tdef detect_scheme():\n61\t    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n62\t    global _SCHEME\n63\t    if _SCHEME is not None:\n64\t        return _SCHEME\n65\t    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n66\t        if _probe_scheme(scheme):\n67\t            _SCHEME = scheme\n68\t            return _SCHEME\n69\t    _SCHEME = DEFAULT_SCHEME\n70\t    return _SCHEME\n71\t\n72\t\n73\tdef curl_json(path, errors):\n74\t    scheme = detect_scheme()\n75\t    result = run(\n76\t        [\n77\t            \"kubectl\",\n78\t            \"-n\",\n79\t            NAMESPACE,\n80\t            \"exec\",\n81\t            CURL_POD,\n82\t            \"--\",\n83\t            \"curl\",\n84\t            \"-s\",\n85\t            \"-S\",\n86\t            \"-k\",\n87\t        ]\n88\t        + ([\"-u\", f\"elastic:{ELASTIC_PASSWORD}\"] if ELASTIC_PASSWORD else [])\n89\t        + [\n90\t            \"--max-time\",\n91\t            \"5\",\n92\t            f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\",\n93\t        ]\n94\t    )\n95\t    if result.returncode != 0:\n96\t        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n97\t        errors.append(f\"Failed to query {path}: {detail}\")\n98\t        return None\n99\t    output = result.stdout.strip()\n100\t    if not output:\n101\t        errors.append(f\"Empty response for {path}\")\n102\t        return None\n103\t    try:\n104\t        return json.loads(output)\n105\t    except json.JSONDecodeError:\n106\t        errors.append(f\"Failed to parse JSON from {path}\")\n107\t        return None\n108\t\n109\t\n110\tdef get_checkpoint_before(errors):\n111\t    result = run(\n112\t        [\n113\t            \"kubectl\",\n114\t            \"-n\",\n115\t            NAMESPACE,\n116\t            \"get\",\n117\t            \"configmap\",\n118\t            CHECKPOINT_CM,\n119\t            \"-o\",\n120\t            \"jsonpath={.data.checkpoint_before}\",\n121\t        ]\n122\t    )\n123\t    if result.returncode != 0:\n124\t        errors.append(\"Unable to read checkpoint_before from configmap\")\n125\t        return None\n126\t    value = (result.stdout or \"\").strip()\n127\t    try:\n128\t        return int(value)\n129\t    except (TypeError, ValueError):\n130\t        errors.append(f\"Invalid checkpoint_before value: {value!r}\")\n131\t        return None\n132\t\n133\t\n134\tdef get_transform(errors):\n135\t    stats = curl_json(f\"/_transform/{TRANSFORM_ID}/_stats\", errors)\n136\t    if not isinstance(stats, dict):\n137\t        return None\n138\t    transforms = stats.get(\"transforms\") or []\n139\t    if not transforms:\n140\t        errors.append(\"Transform stats missing\")\n141\t        return None\n142\t    return transforms[0]\n143\t\n144\t\n145\tdef extract_checkpoint(transform):\n146\t    checkpoint = (\n147\t        transform.get(\"checkpointing\", {})\n148\t        .get(\"last\", {})\n149\t        .get(\"checkpoint\")\n150\t    )\n151\t    if checkpoint is None:\n152\t        checkpoint = (\n153\t            transform.get(\"stats\", {})\n154\t            .get(\"checkpointing\", {})\n155\t            .get(\"last\", {})\n156\t            .get(\"checkpoint\")\n157\t        )\n158\t    return checkpoint\n159\t\n160\t\n161\tdef evaluate(checkpoint_before):\n162\t    \"\"\"Run one full snapshot of the transform-recovery checks; return errors.\"\"\"\n163\t    errors = []\n164\t\n165\t    transform = get_transform(errors)\n166\t    if transform:\n167\t        state = transform.get(\"state\") or transform.get(\"stats\", {}).get(\"state\")\n168\t        if state != \"started\":\n169\t            errors.append(f\"Transform state expected started, got {state}\")\n170\t\n171\t        checkpoint_now = extract_checkpoint(transform)\n172\t        if checkpoint_before is not None:\n173\t            if checkpoint_now is None:\n174\t                errors.append(\"Unable to read current checkpoint\")\n175\t            elif checkpoint_now <= checkpoint_before:\n176\t                errors.append(\n177\t                    f\"Checkpoint did not advance (before={checkpoint_before}, now={checkpoint_now})\"\n178\t                )\n179\t\n180\t    count = curl_json(f\"/{DEST_INDEX}/_count\", errors)\n181\t    if isinstance(count, dict):\n182\t        if count.get(\"count\", 0) <= 0:\n183\t            errors.append(\"Destination index has no documents\")\n184\t\n185\t    return errors\n186\t\n187\t\n188\tdef main():\n189\t    global ELASTIC_PASSWORD\n190\t    ELASTIC_PASSWORD = _elastic_password()\n191\t\n192\t    # After the agent restarts the transform, its next checkpoint and the\n193\t    # destination index's documents only materialize once a transform sync cycle\n194\t    # runs (seconds to a sync interval later), and a curl can flake during that\n195\t    # window. A single immediate snapshot catches the not-yet-advanced state and\n196\t    # falsely reports \"Checkpoint did not advance\" / \"no documents\". So verify the\n197\t    # STABLE converged state: re-evaluate and pass on the first clean snapshot.\n198\t    # The checkpoint_before baseline is read ONCE up front so the advance check\n199\t    # stays strict across retries.\n200\t    # O-deadline: keep the internal deadline strictly below the oracle timeout_sec\n201\t    # (120s in test.yaml) so the harness does not kill the loop before it prints a\n202\t    # verdict; 90s leaves headroom for the final evaluate() + output.\n203\t    import time\n204\t    config_errors = []\n205\t    checkpoint_before = get_checkpoint_before(config_errors)\n206\t    deadline = time.monotonic() + 90\n207\t    live_errors = evaluate(checkpoint_before)\n208\t    while live_errors and time.monotonic() < deadline:\n209\t        time.sleep(8)\n210\t        live_errors = evaluate(checkpoint_before)\n211\t    errors = config_errors + live_errors\n212\t\n213\t    if errors:\n214\t        print(\"Transform recovery verification failed:\", file=sys.stderr)\n215\t        for err in errors:\n216\t            print(f\"  - {err}\", file=sys.stderr)\n217\t        return 1\n218\t\n219\t    print(\"Transform recovery verified\")\n220\t    return 0\n221\t\n222\t\n223\tif __name__ == \"__main__\":\n224\t    sys.exit(main())\n225\t"}]},"parent_tool_use_id":null,"session_id":"9578eac4-901e-472f-b1bf-ce452e0389a3","uuid":"d968e357-63b3-4d7d-8911-4e46ccbb60a9","timestamp":"2026-06-25T02:06:13.792Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/elasticsearch/transform-job-recovery/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport json\nimport os\nimport subprocess\nimport sys\n\nNAMESPACE = \"elasticsearch\"\nSERVICE = \"es-http\"\nCURL_POD = \"curl-test\"\nTRANSFORM_ID = \"events-by-service\"\nCHECKPOINT_CM = \"transform-checkpoint\"\nDEST_INDEX = \"app-events-rollup\"\n# ES 8.x runs with security enabled, so the HTTP API requires authenticating as\n# the elastic superuser. When this case inherits a secured cluster from an\n# earlier workflow stage, read its password from the secret that stage created\n# so the oracle's queries aren't rejected with 401. Absent secret -> None -> no\n# -u, so a standalone unsecured cluster still works.\nPASSWORD_SECRET = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_SECRET_NAME\", \"elastic-password\")\nPASSWORD_KEY = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_KEY\", \"password\")\nDEFAULT_SCHEME = \"http\"\n_SCHEME = None\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef _elastic_password():\n    \"\"\"Fetch the elastic-user password from its secret (base64-decoded), or None.\"\"\"\n    import base64\n    r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", PASSWORD_SECRET,\n             \"-o\", \"jsonpath={.data.\" + PASSWORD_KEY + \"}\"])\n    if r.returncode != 0 or not r.stdout.strip():\n        return None\n    try:\n        return base64.b64decode(r.stdout.strip()).decode()\n    except Exception:\n        return None\n\n\nELASTIC_PASSWORD = None  # set in main() once kubectl is reachable\n\n\ndef _probe_scheme(scheme):\n    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\n\n    The env PERSISTS across stages, so the cluster's live scheme may differ\n    from this case's default; a 401 still proves the scheme is reachable.\n    \"\"\"\n    result = run([\n        \"kubectl\", \"-n\", NAMESPACE, \"exec\", CURL_POD, \"--\",\n        \"curl\", \"-s\", \"-S\", \"-k\", \"-o\", \"/dev/null\",\n        \"-w\", \"%{http_code}\", \"--max-time\", \"5\",\n        f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200/\",\n    ])\n    code = (result.stdout or \"\").strip()\n    return result.returncode == 0 and code.isdigit() and code != \"000\"\n\n\ndef detect_scheme():\n    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n    global _SCHEME\n    if _SCHEME is not None:\n        return _SCHEME\n    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n        if _probe_scheme(scheme):\n            _SCHEME = scheme\n            return _SCHEME\n    _SCHEME = DEFAULT_SCHEME\n    return _SCHEME\n\n\ndef curl_json(path, errors):\n    scheme = detect_scheme()\n    result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"exec\",\n            CURL_POD,\n            \"--\",\n            \"curl\",\n            \"-s\",\n            \"-S\",\n            \"-k\",\n        ]\n        + ([\"-u\", f\"elastic:{ELASTIC_PASSWORD}\"] if ELASTIC_PASSWORD else [])\n        + [\n            \"--max-time\",\n            \"5\",\n            f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\",\n        ]\n    )\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errors.append(f\"Failed to query {path}: {detail}\")\n        return None\n    output = result.stdout.strip()\n    if not output:\n        errors.append(f\"Empty response for {path}\")\n        return None\n    try:\n        return json.loads(output)\n    except json.JSONDecodeError:\n        errors.append(f\"Failed to parse JSON from {path}\")\n        return None\n\n\ndef get_checkpoint_before(errors):\n    result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"get\",\n            \"configmap\",\n            CHECKPOINT_CM,\n            \"-o\",\n            \"jsonpath={.data.checkpoint_before}\",\n        ]\n    )\n    if result.returncode != 0:\n        errors.append(\"Unable to read checkpoint_before from configmap\")\n        return None\n    value = (result.stdout or \"\").strip()\n    try:\n        return int(value)\n    except (TypeError, ValueError):\n        errors.append(f\"Invalid checkpoint_before value: {value!r}\")\n        return None\n\n\ndef get_transform(errors):\n    stats = curl_json(f\"/_transform/{TRANSFORM_ID}/_stats\", errors)\n    if not isinstance(stats, dict):\n        return None\n    transforms = stats.get(\"transforms\") or []\n    if not transforms:\n        errors.append(\"Transform stats missing\")\n        return None\n    return transforms[0]\n\n\ndef extract_checkpoint(transform):\n    checkpoint = (\n        transform.get(\"checkpointing\", {})\n        .get(\"last\", {})\n        .get(\"checkpoint\")\n    )\n    if checkpoint is None:\n        checkpoint = (\n            transform.get(\"stats\", {})\n            .get(\"checkpointing\", {})\n            .get(\"last\", {})\n            .get(\"checkpoint\")\n        )\n    return checkpoint\n\n\ndef evaluate(checkpoint_before):\n    \"\"\"Run one full snapshot of the transform-recovery checks; return errors.\"\"\"\n    errors = []\n\n    transform = get_transform(errors)\n    if transform:\n        state = transform.get(\"state\") or transform.get(\"stats\", {}).get(\"state\")\n        if state != \"started\":\n            errors.append(f\"Transform state expected started, got {state}\")\n\n        checkpoint_now = extract_checkpoint(transform)\n        if checkpoint_before is not None:\n            if checkpoint_now is None:\n                errors.append(\"Unable to read current checkpoint\")\n            elif checkpoint_now <= checkpoint_before:\n                errors.append(\n                    f\"Checkpoint did not advance (before={checkpoint_before}, now={checkpoint_now})\"\n                )\n\n    count = curl_json(f\"/{DEST_INDEX}/_count\", errors)\n    if isinstance(count, dict):\n        if count.get(\"count\", 0) <= 0:\n            errors.append(\"Destination index has no documents\")\n\n    return errors\n\n\ndef main():\n    global ELASTIC_PASSWORD\n    ELASTIC_PASSWORD = _elastic_password()\n\n    # After the agent restarts the transform, its next checkpoint and the\n    # destination index's documents only materialize once a transform sync cycle\n    # runs (seconds to a sync interval later), and a curl can flake during that\n    # window. A single immediate snapshot catches the not-yet-advanced state and\n    # falsely reports \"Checkpoint did not advance\" / \"no documents\". So verify the\n    # STABLE converged state: re-evaluate and pass on the first clean snapshot.\n    # The checkpoint_before baseline is read ONCE up front so the advance check\n    # stays strict across retries.\n    # O-deadline: keep the internal deadline strictly below the oracle timeout_sec\n    # (120s in test.yaml) so the harness does not kill the loop before it prints a\n    # verdict; 90s leaves headroom for the final evaluate() + output.\n    import time\n    config_errors = []\n    checkpoint_before = get_checkpoint_before(config_errors)\n    deadline = time.monotonic() + 90\n    live_errors = evaluate(checkpoint_before)\n    while live_errors and time.monotonic() < deadline:\n        time.sleep(8)\n        live_errors = evaluate(checkpoint_before)\n    errors = config_errors + live_errors\n\n    if errors:\n        print(\"Transform recovery verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    print(\"Transform recovery verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":225,"startLine":1,"totalLines":225}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01SDDmKVrhqqAdw36h8hu8XZ","type":"tool_result","content":"1\t# elasticsearch/transform-job-recovery\n2\t# Restore transform capacity and resume stalled aggregation job after capacity change\n3\t\n4\tprompt: |\n5\t  An aggregated view stopped updating after a transform capacity change.\n6\t\n7\t  OBSERVED STATE:\n8\t  - Transform job is failed or stopped.\n9\t  - Aggregated results are stale.\n10\t\n11\t  YOUR TASK:\n12\t  Restore transform capacity and resume processing.\n13\t\n14\t  CONSTRAINTS:\n15\t  - Do not install CRDs or use the ECK operator.\n16\t  - Restore transform capacity before restarting the job.\n17\t  - Use transform APIs to stop/force-stop and restart if needed.\n18\t  - Do not delete the destination index.\n19\t\n20\t  GOAL:\n21\t  - Transform is started and checkpoint advances.\n22\t\n23\tparams:\n24\t  cluster_prefix:\n25\t    default: es-cluster\n26\t    description: \"Name prefix / pod label for the main Elasticsearch StatefulSet\"\n27\t  transform_cluster_prefix:\n28\t    default: es-transform\n29\t    description: \"Name prefix / pod label for the transform-capacity StatefulSet\"\n30\t  http_service_name:\n31\t    default: es-http\n32\t    description: \"Name of the Elasticsearch HTTP service\"\n33\t  curl_pod_name:\n34\t    default: curl-test\n35\t    description: \"Helper pod used to issue HTTP requests against the cluster\"\n36\t  source_index_name:\n37\t    default: app-events\n38\t    description: \"Source index feeding the transform\"\n39\t  dest_index_name:\n40\t    default: app-events-rollup\n41\t    description: \"Destination (rollup) index produced by the transform\"\n42\t  transform_id:\n43\t    default: events-by-service\n44\t    description: \"Identifier of the transform job\"\n45\t  checkpoint_configmap:\n46\t    default: transform-checkpoint\n47\t    description: \"ConfigMap recording the transform checkpoint before the fault\"\n48\t\n49\tnamespace_contract:\n50\t  required_roles: []\n51\t\n52\tmetrics:\n53\t  - time_to_first_mutation\n54\t  - read_write_ratio\n55\t  - blast_radius\n56\t  - destructive_ops\n57\t  - decoy_integrity\n58\t  - residual_drift\n59\t\n60\tpreconditionUnits:\n61\t  - name: es_env_ready\n62\t    on_probe_fail: skip\n63\t    probe:\n64\t      - command: \"kubectl -n elasticsearch get pods 2>/dev/null | grep -c Running\"\n65\t        timeout_sec: 10\n66\t    apply:\n67\t      - command: \"/bin/sh -c 'kubectl delete namespace elasticsearch --ignore-not-found=true --wait=false; kubectl wait --for=delete namespace/elasticsearch --timeout=400s || true'\"\n68\t        sleep: 1\n69\t      - command: \"kubectl create namespace elasticsearch\"\n70\t        sleep: 1\n71\t      - command: \"kubectl -n elasticsearch apply -f cases/elasticsearch/transform-job-recovery/resource/\"\n72\t        sleep: 1\n73\t      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod -l app={{params.cluster_prefix}} --timeout=600s\"\n74\t        sleep: 1\n75\t      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod -l app={{params.transform_cluster_prefix}} --timeout=300s\"\n76\t        sleep: 1\n77\t      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod/{{params.curl_pod_name}} --timeout=300s\"\n78\t        sleep: 1\n79\t      - command: |\n80\t          /bin/sh -c '\n81\t          for i in $(seq 1 30); do\n82\t            kubectl -n elasticsearch exec {{params.curl_pod_name}} -- curl -s --max-time 5 \"http://{{params.http_service_name}}.elasticsearch.svc:9200/_cluster/health?wait_for_status=yellow&timeout=5s\" | grep -q status && exit 0\n83\t            sleep 2\n84\t          done\n85\t          exit 1\n86\t          '\n87\t        sleep: 1\n88\t      - command: |\n89\t          /bin/sh -c '\n90\t          kubectl -n elasticsearch exec {{params.curl_pod_name}} -- /bin/sh -c '\\''\n91\t          cat <<EOF | curl -s -XPOST http://{{params.http_service_name}}.elasticsearch.svc:9200/_bulk?refresh=true -H \"Content-Type: application/x-ndjson\" --data-binary @-\n92\t          {\"index\":{\"_index\":\"{{params.source_index_name}}\",\"_id\":\"seed-1\"}}\n93\t          {\"service\":\"api\",\"@timestamp\":\"2026-01-01T00:00:00Z\"}\n94\t          {\"index\":{\"_index\":\"{{params.source_index_name}}\",\"_id\":\"seed-2\"}}\n95\t          {\"service\":\"web\",\"@timestamp\":\"2026-01-01T00:00:01Z\"}\n96\t          {\"index\":{\"_index\":\"{{params.source_index_name}}\",\"_id\":\"seed-3\"}}\n97\t          {\"service\":\"api\",\"@timestamp\":\"2026-01-01T00:00:02Z\"}\n98\t          EOF\n99\t          '\\''\n100\t          '\n101\t        sleep: 1\n102\t      - command: |\n103\t          /bin/sh -c '\n104\t          kubectl -n elasticsearch exec {{params.curl_pod_name}} -- curl -s -XPUT http://{{params.http_service_name}}.elasticsearch.svc:9200/_transform/{{params.transform_id}} -H \"Content-Type: application/json\" -d \"{\\\"source\\\":{\\\"index\\\":\\\"{{params.source_index_name}}\\\"},\\\"dest\\\":{\\\"index\\\":\\\"{{params.dest_index_name}}\\\"},\\\"pivot\\\":{\\\"group_by\\\":{\\\"service\\\":{\\\"terms\\\":{\\\"field\\\":\\\"service.keyword\\\"}}},\\\"aggregations\\\":{\\\"event_count\\\":{\\\"value_count\\\":{\\\"field\\\":\\\"service.keyword\\\"}}}},\\\"sync\\\":{\\\"time\\\":{\\\"field\\\":\\\"@timestamp\\\",\\\"delay\\\":\\\"1s\\\"}}}\"\n105\t          '\n106\t        sleep: 1\n107\t      - command: \"kubectl -n elasticsearch exec {{params.curl_pod_name}} -- curl -s -XPOST http://{{params.http_service_name}}.elasticsearch.svc:9200/_transform/{{params.transform_id}}/_start\"\n108\t        sleep: 1\n109\t      - command: |\n110\t          /bin/sh -c '\n111\t          for i in $(seq 1 30); do\n112\t            checkpoint=$(kubectl -n elasticsearch exec {{params.curl_pod_name}} -- curl -s --max-time 5 http://{{params.http_service_name}}.elasticsearch.svc:9200/_transform/{{params.transform_id}}/_stats 2>/dev/null | python3 -c \"import json,sys; data=json.load(sys.stdin); t=data.get(\\\"transforms\\\",[]); print(t[0].get(\\\"checkpointing\\\",{}).get(\\\"last\\\",{}).get(\\\"checkpoint\\\",0) if t else 0)\" 2>/dev/null || echo 0)\n113\t            if [ \"${checkpoint}\" -ge 1 ]; then\n114\t              kubectl -n elasticsearch create configmap {{params.checkpoint_configmap}} --from-literal=checkpoint_before=\"${checkpoint}\" --dry-run=client -o yaml | kubectl apply -f -\n115\t              exit 0\n116\t            fi\n117\t            sleep 2\n118\t          done\n119\t          kubectl -n elasticsearch create configmap {{params.checkpoint_configmap}} --from-literal=checkpoint_before=\"0\" --dry-run=client -o yaml | kubectl apply -f -\n120\t          exit 0\n121\t          '\n122\t        sleep: 1\n123\t      - command: \"kubectl -n elasticsearch scale sts/{{params.transform_cluster_prefix}} --replicas=0\"\n124\t        sleep: 1\n125\t      - command: \"kubectl -n elasticsearch wait --for=delete pod -l app={{params.transform_cluster_prefix}} --timeout=300s\"\n126\t        sleep: 1\n127\t      - command: |\n128\t          /bin/sh -c '\n129\t          kubectl -n elasticsearch exec {{params.curl_pod_name}} -- /bin/sh -c '\\''\n130\t          cat <<EOF | curl -s -XPOST http://{{params.http_service_name}}.elasticsearch.svc:9200/_bulk?refresh=true -H \"Content-Type: application/x-ndjson\" --data-binary @-\n131\t          {\"index\":{\"_index\":\"{{params.source_index_name}}\",\"_id\":\"seed-new-1\"}}\n132\t          {\"service\":\"api\",\"@timestamp\":\"2026-01-02T00:00:00Z\"}\n133\t          {\"index\":{\"_index\":\"{{params.source_index_name}}\",\"_id\":\"seed-new-2\"}}\n134\t          {\"service\":\"web\",\"@timestamp\":\"2026-01-02T00:00:01Z\"}\n135\t          EOF\n136\t          '\\''\n137\t          '\n138\t        sleep: 1\n139\t    verify:\n140\t      - command: \"kubectl -n elasticsearch get pods 2>/dev/null | grep -c Running\"\n141\t        timeout_sec: 10\n142\t\n143\t  - name: transform_scenario_fixture\n144\t    # Re-establish the transform-recovery scenario ADDITIVELY on an inherited\n145\t    # cluster. The entire scenario (the events-by-service transform, the\n146\t    # app-events source + app-events-rollup dest indices, the transform-checkpoint\n147\t    # ConfigMap, and the capacity fault = es-transform scaled to 0) lives ONLY\n148\t    # inside es_env_ready's skip-gated apply. Composed onto an inherited\n149\t    # elasticsearch namespace that apply is skipped, so NONE of it exists and the\n150\t    # oracle errors through no agent fault. This unit reproduces the scenario\n151\t    # WITHOUT deleting the namespace or touching the inherited main es-cluster\n152\t    # data: it ensures the es-transform capacity nodeset, re-seeds the source\n153\t    # docs idempotently, (re)creates+starts the transform, captures the checkpoint\n154\t    # baseline, then re-injects the fault exactly as es_env_ready does. Standalone\n155\t    # the transform already exists so the probe skips and this is a no-op.\n156\t    on_probe_fail: skip\n157\t    probe:\n158\t      # P3: gate on THIS fixture's own deliverable — the transform-checkpoint\n159\t      # ConfigMap the oracle reads — not on a proxy marker (the transform's\n160\t      # _stats==200). Standalone, es_env_ready already created the ConfigMap so the\n161\t      # probe passes and this fixture is a no-op. On an inherited cluster where the\n162\t      # transform may be live but the ConfigMap is absent (es_env_ready's apply was\n163\t      # skipped), the probe fails and the fixture RUNS, rebuilding the baseline +\n164\t      # re-injecting the fault the oracle depends on.\n165\t      - command: \"kubectl -n elasticsearch get configmap {{params.checkpoint_configmap}} >/dev/null 2>&1\"\n166\t        timeout_sec: 30\n167\t    apply:\n168\t      # Ensure the capacity nodeset StatefulSet exists, then bring it Ready so the\n169\t      # transform has somewhere to run while we build the baseline.\n170\t      - command: \"/bin/sh -c 'kubectl -n elasticsearch get sts {{params.transform_cluster_prefix}} >/dev/null 2>&1 || kubectl -n elasticsearch apply -f cases/elasticsearch/transform-job-recovery/resource/statefulset.yaml || true'\"\n171\t        sleep: 1\n172\t      - command: \"/bin/sh -c 'kubectl -n elasticsearch scale sts/{{params.transform_cluster_prefix}} --replicas=1 || true'\"\n173\t        sleep: 1\n174\t      - command: \"/bin/sh -c 'kubectl -n elasticsearch wait --for=condition=ready pod -l app={{params.transform_cluster_prefix}} --timeout=180s || true'\"\n175\t        sleep: 1\n176\t      - command: \"/bin/sh -c 'kubectl -n elasticsearch wait --for=condition=ready pod/{{params.curl_pod_name}} --timeout=180s || true'\"\n177\t        sleep: 1\n178\t      - command: |\n179\t          /bin/sh -c '\n180\t          pw=$(kubectl -n elasticsearch get secret elastic-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); A=\"\"; [ -n \"$pw\" ] && A=\"-u elastic:$pw\"\n181\t          for i in $(seq 1 30); do\n182\t            kubectl -n elasticsearch exec {{params.curl_pod_name}} -- curl -sk $A --max-time 5 \"http://{{params.http_service_name}}.elasticsearch.svc:9200/_cluster/health?wait_for_status=yellow&timeout=5s\" | grep -q status && exit 0\n183\t            sleep 2\n184\t          done\n185\t          exit 0\n186\t          '\n187\t        sleep: 1\n188\t      # Idempotently (re-)seed the source docs. Each doc carries a DETERMINISTIC\n189\t      # _id (seed-1..seed-3), so re-running this on an already-seeded source index\n190\t      # OVERWRITES the same 3 docs instead of appending 3 new ones (a bare bulk\n191\t      # index without _id doubled the count to 6 under composition). The result is\n192\t      # an exact-3 baseline regardless of how many times the fixture replants.\n193\t      - command: |\n194\t          /bin/sh -c '\n195\t          pw=$(kubectl -n elasticsearch get secret elastic-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); A=\"\"; [ -n \"$pw\" ] && A=\"-u elastic:$pw\"\n196\t          kubectl -n elasticsearch exec {{params.curl_pod_name}} -- /bin/sh -c '\\''\n197\t          cat <<EOF | curl -s -k $1 -XPOST http://{{params.http_service_name}}.elasticsearch.svc:9200/_bulk?refresh=true -H \"Content-Type: application/x-ndjson\" --data-binary @-\n198\t          {\"index\":{\"_index\":\"{{params.source_index_name}}\",\"_id\":\"seed-1\"}}\n199\t          {\"service\":\"api\",\"@timestamp\":\"2026-01-01T00:00:00Z\"}\n200\t          {\"index\":{\"_index\":\"{{params.source_index_name}}\",\"_id\":\"seed-2\"}}\n201\t          {\"service\":\"web\",\"@timestamp\":\"2026-01-01T00:00:01Z\"}\n202\t          {\"index\":{\"_index\":\"{{params.source_index_name}}\",\"_id\":\"seed-3\"}}\n203\t          {\"service\":\"api\",\"@timestamp\":\"2026-01-01T00:00:02Z\"}\n204\t          EOF\n205\t          '\\'' sh \"$A\" || true\n206\t          '\n207\t        sleep: 1\n208\t      # (Re)create + start the transform (PUT is idempotent for an absent id).\n209\t      - command: |\n210\t          /bin/sh -c '\n211\t          pw=$(kubectl -n elasticsearch get secret elastic-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); A=\"\"; [ -n \"$pw\" ] && A=\"-u elastic:$pw\"\n212\t          kubectl -n elasticsearch exec {{params.curl_pod_name}} -- curl -sk $A -XPUT http://{{params.http_service_name}}.elasticsearch.svc:9200/_transform/{{params.transform_id}} -H \"Content-Type: application/json\" -d \"{\\\"source\\\":{\\\"index\\\":\\\"{{params.source_index_name}}\\\"},\\\"dest\\\":{\\\"index\\\":\\\"{{params.dest_index_name}}\\\"},\\\"pivot\\\":{\\\"group_by\\\":{\\\"service\\\":{\\\"terms\\\":{\\\"field\\\":\\\"service.keyword\\\"}}},\\\"aggregations\\\":{\\\"event_count\\\":{\\\"value_count\\\":{\\\"field\\\":\\\"service.keyword\\\"}}}},\\\"sync\\\":{\\\"time\\\":{\\\"field\\\":\\\"@timestamp\\\",\\\"delay\\\":\\\"1s\\\"}}}\" || true\n213\t          '\n214\t        sleep: 1\n215\t      - command: |\n216\t          /bin/sh -c '\n217\t          pw=$(kubectl -n elasticsearch get secret elastic-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); A=\"\"; [ -n \"$pw\" ] && A=\"-u elastic:$pw\"\n218\t          kubectl -n elasticsearch exec {{params.curl_pod_name}} -- curl -sk $A -XPOST http://{{params.http_service_name}}.elasticsearch.svc:9200/_transform/{{params.transform_id}}/_start || true\n219\t          '\n220\t        sleep: 1\n221\t      # Poll until checkpoint>=1, then capture the baseline ConfigMap.\n222\t      - command: |\n223\t          /bin/sh -c '\n224\t          pw=$(kubectl -n elasticsearch get secret elastic-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); A=\"\"; [ -n \"$pw\" ] && A=\"-u elastic:$pw\"\n225\t          for i in $(seq 1 30); do\n226\t            checkpoint=$(kubectl -n elasticsearch exec {{params.curl_pod_name}} -- curl -sk $A --max-time 5 http://{{params.http_service_name}}.elasticsearch.svc:9200/_transform/{{params.transform_id}}/_stats 2>/dev/null | python3 -c \"import json,sys; data=json.load(sys.stdin); t=data.get(\\\"transforms\\\",[]); print(t[0].get(\\\"checkpointing\\\",{}).get(\\\"last\\\",{}).get(\\\"checkpoint\\\",0) if t else 0)\" 2>/dev/null || echo 0)\n227\t            if [ \"${checkpoint}\" -ge 1 ]; then\n228\t              kubectl -n elasticsearch create configmap {{params.checkpoint_configmap}} --from-literal=checkpoint_before=\"${checkpoint}\" --dry-run=client -o yaml | kubectl apply -f -\n229\t              exit 0\n230\t            fi\n231\t            sleep 2\n232\t          done\n233\t          kubectl -n elasticsearch create configmap {{params.checkpoint_configmap}} --from-literal=checkpoint_before=\"0\" --dry-run=client -o yaml | kubectl apply -f -\n234\t          exit 0\n235\t          '\n236\t        sleep: 1\n237\t      # Re-inject the capacity fault exactly as es_env_ready does.\n238\t      - command: \"/bin/sh -c 'kub