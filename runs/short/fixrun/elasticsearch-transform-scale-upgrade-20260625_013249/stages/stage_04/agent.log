 # the transform already exists so the probe skips and this is a no-op.\n    on_probe_fail: skip\n    probe:\n      # P3: gate on THIS fixture's own deliverable — the transform-checkpoint\n      # ConfigMap the oracle reads — not on a proxy marker (the transform's\n      # _stats==200). Standalone, es_env_ready already created the ConfigMap so the\n      # probe passes and this fixture is a no-op. On an inherited cluster where the\n      # transform may be live but the ConfigMap is absent (es_env_ready's apply was\n      # skipped), the probe fails and the fixture RUNS, rebuilding the baseline +\n      # re-injecting the fault the oracle depends on.\n      - command: \"kubectl -n elasticsearch get configmap {{params.checkpoint_configmap}} >/dev/null 2>&1\"\n        timeout_sec: 30\n    apply:\n      # Ensure the capacity nodeset StatefulSet exists, then bring it Ready so the\n      # transform has somewhere to run while we build the baseline.\n      - command: \"/bin/sh -c 'kubectl -n elasticsearch get sts {{params.transform_cluster_prefix}} >/dev/null 2>&1 || kubectl -n elasticsearch apply -f cases/elasticsearch/transform-job-recovery/resource/statefulset.yaml || true'\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n elasticsearch scale sts/{{params.transform_cluster_prefix}} --replicas=1 || true'\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n elasticsearch wait --for=condition=ready pod -l app={{params.transform_cluster_prefix}} --timeout=180s || true'\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n elasticsearch wait --for=condition=ready pod/{{params.curl_pod_name}} --timeout=180s || true'\"\n        sleep: 1\n      - command: |\n          /bin/sh -c '\n          pw=$(kubectl -n elasticsearch get secret elastic-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); A=\"\"; [ -n \"$pw\" ] && A=\"-u elastic:$pw\"\n          for i in $(seq 1 30); do\n            kubectl -n elasticsearch exec {{params.curl_pod_name}} -- curl -sk $A --max-time 5 \"http://{{params.http_service_name}}.elasticsearch.svc:9200/_cluster/health?wait_for_status=yellow&timeout=5s\" | grep -q status && exit 0\n            sleep 2\n          done\n          exit 0\n          '\n        sleep: 1\n      # Idempotently (re-)seed the source docs. Each doc carries a DETERMINISTIC\n      # _id (seed-1..seed-3), so re-running this on an already-seeded source index\n      # OVERWRITES the same 3 docs instead of appending 3 new ones (a bare bulk\n      # index without _id doubled the count to 6 under composition). The result is\n      # an exact-3 baseline regardless of how many times the fixture replants.\n      - command: |\n          /bin/sh -c '\n          pw=$(kubectl -n elasticsearch get secret elastic-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); A=\"\"; [ -n \"$pw\" ] && A=\"-u elastic:$pw\"\n          kubectl -n elasticsearch exec {{params.curl_pod_name}} -- /bin/sh -c '\\''\n          cat <<EOF | curl -s -k $1 -XPOST http://{{params.http_service_name}}.elasticsearch.svc:9200/_bulk?refresh=true -H \"Content-Type: application/x-ndjson\" --data-binary @-\n          {\"index\":{\"_index\":\"{{params.source_index_name}}\",\"_id\":\"seed-1\"}}\n          {\"service\":\"api\",\"@timestamp\":\"2026-01-01T00:00:00Z\"}\n          {\"index\":{\"_index\":\"{{params.source_index_name}}\",\"_id\":\"seed-2\"}}\n          {\"service\":\"web\",\"@timestamp\":\"2026-01-01T00:00:01Z\"}\n          {\"index\":{\"_index\":\"{{params.source_index_name}}\",\"_id\":\"seed-3\"}}\n          {\"service\":\"api\",\"@timestamp\":\"2026-01-01T00:00:02Z\"}\n          EOF\n          '\\'' sh \"$A\" || true\n          '\n        sleep: 1\n      # (Re)create + start the transform (PUT is idempotent for an absent id).\n      - command: |\n          /bin/sh -c '\n          pw=$(kubectl -n elasticsearch get secret elastic-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); A=\"\"; [ -n \"$pw\" ] && A=\"-u elastic:$pw\"\n          kubectl -n elasticsearch exec {{params.curl_pod_name}} -- curl -sk $A -XPUT http://{{params.http_service_name}}.elasticsearch.svc:9200/_transform/{{params.transform_id}} -H \"Content-Type: application/json\" -d \"{\\\"source\\\":{\\\"index\\\":\\\"{{params.source_index_name}}\\\"},\\\"dest\\\":{\\\"index\\\":\\\"{{params.dest_index_name}}\\\"},\\\"pivot\\\":{\\\"group_by\\\":{\\\"service\\\":{\\\"terms\\\":{\\\"field\\\":\\\"service.keyword\\\"}}},\\\"aggregations\\\":{\\\"event_count\\\":{\\\"value_count\\\":{\\\"field\\\":\\\"service.keyword\\\"}}}},\\\"sync\\\":{\\\"time\\\":{\\\"field\\\":\\\"@timestamp\\\",\\\"delay\\\":\\\"1s\\\"}}}\" || true\n          '\n        sleep: 1\n      - command: |\n          /bin/sh -c '\n          pw=$(kubectl -n elasticsearch get secret elastic-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); A=\"\"; [ -n \"$pw\" ] && A=\"-u elastic:$pw\"\n          kubectl -n elasticsearch exec {{params.curl_pod_name}} -- curl -sk $A -XPOST http://{{params.http_service_name}}.elasticsearch.svc:9200/_transform/{{params.transform_id}}/_start || true\n          '\n        sleep: 1\n      # Poll until checkpoint>=1, then capture the baseline ConfigMap.\n      - command: |\n          /bin/sh -c '\n          pw=$(kubectl -n elasticsearch get secret elastic-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); A=\"\"; [ -n \"$pw\" ] && A=\"-u elastic:$pw\"\n          for i in $(seq 1 30); do\n            checkpoint=$(kubectl -n elasticsearch exec {{params.curl_pod_name}} -- curl -sk $A --max-time 5 http://{{params.http_service_name}}.elasticsearch.svc:9200/_transform/{{params.transform_id}}/_stats 2>/dev/null | python3 -c \"import json,sys; data=json.load(sys.stdin); t=data.get(\\\"transforms\\\",[]); print(t[0].get(\\\"checkpointing\\\",{}).get(\\\"last\\\",{}).get(\\\"checkpoint\\\",0) if t else 0)\" 2>/dev/null || echo 0)\n            if [ \"${checkpoint}\" -ge 1 ]; then\n              kubectl -n elasticsearch create configmap {{params.checkpoint_configmap}} --from-literal=checkpoint_before=\"${checkpoint}\" --dry-run=client -o yaml | kubectl apply -f -\n              exit 0\n            fi\n            sleep 2\n          done\n          kubectl -n elasticsearch create configmap {{params.checkpoint_configmap}} --from-literal=checkpoint_before=\"0\" --dry-run=client -o yaml | kubectl apply -f -\n          exit 0\n          '\n        sleep: 1\n      # Re-inject the capacity fault exactly as es_env_ready does.\n      - command: \"/bin/sh -c 'kubectl -n elasticsearch scale sts/{{params.transform_cluster_prefix}} --replicas=0 || true'\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n elasticsearch wait --for=delete pod -l app={{params.transform_cluster_prefix}} --timeout=300s || true'\"\n        sleep: 1\n      - command: |\n          /bin/sh -c '\n          pw=$(kubectl -n elasticsearch get secret elastic-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); A=\"\"; [ -n \"$pw\" ] && A=\"-u elastic:$pw\"\n          kubectl -n elasticsearch exec {{params.curl_pod_name}} -- /bin/sh -c '\\''\n          cat <<EOF | curl -s -k $1 -XPOST http://{{params.http_service_name}}.elasticsearch.svc:9200/_bulk?refresh=true -H \"Content-Type: application/x-ndjson\" --data-binary @-\n          {\"index\":{\"_index\":\"{{params.source_index_name}}\",\"_id\":\"seed-new-1\"}}\n          {\"service\":\"api\",\"@timestamp\":\"2026-01-02T00:00:00Z\"}\n          {\"index\":{\"_index\":\"{{params.source_index_name}}\",\"_id\":\"seed-new-2\"}}\n          {\"service\":\"web\",\"@timestamp\":\"2026-01-02T00:00:01Z\"}\n          EOF\n          '\\'' sh \"$A\" || true\n          '\n        sleep: 1\n    verify:\n      - command: \"/bin/sh -c true\"\n        timeout_sec: 5\n\noracle:\n  verify:\n    commands:\n      - command: \"python3 cases/elasticsearch/transform-job-recovery/oracle/oracle.py\"\n        timeout_sec: 120\n","numLines":264,"startLine":1,"totalLines":264}}}
