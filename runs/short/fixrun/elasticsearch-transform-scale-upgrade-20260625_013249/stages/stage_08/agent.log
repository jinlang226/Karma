base64 -d 2>/dev/null); A=\"\"; [ -n \"$pw\" ] && A=\"-u elastic:$pw\"\n196\t          kubectl -n elasticsearch exec {{params.curl_pod_name}} -- /bin/sh -c '\\''\n197\t          cat <<EOF | curl -s -k $1 -XPOST http://{{params.http_service_name}}.elasticsearch.svc:9200/_bulk?refresh=true -H \"Content-Type: application/x-ndjson\" --data-binary @-\n198\t          {\"index\":{\"_index\":\"{{params.source_index_name}}\",\"_id\":\"seed-1\"}}\n199\t          {\"service\":\"api\",\"@timestamp\":\"2026-01-01T00:00:00Z\"}\n200\t          {\"index\":{\"_index\":\"{{params.source_index_name}}\",\"_id\":\"seed-2\"}}\n201\t          {\"service\":\"web\",\"@timestamp\":\"2026-01-01T00:00:01Z\"}\n202\t          {\"index\":{\"_index\":\"{{params.source_index_name}}\",\"_id\":\"seed-3\"}}\n203\t          {\"service\":\"api\",\"@timestamp\":\"2026-01-01T00:00:02Z\"}\n204\t          EOF\n205\t          '\\'' sh \"$A\" || true\n206\t          '\n207\t        sleep: 1\n208\t      # (Re)create + start the transform (PUT is idempotent for an absent id).\n209\t      - command: |\n210\t          /bin/sh -c '\n211\t          pw=$(kubectl -n elasticsearch get secret elastic-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); A=\"\"; [ -n \"$pw\" ] && A=\"-u elastic:$pw\"\n212\t          kubectl -n elasticsearch exec {{params.curl_pod_name}} -- curl -sk $A -XPUT http://{{params.http_service_name}}.elasticsearch.svc:9200/_transform/{{params.transform_id}} -H \"Content-Type: application/json\" -d \"{\\\"source\\\":{\\\"index\\\":\\\"{{params.source_index_name}}\\\"},\\\"dest\\\":{\\\"index\\\":\\\"{{params.dest_index_name}}\\\"},\\\"pivot\\\":{\\\"group_by\\\":{\\\"service\\\":{\\\"terms\\\":{\\\"field\\\":\\\"service.keyword\\\"}}},\\\"aggregations\\\":{\\\"event_count\\\":{\\\"value_count\\\":{\\\"field\\\":\\\"service.keyword\\\"}}}},\\\"sync\\\":{\\\"time\\\":{\\\"field\\\":\\\"@timestamp\\\",\\\"delay\\\":\\\"1s\\\"}}}\" || true\n213\t          '\n214\t        sl