             mountPath: /usr/share/elasticsearch/config/elasticsearch.yml\n              subPath: elasticsearch.yml\n            - name: es-tls\n              mountPath: /usr/share/elasticsearch/config/certs\n              readOnly: true\n          readinessProbe:\n            exec:\n              command:\n                - sh\n                - -c\n                - |\n                  curl -sk -u \"elastic:${ELASTIC_PASSWORD}\" https://localhost:9200/_cluster/health \\\n                    --cacert /usr/share/elasticsearch/config/certs/ca.crt \\\n                    | grep -qE '\"status\":\"(green|yellow)\"'\n            initialDelaySeconds: 30\n            periodSeconds: 10\n            timeoutSeconds: 10\n            failureThreshold: 12\n          resources:\n            requests:\n              memory: \"1Gi\"\n              cpu: \"500m\"\n            limits:\n              memory: \"2Gi\"\n              cpu: \"1\"\n      volumes:\n        - name: es-config\n          configMap:\n            name: es-config\n        - name: es-tls\n          secret:\n            secretName: es-http-tls\n  volumeClaimTemplates:\n    - metadata:\n        name: es-data\n      spec:\n        accessModes: [\"ReadWriteOnce\"]\n        resources:\n          requests:\n            storage: 5Gi\nEOF\n","description":"Create the 3-node Elasticsearch StatefulSet"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":681,"cache_read_input_tokens":29423,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":681},"output_tokens":58,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"fd259128-069b-45cd-b525-e5e3bdceb713","uuid":"33ce1c5a-19e5-4762-94b2-849974dc185a","request_id":"req_011CcQ8Cvc2UEhMD7qNUHeQh"}
