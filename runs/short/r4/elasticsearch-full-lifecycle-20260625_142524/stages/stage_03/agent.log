n/sh -c 'kubectl -n elasticsearch wait --for=condition=ready pod/file-realm-gen --timeout=300s || true'\"\n        sleep: 1\n      - command: |\n          /bin/sh -c '\n          set -e\n          TMP_DIR=$(mktemp -d)\n          kubectl -n elasticsearch exec file-realm-gen -- /bin/sh -c '\\''\n          set -e\n          mkdir -p /tmp/ops /tmp/report\n          : > /tmp/ops/users; : > /tmp/ops/users_roles; : > /tmp/report/users; : > /tmp/report/users_roles\n          ES_PATH_CONF=/tmp/ops /usr/share/elasticsearch/bin/elasticsearch-users useradd {{params.ops_user}} -p {{params.ops_password}} -r superuser\n          ES_PATH_CONF=/tmp/report /usr/share/elasticsearch/bin/elasticsearch-users useradd {{params.report_user}} -p {{params.report_password}} -r viewer\n          : > /tmp/ops/roles.yml; : > /tmp/report/roles.yml\n          '\\''\n          kubectl -n elasticsearch cp file-realm-gen:/tmp/ops \"${TMP_DIR}/ops\"\n          kubectl -n elasticsearch cp file-realm-gen:/tmp/report \"${TMP_DIR}/report\"\n          kubectl -n elasticsearch create secret generic {{params.aggregate_secret_name}} --from-file=users=\"${TMP_DIR}/ops/users\" --from-file=users_roles=\"${TMP_DIR}/ops/users_roles\" --from-file=roles.yml=\"${TMP_DIR}/ops/roles.yml\" --dry-run=client -o yaml | kubectl apply -f -\n          kubectl -n elasticsearch create secret generic {{params.provided_secret_name}} --from-file=users=\"${TMP_DIR}/report/users\" --from-file=users_roles=\"${TMP_DIR}/report/users_roles\" --from-file=roles.yml=\"${TMP_DIR}/report/roles.yml\" --dry-run=client -o yaml | kubectl apply -f - || true\n          '\n        sleep: 1\n      # Seed the app-data index that report-user reads (composition safety): the\n      # standalone es_env_ready apply seeds it (via curl-test + ops_user), but on an\n      # INHERITED cluster that apply is probe-skipped, so app-data is absent and the\n      # oracle's report-user read fails even after a correct merge. Recreate it\n      # ADDITIVELY here: deplo