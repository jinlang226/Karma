error logs from the Elasticsearch pods to see what's really failing.","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1563,"cache_read_input_tokens":86415,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1563},"output_tokens":22,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"7dfcb699-3238-4724-9d70-a60a45e29af4","uuid":"887f2a8e-130c-48db-8dad-b6a7cc45890b","request_id":"req_011CcQeA2UQXi7GafWthdsMS"}
