{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_01B9avCcnCR4mnVjeHSNiaSN","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01FUvpnVVpKKCAKzSQjte48F","name":"Write","input":{"file_path":"/tmp/es-cluster.yaml","content":"---\napiVersion: v1\nkind: ConfigMap\nmetadata:\n  name: es-config\n  namespace: elasticsearch\ndata:\n  elasticsearch.yml: |\n    cluster.name: es-cluster\n    node.name: ${HOSTNAME}\n    network.host: 0.0.0.0\n\n    discovery.seed_hosts:\n      - es-0.es-transport.elasticsearch.svc.cluster.local\n      - es-1.es-transport.elasticsearch.svc.cluster.local\n      - es-2.es-transport.elasticsearch.svc.cluster.local\n    cluster.initial_master_nodes:\n      - es-0\n      - es-1\n      - es-2\n\n    xpack.security.enabled: true\n\n    xpack.security.http.ssl.enabled: true\n    xpack.security.http.ssl.key: /usr/share/elasticsearch/config/certs/tls.key\n    xpack.security.http.ssl.certificate: /usr/share/elasticsearch/config/certs/tls.crt\n    xpack.security.http.ssl.certificate_authorities: /usr/share/elasticsearch/config/certs/ca.crt\n\n    xpack.security.transport.ssl.enabled: true\n    xpack.security.transport.ssl.verification_mode: certificate\n    xpack.security.transport.ssl.key: /usr/share/elasticsearch/config/certs/tls.key\n    xpack.security.transport.ssl.certificate: /usr/share/elasticsearch/config/certs/tls.crt\n    xpack.security.transport.ssl.certificate_authorities: /usr/share/elasticsearch/config/certs/ca.crt\n---\napiVersion: v1\nkind: Service\nmetadata:\n  name: es-transport\n  namespace: elasticsearch\nspec:\n  clusterIP: None\n  selector:\n    app: elasticsearch\n  ports:\n    - name: transport\n      port: 9300\n      targetPort: 9300\n---\napiVersion: v1\nkind: Service\nmetadata:\n  name: es-http\n  namespace: elasticsearch\nspec:\n  selector:\n    app: elasticsearch\n  ports:\n    - name: https\n      port: 9200\n      targetPort: 9200\n---\napiVersion: policy/v1\nkind: PodDisruptionBudget\nmetadata:\n  name: es-pdb\n  namespace: elasticsearch\nspec:\n  minAvailable: 2\n  selector:\n    matchLabels:\n      app: elasticsearch\n---\napiVersion: apps/v1\nkind: StatefulSet\nmetadata:\n  name: es\n  namespace: elasticsearch\nspec:\n  serviceName: es-transport\n  replicas: 3\n  selector:\n    matchLabels:\n      app: elasticsearch\n  template:\n    metadata:\n      labels:\n        app: elasticsearch\n    spec:\n      initContainers:\n        - name: sysctl\n          image: busybox\n          command: [\"sysctl\", \"-w\", \"vm.max_map_count=262144\"]\n          securityContext:\n            privileged: true\n      containers:\n        - name: elasticsearch\n          image: docker.elastic.co/elasticsearch/elasticsearch:8.11.1\n          env:\n            - name: ELASTIC_PASSWORD\n              valueFrom:\n                secretKeyRef:\n                  name: elastic-password\n                  key: password\n            - name: ES_JAVA_OPTS\n              value: \"-Xms512m -Xmx512m\"\n          ports:\n            - containerPort: 9200\n              name: https\n            - containerPort: 9300\n              name: transport\n          resources:\n            requests:\n              memory: \"1Gi\"\n              cpu: \"250m\"\n            limits:\n              memory: \"1.5Gi\"\n              cpu: \"1\"\n          readinessProbe:\n            exec:\n              command:\n                - bash\n                - -c\n                - |\n                  curl -sf -k -u \"elastic:${ELASTIC_PASSWORD}\" \\\n                    https://localhost:9200/_cluster/health \\\n                    | grep -qE '\"status\":\"(green|yellow)\"'\n            initialDelaySeconds: 30\n            periodSeconds: 10\n            timeoutSeconds: 5\n            failureThreshold: 6\n          volumeMounts:\n            - name: config\n              mountPath: /usr/share/elasticsearch/config/elasticsearch.yml\n              subPath: elasticsearch.yml\n            - name: certs\n              mountPath: /usr/share/elasticsearch/config/certs\n              readOnly: true\n            - name: data\n              mountPath: /usr/share/elasticsearch/data\n      volumes:\n        - name: config\n          configMap:\n            name: es-config\n        - name: certs\n          secret:\n            secretName: es-http-tls\n        - name: data\n          emptyDir: {}\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":315,"cache_read_input_tokens":29225,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":315},"output_tokens":8,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"f7cc2bc1-d1ae-4b8c-ae09-e1ca7d9cdcd8","uuid":"bb142f05-daa5-4bdb-979e-778787f48226","request_id":"req_011CcfCgLYxZ7Y6bXj9AKhCf"}
