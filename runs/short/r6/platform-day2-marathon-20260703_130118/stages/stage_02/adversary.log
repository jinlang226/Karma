$ kubectl -n cockroachdb get pods -l app.kubernetes.io/name=cockroachdb --no-headers
crdb-cluster-0   1/1   Running   0     58s
crdb-cluster-1   1/1   Running   0     58s
crdb-cluster-2   1/1   Running   0     58s

$ kubectl -n cockroachdb apply -f - <<'EOF'
apiVersion: networking.k8s.io/v1
kind: NetworkPolicy
metadata:
  name: block-crdb-sql
  namespace: cockroachdb
spec:
  podSelector:
    matchLabels:
      app.kubernetes.io/name: cockroachdb
  policyTypes:
  - Ingress
  ingress:
  - ports:
    - port: 8080
      protocol: TCP
EOF

networkpolicy.networking.k8s.io/block-crdb-sql created

$ kubectl -n cockroachdb get networkpolicy block-crdb-sql
NAME             POD-SELECTOR                         AGE
block-crdb-sql   app.kubernetes.io/name=cockroachdb   0s

