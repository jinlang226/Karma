{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AVb7xXpVE5dHQ93fKhzJrn","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport argparse\n3\timport base64\n4\timport json\n5\timport os\n6\timport subprocess\n7\timport sys\n8\t\n9\t\n10\tNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"mongodb\")\n11\tCLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"mongodb-replica\")\n12\tPOD = f\"{CLUSTER_PREFIX}-0\"\n13\tADMIN_SECRET = os.environ.get(\"BENCH_PARAM_ADMIN_SECRET_NAME\", \"admin-user-password\")\n14\tREPORTING_SECRET = os.environ.get(\"BENCH_PARAM_REPORTING_SECRET_NAME\", \"reporting-user-password\")\n15\tADMIN_USER = os.environ.get(\"BENCH_PARAM_ADMIN_USERNAME\", \"admin-user\")\n16\tREPORTING_USER = os.environ.get(\"BENCH_PARAM_REPORTING_USERNAME\", \"reporting-user\")\n17\tAPP_DB = os.environ.get(\"BENCH_PARAM_APP_DATABASE\", \"appdb\")\n18\tREPORTS_COLLECTION = os.environ.get(\"BENCH_PARAM_REPORTS_COLLECTION\", \"reports\")\n19\tRAW_COLLECTION = os.environ.get(\"BENCH_PARAM_RAW_COLLECTION\", \"raw\")\n20\tBAD_ROLE = os.environ.get(\"BENCH_PARAM_BAD_ROLE_NAME\", \"rawRead\")\n21\tREPORTING_ROLE = os.environ.get(\"BENCH_PARAM_REPORTING_ROLE_NAME\", \"reportingRole\")\n22\t\n23\t\n24\tdef run(cmd, timeout=30):\n25\t    \"\"\"Run a command bounded (O17): a hung kubectl/mongosh exec becomes a\n26\t    failed attempt instead of an uncaught TimeoutExpired that would crash the\n27\t    whole oracle at its deadline.\"\"\"\n28\t    try:\n29\t        return subprocess.run(cmd, text=True, stdout=subprocess.PIPE,\n30\t                              stderr=subprocess.PIPE, timeout=timeout)\n31\t    except subprocess.TimeoutExpired:\n32\t        return subprocess.CompletedProcess(cmd, 124, \"\", \"timed out\")\n33\t\n34\t\n35\t_TLS_FLAGS_CACHE = None\n36\t\n37\t\n38\tdef _mongo_tls_flags(probe_pod=None):\n39\t    \"\"\"mongosh transport flags that adapt to the cluster's LIVE TLS mode.\n40\t\n41\t    The environment PERSISTS across workflow stages, so an earlier stage\n42\t    (mongodb/tls-setup or mongodb/certificate-rotation) may have turned TLS on,\n43\t    after which a plain mongosh connection is refused. Detect TLS by probing the\n44\t    running mongo pod for a CA cert mounted at the paths the TLS stages use; if\n45\t    present, connect with --tls --tlsCAFile (and a client cert for mutual TLS\n46\t    when one is mounted), else connect plain. Standalone (no CA mounted) this\n47\t    returns [] -> identical plain behaviour. It only adds transport flags; every\n48\t    real check still runs and still fails when its condition is unmet.\n49\t    \"\"\"\n50\t    global _TLS_FLAGS_CACHE\n51\t    if _TLS_FLAGS_CACHE is not None:\n52\t        return list(_TLS_FLAGS_CACHE)\n53\t    flags = []\n54\t    pod = probe_pod or f\"{CLUSTER_PREFIX}-0\"\n55\t    ca_path = None\n56\t    for cand in (\n57\t        \"/etc/tls/ca.crt\",\n58\t        \"/etc/mongo-ca/ca.crt\",\n59\t        \"/etc/mongodb/tls/ca.crt\",\n60\t        \"/etc/ssl/mongodb/ca.crt\",\n61\t    ):\n62\t        probe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + cand])\n63\t        if probe.returncode == 0:\n64\t            ca_path = cand\n65\t            break\n66\t    if ca_path:\n67\t        flags = [\"--tls\", \"--tlsAllowInvalidHostnames\", \"--tlsAllowInvalidCertificates\", \"--tlsCAFile\", ca_path]\n68\t        for client_pem in (\"/etc/tls/client.pem\", \"/etc/mongo-ca/client.pem\"):\n69\t            cprobe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + client_pem])\n70\t            if cprobe.returncode == 0:\n71\t                flags += [\"--tlsCertificateKeyFile\", client_pem]\n72\t                break\n73\t    _TLS_FLAGS_CACHE = flags\n74\t    return list(flags)\n75\t\n76\tdef fail(prefix, errors):\n77\t    if errors:\n78\t        print(prefix, file=sys.stderr)\n79\t        for err in errors:\n80\t            print(f\"  - {err}\", file=sys.stderr)\n81\t        return 1\n82\t    return 0\n83\t\n84\t\n85\tdef get_secret(secret_name, errors):\n86\t    res = run([\n87\t        \"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", secret_name, \"-o\", \"jsonpath={.data.password}\"\n88\t    ])\n89\t    if res.returncode != 0:\n90\t        errors.append(f\"Failed to read secret {secret_name}: {res.stderr.strip() or res.stdout.strip()}\")\n91\t        return None\n92\t    try:\n93\t        return base64.b64decode((res.stdout or \"\").strip()).decode(\"utf-8\")\n94\t    except Exception:\n95\t        errors.append(f\"Failed to decode secret {secret_name}.password\")\n96\t        return None\n97\t\n98\t\n99\tdef _exec_mongo(pod, uri, eval_str):\n100\t    return run([\n101\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"mongosh\", \"--quiet\", *_mongo_tls_flags(), uri, \"--eval\", eval_str\n102\t    ])\n103\t\n104\t\n105\t_PRIMARY_POD_CACHE = None\n106\t\n107\t\n108\tdef find_primary(uri):\n109\t    \"\"\"Locate the replica-set PRIMARY pod, falling back to POD.\n110\t\n111\t    The environment PERSISTS across workflow stages, so an earlier stage (e.g.\n112\t    mongodb/arbiters) can trigger an election that moves the PRIMARY off\n113\t    ``{CLUSTER_PREFIX}-0``. getRole/getUser lookups and reads/writes here\n114\t    require the primary -- on a secondary they fail with \"not primary and\n115\t    secondaryOk=false\". Exec db.hello() into each member, parse the\n116\t    writable-primary node, and route subsequent mongosh exec there. Standalone\n117\t    (single node) this resolves to POD -> identical behaviour; no check or\n118\t    expected value changes.\n119\t    \"\"\"\n120\t    global _PRIMARY_POD_CACHE\n121\t    if _PRIMARY_POD_CACHE is not None:\n122\t        return _PRIMARY_POD_CACHE\n123\t    for idx in range(9):\n124\t        pod = f\"{CLUSTER_PREFIX}-{idx}\"\n125\t        res = _exec_mongo(pod, uri, \"db.hello().isWritablePrimary\")\n126\t        if res.returncode != 0:\n127\t            if idx > 0 and \"NotFound\" in (res.stderr or \"\"):\n128\t                break\n129\t            continue\n130\t        if \"true\" in (res.stdout or \"\"):\n131\t            _PRIMARY_POD_CACHE = pod\n132\t            return pod\n133\t    return POD\n134\t\n135\t\n136\tdef run_mongo(uri, eval_str):\n137\t    # Route every read/write to the PRIMARY so a workflow election off\n138\t    # replica-0 does not surface as \"not primary\"/missing-role failures.\n139\t    return _exec_mongo(find_primary(uri), uri, eval_str)\n140\t\n141\t\n142\tdef load_json(uri, eval_str, label, errors):\n143\t    res = run_mongo(uri, eval_str)\n144\t    if res.returncode != 0:\n145\t        errors.append(f\"{label} failed: {res.stderr.strip() or res.stdout.strip()}\")\n146\t        return None\n147\t    raw = (res.stdout or \"\").strip()\n148\t    if not raw:\n149\t        errors.append(f\"{label} returned empty output\")\n150\t        return None\n151\t    try:\n152\t        return json.loads(raw)\n153\t    except json.JSONDecodeError:\n154\t        errors.append(f\"Unable to parse {label} JSON output\")\n155\t        return None\n156\t\n157\t\n158\tdef role_has_reports_privileges(role):\n159\t    for priv in role.get(\"privileges\", []):\n160\t        resource = priv.get(\"resource\", {})\n161\t        if resource.get(\"db\") != APP_DB or resource.get(\"collection\") != REPORTS_COLLECTION:\n162\t            continue\n163\t        actions = set(priv.get(\"actions\", []))\n164\t        if \"find\" in actions:\n165\t            return True\n166\t    return False\n167\t\n168\t\n169\tdef role_touches_raw(role):\n170\t    for priv in role.get(\"privileges\", []):\n171\t        resource = priv.get(\"resource\", {})\n172\t        if resource.get(\"db\") == APP_DB and resource.get(\"collection\") == RAW_COLLECTION:\n173\t            return True\n174\t    return False\n175\t\n176\t\n177\tdef user_has_role(user, role_name, role_db=None):\n178\t    for role in user.get(\"roles\", []):\n179\t        if role.get(\"role\") != role_name:\n180\t            continue\n181\t        if role_db is None or role.get(\"db\") == role_db:\n182\t            return True\n183\t    return False\n184\t\n185\t\n186\tdef credentials(errors):\n187\t    admin_pw = get_secret(ADMIN_SECRET, errors)\n188\t    reporting_pw = get_secret(REPORTING_SECRET, errors)\n189\t    if errors:\n190\t        return None\n191\t    return {\n192\t        # directConnection skips SDAM topology monitoring (via find_primary's\n193\t        # db.hello), which a localhost connection would start and which fails\n194\t        # under a persisted requireTLS mode.\n195\t        \"admin_uri\": f\"mongodb://{ADMIN_USER}:{admin_pw}@localhost:27017/admin?directConnection=true\",\n196\t        \"reporting_uri\": f\"mongodb://{REPORTING_USER}:{reporting_pw}@localhost:27017/{APP_DB}?authSource=admin&directConnection=true\",\n197\t    }\n198\t\n199\t\n200\tdef check_role():\n201\t    errors = []\n202\t    c = credentials(errors)\n203\t    if c is None:\n204\t        return fail(\"Custom roles role check failed:\", errors)\n205\t\n206\t    # Name-agnostic: the prompt asks to \"restore the minimum access needed for\n207\t    # reporting dashboards\" without dictating a role name, so the agent is free to\n208\t    # name the restored role anything (e.g. reportsRead). Inspect the roles the\n209\t    # reporting-user ACTUALLY holds rather than a hardcoded REPORTING_ROLE name:\n210\t    # at least one held role must grant find on reports, and NO held role may\n211\t    # carry any privilege on raw. check_access independently proves the effective\n212\t    # read/deny behaviour, so the security bar is unchanged -- only the unstated\n213\t    # exact-name requirement is dropped.\n214\t    user = load_json(c[\"admin_uri\"], f'JSON.stringify(db.getUser(\"{REPORTING_USER}\"))', REPORTING_USER, errors)\n215\t    if not isinstance(user, dict):\n216\t        return fail(\"Custom roles role check failed:\", errors)\n217\t\n218\t    grants_reports = False\n219\t    for r in user.get(\"roles\", []):\n220\t        rname, rdb = r.get(\"role\"), r.get(\"db\")\n221\t        if not rname or not rdb:\n222\t            continue\n223\t        role = load_json(\n224\t            c[\"admin_uri\"],\n225\t            f'JSON.stringify(db.getSiblingDB(\"{rdb}\").getRole(\"{rname}\",{{showPrivileges:true}}))',\n226\t            f\"{rname} ({rdb})\",\n227\t            [],\n228\t        )\n229\t        if not isinstance(role, dict):\n230\t            continue\n231\t        if role_has_reports_privileges(role):\n232\t            grants_reports = True\n233\t        if role_touches_raw(role):\n234\t            errors.append(f\"role {rname} held by {REPORTING_USER} must not grant access to {APP_DB}.{RAW_COLLECTION}\")\n235\t\n236\t    if not grants_reports:\n237\t        errors.append(f\"{REPORTING_USER} has no role granting find on {APP_DB}.{REPORTS_COLLECTION}\")\n238\t\n239\t    return fail(\"Custom roles role check failed:\", errors)\n240\t\n241\t\n242\tdef check_bindings():\n243\t    errors = []\n244\t    c = credentials(errors)\n245\t    if c is None:\n246\t        return fail(\"Custom roles bindings check failed:\", errors)\n247\t\n248\t    user = load_json(c[\"admin_uri\"], f'JSON.stringify(db.getUser(\"{REPORTING_USER}\"))', REPORTING_USER, errors)\n249\t    if isinstance(user, dict):\n250\t        # The deprecated over-permissive role must be removed...\n251\t        if user_has_role(user, BAD_ROLE, APP_DB):\n252\t            errors.append(f\"{REPORTING_USER} still has deprecated role {BAD_ROLE}\")\n253\t        # ...and the user must hold some replacement role (name-agnostic: the\n254\t        # agent chooses the name; check_role validates that role's privileges).\n255\t        replacement = [\n256\t            r for r in user.get(\"roles\", [])\n257\t            if not (r.get(\"role\") == BAD_ROLE and r.get(\"db\") == APP_DB)\n258\t        ]\n259\t        if not replacement:\n260\t            errors.append(f\"{REPORTING_USER} has no replacement role granting reporting access\")\n261\t\n262\t    return fail(\"Custom roles bindings check failed:\", errors)\n263\t\n264\t\n265\tdef check_access():\n266\t    errors = []\n267\t    c = credentials(errors)\n268\t    if c is None:\n269\t        return fail(\"Custom roles access check failed:\", errors)\n270\t\n271\t    reports_read = run_mongo(c[\"reporting_uri\"], f'db.{REPORTS_COLLECTION}.findOne({{}})')\n272\t    if reports_read.returncode != 0:\n273\t        errors.append(f\"{REPORTING_USER} read on reports failed: {reports_read.stderr.strip() or reports_read.stdout.strip()}\")\n274\t\n275\t    reports_agg = run_mongo(c[\"reporting_uri\"], f'db.{REPORTS_COLLECTION}.aggregate([{{$match:{{}}}}]).toArray().length')\n276\t    if reports_agg.returncode != 0:\n277\t        errors.append(f\"{REPORTING_USER} aggregate on reports failed: {reports_agg.stderr.strip() or reports_agg.stdout.strip()}\")\n278\t\n279\t    raw_read = run_mongo(c[\"reporting_uri\"], f'db.{RAW_COLLECTION}.findOne({{}})')\n280\t    raw_combined = (raw_read.stdout + raw_read.stderr).lower()\n281\t    if raw_read.returncode == 0 and \"not authorized\" not in raw_combined:\n282\t        errors.append(f\"{REPORTING_USER} can read {RAW_COLLECTION} unexpectedly\")\n283\t\n284\t    reports_write = run_mongo(c[\"reporting_uri\"], f'db.{REPORTS_COLLECTION}.insertOne({{bad:\"write\"}})')\n285\t    write_combined = (reports_write.stdout + reports_write.stderr).lower()\n286\t    if reports_write.returncode == 0 and \"not authorized\" not in write_combined:\n287\t        errors.append(f\"{REPORTING_USER} can write {REPORTS_COLLECTION} unexpectedly\")\n288\t\n289\t    return fail(\"Custom roles access check failed:\", errors)\n290\t\n291\t\n292\tdef main():\n293\t    parser = argparse.ArgumentParser()\n294\t    parser.add_argument(\"--check\", default=\"all\", choices=[\"all\", \"role\", \"bindings\", \"access\"])\n295\t    args = parser.parse_args()\n296\t\n297\t    if args.check == \"role\":\n298\t        return check_role()\n299\t    if args.check == \"bindings\":\n300\t        return check_bindings()\n301\t    if args.check == \"access\":\n302\t        return check_access()\n303\t\n304\t    for fn in (check_role, check_bindings, check_access):\n305\t        rc = fn()\n306\t        if rc != 0:\n307\t            return rc\n308\t    print(\"Custom roles verified\")\n309\t    return 0\n310\t\n311\t\n312\tif __name__ == \"__main__\":\n313\t    sys.exit(main())\n314\t"}]},"parent_tool_use_id":null,"session_id":"f52bdb1a-fcc9-414e-88fd-0e06dfc64071","uuid":"be903db9-3f8d-4d35-9538-28ae42acd017","timestamp":"2026-07-03T12:38:10.278Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/mongodb/custom-roles/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport argparse\nimport base64\nimport json\nimport os\nimport subprocess\nimport sys\n\n\nNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"mongodb\")\nCLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"mongodb-replica\")\nPOD = f\"{CLUSTER_PREFIX}-0\"\nADMIN_SECRET = os.environ.get(\"BENCH_PARAM_ADMIN_SECRET_NAME\", \"admin-user-password\")\nREPORTING_SECRET = os.environ.get(\"BENCH_PARAM_REPORTING_SECRET_NAME\", \"reporting-user-password\")\nADMIN_USER = os.environ.get(\"BENCH_PARAM_ADMIN_USERNAME\", \"admin-user\")\nREPORTING_USER = os.environ.get(\"BENCH_PARAM_REPORTING_USERNAME\", \"reporting-user\")\nAPP_DB = os.environ.get(\"BENCH_PARAM_APP_DATABASE\", \"appdb\")\nREPORTS_COLLECTION = os.environ.get(\"BENCH_PARAM_REPORTS_COLLECTION\", \"reports\")\nRAW_COLLECTION = os.environ.get(\"BENCH_PARAM_RAW_COLLECTION\", \"raw\")\nBAD_ROLE = os.environ.get(\"BENCH_PARAM_BAD_ROLE_NAME\", \"rawRead\")\nREPORTING_ROLE = os.environ.get(\"BENCH_PARAM_REPORTING_ROLE_NAME\", \"reportingRole\")\n\n\ndef run(cmd, timeout=30):\n    \"\"\"Run a command bounded (O17): a hung kubectl/mongosh exec becomes a\n    failed attempt instead of an uncaught TimeoutExpired that would crash the\n    whole oracle at its deadline.\"\"\"\n    try:\n        return subprocess.run(cmd, text=True, stdout=subprocess.PIPE,\n                              stderr=subprocess.PIPE, timeout=timeout)\n    except subprocess.TimeoutExpired:\n        return subprocess.CompletedProcess(cmd, 124, \"\", \"timed out\")\n\n\n_TLS_FLAGS_CACHE = None\n\n\ndef _mongo_tls_flags(probe_pod=None):\n    \"\"\"mongosh transport flags that adapt to the cluster's LIVE TLS mode.\n\n    The environment PERSISTS across workflow stages, so an earlier stage\n    (mongodb/tls-setup or mongodb/certificate-rotation) may have turned TLS on,\n    after which a plain mongosh connection is refused. Detect TLS by probing the\n    running mongo pod for a CA cert mounted at the paths the TLS stages use; if\n    present, connect with --tls --tlsCAFile (and a client cert for mutual TLS\n    when one is mounted), else connect plain. Standalone (no CA mounted) this\n    returns [] -> identical plain behaviour. It only adds transport flags; every\n    real check still runs and still fails when its condition is unmet.\n    \"\"\"\n    global _TLS_FLAGS_CACHE\n    if _TLS_FLAGS_CACHE is not None:\n        return list(_TLS_FLAGS_CACHE)\n    flags = []\n    pod = probe_pod or f\"{CLUSTER_PREFIX}-0\"\n    ca_path = None\n    for cand in (\n        \"/etc/tls/ca.crt\",\n        \"/etc/mongo-ca/ca.crt\",\n        \"/etc/mongodb/tls/ca.crt\",\n        \"/etc/ssl/mongodb/ca.crt\",\n    ):\n        probe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + cand])\n        if probe.returncode == 0:\n            ca_path = cand\n            break\n    if ca_path:\n        flags = [\"--tls\", \"--tlsAllowInvalidHostnames\", \"--tlsAllowInvalidCertificates\", \"--tlsCAFile\", ca_path]\n        for client_pem in (\"/etc/tls/client.pem\", \"/etc/mongo-ca/client.pem\"):\n            cprobe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + client_pem])\n            if cprobe.returncode == 0:\n                flags += [\"--tlsCertificateKeyFile\", client_pem]\n                break\n    _TLS_FLAGS_CACHE = flags\n    return list(flags)\n\ndef fail(prefix, errors):\n    if errors:\n        print(prefix, file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n    return 0\n\n\ndef get_secret(secret_name, errors):\n    res = run([\n        \"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", secret_name, \"-o\", \"jsonpath={.data.password}\"\n    ])\n    if res.returncode != 0:\n        errors.append(f\"Failed to read secret {secret_name}: {res.stderr.strip() or res.stdout.strip()}\")\n        return None\n    try:\n        return base64.b64decode((res.stdout or \"\").strip()).decode(\"utf-8\")\n    except Exception:\n        errors.append(f\"Failed to decode secret {secret_name}.password\")\n        return None\n\n\ndef _exec_mongo(pod, uri, eval_str):\n    return run([\n        \"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"mongosh\", \"--quiet\", *_mongo_tls_flags(), uri, \"--eval\", eval_str\n    ])\n\n\n_PRIMARY_POD_CACHE = None\n\n\ndef find_primary(uri):\n    \"\"\"Locate the replica-set PRIMARY pod, falling back to POD.\n\n    The environment PERSISTS across workflow stages, so an earlier stage (e.g.\n    mongodb/arbiters) can trigger an election that moves the PRIMARY off\n    ``{CLUSTER_PREFIX}-0``. getRole/getUser lookups and reads/writes here\n    require the primary -- on a secondary they fail with \"not primary and\n    secondaryOk=false\". Exec db.hello() into each member, parse the\n    writable-primary node, and route subsequent mongosh exec there. Standalone\n    (single node) this resolves to POD -> identical behaviour; no check or\n    expected value changes.\n    \"\"\"\n    global _PRIMARY_POD_CACHE\n    if _PRIMARY_POD_CACHE is not None:\n        return _PRIMARY_POD_CACHE\n    for idx in range(9):\n        pod = f\"{CLUSTER_PREFIX}-{idx}\"\n        res = _exec_mongo(pod, uri, \"db.hello().isWritablePrimary\")\n        if res.returncode != 0:\n            if idx > 0 and \"NotFound\" in (res.stderr or \"\"):\n                break\n            continue\n        if \"true\" in (res.stdout or \"\"):\n            _PRIMARY_POD_CACHE = pod\n            return pod\n    return POD\n\n\ndef run_mongo(uri, eval_str):\n    # Route every read/write to the PRIMARY so a workflow election off\n    # replica-0 does not surface as \"not primary\"/missing-role failures.\n    return _exec_mongo(find_primary(uri), uri, eval_str)\n\n\ndef load_json(uri, eval_str, label, errors):\n    res = run_mongo(uri, eval_str)\n    if res.returncode != 0:\n        errors.append(f\"{label} failed: {res.stderr.strip() or res.stdout.strip()}\")\n        return None\n    raw = (res.stdout or \"\").strip()\n    if not raw:\n        errors.append(f\"{label} returned empty output\")\n        return None\n    try:\n        return json.loads(raw)\n    except json.JSONDecodeError:\n        errors.append(f\"Unable to parse {label} JSON output\")\n        return None\n\n\ndef role_has_reports_privileges(role):\n    for priv in role.get(\"privileges\", []):\n        resource = priv.get(\"resource\", {})\n        if resource.get(\"db\") != APP_DB or resource.get(\"collection\") != REPORTS_COLLECTION:\n            continue\n        actions = set(priv.get(\"actions\", []))\n        if \"find\" in actions:\n            return True\n    return False\n\n\ndef role_touches_raw(role):\n    for priv in role.get(\"privileges\", []):\n        resource = priv.get(\"resource\", {})\n        if resource.get(\"db\") == APP_DB and resource.get(\"collection\") == RAW_COLLECTION:\n            return True\n    return False\n\n\ndef user_has_role(user, role_name, role_db=None):\n    for role in user.get(\"roles\", []):\n        if role.get(\"role\") != role_name:\n            continue\n        if role_db is None or role.get(\"db\") == role_db:\n            return True\n    return False\n\n\ndef credentials(errors):\n    admin_pw = get_secret(ADMIN_SECRET, errors)\n    reporting_pw = get_secret(REPORTING_SECRET, errors)\n    if errors:\n        return None\n    return {\n        # directConnection skips SDAM topology monitoring (via find_primary's\n        # db.hello), which a localhost connection would start and which fails\n        # under a persisted requireTLS mode.\n        \"admin_uri\": f\"mongodb://{ADMIN_USER}:{admin_pw}@localhost:27017/admin?directConnection=true\",\n        \"reporting_uri\": f\"mongodb://{REPORTING_USER}:{reporting_pw}@localhost:27017/{APP_DB}?authSource=admin&directConnection=true\",\n    }\n\n\ndef check_role():\n    errors = []\n    c = credentials(errors)\n    if c is None:\n        return fail(\"Custom roles role check failed:\", errors)\n\n    # Name-agnostic: the prompt asks to \"restore the minimum access needed for\n    # reporting dashboards\" without dictating a role name, so the agent is free to\n    # name the restored role anything (e.g. reportsRead). Inspect the roles the\n    # reporting-user ACTUALLY holds rather than a hardcoded REPORTING_ROLE name:\n    # at least one held role must grant find on reports, and NO held role may\n    # carry any privilege on raw. check_access independently proves the effective\n    # read/deny behaviour, so the security bar is unchanged -- only the unstated\n    # exact-name requirement is dropped.\n    user = load_json(c[\"admin_uri\"], f'JSON.stringify(db.getUser(\"{REPORTING_USER}\"))', REPORTING_USER, errors)\n    if not isinstance(user, dict):\n        return fail(\"Custom roles role check failed:\", errors)\n\n    grants_reports = False\n    for r in user.get(\"roles\", []):\n        rname, rdb = r.get(\"role\"), r.get(\"db\")\n        if not rname or not rdb:\n            continue\n        role = load_json(\n            c[\"admin_uri\"],\n            f'JSON.stringify(db.getSiblingDB(\"{rdb}\").getRole(\"{rname}\",{{showPrivileges:true}}))',\n            f\"{rname} ({rdb})\",\n            [],\n        )\n        if not isinstance(role, dict):\n            continue\n        if role_has_reports_privileges(role):\n            grants_reports = True\n        if role_touches_raw(role):\n            errors.append(f\"role {rname} held by {REPORTING_USER} must not grant access to {APP_DB}.{RAW_COLLECTION}\")\n\n    if not grants_reports:\n        errors.append(f\"{REPORTING_USER} has no role granting find on {APP_DB}.{REPORTS_COLLECTION}\")\n\n    return fail(\"Custom roles role check failed:\", errors)\n\n\ndef check_bindings():\n    errors = []\n    c = credentials(errors)\n    if c is None:\n        return fail(\"Custom roles bindings check failed:\", errors)\n\n    user = load_json(c[\"admin_uri\"], f'JSON.stringify(db.getUser(\"{REPORTING_USER}\"))', REPORTING_USER, errors)\n    if isinstance(user, dict):\n        # The deprecated over-permissive role must be removed...\n        if user_has_role(user, BAD_ROLE, APP_DB):\n            errors.append(f\"{REPORTING_USER} still has deprecated role {BAD_ROLE}\")\n        # ...and the user must hold some replacement role (name-agnostic: the\n        # agent chooses the name; check_role validates that role's privileges).\n        replacement = [\n            r for r in user.get(\"roles\", [])\n            if not (r.get(\"role\") == BAD_ROLE and r.get(\"db\") == APP_DB)\n        ]\n        if not replacement:\n            errors.append(f\"{REPORTING_USER} has no replacement role granting reporting access\")\n\n    return fail(\"Custom roles bindings check failed:\", errors)\n\n\ndef check_access():\n    errors = []\n    c = credentials(errors)\n    if c is None:\n        return fail(\"Custom roles access check failed:\", errors)\n\n    reports_read = run_mongo(c[\"reporting_uri\"], f'db.{REPORTS_COLLECTION}.findOne({{}})')\n    if reports_read.returncode != 0:\n        errors.append(f\"{REPORTING_USER} read on reports failed: {reports_read.stderr.strip() or reports_read.stdout.strip()}\")\n\n    reports_agg = run_mongo(c[\"reporting_uri\"], f'db.{REPORTS_COLLECTION}.aggregate([{{$match:{{}}}}]).toArray().length')\n    if reports_agg.returncode != 0:\n        errors.append(f\"{REPORTING_USER} aggregate on reports failed: {reports_agg.stderr.strip() or reports_agg.stdout.strip()}\")\n\n    raw_read = run_mongo(c[\"reporting_uri\"], f'db.{RAW_COLLECTION}.findOne({{}})')\n    raw_combined = (raw_read.stdout + raw_read.stderr).lower()\n    if raw_read.returncode == 0 and \"not authorized\" not in raw_combined:\n        errors.append(f\"{REPORTING_USER} can read {RAW_COLLECTION} unexpectedly\")\n\n    reports_write = run_mongo(c[\"reporting_uri\"], f'db.{REPORTS_COLLECTION}.insertOne({{bad:\"write\"}})')\n    write_combined = (reports_write.stdout + reports_write.stderr).lower()\n    if reports_write.returncode == 0 and \"not authorized\" not in write_combined:\n        errors.append(f\"{REPORTING_USER} can write {REPORTS_COLLECTION} unexpectedly\")\n\n    return fail(\"Custom roles access check failed:\", errors)\n\n\ndef main():\n    parser = argparse.ArgumentParser()\n    parser.add_argument(\"--check\", default=\"all\", choices=[\"all\", \"role\", \"bindings\", \"access\"])\n    args = parser.parse_args()\n\n    if args.check == \"role\":\n        return check_role()\n    if args.check == \"bindings\":\n        return check_bindings()\n    if args.check == \"access\":\n        return check_access()\n\n    for fn in (check_role, check_bindings, check_access):\n        rc = fn()\n        if rc != 0:\n            return rc\n    print(\"Custom roles verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":314,"startLine":1,"totalLines":314}}}
