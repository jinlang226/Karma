{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01AsoUofQz63tWSjRkUwtP5A","type":"tool_result","content":"1\t# mongodb/arbiters\n2\t# MongoDB operator-add-arbiters task\n3\t\n4\tparams:\n5\t  data_cluster_prefix:\n6\t    default: mongo-rs\n7\t    description: StatefulSet name of the data-bearing replica set members.\n8\t  replica_set_name:\n9\t    default: rs0\n10\t    description: MongoDB replica set _id used when initiating the set.\n11\t  app_database:\n12\t    default: app\n13\t    description: Application database that must remain intact.\n14\t  app_collection:\n15\t    default: test\n16\t    description: Application collection seeded with data.\n17\t\n18\tprompt: |\n19\t  The MongoDB replica set has two data-bearing members and a running arbiter pod.\n20\t  Elections are unstable unless you add a voting member without increasing storage cost.\n21\t\n22\t  Task:\n23\t  - Stabilize elections without adding a data-bearing member.\n24\t  - Data in the app database must remain intact.\n25\t\n26\tnamespace_contract:\n27\t  required_roles: []\n28\t\n29\tmetrics:\n30\t  - time_to_first_mutation\n31\t\n32\tpreconditionUnits:\n33\t  - name: mongo_env_ready\n34\t    on_probe_fail: skip\n35\t    probe:\n36\t      - command: \"kubectl -n mongodb get pod {{params.data_cluster_prefix}}-0 2>/dev/null | grep -c Running\"\n37\t        timeout_sec: 10\n38\t    apply:\n39\t      - command: |\n40\t          /bin/sh -c '\n41\t          kubectl delete namespace mongodb --ignore-not-found=true; kubectl wait --for=delete namespace/mongodb --timeout=120s || true\n42\t          '\n43\t        sleep: 2\n44\t      - command: \"kubectl create namespace mongodb\"\n45\t        sleep: 1\n46\t      - command: \"kubectl -n mongodb apply -f cases/mongodb/arbiters/resource/services.yaml\"\n47\t        sleep: 2\n48\t      - command: \"kubectl -n mongodb apply -f cases/mongodb/arbiters/resource/statefulset-data.yaml\"\n49\t        sleep: 5\n50\t      - command: \"kubectl -n mongodb apply -f cases/mongodb/arbiters/resource/statefulset-arbiter.yaml\"\n51\t        sleep: 5\n52\t      - command: |\n53\t          for i in $(seq 1 60); do\n54\t            ready=$(kubectl -n mongodb get sts {{params.data_cluster_prefix}} -o jsonpath='{.status.readyReplicas}' 2>/dev/null)\n55\t            if [ \"${ready:-0}\" -ge 2 ]; then\n56\t              exit 0\n57\t            fi\n58\t            sleep 5\n59\t          done\n60\t          exit 1\n61\t        sleep: 5\n62\t      - command: \"kubectl -n mongodb wait --for=condition=ready pod -l app=mongo-arb --timeout=300s\"\n63\t        sleep: 5\n64\t      # Pod-Ready != mongod accepting TCP (§1.10): ping-until-ok before rs.initiate.\n65\t      - command: |\n66\t          for i in $(seq 1 30); do\n67\t            kubectl -n mongodb exec mongo-rs-0 -- mongosh --quiet --eval 'db.runCommand({ping:1}).ok' 2>/dev/null | grep -q 1 && exit 0\n68\t            sleep 3\n69\t          done\n70\t          exit 1\n71\t        sleep: 2\n72\t      - command: |\n73\t          kubectl -n mongodb exec mongo-rs-0 -- mongosh --quiet --eval '\n74\t          rs.initiate({_id:\"{{params.replica_set_name}}\",members:[\n75\t            {_id:0,host:\"mongo-rs-0.mongo.mongodb.svc.cluster.local:27017\"},\n76\t            {_id:1,host:\"mongo-rs-1.mongo.mongodb.svc.cluster.local:27017\"}\n77\t          ]})'\n78\t        sleep: 5\n79\t      - command: |\n80\t          for i in $(seq 1 20); do\n81\t            kubectl -n mongodb exec mongo-rs-0 -- mongosh --quiet --eval 'db.hello().isWritablePrimary' | grep true && exit 0\n82\t            sleep 3\n83\t          done\n84\t          exit 1\n85\t        sleep: 2\n86\t      - command: \"kubectl -n mongodb exec mongo-rs-0 -- mongosh --quiet --eval 'db.getSiblingDB(\\\"{{params.app_database}}\\\").{{params.app_collection}}.insertMany([{x:1},{x:2},{x:3}], {writeConcern:{w:1}}); db.getSiblingDB(\\\"{{params.app_database}}\\\").{{params.app_collection}}.countDocuments({});'\"\n87\t        sleep: 2\n88\t    verify:\n89\t      - command: \"kubectl -n mongodb get pods 2>/dev/null | grep -c Running\"\n90\t        timeout_sec: 10\n91\t\n92\t  # Additive data fixture (composition safety): the oracle requires >= 3 docs in\n93\t  # {{params.app_database}}.{{params.app_collection}}. When this case runs chained on an inherited cluster the\n94\t  # destructive `apply` above is skipped, so a prior stage may have left the\n95\t  # collection short. This unit tops it up ADDITIVELY to the required count WITHOUT\n96\t  # dropping/recreating the collection or touching the namespace/cluster.\n97\t  # The probe gates on the DATA COUNT (not \"pods Running\"), so it runs\n98\t  # whenever the collection is short; standalone (where `apply` already seeded 3)\n99\t  # it sees the required count and skips -> identical behaviour. Idempotent: inserts\n100\t  # only the deficit (required - current).\n101\t  - name: mongo_seed_fixture\n102\t    on_probe_fail: skip\n103\t    probe:\n104\t      # Auth-adaptive: when an inherited cluster has auth enabled the admin secret\n105\t      # exists, so authenticate; otherwise connect plain. Works both ways.\n106\t      - command: |\n107\t          /bin/sh -c 't=\"\"; for cca in /etc/tls/ca.crt /etc/mongo-ca/ca.crt; do kubectl -n mongodb exec mongo-rs-0 -- ls $cca >/dev/null 2>&1 && { t=\"--tls --tlsAllowInvalidHostnames --tlsAllowInvalidCertificates --tlsCAFile $cca\"; break; }; done; au=\"\"; pw=$(kubectl -n mongodb get secret admin-user-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); [ -n \"$pw\" ] && au=\"-u admin-user -p $pw --authenticationDatabase admin\"; n=$(P=\"\"; for _pi in $(seq 1 30); do P=$(kubectl -n mongodb exec mongo-rs-0 -- mongosh --quiet $t $au --eval '\\''rs.hello().primary'\\'' 2>/dev/null | cut -d. -f1); [ -n \"$P\" ] && break; sleep 2; done; P=${P:-mongo-rs-0}; kubectl -n mongodb exec \"$P\" -- mongosh --quiet $t $au --eval '\\''db.getSiblingDB(\"{{params.app_database}}\").{{params.app_collection}}.countDocuments({})'\\'' 2>/dev/null | tr -dc 0-9); [ \"${n:-0}\" -ge 3 ] && echo ok | grep -c ok'\n108\t        timeout_sec: 30\n109\t    apply:\n110\t      - command: |\n111\t          /bin/sh -c 'au=\"\"; pw=$(kubectl -n mongodb get secret admin-user-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); [ -n \"$pw\" ] && au=\"-u admin-user -p $pw --authenticationDatabase admin\"; P=\"\"; for _pi in $(seq 1 30); do P=$(kubectl -n mongodb exec mongo-rs-0 -- mongosh --quiet $au --eval '\\''rs.hello().primary'\\'' 2>/dev/null | cut -d. -f1); [ -n \"$P\" ] && break; sleep 2; done; P=${P:-mongo-rs-0}; kubectl -n mongodb exec \"$P\" -- mongosh --quiet $au --eval '\\''var c=db.getSiblingDB(\"{{params.app_database}}\").{{params.app_collection}}; var need=3-c.countDocuments({}); var docs=[]; for(var i=0;i<need;i++){docs.push({seed:\"fixture\",ts:new Date()});} if(docs.length>0){c.insertMany(docs,{writeConcern:{w:1}});}'\\'''\n112\t        sleep: 2\n113\t    verify:\n114\t      - command: |\n115\t          /bin/sh -c 't=\"\"; for cca in /etc/tls/ca.crt /etc/mongo-ca/ca.crt; do kubectl -n mongodb exec mongo-rs-0 -- ls $cca >/dev/null 2>&1 && { t=\"--tls --tlsAllowInvalidHostnames --tlsAllowInvalidCertificates --tlsCAFile $cca\"; break; }; done; au=\"\"; pw=$(kubectl -n mongodb get secret admin-user-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); [ -n \"$pw\" ] && au=\"-u admin-user -p $pw --authenticationDatabase admin\"; n=$(P=\"\"; for _pi in $(seq 1 30); do P=$(kubectl -n mongodb exec mongo-rs-0 -- mongosh --quiet $t $au --eval '\\''rs.hello().primary'\\'' 2>/dev/null | cut -d. -f1); [ -n \"$P\" ] && break; sleep 2; done; P=${P:-mongo-rs-0}; kubectl -n mongodb exec \"$P\" -- mongosh --quiet $t $au --eval '\\''db.getSiblingDB(\"{{params.app_database}}\").{{params.app_collection}}.countDocuments({})'\\'' 2>/dev/null | tr -dc 0-9); [ \"${n:-0}\" -ge 3 ]'\n116\t        timeout_sec: 30\n117\t\n118\toracle:\n119