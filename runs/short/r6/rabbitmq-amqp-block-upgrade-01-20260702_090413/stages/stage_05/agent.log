t right now.","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":193,"cache_read_input_tokens":75336,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":193},"output_tokens":22,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":{"cache_miss_reason":{"type":"unavailable"}},"context_management":null},"parent_tool_use_id":null,"session_id":"17fe7a5a-65fd-4eea-8779-ad7313d51734","uuid":"582a6914-1707-4fd7-a71d-39b1315a3e3d","request_id":"req_011Ccd1U87j8JMRqQ3aX6jSi"}
