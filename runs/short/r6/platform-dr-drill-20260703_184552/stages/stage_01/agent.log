{"type":"assistant","message":{"model":"claude-sonnet-4-6","id":"msg_011b9Zjvrg4GDGBh9Chk2e7o","type":"message","role":"assistant","content":[{"type":"tool_use","id":"toolu_01EEQhCdf6YaUKMhbpjxHaDP","name":"Bash","input":{"command":"kubectl apply -f - <<'EOF'\napiVersion: v1\nkind: Service\nmetadata:\n  name: crdb-cluster\n  namespace: cockroachdb\n  labels:\n    app.kubernetes.io/name: cockroachdb\n    app.kubernetes.io/instance: crdb-cluster\nspec:\n  clusterIP: None\n  publishNotReadyAddresses: true\n  selector:\n    app.kubernetes.io/name: cockroachdb\n    app.kubernetes.io/instance: crdb-cluster\n  ports:\n    - name: grpc\n      port: 26257\n      targetPort: 26257\n    - name: http\n      port: 8080\n      targetPort: 8080\n---\napiVersion: v1\nkind: Service\nmetadata:\n  name: crdb-cluster-public\n  namespace: cockroachdb\n  labels:\n    app.kubernetes.io/name: cockroachdb\n    app.kubernetes.io/instance: crdb-cluster\nspec:\n  selector:\n    app.kubernetes.io/name: cockroachdb\n    app.kubernetes.io/instance: crdb-cluster\n  ports:\n    - name: grpc\n      port: 26257\n      targetPort: 26257\n    - name: http\n      port: 8080\n      targetPort: 8080\n---\napiVersion: apps/v1\nkind: StatefulSet\nmetadata:\n  name: crdb-cluster\n  namespace: cockroachdb\n  labels:\n    app.kubernetes.io/name: cockroachdb\n    app.kubernetes.io/instance: crdb-cluster\nspec:\n  serviceName: crdb-cluster\n  replicas: 3\n  selector:\n    matchLabels:\n      app.kubernetes.io/name: cockroachdb\n      app.kubernetes.io/instance: crdb-cluster\n  template:\n    metadata:\n      labels:\n        app.kubernetes.io/name: cockroachdb\n        app.kubernetes.io/instance: crdb-cluster\n    spec:\n      serviceAccountName: crdb-cluster-sa\n      terminationGracePeriodSeconds: 60\n      containers:\n        - name: cockroachdb\n          image: cockroachdb/cockroach:v24.1.0\n          imagePullPolicy: IfNotPresent\n          ports:\n            - name: grpc\n              containerPort: 26257\n            - name: http\n              containerPort: 8080\n          command:\n            - /bin/bash\n            - -ecx\n            - |\n              exec /cockroach/cockroach start \\\n                --insecure \\\n                --advertise-addr=$(hostname -f) \\\n                --http-addr=0.0.0.0:8080 \\\n                --listen-addr=0.0.0.0:26257 \\\n                --join=crdb-cluster-0.crdb-cluster.cockroachdb.svc.cluster.local:26257,crdb-cluster-1.crdb-cluster.cockroachdb.svc.cluster.local:26257,crdb-cluster-2.crdb-cluster.cockroachdb.svc.cluster.local:26257 \\\n                --cache=25% \\\n                --max-sql-memory=25% \\\n                --logtostderr\n          env:\n            - name: COCKROACH_CHANNEL\n              value: kubernetes-insecure\n          livenessProbe:\n            httpGet:\n              path: /health\n              port: http\n              scheme: HTTP\n            initialDelaySeconds: 30\n            periodSeconds: 5\n          readinessProbe:\n            httpGet:\n              path: /health?ready=1\n              port: http\n              scheme: HTTP\n            initialDelaySeconds: 10\n            periodSeconds: 5\n            failureThreshold: 2\n          volumeMounts:\n            - name: datadir\n              mountPath: /cockroach/cockroach-data\n  volumeClaimTemplates:\n    - metadata:\n        name: datadir\n      spec:\n        accessModes: [\"ReadWriteOnce\"]\n        resources:\n          requests:\n            storage: 10Gi\n---\napiVersion: policy/v1\nkind: PodDisruptionBudget\nmetadata:\n  name: crdb-cluster-pdb\n  namespace: cockroachdb\nspec:\n  minAvailable: 2\n  selector:\n    matchLabels:\n      app.kubernetes.io/name: cockroachdb\n      app.kubernetes.io/instance: crdb-cluster\nEOF","description":"Deploy CockroachDB headless service, public service, StatefulSet, and PodDisruptionBudget"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage"