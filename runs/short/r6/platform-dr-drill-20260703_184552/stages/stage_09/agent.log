{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013Ub6PapabaRuAPquSzFidu","type":"tool_result","content":"1\tapiVersion: apps/v1\n2\tkind: StatefulSet\n3\tmetadata:\n4\t  name: es-cluster\n5\t  namespace: elasticsearch\n6\tspec:\n7\t  serviceName: es-cluster\n8\t  podManagementPolicy: Parallel\n9\t  replicas: 3\n10\t  selector:\n11\t    matchLabels:\n12\t      app: es-cluster\n13\t  template:\n14\t    metadata:\n15\t      labels:\n16\t        app: es-cluster\n17\t    spec:\n18\t      containers:\n19\t        - name: elasticsearch\n20\t          image: docker.elastic.co/elasticsearch/elasticsearch:7.17.9\n21\t          env:\n22\t            - name: POD_NAME\n23\t              valueFrom:\n24\t                fieldRef:\n25\t                  fieldPath: metadata.name\n26\t            - name: ES_JAVA_OPTS\n27\t              value: \"-Xms512m -Xmx512m\"\n28\t          ports:\n29\t            - containerPort: 9200\n30\t              name: http\n31\t            - containerPort: 9300\n32\t              name: transport\n33\t          readinessProbe:\n34\t            tcpSocket:\n35\t              port: 9200\n36\t            initialDelaySeconds: 10\n37\t            periodSeconds: 5\n38\t            timeoutSeconds: 1\n39\t            failureThreshold: 6\n40\t          volumeMounts:\n41\t            - name: es-config\n42\t              mountPath: /usr/share/elasticsearch/config/elasticsearch.yml\n43\t              subPath: elasticsearch.yml\n44\t            - name: data\n45\t              mountPath: /usr/share/elasticsearch/data\n46\t          resources:\n47\t            requests:\n48\t              cpu: \"500m\"\n49\t              memory: \"1Gi\"\n50\t            limits:\n51\t              cpu: \"1\"\n52\t              memory: \"2Gi\"\n53\t      volumes:\n54\t        - name: es-config\n55\t          configMap:\n56\t            name: es-config\n57\t            items:\n58\t              - key: elasticsearch.yml\n59\t                path: elasticsearch.yml\n60\t  volumeClaimTemplates:\n61\t    - metadata:\n62\t        name: data\n63\t      spec:\n64\t        accessModes: [\"ReadWriteOnce\"]\n65\t        resources:\n66\t          requests:\n67\t            storage: 5Gi\n68\t---\n69\tapiVersion: apps/v1\n70\tkind: StatefulSet\n71\tmetadata:\n72\t  name: es-transform\n73\t  namespace: elasticsearch\n74\tspec:\n75\t  serviceName: es-transform\n76\t  podManagementPolicy: Parallel\n77\t  replicas: 1\n78\t  selector:\n79\t    matchLabels:\n80\t      app: es-transform\n81\t  template:\n82\t    metadata:\n83\t      labels:\n84\t        app: es-transform\n85\t    spec:\n86\t      containers:\n87\t        - name: elasticsearch\n88\t          image: docker.elastic.co/elasticsearch/elasticsearch:7.17.9\n89\t          env:\n90\t            - name: POD_NAME\n91\t              valueFrom:\n92\t                fieldRef:\n93\t                  fieldPath: metadata.name\n94\t            - name: ES_JAVA_OPTS\n95\t              value: \"-Xms512m -Xmx512m\"\n96\t          ports:\n97\t            - containerPort: 9200\n98\t              name: http\n99\t            - containerPort: 9300\n100\t              name: transport\n101\t          readinessProbe:\n102\t            tcpSocket:\n103\t              port: 9200\n104\t            initialDelaySeconds: 10\n105\t            periodSeconds: 5\n106\t            timeoutSeconds: 1\n107\t            failureThreshold: 6\n108\t          volumeMounts:\n109\t            - name: es-transform-config\n110\t              mountPath: /usr/share/elasticsearch/config/elasticsearch.yml\n111\t              subPath: elasticsearch.yml\n112\t            - name: data\n113\t              mountPath: /usr/share/elasticsearch/data\n114\t          resources:\n115\t            requests:\n116\t              cpu: \"500m\"\n117\t              memory: \"1Gi\"\n118\t            limits:\n119\t              cpu: \"1\"\n120\t              memory: \"2Gi\"\n121\t      volumes:\n122\t        - name: es-transform-config\n123\t          configMap:\n124\t            name: es-transform-config\n125\t            items:\n126\t              - key: elasticsearch.yml\n127\t                path: elasticsearch.yml\n128\t        - name: data\n129\t          emptyDir: {}\n130\t"}]},"parent_tool_use_id":null,"session_id":"995aec0d-ad7a-483c-a188-f7ca871b7a1a","uuid":"f4c69790-65cd-43e4-9e15-306157cbdf4e","timestamp":"2026-07-03T20:10:23.451Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/elasticsearch/transform-job-recovery/resource/statefulset.yaml","content":"apiVersion: apps/v1\nkind: StatefulSet\nmetadata:\n  name: es-cluster\n  namespace: elasticsearch\nspec:\n  serviceName: es-cluster\n  podManagementPolicy: Parallel\n  replicas: 3\n  selector:\n    matchLabels:\n      app: es-cluster\n  template:\n    metadata:\n      labels:\n        app: es-cluster\n    spec:\n      containers:\n        - name: elasticsearch\n          image: docker.elastic.co/elasticsearch/elasticsearch:7.17.9\n          env:\n            - name: POD_NAME\n              valueFrom:\n                fieldRef:\n                  fieldPath: metadata.name\n            - name: ES_JAVA_OPTS\n              value: \"-Xms512m -Xmx512m\"\n          ports:\n            - containerPort: 9200\n              name: http\n            - containerPort: 9300\n              name: transport\n          readinessProbe:\n            tcpSocket:\n              port: 9200\n            initialDelaySeconds: 10\n            periodSeconds: 5\n            timeoutSeconds: 1\n            failureThreshold: 6\n          volumeMounts:\n            - name: es-config\n              mountPath: /usr/share/elasticsearch/config/elasticsearch.yml\n              subPath: elasticsearch.yml\n            - name: data\n              mountPath: /usr/share/elasticsearch/data\n          resources:\n            requests:\n              cpu: \"500m\"\n              memory: \"1Gi\"\n            limits:\n              cpu: \"1\"\n              memory: \"2Gi\"\n      volumes:\n        - name: es-config\n          configMap:\n            name: es-config\n            items:\n              - key: elasticsearch.yml\n                path: elasticsearch.yml\n  volumeClaimTemplates:\n    - metadata:\n        name: data\n      spec:\n        accessModes: [\"ReadWriteOnce\"]\n        resources:\n          requests:\n            storage: 5Gi\n---\napiVersion: apps/v1\nkind: StatefulSet\nmetadata:\n  name: es-transform\n  namespace: elasticsearch\nspec:\n  serviceName: es-transform\n  podManagementPolicy: Parallel\n  replicas: 1\n  selector:\n    matchLabels:\n      app: es-transform\n  template:\n    metadata:\n      labels:\n        app: es-transform\n    spec:\n      containers:\n        - name: elasticsearch\n          image: docker.elastic.co/elasticsearch/elasticsearch:7.17.9\n          env:\n            - name: POD_NAME\n              valueFrom:\n                fieldRef:\n                  fieldPath: metadata.name\n            - name: ES_JAVA_OPTS\n              value: \"-Xms512m -Xmx512m\"\n          ports:\n            - containerPort: 9200\n              name: http\n            - containerPort: 9300\n              name: transport\n          readinessProbe:\n            tcpSocket:\n              port: 9200\n            initialDelaySeconds: 10\n            periodSeconds: 5\n            timeoutSeconds: 1\n            failureThreshold: 6\n          volumeMounts:\n            - name: es-transform-config\n              mountPath: /usr/share/elasticsearch/config/elasticsearch.yml\n              subPath: elasticsearch.yml\n            - name: data\n              mountPath: /usr/share/elasticsearch/data\n          resources:\n            requests:\n              cpu: \"500m\"\n              memory: \"1Gi\"\n            limits:\n              cpu: \"1\"\n              memory: \"2Gi\"\n      volumes:\n        - name: es-transform-config\n          configMap:\n            name: es-transform-config\n            items:\n              - key: elasticsearch.yml\n                path: elasticsearch.yml\n        - name: data\n          emptyDir: {}\n","numLines":130,"startLine":1,"totalLines":130}}}
{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QJhwPAomdqch3DVApBW5XN","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport json\n3\timport os\n4\timport subprocess\n5\timport sys\n6\t\n7\tNAMESPACE = \"elasticsearch\"\n8\tSERVICE = \"es-http\"\n9\tCURL_POD = \"curl-test\"\n10\tTRANSFORM_ID = \"events-by-service\"\n11\tCHECKPOINT_CM = \"transform-checkpoint\"\n12\tDEST_INDEX = \"app-events-rollup\"\n13\t# ES 8.x runs with security enabled, so the HTTP API requires authenticating as\n14\t# the elastic superuser. When this case inherits a secured cluster from an\n15\t# earlier workflow stage, read its password from the secret that stage created\n16\t# so the oracle's queries aren't rejected with 401. Absent secret -> None -> no\n17\t# -u, so a standalone unsecured cluster still works.\n18\tPASSWORD_SECRET = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_SECRET_NAME\", \"elastic-password\")\n19\tPASSWORD_KEY = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_KEY\", \"password\")\n20\tDEFAULT_SCHEME = \"http\"\n21\t_SCHEME = None\n22\t\n23\t\n24\tdef run(cmd):\n25\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n26\t\n27\t\n28\tdef _elastic_password():\n29\t    \"\"\"Fetch the elastic-user password from its secret (base64-decoded), or None.\"\"\"\n30\t    import base64\n31\t    r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", PASSWORD_SECRET,\n32\t             \"-o\", \"jsonpath={.data.\" + PASSWORD_KEY + \"}\"])\n33\t    if r.returncode != 0 or not r.stdout.strip():\n34\t        return None\n35\t    try:\n36\t        return base64.b64decode(r.stdout.strip()).decode()\n37\t    except Exception:\n38\t        return None\n39\t\n40\t\n41\tdef _password_from_sts():\n42\t    \"\"\"Fall back to a live ES StatefulSet's ELASTIC_PASSWORD env when the\n43\t    elastic-password secret is absent (skip-gated on an inherited cluster), so\n44\t    the oracle authenticates instead of 401-ing (C1). Reads the literal env\n45\t    value, or resolves its secretKeyRef; returns the password or None.\"\"\"\n46\t    import base64\n47\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n48\t    if res.returncode != 0:\n49\t        return None\n50\t    try:\n51\t        items = json.loads(res.stdout).get(\"items\", [])\n52\t    except (json.JSONDecodeError, AttributeError):\n53\t        return None\n54\t    for sts in items:\n55\t        spec = sts.get(\"spec\", {}) or {}\n56\t        containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", []) or []\n57\t        if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n58\t            continue\n59\t        for c in containers:\n60\t            for e in c.get(\"env\", []) or []:\n61\t                if e.get(\"name\") != \"ELASTIC_PASSWORD\":\n62\t                    continue\n63\t                if e.get(\"value\"):\n64\t                    return e[\"value\"]\n65\t                ref = (e.get(\"valueFrom\", {}) or {}).get(\"secretKeyRef\", {}) or {}\n66\t                name = ref.get(\"name\")\n67\t                if name:\n68\t                    rs = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", name,\n69\t                              \"-o\", \"jsonpath={.data.\" + (ref.get(\"key\") or \"password\") + \"}\"])\n70\t                    if rs.returncode == 0 and rs.stdout.strip():\n71\t                        try:\n72\t                            return base64.b64decode(rs.stdout.strip()).decode()\n73\t                        except Exception:\n74\t                            pass\n75\t    return None\n76\t\n77\t\n78\tELASTIC_PASSWORD = None  # set in main() once kubectl is reachable\n79\t\n80\t\n81\tdef _probe_scheme(scheme):\n82\t    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\n83\t\n84\t    The env PERSISTS across stages, so the cluster's live scheme may differ\n85\t    from this case's default; a 401 still proves the scheme is reachable.\n86\t    \"\"\"\n87\t    result = run([\n88\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", CURL_POD, \"--\",\n89\t        \"curl\", \"-s\", \"-S\", \"-k\", \"-o\", \"/dev/null\",\n90\t        \"-w\", \"%{http_code}\", \"--max-time\", \"5\",\n91\t        f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200/\",\n92\t    ])\n93\t    code = (result.stdout or \"\").strip()\n94\t    return result.returncode == 0 and code.isdigit() and code != \"000\"\n95\t\n96\t\n97\tdef detect_scheme():\n98\t    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n99\t    global _SCHEME\n100\t    if _SCHEME is not None:\n101\t        return _SCHEME\n102\t    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n103\t        if _probe_scheme(scheme):\n104\t            _SCHEME = scheme\n105\t            return _SCHEME\n106\t    _SCHEME = DEFAULT_SCHEME\n107\t    return _SCHEME\n108\t\n109\t\n110\tdef curl_json(path, errors):\n111\t    scheme = detect_scheme()\n112\t    result = run(\n113\t        [\n114\t            \"kubectl\",\n115\t            \"-n\",\n116\t            NAMESPACE,\n117\t            \"exec\",\n118\t            CURL_POD,\n119\t            \"--\",\n120\t            \"curl\",\n121\t            \"-s\",\n122\t            \"-S\",\n123\t            \"-k\",\n124\t        ]\n125\t        + ([\"-u\", f\"elastic:{ELASTIC_PASSWORD}\"] if ELASTIC_PASSWORD else [])\n126\t        + [\n127\t            \"--max-time\",\n128\t            \"5\",\n129\t            f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\",\n130\t        ]\n131\t    )\n132\t    if result.returncode != 0:\n133\t        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n134\t        errors.append(f\"Failed to query {path}: {detail}\")\n135\t        return None\n136\t    output = result.stdout.strip()\n137\t    if not output:\n138\t        errors.append(f\"Empty response for {path}\")\n139\t        return None\n140\t    try:\n141\t        return json.loads(output)\n142\t    except json.JSONDecodeError:\n143\t        errors.append(f\"Failed to parse JSON from {path}\")\n144\t        return None\n145\t\n146\t\n147\tdef get_checkpoint_before(errors):\n148\t    result = run(\n149\t        [\n150\t            \"kubectl\",\n151\t            \"-n\",\n152\t            NAMESPACE,\n153\t            \"get\",\n154\t            \"configmap\",\n155\t            CHECKPOINT_CM,\n156\t            \"-o\",\n157\t            \"jsonpath={.data.checkpoint_before}\",\n158\t        ]\n159\t    )\n160\t    if result.returncode != 0:\n161\t        errors.append(\"Unable to read checkpoint_before from configmap\")\n162\t        return None\n163\t    value = (result.stdout or \"\").strip()\n164\t    try:\n165\t        return int(value)\n166\t    except (TypeError, ValueError):\n167\t        errors.append(f\"Invalid checkpoint_before value: {value!r}\")\n168\t        return None\n169\t\n170\t\n171\tdef get_transform(errors):\n172\t    stats = curl_json(f\"/_transform/{TRANSFORM_ID}/_stats\", errors)\n173\t    if not isinstance(stats, dict):\n174\t        return None\n175\t    transforms = stats.get(\"transforms\") or []\n176\t    if not transforms:\n177\t        errors.append(\"Transform stats missing\")\n178\t        return None\n179\t    return transforms[0]\n180\t\n181\t\n182\tdef extract_checkpoint(transform):\n183\t    checkpoint = (\n184\t        transform.get(\"checkpointing\", {})\n185\t        .get(\"last\", {})\n186\t        .get(\"checkpoint\")\n187\t    )\n188\t    if checkpoint is None:\n189\t        checkpoint = (\n190\t            transform.get(\"stats\", {})\n191\t            .get(\"checkpointing\", {})\n192\t            .get(\"last\", {})\n193\t            .get(\"checkpoint\")\n194\t        )\n195\t    return checkpoint\n196\t\n197\t\n198\tdef evaluate(checkpoint_before):\n199\t    \"\"\"Run one full snapshot of the transform-recovery checks; return errors.\"\"\"\n200\t    errors = []\n201\t\n202\t    transform = get_transform(errors)\n203\t    if transform:\n204\t        state = transform.get(\"state\") or transform.get(\"stats\", {}).get(\"state\")\n205\t        if state != \"started\":\n206\t            errors.append(f\"Transform state expected started, got {state}\")\n207\t\n208\t        checkpoint_now = extract_checkpoint(transform)\n209\t        if checkpoint_before is not None:\n210\t            if checkpoint_now is None:\n211\t                errors.append(\"Unable to read current checkpoint\")\n212\t            elif checkpoint_now <= checkpoint_before:\n213\t                errors.append(\n214\t                    f\"Checkpoint did not advance (before={checkpoint_before}, now={checkpoint_now})\"\n215\t                )\n216\t\n217\t    count = curl_json(f\"/{DEST_INDEX}/_count\", errors)\n218\t    if isinstance(count, dict):\n219\t        if count.get(\"count\", 0) <= 0:\n220\t            errors.append(\"Destination index has no documents\")\n221\t\n222\t    return errors\n223\t\n224\t\n225\tdef main():\n226\t    global ELASTIC_PASSWORD\n227\t    ELASTIC_PASSWORD = _elastic_password() or _password_from_sts()\n228\t\n229\t    # After the agent restarts the transform, its next checkpoint and the\n230\t    # destination index's documents only materialize once a transform sync cycle\n231\t    # runs (seconds to a sync interval later), and a curl can flake during that\n232\t    # window. A single immediate snapshot catches the not-yet-advanced state and\n233\t    # falsely reports \"Checkpoint did not advance\" / \"no documents\". So verify the\n234\t    # STABLE converged state: re-evaluate and pass on the first clean snapshot.\n235\t    # The checkpoint_before baseline is read ONCE up front so the advance check\n236\t    # stays strict across retries.\n237\t    # O-deadline: keep the internal deadline strictly below the oracle timeout_sec\n238\t    # (120s in test.yaml) so the harness does not kill the loop before it prints a\n239\t    # verdict; 90s leaves headroom for the final evaluate() + output.\n240\t    import time\n241\t    config_errors = []\n242\t    checkpoint_before = get_checkpoint_before(config_errors)\n243\t    deadline = time.monotonic() + 90\n244\t    live_errors = evaluate(checkpoint_before)\n245\t    while live_errors and time.monotonic() < deadline:\n246\t        time.sleep(8)\n247\t        live_errors = evaluate(checkpoint_before)\n248\t    errors = config_errors + live_errors\n249\t\n250\t    if errors:\n251\t        print(\"Transform recovery verification failed:\", file=sys.stderr)\n252\t        for err in errors:\n253\t            print(f\"  - {err}\", file=sys.stderr)\n254\t        return 1\n255\t\n256\t    print(\"Transform recovery verified\")\n257\t    return 0\n258\t\n259\t\n260\tif __name__ == \"__main__\":\n261\t    sys.exit(main())\n262\t"}]},"parent_tool_use_id":null,"session_id":"995aec0d-ad7a-483c-a188-f7ca871b7a1a","uuid":"fa6763c7-79a3-493e-acf8-0ff78527bfd2","timestamp":"2026-07-03T20:10:23.464Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/elasticsearch/transform-job-recovery/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport json\nimport os\nimport subprocess\nimport sys\n\nNAMESPACE = \"elasticsearch\"\nSERVICE = \"es-http\"\nCURL_POD = \"curl-test\"\nTRANSFORM_ID = \"events-by-service\"\nCHECKPOINT_CM = \"transform-checkpoint\"\nDEST_INDEX = \"app-events-rollup\"\n# ES 8.x runs with security enabled, so the HTTP API requires authenticating as\n# the elastic superuser. When this case inherits a secured cluster from an\n# earlier workflow stage, read its password from the secret that stage created\n# so the oracle's queries aren't rejected with 401. Absent secret -> None -> no\n# -u, so a standalone unsecured cluster still works.\nPASSWORD_SECRET = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_SECRET_NAME\", \"elastic-password\")\nPASSWORD_KEY = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_KEY\", \"password\")\nDEFAULT_SCHEME = \"http\"\n_SCHEME = None\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef _elastic_password():\n    \"\"\"Fetch the elastic-user password from its secret (base64-decoded), or None.\"\"\"\n    import base64\n    r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", PASSWORD_SECRET,\n             \"-o\", \"jsonpath={.data.\" + PASSWORD_KEY + \"}\"])\n    if r.returncode != 0 or not r.stdout.strip():\n        return None\n    try:\n        return base64.b64decode(r.stdout.strip()).decode()\n    except Exception:\n        return None\n\n\ndef _password_from_sts():\n    \"\"\"Fall back to a live ES StatefulSet's ELASTIC_PASSWORD env when the\n    elastic-password secret is absent (skip-gated on an inherited cluster), so\n    the oracle authenticates instead of 401-ing (C1). Reads the literal env\n    value, or resolves its secretKeyRef; returns the password or None.\"\"\"\n    import base64\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n    if res.returncode != 0:\n        return None\n    try:\n        items = json.loads(res.stdout).get(\"items\", [])\n    except (json.JSONDecodeError, AttributeError):\n        return None\n    for sts in items:\n        spec = sts.get(\"spec\", {}) or {}\n        containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", []) or []\n        if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n            continue\n        for c in containers:\n            for e in c.get(\"env\", []) or []:\n                if e.get(\"name\") != \"ELASTIC_PASSWORD\":\n                    continue\n                if e.get(\"value\"):\n                    return e[\"value\"]\n                ref = (e.get(\"valueFrom\", {}) or {}).get(\"secretKeyRef\", {}) or {}\n                name = ref.get(\"name\")\n                if name:\n                    rs = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", name,\n                              \"-o\", \"jsonpath={.data.\" + (ref.get(\"key\") or \"password\") + \"}\"])\n                    if rs.returncode == 0 and rs.stdout.strip():\n                        try:\n                            return base64.b64decode(rs.stdout.strip()).decode()\n                        except Exception:\n                            pass\n    return None\n\n\nELASTIC_PASSWORD = None  # set in main() once kubectl is reachable\n\n\ndef _probe_scheme(scheme):\n    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\n\n    The env PERSISTS across stages, so the cluster's live scheme may differ\n    from this case's default; a 401 still proves the scheme is reachable.\n    \"\"\"\n    result = run([\n        \"kubectl\", \"-n\", NAMESPACE, \"exec\", CURL_POD, \"--\",\n        \"curl\", \"-s\", \"-S\", \"-k\", \"-o\", \"/dev/null\",\n        \"-w\", \"%{http_code}\", \"--max-time\", \"5\",\n        f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200/\",\n    ])\n    code = (result.stdout or \"\").strip()\n    return result.returncode == 0 and code.isdigit() and code != \"000\"\n\n\ndef detect_scheme():\n    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n    global _SCHEME\n    if _SCHEME is not None:\n        return _SCHEME\n    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n        if _probe_scheme(scheme):\n            _SCHEME = scheme\n            return _SCHEME\n    _SCHEME = DEFAULT_SCHEME\n    return _SCHEME\n\n\ndef curl_json(path, errors):\n    scheme = detect_scheme()\n    result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"exec\",\n            CURL_POD,\n            \"--\",\n            \"curl\",\n            \"-s\",\n            \"-S\",\n            \"-k\",\n        ]\n        + ([\"-u\", f\"elastic:{ELASTIC_PASSWORD}\"] if ELASTIC_PASSWORD else [])\n        + [\n            \"--max-time\",\n            \"5\",\n            f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\",\n        ]\n    )\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errors.append(f\"Failed to query {path}: {detail}\")\n        return None\n    output = result.stdout.strip()\n    if not output:\n        errors.append(f\"Empty response for {path}\")\n        return None\n    try:\n        return json.loads(output)\n    except json.JSONDecodeError:\n        errors.append(f\"Failed to parse JSON from {path}\")\n        return None\n\n\ndef get_checkpoint_before(errors):\n    result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"get\",\n            \"configmap\",\n            CHECKPOINT_CM,\n            \"-o\",\n            \"jsonpath={.data.checkpoint_before}\",\n        ]\n    )\n    if result.returncode != 0:\n        errors.append(\"Unable to read checkpoint_before from configmap\")\n        return None\n    value = (result.stdout or \"\").strip()\n    try:\n        return int(value)\n    except (TypeError, ValueError):\n        errors.append(f\"Invalid checkpoint_before value: {value!r}\")\n        return None\n\n\ndef get_transform(errors):\n    stats = curl_json(f\"/_transform/{TRANSFORM_ID}/_stats\", errors)\n    if not isinstance(stats, dict):\n        return None\n    transforms = stats.get(\"transforms\") or []\n    if not transforms:\n        errors.append(\"Transform stats missing\")\n        return None\n    return transforms[0]\n\n\ndef extract_checkpoint(transform):\n    checkpoint = (\n        transform.get(\"checkpointing\", {})\n        .get(\"last\", {})\n        .get(\"checkpoint\")\n    )\n    if checkpoint is None:\n        checkpoint = (\n            transform.get(\"stats\", {})\n            .get(\"checkpointing\", {})\n            .get(\"last\", {})\n            .get(\"checkpoint\")\n        )\n    return checkpoint\n\n\ndef evaluate(checkpoint_before):\n    \"\"\"Run one full snapshot of the transform-recovery checks; return errors.\"\"\"\n    errors = []\n\n    transform = get_transform(errors)\n    if transform:\n        state = transform.get(\"state\") or transform.get(\"stats\", {}).get(\"state\")\n        if state != \"started\":\n            errors.append(f\"Transform state expected started, got {state}\")\n\n        checkpoint_now = extract_checkpoint(transform)\n        if checkpoint_before is not None:\n            if checkpoint_now is None:\n                errors.append(\"Unable to read current checkpoint\")\n            elif checkpoint_now <= checkpoint_before:\n                errors.append(\n                    f\"Checkpoint did not advance (before={checkpoint_before}, now={checkpoint_now})\"\n                )\n\n    count = curl_json(f\"/{DEST_INDEX}/_count\", errors)\n    if isinstance(count, dict):\n        if count.get(\"count\", 0) <= 0:\n            errors.append(\"Destination index has no documents\")\n\n    return errors\n\n\ndef main():\n    global ELASTIC_PASSWORD\n    ELASTIC_PASSWORD = _elastic_password() or _password_from_sts()\n\n    # After the agent restarts the transform, its next checkpoint and the\n    # destination index's documents only materialize once a transform sync cycle\n    # runs (seconds to a sync interval later), and a curl can flake during that\n    # window. A single immediate snapshot catches the not-yet-advanced state and\n    # falsely reports \"Checkpoint did not advance\" / \"no documents\". So verify the\n    # STABLE converged state: re-evaluate and pass on the first clean snapshot.\n    # The checkpoint_before baseline is read ONCE up front so the advance check\n    # stays strict across retries.\n    # O-deadline: keep the internal deadline strictly below the oracle timeout_sec\n    # (120s in test.yaml) so the harness does not kill the loop before it prints a\n    # verdict; 90s leaves headroom for the final evaluate() + output.\n    import time\n    config_errors = []\n    checkpoint_before = get_checkpoint_before(config_errors)\n    deadline = time.monotonic() + 90\n    live_errors = evaluate(checkpoint_before)\n    while live_errors and time.monotonic() < deadline:\n        time.sleep(8)\n        live_errors = evaluate(checkpoint_before)\n    errors = config_errors + live_errors\n\n    if errors:\n        print(\"Transform recovery verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    print(\"Transform recovery verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":262,"startLine":1,"totalLines":262}}}
