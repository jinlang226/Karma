{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01X4tCL4GkVUf1SESqCHyArN","type":"tool_result","content":"1\t# mongodb/initialize\n2\t# MongoDB initialize task\n3\t\n4\tparams:\n5\t  cluster_prefix:\n6\t    default: mongodb-replica\n7\t    description: StatefulSet name of the replica set members.\n8\t  replica_set_name:\n9\t    default: mongodb-replica\n10\t    description: MongoDB replica set _id used when initiating the set.\n11\t  fault_host_suffix:\n12\t    default: mongo-wrong\n13\t    description: Bad host suffix injected to break a member's configuration.\n14\t  app_database:\n15\t    default: app\n16\t    description: Application database seeded with data.\n17\t  app_collection:\n18\t    default: test\n19\t    description: Application collection seeded with data.\n20\t\n21\tprompt: |\n22\t  Replica set is not healthy. Restore a stable 3-member replica set without data loss.\n23\t\n24\tnamespace_contract:\n25\t  required_roles: []\n26\t\n27\tmetrics:\n28\t  - time_to_first_mutation\n29\t\n30\tpreconditionUnits:\n31\t  - name: mongo_env_ready\n32\t    on_probe_fail: skip\n33\t    probe:\n34\t      # AUTHORITATIVE skip-if-running probe (P32): succeed when the canonical\n35\t      # StatefulSet exists OR any pod is Running, so the destructive namespace\n36\t      # rebuild below is skipped on an inherited cluster even if its pods are\n37\t      # momentarily not Running (mid-restart from a prior stage) -- the\n38\t      # StatefulSet persists across that window. The bare `grep -c Running`\n39\t      # could miss such a cluster and clobber inherited state.\n40\t      - command: \"/bin/sh -c 'kubectl -n mongodb get statefulset {{params.cluster_prefix}} >/dev/null 2>&1 || kubectl -n mongodb get pods 2>/dev/null | grep -q Running'\"\n41\t        timeout_sec: 10\n42\t    apply:\n43\t      - command: |\n44\t          /bin/sh -c '\n45\t          kubectl delete namespace mongodb --ignore-not-found=true; kubectl wait --for=delete namespace/mongodb --timeout=120s || true\n46\t          '\n47\t        sleep: 2\n48\t      - command: \"kubectl create namespace mongodb\"\n49\t        sleep: 1\n50\t      - command: \"kubectl -n mongodb apply -f cases/mongodb/initialize/resource/services.yaml\"\n51\t        sleep: 2\n52\t      - command: \"kubectl -n mongodb apply -f cases/mongodb/initialize/resource/statefulset.yaml\"\n53\t        sleep: 5\n54\t      - command: |\n55\t          for i in $(seq 1 120); do\n56\t            ready=$(kubectl -n mongodb get sts {{params.cluster_prefix}} -o jsonpath='{.status.readyReplicas}' 2>/dev/null)\n57\t            if [ \"${ready:-0}\" -ge 3 ]; then\n58\t              exit 0\n59\t            fi\n60\t            sleep 5\n61\t          done\n62\t          exit 1\n63\t        sleep: 2\n64\t      # Pod-Ready != mongod accepting TCP (§1.10): ping-until-ok before rs.initiate.\n65\t      - command: |\n66\t          for i in $(seq 1 30); do\n67\t            kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval 'db.runCommand({ping:1}).ok' 2>/dev/null | grep -q 1 && exit 0\n68\t            sleep 3\n69\t          done\n70\t          exit 1\n71\t        sleep: 2\n72\t      - command: |\n73\t          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\n74\t          rs.initiate({_id:\"{{params.replica_set_name}}\",members:[\n75\t            {_id:0,host:\"mongodb-replica-0.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"},\n76\t            {_id:1,host:\"mongodb-replica-1.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"},\n77\t            {_id:2,host:\"mongodb-replica-2.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"}\n78\t          ]})'\n79\t        sleep: 5\n80\t      - command: |\n81\t          for i in $(seq 1 20); do\n82\t            kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval 'db.hello().isWritablePrimary' | grep true && exit 0\n83\t            sleep 3\n84\t          done\n85\t          exit 1\n86\t        sleep: 2\n87\t      - command: |\n88\t          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\n89\t          cfg = rs.conf();\n90\t          cfg.members[1].host = \"mongodb-replica-1.{{params.fault_host_suffix}}.svc.cluster.local:27017\";\n91\t          cfg.version += 1;\n92\t          rs.reconfig(cfg);\n93\t          '\n94\t        sleep: 5\n95\t      - command: \"kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval 'db.getSiblingDB(\\\"{{params.app_database}}\\\").{{params.app_collection}}.insertMany([{x:1},{x:2},{x:3}], {writeConcern:{w:1}});'\"\n96\t        sleep: 2\n97\t    verify:\n98\t      - command: \"kubectl -n mongodb get pods 2>/dev/null | grep -c Running\"\n99\t        timeout_sec: 10\n100\t\n101\t  # Additive data fixture (composition safety): the oracle requires >= 3 docs in\n102\t  # {{params.app_database}}.{{params.app_collection}}. When this case runs chained on an inherited cluster the\n103\t  # destructive `apply` above is skipped, so a prior stage may have left the\n104\t  # collection short. This unit tops it up ADDITIVELY to the required count WITHOUT\n105\t  # dropping/recreating the collection or touching the namespace/cluster.\n106\t  # The probe gates on the DATA COUNT (not \"pods Running\"), so it runs\n107\t  # whenever the collection is short; standalone (where `apply` already seeded 3)\n108\t  # it sees the required count and skips -> identical behaviour. Idempotent: inserts\n109\t  # only the deficit (required - current).\n110\t  - name: mongo_seed_fixture\n111\t    on_probe_fail: skip\n112\t    probe:\n113\t      # Auth-adaptive: when an inherited cluster has auth enabled the admin secret\n114\t      # exists, so authenticate; otherwise connect plain. Works both ways.\n115\t      - command: |\n116\t          /bin/sh -c 't=\"\"; for cca in /etc/tls/ca.crt /etc/mongo-ca/ca.crt; do kubectl -n mongodb exec mongodb-replica-0 -- ls $cca >/dev/null 2>&1 && { t=\"--tls --tlsAllowInvalidHostnames --tlsAllowInvalidCertificates --tlsCAFile $cca\"; break; }; done; au=\"\"; pw=$(kubectl -n mongodb get secret admin-user-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); [ -n \"$pw\" ] && au=\"-u admin-user -p $pw --authenticationDatabase admin\"; n=$(P=\"\"; for _pi in $(seq 1 30); do P=$(kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet $t $au --eval '\\''rs.hello().primary'\\'' 2>/dev/null | cut -d. -f1); [ -n \"$P\" ] && break; sleep 2; done; P=${P:-mongodb-replica-0}; kubectl -n mongodb exec \"$P\" -- mongosh --quiet $t $au --eval '\\''db.getSiblingDB(\"{{params.app_database}}\").{{params.app_collection}}.countDocuments({})'\\'' 2>/dev/null | tr -dc 0-9); [ \"${n:-0}\" -ge 3 ] && echo ok | grep -c ok'\n117\t        timeout_sec: 30\n118\t    apply:\n119\t      - command: |\n120\t          /bin/sh -c 'au=\"\"; pw=$(kubectl -n mongodb get secret admin-user-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); [ -n \"$pw\" ] && au=\"-u admin-user -p $pw --authenticationDatabase admin\"; P=\"\"; for _pi in $(seq 1 30); do P=$(kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet $au --eval '\\''rs.hello().primary'\\'' 2>/dev/null | cut -d. -f1); [ -n \"$P\" ] && break; sleep 2; done; P=${P:-mongodb-replica-0}; kubectl -n mongodb exec \"$P\" -- mongosh --quiet $au --eval '\\''var c=db.getSiblingDB(\"{{params.app_database}}\").{{params.app_collection}}; var need=3-c.countDocuments({}); var docs=[]; for(var i=0;i<need;i++){docs.push({seed:\"fixture\",ts:new Date()});} if(docs.length>0){c.insertMany(docs,{writeConcern:{w:1}});}'\\'''\n121\t        sleep: 2\n122\t    verify:\n123\t      - command: |\n124\t          /bin/sh -c 't=\"\"; for cca in /etc/tls/ca.crt /etc/mongo-ca/ca.crt; do kubectl -n mongodb exec mongodb-replica-0 -- ls $cca >/dev/null 2>&1 && { t=\"--tls --tlsAllowInvalidHostnames --tlsAllowInvalidCertificates --tlsCAFile $cca\"; break; }; done; au=\"\"; pw=$(kubectl -n mongodb get secret admin-user-p