$ /bin/sh -c 'NS=mongodb; P=$(kubectl -n "$NS" get secret admin-user-password -o jsonpath="{.data.password}" | base64 -d); POD=$(kubectl -n "$NS" get pods -l app=mongodb-replica --field-selector=status.phase=Running -o name 2>/dev/null | head -1); [ -z "$POD" ] && exit 0; T=""; for ca in /etc/tls/ca.crt /etc/mongo-ca/ca.crt /etc/mongodb/tls/ca.crt /etc/ssl/mongodb/ca.crt; do kubectl -n "$NS" exec "$POD" -- test -f "$ca" 2>/dev/null && { T="--tls --tlsAllowInvalidHostnames --tlsCAFile $ca"; break; }; done; ! kubectl -n "$NS" exec "$POD" -- mongosh --quiet $T -u "admin-user" -p "$P" --authenticationDatabase admin --eval "db.hello().isWritablePrimary" 2>/dev/null | grep -q true'

