t configuration before applying the horizon settings.","signature":""}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":2798,"cache_read_input_tokens":33552,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":2798},"output_tokens":27,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"8b1e980e-c467-43ad-ad75-d3fbd7aed506","uuid":"4c5def94-b4e4-4f96-a9e7-308636d80301","request_id":"req_011Ccf3U1QtxJ7GLxqAbSF5D"}
