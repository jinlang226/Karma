ort\n    port: 9300\n    targetPort: 9300\n---\napiVersion: apps/v1\nkind: StatefulSet\nmetadata:\n  name: es-data-new\n  namespace: elasticsearch\n  labels:\n    app: es-data-new\nspec:\n  serviceName: es-data-new\n  replicas: 2\n  podManagementPolicy: Parallel\n  selector:\n    matchLabels:\n      app: es-data-new\n  template:\n    metadata:\n      labels:\n        app: es-data-new\n    spec:\n      initContainers:\n      - name: fix-permissions\n        image: busybox:1.35\n        command: [\"sh\", \"-c\", \"chown -R 1000:1000 /usr/share/elasticsearch/data\"]\n        volumeMounts:\n        - name: data\n          mountPath: /usr/share/elasticsearch/data\n      - name: increase-vm-max-map\n        image: busybox:1.35\n        command: [\"sysctl\", \"-w\", \"vm.max_map_count=262144\"]\n        securityContext:\n          privileged: true\n      containers:\n      - name: elasticsearch\n        image: docker.elastic.co/elasticsearch/elasticsearch:8.11.1\n        env:\n        - name: node.name\n          valueFrom:\n            fieldRef:\n              fieldPath: metadata.name\n        - name: ELASTIC_PASSWORD\n          valueFrom:\n            secretKeyRef:\n              name: elastic-password\n              key: password\n        - name: ES_JAVA_OPTS\n          value: \"-Xms512m -Xmx512m\"\n        ports:\n        - containerPort: 9200\n          name: https\n        - containerPort: 9300\n          name: transport\n        resources:\n          requests:\n            cpu: \"500m\"\n            memory: \"1Gi\"\n          limits:\n            cpu: \"1\"\n            memory: \"2Gi\"\n        readinessProbe:\n          exec:\n            command:\n            - sh\n            - -c\n            - |\n              curl -sk --max-time 5 -u \"elastic:${ELASTIC_PASSWORD}\" \\\n                https://localhost:9200/_cluster/health \\\n                | grep -qE '\"status\":\"(green|yellow)\"'\n          initialDelaySeconds: 60\n          periodSeconds: 15\n          timeoutSeconds: 10\n          failureThreshold: 20\n        volumeMounts:\n        - name: data\n          mountPath: /usr/share/elasticsearch/data\n        - name: config\n          mountPath: /usr/share/elasticsearch/config/elasticsearch.yml\n          subPath: elasticsearch.yml\n        - name: certs\n          mountPath: /usr/share/elasticsearch/config/certs\n          readOnly: true\n      volumes:\n      - name: config\n        configMap:\n          name: es-data-new-config\n      - name: certs\n        secret:\n          secretName: es-http-tls\n  volumeClaimTemplates:\n  - metadata:\n      name: data\n    spec:\n      accessModes: [\"ReadWriteOnce\"]\n      resources:\n        requests:\n          storage: 5Gi\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":5699,"cache_read_input_tokens":40494,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":5699},"output_tokens":23,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"704799b3-acd6-4d2f-ab3c-9286f5d3b1d2","uuid":"8d75566d-b027-489c-9d31-6282487e1a97","request_id":"req_011CceyTjHKUjMxs7TrikUFZ"}
