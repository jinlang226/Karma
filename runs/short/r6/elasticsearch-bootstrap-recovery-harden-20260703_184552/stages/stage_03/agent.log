         failureThreshold: 12\n        volumeMounts:\n        - name: data\n          mountPath: /usr/share/elasticsearch/data\n        - name: es-config\n          mountPath: /usr/share/elasticsearch/config/elasticsearch.yml\n          subPath: elasticsearch.yml\n        - name: es-tls\n          mountPath: /usr/share/elasticsearch/config/tls\n          readOnly: true\n      volumes:\n      - name: es-config\n        configMap:\n          name: es-config\n      - name: es-tls\n        secret:\n          secretName: es-http-tls\n  volumeClaimTemplates:\n  - metadata:\n      name: data\n    spec:\n      accessModes: [\"ReadWriteOnce\"]\n      resources:\n        requests:\n          storage: 5Gi\nEOF","description":"Deploy ES 8.11.1 StatefulSet with TLS certs and security enabled"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":581,"cache_read_input_tokens":41954,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":581},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"dba7340a-94eb-4c5f-a0d8-815ed63dc982","uuid":"12a7485a-2447-479a-95af-24c65819c63b","request_id":"req_011CcfeLizoWyBJUbnyTqPpJ"}
