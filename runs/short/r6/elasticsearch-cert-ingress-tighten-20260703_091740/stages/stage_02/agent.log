t -sha256\n\necho \"\"\necho \"5. Days remaining:\"\nNOT_AFTER=$(kubectl -n elasticsearch get secret es-http-tls -o jsonpath='{.data.tls\\.crt}' | base64 -d | openssl x509 -noout -enddate | cut -d= -f2)\npython3 -c \"\nimport datetime\nnot_after = datetime.datetime.strptime('$NOT_AFTER', '%b %d %H:%M:%S %Y %Z').replace(tzinfo=datetime.timezone.utc)\nnow = datetime.datetime.now(datetime.timezone.utc)\nprint(f'  {(not_after - now).days} days remaining (need 300-400)')\n\"","description":"Run pre-flight oracle checks to verify all conditions"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":645,"cache_read_input_tokens":60968,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":645},"output_tokens":32,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"74c2cc84-754d-4db6-921e-d8fedf78493f","uuid":"ee6b96c6-dfc0-4ce7-aa0c-4439343bd8b3","request_id":"req_011CceuYJHLYjz2F26TDdLEJ"}
