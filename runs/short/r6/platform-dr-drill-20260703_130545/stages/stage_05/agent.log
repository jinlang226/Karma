{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Bf6A6nXuCQP8dtoHCVDyNn","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport argparse\n3\timport base64\n4\timport json\n5\timport os\n6\timport subprocess\n7\timport sys\n8\timport time\n9\t\n10\t\n11\tNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"mongodb\")\n12\tCLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"mongodb-replica\")\n13\tHEADLESS_SERVICE = os.environ.get(\"BENCH_PARAM_HEADLESS_SERVICE_NAME\", \"mongodb-replica-svc\")\n14\tREPLICA_SET_NAME = os.environ.get(\"BENCH_PARAM_REPLICA_SET_NAME\", CLUSTER_PREFIX)\n15\tAPP_DATABASE = os.environ.get(\"BENCH_PARAM_APP_DATABASE\", \"app\")\n16\tAPP_COLLECTION = os.environ.get(\"BENCH_PARAM_APP_COLLECTION\", \"test\")\n17\tSEED_DOCS = int(os.environ.get(\"BENCH_PARAM_SEED_DOCS\", \"3\"))\n18\t\n19\t\n20\tdef run(cmd, timeout=30):\n21\t    \"\"\"Run a command bounded (O17): a hung kubectl/mongosh exec becomes a\n22\t    failed attempt instead of an uncaught TimeoutExpired that would crash the\n23\t    whole oracle at its deadline.\"\"\"\n24\t    try:\n25\t        return subprocess.run(cmd, text=True, stdout=subprocess.PIPE,\n26\t                              stderr=subprocess.PIPE, timeout=timeout)\n27\t    except subprocess.TimeoutExpired:\n28\t        return subprocess.CompletedProcess(cmd, 124, \"\", \"timed out\")\n29\t\n30\t\n31\t_ADMIN_PW = None\n32\t\n33\t\n34\tdef _admin_auth_flags():\n35\t    \"\"\"`-u <admin> -p <pw> --authenticationDatabase admin` when the admin secret\n36\t    exists. The env PERSISTS across stages, so a prior deploy stage may have\n37\t    enabled auth (keyfile + admin user), after which rs.conf()/rs.status()\n38\t    require credentials. Empty when no admin secret is present (standalone,\n39\t    pre-auth) so the plain connection is used. Cached.\"\"\"\n40\t    global _ADMIN_PW\n41\t    if _ADMIN_PW is None:\n42\t        secret = os.environ.get(\"BENCH_PARAM_ADMIN_SECRET_NAME\", \"admin-user-password\")\n43\t        r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", secret,\n44\t                 \"-o\", \"jsonpath={.data.password}\"])\n45\t        pw = \"\"\n46\t        if r.returncode == 0 and r.stdout.strip():\n47\t            try:\n48\t                pw = base64.b64decode(r.stdout.strip()).decode()\n49\t            except Exception:\n50\t                pw = \"\"\n51\t        _ADMIN_PW = pw\n52\t    if _ADMIN_PW:\n53\t        user = os.environ.get(\"BENCH_PARAM_ADMIN_USERNAME\", \"admin-user\")\n54\t        return [\"-u\", user, \"-p\", _ADMIN_PW, \"--authenticationDatabase\", \"admin\"]\n55\t    return []\n56\t\n57\t\n58\t_TLS_FLAGS_CACHE = None\n59\t\n60\t\n61\tdef _mongo_tls_flags(probe_pod=None):\n62\t    \"\"\"mongosh transport flags that adapt to the cluster's LIVE TLS mode.\n63\t\n64\t    The environment PERSISTS across workflow stages, so an earlier stage\n65\t    (mongodb/tls-setup or mongodb/certificate-rotation) may have turned TLS on,\n66\t    after which a plain mongosh connection is refused. Detect TLS by probing the\n67\t    running mongo pod for a CA cert mounted at the paths the TLS stages use; if\n68\t    present, connect with --tls --tlsCAFile (and a client cert for mutual TLS\n69\t    when one is mounted), else connect plain. Standalone (no CA mounted) this\n70\t    returns [] -> identical plain behaviour. It only adds transport flags; every\n71\t    real check still runs and still fails when its condition is unmet.\n72\t    \"\"\"\n73\t    global _TLS_FLAGS_CACHE\n74\t    if _TLS_FLAGS_CACHE is not None:\n75\t        return list(_TLS_FLAGS_CACHE)\n76\t    flags = []\n77\t    pod = probe_pod or f\"{CLUSTER_PREFIX}-0\"\n78\t    ca_path = None\n79\t    for cand in (\n80\t        \"/etc/tls/ca.crt\",\n81\t        \"/etc/mongo-ca/ca.crt\",\n82\t        \"/etc/mongodb/tls/ca.crt\",\n83\t        \"/etc/ssl/mongodb/ca.crt\",\n84\t    ):\n85\t        probe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + cand])\n86\t        if probe.returncode == 0:\n87\t            ca_path = cand\n88\t            break\n89\t    if ca_path:\n90\t        flags = [\"--tls\", \"--tlsAllowInvalidHostnames\", \"--tlsAllowInvalidCertificates\", \"--tlsCAFile\", ca_path]\n91\t        for client_pem in (\"/etc/tls/client.pem\", \"/etc/mongo-ca/client.pem\"):\n92\t            cprobe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + client_pem])\n93\t            if cprobe.returncode == 0:\n94\t                flags += [\"--tlsCertificateKeyFile\", client_pem]\n95\t                break\n96\t    _TLS_FLAGS_CACHE = flags\n97\t    return list(flags)\n98\t\n99\tdef _resolve_expected_replicas():\n100\t    \"\"\"Topology size to enforce: param-first, defaulting to 3 (O2 exception).\n101\t\n102\t    The member count IS this case's graded outcome -- the prompt promises a\n103\t    3-member replica set -- so it is never derived from the live cluster\n104\t    (live-deriving would mask a failed or partial deployment). An explicit\n105\t    ``expected_replicas``/``target_replicas`` param override wins, else 3.\n106\t    \"\"\"\n107\t    for key in (\"BENCH_PARAM_EXPECTED_REPLICAS\", \"BENCH_PARAM_TARGET_REPLICAS\"):\n108\t        val = os.environ.get(key)\n109\t        if val is not None and str(val).strip():\n110\t            try:\n111\t                return int(val)\n112\t            except ValueError:\n113\t                pass\n114\t    return 3\n115\t\n116\t\n117\tEXPECTED_REPLICAS = _resolve_expected_replicas()\n118\t\n119\t\n120\tdef fail(prefix, errors):\n121\t    if errors:\n122\t        print(prefix, file=sys.stderr)\n123\t        for err in errors:\n124\t            print(f\"  - {err}\", file=sys.stderr)\n125\t        return 1\n126\t    return 0\n127\t\n128\t\n129\tdef mongo_eval(pod, script):\n130\t    # Connect via the member's own FQDN with directConnection=true to skip SDAM\n131\t    # topology monitoring, which a bare localhost connection would start and\n132\t    # which fails under a persisted requireTLS mode. directConnection works on\n133\t    # any single member for rs.conf()/rs.status() reads.\n134\t    uri = (f\"mongodb://{pod}.{HEADLESS_SERVICE}.{NAMESPACE}.svc.cluster.local:27017/\"\n135\t           \"?directConnection=true\")\n136\t    base = [\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\",\n137\t            \"mongosh\", \"--quiet\", *_mongo_tls_flags(), uri]\n138\t    res = run(base + [\"--eval\", script])\n139\t    # Adaptive auth: a deploy stage may have enabled auth, so a plain rs.conf()\n140\t    # fails \"requires authentication\". Retry once with the live admin credentials.\n141\t    out = ((res.stderr or \"\") + (res.stdout or \"\")).lower()\n142\t    if res.returncode != 0 and (\n143\t        \"requires authentication\" in out or \"not authorized\" in out\n144\t        or \"unauthorized\" in out or \"authentication failed\" in out\n145\t    ):\n146\t        af = _admin_auth_flags()\n147\t        if af:\n148\t            res = run(base + af + [\"--eval\", script])\n149\t    return res\n150\t\n151\t\n152\t_PRIMARY_POD_CACHE = None\n153\t\n154\t\n155\tdef find_primary():\n156\t    \"\"\"Locate the replica-set PRIMARY replica-set pod, falling back to CLUSTER_PREFIX-0.\n157\t\n158\t    The environment PERSISTS across workflow stages, so an earlier stage (or\n159\t    this case's own election) can move the PRIMARY off pod-0. countDocuments\n160\t    requires the primary -- on a secondary it fails \"not primary and\n161\t    secondaryOk=false\" (O8). Exec db.hello() into each replica-set member and route\n162\t    the data read to the writable primary; standalone this resolves to pod-0\n163\t    -> identical behaviour. Copied from decommission's oracle. Cached.\n164\t    \"\"\"\n165\t    global _PRIMARY_POD_CACHE\n166\t    if _PRIMARY_POD_CACHE is not None:\n167\t        return _PRIMARY_POD_CACHE\n168\t    for idx in range(9):\n169\t        pod = f\"{CLUSTER_PREFIX}-{idx}\"\n170\t        res = mongo_eval(pod, \"db.hello().isWritablePrimary\")\n171\t        if res.returncode != 0:\n172\t            if idx > 0 and \"NotFound\" in (res.stderr or \"\"):\n173\t                break\n174\t            continue\n175\t        if \"true\" in (res.stdout or \"\"):\n176\t            _PRIMARY_POD_CACHE = pod\n177\t            return pod\n178\t    return f\"{CLUSTER_PREFIX}-0\"\n179\t\n180\t\n181\tdef mongo_json(pod, script, label, errors):\n182\t    res = mongo_eval(pod, script)\n183\t    if res.returncode != 0:\n184\t        detail = res.stderr.strip() or res.stdout.strip() or f\"exit {res.returncode}\"\n185\t        errors.append(f\"{label} failed on {pod}: {detail}\")\n186\t        return None\n187\t    raw = (res.stdout or \"\").strip()\n188\t    if not raw:\n189\t        errors.append(f\"{label} returned empty output on {pod}\")\n190\t        return None\n191\t    try:\n192\t        return json.loads(raw)\n193\t    except json.JSONDecodeError:\n194\t        errors.append(f\"Unable to parse {label} JSON output on {pod}\")\n195\t        return None\n196\t\n197\t\n198\tdef expected_hosts():\n199\t    return {\n200\t        f\"{CLUSTER_PREFIX}-{i}.{HEADLESS_SERVICE}.{NAMESPACE}.svc.cluster.local:27017\"\n201\t        for i in range(EXPECTED_REPLICAS)\n202\t    }\n203\t\n204\t\n205\tdef check_topology():\n206\t    errors = []\n207\t    pod = f\"{CLUSTER_PREFIX}-0\"\n208\t    conf = mongo_json(pod, \"JSON.stringify(rs.conf())\", \"rs.conf()\", errors)\n209\t    if isinstance(conf, dict):\n210\t        members = conf.get(\"members\", [])\n211\t        if len(members) != EXPECTED_REPLICAS:\n212\t            errors.append(f\"Expected {EXPECTED_REPLICAS} members in rs.conf(), got {len(members)}\")\n213\t        actual_hosts = {m.get(\"host\") for m in members if m.get(\"host\")}\n214\t        want_hosts = expected_hosts()\n215\t        if actual_hosts != want_hosts:\n216\t            errors.append(f\"Replica set hosts mismatch: expected={sorted(want_hosts)} actual={sorted(actual_hosts)}\")\n217\t\n218\t    status = mongo_json(pod, \"JSON.stringify(rs.status())\", \"rs.status()\", errors)\n219\t    if isinstance(status, dict):\n220\t        set_name = status.get(\"set\")\n221\t        if set_name != REPLICA_SET_NAME:\n222\t            errors.append(f\"Replica set name expected {REPLICA_SET_NAME}, got {set_name}\")\n223\t\n224\t    return fail(\"MongoDB initialize topology check failed:\", errors)\n225\t\n226\t\n227\tdef _health_attempt():\n228\t    errors = []\n229\t    pod = f\"{CLUSTER_PREFIX}-0\"\n230\t    status = mongo_json(pod, \"JSON.stringify(rs.status())\", \"rs.status()\", errors)\n231\t    if isinstance(status, dict):\n232\t        members = status.get(\"members\", [])\n233\t        primary = sum(1 for m in members if m.get(\"stateStr\") == \"PRIMARY\")\n234\t        secondary = sum(1 for m in members if m.get(\"stateStr\") == \"SECONDARY\")\n235\t        if primary != 1:\n236\t            errors.append(f\"Expected 1 PRIMARY, got {primary}\")\n237\t        if secondary != EXPECTED_REPLICAS - 1:\n238\t            errors.append(f\"Expected {EXPECTED_REPLICAS - 1} SECONDARY, got {secondary}\")\n239\t\n240\t    sts = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", CLUSTER_PREFIX, \"-o\", \"json\"])\n241\t    if sts.returncode != 0:\n242\t        detail = sts.stderr.strip() or sts.stdout.strip() or f\"exit {sts.returncode}\"\n243\t        errors.append(f\"Failed to read statefulset {CLUSTER_PREFIX}: {detail}\")\n244\t    else:\n245\t        try:\n246\t            sts_obj = json.loads(sts.stdout)\n247\t        except json.JSONDecodeError:\n248\t            errors.append(\"Failed to parse statefulset JSON\")\n249\t            sts_obj = {}\n250\t        spec_replicas = sts_obj.get(\"spec\", {}).get(\"replicas\")\n251\t        ready_replicas = sts_obj.get(\"status\", {}).get(\"readyReplicas\", 0)\n252\t        if spec_replicas != EXPECTED_REPLICAS:\n253\t            errors.append(f\"StatefulSet replicas expected {EXPECTED_REPLICAS}, got {spec_replicas}\")\n254\t        if ready_replicas != EXPECTED_REPLICAS:\n255\t            errors.append(f\"Ready replicas expected {EXPECTED_REPLICAS}, got {ready_replicas}\")\n256\t\n257\t    return errors\n258\t\n259\t\n260\tdef check_health():\n261\t    # O-flap-restart: restoring/reforming the set leaves members briefly in\n262\t    # STARTUP2/RECOVERING and pods Ready staggered, so the PRIMARY/SECONDARY and\n263\t    # readyReplicas tallies read short. Poll to convergence (~120s, 5s between\n264\t    # attempts); assertions unchanged.\n265\t    deadline = time.monotonic() + 120\n266\t    errors = []\n267\t    while True:\n268\t        errors = _health_attempt()\n269\t        if not errors:\n270\t            break\n271\t        if time.monotonic() >= deadline:\n272\t            break\n273\t        time.sleep(5)\n274\t    return fail(\"MongoDB initialize health check failed:\", errors)\n275\t\n276\t\n277\tdef check_data():\n278\t    errors = []\n279\t    pod = find_primary()\n280\t    res = mongo_eval(\n281\t        pod,\n282\t        f\"db.getSiblingDB('{APP_DATABASE}').{APP_COLLECTION}.countDocuments({{}})\",\n283\t    )\n284\t    if res.returncode != 0:\n285\t        detail = res.stderr.strip() or res.stdout.strip() or f\"exit {res.returncode}\"\n286\t        errors.append(f\"Failed to read {APP_DATABASE}.{APP_COLLECTION}: {detail}\")\n287\t    else:\n288\t        raw = (res.stdout or \"\").strip()\n289\t        if not raw.isdigit() or int(raw) < SEED_DOCS:\n290\t            errors.append(f\"Expected >= {SEED_DOCS} docs in {APP_DATABASE}.{APP_COLLECTION}, got {raw}\")\n291\t\n292\t    return fail(\"MongoDB initialize data check failed:\", errors)\n293\t\n294\t\n295\tdef main():\n296\t    parser = argparse.ArgumentParser()\n297\t    parser.add_argument(\"--check\", default=\"all\", choices=[\"all\", \"topology\", \"health\", \"data\"])\n298\t    args = parser.parse_args()\n299\t\n300\t    if args.check == \"topology\":\n301\t        return check_topology()\n302\t    if args.check == \"health\":\n303\t        return check_health()\n304\t    if args.check == \"data\":\n305\t        return check_data()\n306\t\n307\t    for fn in (check_topology, check_health, check_data):\n308\t        rc = fn()\n309\t        if rc != 0:\n310\t            return rc\n311\t    print(\"MongoDB initialize verified\")\n312\t    return 0\n313\t\n314\t\n315\tif __name__ == \"__main__\":\n316\t    sys.exit(main())\n317\t"}]},"parent_tool_use_id":null,"session_id":"5a6c058b-b8a5-4cef-aeaf-7999e1cdd491","uuid":"fd708630-1daa-4638-9ea9-21992000868f","timestamp":"2026-07-03T13:27:16.574Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/mongodb/initialize/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport argparse\nimport base64\nimport json\nimport os\nimport subprocess\nimport sys\nimport time\n\n\nNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"mongodb\")\nCLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"mongodb-replica\")\nHEADLESS_SERVICE = os.environ.get(\"BENCH_PARAM_HEADLESS_SERVICE_NAME\", \"mongodb-replica-svc\")\nREPLICA_SET_NAME = os.environ.get(\"BENCH_PARAM_REPLICA_SET_NAME\", CLUSTER_PREFIX)\nAPP_DATABASE = os.environ.get(\"BENCH_PARAM_APP_DATABASE\", \"app\")\nAPP_COLLECTION = os.environ.get(\"BENCH_PARAM_APP_COLLECTION\", \"test\")\nSEED_DOCS = int(os.environ.get(\"BENCH_PARAM_SEED_DOCS\", \"3\"))\n\n\ndef run(cmd, timeout=30):\n    \"\"\"Run a command bounded (O17): a hung kubectl/mongosh exec becomes a\n    failed attempt instead of an uncaught TimeoutExpired that would crash the\n    whole oracle at its deadline.\"\"\"\n    try:\n        return subprocess.run(cmd, text=True, stdout=subprocess.PIPE,\n                              stderr=subprocess.PIPE, timeout=timeout)\n    except subprocess.TimeoutExpired:\n        return subprocess.CompletedProcess(cmd, 124, \"\", \"timed out\")\n\n\n_ADMIN_PW = None\n\n\ndef _admin_auth_flags():\n    \"\"\"`-u <admin> -p <pw> --authenticationDatabase admin` when the admin secret\n    exists. The env PERSISTS across stages, so a prior deploy stage may have\n    enabled auth (keyfile + admin user), after which rs.conf()/rs.status()\n    require credentials. Empty when no admin secret is present (standalone,\n    pre-auth) so the plain connection is used. Cached.\"\"\"\n    global _ADMIN_PW\n    if _ADMIN_PW is None:\n        secret = os.environ.get(\"BENCH_PARAM_ADMIN_SECRET_NAME\", \"admin-user-password\")\n        r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", secret,\n                 \"-o\", \"jsonpath={.data.password}\"])\n        pw = \"\"\n        if r.returncode == 0 and r.stdout.strip():\n            try:\n                pw = base64.b64decode(r.stdout.strip()).decode()\n            except Exception:\n                pw = \"\"\n        _ADMIN_PW = pw\n    if _ADMIN_PW:\n        user = os.environ.get(\"BENCH_PARAM_ADMIN_USERNAME\", \"admin-user\")\n        return [\"-u\", user, \"-p\", _ADMIN_PW, \"--authenticationDatabase\", \"admin\"]\n    return []\n\n\n_TLS_FLAGS_CACHE = None\n\n\ndef _mongo_tls_flags(probe_pod=None):\n    \"\"\"mongosh transport flags that adapt to the cluster's LIVE TLS mode.\n\n    The environment PERSISTS across workflow stages, so an earlier stage\n    (mongodb/tls-setup or mongodb/certificate-rotation) may have turned TLS on,\n    after which a plain mongosh connection is refused. Detect TLS by probing the\n    running mongo pod for a CA cert mounted at the paths the TLS stages use; if\n    present, connect with --tls --tlsCAFile (and a client cert for mutual TLS\n    when one is mounted), else connect plain. Standalone (no CA mounted) this\n    returns [] -> identical plain behaviour. It only adds transport flags; every\n    real check still runs and still fails when its condition is unmet.\n    \"\"\"\n    global _TLS_FLAGS_CACHE\n    if _TLS_FLAGS_CACHE is not None:\n        return list(_TLS_FLAGS_CACHE)\n    flags = []\n    pod = probe_pod or f\"{CLUSTER_PREFIX}-0\"\n    ca_path = None\n    for cand in (\n        \"/etc/tls/ca.crt\",\n        \"/etc/mongo-ca/ca.crt\",\n        \"/etc/mongodb/tls/ca.crt\",\n        \"/etc/ssl/mongodb/ca.crt\",\n    ):\n        probe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + cand])\n        if probe.returncode == 0:\n            ca_path = cand\n            break\n    if ca_path:\n        flags = [\"--tls\", \"--tlsAllowInvalidHostnames\", \"--tlsAllowInvalidCertificates\", \"--tlsCAFile\", ca_path]\n        for client_pem in (\"/etc/tls/client.pem\", \"/etc/mongo-ca/client.pem\"):\n            cprobe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + client_pem])\n            if cprobe.returncode == 0:\n                flags += [\"--tlsCertificateKeyFile\", client_pem]\n                break\n    _TLS_FLAGS_CACHE = flags\n    return list(flags)\n\ndef _resolve_expected_replicas():\n    \"\"\"Topology size to enforce: param-first, defaulting to 3 (O2 exception).\n\n    The member count IS this case's graded outcome -- the prompt promises a\n    3-member replica set -- so it is never derived from the live cluster\n    (live-deriving would mask a failed or partial deployment). An explicit\n    ``expected_replicas``/``target_replicas`` param override wins, else 3.\n    \"\"\"\n    for key in (\"BENCH_PARAM_EXPECTED_REPLICAS\", \"BENCH_PARAM_TARGET_REPLICAS\"):\n        val = os.environ.get(key)\n        if val is not None and str(val).strip():\n            try:\n                return int(val)\n            except ValueError:\n                pass\n    return 3\n\n\nEXPECTED_REPLICAS = _resolve_expected_replicas()\n\n\ndef fail(prefix, errors):\n    if errors:\n        print(prefix, file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n    return 0\n\n\ndef mongo_eval(pod, script):\n    # Connect via the member's own FQDN with directConnection=true to skip SDAM\n    # topology monitoring, which a bare localhost connection would start and\n    # which fails under a persisted requireTLS mode. directConnection works on\n    # any single member for rs.conf()/rs.status() reads.\n    uri = (f\"mongodb://{pod}.{HEADLESS_SERVICE}.{NAMESPACE}.svc.cluster.local:27017/\"\n           \"?directConnection=true\")\n    base = [\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\",\n            \"mongosh\", \"--quiet\", *_mongo_tls_flags(), uri]\n    res = run(base + [\"--eval\", script])\n    # Adaptive auth: a deploy stage may have enabled auth, so a plain rs.conf()\n    # fails \"requires authentication\". Retry once with the live admin credentials.\n    out = ((res.stderr or \"\") + (res.stdout or \"\")).lower()\n    if res.returncode != 0 and (\n        \"requires authentication\" in out or \"not authorized\" in out\n        or \"unauthorized\" in out or \"authentication failed\" in out\n    ):\n        af = _admin_auth_flags()\n        if af:\n            res = run(base + af + [\"--eval\", script])\n    return res\n\n\n_PRIMARY_POD_CACHE = None\n\n\ndef find_primary():\n    \"\"\"Locate the replica-set PRIMARY replica-set pod, falling back to CLUSTER_PREFIX-0.\n\n    The environment PERSISTS across workflow stages, so an earlier stage (or\n    this case's own election) can move the PRIMARY off pod-0. countDocuments\n    requires the primary -- on a secondary it fails \"not primary and\n    secondaryOk=false\" (O8). Exec db.hello() into each replica-set member and route\n    the data read to the writable primary; standalone this resolves to pod-0\n    -> identical behaviour. Copied from decommission's oracle. Cached.\n    \"\"\"\n    global _PRIMARY_POD_CACHE\n    if _PRIMARY_POD_CACHE is not None:\n        return _PRIMARY_POD_CACHE\n    for idx in range(9):\n        pod = f\"{CLUSTER_PREFIX}-{idx}\"\n        res = mongo_eval(pod, \"db.hello().isWritablePrimary\")\n        if res.returncode != 0:\n            if idx > 0 and \"NotFound\" in (res.stderr or \"\"):\n                break\n            continue\n        if \"true\" in (res.stdout or \"\"):\n            _PRIMARY_POD_CACHE = pod\n            return pod\n    return f\"{CLUSTER_PREFIX}-0\"\n\n\ndef mongo_json(pod, script, label, errors):\n    res = mongo_eval(pod, script)\n    if res.returncode != 0:\n        detail = res.stderr.strip() or res.stdout.strip() or f\"exit {res.returncode}\"\n        errors.append(f\"{label} failed on {pod}: {detail}\")\n        return None\n    raw = (res.stdout or \"\").strip()\n    if not raw:\n        errors.append(f\"{label} returned empty output on {pod}\")\n        return None\n    try:\n        return json.loads(raw)\n    except json.JSONDecodeError:\n        errors.append(f\"Unable to parse {label} JSON output on {pod}\")\n        return None\n\n\ndef expected_hosts():\n    return {\n        f\"{CLUSTER_PREFIX}-{i}.{HEADLESS_SERVICE}.{NAMESPACE}.svc.cluster.local:27017\"\n        for i in range(EXPECTED_REPLICAS)\n    }\n\n\ndef check_topology():\n    errors = []\n    pod = f\"{CLUSTER_PREFIX}-0\"\n    conf = mongo_json(pod, \"JSON.stringify(rs.conf())\", \"rs.conf()\", errors)\n    if isinstance(conf, dict):\n        members = conf.get(\"members\", [])\n        if len(members) != EXPECTED_REPLICAS:\n            errors.append(f\"Expected {EXPECTED_REPLICAS} members in rs.conf(), got {len(members)}\")\n        actual_hosts = {m.get(\"host\") for m in members if m.get(\"host\")}\n        want_hosts = expected_hosts()\n        if actual_hosts != want_hosts:\n            errors.append(f\"Replica set hosts mismatch: expected={sorted(want_hosts)} actual={sorted(actual_hosts)}\")\n\n    status = mongo_json(pod, \"JSON.stringify(rs.status())\", \"rs.status()\", errors)\n    if isinstance(status, dict):\n        set_name = status.get(\"set\")\n        if set_name != REPLICA_SET_NAME:\n            errors.append(f\"Replica set name expected {REPLICA_SET_NAME}, got {set_name}\")\n\n    return fail(\"MongoDB initialize topology check failed:\", errors)\n\n\ndef _health_attempt():\n    errors = []\n    pod = f\"{CLUSTER_PREFIX}-0\"\n    status = mongo_json(pod, \"JSON.stringify(rs.status())\", \"rs.status()\", errors)\n    if isinstance(status, dict):\n        members = status.get(\"members\", [])\n        primary = sum(1 for m in members if m.get(\"stateStr\") == \"PRIMARY\")\n        secondary = sum(1 for m in members if m.get(\"stateStr\") == \"SECONDARY\")\n        if primary != 1:\n            errors.append(f\"Expected 1 PRIMARY, got {primary}\")\n        if secondary != EXPECTED_REPLICAS - 1:\n            errors.append(f\"Expected {EXPECTED_REPLICAS - 1} SECONDARY, got {secondary}\")\n\n    sts = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", CLUSTER_PREFIX, \"-o\", \"json\"])\n    if sts.returncode != 0:\n        detail = sts.stderr.strip() or sts.stdout.strip() or f\"exit {sts.returncode}\"\n        errors.append(f\"Failed to read statefulset {CLUSTER_PREFIX}: {detail}\")\n    else:\n        try:\n            sts_obj = json.loads(sts.stdout)\n        except json.JSONDecodeError:\n            errors.append(\"Failed to parse statefulset JSON\")\n            sts_obj = {}\n        spec_replicas = sts_obj.get(\"spec\", {}).get(\"replicas\")\n        ready_replicas = sts_obj.get(\"status\", {}).get(\"readyReplicas\", 0)\n        if spec_replicas != EXPECTED_REPLICAS:\n            errors.append(f\"StatefulSet replicas expected {EXPECTED_REPLICAS}, got {spec_replicas}\")\n        if ready_replicas != EXPECTED_REPLICAS:\n            errors.append(f\"Ready replicas expected {EXPECTED_REPLICAS}, got {ready_replicas}\")\n\n    return errors\n\n\ndef check_health():\n    # O-flap-restart: restoring/reforming the set leaves members briefly in\n    # STARTUP2/RECOVERING and pods Ready staggered, so the PRIMARY/SECONDARY and\n    # readyReplicas tallies read short. Poll to convergence (~120s, 5s between\n    # attempts); assertions unchanged.\n    deadline = time.monotonic() + 120\n    errors = []\n    while True:\n        errors = _health_attempt()\n        if not errors:\n            break\n        if time.monotonic() >= deadline:\n            break\n        time.sleep(5)\n    return fail(\"MongoDB initialize health check failed:\", errors)\n\n\ndef check_data():\n    errors = []\n    pod = find_primary()\n    res = mongo_eval(\n        pod,\n        f\"db.getSiblingDB('{APP_DATABASE}').{APP_COLLECTION}.countDocuments({{}})\",\n    )\n    if res.returncode != 0:\n        detail = res.stderr.strip() or res.stdout.strip() or f\"exit {res.returncode}\"\n        errors.append(f\"Failed to read {APP_DATABASE}.{APP_COLLECTION}: {detail}\")\n    else:\n        raw = (res.stdout or \"\").strip()\n        if not raw.isdigit() or int(raw) < SEED_DOCS:\n            errors.append(f\"Expected >= {SEED_DOCS} docs in {APP_DATABASE}.{APP_COLLECTION}, got {raw}\")\n\n    return fail(\"MongoDB initialize data check failed:\", errors)\n\n\ndef main():\n    parser = argparse.ArgumentParser()\n    parser.add_argument(\"--check\", default=\"all\", choices=[\"all\", \"topology\", \"health\", \"data\"])\n    args = parser.parse_args()\n\n    if args.check == \"topology\":\n        return check_topology()\n    if args.check == \"health\":\n        return check_health()\n    if args.check == \"data\":\n        return check_data()\n\n    for fn in (check_topology, check_health, check_data):\n        rc = fn()\n        if rc != 0:\n            return rc\n    print(\"MongoDB initialize verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":317,"startLine":1,"totalLines":317}}}
