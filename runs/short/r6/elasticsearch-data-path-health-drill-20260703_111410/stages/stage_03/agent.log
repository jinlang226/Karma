arch/data\",\n    \"name\": \"data\"\n  },\n  {\n    \"name\": \"es-secure-settings-vol\",\n    \"mountPath\": \"/run/secrets/es-secure\",\n    \"readOnly\": true\n  }\n]\nlifecycle: {\n  \"postStart\": {\n    \"exec\": {\n      \"command\": [\n        \"/bin/bash\",\n        \"-c\",\n        \"elasticsearch-keystore add --stdin --force s3.client.default.access_key < /run/secrets/es-secure/s3.client.default.access_key && elasticsearch-keystore add --stdin --force s3.client.default.secret_key < /run/secrets/es-secure/s3.client.default.secret_key && for i in $(seq 1 30); do curl -sf -k -u elastic:${ELASTIC_PASSWORD} -X POST https://localhost:9200/_nodes/reload_secure_settings -H 'Content-Type: application/json' -d '{}' && break; sleep 10; done\"\n      ]\n    }\n  }\n}\n\nvolumes: [\n  \"config\",\n  \"certs\",\n  \"es-secure-settings-vol\"\n]\ninitContainers: ['fix-permissions', 'increase-vm-max-map']\nSaved clean JSON","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
