{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01S5WoATsEPiaAG9SKC3Q7Hu","type":"tool_result","content":"# mongodb/initialize\n# MongoDB initialize task\n\nparams:\n  cluster_prefix:\n    default: mongodb-replica\n    description: StatefulSet name of the replica set members.\n  replica_set_name:\n    default: mongodb-replica\n    description: MongoDB replica set _id used when initiating the set.\n  fault_host_suffix:\n    default: mongo-wrong\n    description: Bad host suffix injected to break a member's configuration.\n  app_database:\n    default: app\n    description: Application database seeded with data.\n  app_collection:\n    default: test\n    description: Application collection seeded with data.\n\nprompt: |\n  Replica set is not healthy. Restore a stable 3-member replica set without data loss.\n\nnamespace_contract:\n  required_roles: []\n\nmetrics:\n  - time_to_first_mutation\n\npreconditionUnits:\n  - name: mongo_env_ready\n    on_probe_fail: skip\n    probe:\n      # AUTHORITATIVE skip-if-running probe (P32): succeed when the canonical\n      # StatefulSet exists OR any pod is Running, so the destructive namespace\n      # rebuild below is skipped on an inherited cluster even if its pods are\n      # momentarily not Running (mid-restart from a prior stage) -- the\n      # StatefulSet persists across that window. The bare `grep -c Running`\n      # could miss such a cluster and clobber inherited state.\n      - command: \"/bin/sh -c 'kubectl -n mongodb get statefulset {{params.cluster_prefix}} >/dev/null 2>&1 || kubectl -n mongodb get pods 2>/dev/null | grep -q Running'\"\n        timeout_sec: 10\n    apply:\n      - command: |\n          /bin/sh -c '\n          kubectl delete namespace mongodb --ignore-not-found=true; kubectl wait --for=delete namespace/mongodb --timeout=120s || true\n          '\n        sleep: 2\n      - command: \"kubectl create namespace mongodb\"\n        sleep: 1\n      - command: \"kubectl -n mongodb apply -f cases/mongodb/initialize/resource/services.yaml\"\n        sleep: 2\n      - command: \"kubectl -n mongodb apply -f cases/mongodb/initialize/resource/statefulset.yaml\"\n        sleep: 5\n      - command: |\n          for i in $(seq 1 120); do\n            ready=$(kubectl -n mongodb get sts {{params.cluster_prefix}} -o jsonpath='{.status.readyReplicas}' 2>/dev/null)\n            if [ \"${ready:-0}\" -ge 3 ]; then\n              exit 0\n            fi\n            sleep 5\n          done\n          exit 1\n        sleep: 2\n      # Pod-Ready != mongod accepting TCP (§1.10): ping-until-ok before rs.initiate.\n      - command: |\n          for i in $(seq 1 30); do\n            kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval 'db.runCommand({ping:1}).ok' 2>/dev/null | grep -q 1 && exit 0\n            sleep 3\n          done\n          exit 1\n        sleep: 2\n      - command: |\n          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\n          rs.initiate({_id:\"{{params.replica_set_name}}\",members:[\n            {_id:0,host:\"mongodb-replica-0.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"},\n            {_id:1,host:\"mongodb-replica-1.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"},\n            {_id:2,host:\"mongodb-replica-2.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"}\n          ]})'\n        sleep: 5\n      - command: |\n          for i in $(seq 1 20); do\n            kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval 'db.hello().isWritablePrimary' | grep true && exit 0\n            sleep 3\n          done\n          exit 1\n        sleep: 2\n      - command: |\n          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\n          cfg = rs.conf();\n          cfg.members[1].host = \"mongodb-replica-1.{{params.fault_host_suffix}}.svc.cluster.local:27017\";\n          cfg.version += 1;\n          rs.reconfig(cfg);\n          '\n        sleep: 5\n      - command: \"kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval 'db.getSiblingDB(\\\"{{params.app_database}}\\\").{{params.app_collection}}.insertMany([{x:1},{x:2},{x:3}], {writeConcern:{w:1}});'\"\n        sleep: 2\n    verify:\n      - command: \"kubectl -n mongodb get pods 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n\n  # Additive data fixture (composition safety): the oracle requires >= 3 docs in\n  # {{params.app_database}}.{{params.app_collection}}. When this case runs chained on an inherited cluster the\n  # destructive `apply` above is skipped, so a prior stage may have left the\n  # collection short. This unit tops it up ADDITIVELY to the required count WITHOUT\n  # dropping/recreating the collection or touching the namespace/cluster.\n  # The probe gates on the DATA COUNT (not \"pods Running\"), so it runs\n  # whenever the collection is short; standalone (where `apply` already seeded 3)\n  # it sees the required count and skips -> identical behaviour. Idempotent: inserts\n  # only the deficit (required - current).\n  - name: mongo_seed_fixture\n    on_probe_fail: skip\n    probe:\n      # Auth-adaptive: when an inherited cluster has auth enabled the admin secret\n      # exists, so authenticate; otherwise connect plain. Works both ways.\n      - command: |\n          /bin/sh -c 't=\"\"; for cca in /etc/tls/ca.crt /etc/mongo-ca/ca.crt; do kubectl -n mongodb exec mongodb-replica-0 -- ls $cca >/dev/null 2>&1 && { t=\"--tls --tlsAllowInvalidHostnames --tlsAllowInvalidCertificates --tlsCAFile $cca\"; break; }; done; au=\"\"; pw=$(kubectl -n mongodb get secret admin-user-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); [ -n \"$pw\" ] && au=\"-u admin-user -p $pw --authenticationDatabase admin\"; n=$(P=\"\"; for _pi in $(seq 1 30); do P=$(kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet $t $au --eval '\\''rs.hello().primary'\\'' 2>/dev/null | cut -d. -f1); [ -n \"$P\" ] && break; sleep 2; don