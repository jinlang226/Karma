[precondition:mongo_config_baseline_ready:preconditionUnits[3] 'mongo_config_baseline_ready':probe] $ /bin/sh -c '
t=""; for cca in /etc/tls/ca.crt /etc/mongo-ca/ca.crt; do kubectl -n mongodb exec mongodb-replica-0 -- ls $cca >/dev/null 2>&1 && { t="--tls --tlsAllowInvalidHostnames --tlsAllowInvalidCertificates --tlsCAFile $cca"; break; }; done
pw=$(kubectl -n mongodb get secret admin-user-password -o jsonpath="{.data.password}" 2>/dev/null | base64 -d 2>/dev/null); pw=${pw:-admin123password}
base_v=1; base_s=200
ok=1
for i in 0 1 2; do
  out=$(kubectl -n mongodb exec mongodb-replica-$i -- mongosh --quiet $t "mongodb://admin-user:$pw@localhost:27017/admin?directConnection=true" --eval "var o=db.adminCommand({getCmdLineOpts:1}).parsed||{}; var v=(o.systemLog&&o.systemLog.verbosity!=null)?o.systemLog.verbosity:db.adminCommand({getParameter:1,logLevel:1}).logLevel; var s=(o.operationProfiling&&o.operationProfiling.slowOpThresholdMs!=null)?o.operationProfiling.slowOpThresholdMs:db.getProfilingStatus().slowms; print(v+\"|\"+s)" 2>/dev/null)
  v=$(echo "$out" | cut -d"|" -f1); s=$(echo "$out" | cut -d"|" -f2)
  if [ "$v" = "$base_v" ] && [ "$s" = "$base_s" ]; then :; else ok=0; fi
done
[ "$ok" = "1" ]
'


[precondition:mongo_config_baseline_ready:preconditionUnits[3] 'mongo_config_baseline_ready':apply] $ /bin/sh -c '
cm=mongod-config
cur=$(kubectl -n mongodb get configmap $cm -o jsonpath="{.data.mongod\.conf}" 2>/dev/null)
[ -n "$cur" ] || exit 0
new=$(printf "%s" "$cur" | sed -E "s/(verbosity:[[:space:]]*)[0-9]+/\11/; s/(slowOpThresholdMs:[[:space:]]*)[0-9]+/\1200/")
kubectl -n mongodb create configmap $cm --from-literal=mongod.conf="$new" --dry-run=client -o yaml | kubectl -n mongodb apply -f - >/dev/null 2>&1 || true
'


