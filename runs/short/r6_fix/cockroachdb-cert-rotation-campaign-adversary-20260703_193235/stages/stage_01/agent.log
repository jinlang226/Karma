etes.io/name: cockroachdb\n        app.kubernetes.io/instance: crdb-cluster\n    spec:\n      serviceAccountName: crdb-cluster-sa\n      terminationGracePeriodSeconds: 60\n      containers:\n        - name: cockroachdb\n          image: cockroachdb/cockroach:v24.1.0\n          imagePullPolicy: IfNotPresent\n          ports:\n            - name: grpc\n              containerPort: 26257\n            - name: http\n              containerPort: 8080\n          command:\n            - /bin/bash\n            - -ecx\n            - |\n              exec /cockroach/cockroach start \\\n                --insecure \\\n                --advertise-addr=$(hostname -f) \\\n                --http-addr=0.0.0.0 \\\n                --listen-addr=0.0.0.0 \\\n                --join=crdb-cluster-0.crdb-cluster.cockroachdb.svc.cluster.local:26257,crdb-cluster-1.crdb-cluster.cockroachdb.svc.cluster.local:26257,crdb-cluster-2.crdb-cluster.cockroachdb.svc.cluster.local:26257 \\\n                --logtostderr=WARNING\n          env:\n            - name: COCKROACH_CHANNEL\n              value: kubernetes-helm\n          volumeMounts:\n            - name: datadir\n              mountPath: /cockroach/cockroach-data\n          livenessProbe:\n            httpGet:\n              path: /health\n              port: http\n              scheme: HTTP\n            initialDelaySeconds: 30\n            periodSeconds: 5\n          readinessProbe:\n            httpGet:\n              path: /health?ready=1\n              port: http\n              scheme: HTTP\n            initialDelaySeconds: 10\n            periodSeconds: 5\n            failureThreshold: 2\n  volumeClaimTemplates:\n    - metadata:\n        name: datadir\n      spec:\n        accessModes: [\"ReadWriteOnce\"]\n        resources:\n          requests:\n            storage: 10Gi\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":289,"cache_read_input_