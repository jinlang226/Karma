$ /bin/sh -c "! kubectl -n mongodb get configmap mongod-config -o jsonpath='{.data.mongod\.conf}' 2>/dev/null | grep -q systemLog"

$ /bin/sh -c '
conf=$(kubectl -n mongodb get configmap mongod-config-adv-backup -o jsonpath="{.data.mongod\.conf}" 2>/dev/null)
if [ -n "$conf" ]; then
  printf "%s" "$conf" > /tmp/adv-mongod-conf-restore
  kubectl -n mongodb create configmap mongod-config \
    --from-file=mongod.conf=/tmp/adv-mongod-conf-restore \
    --dry-run=client -o yaml | kubectl -n mongodb apply -f -
else
  kubectl -n mongodb apply -f cases/mongodb/mongod-config-update/resource/configmap.yaml
fi
'

configmap/mongod-config created

$ kubectl -n mongodb delete configmap mongod-config-adv-backup --ignore-not-found

$ kubectl -n mongodb get configmap mongod-config -o jsonpath='{.data.mongod\.conf}'
storage:
  dbPath: /data/db
  wiredTiger:
    engineConfig:
      journalCompressor: zlib
net:
  bindIpAll: true
replication:
  replSetName: mongodb-replica
security:
  authorization: enabled
  keyFile: /etc/mongo-keyfile/keyfile
systemLog:
  verbosity: 1
operationProfiling:
  mode: slowOp
  slowOpThresholdMs: 200

