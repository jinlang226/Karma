admin-user -p admin123password --authenticationDatabase admin --eval '\n        db = db.getSiblingDB(\"appdb\");\n        db.createUser({\n          user: \"app-user\",\n          pwd: \"app123password\",\n          roles: [{ role: \"readWrite\", db: \"appdb\" }]\n        });\n      ' --quiet 2>/dev/null || true\n\n      echo \"Init complete.\"\n    fi\n\n    # Keep container running\n    tail -f /dev/null\nEOF","description":"Create init script ConfigMap"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":190,"cache_read_input_tokens":29316,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":190},"output_tokens":59,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"6c8735d2-97db-4305-ae12-ba235fd02c27","uuid":"504b0622-d171-4678-91ba-3d42b260bcb9","request_id":"req_011Ccg6sojCYuGvaeDALRjz9"}
