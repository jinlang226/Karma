{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_015D25xSrBReUxv3DQSJVJwD","type":"tool_result","content":"apiVersion: v1\ndata:\n  init-replica.sh: |\n    #!/bin/bash\n    set -e\n\n    # Wait until mongod is accepting connections (unauthenticated, before auth is enforced)\n    until mongosh --host localhost --port 27017 --eval \"db.adminCommand('ping')\" --quiet 2>/dev/null; do\n      echo \"Waiting for mongod...\"\n      sleep 2\n    done\n\n    # Only the first pod initiates the replica set\n    if [[ \"$HOSTNAME\" == \"mongodb-replica-0\" ]]; then\n      echo \"Initiating replica set...\"\n      mongosh --host localhost --port 27017 --eval '\n        rs.initiate({\n          _id: \"mongodb-replica\",\n          members: [\n            { _id: 0, host: \"mongodb-replica-0.mongodb-replica-svc.mongodb.svc.cluster.local:27017\" },\n            { _id: 1, host: \"mongodb-replica-1.mongodb-replica-svc.mongodb.svc.cluster.local:27017\" },\n            { _id: 2, host: \"mongodb-replica-2.mongodb-replica-svc.mongodb.svc.cluster.local:27017\" }\n          ]\n        })\n      ' --quiet 2>/dev/null || true\n\n      # Wait for PRIMARY\n      echo \"Waiting for PRIMARY...\"\n      until mongosh --host localhost --port 27017 --eval \"rs.status().myState\" --quiet 2>/dev/null | grep -q \"^1$\"; do\n        sleep 3\n      done\n\n      echo \"Creating admin user...\"\n      mongosh --host localhost --port 27017 --eval '\n        db = db.getSiblingDB(\"admin\");\n        db.createUser({\n          user: \"admin-user\",\n          pwd: \"admin123password\",\n          roles: [{ role: \"root\", db: \"admin\" }]\n        });\n      ' --quiet 2>/dev/null || true\n\n      echo \"Creating app user...\"\n      mongosh --host localhost --port 27017 -u admin-user -p admin123password --authenticationDatabase admin --eval '\n        db = db.getSiblingDB(\"appdb\");\n        db.createUser({\n          user: \"app-user\",\n          pwd: \"app123password\",\n          roles: [{ role: \"readWrite\", db: \"appdb\" }]\n        });\n      ' --quiet 2>/dev/null || true\n\n      echo \"Init complete.\"\n    fi\n\n    # Keep container running\n    tail -f /dev/null\nkind: ConfigMap\nmetadata:\n  annotations:\n    kubectl.kubernetes.io/last-applied-configuration: |\n      {\"apiVersion\":\"v1\",\"data\":{\"init-replica.sh\":\"#!/bin/bash\\nset -e\\n\\n# Wait until mongod is accepting connections (unauthenticated, before auth is enforced)\\nuntil mongosh --host localhost --port 27017 --eval \\\"db.adminCommand('ping')\\\" --quiet 2\\u003e/dev/null; do\\n  echo \\\"Waiting for mongod...\\\"\\n  sleep 2\\ndone\\n\\n# Only the first pod initiates the replica set\\nif [[ \\\"$HOSTNAME\\\" == \\\"mongodb-replica-0\\\" ]]; then\\n  echo \\\"Initiating replica set...\\\"\\n  mongosh --host localhost --port 27017 --eval '\\n    rs.initiate({\\n      _id: \\\"mongodb-replica\\\",\\n      members: [\\n        { _id: 0, host: \\\"mongodb-replica-0.mongodb-replica-svc.mongodb.svc.cluster.local:27017\\\" },\\n        { _id: 1, host: \\\"mongodb-replica-1.mongodb-replica-svc.mongodb.svc.cluster.local:27017\\\" },\\n        { _id: 2, host: \\\"mongodb-replica-2.mongodb-replica-svc.mongodb.svc.cluster.local:27017\\\" }\\n      ]\\n    })\\n  ' --quiet 2\\u003e/dev/null || true\\n\\n  # Wait for PRIMARY\\n  echo \\\"Waiting for PRIMARY...\\\"\\n  until mongosh --host localhost --port 27017 --eval \\\"rs.status().myState\\\" --quiet 2\\u003e/dev/null | grep -q \\\"^1$\\\"; do\\n    sleep 3\\n  done\\n\\n  echo \\\"Creating admin user...\\\"\\n  mongosh --host localhost --port 27017 --eval '\\n    db = db.getSiblingDB(\\\"admin\\\");\\n    db.createUser({\\n      user: \\\"admin-user\\\",\\n      pwd: \\\"admin123password\\\",\\n      roles: [{ role: \\\"root\\\", db: \\\"admin\\\" }]\\n    });\\n  ' --quiet 2\\u003e/dev/null || true\\n\\n  echo \\\"Creating app user...\\\"\\n  mongosh --host localhost --port 27017 -u admin-user -p admin123password --authen