[precondition:establish_cert_baseline:preconditionUnits[1] 'establish_cert_baseline':probe] $ /bin/sh -c '
cm=$(kubectl -n cockroachdb get configmap crdb-old-cert -o jsonpath="{.data.fingerprint}" 2>/dev/null)
[ -n "$cm" ] || exit 1
live=$(kubectl -n cockroachdb get secret crdb-cluster-certs -o jsonpath="{.data.node\.crt}" 2>/dev/null | base64 -d 2>/dev/null | openssl x509 -noout -fingerprint -sha256 2>/dev/null | sed "s/.*=//")
[ -n "$live" ] && [ "$cm" = "$live" ]
'


