{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_014RU6EssnbewBRuGHXw3Mut","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport json\n3\timport os\n4\timport re\n5\timport subprocess\n6\timport sys\n7\t\n8\t\n9\tNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"elasticsearch\")\n10\tSERVICE = os.environ.get(\"BENCH_PARAM_HTTP_SERVICE_NAME\", \"es-http\")\n11\t# Hint for the Elasticsearch pod app label. Used as an override when it matches a\n12\t# live StatefulSet's selector; otherwise the real selector label is detected\n13\t# live from the cluster. The env PERSISTS across stages, so a workflow's\n14\t# inherited ES cluster may label its pods differently than this case's standalone\n15\t# default of 'es-cluster'.\n16\tCLUSTER_PREFIX_HINT = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"es-cluster\")\n17\t# ES 8.x runs with security enabled, so the HTTP API requires authenticating as\n18\t# the elastic superuser. When this case inherits a secured cluster from an\n19\t# earlier workflow stage, read its password from the secret that stage created\n20\t# so the oracle's queries aren't rejected with 401. Absent secret -> None -> no\n21\t# -u, so a standalone unsecured cluster still works.\n22\tPASSWORD_SECRET = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_SECRET_NAME\", \"elastic-password\")\n23\tPASSWORD_KEY = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_KEY\", \"password\")\n24\tdef _password_from_sts():\n25\t    \"\"\"Fall back to a live ES StatefulSet's ELASTIC_PASSWORD env when the\n26\t    elastic-password secret is absent (skip-gated on an inherited cluster), so\n27\t    the oracle authenticates instead of 401-ing (C1). Reads the literal env\n28\t    value, or resolves its secretKeyRef; returns the password or None.\"\"\"\n29\t    import base64\n30\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n31\t    if res.returncode != 0:\n32\t        return None\n33\t    try:\n34\t        items = json.loads(res.stdout).get(\"items\", [])\n35\t    except (json.JSONDecodeError, AttributeError):\n36\t        return None\n37\t    for sts in items:\n38\t        spec = sts.get(\"spec\", {}) or {}\n39\t        containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", []) or []\n40\t        if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n41\t            continue\n42\t        for c in containers:\n43\t            for e in c.get(\"env\", []) or []:\n44\t                if e.get(\"name\") != \"ELASTIC_PASSWORD\":\n45\t                    continue\n46\t                if e.get(\"value\"):\n47\t                    return e[\"value\"]\n48\t                ref = (e.get(\"valueFrom\", {}) or {}).get(\"secretKeyRef\", {}) or {}\n49\t                name = ref.get(\"name\")\n50\t                if name:\n51\t                    rs = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", name,\n52\t                              \"-o\", \"jsonpath={.data.\" + (ref.get(\"key\") or \"password\") + \"}\"])\n53\t                    if rs.returncode == 0 and rs.stdout.strip():\n54\t                        try:\n55\t                            return base64.b64decode(rs.stdout.strip()).decode()\n56\t                        except Exception:\n57\t                            pass\n58\t    return None\n59\t\n60\t\n61\tELASTIC_PASSWORD = None  # set in main() once kubectl is reachable\n62\t\n63\t\n64\tdef _elastic_password():\n65\t    \"\"\"Fetch the elastic-user password from its secret (base64-decoded), or None.\"\"\"\n66\t    import base64\n67\t    r = _run_for_label([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", PASSWORD_SECRET,\n68\t                        \"-o\", \"jsonpath={.data.\" + PASSWORD_KEY + \"}\"])\n69\t    if r.returncode != 0 or not r.stdout.strip():\n70\t        return None\n71\t    try:\n72\t        return base64.b64decode(r.stdout.strip()).decode()\n73\t    except Exception:\n74\t        return None\n75\t\n76\t\n77\tdef _run_for_label(cmd):\n78\t    \"\"\"Minimal subprocess runner used by label detection (mirrors run()).\"\"\"\n79\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n80\t\n81\t\n82\t_APP_LABEL = None\n83\t\n84\t\n85\tdef resolve_app_label():\n86\t    \"\"\"Resolve the 'app=<value>' selector for the live ES pods.\n87\t\n88\t    Priority: the BENCH_PARAM_CLUSTER_PREFIX hint when some live StatefulSet\n89\t    actually selects on app=<hint> (explicit override wins) -> the app label of\n90\t    the namespace's Elasticsearch StatefulSet detected live -> the hint.\n91\t    Workflow-agnostic: adapts to an inherited cluster labelled e.g.\n92\t    app=elasticsearch instead of app=es-cluster.\n93\t    \"\"\"\n94\t    global _APP_LABEL\n95\t    if _APP_LABEL is not None:\n96\t        return _APP_LABEL\n97\t    res = _run_for_label([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n98\t    labels = []\n99\t    if res.returncode == 0:\n100\t        try:\n101\t            for sts in json.loads(res.stdout).get(\"items\", []):\n102\t                spec = sts.get(\"spec\", {})\n103\t                containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n104\t                if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n105\t                    continue\n106\t                app = (spec.get(\"selector\", {}).get(\"matchLabels\", {}) or {}).get(\"app\")\n107\t                ts = sts.get(\"metadata\", {}).get(\"creationTimestamp\", \"\")\n108\t                if app:\n109\t                    labels.append((app, ts))\n110\t        except (json.JSONDecodeError, AttributeError):\n111\t            pass\n112\t    if any(app == CLUSTER_PREFIX_HINT for app, _ in labels):\n113\t        _APP_LABEL = f\"app={CLUSTER_PREFIX_HINT}\"\n114\t        return _APP_LABEL\n115\t    if labels:\n116\t        labels.sort(key=lambda x: (x[1] or \"\"))\n117\t        _APP_LABEL = f\"app={labels[0][0]}\"\n118\t        return _APP_LABEL\n119\t    _APP_LABEL = f\"app={CLUSTER_PREFIX_HINT}\"\n120\t    return _APP_LABEL\n121\t\n122\t\n123\tAPP_LABEL = resolve_app_label()\n124\t\n125\t\n126\tdef _list_es_statefulset_replicas():\n127\t    \"\"\"Return {sts_name: spec.replicas} for the namespace's Elasticsearch\n128\t    StatefulSets (those whose pod template runs an Elasticsearch image).\"\"\"\n129\t    res = subprocess.run(\n130\t        [\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"],\n131\t        text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE,\n132\t    )\n133\t    if res.returncode != 0:\n134\t        return {}\n135\t    try:\n136\t        items = json.loads(res.stdout).get(\"items\", [])\n137\t    except (json.JSONDecodeError, AttributeError):\n138\t        return {}\n139\t    out = {}\n140\t    for sts in items:\n141\t        spec = sts.get(\"spec\", {})\n142\t        containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n143\t        if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n144\t            continue\n145\t        name = sts.get(\"metadata\", {}).get(\"name\")\n146\t        replicas = spec.get(\"replicas\")\n147\t        if name and isinstance(replicas, int):\n148\t            out[name] = replicas\n149\t    return out\n150\t\n151\t\n152\tdef _sts_name_for_node(node_name):\n153\t    \"\"\"Map a live ES node name to its backing StatefulSet name.\n154\t\n155\t    An ES node name equals its pod name, which for a StatefulSet pod is\n156\t    ``<statefulset-name>-<ordinal>`` (e.g. ``es-cluster-0`` -> ``es-cluster``,\n157\t    ``es-data-1`` -> ``es-data``). Strip the trailing ``-<digits>`` ordinal.\n158\t    Returns the node name unchanged if it carries no ordinal suffix.\n159\t    \"\"\"\n160\t    if not node_name:\n161\t        return node_name\n162\t    return re.sub(r\"-\\d+$\", \"\", node_name)\n163\t\n164\t\n165\tdef _live_sts_names(node_names):\n166\t    \"\"\"Set of StatefulSet names actually backing the live cluster nodes.\n167\t\n168\t    Derived by stripping each live node name's ordinal. This excludes\n169\t    accumulated/stale/other ES StatefulSets in the (persisted) namespace that\n170\t    back no node in the queried cluster.\n171\t    \"\"\"\n172\t    return {_sts_name_for_node(n) for n in node_names if n}\n173\t\n174\t\n175\tdef _resolve_expected_nodes(node_names, default=3):\n176\t    \"\"\"Expected node count to enforce, derived from the LIVE cluster.\n177\t\n178\t    The expected total is the DESIRED topology of ONLY the StatefulSets that\n179\t    actually back the live cluster (the nodes returned by ``_cat/nodes``): the\n180\t    sum of spec.replicas over just those StatefulSets. The namespace PERSISTS\n181\t    across workflow stages and accumulates multiple ES clusters, so summing\n182\t    replicas across *every* ES StatefulSet overcounts versus the single cluster\n183\t    the oracle queries. Restricting to the live cluster's StatefulSets fixes that.\n184\t\n185\t    Using DESIRED spec.replicas (not the live count) keeps the check strict: a\n186\t    node that FAILED to join leaves its StatefulSet \"live\" (siblings are up) but\n187\t    absent from ``_cat/nodes``, so EXPECTED stays above the actual count -- no\n188\t    masking. The LIVE cluster is derived FIRST; the param is a FALLBACK used only\n189\t    when no live StatefulSets resolve (e.g. _cat/nodes failed or returned empty).\n190\t    \"\"\"\n191\t    # Derive from the LIVE cluster FIRST (workflow-agnostic + composition-aware):\n192\t    # sum spec.replicas over the active ES StatefulSets -- the base cluster PLUS\n193\t    # any nodeset a PRIOR stage added to the same cluster (e.g. an inherited\n194\t    # transform nodeset). A static EXPECTED_NODES param encodes a standalone\n195\t    # baseline that wrongly ignores such inherited nodesets, so it is demoted to a\n196\t    # FALLBACK below, used only when the live cluster cannot be resolved.\n197\t    # Scope the sum to ONLY the ES StatefulSets that actually back a live node\n198\t    # returned by ``_cat/nodes`` (the queried cluster). The namespace PERSISTS and\n199\t    # ACCUMULATES several ES clusters/nodesets across stages; summing spec.replicas\n200\t    # over *every* ES StatefulSet overcounts the single cluster the oracle queries.\n201\t    # Mapping each live node name -> its StatefulSet (strip the pod ordinal) scopes\n202\t    # the sum. Using DESIRED spec.replicas stays strict: a node that failed to join\n203\t    # leaves its STS live but absent from _cat/nodes, so the sum exceeds the count.\n204\t    live_sts = _live_sts_names(node_names)\n205\t    if live_sts:\n206\t        res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n207\t        if res.returncode == 0:\n208\t            try:\n209\t                items = json.loads(res.stdout).get(\"items\", [])\n210\t            except Exception:\n211\t                items = []\n212\t            desired = 0\n213\t            for sts in items:\n214\t                spec = sts.get(\"spec\", {}) or {}\n215\t                name = (sts.get(\"metadata\", {}) or {}).get(\"name\")\n216\t                if name not in live_sts:\n217\t                    continue\n218\t                containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", []) or []\n219\t                if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n220\t                    continue\n221\t                replicas = spec.get(\"replicas\")\n222\t                being_deleted = (sts.get(\"metadata\", {}) or {}).get(\"deletionTimestamp\") is not None\n223\t                if isinstance(replicas, int) and replicas > 0 and not being_deleted:\n224\t                    desired += replicas\n225\t            if desired > 0:\n226\t                return desired\n227\t\n228\t    # Fallbacks (live cluster unresolvable): explicit param, then the default.\n229\t    for key in (\"BENCH_PARAM_EXPECTED_NODES\", \"BENCH_PARAM_EXPECTED_NODE_COUNT\"):\n230\t        val = os.environ.get(key)\n231\t        if val is not None and str(val).strip():\n232\t            try:\n233\t                return int(val)\n234\t            except ValueError:\n235\t                pass\n236\t    return default\n237\t\n238\t\n239\t# Default scheme for the standalone case; may be flipped by _detect_scheme() when\n240\t# a prior workflow stage toggled xpack.security.http.ssl on this cluster.\n241\tDEFAULT_SCHEME = \"http\"\n242\t_SCHEME = None\n243\t\n244\t\n245\tdef run(cmd):\n246\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n247\t\n248\t\n249\tdef _probe_scheme(scheme):\n250\t    \"\"\"Return True if the ES HTTP API answers on the given scheme.\n251\t\n252\t    The env PERSISTS across stages, so the cluster's actual HTTP scheme may\n253\t    differ from this case's standalone default. A reachable endpoint answers\n254\t    even when auth is required (401/anything HTTP), so any non-empty body or a\n255\t    clean exit counts as 'this scheme is live'. -k tolerates the self-signed\n256\t    cert on https.\n257\t    \"\"\"\n258\t    result = run([\n259\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\",\n260\t        \"curl\", \"-s\", \"-S\", \"-k\", \"-o\", \"/dev/null\",\n261\t        \"-w\", \"%{http_code}\", \"--max-time\", \"5\",\n262\t        f\"{scheme}://{SERVICE}:9200/\",\n263\t    ])\n264\t    code = (result.stdout or \"\").strip()\n265\t    return result.returncode == 0 and code.isdigit() and code != \"000\"\n266\t\n267\t\n268\tdef detect_scheme():\n269\t    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n270\t    global _SCHEME\n271\t    if _SCHEME is not None:\n272\t        return _SCHEME\n273\t    order = [DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"]\n274\t    for scheme in order:\n275\t        if _probe_scheme(scheme):\n276\t            _SCHEME = scheme\n277\t            return _SCHEME\n278\t    _SCHEME = DEFAULT_SCHEME\n279\t    return _SCHEME\n280\t\n281\t\n282\tdef curl(path, errors):\n283\t    scheme = detect_scheme()\n284\t    # The client deadline must exceed any server-side ``wait_for`` in `path``,\n285\t    # otherwise curl aborts (exit 28) before ES can answer. The retry loop in\n286\t    # main() does the real waiting, so each call's server wait stays short (10s)\n287\t    # and --max-time (20) comfortably exceeds it.\n288\t    cmd = [\n289\t        \"kubectl\",\n290\t        \"-n\",\n291\t        NAMESPACE,\n292\t        \"exec\",\n293\t        \"curl-test\",\n294\t        \"--\",\n295\t        \"curl\",\n296\t        \"-s\",\n297\t        \"-S\",\n298\t        \"-k\",\n299\t    ]\n300\t    if ELASTIC_PASSWORD:\n301\t        cmd += [\"-u\", f\"elastic:{ELASTIC_PASSWORD}\"]\n302\t    cmd += [\n303\t        \"--max-time\",\n304\t        \"20\",\n305\t        f\"{scheme}://{SERVICE}:9200{path}\",\n306\t    ]\n307\t    result = run(cmd)\n308\t    if result.returncode != 0:\n309\t        stderr = result.stderr.strip()\n310\t        stdout = result.stdout.strip()\n311\t        detail = stderr or stdout or f\"command terminated with exit code {result.returncode}\"\n312\t        errors.append(f\"Failed to query {path}: {detail}\")\n313\t        return None\n314\t    output = result.stdout.strip()\n315\t    if not output:\n316\t        errors.append(f\"Empty response for {path}\")\n317\t        return None\n318\t    try:\n319\t        return json.loads(output)\n320\t    except json.JSONDecodeError:\n321\t        errors.append(f\"Failed to parse JSON from {path}\")\n322\t        return None\n323\t\n324\t\n325\tdef check_cluster(errors):\n326\t    \"\"\"Run the cluster-side checks; return the per-evaluate expected node count.\n327\t\n328\t    The expected node count is derived from the live cluster (the StatefulSets\n329\t    backing ``_cat/nodes``), so it is computed here after that query and returned\n330\t    to evaluate() for the pod-count assertion.\n331\t    \"\"\"\n332\t    # Resolve the live cluster's node list FIRST: the expected node count is\n333\t    # derived from only the StatefulSets that actually back these live nodes\n334\t    # (the persisted namespace accumulates several ES clusters across stages, so\n335\t    # summing every ES StatefulSet's replicas overcounts the queried cluster).\n336\t    nodes = curl(\"/_cat/nodes?format=json\", errors)\n337\t    node_names = []\n338\t    if isinstance(nodes, list):\n339\t        node_names = [n.get(\"name\") for n in nodes if n.get(\"name\")]\n340\t    expected_nodes = _resolve_expected_nodes(node_names, default=3)\n341\t\n342\t    ep_result = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"endpoints\", SERVICE, \"-o\", \"json\"])\n343\t    if ep_result.returncode != 0:\n344\t        errors.append(f\"Failed to read {SERVICE} endpoints: {ep_result.stderr.strip()}\")\n345\t    else:\n346\t        try:\n347\t            ep = json.loads(ep_result.stdout)\n348\t        except json.JSONDecodeError:\n349\t            errors.append(f\"Failed to parse {SERVICE} endpoints JSON\")\n350\t            ep = None\n351\t        if ep is not None:\n352\t            # O-funcready: a Service only lists a pod under subsets.addresses\n353\t            # once it is k8s-Ready; a serving-but-Ready-lagging ES node sits in\n354\t            # notReadyAddresses, so counting only addresses re-imposes the laggy\n355\t            # pod-Ready gate. Count BOTH so the check proves the pod is wired\n356\t            # into the Service (the real config deliverable), not that its\n357\t            # readiness probe has caught up. A node genuinely absent from the\n358\t            # Service is in neither list and still fails the count.\n359\t            addr_count = 0\n360\t            for subset in ep.get(\"subsets\", []) or []:\n361\t                addr_count += len(subset.get(\"addresses\", []) or [])\n362\t                addr_count += len(subset.get(\"notReadyAddresses\", []) or [])\n363\t            if addr_count != expected_nodes:\n364\t                errors.append(f\"Expected {expected_nodes} endpoints, got {addr_count}\")\n365\t\n366\t    health = curl(\n367\t        f\"/_cluster/health?wait_for_status=yellow&wait_for_nodes={expected_nodes}&timeout=10s\",\n368\t        errors,\n369\t    )\n370\t    if isinstance(health, dict):\n371\t        status = health.get(\"status\")\n372\t        if status not in {\"yellow\", \"green\"}:\n373\t            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n374\t        if health.get(\"number_of_nodes\") != expected_nodes:\n375\t            errors.append(f\"Expected {expected_nodes} nodes, got {health.get('number_of_nodes')}\")\n376\t\n377\t    root = curl(\"/\", errors)\n378\t    if isinstance(root, dict):\n379\t        uuid = root.get(\"cluster_uuid\")\n380\t        if not uuid or uuid == \"_na_\":\n381\t            errors.append(\"Cluster UUID not set\")\n382\t\n383\t    if isinstance(nodes, list) and len(node_names) != expected_nodes:\n384\t        errors.append(f\"Expected {expected_nodes} nodes in _cat/nodes, got {len(node_names)}\")\n385\t\n386\t    return expected_nodes\n387\t\n388\t\n389\tdef evaluate():\n390\t    \"\"\"Run one full snapshot of the bootstrap checks; return the list of errors.\"\"\"\n391\t    errors = []\n392\t\n393\t    cm_result = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"configmap\", \"es-config\", \"-o\", \"json\"])\n394\t    if cm_result.returncode != 0:\n395\t        errors.append(f\"Failed to read es-config ConfigMap: {cm_result.stderr.strip()}\")\n396\t    else:\n397\t        try:\n398\t            cm = json.loads(cm_result.stdout)\n399\t        except json.JSONDecodeError:\n400\t            errors.append(\"Failed to parse es-config ConfigMap JSON\")\n401\t            cm = {}\n402\t        config = cm.get(\"data\", {}).get(\"elasticsearch.yml\", \"\")\n403\t        if \"cluster.initial_master_nodes\" in config:\n404\t            errors.append(\"cluster.initial_master_nodes still present in es-config\")\n405\t\n406\t    # Cluster-side checks run first so the live-cluster expected node count can\n407\t    # be reused by the pod-count assertion below.\n408\t    expected_nodes = check_cluster(errors)\n409\t\n410\t    pods_result = run(\n411\t        [\"kubectl\", \"-n\", NAMESPACE, \"get\", \"pods\", \"-l\", APP_LABEL, \"-o\", \"json\"]\n412\t    )\n413\t    if pods_result.returncode != 0:\n414\t        errors.append(f\"Failed to read pods: {pods_result.stderr.strip()}\")\n415\t    else:\n416\t        try:\n417\t            pods = json.loads(pods_result.stdout)\n418\t        except json.JSONDecodeError:\n419\t            errors.append(\"Failed to parse pods JSON\")\n420\t            pods = {}\n421\t        items = pods.get(\"items\", []) if isinstance(pods, dict) else []\n422\t        if len(items) != expected_nodes:\n423\t            errors.append(f\"Expected {expected_nodes} pods, got {len(items)}\")\n424\t        # O-funcready: do NOT gate the verdict on the k8s pod-`Ready` bit. An ES\n425\t        # node serves (and joins the cluster as a master/data node) before -- and\n426\t        # can dip back below -- its HTTP readiness probe during GC or shard\n427\t        # recovery, so asserting all N pods carry the Ready condition false-fails\n428\t        # a cluster that already bootstrapped and serves N nodes. The DELIVERABLE\n429\t        # (the cluster bootstrapped and serves N nodes) is graded functionally in\n430\t        # check_cluster: `_cat/nodes` count, `_cluster/health` (yellow/green,\n431\t        # number_of_nodes == N), and cluster_uuid set. Pod existence is still\n432\t        # asserted above; a node that never joins drops the node count and fails.\n433\t\n434\t    return errors\n435\t\n436\t\n437\tdef main():\n438\t    global ELASTIC_PASSWORD\n439\t    ELASTIC_PASSWORD = _elastic_password()\n440\t\n441\t    # A multi-node ES cluster can flap at the edge of readiness under load: a\n442\t    # node briefly fails its HTTP readiness probe during GC or shard recovery\n443\t    # even though the cluster is stably green (writes succeed). A single snapshot\n444\t    # can catch that transient and report a false \"2/3 Ready\" / node-count miss.\n445\t    # So verify the STABLE converged state: re-evaluate for up to ~75s and pass\n446\t    # as soon as one clean snapshot is seen. This does not loosen the\n447\t    # N-node/green requirement -- a genuinely degraded cluster (a node that never\n448\t    # joins) fails every attempt and still fails the oracle.\n449\t    import time\n450\t    deadline = time.monotonic() + 75\n451\t    errors = evaluate()\n452\t    while errors and time.monotonic() < deadline:\n453\t        time.sleep(8)\n454\t        errors = evaluate()\n455\t\n456\t    if errors:\n457\t        print(\"Bootstrap verification failed:\", file=sys.stderr)\n458\t        for err in errors:\n459\t            print(f\"  - {err}\", file=sys.stderr)\n460\t        return 1\n461\t\n462\t    print(\"Bootstrap initial master nodes verified\")\n463\t    return 0\n464\t\n465\t\n466\tif __name__ == \"__main__\":\n467\t    sys.exit(main())\n468\t"}]},"parent_tool_use_id":null,"session_id":"62badd50-a48f-465e-bdb3-22c353b19308","uuid":"d65e0c58-4890-447e-9127-c5d386fa4445","timestamp":"2026-07-03T20:38:50.917Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/elasticsearch/bootstrap-initial-master-nodes/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport json\nimport os\nimport re\nimport subprocess\nimport sys\n\n\nNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"elasticsearch\")\nSERVICE = os.environ.get(\"BENCH_PARAM_HTTP_SERVICE_NAME\", \"es-http\")\n# Hint for the Elasticsearch pod app label. Used as an override when it matches a\n# live StatefulSet's selector; otherwise the real selector label is detected\n# live from the cluster. The env PERSISTS across stages, so a workflow's\n# inherited ES cluster may label its pods differently than this case's standalone\n# default of 'es-cluster'.\nCLUSTER_PREFIX_HINT = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"es-cluster\")\n# ES 8.x runs with security enabled, so the HTTP API requires authenticating as\n# the elastic superuser. When this case inherits a secured cluster from an\n# earlier workflow stage, read its password from the secret that stage created\n# so the oracle's queries aren't rejected with 401. Absent secret -> None -> no\n# -u, so a standalone unsecured cluster still works.\nPASSWORD_SECRET = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_SECRET_NAME\", \"elastic-password\")\nPASSWORD_KEY = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_KEY\", \"password\")\ndef _password_from_sts():\n    \"\"\"Fall back to a live ES StatefulSet's ELASTIC_PASSWORD env when the\n    elastic-password secret is absent (skip-gated on an inherited cluster), so\n    the oracle authenticates instead of 401-ing (C1). Reads the literal env\n    value, or resolves its secretKeyRef; returns the password or None.\"\"\"\n    import base64\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n    if res.returncode != 0:\n        return None\n    try:\n        items = json.loads(res.stdout).get(\"items\", [])\n    except (json.JSONDecodeError, AttributeError):\n        return None\n    for sts in items:\n        spec = sts.get(\"spec\", {}) or {}\n        containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", []) or []\n        if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n            continue\n        for c in containers:\n            for e in c.get(\"env\", []) or []:\n                if e.get(\"name\") != \"ELASTIC_PASSWORD\":\n                    continue\n                if e.get(\"value\"):\n                    return e[\"value\"]\n                ref = (e.get(\"valueFrom\", {}) or {}).get(\"secretKeyRef\", {}) or {}\n                name = ref.get(\"name\")\n                if name:\n                    rs = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", name,\n                              \"-o\", \"jsonpath={.data.\" + (ref.get(\"key\") or \"password\") + \"}\"])\n                    if rs.returncode == 0 and rs.stdout.strip():\n                        try:\n                            return base64.b64decode(rs.stdout.strip()).decode()\n                        except Exception:\n                            pass\n    return None\n\n\nELASTIC_PASSWORD = None  # set in main() once kubectl is reachable\n\n\ndef _elastic_password():\n    \"\"\"Fetch the elastic-user password from its secret (base64-decoded), or None.\"\"\"\n    import base64\n    r = _run_for_label([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", PASSWORD_SECRET,\n                        \"-o\", \"jsonpath={.data.\" + PASSWORD_KEY + \"}\"])\n    if r.returncode != 0 or not r.stdout.strip():\n        return None\n    try:\n        return base64.b64decode(r.stdout.strip()).decode()\n    except Exception:\n        return None\n\n\ndef _run_for_label(cmd):\n    \"\"\"Minimal subprocess runner used by label detection (mirrors run()).\"\"\"\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\n_APP_LABEL = None\n\n\ndef resolve_app_label():\n    \"\"\"Resolve the 'app=<value>' selector for the live ES pods.\n\n    Priority: the BENCH_PARAM_CLUSTER_PREFIX hint when some live StatefulSet\n    actually selects on app=<hint> (explicit override wins) -> the app label of\n    the namespace's Elasticsearch StatefulSet detected live -> the hint.\n    Workflow-agnostic: adapts to an inherited cluster labelled e.g.\n    app=elasticsearch instead of app=es-cluster.\n    \"\"\"\n    global _APP_LABEL\n    if _APP_LABEL is not None:\n        return _APP_LABEL\n    res = _run_for_label([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n    labels = []\n    if res.returncode == 0:\n        try:\n            for sts in json.loads(res.stdout).get(\"items\", []):\n                spec = sts.get(\"spec\", {})\n                containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n                if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n                    continue\n                app = (spec.get(\"selector\", {}).get(\"matchLabels\", {}) or {}).get(\"app\")\n                ts = sts.get(\"metadata\", {}).get(\"creationTimestamp\", \"\")\n                if app:\n                    labels.append((app, ts))\n        except (json.JSONDecodeError, AttributeError):\n            pass\n    if any(app == CLUSTER_PREFIX_HINT for app, _ in labels):\n        _APP_LABEL = f\"app={CLUSTER_PREFIX_HINT}\"\n        return _APP_LABEL\n    if labels:\n        labels.sort(key=lambda x: (x[1] or \"\"))\n        _APP_LABEL = f\"app={labels[0][0]}\"\n        return _APP_LABEL\n    _APP_LABEL = f\"app={CLUSTER_PREFIX_HINT}\"\n    return _APP_LABEL\n\n\nAPP_LABEL = resolve_app_label()\n\n\ndef _list_es_statefulset_replicas():\n    \"\"\"Return {sts_name: spec.replicas} for the namespace's Elasticsearch\n    StatefulSets (those whose pod template runs an Elasticsearch image).\"\"\"\n    res = subprocess.run(\n        [\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"],\n        text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE,\n    )\n    if res.returncode != 0:\n        return {}\n    try:\n        items = json.loads(res.stdout).get(\"items\", [])\n    except (json.JSONDecodeError, AttributeError):\n        return {}\n    out = {}\n    for sts in items:\n        spec = sts.get(\"spec\", {})\n        containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n        if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n            continue\n        name = sts.get(\"metadata\", {}).get(\"name\")\n        replicas = spec.get(\"replicas\")\n        if name and isinstance(replicas, int):\n            out[name] = replicas\n    return out\n\n\ndef _sts_name_for_node(node_name):\n    \"\"\"Map a live ES node name to its backing StatefulSet name.\n\n    An ES node name equals its pod name, which for a StatefulSet pod is\n    ``<statefulset-name>-<ordinal>`` (e.g. ``es-cluster-0`` -> ``es-cluster``,\n    ``es-data-1`` -> ``es-data``). Strip the trailing ``-<digits>`` ordinal.\n    Returns the node name unchanged if it carries no ordinal suffix.\n    \"\"\"\n    if not node_name:\n        return node_name\n    return re.sub(r\"-\\d+$\", \"\", node_name)\n\n\ndef _live_sts_names(node_names):\n    \"\"\"Set of StatefulSet names actually backing the live cluster nodes.\n\n    Derived by stripping each live node name's ordinal. This excludes\n    accumulated/stale/other ES StatefulSets in the (persisted) namespace that\n    back no node in the queried cluster.\n    \"\"\"\n    return {_sts_name_for_node(n) for n in node_names if n}\n\n\ndef _resolve_expected_nodes(node_names, default=3):\n    \"\"\"Expected node count to enforce, derived from the LIVE cluster.\n\n    The expected total is the DESIRED topology of ONLY the StatefulSets that\n    actually back the live cluster (the nodes returned by ``_cat/nodes``): the\n    sum of spec.replicas over just those StatefulSets. The namespace PERSISTS\n    across workflow stages and accumulates multiple ES clusters, so summing\n    replicas across *every* ES StatefulSet overcounts versus the single cluster\n    the oracle queries. Restricting to the live cluster's StatefulSets fixes that.\n\n    Using DESIRED spec.replicas (not the live count) keeps the check strict: a\n    node that FAILED to join leaves its StatefulSet \"live\" (siblings are up) but\n    absent from ``_cat/nodes``, so EXPECTED stays above the actual count -- no\n    masking. The LIVE cluster is derived FIRST; the param is a FALLBACK used only\n    when no live StatefulSets resolve (e.g. _cat/nodes failed or returned empty).\n    \"\"\"\n    # Derive from the LIVE cluster FIRST (workflow-agnostic + composition-aware):\n    # sum spec.replicas over the active ES StatefulSets -- the base cluster PLUS\n    # any nodeset a PRIOR stage added to the same cluster (e.g. an inherited\n    # transform nodeset). A static EXPECTED_NODES param encodes a standalone\n    # baseline that wrongly ignores such inherited nodesets, so it is demoted to a\n    # FALLBACK below, used only when the live cluster cannot be resolved.\n    # Scope the sum to ONLY the ES StatefulSets that actually back a live node\n    # returned by ``_cat/nodes`` (the queried cluster). The namespace PERSISTS and\n    # ACCUMULATES several ES clusters/nodesets across stages; summing spec.replicas\n    # over *every* ES StatefulSet overcounts the single cluster the oracle queries.\n    # Mapping each live node name -> its StatefulSet (strip the pod ordinal) scopes\n    # the sum. Using DESIRED spec.replicas stays strict: a node that failed to join\n    # leaves its STS live but absent from _cat/nodes, so the sum exceeds the count.\n    live_sts = _live_sts_names(node_names)\n    if live_sts:\n        res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n        if res.returncode == 0:\n            try:\n                items = json.loads(res.stdout).get(\"items\", [])\n            except Exception:\n                items = []\n            desired = 0\n            for sts in items:\n                spec = sts.get(\"spec\", {}) or {}\n                name = (sts.get(\"metadata\", {}) or {}).get(\"name\")\n                if name not in live_sts:\n                    continue\n                containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", []) or []\n                if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n                    continue\n                replicas = spec.get(\"replicas\")\n                being_deleted = (sts.get(\"metadata\", {}) or {}).get(\"deletionTimestamp\") is not None\n                if isinstance(replicas, int) and replicas > 0 and not being_deleted:\n                    desired += replicas\n            if desired > 0:\n                return desired\n\n    # Fallbacks (live cluster unresolvable): explicit param, then the default.\n    for key in (\"BENCH_PARAM_EXPECTED_NODES\", \"BENCH_PARAM_EXPECTED_NODE_COUNT\"):\n        val = os.environ.get(key)\n        if val is not None and str(val).strip():\n            try:\n                return int(val)\n            except ValueError:\n                pass\n    return default\n\n\n# Default scheme for the standalone case; may be flipped by _detect_scheme() when\n# a prior workflow stage toggled xpack.security.http.ssl on this cluster.\nDEFAULT_SCHEME = \"http\"\n_SCHEME = None\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef _probe_scheme(scheme):\n    \"\"\"Return True if the ES HTTP API answers on the given scheme.\n\n    The env PERSISTS across stages, so the cluster's actual HTTP scheme may\n    differ from this case's standalone default. A reachable endpoint answers\n    even when auth is required (401/anything HTTP), so any non-empty body or a\n    clean exit counts as 'this scheme is live'. -k tolerates the self-signed\n    cert on https.\n    \"\"\"\n    result = run([\n        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\",\n        \"curl\", \"-s\", \"-S\", \"-k\", \"-o\", \"/dev/null\",\n        \"-w\", \"%{http_code}\", \"--max-time\", \"5\",\n        f\"{scheme}://{SERVICE}:9200/\",\n    ])\n    code = (result.stdout or \"\").strip()\n    return result.returncode == 0 and code.isdigit() and code != \"000\"\n\n\ndef detect_scheme():\n    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n    global _SCHEME\n    if _SCHEME is not None:\n        return _SCHEME\n    order = [DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"]\n    for scheme in order:\n        if _probe_scheme(scheme):\n            _SCHEME = scheme\n            return _SCHEME\n    _SCHEME = DEFAULT_SCHEME\n    return _SCHEME\n\n\ndef curl(path, errors):\n    scheme = detect_scheme()\n    # The client deadline must exceed any server-side ``wait_for`` in `path``,\n    # otherwise curl aborts (exit 28) before ES can answer. The retry loop in\n    # main() does the real waiting, so each call's server wait stays short (10s)\n    # and --max-time (20) comfortably exceeds it.\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"exec\",\n        \"curl-test\",\n        \"--\",\n        \"curl\",\n        \"-s\",\n        \"-S\",\n        \"-k\",\n    ]\n    if ELASTIC_PASSWORD:\n        cmd += [\"-u\", f\"elastic:{ELASTIC_PASSWORD}\"]\n    cmd += [\n        \"--max-time\",\n        \"20\",\n        f\"{scheme}://{SERVICE}:9200{path}\",\n    ]\n    result = run(cmd)\n    if result.returncode != 0:\n        stderr = result.stderr.strip()\n        stdout = result.stdout.strip()\n        detail = stderr or stdout or f\"command terminated with exit code {result.returncode}\"\n        errors.append(f\"Failed to query {path}: {detail}\")\n        return None\n    output = result.stdout.strip()\n    if not output:\n        errors.append(f\"Empty response for {path}\")\n        return None\n    try:\n        return json.loads(output)\n    except json.JSONDecodeError:\n        errors.append(f\"Failed to parse JSON from {path}\")\n        return None\n\n\ndef check_cluster(errors):\n    \"\"\"Run the cluster-side checks; return the per-evaluate expected node count.\n\n    The expected node count is derived from the live cluster (the StatefulSets\n    backing ``_cat/nodes``), so it is computed here after that query and returned\n    to evaluate() for the pod-count assertion.\n    \"\"\"\n    # Resolve the live cluster's node list FIRST: the expected node count is\n    # derived from only the StatefulSets that actually back these live nodes\n    # (the persisted namespace accumulates several ES clusters across stages, so\n    # summing every ES StatefulSet's replicas overcounts the queried cluster).\n    nodes = curl(\"/_cat/nodes?format=json\", errors)\n    node_names = []\n    if isinstance(nodes, list):\n        node_names = [n.get(\"name\") for n in nodes if n.get(\"name\")]\n    expected_nodes = _resolve_expected_nodes(node_names, default=3)\n\n    ep_result = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"endpoints\", SERVICE, \"-o\", \"json\"])\n    if ep_result.returncode != 0:\n        errors.append(f\"Failed to read {SERVICE} endpoints: {ep_result.stderr.strip()}\")\n    else:\n        try:\n            ep = json.loads(ep_result.stdout)\n        except json.JSONDecodeError:\n            errors.append(f\"Failed to parse {SERVICE} endpoints JSON\")\n            ep = None\n        if ep is not None:\n            # O-funcready: a Service only lists a pod under subsets.addresses\n            # once it is k8s-Ready; a serving-but-Ready-lagging ES node sits in\n            # notReadyAddresses, so counting only addresses re-imposes the laggy\n            # pod-Ready gate. Count BOTH so the check proves the pod is wired\n            # into the Service (the real config deliverable), not that its\n            # readiness probe has caught up. A node genuinely absent from the\n            # Service is in neither list and still fails the count.\n            addr_count = 0\n            for subset in ep.get(\"subsets\", []) or []:\n                addr_count += len(subset.get(\"addresses\", []) or [])\n                addr_count += len(subset.get(\"notReadyAddresses\", []) or [])\n            if addr_count != expected_nodes:\n                errors.append(f\"Expected {expected_nodes} endpoints, got {addr_count}\")\n\n    health = curl(\n        f\"/_cluster/health?wait_for_status=yellow&wait_for_nodes={expected_nodes}&timeout=10s\",\n        errors,\n    )\n    if isinstance(health, dict):\n        status = health.get(\"status\")\n        if status not in {\"yellow\", \"green\"}:\n            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n        if health.get(\"number_of_nodes\") != expected_nodes:\n            errors.append(f\"Expected {expected_nodes} nodes, got {health.get('number_of_nodes')}\")\n\n    root = curl(\"/\", errors)\n    if isinstance(root, dict):\n        uuid = root.get(\"cluster_uuid\")\n        if not uuid or uuid == \"_na_\":\n            errors.append(\"Cluster UUID not set\")\n\n    if isinstance(nodes, list) and len(node_names) != expected_nodes:\n        errors.append(f\"Expected {expected_nodes} nodes in _cat/nodes, got {len(node_names)}\")\n\n    return expected_nodes\n\n\ndef evaluate():\n    \"\"\"Run one full snapshot of the bootstrap checks; return the list of errors.\"\"\"\n    errors = []\n\n    cm_result = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"configmap\", \"es-config\", \"-o\", \"json\"])\n    if cm_result.returncode != 0:\n        errors.append(f\"Failed to read es-config ConfigMap: {cm_result.stderr.strip()}\")\n    else:\n        try:\n            cm = json.loads(cm_result.stdout)\n        except json.JSONDecodeError:\n            errors.append(\"Failed to parse es-config ConfigMap JSON\")\n            cm = {}\n        config = cm.get(\"data\", {}).get(\"elasticsearch.yml\", \"\")\n        if \"cluster.initial_master_nodes\" in config:\n            errors.append(\"cluster.initial_master_nodes still present in es-config\")\n\n    # Cluster-side checks run first so the live-cluster expected node count can\n    # be reused by the pod-count assertion below.\n    expected_nodes = check_cluster(errors)\n\n    pods_result = run(\n        [\"kubectl\", \"-n\", NAMESPACE, \"get\", \"pods\", \"-l\", APP_LABEL, \"-o\", \"json\"]\n    )\n    if pods_result.returncode != 0:\n        errors.append(f\"Failed to read pods: {pods_result.stderr.strip()}\")\n    else:\n        try:\n            pods = json.loads(pods_result.stdout)\n        except json.JSONDecodeError:\n            errors.append(\"Failed to parse pods JSON\")\n            pods = {}\n        items = pods.get(\"items\", []) if isinstance(pods, dict) else []\n        if len(items) != expected_nodes:\n            errors.append(f\"Expected {expected_nodes} pods, got {len(items)}\")\n        # O-funcready: do NOT gate the verdict on the k8s pod-`Ready` bit. An ES\n        # node serves (and joins the cluster as a master/data node) before -- and\n        # can dip back below -- its HTTP readiness probe during GC or shard\n        # recovery, so asserting all N pods carry the Ready condition false-fails\n        # a cluster that already bootstrapped and serves N nodes. The DELIVERABLE\n        # (the cluster bootstrapped and serves N nodes) is graded functionally in\n        # check_cluster: `_cat/nodes` count, `_cluster/health` (yellow/green,\n        # number_of_nodes == N), and cluster_uuid set. Pod existence is still\n        # asserted above; a node that never joins drops the node count and fails.\n\n    return errors\n\n\ndef main():\n    global ELASTIC_PASSWORD\n    ELASTIC_PASSWORD = _elastic_password()\n\n    # A multi-node ES cluster can flap at the edge of readiness under load: a\n    # node briefly fails its HTTP readiness probe during GC or shard recovery\n    # even though the cluster is stably green (writes succeed). A single snapshot\n    # can catch that transient and report a false \"2/3 Ready\" / node-count miss.\n    # So verify the STABLE converged state: re-evaluate for up to ~75s and pass\n    # as soon as one clean snapshot is seen. This does not loosen the\n    # N-node/green requirement -- a genuinely degraded cluster (a node that never\n    # joins) fails every attempt and still fails the oracle.\n    import time\n    deadline = time.monotonic() + 75\n    errors = evaluate()\n    while errors and time.monotonic() < deadline:\n        time.sleep(8)\n        errors = evaluate()\n\n    if errors:\n        print(\"Bootstrap verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    print(\"Bootstrap initial master nodes verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":468,"startLine":1,"totalLines":468}}}
