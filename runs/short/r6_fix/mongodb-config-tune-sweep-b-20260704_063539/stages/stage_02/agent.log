or _pi in $(seq 1 30); do P=$(kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet $t $au --eval '\\''rs.hello().primary'\\'' 2>/dev/null | cut -d. -f1); [ -n \"$P\" ] && break; sleep 2; done; P=${P:-mongodb-replica-0}; kubectl -n mongodb exec \"$P\" -- mongosh --quiet $t $au --eval '\\''db.getSiblingDB(\"{{params.app_database}}\").{{params.app_collection}}.countDocuments({})'\\'' 2>/dev/null | tr -dc 0-9); [ \"${n:-0}\" -ge 3 ]'\n        timeout_sec: 30\n\noracle:\n  verify:\n    commands:\n      - command: \"python3 cases/mongodb/initialize/oracle/oracle.py\"\n        timeout_sec: 180","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
