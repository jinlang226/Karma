{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01WdYgeJqJSM3uRU7K22HXFh","type":"tool_result","content":"265\t                fh.write(f\"[{label}:{unit_id}:{phase}] $ {cmd}\\n[error: {exc}]\\n\")\n266\t            return None\n267\t\n268\t    for unit in units or []:\n269\t        if timed_out:\n270\t            break\n271\t        unit_id = unit.get(\"id\") or unit.get(\"name\") or \"unknown\"\n272\t        on_fail = unit.get(\"on_probe_fail\", \"skip\")\n273\t        if on_progress:\n274\t            on_progress(f\"    • {label}: {unit_id}\")\n275\t\n276\t        # Probe. A skip-gate probes once: a failure just means \"not present\n277\t        # yet\" -> fall through to apply. An error-gate asserts a state the apply\n278\t        # cannot create (a readiness/convergence condition: pods Ready, cluster\n279\t        # quorate, a planted baseline reaching its expected steady-state). On a\n280\t        # loaded/slow cluster a one-shot check is flaky and such a condition may\n281\t        # need a few seconds to settle, so an error-gate retries its probe up to\n282\t        # verify_retries times with verify_interval_sec between tries before the\n283\t        # failure becomes fatal. This never turns a genuine miss into a pass --\n284\t        # if the state never holds it still fails after the budget; it only\n285\t        # waits for convergence instead of sampling exactly once.\n286\t        probe_tries = (unit.get(\"verify_retries\") or 1) if on_fail == \"error\" else 1\n287\t        probe_interval = unit.get(\"verify_interval_sec\") or 0.0\n288\t        probe_ok = False\n289\t        for _p_attempt in range(probe_tries):\n290\t            if _p_attempt > 0:\n291\t                time.sleep(probe_interval)\n292\t            probe_ok = True\n293\t            for cmd_entry in unit.get(\"probe_commands\") or []:\n294\t                rc = _exec(cmd_entry, \"probe\", unit_id)\n295\t                if rc != 0:\n296\t                    probe_ok = False\n297\t                    break\n298\t            if probe_ok or timed_out:\n299\t                break\n300\t        if timed_out:\n301\t            overall_ok = False\n302\t            unit_outcomes.append({\"id\": unit_id, \"ok\": False, \"phase\": \"probe\", \"timed_out\": True})\n303\t            break\n304\t\n305\t        if probe_ok:\n306\t            # Target state already present -> no apply needed.\n307\t            unit_outcomes.append({\"id\": unit_id, \"ok\": True, \"skipped\": True})\n308\t            if on_progress:\n309\t                on_progress(f\"    ✓ {label}: {unit_id} (already present)\")\n310\t            continue\n311\t        if on_fail == \"error\":\n312\t            # Probe failed after its full retry budget: the required state never\n313\t            # converged, so the precondition fails.\n314\t            overall_ok = False\n315\t            unit_outcomes.append({\"id\": unit_id, \"ok\": False, \"phase\": \"probe\"})\n316\t            continue\n317\t        # on_fail == \"skip\" (default): the probe failing is the expected\n318\t        # \"not yet present\" signal -> fall through to apply to establish it.\n319\t\n320\t        # Apply\n321\t        apply_ok = True\n322\t        for cmd_entry in unit.get(\"apply_commands\") or []:\n323\t            rc = _exec(cmd_entry, \"apply\", unit_id)\n324\t            # Retry an apply that failed on a transient not-ready-yet condition\n325\t            # (default SA not provisioned, a peer not yet accepting connections,\n326\t            # apiserver briefly unreachable). These clear within seconds on a\n327\t            # fresh/loaded cluster; the apply command is idempotent so retrying is\n328\t            # safe, and only the transient signatures trigger it.\n329\t            _t_tries = 0\n330\t            while (rc not in (0, None) and not timed_out and _t_tries < 8\n331\t                   and _is_transient_apply_error(all_output[-1] if all_output else \"\")):\n332\t                time.sleep(6)\n333\t                _t_tries += 1\n334\t                rc = _exec(cmd_entry, \"apply\", unit_id)\n335\t            if rc != 0:\n336\t                apply_ok = False\n337\t                break\n338\t        if timed_out:\n339\t            overall_ok = False\n340\t            unit_outcomes.append({\"id\": unit_id, \"ok\": False, \"phase\": \"apply\", \"timed_out\": True})\n341\t            break\n342\t        if not apply_ok:\n343\t            overall_ok = False\n344\t            unit_outcomes.append({\"id\": unit_id, \"ok\": False, \"phase\": \"apply\"})\n345\t            continue\n346\t\n347\t        # Verify\n348\t        retries = unit.get(\"verify_retries\") or 1\n349\t        interval = unit.get(\"verify_interval_sec\") or 0.0\n350\t        verify_ok = False\n351\t        for _attempt in range(retries):\n352\t            if _attempt > 0:\n353\t                time.sleep(interval)\n354\t            verify_ok = True\n355\t            for cmd_entry in unit.get(\"verify_commands\") or []:\n356\t                rc = _exec(cmd_entry, \"verify\", unit_id)\n357\t                if rc != 0:\n358\t                    verify_ok = False\n359\t                    break\n360\t            if verify_ok or timed_out:\n361\t                break\n362\t        if timed_out:\n363\t            overall_ok = False\n364\t            unit_outcomes.append({\"id\": unit_id, \"ok\": False, \"phase\": \"verify\", \"timed_out\": True})"}]},"parent_tool_use_id":null,"session_id":"3cef0dbd-1c6e-4fe8-a79c-f87632e7c29e","uuid":"05f70e55-b060-4306-8dd9-2d6a03342a16","timestamp":"2026-07-04T06:41:54.964Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/karma/runtime/case.py","content":"                fh.write(f\"[{label}:{unit_id}:{phase}] $ {cmd}\\n[error: {exc}]\\n\")\n            return None\n\n    for unit in units or []:\n        if timed_out:\n            break\n        unit_id = unit.get(\"id\") or unit.get(\"name\") or \"unknown\"\n        on_fail = unit.get(\"on_probe_fail\", \"skip\")\n        if on_progress:\n            on_progress(f\"    • {label}: {unit_id}\")\n\n        # Probe. A skip-gate probes once: a failure just means \"not present\n        # yet\" -> fall through to apply. An error-gate asserts a state the apply\n        # cannot create (a readiness/convergence condition: pods Ready, cluster\n        # quorate, a planted baseline reaching its expected steady-state). On a\n        # loaded/slow cluster a one-shot check is flaky and such a condition may\n        # need a few seconds to settle, so an error-gate retries its probe up to\n        # verify_retries times with verify_interval_sec between tries before the\n        # failure becomes fatal. This never turns a genuine miss into a pass --\n        # if the state never holds it still fails after the budget; it only\n        # waits for convergence instead of sampling exactly once.\n        probe_tries = (unit.get(\"verify_retries\") or 1) if on_fail == \"error\" else 1\n        probe_interval = unit.get(\"verify_interval_sec\") or 0.0\n        probe_ok = False\n        for _p_attempt in range(probe_tries):\n            if _p_attempt > 0:\n                time.sleep(probe_interval)\n            probe_ok = True\n            for cmd_entry in unit.get(\"probe_commands\") or []:\n                rc = _exec(cmd_entry, \"probe\", unit_id)\n                if rc != 0:\n                    probe_ok = False\n                    break\n            if probe_ok or timed_out:\n                break\n        if timed_out:\n            overall_ok = False\n            unit_outcomes.append({\"id\": unit_id, \"ok\": False, \"phase\": \"probe\", \"timed_out\": True})\n            break\n\n        if probe_ok:\n            # Target state already present -> no apply needed.\n            unit_outcomes.append({\"id\": unit_id, \"ok\": True, \"skipped\": True})\n            if on_progress:\n                on_progress(f\"    ✓ {label}: {unit_id} (already present)\")\n            continue\n        if on_fail == \"error\":\n            # Probe failed after its full retry budget: the required state never\n            # converged, so the precondition fails.\n            overall_ok = False\n            unit_outcomes.append({\"id\": unit_id, \"ok\": False, \"phase\": \"probe\"})\n            continue\n        # on_fail == \"skip\" (default): the probe failing is the expected\n        # \"not yet present\" signal -> fall through to apply to establish it.\n\n        # Apply\n        apply_ok = True\n        for cmd_entry in unit.get(\"apply_commands\") or []:\n            rc = _exec(cmd_entry, \"apply\", unit_id)\n            # Retry an apply that failed on a transient not-ready-yet condition\n            # (default SA not provisioned, a peer not yet accepting connections,\n            # apiserver briefly unreachable). These clear within seconds on a\n            # fresh/loaded cluster; the apply command is idempotent so retrying is\n            # safe, and only the transient signatures trigger it.\n            _t_tries = 0\n            while (rc not in (0, None) and not timed_out and _t_tries < 8\n                   and _is_transient_apply_error(all_output[-1] if all_output else \"\")):\n                time.sleep(6)\n                _t_tries += 1\n                rc = _exec(cmd_entry, \"apply\", unit_id)\n            if rc != 0:\n                apply_ok = False\n                break\n        if timed_out:\n            overall_ok = False\n            unit_outcomes.append({\"id\": unit_id, \"ok\": False, \"phase\": \"apply\", \"timed_out\": True})\n            break\n        if not apply_ok:\n            overall_ok = False\n            unit_outcomes.append({\"id\": unit_id, \"ok\": False, \"phase\": \"apply\"})\n            continue\n\n        # Verify\n        retries = unit.get(\"verify_retries\") or 1\n        interval = unit.get(\"verify_interval_sec\") or 0.0\n        verify_ok = False\n        for _attempt in range(retries):\n            if _attempt > 0:\n                time.sleep(interval)\n            verify_ok = True\n            for cmd_entry in unit.get(\"verify_commands\") or []:\n                rc = _exec(cmd_entry, \"verify\", unit_id)\n                if rc != 0:\n                    verify_ok = False\n                    break\n            if verify_ok or timed_out:\n                break\n        if timed_out:\n            overall_ok = False\n            unit_outcomes.append({\"id\": unit_id, \"ok\": False, \"phase\": \"verify\", \"timed_out\": True})","numLines":100,"startLine":265,"totalLines":1051}}}
