{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Cq7v81ARLUfWHD1MqYGYHn","type":"tool_result","content":"    default: app-user-password\n    description: Kubernetes Secret holding the app user's current password.\n  app_next_secret_name:\n    default: app-user-password-next\n    description: Kubernetes Secret holding the app user's next password.\n  reporting_secret_name:\n    default: reporting-user-password\n    description: Kubernetes Secret holding the reporting user's password.\n  admin_username:\n    default: admin-user\n--\n  app_username:\n    default: app-user\n    description: Username of the application user being rotated.\n  reporting_username:\n    default: reporting-user\n    description: Username of the reporting user.\n  app_database:\n--\n  - Rotate {{params.app_username}} to the password in {{params.app_next_secret_name}}.\n  - Update the {{params.app_secret_name}} Secret to match the new password.\n  - Do not break {{params.reporting_username}} or admin access.\n  - Data in {{params.app_database}}.{{params.app_collection}} must remain accessible.\n\n  Notes:\n--\n          /bin/sh -c 'kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet \"mongodb://{{params.admin_username}}:admin123password@localhost:27017/admin\" --eval '\\''db.getSiblingDB(\"admin\").createUser({user:\"{{params.app_username}}\",pwd:\"appuser123password\",roles:[{role:\"readWrite\",db:\"{{params.app_database}}\"}]})'\\'''\n        sleep: 2\n      - command: |\n          /bin/sh -c 'kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet \"mongodb://{{params.admin_username}}:admin123password@localhost:27017/admin\" --eval '\\''db.getSiblingDB(\"admin\").createUser({user:\"{{params.reporting_username}}\",pwd:\"reporting123password\",roles:[{role:\"read\",db:\"{{params.app_database}}\"}]})'\\'''\n        sleep: 2\n      - command: |\n--\n  # secrets.yaml creates app-user-password-old (the pre-rotation reference the\n  # oracle reads to confirm the password CHANGED) and app-user-password-next (the\n  # rotation target). On an INHERITED cluster the build is skipped, and the\n  # reporting_user_fixture above also skips (its reporting-user already exists\n  # from an earlier stage), so these two secrets are never created -> oracle\n  # fails \"app-user-password-old not found\". Ensure them additively when absent:\n  # -old captures the app-user's CURRENT (live pre-rotation) password; -next is\n  # the scenario target. Never touches the cluster/data; probe skips when present.\n  - name: app_rotation_secrets_fixture\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n mongodb get secret app-user-password-old\"\n        timeout_sec: 15\n    apply:\n      - command: \"/bin/sh -c 'op=$(kubectl -n mongodb get secret {{params.app_secret_name}} -o jsonpath=\\\"{.data.password}\\\" 2>/dev/null | base64 -d 2>/dev/null); op=${op:-appuser123password}; kubectl -n mongodb create secret generic app-user-password-old --from-literal=password=\\\"$op\\\" --dry-run=client -o yaml | kubectl apply -f -'\"\n        sleep: 1\n      - command: \"/bin/sh -c 'kubectl -n mongodb get secret {{params.app_next_secret_name}} >/dev/null 2>&1 || kubectl -n mongodb create secret generic {{params.app_next_secret_name}} --from-literal=password=newAppUserPassword456 --dry-run=client -o yaml | kubectl apply -f -'\"\n        sleep: 1\n    verify:\n      - command: \"/bin/sh -c 'kubectl -n mongodb get secret app-user-password-old >/dev/null 2>&1; true'\"\n        timeout_sec: 10\n\noracle:\n  verify:\n    commands:","is_error":false}]},"parent_tool_use_id":null,"session_id":"239b7986-c9dd-48f8-b32e-77b5badc92ba","uuid":"ea925548-66b6-40ee-91e6-70d7fe1ed8ba","timestamp":"2026-07-04T08:31:02.364Z","tool_use_result":{"stdout":"    default: app-user-password\n    description: Kubernetes Secret holding the app user's current password.\n  app_next_secret_name:\n    default: app-user-password-next\n    description: Kubernetes Secret holding