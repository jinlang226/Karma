ams.app_secret_name}}\n  - {{params.app_next_secret_name}}\n  - {{params.reporting_secret_name}}\n\n  Task:\n  - Rotate {{params.app_username}} to the password in {{params.app_next_secret_name}}.\n  - Update the {{params.app_secret_name}} Secret to match the new password.\n  - Do not break {{params.reporting_username}} or admin access.\n  - Data in {{params.app_database}}.{{params.app_collection}} must remain accessible.\n\n  Notes:\n  - Do not use operators or CRDs.\n\nnamespace_contract:\n  required_roles: []\n\nmetrics:\n  - time_to_first_mutation\n\npreconditionUnits:\n  - name: mongo_env_ready\n    on_probe_fail: skip\n    probe:\n      # AUTHORITATIVE skip-if-running probe (P32): succeed when the canonical\n      # StatefulSet exists OR any pod is Running, so the destructive namespace\n      # rebuild below is skipped on an inherited cluster even if its pods are\n      # momentarily not Running (mid-restart from a prior stage) -- the\n      # StatefulSet persists across that window. The bare `grep -c Running`\n      # could miss such a cluster and clobber inherited state.\n      - command: \"/bin/sh -c 'kubectl -n mongodb get statefulset {{params.cluster_prefix}} >/dev/null 2>&1 || kubectl -n mongodb get pods 2>/dev/null | grep -q Running'\"\n        timeout_sec: 10\n    apply:\n      - command: \"/bin/sh -c 'kubectl delete namespace mongodb --ignore-not-found=true; kubectl wait --for=delete namespace/mongodb --timeout=120s || true'\"\n        sleep: 2\n      - command: \"kubectl create namespace mongodb\"\n        sleep: 1\n      - command: \"kubectl -n mongodb apply -f cases/mongodb/password-rotation/resource/secrets.yaml\"\n        sleep: 1\n      - command: \"kubectl -n mongodb apply -f cases/mongodb/password-rotation/resource/services.yaml\"\n        sleep: 1\n      - command: \"kubectl -n mongodb apply -f cases/mongodb/password-rotation/resource/statefulset.yaml\"\n        sleep: 5\n      - command: |\n          /bin/sh -c 'for i in $(seq 1 120); do ready=$(kubectl -n mongodb get sts {{params.cluster_prefix}} -o jsonpath='\\''{.status.readyReplicas}'\\'' 2>/dev/null); if [ \"${ready:-0}\" -ge 3 ]; then exit 0; fi; sleep 5; done; exit 1'\n        sleep: 2\n      # Pod-Ready != mongod accepting TCP (§1.10): ping-until-ok before rs.initiate.\n      - command: |\n          /bin/sh -c 'for i in $(seq 1 30); do kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\\''db.runCommand({ping:1}).ok'\\'' 2>/dev/null | grep -q 1 && exit 0; sleep 3; done; exit 1'\n        sleep: 2\n      - command: |\n          /bin/sh -c 'kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\\''rs.initiate({_id:\"{{params.replica_set_name}}\",members:[{_id:0,host:\"mongodb-replica-0.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"},{_id:1,host:\"mongodb-replica-1.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"},{_id:2,host:\"mongodb-replica-2.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"}]})'\\'''\n        sleep: 5\n      - command: |\n          /bin/sh -c 'for i in $(seq 1 20); do kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\\''db.hello().isWritablePrimary'\\'' | grep true && exit 0; sleep 3; done; exit 1'\n        sleep: 2\n      - command: |\n          /bin/sh -c 'kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\\''db.getSiblingDB(\"admin\").createUser({user:\"{{params.admin_username}}\",pwd:\"admin123password\",roles:[{role:\"clusterAdmin\",db:\"admin\"},{role:\"userAdminAnyDatabase\",db:\"admin\"},{role:\"readWriteAnyDatabase\",db:\"admin\"}]})'\\'''\n        sleep: 2\n      - command: |\n          /bin/sh -c 'kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet \"mongodb://{{params.admin_username}}:admin123password@localhost:27017/admin\" --eval '\\''db.getSiblingDB(\"admin\").createUser({user:\"{{params.app_username}}\",pwd:\"appuser123password\",roles:[{role:\"readWrite\",db:\"{{params.app_database}}\"}]})'\\'''\n        sleep: 2\n  