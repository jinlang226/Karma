t \"mongodb://{{params.admin_username}}:$pw@localhost:27017/admin\" --eval \"db.runCommand({ping:1}).ok\" 2>/dev/null | grep -q 1\n          '\n        timeout_sec: 30\n    apply:\n      # Ensure the admin secret (idempotent: create only if missing).\n      - command: \"/bin/sh -c 'kubectl -n mongodb get secret admin-user-password >/dev/null 2>&1 || kubectl -n mongodb create secret generic admin-user-password --from-literal=password=admin123password'\"\n        sleep: 1\n      # Ensure the admin-user MongoDB user. On a no-auth inherited cluster this\n      # runs unauthenticated and succeeds; where it already exists it errors and\n      # the `|| true` keeps it a no-op. Never drops or alters existing users/data.\n      - command: |\n          /bin/sh -c '\n          t=\"\"; for cca in /etc/tls/ca.crt /etc/mongo-ca/ca.crt; do kubectl -n mongodb exec mongodb-replica-0 -- ls $cca >/dev/null 2>&1 && { t=\"--tls --tlsAllowInvalidHostnames --tlsAllowInvalidCertificates --tlsCAFile $cca\"; break; }; done\n          P=\"\"; for _pi in $(seq 1 30); do P=$(kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet $t --eval \"rs.hello().primary\" 2>/dev/null | cut -d. -f1); [ -n \"$P\" ] && break; sleep 2; done; P=${P:-mongodb-replica-0}\n          kubectl -n mongodb exec \"$P\" -- mongosh --quiet $t --eval \"db.getSiblingDB(\\\"admin\\\").createUser({user:\\\"{{params.admin_username}}\\\",pwd:\\\"admin123password\\\",roles:[{role:\\\"root\\\",db:\\\"admin\\\"}]})\" 2>/dev/null || true\n          '\n        sleep: 2\n    verify:\n      # P38: read the write back -- authenticate AS the admin user just created and\n      # ping (bounded poll to tolerate election/replication lag), not merely assert\n      # the companion secret exists.\n      - command: |","numLines":150,"startLine":1,"totalLines":250}}}
