efore|Not After|DNS:|IP:\"\necho \"Leaf cert generated OK\""},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":365,"cache_read_input_tokens":37980,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":365},"output_tokens":53,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"a4761880-da88-4c02-890d-4b0b4f77ac23","uuid":"7e29942b-5635-43d5-a390-34b7012890cb","request_id":"req_011Ccg9RwMiD9Rh23nD1Jnuc"}
