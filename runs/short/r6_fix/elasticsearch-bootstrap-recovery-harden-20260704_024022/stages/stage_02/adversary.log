$ kubectl -n elasticsearch get configmap es-config
NAME        DATA   AGE
es-config   1      8m50s

$ kubectl -n elasticsearch get configmap es-config -o jsonpath='{.data.elasticsearch\.yml}' | grep -q 'invalid-host-' || kubectl -n elasticsearch create configmap es-config-adv-backup --from-literal=elasticsearch.yml="$(kubectl -n elasticsearch get configmap es-config -o jsonpath='{.data.elasticsearch\.yml}')" --dry-run=client -o yaml | kubectl -n elasticsearch apply -f -
configmap/es-config-adv-backup created

$ kubectl -n elasticsearch patch configmap es-config --type=merge -p "$(kubectl -n elasticsearch create configmap es-config --from-literal=elasticsearch.yml="$(kubectl -n elasticsearch get configmap es-config -o jsonpath='{.data.elasticsearch\.yml}' | awk '/^discovery.seed_hosts:/{print; inlist=1; n=0; next} inlist && /^[[:space:]]*-[[:space:]]/{n++; print "  - invalid-host-" n; next} {inlist=0; print}')" --dry-run=client -o json)"
configmap/es-config patched

$ kubectl -n elasticsearch delete pod -l app=es-cluster --ignore-not-found=true --wait=false
pod "es-cluster-0" deleted
pod "es-cluster-1" deleted
pod "es-cluster-2" deleted

$ /bin/sh -c "kubectl -n elasticsearch get configmap es-config -o jsonpath='{.data.elasticsearch\\.yml}' | grep -q 'invalid-host-1'"

