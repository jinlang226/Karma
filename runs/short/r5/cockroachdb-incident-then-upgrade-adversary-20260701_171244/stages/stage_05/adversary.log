$ /bin/sh -c 'if kubectl -n cockroachdb exec crdb-cluster-0 -- test -f /cockroach/cockroach-certs/ca.crt 2>/dev/null; then F=--certs-dir=/cockroach/cockroach-certs; else F=--insecure; fi; kubectl -n cockroachdb exec crdb-cluster-0 -- ./cockroach sql $F --format=tsv -e "SHOW CLUSTER SETTING kv.snapshot_rebalance.max_rate;" | tail -1 | grep -q "1.0 MiB"'

