      }
    },
    {
      "id": "stage_02",
      "service": "cockroachdb",
      "case_name": "cluster-settings",
      "param_overrides": {
        "setting_name": "kv.snapshot_rebalance.max_rate",
        "setting_value": "128MiB"
      }
    },
    {
      "id": "stage_03",
      "service": "cockroachdb",
      "case_name": "zone-config",
      "param_overrides": {
        "gc_ttl_seconds": "14400"
      }
    }
  ],
  "adversary": []
}