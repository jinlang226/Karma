icsearch.svc.cluster.local\n          DNS.12=es-cluster-2.{{params.cluster_prefix}}.elasticsearch.svc.cluster.local\n          EOF\n          openssl genrsa -out /tmp/certs/ca.key 2048\n          openssl req -x509 -new -nodes -key /tmp/certs/ca.key -sha256 -days 2 -subj \"/CN={{params.http_ca_configmap_name}}\" -out /tmp/certs/ca.crt\n          openssl genrsa -out /tmp/certs/tls.key 2048\n          openssl req -new -key /tmp/certs/tls.key -out /tmp/certs/tls.csr -config /tmp/certs/openssl.cnf\n          openssl x509 -req -in /tmp/certs/tls.csr -CA /tmp/certs/ca.crt -CAkey /tmp/certs/ca.key -CAcreateserial -out /tmp/certs/tls.crt -days 2 -extensions v3_req -extfile /tmp/certs/openssl.cnf\n          '\\''\n          kubectl -n elasticsearch cp openssl-toolbox:/tmp/certs \"${TMP_DIR}/certs\"\n          kubectl -n elasticsearch create secret generic {{params.tls_secret_name}} --from-file=tls.crt=\"${TMP_DIR}/certs/tls.crt\" --from-file=tls.key=\"${TMP_DIR}/certs/tls.key\" --from-file=ca.crt=\"${TMP_DIR}/certs/ca.crt\" --dry-run=client -o yaml | kubectl apply -f -\n          kubectl -n elasticsearch create configmap {{params.http_ca_configmap_name}} --from-file=ca.crt=\"${TMP_DIR}/certs/ca.crt\" --dry-run=client -o yaml | kubectl apply -f -\n          CA_FP=$(openssl x509 -noout -fingerprint -sha256 -in \"${TMP_DIR}/certs/ca.crt\" | cut -d= -f2)\n          LEAF_FP=$(openssl x509 -noout -fingerprint -sha256 -in \"${TMP_DIR}/certs/tls.crt\" | cut -d= -f2)\n          kubectl -n elasticsearch create configmap {{params.old_fingerprint_configmap_name}} --from-file=ca.crt=\"${TMP_DIR}/certs/ca.crt\" --from-literal=ca_fingerprint_sha256=\"${CA_FP}\" --from-literal=leaf_fingerprint_sha256=\"${LEAF_FP}\" --dry-run=client -o yaml | kubectl apply -f -\n          '\n        sleep: 1\n      - command: \"kubectl -n elasticsearch apply -f cases/elasticsearch/rotate-http-certs/resource/configmap.yaml\"\n        sleep: 1\n      - command: \"kubectl -n elasticsearch apply -f cases/elastics