  containers:\n      - name: cockroachdb\n        image: cockroachdb/cockroach:v24.1.0\n        imagePullPolicy: IfNotPresent\n        command:\n        - /bin/bash\n        - -ecx\n        - |\n          exec /cockroach/cockroach start \\\n            --insecure \\\n            --advertise-host=$(hostname -f) \\\n            --http-addr=0.0.0.0:8080 \\\n            --listen-addr=0.0.0.0:26257 \\\n            --join=crdb-cluster-0.crdb-cluster.cockroachdb.svc.cluster.local:26257,crdb-cluster-1.crdb-cluster.cockroachdb.svc.cluster.local:26257,crdb-cluster-2.crdb-cluster.cockroachdb.svc.cluster.local:26257 \\\n            --cache=25% \\\n            --max-sql-memory=25%\n        env:\n        - name: COCKROACH_CHANNEL\n          value: kubernetes-insecure\n        ports:\n        - name: grpc\n          containerPort: 26257\n        - name: http\n          containerPort: 8080\n        readinessProbe:\n          httpGet:\n            path: /health?ready=1\n            port: http\n          initialDelaySeconds: 10\n          periodSeconds: 5\n          failureThreshold: 2\n        livenessProbe:\n          httpGet:\n            path: /health\n            port: http\n          initialDelaySeconds: 30\n          periodSeconds: 5\n        volumeMounts:\n        - name: datadir\n          mountPath: /cockroach/cockroach-data\n  volumeClaimTemplates:\n  - metadata:\n      name: datadir\n    spec:\n      accessModes: [\"ReadWriteOnce\"]\n      resources:\n        requests:\n          storage: 10Gi\nEOF","description":"Deploy CockroachDB headless service, public service, PDB, and StatefulSet"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":472,"cache_read_input_tokens":28654,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":472},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"pare