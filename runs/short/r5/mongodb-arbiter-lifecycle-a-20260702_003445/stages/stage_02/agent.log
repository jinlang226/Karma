{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01UZooH4gfnU6odJtk8HzrUf","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport argparse\n3\timport base64\n4\timport json\n5\timport os\n6\timport subprocess\n7\timport sys\n8\timport time\n9\t\n10\t\n11\tNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"mongodb\")\n12\tCLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"mongodb-replica\")\n13\tHEADLESS_SERVICE = os.environ.get(\"BENCH_PARAM_HEADLESS_SERVICE_NAME\", \"mongodb-replica-svc\")\n14\tREPLICA_SET_NAME = os.environ.get(\"BENCH_PARAM_REPLICA_SET_NAME\", CLUSTER_PREFIX)\n15\tAPP_DATABASE = os.environ.get(\"BENCH_PARAM_APP_DATABASE\", \"app\")\n16\tAPP_COLLECTION = os.environ.get(\"BENCH_PARAM_APP_COLLECTION\", \"test\")\n17\tSEED_DOCS = int(os.environ.get(\"BENCH_PARAM_SEED_DOCS\", \"3\"))\n18\t\n19\t\n20\tdef run(cmd):\n21\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n22\t\n23\t\n24\t_ADMIN_PW = None\n25\t\n26\t\n27\tdef _admin_auth_flags():\n28\t    \"\"\"`-u <admin> -p <pw> --authenticationDatabase admin` when the admin secret\n29\t    exists. The env PERSISTS across stages, so a prior deploy stage may have\n30\t    enabled auth (keyfile + admin user), after which rs.conf()/rs.status()\n31\t    require credentials. Empty when no admin secret is present (standalone,\n32\t    pre-auth) so the plain connection is used. Cached.\"\"\"\n33\t    global _ADMIN_PW\n34\t    if _ADMIN_PW is None:\n35\t        secret = os.environ.get(\"BENCH_PARAM_ADMIN_SECRET_NAME\", \"admin-user-password\")\n36\t        r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", secret,\n37\t                 \"-o\", \"jsonpath={.data.password}\"])\n38\t        pw = \"\"\n39\t        if r.returncode == 0 and r.stdout.strip():\n40\t            try:\n41\t                pw = base64.b64decode(r.stdout.strip()).decode()\n42\t            except Exception:\n43\t                pw = \"\"\n44\t        _ADMIN_PW = pw\n45\t    if _ADMIN_PW:\n46\t        user = os.environ.get(\"BENCH_PARAM_ADMIN_USERNAME\", \"admin-user\")\n47\t        return [\"-u\", user, \"-p\", _ADMIN_PW, \"--authenticationDatabase\", \"admin\"]\n48\t    return []\n49\t\n50\t\n51\t_TLS_FLAGS_CACHE = None\n52\t\n53\t\n54\tdef _mongo_tls_flags(probe_pod=None):\n55\t    \"\"\"mongosh transport flags that adapt to the cluster's LIVE TLS mode.\n56\t\n57\t    The environment PERSISTS across workflow stages, so an earlier stage\n58\t    (mongodb/tls-setup or mongodb/certificate-rotation) may have turned TLS on,\n59\t    after which a plain mongosh connection is refused. Detect TLS by probing the\n60\t    running mongo pod for a CA cert mounted at the paths the TLS stages use; if\n61\t    present, connect with --tls --tlsCAFile (and a client cert for mutual TLS\n62\t    when one is mounted), else connect plain. Standalone (no CA mounted) this\n63\t    returns [] -> identical plain behaviour. It only adds transport flags; every\n64\t    real check still runs and still fails when its condition is unmet.\n65\t    \"\"\"\n66\t    global _TLS_FLAGS_CACHE\n67\t    if _TLS_FLAGS_CACHE is not None:\n68\t        return list(_TLS_FLAGS_CACHE)\n69\t    flags = []\n70\t    pod = probe_pod or f\"{CLUSTER_PREFIX}-0\"\n71\t    ca_path = None\n72\t    for cand in (\n73\t        \"/etc/tls/ca.crt\",\n74\t        \"/etc/mongo-ca/ca.crt\",\n75\t        \"/etc/mongodb/tls/ca.crt\",\n76\t        \"/etc/ssl/mongodb/ca.crt\",\n77\t    ):\n78\t        probe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + cand])\n79\t        if probe.returncode == 0:\n80\t            ca_path = cand\n81\t            break\n82\t    if ca_path:\n83\t        flags = [\"--tls\", \"--tlsAllowInvalidHostnames\", \"--tlsAllowInvalidCertificates\", \"--tlsCAFile\", ca_path]\n84\t        for client_pem in (\"/etc/tls/client.pem\", \"/etc/mongo-ca/client.pem\"):\n85\t            cprobe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + client_pem])\n86\t            if cprobe.returncode == 0:\n87\t                flags += [\"--tlsCertificateKeyFile\", client_pem]\n88\t                break\n89\t    _TLS_FLAGS_CACHE = flags\n90\t    return list(flags)\n91\t\n92\tdef _resolve_expected_replicas():\n93\t    \"\"\"Topology size to enforce.\n94\t\n95\t    The environment PERSISTS across workflow stages, so an earlier\n96\t    replica-scaling stage may have grown the replica set past the standalone\n97\t    default of 3. Resolve the expected count from (in priority order): an\n98\t    explicit ``expected_replicas``/``target_replicas`` param override, else the\n99\t    LIVE StatefulSet (ready, else spec'd replicas), else the standalone default\n100\t    of 3. This adapts the topology/count check to whatever the workflow\n101\t    accumulated without loosening it -- a non-solving agent that drops or fails\n102\t    a member still mismatches the live ready/spec count.\n103\t    \"\"\"\n104\t    for key in (\"BENCH_PARAM_EXPECTED_REPLICAS\", \"BENCH_PARAM_TARGET_REPLICAS\"):\n105\t        val = os.environ.get(key)\n106\t        if val is not None and str(val).strip():\n107\t            try:\n108\t                return int(val)\n109\t            except ValueError:\n110\t                pass\n111\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", CLUSTER_PREFIX, \"-o\", \"json\"])\n112\t    if res.returncode == 0:\n113\t        try:\n114\t            sts = json.loads(res.stdout)\n115\t            status = sts.get(\"status\", {}) or {}\n116\t            spec = sts.get(\"spec\", {}) or {}\n117\t            live = status.get(\"readyReplicas\")\n118\t            if not isinstance(live, int) or live <= 0:\n119\t                live = spec.get(\"replicas\")\n120\t            if isinstance(live, int) and live > 0:\n121\t                return live\n122\t        except (json.JSONDecodeError, AttributeError):\n123\t            pass\n124\t    return 3\n125\t\n126\t\n127\tEXPECTED_REPLICAS = _resolve_expected_replicas()\n128\t\n129\t\n130\tdef fail(prefix, errors):\n131\t    if errors:\n132\t        print(prefix, file=sys.stderr)\n133\t        for err in errors:\n134\t            print(f\"  - {err}\", file=sys.stderr)\n135\t        return 1\n136\t    return 0\n137\t\n138\t\n139\tdef mongo_eval(pod, script):\n140\t    # Connect via the member's own FQDN with directConnection=true to skip SDAM\n141\t    # topology monitoring, which a bare localhost connection would start and\n142\t    # which fails under a persisted requireTLS mode. directConnection works on\n143\t    # any single member for rs.conf()/rs.status() reads.\n144\t    uri = (f\"mongodb://{pod}.{HEADLESS_SERVICE}.{NAMESPACE}.svc.cluster.local:27017/\"\n145\t           \"?directConnection=true\")\n146\t    base = [\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\",\n147\t            \"mongosh\", \"--quiet\", *_mongo_tls_flags(), uri]\n148\t    res = run(base + [\"--eval\", script])\n149\t    # Adaptive auth: a deploy stage may have enabled auth, so a plain rs.conf()\n150\t    # fails \"requires authentication\". Retry once with the live admin credentials.\n151\t    out = ((res.stderr or \"\") + (res.stdout or \"\")).lower()\n152\t    if res.returncode != 0 and (\n153\t        \"requires authentication\" in out or \"not authorized\" in out\n154\t        or \"unauthorized\" in out or \"authentication failed\" in out\n155\t    ):\n156\t        af = _admin_auth_flags()\n157\t        if af:\n158\t            res = run(base + af + [\"--eval\", script])\n159\t    return res\n160\t\n161\t\n162\tdef mongo_json(pod, script, label, errors):\n163\t    res = mongo_eval(pod, script)\n164\t    if res.returncode != 0:\n165\t        detail = res.stderr.strip() or res.stdout.strip() or f\"exit {res.returncode}\"\n166\t        errors.append(f\"{label} failed on {pod}: {detail}\")\n167\t        return None\n168\t    raw = (res.stdout or \"\").strip()\n169\t    if not raw:\n170\t        errors.append(f\"{label} returned empty output on {pod}\")\n171\t        return None\n172\t    try:\n173\t        return json.loads(raw)\n174\t    except json.JSONDecodeError:\n175\t        errors.append(f\"Unable to parse {label} JSON output on {pod}\")\n176\t        return None\n177\t\n178\t\n179\tdef expected_hosts():\n180\t    return {\n181\t        f\"{CLUSTER_PREFIX}-{i}.{HEADLESS_SERVICE}.{NAMESPACE}.svc.cluster.local:27017\"\n182\t        for i in range(EXPECTED_REPLICAS)\n183\t    }\n184\t\n185\t\n186\tdef check_topology():\n187\t    errors = []\n188\t    pod = f\"{CLUSTER_PREFIX}-0\"\n189\t    conf = mongo_json(pod, \"JSON.stringify(rs.conf())\", \"rs.conf()\", errors)\n190\t    if isinstance(conf, dict):\n191\t        members = conf.get(\"members\", [])\n192\t        if len(members) != EXPECTED_REPLICAS:\n193\t            errors.append(f\"Expected {EXPECTED_REPLICAS} members in rs.conf(), got {len(members)}\")\n194\t        actual_hosts = {m.get(\"host\") for m in members if m.get(\"host\")}\n195\t        want_hosts = expected_hosts()\n196\t        if actual_hosts != want_hosts:\n197\t            errors.append(f\"Replica set hosts mismatch: expected={sorted(want_hosts)} actual={sorted(actual_hosts)}\")\n198\t\n199\t    status = mongo_json(pod, \"JSON.stringify(rs.status())\", \"rs.status()\", errors)\n200\t    if isinstance(status, dict):\n201\t        set_name = status.get(\"set\")\n202\t        if set_name != REPLICA_SET_NAME:\n203\t            errors.append(f\"Replica set name expected {REPLICA_SET_NAME}, got {set_name}\")\n204\t\n205\t    return fail(\"MongoDB initialize topology check failed:\", errors)\n206\t\n207\t\n208\tdef _health_attempt():\n209\t    errors = []\n210\t    pod = f\"{CLUSTER_PREFIX}-0\"\n211\t    status = mongo_json(pod, \"JSON.stringify(rs.status())\", \"rs.status()\", errors)\n212\t    if isinstance(status, dict):\n213\t        members = status.get(\"members\", [])\n214\t        primary = sum(1 for m in members if m.get(\"stateStr\") == \"PRIMARY\")\n215\t        secondary = sum(1 for m in members if m.get(\"stateStr\") == \"SECONDARY\")\n216\t        if primary != 1:\n217\t            errors.append(f\"Expected 1 PRIMARY, got {primary}\")\n218\t        if secondary != EXPECTED_REPLICAS - 1:\n219\t            errors.append(f\"Expected {EXPECTED_REPLICAS - 1} SECONDARY, got {secondary}\")\n220\t\n221\t    sts = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", CLUSTER_PREFIX, \"-o\", \"json\"])\n222\t    if sts.returncode != 0:\n223\t        detail = sts.stderr.strip() or sts.stdout.strip() or f\"exit {sts.returncode}\"\n224\t        errors.append(f\"Failed to read statefulset {CLUSTER_PREFIX}: {detail}\")\n225\t    else:\n226\t        try:\n227\t            sts_obj = json.loads(sts.stdout)\n228\t        except json.JSONDecodeError:\n229\t            errors.append(\"Failed to parse statefulset JSON\")\n230\t            sts_obj = {}\n231\t        spec_replicas = sts_obj.get(\"spec\", {}).get(\"replicas\")\n232\t        ready_replicas = sts_obj.get(\"status\", {}).get(\"readyReplicas\", 0)\n233\t        if spec_replicas != EXPECTED_REPLICAS:\n234\t            errors.append(f\"StatefulSet replicas expected {EXPECTED_REPLICAS}, got {spec_replicas}\")\n235\t        if ready_replicas != EXPECTED_REPLICAS:\n236\t            errors.append(f\"Ready replicas expected {EXPECTED_REPLICAS}, got {ready_replicas}\")\n237\t\n238\t    return errors\n239\t\n240\t\n241\tdef check_health():\n242\t    # O-flap-restart: restoring/reforming the set leaves members briefly in\n243\t    # STARTUP2/RECOVERING and pods Ready staggered, so the PRIMARY/SECONDARY and\n244\t    # readyReplicas tallies read short. Poll to convergence (~120s, 5s between\n245\t    # attempts); assertions unchanged.\n246\t    deadline = time.monotonic() + 120\n247\t    errors = []\n248\t    while True:\n249\t        errors = _health_attempt()\n250\t        if not errors:\n251\t            break\n252\t        if time.monotonic() >= deadline:\n253\t            break\n254\t        time.sleep(5)\n255\t    return fail(\"MongoDB initialize health check failed:\", errors)\n256\t\n257\t\n258\tdef check_data():\n259\t    errors = []\n260\t    pod = f\"{CLUSTER_PREFIX}-0\"\n261\t    res = mongo_eval(\n262\t        pod,\n263\t        f\"db.getSiblingDB('{APP_DATABASE}').{APP_COLLECTION}.countDocuments({{}})\",\n264\t    )\n265\t    if res.returncode != 0:\n266\t        detail = res.stderr.strip() or res.stdout.strip() or f\"exit {res.returncode}\"\n267\t        errors.append(f\"Failed to read {APP_DATABASE}.{APP_COLLECTION}: {detail}\")\n268\t    else:\n269\t        raw = (res.stdout or \"\").strip()\n270\t        if not raw.isdigit() or int(raw) < SEED_DOCS:\n271\t            errors.append(f\"Expected >= {SEED_DOCS} docs in {APP_DATABASE}.{APP_COLLECTION}, got {raw}\")\n272\t\n273\t    return fail(\"MongoDB initialize data check failed:\", errors)\n274\t\n275\t\n276\tdef main():\n277\t    parser = argparse.ArgumentParser()\n278\t    parser.add_argument(\"--check\", default=\"all\", choices=[\"all\", \"topology\", \"health\", \"data\"])\n279\t    args = parser.parse_args()\n280\t\n281\t    if args.check == \"topology\":\n282\t        return check_topology()\n283\t    if args.check == \"health\":\n284\t        return check_health()\n285\t    if args.check == \"data\":\n286\t        return check_data()\n287\t\n288\t    for fn in (check_topology, check_health, check_data):\n289\t        rc = fn()\n290\t        if rc != 0:\n291\t            return rc\n292\t    print(\"MongoDB initialize verified\")\n293\t    return 0\n294\t\n295\t\n296\tif __name__ == \"__main__\":\n297\t    sys.exit(main())\n298\t"}]},"parent_tool_use_id":null,"session_id":"40701d80-6e15-4f62-9c68-be8814464cd3","uuid":"0ad0a0f1-347e-49e2-a127-b624639dd5d7","timestamp":"2026-07-02T00:40:14.457Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/mongodb/initialize/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport argparse\nimport base64\nimport json\nimport os\nimport subprocess\nimport sys\nimport time\n\n\nNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"mongodb\")\nCLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"mongodb-replica\")\nHEADLESS_SERVICE = os.environ.get(\"BENCH_PARAM_HEADLESS_SERVICE_NAME\", \"mongodb-replica-svc\")\nREPLICA_SET_NAME = os.environ.get(\"BENCH_PARAM_REPLICA_SET_NAME\", CLUSTER_PREFIX)\nAPP_DATABASE = os.environ.get(\"BENCH_PARAM_APP_DATABASE\", \"app\")\nAPP_COLLECTION = os.environ.get(\"BENCH_PARAM_APP_COLLECTION\", \"test\")\nSEED_DOCS = int(os.environ.get(\"BENCH_PARAM_SEED_DOCS\", \"3\"))\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\n_ADMIN_PW = None\n\n\ndef _admin_auth_flags():\n    \"\"\"`-u <admin> -p <pw> --authenticationDatabase admin` when the admin secret\n    exists. The env PERSISTS across stages, so a prior deploy stage may have\n    enabled auth (keyfile + admin user), after which rs.conf()/rs.status()\n    require credentials. Empty when no admin secret is present (standalone,\n    pre-auth) so the plain connection is used. Cached.\"\"\"\n    global _ADMIN_PW\n    if _ADMIN_PW is None:\n        secret = os.environ.get(\"BENCH_PARAM_ADMIN_SECRET_NAME\", \"admin-user-password\")\n        r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", secret,\n                 \"-o\", \"jsonpath={.data.password}\"])\n        pw = \"\"\n        if r.returncode == 0 and r.stdout.strip():\n            try:\n                pw = base64.b64decode(r.stdout.strip()).decode()\n            except Exception:\n                pw = \"\"\n        _ADMIN_PW = pw\n    if _ADMIN_PW:\n        user = os.environ.get(\"BENCH_PARAM_ADMIN_USERNAME\", \"admin-user\")\n        return [\"-u\", user, \"-p\", _ADMIN_PW, \"--authenticationDatabase\", \"admin\"]\n    return []\n\n\n_TLS_FLAGS_CACHE = None\n\n\ndef _mongo_tls_flags(probe_pod=None):\n    \"\"\"mongosh transport flags that adapt to the cluster's LIVE TLS mode.\n\n    The environment PERSISTS across workflow stages, so an earlier stage\n    (mongodb/tls-setup or mongodb/certificate-rotation) may have turned TLS on,\n    after which a plain mongosh connection is refused. Detect TLS by probing the\n    running mongo pod for a CA cert mounted at the paths the TLS stages use; if\n    present, connect with --tls --tlsCAFile (and a client cert for mutual TLS\n    when one is mounted), else connect plain. Standalone (no CA mounted) this\n    returns [] -> identical plain behaviour. It only adds transport flags; every\n    real check still runs and still fails when its condition is unmet.\n    \"\"\"\n    global _TLS_FLAGS_CACHE\n    if _TLS_FLAGS_CACHE is not None:\n        return list(_TLS_FLAGS_CACHE)\n    flags = []\n    pod = probe_pod or f\"{CLUSTER_PREFIX}-0\"\n    ca_path = None\n    for cand in (\n        \"/etc/tls/ca.crt\",\n        \"/etc/mongo-ca/ca.crt\",\n        \"/etc/mongodb/tls/ca.crt\",\n        \"/etc/ssl/mongodb/ca.crt\",\n    ):\n        probe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + cand])\n        if probe.returncode == 0:\n            ca_path = cand\n            break\n    if ca_path:\n        flags = [\"--tls\", \"--tlsAllowInvalidHostnames\", \"--tlsAllowInvalidCertificates\", \"--tlsCAFile\", ca_path]\n        for client_pem in (\"/etc/tls/client.pem\", \"/etc/mongo-ca/client.pem\"):\n            cprobe = run([\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\", \"/bin/sh\", \"-c\", \"test -f \" + client_pem])\n            if cprobe.returncode == 0:\n                flags += [\"--tlsCertificateKeyFile\", client_pem]\n                break\n    _TLS_FLAGS_CACHE = flags\n    return list(flags)\n\ndef _resolve_expected_replicas():\n    \"\"\"Topology size to enforce.\n\n    The environment PERSISTS across workflow stages, so an earlier\n    replica-scaling stage may have grown the replica set past the standalone\n    default of 3. Resolve the expected count from (in priority order): an\n    explicit ``expected_replicas``/``target_replicas`` param override, else the\n    LIVE StatefulSet (ready, else spec'd replicas), else the standalone default\n    of 3. This adapts the topology/count check to whatever the workflow\n    accumulated without loosening it -- a non-solving agent that drops or fails\n    a member still mismatches the live ready/spec count.\n    \"\"\"\n    for key in (\"BENCH_PARAM_EXPECTED_REPLICAS\", \"BENCH_PARAM_TARGET_REPLICAS\"):\n        val = os.environ.get(key)\n        if val is not None and str(val).strip():\n            try:\n                return int(val)\n            except ValueError:\n                pass\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", CLUSTER_PREFIX, \"-o\", \"json\"])\n    if res.returncode == 0:\n        try:\n            sts = json.loads(res.stdout)\n            status = sts.get(\"status\", {}) or {}\n            spec = sts.get(\"spec\", {}) or {}\n            live = status.get(\"readyReplicas\")\n            if not isinstance(live, int) or live <= 0:\n                live = spec.get(\"replicas\")\n            if isinstance(live, int) and live > 0:\n                return live\n        except (json.JSONDecodeError, AttributeError):\n            pass\n    return 3\n\n\nEXPECTED_REPLICAS = _resolve_expected_replicas()\n\n\ndef fail(prefix, errors):\n    if errors:\n        print(prefix, file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n    return 0\n\n\ndef mongo_eval(pod, script):\n    # Connect via the member's own FQDN with directConnection=true to skip SDAM\n    # topology monitoring, which a bare localhost connection would start and\n    # which fails under a persisted requireTLS mode. directConnection works on\n    # any single member for rs.conf()/rs.status() reads.\n    uri = (f\"mongodb://{pod}.{HEADLESS_SERVICE}.{NAMESPACE}.svc.cluster.local:27017/\"\n           \"?directConnection=true\")\n    base = [\"kubectl\", \"-n\", NAMESPACE, \"exec\", pod, \"--\",\n            \"mongosh\", \"--quiet\", *_mongo_tls_flags(), uri]\n    res = run(base + [\"--eval\", script])\n    # Adaptive auth: a deploy stage may have enabled auth, so a plain rs.conf()\n    # fails \"requires authentication\". Retry once with the live admin credentials.\n    out = ((res.stderr or \"\") + (res.stdout or \"\")).lower()\n    if res.returncode != 0 and (\n        \"requires authentication\" in out or \"not authorized\" in out\n        or \"unauthorized\" in out or \"authentication failed\" in out\n    ):\n        af = _admin_auth_flags()\n        if af:\n            res = run(base + af + [\"--eval\", script])\n    return res\n\n\ndef mongo_json(pod, script, label, errors):\n    res = mongo_eval(pod, script)\n    if res.returncode != 0:\n        detail = res.stderr.strip() or res.stdout.strip() or f\"exit {res.returncode}\"\n        errors.append(f\"{label} failed on {pod}: {detail}\")\n        return None\n    raw = (res.stdout or \"\").strip()\n    if not raw:\n        errors.append(f\"{label} returned empty output on {pod}\")\n        return None\n    try:\n        return json.loads(raw)\n    except json.JSONDecodeError:\n        errors.append(f\"Unable to parse {label} JSON output on {pod}\")\n        return None\n\n\ndef expected_hosts():\n    return {\n        f\"{CLUSTER_PREFIX}-{i}.{HEADLESS_SERVICE}.{NAMESPACE}.svc.cluster.local:27017\"\n        for i in range(EXPECTED_REPLICAS)\n    }\n\n\ndef check_topology():\n    errors = []\n    pod = f\"{CLUSTER_PREFIX}-0\"\n    conf = mongo_json(pod, \"JSON.stringify(rs.conf())\", \"rs.conf()\", errors)\n    if isinstance(conf, dict):\n        members = conf.get(\"members\", [])\n        if len(members) != EXPECTED_REPLICAS:\n            errors.append(f\"Expected {EXPECTED_REPLICAS} members in rs.conf(), got {len(members)}\")\n        actual_hosts = {m.get(\"host\") for m in members if m.get(\"host\")}\n        want_hosts = expected_hosts()\n        if actual_hosts != want_hosts:\n            errors.append(f\"Replica set hosts mismatch: expected={sorted(want_hosts)} actual={sorted(actual_hosts)}\")\n\n    status = mongo_json(pod, \"JSON.stringify(rs.status())\", \"rs.status()\", errors)\n    if isinstance(status, dict):\n        set_name = status.get(\"set\")\n        if set_name != REPLICA_SET_NAME:\n            errors.append(f\"Replica set name expected {REPLICA_SET_NAME}, got {set_name}\")\n\n    return fail(\"MongoDB initialize topology check failed:\", errors)\n\n\ndef _health_attempt():\n    errors = []\n    pod = f\"{CLUSTER_PREFIX}-0\"\n    status = mongo_json(pod, \"JSON.stringify(rs.status())\", \"rs.status()\", errors)\n    if isinstance(status, dict):\n        members = status.get(\"members\", [])\n        primary = sum(1 for m in members if m.get(\"stateStr\") == \"PRIMARY\")\n        secondary = sum(1 for m in members if m.get(\"stateStr\") == \"SECONDARY\")\n        if primary != 1:\n            errors.append(f\"Expected 1 PRIMARY, got {primary}\")\n        if secondary != EXPECTED_REPLICAS - 1:\n            errors.append(f\"Expected {EXPECTED_REPLICAS - 1} SECONDARY, got {secondary}\")\n\n    sts = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", CLUSTER_PREFIX, \"-o\", \"json\"])\n    if sts.returncode != 0:\n        detail = sts.stderr.strip() or sts.stdout.strip() or f\"exit {sts.returncode}\"\n        errors.append(f\"Failed to read statefulset {CLUSTER_PREFIX}: {detail}\")\n    else:\n        try:\n            sts_obj = json.loads(sts.stdout)\n        except json.JSONDecodeError:\n            errors.append(\"Failed to parse statefulset JSON\")\n            sts_obj = {}\n        spec_replicas = sts_obj.get(\"spec\", {}).get(\"replicas\")\n        ready_replicas = sts_obj.get(\"status\", {}).get(\"readyReplicas\", 0)\n        if spec_replicas != EXPECTED_REPLICAS:\n            errors.append(f\"StatefulSet replicas expected {EXPECTED_REPLICAS}, got {spec_replicas}\")\n        if ready_replicas != EXPECTED_REPLICAS:\n            errors.append(f\"Ready replicas expected {EXPECTED_REPLICAS}, got {ready_replicas}\")\n\n    return errors\n\n\ndef check_health():\n    # O-flap-restart: restoring/reforming the set leaves members briefly in\n    # STARTUP2/RECOVERING and pods Ready staggered, so the PRIMARY/SECONDARY and\n    # readyReplicas tallies read short. Poll to convergence (~120s, 5s between\n    # attempts); assertions unchanged.\n    deadline = time.monotonic() + 120\n    errors = []\n    while True:\n        errors = _health_attempt()\n        if not errors:\n            break\n        if time.monotonic() >= deadline:\n            break\n        time.sleep(5)\n    return fail(\"MongoDB initialize health check failed:\", errors)\n\n\ndef check_data():\n    errors = []\n    pod = f\"{CLUSTER_PREFIX}-0\"\n    res = mongo_eval(\n        pod,\n        f\"db.getSiblingDB('{APP_DATABASE}').{APP_COLLECTION}.countDocuments({{}})\",\n    )\n    if res.returncode != 0:\n        detail = res.stderr.strip() or res.stdout.strip() or f\"exit {res.returncode}\"\n        errors.append(f\"Failed to read {APP_DATABASE}.{APP_COLLECTION}: {detail}\")\n    else:\n        raw = (res.stdout or \"\").strip()\n        if not raw.isdigit() or int(raw) < SEED_DOCS:\n            errors.append(f\"Expected >= {SEED_DOCS} docs in {APP_DATABASE}.{APP_COLLECTION}, got {raw}\")\n\n    return fail(\"MongoDB initialize data check failed:\", errors)\n\n\ndef main():\n    parser = argparse.ArgumentParser()\n    parser.add_argument(\"--check\", default=\"all\", choices=[\"all\", \"topology\", \"health\", \"data\"])\n    args = parser.parse_args()\n\n    if args.check == \"topology\":\n        return check_topology()\n    if args.check == \"health\":\n        return check_health()\n    if args.check == \"data\":\n        return check_data()\n\n    for fn in (check_topology, check_health, check_data):\n        rc = fn()\n        if rc != 0:\n            return rc\n    print(\"MongoDB initialize verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":298,"startLine":1,"totalLines":298}}}
