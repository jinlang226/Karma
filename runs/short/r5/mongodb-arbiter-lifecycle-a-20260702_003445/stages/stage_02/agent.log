{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01DEiHw2gbJQ1Bnmg3poFmtw","type":"tool_result","content":"1\t# mongodb/initialize\n2\t# MongoDB initialize task\n3\t\n4\tparams:\n5\t  cluster_prefix:\n6\t    default: mongodb-replica\n7\t    description: StatefulSet name of the replica set members.\n8\t  replica_set_name:\n9\t    default: mongodb-replica\n10\t    description: MongoDB replica set _id used when initiating the set.\n11\t  fault_host_suffix:\n12\t    default: mongo-wrong\n13\t    description: Bad host suffix injected to break a member's configuration.\n14\t  app_database:\n15\t    default: app\n16\t    description: Application database seeded with data.\n17\t  app_collection:\n18\t    default: test\n19\t    description: Application collection seeded with data.\n20\t\n21\tprompt: |\n22\t  Replica set is not healthy. Restore a stable 3-member replica set without data loss.\n23\t\n24\tnamespace_contract:\n25\t  required_roles: []\n26\t\n27\tmetrics:\n28\t  - time_to_first_mutation\n29\t\n30\tpreconditionUnits:\n31\t  - name: mongo_env_ready\n32\t    on_probe_fail: skip\n33\t    probe:\n34\t      - command: \"kubectl -n mongodb get pod {{params.cluster_prefix}}-0 2>/dev/null | grep -c Running\"\n35\t        timeout_sec: 10\n36\t    apply:\n37\t      - command: |\n38\t          /bin/sh -c '\n39\t          kubectl delete namespace mongodb --ignore-not-found=true; kubectl wait --for=delete namespace/mongodb --timeout=120s || true\n40\t          '\n41\t        sleep: 2\n42\t      - command: \"kubectl create namespace mongodb\"\n43\t        sleep: 1\n44\t      - command: \"kubectl -n mongodb apply -f cases/mongodb/initialize/resource/services.yaml\"\n45\t        sleep: 2\n46\t      - command: \"kubectl -n mongodb apply -f cases/mongodb/initialize/resource/statefulset.yaml\"\n47\t        sleep: 5\n48\t      - command: |\n49\t          for i in $(seq 1 120); do\n50\t            ready=$(kubectl -n mongodb get sts {{params.cluster_prefix}} -o jsonpath='{.status.readyReplicas}' 2>/dev/null)\n51\t            if [ \"${ready:-0}\" -ge 3 ]; then\n52\t              exit 0\n53\t            fi\n54\t            sleep 5\n55\t          done\n56\t          exit 1\n57\t        sleep: 2\n58\t      # Pod-Ready != mongod accepting TCP (§1.10): ping-until-ok before rs.initiate.\n59\t      - command: |\n60\t          for i in $(seq 1 30); do\n61\t            kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval 'db.runCommand({ping:1}).ok' 2>/dev/null | grep -q 1 && exit 0\n62\t            sleep 3\n63\t          done\n64\t          exit 1\n65\t        sleep: 2\n66\t      - command: |\n67\t          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\n68\t          rs.initiate({_id:\"{{params.replica_set_name}}\",members:[\n69\t            {_id:0,host:\"mongodb-replica-0.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"},\n70\t            {_id:1,host:\"mongodb-replica-1.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"},\n71\t            {_id:2,host:\"mongodb-replica-2.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"}\n72\t          ]})'\n73\t        sleep: 5\n74\t      - command: |\n75\t          for i in $(seq 1 20); do\n76\t            kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval 'db.hello().isWritablePrimary' | grep true && exit 0\n77\t            sleep 3\n78\t          done\n79\t          exit 1\n80\t        sleep: 2\n81\t      - command: |\n82\t          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\n83\t          cfg = rs.conf();\n84\t          cfg.members[1].host = \"mongodb-replica-1.{{params.fault_host_suffix}}.svc.cluster.local:27017\";\n85\t          cfg.version += 1;\n86\t          rs.reconfig(cfg);\n87\t          '\n88\t        sleep: 5\n89\t      - command: \"kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval 'db.getSiblingDB(\\\"{{params.app_database}}\\\").{{params.app_collection}}.insertMany([{x:1},{x:2},{x:3}], {writeConcern:{w:1}});'\"\n90\t        sleep: 2\n91\t    verify:\n92\t      - command: \"kubectl -n mongodb get pods 2>/dev/null | grep -c Running\"\n93\t        timeout_sec: 10\n94\t\n95\t  # Additive data fixture (composition safety): the oracle requires >= 3 docs in\n96\t  # {{params.app_database}}.{{params.app_collection}}. When this case runs chained on an inherited cluster the\n97\t  # destructive `apply` above is skipped, so a prior stage may have left the\n98\t  # collection short. This unit tops it up ADDITIVELY to the required count WITHOUT\n99\t  # dropping/recreating the collection or touching the namespace/cluster.\n100\t  # The probe gates on the DATA COUNT (not \"pods Running\"), so it runs\n101\t  # whenever the collection is short; standalone (where `apply` already seeded 3)\n102\t  # it sees the required count and skips -> identical behaviour. Idempotent: inserts\n103\t  # only the deficit (required - current).\n104\t  - name: mongo_seed_fixture\n105\t    on_probe_fail: skip\n106\t    probe:\n107\t      # Auth-adaptive: when an inherited cluster has auth enabled the admin secret\n108\t      # exists, so authenticate; otherwise connect plain. Works both ways.\n109\t      - command: |\n110\t          /bin/sh -c 't=\"\"; for cca in /etc/tls/ca.crt /etc/mongo-ca/ca.crt; do kubectl -n mongodb exec mongodb-replica-0 -- ls $cca >/dev/null 2>&1 && { t=\"--tls --tlsAllowInvalidHostnames --tlsAllowInvalidCertificates --tlsCAFile $cca\"; break; }; done; au=\"\"; pw=$(kubectl -n mongodb get secret admin-user-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null); [ -n \"$pw\" ] && au=\"-u admin-user -p $pw --authenticationDatabase admin\"; n=$(P=\"\"; for _pi in $(seq 1 30); do P=$(kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet $t $au --eval '\\''rs.hello().primary'\\'' 2>/dev/null | cut -d. -f1); [ -n \"$P\" ] && break; sleep 2; done; P=${P:-mongodb-replica-0}; kubectl -n mongodb exec \"$P\" -- mongosh --qu