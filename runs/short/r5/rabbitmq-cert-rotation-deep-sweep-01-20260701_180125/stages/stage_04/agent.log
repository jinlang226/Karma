{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01R4EDu17W4eBRLtc2Km8DBJ","type":"tool_result","content":"# rabbitmq/adversarial/clear_ha_policy\n#\n# Clears the ha-all mirroring policy on the /app vhost mid-task, simulating a\n# config drift that silently removes queue mirroring. The agent's policy-sync\n# task must re-establish the policy rather than assume it is still present.\n#\n# Commands target the bench namespace explicitly (-n ${BENCH_NAMESPACE}) and\n# exec into <cluster_prefix>-0.\n#\n# Deploy: clear the ha-all policy on the vhost.\n# Lift:   no-op (the agent is expected to restore it; verify the cluster is up).\n\nparams:\n  cluster_prefix:\n    default: rabbitmq\n    description: Name prefix of the RabbitMQ cluster; the adversary execs into <prefix>-0.\n  vhost:\n    default: /app\n    description: Virtual host whose mirroring policy is cleared.\n  policy_name:\n    default: ha-all\n    description: Name of the mirroring policy the adversary removes (the injected fault).\n\ndeploy:\n  # The cluster pod must already exist (the case precondition stands it up).\n  on_probe_fail: error\n  probe:\n    - command: \"kubectl -n ${BENCH_NAMESPACE} exec {{params.cluster_prefix}}-0 -- rabbitmqctl cluster_status\"\n      timeout_sec: 30\n  apply:\n    - command: \"kubectl -n ${BENCH_NAMESPACE} exec {{params.cluster_prefix}}-0 -- rabbitmqctl clear_policy -p {{params.vhost}} {{params.policy_name}}\"\n      timeout_sec: 30\n  verify:\n    - command: >-\n        /bin/sh -c \"! kubectl -n ${BENCH_NAMESPACE} exec {{params.cluster_prefix}}-0 -- rabbitmqctl list_policies -p {{params.vhost}}\n        | grep -qw {{params.policy_name}}\"\n      timeout_sec: 30\n\nlift:\n  # Nothing to undo -- restoring the policy is the agent's job. Probe always\n  # 'fails' so the (empty) apply is skipped; this just records cluster health.\n  on_probe_fail: skip\n  probe:\n    - command: \"/bin/sh -c false\"\n      timeout_sec: 5\n  apply:\n    - command: \"kubectl -n ${BENCH_NAMESPACE} exec {{params.cluster_prefix}}-0 -- rabbitmqctl cluster_status\"\n      timeout_sec: 30\n  verify:\n    - command: \"kubectl -n ${BENCH_NAMESPACE} exec {{params.cluster_prefix}}-0 -- rabbitmqctl cluster_status\"\n      timeout_sec: 30\n\nprompt_hints:\n  deploy: |\n    Note: queue mirroring policies on this cluster may have been altered by an\n    external change during this task. Verify the required policy is present on\n    the vhost before concluding the cluster is correctly configured.\n  active: |\n    Reminder: a policy that should be in place may have been cleared earlier.\n    Re-check the vhost's policies before finishing.","is_error":false}]},"parent_tool_use_id":null,"session_id":"2a1802f3-d09d-48d3-b09c-7a756ff06a8b","uuid":"0a99fd9e-b383-4a6b-864f-17231bdf2839","timestamp":"2026-07-01T18:32:13.291Z","tool_use_result":{"stdout":"# rabbitmq/adversarial/clear_ha_policy\n#\n# Clears the ha-all mirroring policy on the /app vhost mid-task, simulating a\n# config drift that silently removes queue mirroring. The agent's policy-sync\n# task must re-establish the policy rather than assume it is still present.\n#\n# Commands target the bench namespace explicitly (-n ${BENCH_NAMESPACE}) and\n# exec into <cluster_prefix>-0.\n#\n# Deploy: clear the ha-all policy on the vhost.\n# Lift:   no-op (the agent is expected to restore it; verify the cluster is up).\n\nparams:\n  cluster_prefix:\n    default: rabbitmq\n    description: Name prefix of the RabbitMQ cluster; the adversary execs into <prefix>-0.\n  vhost:\n    default: /app\n    description: Virtual host whose mirroring policy is cleared.\n  policy_name:\n    default: ha-all\n    description: Name of the mirroring policy the adversary removes (the injected fault).\n\ndeploy:\n  # The cluster pod must already exist (the case precondition stands it up).\n  on_probe_fail: error\n  probe:\n    - command: \"kubectl -n ${BENCH_NAMESPACE} exec {{params.cluster_prefix}}-0 -- rabbitmqctl cluster_status\"\n      timeout_sec: 30\n  apply:\n    - command: \"kubectl -n ${BENCH_NAMESPACE} exec {{params.cluster_prefix}}-0 -- rabbitmqctl clear_policy -p {{params.vhost}} {{params.policy_name}}\"\n      timeout_sec: 30\n  verify:\n    - command: >-\n        /bin/sh -c \"! kubectl -n ${BENCH_NAMESPACE} exec {{params.cluster_prefix}}-0 -- rabbitmqctl list_policies -p {{params.vhost}}\n        | grep -qw {{params.policy_name}}\"\n      timeout_sec: 30\n\nlift:\n  # Nothing to undo -- restoring the policy is the agent's job. Probe always\n  # 'fails' so the (empty) apply is skipped; this just records cluster health.\n  on_probe_fail: skip\n  probe:\n    - command: \"/bin/sh -c false\"\n      timeout_sec: 5\n  apply:\n    - command: \"kubectl -n ${BENCH_NAMESPACE} exec {{params.cluster_prefix}}-0 -- rabbitmqctl cluster_status\"\n      timeout_sec: 30\n  verify:\n    - command: \"kubectl -n ${BENCH_NAMESPACE} exec {{params.cluster_prefix}}-0 -- rabbitmqctl cluster_status\"\n      timeout_sec: 30\n\nprompt_hints:\n  deploy: |\n    Note: queue mirroring policies on this cluster may have been altered by an\n    external change during this task. Verify the required policy is present on\n    the vhost before concluding the cluster is correctly configured.\n  active: |\n    Reminder: a policy that should be in place may have been cleared earlier.\n    Re-check the vhost's policies before finishing.","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
