runs as a later workflow\n  # stage a prior identical stage already pointed Prometheus at rabbitmq (>= 3\n  # active targets), so the agent would have nothing to do and the baseline never\n  # held. The apply resets this case's OWN prometheus-config back to its base\n  # scrape config (no rabbitmq job) and restarts Prometheus so the rabbitmq\n  # targets drop below 3 -> baseline restored for the agent to re-configure.\n  # Standalone (config already base) it re-applies the same configmap and is a\n  # harmless restart -> identical behaviour. Resets only this case's own\n  # monitoring artifact, never inherited cluster state.\n  - name: monitoring_baseline_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"python3 cases/rabbitmq/manual_monitoring/setup_precondition_check.py --namespace ${BENCH_NAMESPACE} --min-ready 3\"\n        timeout_sec: 40\n    apply:\n      - command: \"envsubst '$BENCH_NAMESPACE $BENCH_NS_SOURCE $BENCH_NS_TARGET $BENCH_PARAM_CLUSTER_PREFIX $BENCH_PARAM_BLUE_CLUSTER_PREFIX $BENCH_PARAM_GREEN_CLUSTER_PREFIX $BENCH_PARAM_FROM_VERSION' < cases/rabbitmq/manual_monitoring/resource/prometheus.yaml | kubectl -n ${BENCH_NAMESPACE} apply -f -\"\n        sleep: 1\n      - command: \"kubectl -n ${BENCH_NAMESPACE} rollout restart deploy/prometheus\"\n        sleep: 2\n      - command: \"kubectl -n ${BENCH_NAMESPACE} rollout status deploy/prometheus --timeout=120s\"\n        sleep: 1\n    verify:\n      - command: \"python3 cases/rabbitmq/manual_monitoring/setup_precondition_check.py --namespace ${BENCH_NAMESPACE} --min-ready 3\"\n        timeout_sec: 40\n\noracle:\n  verify:\n    before_commands:\n      - command: \"envsubst '$BENCH_NAMESPACE $BENCH_NS_SOURCE $BENCH_NS_TARGET $BENCH_PARAM_CLUSTER_PREFIX $BENCH_PARAM_BLUE_CLUSTER_PREFIX $BENCH_PARAM_GREEN_CLUSTER_PREFIX $BENCH_PARAM_FROM_VERSION' < cases/rabbitmq/common/oracle-client.yaml | kubectl -n ${BENCH_NAMESPACE} apply -f -\"\n        timeout_sec: 30\n      - command: \"kubectl -n ${BENCH