ttpGet:\n            path: /health\n            port: 8080\n          initialDelaySeconds: 30\n          periodSeconds: 10\n          failureThreshold: 3\n        volumeMounts:\n        - name: datadir\n          mountPath: /cockroach/cockroach-data\n  volumeClaimTemplates:\n  - metadata:\n      name: datadir\n    spec:\n      accessModes: [\"ReadWriteOnce\"]\n      resources:\n        requests:\n          storage: 10Gi\nEOF","description":"Recreate StatefulSet with Parallel pod management"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":465,"cache_read_input_tokens":33675,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":465},"output_tokens":60,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"57feb0c6-f11a-4e5d-a4d7-79f6638dafdd","uuid":"c9fe40d9-49c4-4e1f-aad1-993628014c56","request_id":"req_011CccDocHJzeuDYYVRFuJc6"}
