   }\n            },\n            {\n                'secret': {\n                    'name': 'cockroachdb-client-root',\n                    'items': [\n                        {'key': 'client.root.crt', 'path': 'client.root.crt', 'mode': 292},\n                        {'key': 'client.root.key', 'path': 'client.root.key', 'mode': 256}\n                    ]\n                }\n            }\n        ]\n    }\n})\n\n# Update probes to HTTPS\ncontainer['livenessProbe']['httpGet']['scheme'] = 'HTTPS'\ncontainer['readinessProbe']['httpGet']['scheme'] = 'HTTPS'\n\nprint(json.dumps(ss))\n\" | kubectl apply -f - 2>&1","description":"Update StatefulSet to enable TLS with cert mounts and HTTPS probes"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":766,"cache_read_input_tokens":36795,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":766},"output_tokens":68,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"9a2cfedd-deef-4b4c-b890-670b3d27cbd9","uuid":"d7957204-474a-479a-b3fe-e8cd665b3a95","request_id":"req_011Ccb4hkTUMxsY3hWKGEBb5"}
