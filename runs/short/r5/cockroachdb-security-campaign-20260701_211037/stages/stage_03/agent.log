1\n            port: http\n            scheme: HTTPS\n          initialDelaySeconds: 10\n          periodSeconds: 5\n          failureThreshold: 2\n        volumeMounts:\n        - mountPath: /cockroach/cockroach-data\n          name: datadir\n        - mountPath: /cockroach/cockroach-certs\n          name: certs\n          readOnly: true\n      volumes:\n      - name: certs\n        secret:\n          secretName: crdb-certs\n          defaultMode: 0400\n  volumeClaimTemplates:\n  - metadata:\n      name: datadir\n    spec:\n      accessModes:\n      - ReadWriteOnce\n      resources:\n        requests:\n          storage: 10Gi\nEOF","description":"Apply updated StatefulSet with TLS certs-dir and HTTPS probes"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":1,"cache_creation_input_tokens":1200,"cache_read_input_tokens":34888,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1200},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"39c57f24-2c9d-4807-b515-440403b200fd","uuid":"8b1f50dd-3621-4d27-b69d-d31c4947267f","request_id":"req_011Ccc3BwEfXtv6MHiSqEqEL"}
