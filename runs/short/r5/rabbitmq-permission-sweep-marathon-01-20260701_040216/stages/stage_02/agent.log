{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_017tMme4sTEquiBhJsWbiVsT","type":"tool_result","content":"Usage\n\nrabbitmqctl [--node <node>] [--longnames] [--quiet] delete_queue <queue_name> [--if-empty|-e] [--if-unused|-u] [--timeout <timeout>]\n\n   cancel_sync_queue                      Instructs a synchronising mirrored queue to stop synchronising itself\n   sync_queue                             Instructs a mirrored queue with unsynchronised mirrors (follower replicas) to synchronise them\n   list_queues                            Lists queues and their properties\n   list_unresponsive_queues               Tests queues to respond within timeout. Lists those which did not respond\n   restart_vhost                          Restarts a failed vhost data stores and queues\n   update_vhost_metadata                  Updates metadata (tags, description, default queue type) a virtual host\nQueues:\n   delete_queue                           Deletes a queue\n   purge_queue                            Purges a queue (removes all messages in it)","is_error":false}]},"parent_tool_use_id":null,"session_id":"a6aa628a-d724-4f36-b8fb-d8ce3159d322","uuid":"963e4812-fd46-4e7d-b02e-1cfb3415f965","timestamp":"2026-07-01T04:07:45.385Z","tool_use_result":{"stdout":"Usage\n\nrabbitmqctl [--node <node>] [--longnames] [--quiet] delete_queue <queue_name> [--if-empty|-e] [--if-unused|-u] [--timeout <timeout>]\n\n   cancel_sync_queue                      Instructs a synchronising mirrored queue to stop synchronising itself\n   sync_queue                             Instructs a mirrored queue with unsynchronised mirrors (follower replicas) to synchronise them\n   list_queues                            Lists queues and their properties\n   list_unresponsive_queues               Tests queues to respond within timeout. Lists those which did not respond\n   restart_vhost                          Restarts a failed vhost data stores and queues\n   update_vhost_metadata                  Updates metadata (tags, description, default queue type) a virtual host\nQueues:\n   delete_queue                           Deletes a queue\n   purge_queue                            Purges a queue (removes all messages in it)","stderr":"","interrupted":false,"isImage":false,"noOutputExpected":false}}
