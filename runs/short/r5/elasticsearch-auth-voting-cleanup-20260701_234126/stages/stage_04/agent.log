{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01QtUDSpNh2PhySKzofBBjyn","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport base64\n3\timport datetime\n4\timport os\n5\timport subprocess\n6\timport sys\n7\timport tempfile\n8\timport json\n9\t\n10\tNAMESPACE = \"elasticsearch\"\n11\tSECRET = \"es-http-tls\"\n12\tOLD_CM = \"es-http-old\"\n13\tCLIENT_CA_CM = \"es-http-ca\"\n14\tSERVICE = \"es-http\"\n15\tCURL_POD = \"curl-test\"\n16\tMIN_VALID_DAYS = 300\n17\tMAX_VALID_DAYS = 400\n18\t\n19\t\n20\tdef run(cmd):\n21\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n22\t\n23\t\n24\tdef get_secret_data(key, errors):\n25\t    json_key = key.replace(\".\", \"\\\\.\")\n26\t    cmd = [\n27\t        \"kubectl\",\n28\t        \"-n\",\n29\t        NAMESPACE,\n30\t        \"get\",\n31\t        \"secret\",\n32\t        SECRET,\n33\t        \"-o\",\n34\t        f\"jsonpath={{.data.{json_key}}}\",\n35\t    ]\n36\t    result = run(cmd)\n37\t    if result.returncode != 0:\n38\t        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n39\t        errors.append(f\"Failed to read secret {SECRET} {key}: {detail}\")\n40\t        return None\n41\t    raw = result.stdout.strip()\n42\t    if not raw:\n43\t        errors.append(f\"Secret {SECRET} missing key {key}\")\n44\t        return None\n45\t    try:\n46\t        return base64.b64decode(raw)\n47\t    except base64.binascii.Error:\n48\t        errors.append(f\"Secret {SECRET} key {key} is not valid base64\")\n49\t        return None\n50\t\n51\t\n52\tdef get_configmap_text(name, key, errors):\n53\t    json_key = key.replace(\".\", \"\\\\.\")\n54\t    cmd = [\n55\t        \"kubectl\",\n56\t        \"-n\",\n57\t        NAMESPACE,\n58\t        \"get\",\n59\t        \"configmap\",\n60\t        name,\n61\t        \"-o\",\n62\t        f\"jsonpath={{.data.{json_key}}}\",\n63\t    ]\n64\t    result = run(cmd)\n65\t    if result.returncode != 0:\n66\t        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n67\t        errors.append(f\"Failed to read configmap {name} {key}: {detail}\")\n68\t        return None\n69\t    return result.stdout.strip()\n70\t\n71\t\n72\tdef openssl_fingerprint(path, errors, label):\n73\t    result = run([\"openssl\", \"x509\", \"-noout\", \"-fingerprint\", \"-sha256\", \"-in\", path])\n74\t    if result.returncode != 0:\n75\t        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n76\t        errors.append(f\"Failed to read fingerprint for {label}: {detail}\")\n77\t        return None\n78\t    line = result.stdout.strip()\n79\t    if \"=\" not in line:\n80\t        errors.append(f\"Unexpected fingerprint output for {label}: {line}\")\n81\t        return None\n82\t    return line.split(\"=\", 1)[1].strip()\n83\t\n84\t\n85\tdef _split_pem_certs(text):\n86\t    \"\"\"Split a PEM blob into its individual certificate blocks.\n87\t\n88\t    A ca.crt may legitimately be a trust BUNDLE (old-CA + new-CA) for a zero-gap\n89\t    rollover, so we must inspect every entry, not just the leading one.\n90\t    \"\"\"\n91\t    certs = []\n92\t    cur = []\n93\t    capture = False\n94\t    for line in (text or \"\").splitlines():\n95\t        if \"BEGIN CERTIFICATE\" in line:\n96\t            capture = True\n97\t            cur = [line]\n98\t        elif \"END CERTIFICATE\" in line:\n99\t            cur.append(line)\n100\t            certs.append(\"\\n\".join(cur) + \"\\n\")\n101\t            capture = False\n102\t            cur = []\n103\t        elif capture:\n104\t            cur.append(line)\n105\t    return certs\n106\t\n107\t\n108\tdef openssl_fingerprints_all(path, errors, label):\n109\t    \"\"\"Fingerprint EVERY certificate in a PEM file (O-multi).\n110\t\n111\t    ``openssl x509`` reads only the FIRST cert in a bundle, so a single call\n112\t    silently grades the wrong element. Split the PEM and fingerprint each block,\n113\t    returning the set of fingerprints found. Returns None only on a hard read\n114\t    failure; an empty set means no parseable certs.\n115\t    \"\"\"\n116\t    try:\n117\t        with open(path, \"r\", encoding=\"utf-8\") as f:\n118\t            blob = f.read()\n119\t    except OSError as exc:\n120\t        errors.append(f\"Failed to read {label} PEM: {exc}\")\n121\t        return None\n122\t    blocks = _split_pem_certs(blob)\n123\t    if not blocks:\n124\t        errors.append(f\"No certificates found in {label} PEM\")\n125\t        return set()\n126\t    fps = set()\n127\t    with tempfile.TemporaryDirectory() as td:\n128\t        for idx, block in enumerate(blocks):\n129\t            one = f\"{td}/cert-{idx}.crt\"\n130\t            with open(one, \"w\", encoding=\"utf-8\") as f:\n131\t                f.write(block)\n132\t            result = run([\"openssl\", \"x509\", \"-noout\", \"-fingerprint\", \"-sha256\", \"-in\", one])\n133\t            if result.returncode != 0:\n134\t                continue\n135\t            line = result.stdout.strip()\n136\t            if \"=\" in line:\n137\t                fps.add(line.split(\"=\", 1)[1].strip())\n138\t    return fps\n139\t\n140\t\n141\tdef openssl_not_after(path, errors):\n142\t    result = run([\"openssl\", \"x509\", \"-noout\", \"-enddate\", \"-in\", path])\n143\t    if result.returncode != 0:\n144\t        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n145\t        errors.append(f\"Failed to read NotAfter from leaf cert: {detail}\")\n146\t        return None\n147\t    line = result.stdout.strip()\n148\t    if not line.startswith(\"notAfter=\"):\n149\t        errors.append(f\"Unexpected NotAfter output: {line}\")\n150\t        return None\n151\t    value = line.split(\"=\", 1)[1].strip()\n152\t    try:\n153\t        ts = datetime.datetime.strptime(value, \"%b %d %H:%M:%S %Y %Z\")\n154\t    except ValueError:\n155\t        errors.append(f\"Unable to parse NotAfter date: {value}\")\n156\t        return None\n157\t    return ts.replace(tzinfo=datetime.timezone.utc)\n158\t\n159\t\n160\tdef verify_cert(ca_path, cert_path):\n161\t    return run([\"openssl\", \"verify\", \"-CAfile\", ca_path, cert_path])\n162\t\n163\t\n164\t_ELASTIC_PW = None\n165\t\n166\t\n167\tdef _elastic_password():\n168\t    \"\"\"Live elastic-user password.\n169\t\n170\t    Reads the elastic-password secret (a prior rotate-elastic-password stage may\n171\t    have rotated it away from this case's default, so the env PERSISTS a new\n172\t    value), base64-decoded; falls back to the case default. Cached so the retry\n173\t    loop does not re-read the secret each attempt.\n174\t    \"\"\"\n175\t    global _ELASTIC_PW\n176\t    if _ELASTIC_PW is not None:\n177\t        return _ELASTIC_PW\n178\t    import base64\n179\t    r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", \"elastic-password\",\n180\t             \"-o\", \"jsonpath={.data.password}\"])\n181\t    pw = None\n182\t    if r.returncode == 0 and r.stdout.strip():\n183\t        try:\n184\t            pw = base64.b64decode(r.stdout.strip()).decode()\n185\t        except Exception:\n186\t            pw = None\n187\t    _ELASTIC_PW = pw or os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD\") or \"elasticpass\"\n188\t    return _ELASTIC_PW\n189\t\n190\t\n191\tdef _health_curl(scheme):\n192\t    \"\"\"Run the cluster-health curl over the given scheme.\n193\t\n194\t    https uses the rotated CA (--cacert); http (fallback for a cluster whose\n195\t    HTTP TLS a prior stage disabled) adds nothing. -k is a belt-and-suspenders\n196\t    in case the served leaf doesn't chain to the mounted CA path.\n197\t    \"\"\"\n198\t    # The client deadline (--max-time 20) must exceed the server-side\n199\t    # ``timeout`` in the path, otherwise curl aborts (exit 28) before ES can\n200\t    # answer. curl_health() retries to absorb transient flapping, so the server\n201\t    # wait stays short (5s).\n202\t    path = \"/_cluster/health?wait_for_status=yellow&timeout=5s\"\n203\t    cmd = [\n204\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", CURL_POD, \"--\",\n205\t        \"curl\", \"-s\", \"-S\", \"--max-time\", \"20\",\n206\t    ]\n207\t    if scheme == \"https\":\n208\t        cmd += [\"--cacert\", \"/etc/es-http-ca/ca.crt\", \"-k\"]\n209\t    cmd += [\"-u\", f\"elastic:{_elastic_password()}\",\n210\t            f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\"]\n211\t    return run(cmd)\n212\t\n213\t\n214\tdef _evaluate_health():\n215\t    \"\"\"Run one cluster-health snapshot; return the list of health errors.\"\"\"\n216\t    errs = []\n217\t    # The env PERSISTS across stages; the cluster's live scheme may differ from\n218\t    # this case's default (https for a cert-rotation task). Try https (with the\n219\t    # rotated CA) then fall back to http. Cert assertions above are unaffected.\n220\t    result = _health_curl(\"https\")\n221\t    if result.returncode != 0:\n222\t        result = _health_curl(\"http\")\n223\t    if result.returncode != 0:\n224\t        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n225\t        errs.append(f\"Cluster health check failed: {detail}\")\n226\t        return errs\n227\t    output = result.stdout.strip()\n228\t    if not output:\n229\t        errs.append(\"HTTPS health check returned empty response\")\n230\t        return errs\n231\t    try:\n232\t        data = json.loads(output)\n233\t    except json.JSONDecodeError:\n234\t        errs.append(\"HTTPS health check returned invalid JSON\")\n235\t        return errs\n236\t    status = data.get(\"status\")\n237\t    if status not in {\"yellow\", \"green\"}:\n238\t        errs.append(f\"Cluster health expected yellow/green, got {status}\")\n239\t    return errs\n240\t\n241\t\n242\tdef curl_health(errors):\n243\t    # A multi-node ES cluster can flap at the edge of readiness under load: it\n244\t    # briefly reports a non-green/yellow status during GC or shard recovery even\n245\t    # though it converges green. A single snapshot can catch that transient. So\n246\t    # verify the STABLE converged health: re-evaluate for up to ~75s and accept\n247\t    # the first clean snapshot. This does not loosen the green/yellow\n248\t    # requirement -- a genuinely degraded cluster fails every attempt. The cert\n249\t    # assertions above are deterministic and stay single-pass.\n250\t    import time\n251\t    deadline = time.monotonic() + 75\n252\t    health_errors = _evaluate_health()\n253\t    while health_errors and time.monotonic() < deadline:\n254\t        time.sleep(8)\n255\t        health_errors = _evaluate_health()\n256\t    errors.extend(health_errors)\n257\t\n258\t\n259\tdef main():\n260\t    errors = []\n261\t\n262\t    old_ca_fp = get_configmap_text(OLD_CM, \"ca_fingerprint_sha256\", errors)\n263\t    old_leaf_fp = get_configmap_text(OLD_CM, \"leaf_fingerprint_sha256\", errors)\n264\t    old_ca_pem = get_configmap_text(OLD_CM, \"ca.crt\", errors)\n265\t    client_ca_pem = get_configmap_text(CLIENT_CA_CM, \"ca.crt\", errors)\n266\t\n267\t    if errors:\n268\t        print(\"HTTP cert rotation verification failed:\", file=sys.stderr)\n269\t        for err in errors:\n270\t            print(f\"  - {err}\", file=sys.stderr)\n271\t        return 1\n272\t\n273\t    with tempfile.TemporaryDirectory() as tmpdir:\n274\t        ca_path = f\"{tmpdir}/ca.crt\"\n275\t        leaf_path = f\"{tmpdir}/tls.crt\"\n276\t        old_ca_path = f\"{tmpdir}/old-ca.crt\"\n277\t        client_ca_path = f\"{tmpdir}/client-ca.crt\"\n278\t\n279\t        new_ca = get_secret_data(\"ca.crt\", errors)\n280\t        new_leaf = get_secret_data(\"tls.crt\", errors)\n281\t\n282\t        if new_ca is not None:\n283\t            with open(ca_path, \"wb\") as f:\n284\t                f.write(new_ca)\n285\t        if new_leaf is not None:\n286\t            with open(leaf_path, \"wb\") as f:\n287\t                f.write(new_leaf)\n288\t        if old_ca_pem is not None:\n289\t            with open(old_ca_path, \"w\", encoding=\"utf-8\") as f:\n290\t                f.write(old_ca_pem)\n291\t        if client_ca_pem is not None:\n292\t            with open(client_ca_path, \"w\", encoding=\"utf-8\") as f:\n293\t                f.write(client_ca_pem)\n294\t\n295\t        if new_ca is None or new_leaf is None:\n296\t            errors.append(\"Missing TLS data from es-http-tls secret\")\n297\t        else:\n298\t            # O-multi: the served ca.crt may be a trust BUNDLE (old-CA + new-CA)\n299\t            # for a zero-gap rollover. Inspect EVERY cert in it, not just the\n300\t            # leading one (which openssl x509 would read in isolation and could be\n301\t            # the OLD CA -> a false \"CA fingerprint did not change\"). Assert a NEW\n302\t            # CA is PRESENT among the entries (some fingerprint that is not the old\n303\t            # CA's), rather than requiring the single/first cert to differ.\n304\t            served_ca_fps = openssl_fingerprints_all(ca_path, errors, \"served CA\")\n305\t            served_ca_fps = served_ca_fps or set()\n306\t            new_ca_candidates = served_ca_fps - ({old_ca_fp} if old_ca_fp else set())\n307\t            # The new CA fingerprint = a served CA fp that is not the old one. Used\n308\t            # below only as a truthy \"a new CA is present\" gate; chain validation\n309\t            # via openssl verify -CAfile (bundle-aware) is the real proof.\n310\t            new_ca_fp = next(iter(new_ca_candidates), None)\n311\t            if served_ca_fps and old_ca_fp and not new_ca_candidates:\n312\t                errors.append(\"CA fingerprint did not change (no new CA present in served ca.crt bundle)\")\n313\t\n314\t            new_leaf_fp = openssl_fingerprint(leaf_path, errors, \"new leaf\")\n315\t            if new_leaf_fp and old_leaf_fp and new_leaf_fp == old_leaf_fp:\n316\t                errors.append(\"Leaf fingerprint did not change\")\n317\t\n318\t            # O-multi: the client trust ConfigMap is also legitimately a BUNDLE\n319\t            # (old + new CA). Assert the new CA is PRESENT among its certs, not\n320\t            # that its single/first cert equals the new CA.\n321\t            if new_ca_fp and client_ca_pem:\n322\t                client_fps = openssl_fingerprints_all(client_ca_path, errors, \"client CA\")\n323\t                client_fps = client_fps or set()\n324\t                if client_fps and new_ca_fp not in client_fps:\n325\t                    errors.append(\"Client CA bundle does not contain the new CA\")\n326\t\n327\t            not_after = openssl_not_after(leaf_path, errors)\n328\t            if not_after:\n329\t                now = datetime.datetime.now(datetime.timezone.utc)\n330\t                days_remaining = (not_after - now).days\n331\t                if days_remaining < MIN_VALID_DAYS or days_remaining > MAX_VALID_DAYS:\n332\t                    errors.append(\n333\t                        f\"Leaf validity {days_remaining} days out of expected range ({MIN_VALID_DAYS}-{MAX_VALID_DAYS})\"\n334\t                    )\n335\t\n336\t            if new_ca_fp:\n337\t                verify_new = verify_cert(ca_path, leaf_path)\n338\t                if verify_new.returncode != 0:\n339\t                    detail = verify_new.stderr.strip() or verify_new.stdout.strip()\n340\t                    errors.append(f\"Leaf does not verify with new CA: {detail}\")\n341\t\n342\t                verify_old = verify_cert(old_ca_path, leaf_path)\n343\t                if verify_old.returncode == 0:\n344\t                    errors.append(\"Leaf still verifies with old CA\")\n345\t\n346\t        curl_health(errors)\n347\t\n348\t    if errors:\n349\t        print(\"HTTP cert rotation verification failed:\", file=sys.stderr)\n350\t        for err in errors:\n351\t            print(f\"  - {err}\", file=sys.stderr)\n352\t        return 1\n353\t\n354\t    print(\"HTTP cert rotation verified\")\n355\t    return 0\n356\t\n357\t\n358\tif __name__ == \"__main__\":\n359\t    sys.exit(main())\n360\t"}]},"parent_tool_use_id":null,"session_id":"c7db248e-e544-44e5-817a-006a6388569c","uuid":"dd672750-0051-4ee5-9e42-7ae03871d417","timestamp":"2026-07-02T00:11:49.180Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/elasticsearch/rotate-http-certs/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport base64\nimport datetime\nimport os\nimport subprocess\nimport sys\nimport tempfile\nimport json\n\nNAMESPACE = \"elasticsearch\"\nSECRET = \"es-http-tls\"\nOLD_CM = \"es-http-old\"\nCLIENT_CA_CM = \"es-http-ca\"\nSERVICE = \"es-http\"\nCURL_POD = \"curl-test\"\nMIN_VALID_DAYS = 300\nMAX_VALID_DAYS = 400\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef get_secret_data(key, errors):\n    json_key = key.replace(\".\", \"\\\\.\")\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"get\",\n        \"secret\",\n        SECRET,\n        \"-o\",\n        f\"jsonpath={{.data.{json_key}}}\",\n    ]\n    result = run(cmd)\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errors.append(f\"Failed to read secret {SECRET} {key}: {detail}\")\n        return None\n    raw = result.stdout.strip()\n    if not raw:\n        errors.append(f\"Secret {SECRET} missing key {key}\")\n        return None\n    try:\n        return base64.b64decode(raw)\n    except base64.binascii.Error:\n        errors.append(f\"Secret {SECRET} key {key} is not valid base64\")\n        return None\n\n\ndef get_configmap_text(name, key, errors):\n    json_key = key.replace(\".\", \"\\\\.\")\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"get\",\n        \"configmap\",\n        name,\n        \"-o\",\n        f\"jsonpath={{.data.{json_key}}}\",\n    ]\n    result = run(cmd)\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errors.append(f\"Failed to read configmap {name} {key}: {detail}\")\n        return None\n    return result.stdout.strip()\n\n\ndef openssl_fingerprint(path, errors, label):\n    result = run([\"openssl\", \"x509\", \"-noout\", \"-fingerprint\", \"-sha256\", \"-in\", path])\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errors.append(f\"Failed to read fingerprint for {label}: {detail}\")\n        return None\n    line = result.stdout.strip()\n    if \"=\" not in line:\n        errors.append(f\"Unexpected fingerprint output for {label}: {line}\")\n        return None\n    return line.split(\"=\", 1)[1].strip()\n\n\ndef _split_pem_certs(text):\n    \"\"\"Split a PEM blob into its individual certificate blocks.\n\n    A ca.crt may legitimately be a trust BUNDLE (old-CA + new-CA) for a zero-gap\n    rollover, so we must inspect every entry, not just the leading one.\n    \"\"\"\n    certs = []\n    cur = []\n    capture = False\n    for line in (text or \"\").splitlines():\n        if \"BEGIN CERTIFICATE\" in line:\n            capture = True\n            cur = [line]\n        elif \"END CERTIFICATE\" in line:\n            cur.append(line)\n            certs.append(\"\\n\".join(cur) + \"\\n\")\n            capture = False\n            cur = []\n        elif capture:\n            cur.append(line)\n    return certs\n\n\ndef openssl_fingerprints_all(path, errors, label):\n    \"\"\"Fingerprint EVERY certificate in a PEM file (O-multi).\n\n    ``openssl x509`` reads only the FIRST cert in a bundle, so a single call\n    silently grades the wrong element. Split the PEM and fingerprint each block,\n    returning the set of fingerprints found. Returns None only on a hard read\n    failure; an empty set means no parseable certs.\n    \"\"\"\n    try:\n        with open(path, \"r\", encoding=\"utf-8\") as f:\n            blob = f.read()\n    except OSError as exc:\n        errors.append(f\"Failed to read {label} PEM: {exc}\")\n        return None\n    blocks = _split_pem_certs(blob)\n    if not blocks:\n        errors.append(f\"No certificates found in {label} PEM\")\n        return set()\n    fps = set()\n    with tempfile.TemporaryDirectory() as td:\n        for idx, block in enumerate(blocks):\n            one = f\"{td}/cert-{idx}.crt\"\n            with open(one, \"w\", encoding=\"utf-8\") as f:\n                f.write(block)\n            result = run([\"openssl\", \"x509\", \"-noout\", \"-fingerprint\", \"-sha256\", \"-in\", one])\n            if result.returncode != 0:\n                continue\n            line = result.stdout.strip()\n            if \"=\" in line:\n                fps.add(line.split(\"=\", 1)[1].strip())\n    return fps\n\n\ndef openssl_not_after(path, errors):\n    result = run([\"openssl\", \"x509\", \"-noout\", \"-enddate\", \"-in\", path])\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errors.append(f\"Failed to read NotAfter from leaf cert: {detail}\")\n        return None\n    line = result.stdout.strip()\n    if not line.startswith(\"notAfter=\"):\n        errors.append(f\"Unexpected NotAfter output: {line}\")\n        return None\n    value = line.split(\"=\", 1)[1].strip()\n    try:\n        ts = datetime.datetime.strptime(value, \"%b %d %H:%M:%S %Y %Z\")\n    except ValueError:\n        errors.append(f\"Unable to parse NotAfter date: {value}\")\n        return None\n    return ts.replace(tzinfo=datetime.timezone.utc)\n\n\ndef verify_cert(ca_path, cert_path):\n    return run([\"openssl\", \"verify\", \"-CAfile\", ca_path, cert_path])\n\n\n_ELASTIC_PW = None\n\n\ndef _elastic_password():\n    \"\"\"Live elastic-user password.\n\n    Reads the elastic-password secret (a prior rotate-elastic-password stage may\n    have rotated it away from this case's default, so the env PERSISTS a new\n    value), base64-decoded; falls back to the case default. Cached so the retry\n    loop does not re-read the secret each attempt.\n    \"\"\"\n    global _ELASTIC_PW\n    if _ELASTIC_PW is not None:\n        return _ELASTIC_PW\n    import base64\n    r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", \"elastic-password\",\n             \"-o\", \"jsonpath={.data.password}\"])\n    pw = None\n    if r.returncode == 0 and r.stdout.strip():\n        try:\n            pw = base64.b64decode(r.stdout.strip()).decode()\n        except Exception:\n            pw = None\n    _ELASTIC_PW = pw or os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD\") or \"elasticpass\"\n    return _ELASTIC_PW\n\n\ndef _health_curl(scheme):\n    \"\"\"Run the cluster-health curl over the given scheme.\n\n    https uses the rotated CA (--cacert); http (fallback for a cluster whose\n    HTTP TLS a prior stage disabled) adds nothing. -k is a belt-and-suspenders\n    in case the served leaf doesn't chain to the mounted CA path.\n    \"\"\"\n    # The client deadline (--max-time 20) must exceed the server-side\n    # ``timeout`` in the path, otherwise curl aborts (exit 28) before ES can\n    # answer. curl_health() retries to absorb transient flapping, so the server\n    # wait stays short (5s).\n    path = \"/_cluster/health?wait_for_status=yellow&timeout=5s\"\n    cmd = [\n        \"kubectl\", \"-n\", NAMESPACE, \"exec\", CURL_POD, \"--\",\n        \"curl\", \"-s\", \"-S\", \"--max-time\", \"20\",\n    ]\n    if scheme == \"https\":\n        cmd += [\"--cacert\", \"/etc/es-http-ca/ca.crt\", \"-k\"]\n    cmd += [\"-u\", f\"elastic:{_elastic_password()}\",\n            f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\"]\n    return run(cmd)\n\n\ndef _evaluate_health():\n    \"\"\"Run one cluster-health snapshot; return the list of health errors.\"\"\"\n    errs = []\n    # The env PERSISTS across stages; the cluster's live scheme may differ from\n    # this case's default (https for a cert-rotation task). Try https (with the\n    # rotated CA) then fall back to http. Cert assertions above are unaffected.\n    result = _health_curl(\"https\")\n    if result.returncode != 0:\n        result = _health_curl(\"http\")\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errs.append(f\"Cluster health check failed: {detail}\")\n        return errs\n    output = result.stdout.strip()\n    if not output:\n        errs.append(\"HTTPS health check returned empty response\")\n        return errs\n    try:\n        data = json.loads(output)\n    except json.JSONDecodeError:\n        errs.append(\"HTTPS health check returned invalid JSON\")\n        return errs\n    status = data.get(\"status\")\n    if status not in {\"yellow\", \"green\"}:\n        errs.append(f\"Cluster health expected yellow/green, got {status}\")\n    return errs\n\n\ndef curl_health(errors):\n    # A multi-node ES cluster can flap at the edge of readiness under load: it\n    # briefly reports a non-green/yellow status during GC or shard recovery even\n    # though it converges green. A single snapshot can catch that transient. So\n    # verify the STABLE converged health: re-evaluate for up to ~75s and accept\n    # the first clean snapshot. This does not loosen the green/yellow\n    # requirement -- a genuinely degraded cluster fails every attempt. The cert\n    # assertions above are deterministic and stay single-pass.\n    import time\n    deadline = time.monotonic() + 75\n    health_errors = _evaluate_health()\n    while health_errors and time.monotonic() < deadline:\n        time.sleep(8)\n        health_errors = _evaluate_health()\n    errors.extend(health_errors)\n\n\ndef main():\n    errors = []\n\n    old_ca_fp = get_configmap_text(OLD_CM, \"ca_fingerprint_sha256\", errors)\n    old_leaf_fp = get_configmap_text(OLD_CM, \"leaf_fingerprint_sha256\", errors)\n    old_ca_pem = get_configmap_text(OLD_CM, \"ca.crt\", errors)\n    client_ca_pem = get_configmap_text(CLIENT_CA_CM, \"ca.crt\", errors)\n\n    if errors:\n        print(\"HTTP cert rotation verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    with tempfile.TemporaryDirectory() as tmpdir:\n        ca_path = f\"{tmpdir}/ca.crt\"\n        leaf_path = f\"{tmpdir}/tls.crt\"\n        old_ca_path = f\"{tmpdir}/old-ca.crt\"\n        client_ca_path = f\"{tmpdir}/client-ca.crt\"\n\n        new_ca = get_secret_data(\"ca.crt\", errors)\n        new_leaf = get_secret_data(\"tls.crt\", errors)\n\n        if new_ca is not None:\n            with open(ca_path, \"wb\") as f:\n                f.write(new_ca)\n        if new_leaf is not None:\n            with open(leaf_path, \"wb\") as f:\n                f.write(new_leaf)\n        if old_ca_pem is not None:\n            with open(old_ca_path, \"w\", encoding=\"utf-8\") as f:\n                f.write(old_ca_pem)\n        if client_ca_pem is not None:\n            with open(client_ca_path, \"w\", encoding=\"utf-8\") as f:\n                f.write(client_ca_pem)\n\n        if new_ca is None or new_leaf is None:\n            errors.append(\"Missing TLS data from es-http-tls secret\")\n        else:\n            # O-multi: the served ca.crt may be a trust BUNDLE (old-CA + new-CA)\n            # for a zero-gap rollover. Inspect EVERY cert in it, not just the\n            # leading one (which openssl x509 would read in isolation and could be\n            # the OLD CA -> a false \"CA fingerprint did not change\"). Assert a NEW\n            # CA is PRESENT among the entries (some fingerprint that is not the old\n            # CA's), rather than requiring the single/first cert to differ.\n            served_ca_fps = openssl_fingerprints_all(ca_path, errors, \"served CA\")\n            served_ca_fps = served_ca_fps or set()\n            new_ca_candidates = served_ca_fps - ({old_ca_fp} if old_ca_fp else set())\n            # The new CA fingerprint = a served CA fp that is not the old one. Used\n            # below only as a truthy \"a new CA is present\" gate; chain validation\n            # via openssl verify -CAfile (bundle-aware) is the real proof.\n            new_ca_fp = next(iter(new_ca_candidates), None)\n            if served_ca_fps and old_ca_fp and not new_ca_candidates:\n                errors.append(\"CA fingerprint did not change (no new CA present in served ca.crt bundle)\")\n\n            new_leaf_fp = openssl_fingerprint(leaf_path, errors, \"new leaf\")\n            if new_leaf_fp and old_leaf_fp and new_leaf_fp == old_leaf_fp:\n                errors.append(\"Leaf fingerprint did not change\")\n\n            # O-multi: the client trust ConfigMap is also legitimately a BUNDLE\n            # (old + new CA). Assert the new CA is PRESENT among its certs, not\n            # that its single/first cert equals the new CA.\n            if new_ca_fp and client_ca_pem:\n                client_fps = openssl_fingerprints_all(client_ca_path, errors, \"client CA\")\n                client_fps = client_fps or set()\n                if client_fps and new_ca_fp not in client_fps:\n                    errors.append(\"Client CA bundle does not contain the new CA\")\n\n            not_after = openssl_not_after(leaf_path, errors)\n            if not_after:\n                now = datetime.datetime.now(datetime.timezone.utc)\n                days_remaining = (not_after - now).days\n                if days_remaining < MIN_VALID_DAYS or days_remaining > MAX_VALID_DAYS:\n                    errors.append(\n                        f\"Leaf validity {days_remaining} days out of expected range ({MIN_VALID_DAYS}-{MAX_VALID_DAYS})\"\n                    )\n\n            if new_ca_fp:\n                verify_new = verify_cert(ca_path, leaf_path)\n                if verify_new.returncode != 0:\n                    detail = verify_new.stderr.strip() or verify_new.stdout.strip()\n                    errors.append(f\"Leaf does not verify with new CA: {detail}\")\n\n                verify_old = verify_cert(old_ca_path, leaf_path)\n                if verify_old.returncode == 0:\n                    errors.append(\"Leaf still verifies with old CA\")\n\n        curl_health(errors)\n\n    if errors:\n        print(\"HTTP cert rotation verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    print(\"HTTP cert rotation verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":360,"startLine":1,"totalLines":360}}}
