{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01YWQ8b2DCChMGZhS3CCAYMj","type":"tool_result","content":"      containers:\n      - command:\n        - /bin/sh\n        - -c\n        - |\n          set -e\n          base=\"http://rabbitmq:15672/api\"\n          vhost=\"%2Fapp\"\n          queue=\"app-queue\"\n          auth=\"${APP_USER}:${APP_PASS}\"\n          for i in $(seq 1 60); do\n            if curl -s -u \"$auth\" \"$base/vhosts\" >/dev/null; then\n              break\n            fi\n            sleep 2\n          done\n          payload='{\"durable\":true,\"auto_delete\":false,\"arguments\":{\"x-queue-type\":\"classic\",\"x-queue-mode\":\"lazy\"}}'\n          code=$(curl -s -o /tmp/resp -w \"%{http_code}\" -u \"$auth\" \\\n            -H \"content-type: application/json\" \\\n            -XPUT \"$base/queues/${vhost}/${queue}\" -d \"$payload\")\n          if [ \"$code\" -ge 300 ]; then\n            echo \"app-producer: failed to declare queue in vhost /app: $(cat /tmp/resp)\"\n            exit 1\n          fi\n          i=0\n          while true; do\n            body='{\"properties\":{},\"routing_key\":\"'\"${queue}\"'\",\"payload\":\"msg-'\"${i}\"'\",\"payload_encoding\":\"string\"}'\n            code=$(curl -s -o /tmp/pubresp -w \"%{http_code}\" -u \"$auth\" \\\n              -H \"content-type: application/json\" \\\n              -XPOST \"$base/exchanges/${vhost}/amq.default/publish\" -d \"$body\")\n            if [ \"$code\" -ne 200 ]; then\n              echo \"app-producer: publish failed: $(cat /tmp/pubresp)\"\n              exit 1\n            fi\n            i=$((i+1))\n            sleep 2\n          done\n        env:\n        - name: APP_USER\n          valueFrom:\n            secretKeyRef:\n              key: username\n              name: rabbitmq-app\n        - name: APP_PASS\n          valueFrom:\n            secretKeyRef:\n              key: password\n              name: rabbitmq-app\n        image: curlimages/curl