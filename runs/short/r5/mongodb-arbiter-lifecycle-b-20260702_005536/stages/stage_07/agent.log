{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01CVV8cuiv6Ftc14qjLhcVzq","type":"tool_result","content":"1\t# mongodb/replica-scaling\n2\t# Scale a 3-member MongoDB replica set to 5 members without data loss\n3\t\n4\tparams:\n5\t  cluster_prefix:\n6\t    default: mongodb-replica\n7\t    description: StatefulSet name of the replica set members.\n8\t  replica_set_name:\n9\t    default: mongodb-replica\n10\t    description: MongoDB replica set _id used when initiating the set.\n11\t  target_replicas:\n12\t    default: 5\n13\t    description: Target number of replica set members after scaling.\n14\t  admin_username:\n15\t    default: admin-user\n16\t    description: Username of the MongoDB admin user.\n17\t  app_database:\n18\t    default: testdb\n19\t    description: Application database seeded with data.\n20\t  app_collection:\n21\t    default: data\n22\t    description: Application collection seeded with data.\n23\t\n24\tprompt: |\n25\t  A 3-member MongoDB replica set is running in the mongodb namespace.\n26\t  Scale the replica set to {{params.target_replicas}} members without data loss or loss of availability.\n27\t  Do not use operators or CRDs.\n28\t\n29\tnamespace_contract:\n30\t  required_roles: []\n31\t\n32\tmetrics:\n33\t  - time_to_first_mutation\n34\t\n35\tpreconditionUnits:\n36\t  - name: mongo_env_ready\n37\t    on_probe_fail: skip\n38\t    probe:\n39\t      - command: \"kubectl -n mongodb get pod {{params.cluster_prefix}}-0 2>/dev/null | grep -c Running\"\n40\t        timeout_sec: 10\n41\t    apply:\n42\t      - command: \"/bin/sh -c 'kubectl delete namespace mongodb --ignore-not-found=true; kubectl wait --for=delete namespace/mongodb --timeout=120s || true'\"\n43\t        sleep: 2\n44\t      - command: \"kubectl create namespace mongodb\"\n45\t        sleep: 1\n46\t      - command: \"kubectl -n mongodb apply -f cases/mongodb/replica-scaling/resource/secrets.yaml\"\n47\t        sleep: 1\n48\t      - command: \"kubectl -n mongodb apply -f cases/mongodb/replica-scaling/resource/services.yaml\"\n49\t        sleep: 1\n50\t      - command: \"kubectl -n mongodb apply -f cases/mongodb/replica-scaling/resource/statefulset.yaml\"\n51\t        sleep: 5\n52\t      - command: |\n53\t          /bin/sh -c 'for i in $(seq 1 120); do ready=$(kubectl -n mongodb get sts {{params.cluster_prefix}} -o jsonpath='\\''{.status.readyReplicas}'\\'' 2>/dev/null); if [ \"${ready:-0}\" -ge 3 ]; then exit 0; fi; sleep 5; done; exit 1'\n54\t        sleep: 2\n55\t      # Pod-Ready != mongod accepting TCP (§1.10): ping-until-ok before rs.initiate.\n56\t      - command: |\n57\t          /bin/sh -c 'for i in $(seq 1 30); do kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\\''db.runCommand({ping:1}).ok'\\'' 2>/dev/null | grep -q 1 && exit 0; sleep 3; done; exit 1'\n58\t        sleep: 2\n59\t      - command: |\n60\t          /bin/sh -c 'kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\\''rs.initiate({_id:\"{{params.replica_set_name}}\",members:[{_id:0,host:\"mongodb-replica-0.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"},{_id:1,host:\"mongodb-replica-1.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"},{_id:2,host:\"mongodb-replica-2.mongodb-replica-svc.mongodb.svc.cluster.local:27017\"}]})'\\'''\n61\t        sleep: 5\n62\t      - command: |\n63\t          /bin/sh -c 'for i in $(seq 1 20); do kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\\''db.hello().isWritablePrimary'\\'' | grep true && exit 0; sleep 3; done; exit 1'\n64\t        sleep: 2\n65\t      - command: |\n66\t          /bin/sh -c 'kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet --eval '\\''db.getSiblingDB(\"admin\").createUser({user:\"{{params.admin_username}}\",pwd:\"admin123password\",roles:[{role:\"clusterAdmin\",db:\"admin\"},{role:\"userAdminAnyDatabase\",db:\"admin\"},{role:\"readWriteAnyDatabase\",db:\"admin\"}]})'\\'''\n67\t        sleep: 2\n68\t      - command: |\n69\t          /bin/sh -c 'kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet \"mongodb://{{params.admin_username}}:admin123password@localhost:27017/admin\" --eval '\\''db.getSiblingDB(\"{{params.app_database}}\").{{params.app_collection}}.insertMany([{id:1},{id:2},{id:3}],{writeConcern:{w:1}})'\\'''\n70\t        sleep: 2\n71\t    verify:\n72\t      - command: \"kubectl -n mongodb get pods 2>/dev/null | grep -c Running\"\n73\t        timeout_sec: 10\n74\t\n75\t  - name: admin_user_fixture\n76\t    # Composition self-sufficiency: this case's oracle reads the\n77\t    # `admin-user-password` secret and authenticates as the `admin-user` admin\n78\t    # user (check_topology/check_data hard-fail when the secret is absent). Both\n79\t    # come from mongo_env_ready (secrets.yaml + createUser), whose destructive\n80\t    # apply is SKIPPED on an inherited cluster -> the secret/user are absent and\n81\t    # the oracle fails \"Failed to read secret admin-user-password\" through no\n82\t    # agent fault. Bring our own additively: if admin-user already\n83\t    # authenticates, skip; else ensure the secret and create the user. No\n84\t    # restart, no data touched, idempotent -> never regresses a cluster where\n85\t    # admin already works. Runs BEFORE mongo_seed_fixture so seeding can\n86\t    # authenticate as admin.\n87\t    on_probe_fail: skip\n88\t    probe:\n89\t      - command: |\n90\t          /bin/sh -c '\n91\t          t=\"\"; for cca in /etc/tls/ca.crt /etc/mongo-ca/ca.crt; do kubectl -n mongodb exec mongodb-replica-0 -- ls $cca >/dev/null 2>&1 && { t=\"--tls --tlsAllowInvalidHostnames --tlsAllowInvalidCertificates --tlsCAFile $cca\"; break; }; done\n92\t          pw=$(kubectl -n mongodb get secret admin-user-password -o jsonpath=\"{.data.password}\" 2>/dev/null | base64 -d 2>/dev/null)\n93\t          [ -n \"$pw\" ] || exit 1\n94\t          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet $t \"mongodb://{{params.admin_username}}:$pw@localhost:27017/admin\" --eval \"db.runCommand({ping:1}).ok\" 2>/dev/null | grep -q 1\n95\t          '\n96\t        timeout_sec: 30\n97\t    apply:\n98\t      # Ensure the admin secret (idempotent: create only if missing).\n99\t      - command: \"/bin/sh -c 'kubectl -n mongodb get secret admin-user-password >/dev/null 2>&1 || kubectl -n mongodb create secret generic admin-user-password --from-literal=password=admin123password'\"\n100\t        sleep: 1\n101\t      # Ensure the admin-user MongoDB user, mirroring mongo_env_ready's roles. On\n102\t      # a no-auth inherited cluster this runs unauthenticated and succeeds; where\n103\t      # it already exists it errors and `|| true` keeps it a no-op. Never drops\n104\t      # or alters existing users/data.\n105\t      - command: |\n106\t          /bin/sh -c '\n107\t          t=\"\"; for cca in /etc/tls/ca.crt /etc/mongo-ca/ca.crt; do kubectl -n mongodb exec mongodb-replica-0 -- ls $cca >/dev/null 2>&1 && { t=\"--tls --tlsAllowInvalidHostnames --tlsAllowInvalidCertificates --tlsCAFile $cca\"; break; }; done\n108\t          kubectl -n mongodb exec mongodb-replica-0 -- mongosh --quiet $t --eval \"db.getSiblingDB(\\\"admin\\\").createUser({user:\\\"{{params.admin_username}}\\\",pwd:\\\"admin123password\\\",roles:[{role:\\\"clusterAdmin\\\",db:\\\"admin\\\"},{role:\\\"userAdminAnyDatabase\\\",db:\\\"admin\\\"},{role:\\\"readWriteAnyDatabase\\\",db:\\\"admin\\\"}]})\" 2>/dev/null || true\n109\t          '\n110\t        sleep: 2\n111\t    verify:\n112\t      - command: \"/bin/sh -c 'kubectl -n mongodb get secret admin-user-password >/dev/null 2>&1 && echo ok'\"\n113\t        timeout_sec: 15\n114\t\n115\t  # Additive data fixture (composition safety): the oracle requires >= 3 docs in\n116\t  # {{params.app_database}}.{{params.app_collection}}. When this case runs chained\n117\t  # on an inherited cluster, the destructive `apply` above is skipped, so a prior\n118\t  # stage may have left the collection with FEWER than the required docs (