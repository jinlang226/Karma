NAME       CLASS   HOSTS              ADDRESS   PORTS   AGE
rate-api   nginx   rate.example.com             80      10s

$ kubectl -n demo annotate ingress rate-api nginx.ingress.kubernetes.io/limit-rps- --overwrite
ingress.networking.k8s.io/rate-api annotated

$ /bin/sh -c "kubectl -n demo get ingress rate-api -o jsonpath='{.metadata.annotations.nginx\\.ingress\\.kubernetes\\.io/limit-rps}' | grep -v ."

