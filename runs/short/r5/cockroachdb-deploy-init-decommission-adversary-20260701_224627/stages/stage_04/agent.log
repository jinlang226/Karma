    app.kubernetes.io/name: cockroachdb\n      app.kubernetes.io/instance: crdb-cluster\n  template:\n    metadata:\n      labels:\n        app.kubernetes.io/name: cockroachdb\n        app.kubernetes.io/instance: crdb-cluster\n    spec:\n      serviceAccountName: crdb-cluster-sa\n      containers:\n      - name: db\n        image: cockroachdb/cockroach:v24.1.0\n        imagePullPolicy: IfNotPresent\n        ports:\n        - containerPort: 26257\n          name: grpc\n        - containerPort: 8080\n          name: http\n        volumeMounts:\n        - name: datadir\n          mountPath: /cockroach/cockroach-data\n        env:\n        - name: POD_NAME\n          valueFrom:\n            fieldRef:\n              fieldPath: metadata.name\n        - name: POD_NAMESPACE\n          valueFrom:\n            fieldRef:\n              fieldPath: metadata.namespace\n        command:\n        - /bin/bash\n        - -c\n        - >-\n          exec /cockroach/cockroach start\n          --logtostderr=INFO\n          --insecure\n          --advertise-host=$(POD_NAME).crdb-cluster.$(POD_NAMESPACE).svc.cluster.local\n          --http-addr=0.0.0.0:8080\n          --port=26257\n          --cache=25%\n          --max-sql-memory=25%\n          --join=crdb-cluster-0.crdb-cluster.$(POD_NAMESPACE).svc.cluster.local:26257,crdb-cluster-1.crdb-cluster.$(POD_NAMESPACE).svc.cluster.local:26257,crdb-cluster-2.crdb-cluster.$(POD_NAMESPACE).svc.cluster.local:26257,crdb-cluster-3.crdb-cluster.$(POD_NAMESPACE).svc.cluster.local:26257,crdb-cluster-4.crdb-cluster.$(POD_NAMESPACE).svc.cluster.local:26257\n        resources:\n          requests:\n            cpu: \"1\"\n            memory: \"2Gi\"\n          limits:\n            cpu: \"1\"\n            memory: \"2Gi\"\n        livenessProbe:\n          httpGet:\n            path: /health\n            port: http\n          initialDelaySeconds: 30\n          periodSeconds: 10\n          timeoutSeconds: 5\n          failureThreshold: 6\n        readinessProbe:\n          httpGet:\n            path: /health?ready=1\n            port: http\n          initialDelaySeconds: 10\n          periodSeconds: 5\n          timeoutSeconds: 5\n          failureThreshold: 4\n      terminationGracePeriodSeconds: 60\n  volumeClaimTemplates:\n  - metadata:\n      name: datadir\n      labels:\n        app.kubernetes.io/name: cockroachdb\n        app.kubernetes.io/instance: crdb-cluster\n    spec:\n      accessModes:\n      - ReadWriteOnce\n      resources:\n        requests:\n          storage: 10Gi\n      volumeMode: Filesystem\n","numLines":95,"startLine":1,"totalLines":95}}}
