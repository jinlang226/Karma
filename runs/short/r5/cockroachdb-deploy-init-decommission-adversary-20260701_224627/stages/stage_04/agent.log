{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01P1isLEr8dzmT5Wp18XEKm4","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\t# Verify the cluster was safely decommissioned to 3 nodes with the seeded data\n3\t# preserved. The seeded table name comes from the case param\n4\t# (BENCH_PARAM_SEED_TABLE_NAME), so a workflow that overrides it is honored\n5\t# instead of a hardcoded value. Standalone (default param) this behaves\n6\t# identically.\n7\timport json\n8\timport os\n9\timport subprocess\n10\timport sys\n11\t\n12\t\n13\tNAMESPACE = \"cockroachdb\"\n14\tPOD = \"crdb-cluster-0\"\n15\tSQL_HOST = \"crdb-cluster-0.crdb-cluster.cockroachdb.svc.cluster.local\"\n16\tSEED_TABLE = os.environ.get(\"BENCH_PARAM_SEED_TABLE_NAME\", \"bench.decom_data\")\n17\t\n18\t# Final node count the cluster must be decommissioned down to. This is the TASK\n19\t# OUTCOME (the agent reduces a 5-node cluster to this many), so it must NOT be\n20\t# read from the live cluster — that would make the count check vacuous. It comes\n21\t# from an explicit param override (a workflow that seeds/targets a different size\n22\t# is honored) and otherwise defaults to the old hardcoded 3. Standalone this\n23\t# behaves identically.\n24\tTARGET_NODES = int(\n25\t    os.environ.get(\"BENCH_PARAM_TARGET_NODES\")\n26\t    or os.environ.get(\"BENCH_PARAM_EXPECTED_NODES\")\n27\t    or \"3\"\n28\t)\n29\t# The pods expected to be removed are every ordinal at/above the target. With a\n30\t# 5-node start and target 3 this is crdb-cluster-{3,4}, matching the old check;\n31\t# a larger source (param override) extends the set generically.\n32\tSOURCE_NODES = int(\n33\t    os.environ.get(\"BENCH_PARAM_SOURCE_NODES\")\n34\t    or os.environ.get(\"BENCH_PARAM_SEED_NODE_COUNT\")\n35\t    or \"5\"\n36\t)\n37\tTARGET_PODS = [f\"crdb-cluster-{i}\" for i in range(TARGET_NODES, SOURCE_NODES)]\n38\t\n39\t\n40\tdef run(cmd):\n41\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n42\t\n43\t\n44\t_CONN_FLAG = None\n45\t\n46\t\n47\tdef conn_flag():\n48\t    \"\"\"Return the right cockroach SQL connection flag for the live cluster.\n49\t\n50\t    Standalone this case runs against an INSECURE cluster (`--insecure`). But in\n51\t    a workflow this stage can inherit a SECURE cluster left running by a prior\n52\t    stage (e.g. certificate-rotation), whose precondition probe sees pods already\n53\t    Running and skips its own insecure redeploy. A hardcoded `--insecure` then\n54\t    fails with an SSL authentication error. Detect the mode once by checking for\n55\t    the mounted certs dir and connect accordingly so the same oracle works in\n56\t    both contexts. Mirrors cockroachdb/cluster-settings/oracle/oracle.py.\n57\t    \"\"\"\n58\t    global _CONN_FLAG\n59\t    if _CONN_FLAG is not None:\n60\t        return _CONN_FLAG\n61\t    probe = run([\n62\t        \"kubectl\", \"-n\", NAMESPACE, \"--request-timeout=15s\", \"exec\", POD, \"--\",\n63\t        \"ls\", \"/cockroach/cockroach-certs/ca.crt\",\n64\t    ])\n65\t    if probe.returncode == 0:\n66\t        _CONN_FLAG = \"--certs-dir=/cockroach/cockroach-certs\"\n67\t    else:\n68\t        _CONN_FLAG = \"--insecure\"\n69\t    return _CONN_FLAG\n70\t\n71\t\n72\tdef exec_sql(sql, fmt=None):\n73\t    cmd = [\n74\t        \"kubectl\",\n75\t        \"-n\",\n76\t        NAMESPACE,\n77\t        \"exec\",\n78\t        POD,\n79\t        \"--\",\n80\t        \"./cockroach\",\n81\t        \"sql\",\n82\t        conn_flag(),\n83\t        f\"--host={SQL_HOST}\",\n84\t    ]\n85\t    if fmt:\n86\t        cmd.append(f\"--format={fmt}\")\n87\t    cmd += [\"-e\", sql]\n88\t    return run(cmd)\n89\t\n90\t\n91\tdef parse_tsv(output):\n92\t    lines = [line.strip() for line in output.splitlines() if line.strip()]\n93\t    if not lines:\n94\t        return [], []\n95\t    header = lines[0].split(\"\\t\")\n96\t    rows = [line.split(\"\\t\") for line in lines[1:]]\n97\t    return header, rows\n98\t\n99\t\n100\tdef to_bool(value):\n101\t    return str(value).strip().lower() in (\"true\", \"t\", \"1\", \"yes\")\n102\t\n103\t\n104\tdef evaluate():\n105\t    \"\"\"One full snapshot of the decommission checks; returns error list.\"\"\"\n106\t    errors = []\n107\t\n108\t    cmd = [\"kubectl\", \"-n\", NAMESPACE, \"get\", \"statefulset\", \"crdb-cluster\", \"-o\", \"json\"]\n109\t    result = run(cmd)\n110\t    if result.returncode == 0:\n111\t        try:\n112\t            sts = json.loads(result.stdout)\n113\t            replicas = sts.get(\"spec\", {}).get(\"replicas\", 0)\n114\t            if replicas != TARGET_NODES:\n115\t                errors.append(f\"StatefulSet should have {TARGET_NODES} replicas, got {replicas}\")\n116\t            # We do NOT gate on status.readyReplicas (the k8s pod-Ready tally):\n117\t            # after a decommission a surviving node restarting can lag its\n118\t            # readiness probe while already serving SQL (O-funcready). The\n119\t            # functional signal -- TARGET_NODES nodes is_live and serving, the\n120\t            # data query below -- is graded directly, so a readyReplicas gate\n121\t            # would only add a laggy false-fail without strengthening anything.\n122\t        except json.JSONDecodeError:\n123\t            errors.append(\"Failed to parse StatefulSet JSON\")\n124\t    else:\n125\t        errors.append(result.stderr.strip() or \"Failed to get StatefulSet\")\n126\t\n127\t    cmd = [\n128\t        \"kubectl\",\n129\t        \"-n\",\n130\t        NAMESPACE,\n131\t        \"exec\",\n132\t        POD,\n133\t        \"--\",\n134\t        \"./cockroach\",\n135\t        \"node\",\n136\t        \"status\",\n137\t        conn_flag(),\n138\t        \"--decommission\",\n139\t        \"--format=tsv\",\n140\t    ]\n141\t    result = run(cmd)\n142\t    if result.returncode != 0:\n143\t        errors.append(result.stderr.strip() or \"Failed to read node status\")\n144\t    else:\n145\t        header, rows = parse_tsv(result.stdout)\n146\t        if not header:\n147\t            errors.append(\"Empty node status output\")\n148\t        else:\n149\t            cols = {name: idx for idx, name in enumerate(header)}\n150\t            addr_idx = cols.get(\"address\")\n151\t            live_idx = cols.get(\"is_live\")\n152\t            membership_idx = cols.get(\"membership\")\n153\t            decom_idx = cols.get(\"is_decommissioned\")\n154\t            decom_ing_idx = cols.get(\"is_decommissioning\")\n155\t            if addr_idx is None or live_idx is None or (\n156\t                membership_idx is None and decom_idx is None and decom_ing_idx is None\n157\t            ):\n158\t                errors.append(\n159\t                    \"Missing expected columns in node status output \"\n160\t                    \"(need address, is_live, and one of membership, is_decommissioned, \"\n161\t                    \"is_decommissioning)\"\n162\t                )\n163\t            else:\n164\t                live_active = 0\n165\t                target_states = {}\n166\t                for row in rows:\n167\t                    max_idx = max(\n168\t                        addr_idx,\n169\t                        live_idx,\n170\t                        membership_idx if membership_idx is not None else -1,\n171\t                        decom_idx if decom_idx is not None else -1,\n172\t                        decom_ing_idx if decom_ing_idx is not None else -1,\n173\t                    )\n174\t                    if len(row) <= max_idx:\n175\t                        continue\n176\t                    address = row[addr_idx]\n177\t                    is_live = to_bool(row[live_idx])\n178\t                    if membership_idx is not None:\n179\t                        membership = row[membership_idx].strip().lower()\n180\t                        is_decommissioned = membership == \"decommissioned\"\n181\t                    elif decom_idx is not None:\n182\t                        is_decommissioned = to_bool(row[decom_idx])\n183\t                    else:\n184\t                        is_decommissioned = to_bool(row[decom_ing_idx])\n185\t                    if is_live and not is_decommissioned:\n186\t                        live_active += 1\n187\t                    for pod in TARGET_PODS:\n188\t                        if pod in address:\n189\t                            target_states[pod] = is_decommissioned\n190\t                if live_active != TARGET_NODES:\n191\t                    errors.append(f\"Expected {TARGET_NODES} live nodes, found {live_active}\")\n192\t                for pod in TARGET_PODS:\n193\t                    if pod not in target_states:\n194\t                        errors.append(f\"Missing node status for {pod}\")\n195\t                    elif not target_states[pod]:\n196\t                        errors.append(f\"{pod} is not decommissioned\")\n197\t\n198\t    result = exec_sql(f\"SELECT count(*) FROM {SEED_TABLE};\", fmt=\"tsv\")\n199\t    if result.returncode != 0:\n200\t        errors.append(result.stderr.strip() or f\"Failed to query {SEED_TABLE}\")\n201\t    else:\n202\t        header, rows = parse_tsv(result.stdout)\n203\t        if not rows:\n204\t            errors.append(\"No rows returned for data check\")\n205\t        else:\n206\t            try:\n207\t                count = int(rows[0][0])\n208\t                if count < 3:\n209\t                    errors.append(f\"Expected at least 3 rows, got {count}\")\n210\t            except ValueError:\n211\t                errors.append(\"Failed to parse row count\")\n212\t\n213\t    return errors\n214\t\n215\t\n216\tdef main():\n217\t    # Decommission removes nodes and reshuffles replicas; the StatefulSet's\n218\t    # readyReplicas and the removed nodes' membership (is_decommissioning ->\n219\t    # decommissioned) settle a beat after the operation reports done, and a\n220\t    # surviving node briefly restarting during the scale-down can dip is_live. A\n221\t    # single snapshot can race that convergence on a cluster healthily finishing\n222\t    # its decommission (the same case passes at the prior stages). Every assertion\n223\t    # here already encodes the POST-decommission expectation -- the reduced\n224\t    # TARGET_NODES live count and each removed node confirmed decommissioned -- so\n225\t    # re-evaluating only waits for that asserted state to settle; it never flips\n226\t    # an assertion. A node that genuinely fails to decommission never reports\n227\t    # decommissioned, and a lost survivor never returns to live, so the oracle\n228\t    # still fails after the deadline.\n229\t    import time\n230\t    deadline = time.monotonic() + 70\n231\t    errors = evaluate()\n232\t    while errors and time.monotonic() < deadline:\n233\t        time.sleep(7)\n234\t        errors = evaluate()\n235\t\n236\t    if errors:\n237\t        print(\"Decommission verification failed:\", file=sys.stderr)\n238\t        for error in errors:\n239\t            print(f\"  - {error}\", file=sys.stderr)\n240\t        return 1\n241\t\n242\t    print(\"Decommission verification passed\")\n243\t    return 0\n244\t\n245\t\n246\tif __name__ == \"__main__\":\n247\t    sys.exit(main())\n248\t"}]},"parent_tool_use_id":null,"session_id":"6b6f7fb1-4f30-45f7-82ce-68a21892d12c","uuid":"f7ad34b5-0aca-479c-8320-ce4a6b9da825","timestamp":"2026-07-01T22:58:26.333Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/cockroachdb/decommission/oracle/oracle.py","content":"#!/usr/bin/env python3\n# Verify the cluster was safely decommissioned to 3 nodes with the seeded data\n# preserved. The seeded table name comes from the case param\n# (BENCH_PARAM_SEED_TABLE_NAME), so a workflow that overrides it is honored\n# instead of a hardcoded value. Standalone (default param) this behaves\n# identically.\nimport json\nimport os\nimport subprocess\nimport sys\n\n\nNAMESPACE = \"cockroachdb\"\nPOD = \"crdb-cluster-0\"\nSQL_HOST = \"crdb-cluster-0.crdb-cluster.cockroachdb.svc.cluster.local\"\nSEED_TABLE = os.environ.get(\"BENCH_PARAM_SEED_TABLE_NAME\", \"bench.decom_data\")\n\n# Final node count the cluster must be decommissioned down to. This is the TASK\n# OUTCOME (the agent reduces a 5-node cluster to this many), so it must NOT be\n# read from the live cluster — that would make the count check vacuous. It comes\n# from an explicit param override (a workflow that seeds/targets a different size\n# is honored) and otherwise defaults to the old hardcoded 3. Standalone this\n# behaves identically.\nTARGET_NODES = int(\n    os.environ.get(\"BENCH_PARAM_TARGET_NODES\")\n    or os.environ.get(\"BENCH_PARAM_EXPECTED_NODES\")\n    or \"3\"\n)\n# The pods expected to be removed are every ordinal at/above the target. With a\n# 5-node start and target 3 this is crdb-cluster-{3,4}, matching the old check;\n# a larger source (param override) extends the set generically.\nSOURCE_NODES = int(\n    os.environ.get(\"BENCH_PARAM_SOURCE_NODES\")\n    or os.environ.get(\"BENCH_PARAM_SEED_NODE_COUNT\")\n    or \"5\"\n)\nTARGET_PODS = [f\"crdb-cluster-{i}\" for i in range(TARGET_NODES, SOURCE_NODES)]\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\n_CONN_FLAG = None\n\n\ndef conn_flag():\n    \"\"\"Return the right cockroach SQL connection flag for the live cluster.\n\n    Standalone this case runs against an INSECURE cluster (`--insecure`). But in\n    a workflow this stage can inherit a SECURE cluster left running by a prior\n    stage (e.g. certificate-rotation), whose precondition probe sees pods already\n    Running and skips its own insecure redeploy. A hardcoded `--insecure` then\n    fails with an SSL authentication error. Detect the mode once by checking for\n    the mounted certs dir and connect accordingly so the same oracle works in\n    both contexts. Mirrors cockroachdb/cluster-settings/oracle/oracle.py.\n    \"\"\"\n    global _CONN_FLAG\n    if _CONN_FLAG is not None:\n        return _CONN_FLAG\n    probe = run([\n        \"kubectl\", \"-n\", NAMESPACE, \"--request-timeout=15s\", \"exec\", POD, \"--\",\n        \"ls\", \"/cockroach/cockroach-certs/ca.crt\",\n    ])\n    if probe.returncode == 0:\n        _CONN_FLAG = \"--certs-dir=/cockroach/cockroach-certs\"\n    else:\n        _CONN_FLAG = \"--insecure\"\n    return _CONN_FLAG\n\n\ndef exec_sql(sql, fmt=None):\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"exec\",\n        POD,\n        \"--\",\n        \"./cockroach\",\n        \"sql\",\n        conn_flag(),\n        f\"--host={SQL_HOST}\",\n    ]\n    if fmt:\n        cmd.append(f\"--format={fmt}\")\n    cmd += [\"-e\", sql]\n    return run(cmd)\n\n\ndef parse_tsv(output):\n    lines = [line.strip() for line in output.splitlines() if line.strip()]\n    if not lines:\n        return [], []\n    header = lines[0].split(\"\\t\")\n    rows = [line.split(\"\\t\") for line in lines[1:]]\n    return header, rows\n\n\ndef to_bool(value):\n    return str(value).strip().lower() in (\"true\", \"t\", \"1\", \"yes\")\n\n\ndef evaluate():\n    \"\"\"One full snapshot of the decommission checks; returns error list.\"\"\"\n    errors = []\n\n    cmd = [\"kubectl\", \"-n\", NAMESPACE, \"get\", \"statefulset\", \"crdb-cluster\", \"-o\", \"json\"]\n    result = run(cmd)\n    if result.returncode == 0:\n        try:\n            sts = json.loads(result.stdout)\n            replicas = sts.get(\"spec\", {}).get(\"replicas\", 0)\n            if replicas != TARGET_NODES:\n                errors.append(f\"StatefulSet should have {TARGET_NODES} replicas, got {replicas}\")\n            # We do NOT gate on status.readyReplicas (the k8s pod-Ready tally):\n            # after a decommission a surviving node restarting can lag its\n            # readiness probe while already serving SQL (O-funcready). The\n            # functional signal -- TARGET_NODES nodes is_live and serving, the\n            # data query below -- is graded directly, so a readyReplicas gate\n            # would only add a laggy false-fail without strengthening anything.\n        except json.JSONDecodeError:\n            errors.append(\"Failed to parse StatefulSet JSON\")\n    else:\n        errors.append(result.stderr.strip() or \"Failed to get StatefulSet\")\n\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"exec\",\n        POD,\n        \"--\",\n        \"./cockroach\",\n        \"node\",\n        \"status\",\n        conn_flag(),\n        \"--decommission\",\n        \"--format=tsv\",\n    ]\n    result = run(cmd)\n    if result.returncode != 0:\n        errors.append(result.stderr.strip() or \"Failed to read node status\")\n    else:\n        header, rows = parse_tsv(result.stdout)\n        if not header:\n            errors.append(\"Empty node status output\")\n        else:\n            cols = {name: idx for idx, name in enumerate(header)}\n            addr_idx = cols.get(\"address\")\n            live_idx = cols.get(\"is_live\")\n            membership_idx = cols.get(\"membership\")\n            decom_idx = cols.get(\"is_decommissioned\")\n            decom_ing_idx = cols.get(\"is_decommissioning\")\n            if addr_idx is None or live_idx is None or (\n                membership_idx is None and decom_idx is None and decom_ing_idx is None\n            ):\n                errors.append(\n                    \"Missing expected columns in node status output \"\n                    \"(need address, is_live, and one of membership, is_decommissioned, \"\n                    \"is_decommissioning)\"\n                )\n            else:\n                live_active = 0\n                target_states = {}\n                for row in rows:\n                    max_idx = max(\n                        addr_idx,\n                        live_idx,\n                        membership_idx if membership_idx is not None else -1,\n                        decom_idx if decom_idx is not None else -1,\n                        decom_ing_idx if decom_ing_idx is not None else -1,\n                    )\n                    if len(row) <= max_idx:\n                        continue\n                    address = row[addr_idx]\n                    is_live = to_bool(row[live_idx])\n                    if membership_idx is not None:\n                        membership = row[membership_idx].strip().lower()\n                        is_decommissioned = membership == \"decommissioned\"\n                    elif decom_idx is not None:\n                        is_decommissioned = to_bool(row[decom_idx])\n                    else:\n                        is_decommissioned = to_bool(row[decom_ing_idx])\n                    if is_live and not is_decommissioned:\n                        live_active += 1\n                    for pod in TARGET_PODS:\n                        if pod in address:\n                            target_states[pod] = is_decommissioned\n                if live_active != TARGET_NODES:\n                    errors.append(f\"Expected {TARGET_NODES} live nodes, found {live_active}\")\n                for pod in TARGET_PODS:\n                    if pod not in target_states:\n                        errors.append(f\"Missing node status for {pod}\")\n                    elif not target_states[pod]:\n                        errors.append(f\"{pod} is not decommissioned\")\n\n    result = exec_sql(f\"SELECT count(*) FROM {SEED_TABLE};\", fmt=\"tsv\")\n    if result.returncode != 0:\n        errors.append(result.stderr.strip() or f\"Failed to query {SEED_TABLE}\")\n    else:\n        header, rows = parse_tsv(result.stdout)\n        if not rows:\n            errors.append(\"No rows returned for data check\")\n        else:\n            try:\n                count = int(rows[0][0])\n                if count < 3:\n                    errors.append(f\"Expected at least 3 rows, got {count}\")\n            except ValueError:\n                errors.append(\"Failed to parse row count\")\n\n    return errors\n\n\ndef main():\n    # Decommission removes nodes and reshuffles replicas; the StatefulSet's\n    # readyReplicas and the removed nodes' membership (is_decommissioning ->\n    # decommissioned) settle a beat after the operation reports done, and a\n    # surviving node briefly restarting during the scale-down can dip is_live. A\n    # single snapshot can race that convergence on a cluster healthily finishing\n    # its decommission (the same case passes at the prior stages). Every assertion\n    # here already encodes the POST-decommission expectation -- the reduced\n    # TARGET_NODES live count and each removed node confirmed decommissioned -- so\n    # re-evaluating only waits for that asserted state to settle; it never flips\n    # an assertion. A node that genuinely fails to decommission never reports\n    # decommissioned, and a lost survivor never returns to live, so the oracle\n    # still fails after the deadline.\n    import time\n    deadline = time.monotonic() + 70\n    errors = evaluate()\n    while errors and time.monotonic() < deadline:\n        time.sleep(7)\n        errors = evaluate()\n\n    if errors:\n        print(\"Decommission verification failed:\", file=sys.stderr)\n        for error in errors:\n            print(f\"  - {error}\", file=sys.stderr)\n        return 1\n\n    print(\"Decommission verification passed\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":248,"startLine":1,"totalLines":248}}}
