ate']).decode()\nend = out.strip().split('=',1)[1]\nend_dt = datetime.datetime.strptime(end, '%b %d %H:%M:%S %Y %Z')\nprint('expires', end_dt, 'days from now:', (end_dt - datetime.datetime.utcnow()).days)\n\"\n"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":104,"cache_read_input_tokens":74757,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":104},"output_tokens":48,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"c2cdeee3-acc2-4425-8c66-dee6733a607c","uuid":"6ec874b6-adad-413b-8b6c-b739f3bf52ea","request_id":"req_011CcaqqPcJg4fE39QFEg7MV"}
