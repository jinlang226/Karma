cat /tmp/pubresp)\\\"\\n    exit 1\\n  fi\\n  i=$((i+1))\\n  sleep 2\\ndone\\n\"],\"env\":[{\"name\":\"APP_USER\",\"valueFrom\":{\"secretKeyRef\":{\"key\":\"username\",\"name\":\"rabbitmq-app\"}}},{\"name\":\"APP_PASS\",\"valueFrom\":{\"secretKeyRef\":{\"key\":\"password\",\"name\":\"rabbitmq-app\"}}}],\"image\":\"curlimages/curl:8.6.0\",\"name\":\"producer\"}]}}}}\n  creationTimestamp: \"2026-07-01T04:28:38Z\"\n  generation: 1\n  name: app-producer\n  namespace: karma-rabbitmq-policy-sync-after-setu-9f98b0eb-cluster-a\n  resourceVersion: \"687166\"\n  uid: bb3329d5-3171-484a-8509-475a4e3f5fc5\nspec:\n  progressDeadlineSeconds: 600\n  replicas: 1\n  revisionHistoryLimit: 10\n  selector:\n    matchLabels:\n      app: app-producer\n  strategy:\n    rollingUpdate:\n      maxSurge: 25%\n      maxUnavailable: 25%\n    type: RollingUpdate\n  template:\n    metadata:\n      labels:\n        app: app-producer\n    spec:\n      containers:\n      - command:\n        - /bin/sh\n        - -c\n        - |\n          set -e\n          base=\"http://rabbitmq:15672/api\"\n          vhost=\"%2Fapp\"\n          queue=\"app-queue\"\n          auth=\"${APP_USER}:${APP_PASS}\"\n          for i in $(seq 1 60); do\n            if curl -s -u \"$auth\" \"$base/vhosts\" >/dev/null; then\n              break\n            fi\n            sleep 2\n          done\n          payload='{\"durable\":true,\"auto_delete\":false,\"arguments\":{\"x-queue-type\":\"classic\",\"x-queue-mode\":\"lazy\"}}'\n          code=$(curl -s -o /tmp/resp -w \"%{http_code}\" -u \"$auth\" \\\n            -H \"content-type: application/json\" \\\n            -XPUT \"$base/queues/${vhost}/${queue}\" -d \"$payload\")\n          if [ \"$code\" -ge 300 ]; then\n            echo \"app-producer: failed to declare queue in vhost /app: $(cat /tmp/resp)\"\n            exit 1\n          fi\n          i=0\n          while true; do\n            body='{\"properties\":{},\"routing_key\":\"'\"${queue}\"'\",\"payload\":\"msg-'\"${i}\"'