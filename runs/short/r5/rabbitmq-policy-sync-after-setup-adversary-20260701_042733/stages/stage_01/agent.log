{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01M3yXXDo69utDYDjtmX1LSG","type":"tool_result","content":"=== setup job pod logs ===\n=== setup job spec ===\n      containers:\n      - command:\n        - /bin/sh\n        - -c\n        - |\n          set -e\n          base=\"http://rabbitmq:15672/api\"\n          auth=\"${RABBITMQ_ADMIN_USER}:${RABBITMQ_ADMIN_PASS}\"\n          for i in $(seq 1 60); do\n            if curl -s -u \"$auth\" \"$base/overview\" >/dev/null; then\n              break\n            fi\n            sleep 2\n          done\n          if ! curl -s -u \"$auth\" \"$base/overview\" >/dev/null; then\n            echo \"rabbitmq-setup: management API not ready\"\n            exit 1\n          fi\n          curl -s -u \"$auth\" -H \"content-type: application/json\" \\\n            -XPUT \"$base/vhosts/%2Fapp\" -d '{}' >/dev/null\n          curl -s -u \"$auth\" -H \"content-type: application/json\" \\\n            -XPUT \"$base/users/${APP_USER}\" \\\n            -d \"{\\\"password\\\":\\\"${APP_PASS}\\\",\\\"tags\\\":\\\"management\\\"}\" >/dev/null\n          curl -s -u \"$auth\" -H \"content-type: application/json\" \\\n            -XPUT \"$base/permissions/%2Fapp/${APP_USER}\" \\\n            -d '{\"configure\":\"\",\"write\":\".*\",\"read\":\".*\"}' >/dev/null\n          curl -s -u \"$auth\" -H \"content-type: application/json\" \\\n            -XPUT \"$base/policies/%2Fapp/force-quorum\" \\\n            -d '{\"pattern\":\".*\",\"definition\":{\"queue-type\":\"quorum\"},\"priority\":0,\"apply-to\":\"queues\"}' >/dev/null\n          curl -s -u \"$auth\" -H \"content-type: application/json\" \\\n            -XPUT \"$base/policies/%2F/force-quorum\" \\\n            -d '{\"pattern\":\".*\",\"definition\":{\"queue-type\":\"quorum\"},\"priority\":0,\"apply-to\":\"queues\"}' >/dev/null\n        env:\n        - name: RABBITMQ_ADMIN_USER\n          valueFrom:\n            secretKeyRef:\n              key: username\n              