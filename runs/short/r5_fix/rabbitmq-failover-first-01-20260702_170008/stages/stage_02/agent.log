STER_PREFIX $BENCH_PARAM_GREEN_CLUSTER_PREFIX $BENCH_PARAM_FROM_VERSION' < cases/rabbitmq/manual_policy_sync/resource/statefulset.yaml | kubectl -n ${BENCH_NAMESPACE} apply -f -\"\n        sleep: 1\n      - command: \"kubectl -n ${BENCH_NAMESPACE} rollout status statefulset/{{params.cluster_prefix}} --timeout=600s\"\n        sleep: 1\n    verify:\n      - command: \"/bin/sh -c 'set -e; [ \\\"$(kubectl -n ${BENCH_NAMESPACE} get sts {{params.cluster_prefix}} -o jsonpath=\\\"{.status.readyReplicas}\\\")\\\" = \\\"3\\\" ]'\"\n        timeout_sec: 20\n\n  - name: setup_job_completed\n    on_probe_fail: skip\n    probe:\n      - command: \"python3 cases/rabbitmq/manual_policy_sync/setup_precondition_check.py --namespace ${BENCH_NAMESPACE} --bootstrap-only\"\n        timeout_sec: 30\n    apply:\n      - command: \"kubectl -n ${BENCH_NAMESPACE} delete job {{params.cluster_prefix}}-setup --ignore-not-found=true\"\n        sleep: 1\n      - command: \"envsubst '$BENCH_NAMESPACE $BENCH_NS_SOURCE $BENCH_NS_TARGET $BENCH_PARAM_CLUSTER_PREFIX $BENCH_PARAM_BLUE_CLUSTER_PREFIX $BENCH_PARAM_GREEN_CLUSTER_PREFIX $BENCH_PARAM_FROM_VERSION' < cases/rabbitmq/manual_policy_sync/resource/setup-job.yaml | kubectl -n ${BENCH_NAMESPACE} apply -f -\"\n        sleep: 1\n      - command: \"kubectl -n ${BENCH_NAMESPACE} wait --for=condition=complete job/{{params.cluster_prefix}}-setup --timeout=300s\"\n        sleep: 1\n    verify:\n      - command: \"python3 cases/rabbitmq/manual_policy_sync/setup_precondition_check.py --namespace ${BENCH_NAMESPACE} --bootstrap-only\"\n        timeout_sec: 30\n\n  - name: curl_test_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n ${BENCH_NAMESPACE} wait --for=condition=ready pod -l app=curl-test --timeout=3s\"\n        timeout_sec: 10\n    apply:\n      - command: \"envsubst '$BENCH_NAMESPACE $BENCH_NS_SOURCE $BENCH_NS_TARGET $BENCH_PARAM_CLUSTER_PREFIX $BENCH_PARAM_BLUE_CLUSTER_PREFIX $BENCH_PARAM_GREEN_CLUSTER_PREFIX $BENCH_PARAM_FROM