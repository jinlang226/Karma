erators were used, and no PVC referenced by a running pod was deleted."}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":1353,"cache_read_input_tokens":56144,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1353},"output_tokens":2,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"c57fd2be-f1a7-42d7-861a-cca55421b028","uuid":"591839ae-4f67-402a-9965-39314749e7e0","request_id":"req_011CcAgcTVxpC9GBtxprM5c2"}
