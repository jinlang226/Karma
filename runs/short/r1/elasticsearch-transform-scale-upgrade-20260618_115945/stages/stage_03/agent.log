word\n        - name: ES_JAVA_OPTS\n          value: \"-Xms512m -Xmx512m\"\n        ports:\n        - containerPort: 9200\n          name: https\n        - containerPort: 9300\n          name: transport\n        readinessProbe:\n          exec:\n            command: [\"bash\",\"-c\",\"curl -s -k -u elastic:$ELASTIC_PASSWORD https://localhost:9200/_cluster/health | grep -qE '\\\"status\\\":\\\"(green|yellow)\\\"'\"]\n          failureThreshold: 30\n          initialDelaySeconds: 30\n          periodSeconds: 10\n          timeoutSeconds: 5\n        volumeMounts:\n        - name: config\n          mountPath: /usr/share/elasticsearch/config/elasticsearch.yml\n          subPath: elasticsearch.yml\n        - name: certs\n          mountPath: /usr/share/elasticsearch/config/certs\n          readOnly: true\n        - name: data\n          mountPath: /usr/share/elasticsearch/data\n      volumes:\n      - name: config\n        configMap:\n          name: es-config-extra\n      - name: certs\n        secret:\n          secretName: es-http-tls\n  volumeClaimTemplates:\n  - metadata:\n      name: data\n    spec:\n      accessModes: [\"ReadWriteOnce\"]\n      resources:\n        requests:\n          storage: 2Gi\nEOF\nkubectl apply -f /tmp/es-extra.yaml","description":"Apply new configmap and es-extra statefulset"},"caller":{"type":"direct"}}],"stop_reason":null,"stop_sequence":null,"stop_details":null,"usage":{"input_tokens":2,"cache_creation_input_tokens":1804,"cache_read_input_tokens":34240,"cache_creation":{"ephemeral_5m_input_tokens":0,"ephemeral_1h_input_tokens":1804},"output_tokens":1,"service_tier":"standard","inference_geo":"not_available"},"diagnostics":null,"context_management":null},"parent_tool_use_id":null,"session_id":"32cf3128-5456-4a32-84d4-7d10f687667d","uuid":"103295c2-9575-480c-9298-6842f3afa4da","request_id":"req_011CcAid5yR4rqUhVDva3pN2"}
