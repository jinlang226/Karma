{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_016vYg7v4JrFM7vKL2919JVc","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\t# Verify the rolling partitioned update landed on the configured target version.\n3\t# The target version comes from the case param (BENCH_PARAM_TO_VERSION), so a\n4\t# workflow that overrides to_version is honored instead of a hardcoded value.\n5\t# Standalone (default param) this behaves identically to the old hardcoded check.\n6\timport json\n7\timport os\n8\timport subprocess\n9\timport sys\n10\t\n11\t\n12\tTO_VERSION = os.environ.get(\"BENCH_PARAM_TO_VERSION\", \"24.1.1\")\n13\tTARGET_IMAGE = f\"cockroachdb/cockroach:v{TO_VERSION}\"\n14\tTARGET_VERSION = f\"v{TO_VERSION}\"\n15\t# Accept any patch of the target major.minor (e.g. v24.1.0 for a 24.1 cluster):\n16\t# a prior workflow upgrade stage may leave the cluster on a different 24.1.x patch.\n17\tTARGET_MAJMIN = \".\".join(TO_VERSION.split(\".\")[:2])\n18\t\n19\t\n20\tdef run(cmd):\n21\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n22\t\n23\t\n24\tdef crdb_pods():\n25\t    \"\"\"Return the cluster's pods, robust to how the cluster was labelled (§3.1).\n26\t\n27\t    Resolve by the live `crdb-cluster` StatefulSet's own selector first; fall\n28\t    back to the canonical app.kubernetes.io/name=cockroachdb label, then to the\n29\t    crdb-cluster-* pod-name prefix -- so a downstream oracle survives a workflow\n30\t    whose earlier (agent-built) deploy stage chose different labels.\n31\t    \"\"\"\n32\t    sts = run([\"kubectl\", \"-n\", \"cockroachdb\", \"get\", \"statefulset\",\n33\t               \"crdb-cluster\", \"-o\", \"json\"])\n34\t    if sts.returncode == 0:\n35\t        try:\n36\t            match = (json.loads(sts.stdout).get(\"spec\", {})\n37\t                     .get(\"selector\", {}).get(\"matchLabels\")) or {}\n38\t        except json.JSONDecodeError:\n39\t            match = {}\n40\t        if match:\n41\t            sel = \",\".join(f\"{k}={v}\" for k, v in match.items())\n42\t            res = run([\"kubectl\", \"-n\", \"cockroachdb\", \"get\", \"pods\",\n43\t                       \"-l\", sel, \"-o\", \"json\"])\n44\t            if res.returncode == 0:\n45\t                try:\n46\t                    items = json.loads(res.stdout).get(\"items\", [])\n47\t                except json.JSONDecodeError:\n48\t                    items = []\n49\t                if items:\n50\t                    return items\n51\t    res = run([\"kubectl\", \"-n\", \"cockroachdb\", \"get\", \"pods\",\n52\t               \"-l\", \"app.kubernetes.io/name=cockroachdb\", \"-o\", \"json\"])\n53\t    if res.returncode == 0:\n54\t        try:\n55\t            items = json.loads(res.stdout).get(\"items\", [])\n56\t        except json.JSONDecodeError:\n57\t            items = []\n58\t        if items:\n59\t            return items\n60\t    res = run([\"kubectl\", \"-n\", \"cockroachdb\", \"get\", \"pods\", \"-o\", \"json\"])\n61\t    if res.returncode != 0:\n62\t        return []\n63\t    try:\n64\t        items = json.loads(res.stdout).get(\"items\", [])\n65\t    except json.JSONDecodeError:\n66\t        return []\n67\t    return [p for p in items\n68\t            if p.get(\"metadata\", {}).get(\"name\", \"\").startswith(\"crdb-cluster-\")]\n69\t\n70\t\n71\t_EXPECTED_NODES = None\n72\t\n73\t\n74\tdef expected_nodes():\n75\t    \"\"\"Resolve how many pods / live nodes the cluster should have.\n76\t\n77\t    A partitioned rolling update does not change topology, so the expected count\n78\t    adapts to whatever was inherited: an explicit param override\n79\t    (BENCH_PARAM_EXPECTED_NODES / _REPLICA_COUNT) wins, else the live\n80\t    StatefulSet's DESIRED size (spec.replicas), else the old hardcoded 3. Using\n81\t    the desired size (not readyReplicas) keeps the check honest — a pod lost\n82\t    during the rollout still fails. Only the count target adapts. Cached.\n83\t    \"\"\"\n84\t    global _EXPECTED_NODES\n85\t    if _EXPECTED_NODES is not None:\n86\t        return _EXPECTED_NODES\n87\t    override = (\n88\t        os.environ.get(\"BENCH_PARAM_EXPECTED_NODES\")\n89\t        or os.environ.get(\"BENCH_PARAM_REPLICA_COUNT\")\n90\t    )\n91\t    if override and override.strip().isdigit():\n92\t        _EXPECTED_NODES = int(override)\n93\t        return _EXPECTED_NODES\n94\t    result = run([\n95\t        \"kubectl\", \"-n\", \"cockroachdb\", \"get\", \"statefulset\", \"crdb-cluster\",\n96\t        \"-o\", \"jsonpath={.spec.replicas}\",\n97\t    ])\n98\t    if result.returncode == 0 and result.stdout.strip().isdigit():\n99\t        live = int(result.stdout.strip())\n100\t        if live > 0:\n101\t            _EXPECTED_NODES = live\n102\t            return _EXPECTED_NODES\n103\t    _EXPECTED_NODES = 3\n104\t    return _EXPECTED_NODES\n105\t\n106\t\n107\t_CONN_FLAG = None\n108\t\n109\t\n110\tdef conn_flag():\n111\t    \"\"\"Return the right cockroach SQL connection flag for the live cluster.\n112\t\n113\t    Standalone this case runs against an INSECURE cluster (`--insecure`). But in\n114\t    a workflow this stage can inherit a SECURE cluster left running by a prior\n115\t    stage (e.g. certificate-rotation), whose precondition probe sees pods already\n116\t    Running and skips its own insecure redeploy. A hardcoded `--insecure` then\n117\t    fails with an SSL authentication error. Detect the mode once by checking for\n118\t    the mounted certs dir and connect accordingly so the same oracle works in\n119\t    both contexts. Mirrors cockroachdb/cluster-settings/oracle/oracle.py.\n120\t    \"\"\"\n121\t    global _CONN_FLAG\n122\t    if _CONN_FLAG is not None:\n123\t        return _CONN_FLAG\n124\t    probe = run([\n125\t        \"kubectl\", \"-n\", \"cockroachdb\", \"--request-timeout=15s\", \"exec\",\n126\t        \"crdb-cluster-0\", \"--\", \"ls\", \"/cockroach/cockroach-certs/ca.crt\",\n127\t    ])\n128\t    if probe.returncode == 0:\n129\t        _CONN_FLAG = \"--certs-dir=/cockroach/cockroach-certs\"\n130\t    else:\n131\t        _CONN_FLAG = \"--insecure\"\n132\t    return _CONN_FLAG\n133\t\n134\t\n135\tdef parse_tsv(output):\n136\t    lines = [line.strip() for line in output.splitlines() if line.strip()]\n137\t    if not lines:\n138\t        return [], []\n139\t    header = lines[0].split(\"\\t\")\n140\t    rows = [line.split(\"\\t\") for line in lines[1:]]\n141\t    return header, rows\n142\t\n143\t\n144\tdef to_bool(value):\n145\t    return str(value).strip().lower() in (\"true\", \"t\", \"1\", \"yes\")\n146\t\n147\t\n148\tdef evaluate():\n149\t    \"\"\"One full snapshot of the partitioned-update checks; returns error list.\"\"\"\n150\t    errors = []\n151\t\n152\t    cmd = [\"kubectl\", \"-n\", \"cockroachdb\", \"get\", \"statefulset\", \"crdb-cluster\", \"-o\", \"json\"]\n153\t    result = run(cmd)\n154\t    if result.returncode != 0:\n155\t        errors.append(result.stderr.strip() or \"Failed to read StatefulSet\")\n156\t    else:\n157\t        try:\n158\t            sts = json.loads(result.stdout)\n159\t        except json.JSONDecodeError:\n160\t            errors.append(\"Failed to parse StatefulSet\")\n161\t            sts = {}\n162\t        spec = sts.get(\"spec\", {})\n163\t        status = sts.get(\"status\", {})\n164\t        replicas = spec.get(\"replicas\", 0)\n165\t        updated = status.get(\"updatedReplicas\", 0)\n166\t        if updated != replicas:\n167\t            errors.append(f\"Update not complete: {updated}/{replicas} updated\")\n168\t        if status.get(\"currentRevision\") != status.get(\"updateRevision\"):\n169\t            errors.append(\"StatefulSet revisions do not match\")\n170\t        partition = (\n171\t            spec.get(\"updateStrategy\", {})\n172\t            .get(\"rollingUpdate\", {})\n173\t            .get(\"partition\", 0)\n174\t        )\n175\t        if partition not in (0, \"0\", None):\n176\t            errors.append(f\"Partition not reset: {partition}\")\n177\t\n178\t    pods = crdb_pods()\n179\t    if len(pods) != expected_nodes():\n180\t        errors.append(f\"Expected {expected_nodes()} pods, found {len(pods)}\")\n181\t    for pod in pods:\n182\t        name = pod.get(\"metadata\", {}).get(\"name\", \"unknown\")\n183\t        containers = pod.get(\"spec\", {}).get(\"containers\", [])\n184\t        if not containers:\n185\t            errors.append(f\"No containers found in pod {name}\")\n186\t            continue\n187\t        image = containers[0].get(\"image\") or \"\"\n188\t        if \".\".join(image.split(\":\")[-1].lstrip(\"v\").split(\".\")[:2]) != TARGET_MAJMIN:\n189\t            errors.append(f\"Pod {name} image is {image} (expected v{TARGET_MAJMIN}.x)\")\n190\t\n191\t    cmd = [\n192\t        \"kubectl\",\n193\t        \"-n\",\n194\t        \"cockroachdb\",\n195\t        \"exec\",\n196\t        \"crdb-cluster-0\",\n197\t        \"--\",\n198\t        \"./cockroach\",\n199\t        \"sql\",\n200\t        conn_flag(),\n201\t        \"-e\",\n202\t        \"SELECT version();\",\n203\t    ]\n204\t    result = run(cmd)\n205\t    if result.returncode != 0:\n206\t        errors.append(result.stderr.strip() or \"SQL version check failed\")\n207\t    elif f\"v{TARGET_MAJMIN}.\" not in result.stdout:\n208\t        errors.append(f\"SQL version does not match target v{TARGET_MAJMIN}.x\")\n209\t\n210\t    cmd = [\n211\t        \"kubectl\",\n212\t        \"-n\",\n213\t        \"cockroachdb\",\n214\t        \"exec\",\n215\t        \"crdb-cluster-0\",\n216\t        \"--\",\n217\t        \"./cockroach\",\n218\t        \"node\",\n219\t        \"status\",\n220\t        conn_flag(),\n221\t        \"--format=tsv\",\n222\t    ]\n223\t    result = run(cmd)\n224\t    if result.returncode != 0:\n225\t        errors.append(result.stderr.strip() or \"Failed to read node status\")\n226\t    else:\n227\t        header, rows = parse_tsv(result.stdout)\n228\t        if not header:\n229\t            errors.append(\"Empty node status output\")\n230\t        else:\n231\t            cols = {name: idx for idx, name in enumerate(header)}\n232\t            live_idx = cols.get(\"is_live\")\n233\t            if live_idx is None:\n234\t                errors.append(\"Missing is_live column in node status output\")\n235\t            else:\n236\t                live_nodes = 0\n237\t                for row in rows:\n238\t                    if len(row) <= live_idx:\n239\t                        continue\n240\t                    if to_bool(row[live_idx]):\n241\t                        live_nodes += 1\n242\t                if live_nodes != expected_nodes():\n243\t                    errors.append(f\"Expected {expected_nodes()} live nodes, found {live_nodes}\")\n244\t\n245\t    return errors\n246\t\n247\t\n248\tdef main():\n249\t    # A partitioned rolling update restarts nodes one at a time; a just-restarted\n250\t    # node takes a short while to rejoin and report is_live, and the StatefulSet's\n251\t    # updatedReplicas/revisions settle a beat after the last pod restarts. A\n252\t    # single snapshot can race that convergence and see e.g. \"2 live nodes\" on a\n253\t    # cluster healthily finishing its rollout (the same case passes at the prior\n254\t    # stages). Re-evaluate for up to ~70s and pass on the first clean snapshot.\n255\t    # This does not loosen the check -- a node that genuinely fails to rejoin\n256\t    # never becomes live, so the oracle still fails after the deadline.\n257\t    import time\n258\t    deadline = time.monotonic() + 70\n259\t    errors = evaluate()\n260\t    while errors and time.monotonic() < deadline:\n261\t        time.sleep(7)\n262\t        errors = evaluate()\n263\t\n264\t    if errors:\n265\t        print(\"Partitioned update verification failed:\", file=sys.stderr)\n266\t        for error in errors:\n267\t            print(f\"  - {error}\", file=sys.stderr)\n268\t        return 1\n269\t\n270\t    print(\"Partitioned update completed successfully\")\n271\t    return 0\n272\t\n273\t\n274\tif __name__ == \"__main__\":\n275\t    sys.exit(main())\n276\t"}]},"parent_tool_use_id":null,"session_id":"9890bff2-62c4-4c97-b1f2-1767ee9bac2a","uuid":"8282fb95-fcf6-40f9-b934-1fe29706b62a","timestamp":"2026-06-24T06:27:26.520Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/cockroachdb/partitioned-update/oracle/oracle.py","content":"#!/usr/bin/env python3\n# Verify the rolling partitioned update landed on the configured target version.\n# The target version comes from the case param (BENCH_PARAM_TO_VERSION), so a\n# workflow that overrides to_version is honored instead of a hardcoded value.\n# Standalone (default param) this behaves identically to the old hardcoded check.\nimport json\nimport os\nimport subprocess\nimport sys\n\n\nTO_VERSION = os.environ.get(\"BENCH_PARAM_TO_VERSION\", \"24.1.1\")\nTARGET_IMAGE = f\"cockroachdb/cockroach:v{TO_VERSION}\"\nTARGET_VERSION = f\"v{TO_VERSION}\"\n# Accept any patch of the target major.minor (e.g. v24.1.0 for a 24.1 cluster):\n# a prior workflow upgrade stage may leave the cluster on a different 24.1.x patch.\nTARGET_MAJMIN = \".\".join(TO_VERSION.split(\".\")[:2])\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef crdb_pods():\n    \"\"\"Return the cluster's pods, robust to how the cluster was labelled (§3.1).\n\n    Resolve by the live `crdb-cluster` StatefulSet's own selector first; fall\n    back to the canonical app.kubernetes.io/name=cockroachdb label, then to the\n    crdb-cluster-* pod-name prefix -- so a downstream oracle survives a workflow\n    whose earlier (agent-built) deploy stage chose different labels.\n    \"\"\"\n    sts = run([\"kubectl\", \"-n\", \"cockroachdb\", \"get\", \"statefulset\",\n               \"crdb-cluster\", \"-o\", \"json\"])\n    if sts.returncode == 0:\n        try:\n            match = (json.loads(sts.stdout).get(\"spec\", {})\n                     .get(\"selector\", {}).get(\"matchLabels\")) or {}\n        except json.JSONDecodeError:\n            match = {}\n        if match:\n            sel = \",\".join(f\"{k}={v}\" for k, v in match.items())\n            res = run([\"kubectl\", \"-n\", \"cockroachdb\", \"get\", \"pods\",\n                       \"-l\", sel, \"-o\", \"json\"])\n            if res.returncode == 0:\n                try:\n                    items = json.loads(res.stdout).get(\"items\", [])\n                except json.JSONDecodeError:\n                    items = []\n                if items:\n                    return items\n    res = run([\"kubectl\", \"-n\", \"cockroachdb\", \"get\", \"pods\",\n               \"-l\", \"app.kubernetes.io/name=cockroachdb\", \"-o\", \"json\"])\n    if res.returncode == 0:\n        try:\n            items = json.loads(res.stdout).get(\"items\", [])\n        except json.JSONDecodeError:\n            items = []\n        if items:\n            return items\n    res = run([\"kubectl\", \"-n\", \"cockroachdb\", \"get\", \"pods\", \"-o\", \"json\"])\n    if res.returncode != 0:\n        return []\n    try:\n        items = json.loads(res.stdout).get(\"items\", [])\n    except json.JSONDecodeError:\n        return []\n    return [p for p in items\n            if p.get(\"metadata\", {}).get(\"name\", \"\").startswith(\"crdb-cluster-\")]\n\n\n_EXPECTED_NODES = None\n\n\ndef expected_nodes():\n    \"\"\"Resolve how many pods / live nodes the cluster should have.\n\n    A partitioned rolling update does not change topology, so the expected count\n    adapts to whatever was inherited: an explicit param override\n    (BENCH_PARAM_EXPECTED_NODES / _REPLICA_COUNT) wins, else the live\n    StatefulSet's DESIRED size (spec.replicas), else the old hardcoded 3. Using\n    the desired size (not readyReplicas) keeps the check honest — a pod lost\n    during the rollout still fails. Only the count target adapts. Cached.\n    \"\"\"\n    global _EXPECTED_NODES\n    if _EXPECTED_NODES is not None:\n        return _EXPECTED_NODES\n    override = (\n        os.environ.get(\"BENCH_PARAM_EXPECTED_NODES\")\n        or os.environ.get(\"BENCH_PARAM_REPLICA_COUNT\")\n    )\n    if override and override.strip().isdigit():\n        _EXPECTED_NODES = int(override)\n        return _EXPECTED_NODES\n    result = run([\n        \"kubectl\", \"-n\", \"cockroachdb\", \"get\", \"statefulset\", \"crdb-cluster\",\n        \"-o\", \"jsonpath={.spec.replicas}\",\n    ])\n    if result.returncode == 0 and result.stdout.strip().isdigit():\n        live = int(result.stdout.strip())\n        if live > 0:\n            _EXPECTED_NODES = live\n            return _EXPECTED_NODES\n    _EXPECTED_NODES = 3\n    return _EXPECTED_NODES\n\n\n_CONN_FLAG = None\n\n\ndef conn_flag():\n    \"\"\"Return the right cockroach SQL connection flag for the live cluster.\n\n    Standalone this case runs against an INSECURE cluster (`--insecure`). But in\n    a workflow this stage can inherit a SECURE cluster left running by a prior\n    stage (e.g. certificate-rotation), whose precondition probe sees pods already\n    Running and skips its own insecure redeploy. A hardcoded `--insecure` then\n    fails with an SSL authentication error. Detect the mode once by checking for\n    the mounted certs dir and connect accordingly so the same oracle works in\n    both contexts. Mirrors cockroachdb/cluster-settings/oracle/oracle.py.\n    \"\"\"\n    global _CONN_FLAG\n    if _CONN_FLAG is not None:\n        return _CONN_FLAG\n    probe = run([\n        \"kubectl\", \"-n\", \"cockroachdb\", \"--request-timeout=15s\", \"exec\",\n        \"crdb-cluster-0\", \"--\", \"ls\", \"/cockroach/cockroach-certs/ca.crt\",\n    ])\n    if probe.returncode == 0:\n        _CONN_FLAG = \"--certs-dir=/cockroach/cockroach-certs\"\n    else:\n        _CONN_FLAG = \"--insecure\"\n    return _CONN_FLAG\n\n\ndef parse_tsv(output):\n    lines = [line.strip() for line in output.splitlines() if line.strip()]\n    if not lines:\n        return [], []\n    header = lines[0].split(\"\\t\")\n    rows = [line.split(\"\\t\") for line in lines[1:]]\n    return header, rows\n\n\ndef to_bool(value):\n    return str(value).strip().lower() in (\"true\", \"t\", \"1\", \"yes\")\n\n\ndef evaluate():\n    \"\"\"One full snapshot of the partitioned-update checks; returns error list.\"\"\"\n    errors = []\n\n    cmd = [\"kubectl\", \"-n\", \"cockroachdb\", \"get\", \"statefulset\", \"crdb-cluster\", \"-o\", \"json\"]\n    result = run(cmd)\n    if result.returncode != 0:\n        errors.append(result.stderr.strip() or \"Failed to read StatefulSet\")\n    else:\n        try:\n            sts = json.loads(result.stdout)\n        except json.JSONDecodeError:\n            errors.append(\"Failed to parse StatefulSet\")\n            sts = {}\n        spec = sts.get(\"spec\", {})\n        status = sts.get(\"status\", {})\n        replicas = spec.get(\"replicas\", 0)\n        updated = status.get(\"updatedReplicas\", 0)\n        if updated != replicas:\n            errors.append(f\"Update not complete: {updated}/{replicas} updated\")\n        if status.get(\"currentRevision\") != status.get(\"updateRevision\"):\n            errors.append(\"StatefulSet revisions do not match\")\n        partition = (\n            spec.get(\"updateStrategy\", {})\n            .get(\"rollingUpdate\", {})\n            .get(\"partition\", 0)\n        )\n        if partition not in (0, \"0\", None):\n            errors.append(f\"Partition not reset: {partition}\")\n\n    pods = crdb_pods()\n    if len(pods) != expected_nodes():\n        errors.append(f\"Expected {expected_nodes()} pods, found {len(pods)}\")\n    for pod in pods:\n        name = pod.get(\"metadata\", {}).get(\"name\", \"unknown\")\n        containers = pod.get(\"spec\", {}).get(\"containers\", [])\n        if not containers:\n            errors.append(f\"No containers found in pod {name}\")\n            continue\n        image = containers[0].get(\"image\") or \"\"\n        if \".\".join(image.split(\":\")[-1].lstrip(\"v\").split(\".\")[:2]) != TARGET_MAJMIN:\n            errors.append(f\"Pod {name} image is {image} (expected v{TARGET_MAJMIN}.x)\")\n\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        \"cockroachdb\",\n        \"exec\",\n        \"crdb-cluster-0\",\n        \"--\",\n        \"./cockroach\",\n        \"sql\",\n        conn_flag(),\n        \"-e\",\n        \"SELECT version();\",\n    ]\n    result = run(cmd)\n    if result.returncode != 0:\n        errors.append(result.stderr.strip() or \"SQL version check failed\")\n    elif f\"v{TARGET_MAJMIN}.\" not in result.stdout:\n        errors.append(f\"SQL version does not match target v{TARGET_MAJMIN}.x\")\n\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        \"cockroachdb\",\n        \"exec\",\n        \"crdb-cluster-0\",\n        \"--\",\n        \"./cockroach\",\n        \"node\",\n        \"status\",\n        conn_flag(),\n        \"--format=tsv\",\n    ]\n    result = run(cmd)\n    if result.returncode != 0:\n        errors.append(result.stderr.strip() or \"Failed to read node status\")\n    else:\n        header, rows = parse_tsv(result.stdout)\n        if not header:\n            errors.append(\"Empty node status output\")\n        else:\n            cols = {name: idx for idx, name in enumerate(header)}\n            live_idx = cols.get(\"is_live\")\n            if live_idx is None:\n                errors.append(\"Missing is_live column in node status output\")\n            else:\n                live_nodes = 0\n                for row in rows:\n                    if len(row) <= live_idx:\n                        continue\n                    if to_bool(row[live_idx]):\n                        live_nodes += 1\n                if live_nodes != expected_nodes():\n                    errors.append(f\"Expected {expected_nodes()} live nodes, found {live_nodes}\")\n\n    return errors\n\n\ndef main():\n    # A partitioned rolling update restarts nodes one at a time; a just-restarted\n    # node takes a short while to rejoin and report is_live, and the StatefulSet's\n    # updatedReplicas/revisions settle a beat after the last pod restarts. A\n    # single snapshot can race that convergence and see e.g. \"2 live nodes\" on a\n    # cluster healthily finishing its rollout (the same case passes at the prior\n    # stages). Re-evaluate for up to ~70s and pass on the first clean snapshot.\n    # This does not loosen the check -- a node that genuinely fails to rejoin\n    # never becomes live, so the oracle still fails after the deadline.\n    import time\n    deadline = time.monotonic() + 70\n    errors = evaluate()\n    while errors and time.monotonic() < deadline:\n        time.sleep(7)\n        errors = evaluate()\n\n    if errors:\n        print(\"Partitioned update verification failed:\", file=sys.stderr)\n        for error in errors:\n            print(f\"  - {error}\", file=sys.stderr)\n        return 1\n\n    print(\"Partitioned update completed successfully\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":276,"startLine":1,"totalLines":276}}}
