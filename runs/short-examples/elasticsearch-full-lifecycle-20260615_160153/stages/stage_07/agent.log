{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_013ZXWrCDtqPUpzhSg914aZ2","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport json\n3\timport os\n4\timport subprocess\n5\timport sys\n6\t\n7\tNAMESPACE = \"elasticsearch\"\n8\tSERVICE = \"es-http\"\n9\tCLUSTER_PREFIX = \"es-cluster\"\n10\tREPO_NAME = \"minio-repo\"\n11\tKEYS = {\n12\t    \"s3.client.default.access_key\",\n13\t    \"s3.client.default.secret_key\",\n14\t}\n15\tDEFAULT_SCHEME = \"http\"\n16\t_SCHEME = None\n17\t\n18\t\n19\tdef run(cmd):\n20\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n21\t\n22\t\n23\tdef _resolve_expected_nodes(default=3):\n24\t    \"\"\"Node count to enforce (param override -> live Ready es pods -> default).\n25\t\n26\t    The env PERSISTS across stages; adapt the target to the live cluster\n27\t    without loosening it (a missing/NotReady node still mismatches).\n28\t    \"\"\"\n29\t    for key in (\"BENCH_PARAM_EXPECTED_NODES\", \"BENCH_PARAM_EXPECTED_NODE_COUNT\"):\n30\t        val = os.environ.get(key)\n31\t        if val is not None and str(val).strip():\n32\t            try:\n33\t                return int(val)\n34\t            except ValueError:\n35\t                pass\n36\t    # Authoritative inherited topology = the StatefulSet's desired replicas. A\n37\t    # prior stage (e.g. safe-downscale) may have scaled the cluster down; read\n38\t    # spec.replicas rather than a Ready-pod count because a downscaled single\n39\t    # node is YELLOW and so fails its readiness probe (Ready=False) while still\n40\t    # being a fully functional node -- a Ready count would undercount to 0 and\n41\t    # wrongly fall back to the default.\n42\t    sts = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"statefulset\", CLUSTER_PREFIX,\n43\t               \"-o\", \"jsonpath={.spec.replicas}\"])\n44\t    if sts.returncode == 0 and sts.stdout.strip().isdigit():\n45\t        desired = int(sts.stdout.strip())\n46\t        if desired > 0:\n47\t            return desired\n48\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"pods\", \"-l\", f\"app={CLUSTER_PREFIX}\", \"-o\", \"json\"])\n49\t    if res.returncode == 0:\n50\t        try:\n51\t            items = json.loads(res.stdout).get(\"items\", [])\n52\t            ready = sum(\n53\t                1 for p in items\n54\t                if any(c.get(\"type\") == \"Ready\" and c.get(\"status\") == \"True\"\n55\t                       for c in p.get(\"status\", {}).get(\"conditions\", []))\n56\t            )\n57\t            if ready > 0:\n58\t                return ready\n59\t        except (json.JSONDecodeError, AttributeError):\n60\t            pass\n61\t    return default\n62\t\n63\t\n64\tEXPECTED_NODES = _resolve_expected_nodes(3)\n65\t\n66\t\n67\tdef _probe_scheme(scheme):\n68\t    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\"\"\"\n69\t    result = run([\n70\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\", \"/bin/sh\", \"-c\",\n71\t        f\"curl -s -S -k -o /dev/null -w '%{{http_code}}' --max-time 5 {scheme}://{SERVICE}.{NAMESPACE}.svc:9200/\",\n72\t    ])\n73\t    code = (result.stdout or \"\").strip().strip(\"'\")\n74\t    return result.returncode == 0 and code.isdigit() and code != \"000\"\n75\t\n76\t\n77\tdef detect_scheme():\n78\t    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n79\t    global _SCHEME\n80\t    if _SCHEME is not None:\n81\t        return _SCHEME\n82\t    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n83\t        if _probe_scheme(scheme):\n84\t            _SCHEME = scheme\n85\t            return _SCHEME\n86\t    _SCHEME = DEFAULT_SCHEME\n87\t    return _SCHEME\n88\t\n89\t\n90\tdef curl(path, errors):\n91\t    scheme = detect_scheme()\n92\t    cmd = [\n93\t        \"kubectl\",\n94\t        \"-n\",\n95\t        NAMESPACE,\n96\t        \"exec\",\n97\t        \"curl-test\",\n98\t        \"--\",\n99\t        \"/bin/sh\",\n100\t        \"-c\",\n101\t        f\"curl -s -S -k --max-time 10 {scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\",\n102\t    ]\n103\t    result = run(cmd)\n104\t    if result.returncode != 0:\n105\t        detail = result.stderr.strip() or result.stdout.strip() or f\"command terminated with exit code {result.returncode}\"\n106\t        errors.append(f\"Failed to query {path}: {detail}\")\n107\t        return None\n108\t    output = result.stdout.strip()\n109\t    if not output:\n110\t        errors.append(f\"Empty response for {path}\")\n111\t        return None\n112\t    try:\n113\t        return json.loads(output)\n114\t    except json.JSONDecodeError:\n115\t        errors.append(f\"Failed to parse JSON from {path}\")\n116\t        return None\n117\t\n118\t\n119\tdef get_pods(errors):\n120\t    result = run(\n121\t        [\n122\t            \"kubectl\",\n123\t            \"-n\",\n124\t            NAMESPACE,\n125\t            \"get\",\n126\t            \"pods\",\n127\t            \"-l\",\n128\t            \"app=es-cluster\",\n129\t            \"-o\",\n130\t            \"json\",\n131\t        ]\n132\t    )\n133\t    if result.returncode != 0:\n134\t        errors.append(f\"Failed to list Elasticsearch pods: {result.stderr.strip()}\")\n135\t        return []\n136\t    try:\n137\t        payload = json.loads(result.stdout)\n138\t    except json.JSONDecodeError:\n139\t        errors.append(\"Failed to parse pod list JSON\")\n140\t        return []\n141\t    return [item.get(\"metadata\", {}).get(\"name\") for item in payload.get(\"items\", [])]\n142\t\n143\t\n144\tdef check_keystore(pod, errors):\n145\t    result = run(\n146\t        [\n147\t            \"kubectl\",\n148\t            \"-n\",\n149\t            NAMESPACE,\n150\t            \"exec\",\n151\t            pod,\n152\t            \"--\",\n153\t            \"/usr/share/elasticsearch/bin/elasticsearch-keystore\",\n154\t            \"list\",\n155\t        ]\n156\t    )\n157\t    if result.returncode != 0:\n158\t        detail = result.stderr.strip() or result.stdout.strip()\n159\t        errors.append(f\"Failed to list keystore on {pod}: {detail}\")\n160\t        return\n161\t    keys = {line.strip() for line in result.stdout.splitlines() if line.strip()}\n162\t    missing = sorted(KEYS - keys)\n163\t    if missing:\n164\t        errors.append(f\"Missing keystore keys on {pod}: {', '.join(missing)}\")\n165\t\n166\t\n167\tdef check_configmap(errors):\n168\t    result = run(\n169\t        [\n170\t            \"kubectl\",\n171\t            \"-n\",\n172\t            NAMESPACE,\n173\t            \"get\",\n174\t            \"configmap\",\n175\t            \"es-config\",\n176\t            \"-o\",\n177\t            \"json\",\n178\t        ]\n179\t    )\n180\t    if result.returncode != 0:\n181\t        errors.append(f\"Failed to read es-config ConfigMap: {result.stderr.strip()}\")\n182\t        return\n183\t    try:\n184\t        cm = json.loads(result.stdout)\n185\t    except json.JSONDecodeError:\n186\t        errors.append(\"Failed to parse es-config ConfigMap JSON\")\n187\t        return\n188\t    text = json.dumps(cm)\n189\t    if \"access_key\" in text or \"secret_key\" in text:\n190\t        errors.append(\"Plaintext credentials found in es-config ConfigMap\")\n191\t\n192\t\n193\tdef check_snapshots(errors):\n194\t    repo = curl(f\"/_snapshot/{REPO_NAME}\", errors)\n195\t    if repo is None:\n196\t        return\n197\t    if \"error\" in repo:\n198\t        errors.append(f\"Snapshot repository {REPO_NAME} not found\")\n199\t        return\n200\t\n201\t    snaps = curl(f\"/_snapshot/{REPO_NAME}/_all\", errors)\n202\t    if not isinstance(snaps, dict):\n203\t        return\n204\t    snapshots = snaps.get(\"snapshots\", [])\n205\t    if not snapshots:\n206\t        errors.append(\"No snapshots found in repository\")\n207\t        return\n208\t    success = [s for s in snapshots if s.get(\"state\") == \"SUCCESS\"]\n209\t    if not success:\n210\t        errors.append(\"No SUCCESS snapshots found in repository\")\n211\t\n212\t\n213\tdef main():\n214\t    errors = []\n215\t\n216\t    health = curl(\n217\t        f\"/_cluster/health?wait_for_status=yellow&wait_for_nodes={EXPECTED_NODES}&timeout=30s\",\n218\t        errors,\n219\t    )\n220\t    if isinstance(health, dict):\n221\t        status = health.get(\"status\")\n222\t        if status not in {\"yellow\", \"green\"}:\n223\t            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n224\t        if health.get(\"number_of_nodes\") != EXPECTED_NODES:\n225\t            errors.append(\n226\t                f\"Expected {EXPECTED_NODES} nodes, got {health.get('number_of_nodes')}\"\n227\t            )\n228\t\n229\t    check_snapshots(errors)\n230\t    check_configmap(errors)\n231\t\n232\t    pods = get_pods(errors)\n233\t    if pods:\n234\t        for pod in pods:\n235\t            check_keystore(pod, errors)\n236\t    else:\n237\t        errors.append(\"No Elasticsearch pods found to verify keystore\")\n238\t\n239\t    if errors:\n240\t        print(\"Secure settings verification failed:\", file=sys.stderr)\n241\t        for err in errors:\n242\t            print(f\"  - {err}\", file=sys.stderr)\n243\t        return 1\n244\t\n245\t    print(\"Secure settings verified\")\n246\t    return 0\n247\t\n248\t\n249\tif __name__ == \"__main__\":\n250\t    sys.exit(main())\n251\t"}]},"parent_tool_use_id":null,"session_id":"2d10aae1-653c-4e0a-b24b-7a975145df68","uuid":"ed49351d-e85f-4188-a74f-5dba8d94f4e0","timestamp":"2026-06-15T17:10:59.060Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/leo/Karma/cases/elasticsearch/snapshot-repo-setup/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport json\nimport os\nimport subprocess\nimport sys\n\nNAMESPACE = \"elasticsearch\"\nSERVICE = \"es-http\"\nCLUSTER_PREFIX = \"es-cluster\"\nREPO_NAME = \"minio-repo\"\nKEYS = {\n    \"s3.client.default.access_key\",\n    \"s3.client.default.secret_key\",\n}\nDEFAULT_SCHEME = \"http\"\n_SCHEME = None\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef _resolve_expected_nodes(default=3):\n    \"\"\"Node count to enforce (param override -> live Ready es pods -> default).\n\n    The env PERSISTS across stages; adapt the target to the live cluster\n    without loosening it (a missing/NotReady node still mismatches).\n    \"\"\"\n    for key in (\"BENCH_PARAM_EXPECTED_NODES\", \"BENCH_PARAM_EXPECTED_NODE_COUNT\"):\n        val = os.environ.get(key)\n        if val is not None and str(val).strip():\n            try:\n                return int(val)\n            except ValueError:\n                pass\n    # Authoritative inherited topology = the StatefulSet's desired replicas. A\n    # prior stage (e.g. safe-downscale) may have scaled the cluster down; read\n    # spec.replicas rather than a Ready-pod count because a downscaled single\n    # node is YELLOW and so fails its readiness probe (Ready=False) while still\n    # being a fully functional node -- a Ready count would undercount to 0 and\n    # wrongly fall back to the default.\n    sts = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"statefulset\", CLUSTER_PREFIX,\n               \"-o\", \"jsonpath={.spec.replicas}\"])\n    if sts.returncode == 0 and sts.stdout.strip().isdigit():\n        desired = int(sts.stdout.strip())\n        if desired > 0:\n            return desired\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"pods\", \"-l\", f\"app={CLUSTER_PREFIX}\", \"-o\", \"json\"])\n    if res.returncode == 0:\n        try:\n            items = json.loads(res.stdout).get(\"items\", [])\n            ready = sum(\n                1 for p in items\n                if any(c.get(\"type\") == \"Ready\" and c.get(\"status\") == \"True\"\n                       for c in p.get(\"status\", {}).get(\"conditions\", []))\n            )\n            if ready > 0:\n                return ready\n        except (json.JSONDecodeError, AttributeError):\n            pass\n    return default\n\n\nEXPECTED_NODES = _resolve_expected_nodes(3)\n\n\ndef _probe_scheme(scheme):\n    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\"\"\"\n    result = run([\n        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\", \"/bin/sh\", \"-c\",\n        f\"curl -s -S -k -o /dev/null -w '%{{http_code}}' --max-time 5 {scheme}://{SERVICE}.{NAMESPACE}.svc:9200/\",\n    ])\n    code = (result.stdout or \"\").strip().strip(\"'\")\n    return result.returncode == 0 and code.isdigit() and code != \"000\"\n\n\ndef detect_scheme():\n    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n    global _SCHEME\n    if _SCHEME is not None:\n        return _SCHEME\n    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n        if _probe_scheme(scheme):\n            _SCHEME = scheme\n            return _SCHEME\n    _SCHEME = DEFAULT_SCHEME\n    return _SCHEME\n\n\ndef curl(path, errors):\n    scheme = detect_scheme()\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"exec\",\n        \"curl-test\",\n        \"--\",\n        \"/bin/sh\",\n        \"-c\",\n        f\"curl -s -S -k --max-time 10 {scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\",\n    ]\n    result = run(cmd)\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"command terminated with exit code {result.returncode}\"\n        errors.append(f\"Failed to query {path}: {detail}\")\n        return None\n    output = result.stdout.strip()\n    if not output:\n        errors.append(f\"Empty response for {path}\")\n        return None\n    try:\n        return json.loads(output)\n    except json.JSONDecodeError:\n        errors.append(f\"Failed to parse JSON from {path}\")\n        return None\n\n\ndef get_pods(errors):\n    result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"get\",\n            \"pods\",\n            \"-l\",\n            \"app=es-cluster\",\n            \"-o\",\n            \"json\",\n        ]\n    )\n    if result.returncode != 0:\n        errors.append(f\"Failed to list Elasticsearch pods: {result.stderr.strip()}\")\n        return []\n    try:\n        payload = json.loads(result.stdout)\n    except json.JSONDecodeError:\n        errors.append(\"Failed to parse pod list JSON\")\n        return []\n    return [item.get(\"metadata\", {}).get(\"name\") for item in payload.get(\"items\", [])]\n\n\ndef check_keystore(pod, errors):\n    result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"exec\",\n            pod,\n            \"--\",\n            \"/usr/share/elasticsearch/bin/elasticsearch-keystore\",\n            \"list\",\n        ]\n    )\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip()\n        errors.append(f\"Failed to list keystore on {pod}: {detail}\")\n        return\n    keys = {line.strip() for line in result.stdout.splitlines() if line.strip()}\n    missing = sorted(KEYS - keys)\n    if missing:\n        errors.append(f\"Missing keystore keys on {pod}: {', '.join(missing)}\")\n\n\ndef check_configmap(errors):\n    result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"get\",\n            \"configmap\",\n            \"es-config\",\n            \"-o\",\n            \"json\",\n        ]\n    )\n    if result.returncode != 0:\n        errors.append(f\"Failed to read es-config ConfigMap: {result.stderr.strip()}\")\n        return\n    try:\n        cm = json.loads(result.stdout)\n    except json.JSONDecodeError:\n        errors.append(\"Failed to parse es-config ConfigMap JSON\")\n        return\n    text = json.dumps(cm)\n    if \"access_key\" in text or \"secret_key\" in text:\n        errors.append(\"Plaintext credentials found in es-config ConfigMap\")\n\n\ndef check_snapshots(errors):\n    repo = curl(f\"/_snapshot/{REPO_NAME}\", errors)\n    if repo is None:\n        return\n    if \"error\" in repo:\n        errors.append(f\"Snapshot repository {REPO_NAME} not found\")\n        return\n\n    snaps = curl(f\"/_snapshot/{REPO_NAME}/_all\", errors)\n    if not isinstance(snaps, dict):\n        return\n    snapshots = snaps.get(\"snapshots\", [])\n    if not snapshots:\n        errors.append(\"No snapshots found in repository\")\n        return\n    success = [s for s in snapshots if s.get(\"state\") == \"SUCCESS\"]\n    if not success:\n        errors.append(\"No SUCCESS snapshots found in repository\")\n\n\ndef main():\n    errors = []\n\n    health = curl(\n        f\"/_cluster/health?wait_for_status=yellow&wait_for_nodes={EXPECTED_NODES}&timeout=30s\",\n        errors,\n    )\n    if isinstance(health, dict):\n        status = health.get(\"status\")\n        if status not in {\"yellow\", \"green\"}:\n            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n        if health.get(\"number_of_nodes\") != EXPECTED_NODES:\n            errors.append(\n                f\"Expected {EXPECTED_NODES} nodes, got {health.get('number_of_nodes')}\"\n            )\n\n    check_snapshots(errors)\n    check_configmap(errors)\n\n    pods = get_pods(errors)\n    if pods:\n        for pod in pods:\n            check_keystore(pod, errors)\n    else:\n        errors.append(\"No Elasticsearch pods found to verify keystore\")\n\n    if errors:\n        print(\"Secure settings verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    print(\"Secure settings verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":251,"startLine":1,"totalLines":251}}}
