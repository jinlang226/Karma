{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E1HJgpXB76oVfwXHLKxEGM","type":"tool_result","content":"apiVersion: apps/v1\nkind: StatefulSet\nmetadata:\n  name: es-cluster\n  namespace: elasticsearch\nspec:\n  serviceName: es-cluster\n  podManagementPolicy: Parallel\n  replicas: 3\n  updateStrategy:\n    type: OnDelete\n  selector:\n    matchLabels:\n      app: es-cluster\n  template:\n    metadata:\n      labels:\n        app: es-cluster\n    spec:\n      initContainers:\n        - name: install-s3-plugin\n          image: docker.elastic.co/elasticsearch/elasticsearch:8.11.1\n          command:\n            - /bin/sh\n            - -c\n            - |\n              set -e\n              if [ ! -d /usr/share/elasticsearch/plugins/repository-s3 ]; then\n                /usr/share/elasticsearch/bin/elasticsearch-plugin install --batch repository-s3\n              fi\n          volumeMounts:\n            - name: es-plugins\n              mountPath: /usr/share/elasticsearch/plugins\n      containers:\n        - name: elasticsearch\n          image: docker.elastic.co/elasticsearch/elasticsearch:8.11.1\n          env:\n            - name: POD_NAME\n              valueFrom:\n                fieldRef:\n                  fieldPath: metadata.name\n            - name: ES_JAVA_OPTS\n              value: \"-Xms512m -Xmx512m\"\n          ports:\n            - containerPort: 9200\n              name: http\n            - containerPort: 9300\n              name: transport\n          readinessProbe:\n            httpGet:\n              path: /_cluster/health?local=true\n              port: http\n            initialDelaySeconds: 10\n            periodSeconds: 5\n            timeoutSeconds: 2\n            failureThreshold: 6\n          volumeMounts:\n            - name: es-config\n              mountPath: /usr/share/elasticsearch/config/elasticsearch.yml\n              subPath: elasticsearch.yml\n            - name: es-plugins\n              mountPath: /us