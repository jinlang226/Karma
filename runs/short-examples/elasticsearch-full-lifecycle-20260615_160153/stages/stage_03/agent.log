vice_name}}.elasticsearch\n95\t          DNS.4={{params.http_service_name}}.elasticsearch.svc\n96\t          DNS.5={{params.http_service_name}}.elasticsearch.svc.cluster.local\n97\t          DNS.6={{params.cluster_prefix}}\n98\t          DNS.7={{params.cluster_prefix}}.elasticsearch\n99\t          DNS.8={{params.cluster_prefix}}.elasticsearch.svc\n100\t          DNS.9={{params.cluster_prefix}}.elasticsearch.svc.cluster.local\n101\t          DNS.10=es-cluster-0\n102\t          DNS.11=es-cluster-1\n103\t          DNS.12=es-cluster-2\n104\t          DNS.13=es-cluster-0.{{params.cluster_prefix}}.elasticsearch.svc.cluster.local\n105\t          DNS.14=es-cluster-1.{{params.cluster_prefix}}.elasticsearch.svc.cluster.local\n106\t          DNS.15=es-cluster-2.{{params.cluster_prefix}}.elasticsearch.svc.cluster.local\n107\t          EOF\n108\t          openssl genrsa -out /tmp/certs/ca.key 2048\n109\t          openssl req -x509 -new -nodes -key /tmp/certs/ca.key -sha256 -days 365 -subj \"/CN=es-ca\" -out /tmp/certs/ca.crt\n110\t          openssl genrsa -out /tmp/certs/server.key 2048\n111\t          openssl req -new -key /tmp/certs/server.key -out /tmp/certs/server.csr -config /tmp/certs/openssl.cnf\n112\t          openssl x509 -req -in /tmp/certs/server.csr -CA /tmp/certs/ca.crt -CAkey /tmp/certs/ca.key -CAcreateserial -out /tmp/certs/server.crt -days 365 -extensions v3_req -extfile /tmp/certs/openssl.cnf\n113\t          '\\''\n114\t          kubectl -n elasticsearch cp openssl-toolbox:/tmp/certs \"${TMP_DIR}/certs\"\n115\t          kubectl -n elasticsearch create secret generic {{params.tls_secret_name}} --from-file=tls.crt=\"${TMP_DIR}/certs/server.crt\" --from-file=tls.key=\"${TMP_DIR}/certs/server.key\" --from-file=ca.crt=\"${TMP_DIR}/certs/ca.crt\" --dry-run=client -o yaml | kubectl apply -f -\n116\t          '\n117\t        sleep: 1\n118\t      - command: |\n119\t          /bin/sh -c '\n120\t          set -e\n121\t          TMP_DIR=$(mktemp -d)\n122\t          kubectl -n elasticsearch exec file-realm-gen -- /bin/sh -c '\\''\n123\t          set -e\n124\t          mkdir -p /tmp/ops /tmp/report\n125\t          : > /tmp/ops/users\n126\t          : > /tmp/ops/users_roles\n127\t          : > /tmp/report/users\n128\t          : > /tmp/report/users_roles\n129\t          ES_PATH_CONF=/tmp/ops /usr/share/elasticsearch/bin/elasticsearch-users useradd {{params.ops_user}} -p {{params.ops_password}} -r superuser\n130\t          ES_PATH_CONF=/tmp/report /usr/share/elasticsearch/bin/elasticsearch-users useradd {{params.report_user}} -p {{params.report_password}} -r read\n131\t          : > /tmp/ops/roles.yml\n132\t          : > /tmp/report/roles.yml\n133\t          '\\''\n134\t          kubectl -n elasticsearch cp file-realm-gen:/tmp/ops \"${TMP_DIR}/ops\"\n135\t          kubectl -n elasticsearch cp file-realm-gen:/tmp/report \"${TMP_DIR}/report\"\n136\t          kubectl -n elasticsearch create secret generic {{params.aggregate_secret_name}} --from-file=users=\"${TMP_DIR}/ops/users\" --from-file=users_roles=\"${TMP_DIR}/ops/users_roles\" --from-file=roles.yml=\"${TMP_DIR}/ops/roles.yml\" --dry-run=client -o yaml | kubectl apply -f -\n137\t          kubectl -n elasticsearch create secret generic {{params.provided_secret_name}} --from-file=users=\"${TMP_DIR}/report/users\" --from-file=users_roles=\"${TMP_DIR}/report/users_roles\" --from-file=roles.yml=\"${TMP_DIR}/report/roles.yml\" --dry-run=client -o yaml | kubectl apply -f -\n138\t          '\n139\t        sleep: 1\n140\t      - command: \"kubectl -n elasticsearch apply -f cases/elasticsearch/file-realm-user-roles-merge/resource/\"\n141\t        sleep: 1\n142\t      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod -l app={{params.cluster_prefix}} --timeout=600s\"\n143\t        sleep: 1\n144\t      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod/curl-test --timeout=300s\"\n145\t        sleep: 1\n146\t      - command: |\n147\t          /bin/sh -c '\n148\t 