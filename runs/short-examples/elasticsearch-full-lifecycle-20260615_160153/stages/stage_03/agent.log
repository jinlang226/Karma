secret generic {{params.aggregate_secret_name}} --from-file=users=\"${TMP_DIR}/ops/users\" --from-file=users_roles=\"${TMP_DIR}/ops/users_roles\" --from-file=roles.yml=\"${TMP_DIR}/ops/roles.yml\" --dry-run=client -o yaml | kubectl apply -f -\n          kubectl -n elasticsearch create secret generic {{params.provided_secret_name}} --from-file=users=\"${TMP_DIR}/report/users\" --from-file=users_roles=\"${TMP_DIR}/report/users_roles\" --from-file=roles.yml=\"${TMP_DIR}/report/roles.yml\" --dry-run=client -o yaml | kubectl apply -f -\n          '\n        sleep: 1\n      - command: \"kubectl -n elasticsearch apply -f cases/elasticsearch/file-realm-user-roles-merge/resource/\"\n        sleep: 1\n      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod -l app={{params.cluster_prefix}} --timeout=600s\"\n        sleep: 1\n      - command: \"kubectl -n elasticsearch wait --for=condition=ready pod/curl-test --timeout=300s\"\n        sleep: 1\n      - command: |\n          /bin/sh -c '\n          for i in $(seq 1 30); do\n            kubectl -n elasticsearch exec curl-test -- curl -s -k -u {{params.ops_user}}:{{params.ops_password}} --max-time 5 \"https://{{params.http_service_name}}.elasticsearch.svc:9200/_cluster/health?wait_for_status=yellow&timeout=5s\" | grep -q status && exit 0\n            sleep 2\n          done\n          exit 1\n          '\n        sleep: 1\n      - command: |\n          /bin/sh -c '\n          kubectl -n elasticsearch exec curl-test -- curl -s -k -u {{params.ops_user}}:{{params.ops_password}} -XPUT https://{{params.http_service_name}}.elasticsearch.svc:9200/{{params.seed_index_name}} -H \"Content-Type: application/json\" -d \"{\\\"settings\\\":{\\\"number_of_shards\\\":1,\\\"number_of_replicas\\\":1}}\"\n          kubectl -n elasticsearch exec curl-test -- curl -s -k -u {{params.ops_user}}:{{params.ops_password}} -XPOST https://{{params.http_service_name}}.elasticsearch.svc:9200/{{params.seed_index_name}}/_doc -H \"Content-Type: 