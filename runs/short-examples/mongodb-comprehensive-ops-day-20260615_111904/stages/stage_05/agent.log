{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01NJFWP9g9q3gAhBVHearHwG","type":"tool_result","content":"1\t# mongodb/certificate-rotation\n2\t# MongoDB certificate-rotation task\n3\t\n4\tparams:\n5\t  cluster_prefix:\n6\t    default: mongo-rs\n7\t    description: StatefulSet name / cert CN of the replica set members.\n8\t  replica_set_name:\n9\t    default: rs0\n10\t    description: MongoDB replica set _id used when initiating the set.\n11\t  openssl_pod_name:\n12\t    default: openssl-toolbox\n13\t    description: Helper pod used to generate TLS certificates.\n14\t  tls_ca_secret_name:\n15\t    default: mongodb-tls-ca\n16\t    description: Secret holding the CA certificate and key.\n17\t  tls_cert_secret_name:\n18\t    default: mongodb-tls-cert\n19\t    description: Secret holding the server certificate bundle.\n20\t  old_tls_configmap_name:\n21\t    default: mongodb-tls-old\n22\t    description: ConfigMap recording fingerprints of the pre-rotation certs.\n23\t  old_cert_valid_days:\n24\t    default: 2\n25\t    description: Validity in days of the nearly-expired server certificate.\n26\t\n27\tprompt: |\n28\t  MongoDB is already running with TLS. Its current server certificates are nearing\n29\t  expiry. Rotate the server certificates without downtime, keep the existing CA\n30\t  trust unchanged, and ensure the new server certificates are valid for about one year.\n31\t\n32\t  Notes:\n33\t  - The CA cert and key are stored in the secret {{params.tls_ca_secret_name}}.\n34\t  - The current server cert is stored in {{params.tls_cert_secret_name}}.\n35\t  - The {{params.openssl_pod_name}} pod is available to generate new certificates.\n36\t\n37\tnamespace_contract:\n38\t  required_roles: []\n39\t\n40\tmetrics:\n41\t  - time_to_first_mutation\n42\t\n43\tpreconditionUnits:\n44\t  - name: mongo_env_ready\n45\t    on_probe_fail: skip\n46\t    probe:\n47\t      - command: \"kubectl -n mongodb get pod {{params.cluster_prefix}}-0 2>/dev/null | grep -c Running\"\n48\t        timeout_sec: 10\n49\t    apply:\n50\t      - command: |\n51\t          /bin/sh -c '\n52\t          kubectl delete namespace mongodb --ignore-not-found=true; kubectl wait --for=delete namespace/mongodb --timeout=120s || true\n53\t          '\n54\t        sleep: 2\n55\t      - command: \"kubectl create namespace mongodb\"\n56\t        sleep: 1\n57\t      - command: \"kubectl -n mongodb apply -f cases/mongodb/certificate-rotation/resource/services.yaml\"\n58\t        sleep: 2\n59\t      - command: \"kubectl -n mongodb apply -f cases/mongodb/certificate-rotation/resource/openssl-toolbox.yaml\"\n60\t        sleep: 2\n61\t      - command: \"kubectl -n mongodb wait --for=condition=ready pod {{params.openssl_pod_name}} --timeout=300s\"\n62\t        sleep: 2\n63\t      - command: |\n64\t          set -e\n65\t          TMP_DIR=$(mktemp -d)\n66\t          kubectl -n mongodb exec {{params.openssl_pod_name}} -- /bin/sh -c '\n67\t          set -e\n68\t          mkdir -p /tmp/certs\n69\t          cat > /tmp/certs/openssl.cnf <<EOF\n70\t          distinguished_name=req_distinguished_name\n71\t          req_extensions=v3_req\n72\t          prompt=no\n73\t          [req_distinguished_name]\n74\t          CN={{params.cluster_prefix}}\n75\t          [v3_req]\n76\t          keyUsage=critical,digitalSignature,keyEncipherment\n77\t          extendedKeyUsage=serverAuth,clientAuth\n78\t          subjectAltName=@alt_names\n79\t          [alt_names]\n80\t          DNS.1=localhost\n81\t          DNS.2=mongo\n82\t          DNS.3=mongo.mongodb\n83\t          DNS.4=mongo.mongodb.svc\n84\t          DNS.5=mongo.mongodb.svc.cluster.local\n85\t          DNS.6=mongo-rs-0.mongo.mongodb.svc.cluster.local\n86\t          DNS.7=mongo-rs-1.mongo.mongodb.svc.cluster.local\n87\t          DNS.8=mongo-rs-2.mongo.mongodb.svc.cluster.local\n88\t          EOF\n89\t          openssl genrsa -out /tmp/certs/ca.key 2048\n90\t          openssl req -x509 -new -nodes -key /tmp/certs/ca.key -sha256 -days 3650 -subj \"/CN=mongo-ca\" -out /tmp/certs/ca.crt\n91\t          openssl genrsa -out /tmp/certs/server.key 2048\n92\t          openssl req -new -key /tmp/certs/server.key -out /tmp/certs/server.csr -config /tmp/certs/openssl.cnf\n93\t          openssl x509 -req -in /tmp/certs/server.csr -CA /tmp/certs/ca.crt -CAkey /tmp/certs/ca.key -CAcreateserial -out /tmp/certs/server.crt -days {{params.old_cert_valid_days}} -extensions v3_req -extfile /tmp/certs/openssl.cnf\n94\t          cat /tmp/certs/server.crt /tmp/certs/server.key > /tmp/certs/server.pem\n95\t          '\n96\t          kubectl -n mongodb cp {{params.openssl_pod_name}}:/tmp/certs \"${TMP_DIR}/certs\"\n97\t          kubectl -n mongodb create secret generic {{params.tls_ca_secret_name}} \\\n98\t            --from-file=ca.crt=\"${TMP_DIR}/certs/ca.crt\" \\\n99\t            --from-file=ca.key=\"${TMP_DIR}/certs/ca.key\" \\\n100\t            --dry-run=client -o yaml | kubectl apply -f -\n101\t          kubectl -n mongodb create secret generic {{params.tls_cert_secret_name}} \\\n102\t            --from-file=server.pem=\"${TMP_DIR}/certs/server.pem\" \\\n103\t            --dry-run=client -o yaml | kubectl apply -f -\n104\t          SERVER_FP=$(openssl x509 -noout -fingerprint -sha256 -in \"${TMP_DIR}/certs/server.crt\" | cut -d= -f2)\n105\t          CA_FP=$(openssl x509 -noout -fingerprint -sha256 -in \"${TMP_DIR}/certs/ca.crt\" | cut -d= -f2)\n106\t          kubectl -n mongodb create configmap {{params.old_tls_configmap_name}} \\\n107\t            --from-literal=server_fingerprint_sha256=\"${SERVER_FP}\" \\\n108\t            --from-literal=ca_fingerprint_sha256=\"${CA_FP}\" \\\n109\t            --dry-run=client -o yaml | kubectl apply -f -\n110\t        sleep: 2\n111\t      - command: \"kubectl -n mongodb apply -f cases/mongodb/certificate-rotation/resource/statefulset.yaml\"\n112\t        sleep: 5\n113\t      - command: |\n114\t          for i in $(seq 1 60); do\n115\t            ready=$(kubectl -n mongodb get sts {{params.cluster_prefix}} -o jsonpath='{.status.readyReplicas}' 2>/dev/null)\n116\t            if [ \"${ready:-0}\" -ge 3 ]; then\n117\t              exit 0\n118\t            fi\n119\t            sleep 5\n120\t          done\n121\t          exit 1\n122\t        sleep: 2\n123\t      - command: |\n124\t          kubectl -n mongodb exec mongo-rs-0 -- mongosh --quiet \\\n125\t          \"mongodb://mongo-rs-0.mongo.mongodb.svc.cluster.local:27017/?directConnection=true\" \\\n126\t          --tls --tlsCAFile /etc/mongo-ca/ca.crt \\\n127\t          --eval '\n128\t          rs.initiate({_id:\"{{params.replica_set_name}}\",members:[\n129\t            {_id:0,host:\"mongo-rs-0.mongo.mongodb.svc.cluster.local:27017\"},\n130\t            {_id:1,host:\"mongo-rs-1.mongo.mongodb.svc.cluster.local:27017\"},\n131\t            {_id:2,host:\"mongo-rs-2.mongo.mongodb.svc.cluster.local:27017\"}\n132\t          ]})'\n133\t        sleep: 5\n134\t      - command: |\n135\t          for i in $(seq 1 20); do\n136\t            kubectl -n mongodb exec mongo-rs-0 -- mongosh --quiet \\\n137\t              \"mongodb://mongo-rs-0.mongo.mongodb.svc.cluster.local:27017/?directConnection=true\" \\\n138\t              --tls --tlsCAFile /etc/mongo-ca/ca.crt \\\n139\t              --eval 'db.hello().isWritablePrimary' | grep true && exit 0\n140\t            sleep 3\n141\t          done\n142\t          exit 1\n143\t        sleep: 2\n144\t    verify:\n145\t      - command: \"kubectl -n mongodb get pods 2>/dev/null | grep -c Running\"\n146\t        timeout_sec: 10\n147\t\n148\toracle:\n149\t  verify:\n150\t    commands:\n151\t      - command: \"python3 cases/mongodb/certificate-rotation/oracle/oracle.py\"\n152\t        timeout_sec: 60\n153\t"}]},"parent_tool_use_id":"toolu_013sG6ZhJqQQiaTbK2DvhoA6","session_id":"0656db3c-c9d4-4a0b-8d45-5c2a815a427e","uuid":"f29fe75b-6854-4d4e-8579-c62c9c933804","timestamp":"2026-06-15T11:32:41.508Z","subagent_type":"Explore","task_description":"Find mongodb cert rotation case definition"}
