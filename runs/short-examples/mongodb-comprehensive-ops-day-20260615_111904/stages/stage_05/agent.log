{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01E9Woib7EejgATZNFpajX23","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport argparse\n3\timport base64\n4\timport datetime\n5\timport json\n6\timport os\n7\timport subprocess\n8\timport sys\n9\t\n10\t\n11\tNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"mongodb\")\n12\tCLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"mongo-rs\")\n13\tSERVICE_NAME = os.environ.get(\"BENCH_PARAM_SERVICE_NAME\", \"mongo\")\n14\tOPENSSL_POD = os.environ.get(\"BENCH_PARAM_OPENSSL_POD_NAME\", \"openssl-toolbox\")\n15\tTLS_CA_SECRET = os.environ.get(\"BENCH_PARAM_TLS_CA_SECRET_NAME\", \"mongodb-tls-ca\")\n16\tTLS_CERT_SECRET = os.environ.get(\"BENCH_PARAM_TLS_CERT_SECRET_NAME\", \"mongodb-tls-cert\")\n17\tOLD_CONFIGMAP = os.environ.get(\"BENCH_PARAM_OLD_TLS_CONFIGMAP_NAME\", \"mongodb-tls-old\")\n18\tMIN_VALID_DAYS = int(os.environ.get(\"BENCH_PARAM_TARGET_VALIDITY_MIN_DAYS\", \"300\"))\n19\tMAX_VALID_DAYS = int(os.environ.get(\"BENCH_PARAM_TARGET_VALIDITY_MAX_DAYS\", \"400\"))\n20\tTLS_URI = f\"mongodb://{CLUSTER_PREFIX}-0.{SERVICE_NAME}.{NAMESPACE}.svc.cluster.local:27017/?directConnection=true&serverSelectionTimeoutMS=4000&connectTimeoutMS=4000\"\n21\t\n22\t\n23\tdef run(cmd, input_data=None, text=True):\n24\t    return subprocess.run(\n25\t        cmd,\n26\t        input=input_data,\n27\t        text=text,\n28\t        stdout=subprocess.PIPE,\n29\t        stderr=subprocess.PIPE,\n30\t    )\n31\t\n32\t\n33\tdef fail(prefix, errors):\n34\t    if errors:\n35\t        print(prefix, file=sys.stderr)\n36\t        for err in errors:\n37\t            print(f\"  - {err}\", file=sys.stderr)\n38\t        return 1\n39\t    return 0\n40\t\n41\t\n42\tdef get_configmap_value(name, key, errors):\n43\t    res = run([\n44\t        \"kubectl\", \"-n\", NAMESPACE, \"get\", \"configmap\", name, \"-o\", f\"jsonpath={{.data.{key}}}\"\n45\t    ])\n46\t    if res.returncode != 0:\n47\t        errors.append(f\"Failed to read configmap {name}: {res.stderr.strip() or res.stdout.strip()}\")\n48\t        return None\n49\t    return (res.stdout or \"\").strip()\n50\t\n51\t\n52\tdef get_secret_bytes(secret_name, key, errors):\n53\t    res = run([\n54\t        \"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", secret_name, \"-o\", \"json\"\n55\t    ])\n56\t    if res.returncode != 0:\n57\t        errors.append(f\"Failed to read secret {secret_name}: {res.stderr.strip() or res.stdout.strip()}\")\n58\t        return None\n59\t    try:\n60\t        data = json.loads(res.stdout).get(\"data\", {})\n61\t        val = data.get(key)\n62\t    except Exception:\n63\t        errors.append(f\"Failed to parse secret {secret_name} JSON\")\n64\t        return None\n65\t    if not val:\n66\t        errors.append(f\"Secret {secret_name} missing key {key}\")\n67\t        return None\n68\t    try:\n69\t        return base64.b64decode(val)\n70\t    except Exception:\n71\t        errors.append(f\"Failed to decode secret {secret_name}.{key}\")\n72\t        return None\n73\t\n74\t\n75\tdef openssl_fingerprint_from_pem(pem_bytes, label, errors):\n76\t    res = run(\n77\t        [\n78\t            \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"-i\", OPENSSL_POD, \"--\",\n79\t            \"openssl\", \"x509\", \"-noout\", \"-fingerprint\", \"-sha256\",\n80\t        ],\n81\t        input_data=pem_bytes,\n82\t        text=False,\n83\t    )\n84\t    if res.returncode != 0:\n85\t        errors.append(f\"{label} fingerprint failed: {res.stderr.decode().strip() or res.stdout.decode().strip()}\")\n86\t        return None\n87\t    out = res.stdout.decode().strip()\n88\t    if \"=\" not in out:\n89\t        errors.append(f\"Unable to parse {label} fingerprint output\")\n90\t        return None\n91\t    return out.split(\"=\", 1)[1].strip()\n92\t\n93\t\n94\tdef openssl_not_after_from_pem(pem_bytes, label, errors):\n95\t    res = run(\n96\t        [\n97\t            \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"-i\", OPENSSL_POD, \"--\",\n98\t            \"openssl\", \"x509\", \"-noout\", \"-enddate\",\n99\t        ],\n100\t        input_data=pem_bytes,\n101\t        text=False,\n102\t    )\n103\t    if res.returncode != 0:\n104\t        errors.append(f\"{label} enddate failed: {res.stderr.decode().strip() or res.stdout.decode().strip()}\")\n105\t        return None\n106\t    out = res.stdout.decode().strip()\n107\t    if not out.lower().startswith(\"notafter=\"):\n108\t        errors.append(f\"Unable to parse {label} notAfter output\")\n109\t        return None\n110\t    return out.split(\"=\", 1)[1].strip()\n111\t\n112\t\n113\tdef parse_not_after(not_after, errors):\n114\t    try:\n115\t        return datetime.datetime.strptime(not_after, \"%b %d %H:%M:%S %Y %Z\").replace(tzinfo=datetime.timezone.utc)\n116\t    except Exception:\n117\t        errors.append(f\"Unable to parse notAfter value: {not_after}\")\n118\t        return None\n119\t\n120\t\n121\tdef check_fingerprints():\n122\t    errors = []\n123\t    old_server_fp = get_configmap_value(OLD_CONFIGMAP, \"server_fingerprint_sha256\", errors)\n124\t    old_ca_fp = get_configmap_value(OLD_CONFIGMAP, \"ca_fingerprint_sha256\", errors)\n125\t\n126\t    server_pem = get_secret_bytes(TLS_CERT_SECRET, \"server.pem\", errors)\n127\t    ca_pem = get_secret_bytes(TLS_CA_SECRET, \"ca.crt\", errors)\n128\t\n129\t    if server_pem is None or ca_pem is None:\n130\t        return fail(\"Certificate rotation fingerprint check failed:\", errors)\n131\t\n132\t    cur_server_fp = openssl_fingerprint_from_pem(server_pem, \"server\", errors)\n133\t    cur_ca_fp = openssl_fingerprint_from_pem(ca_pem, \"ca\", errors)\n134\t\n135\t    if old_server_fp and cur_server_fp and old_server_fp == cur_server_fp:\n136\t        errors.append(\"server certificate fingerprint did not change\")\n137\t    if old_ca_fp and cur_ca_fp and old_ca_fp != cur_ca_fp:\n138\t        errors.append(\"CA fingerprint changed; CA trust must remain unchanged\")\n139\t\n140\t    return fail(\"Certificate rotation fingerprint check failed:\", errors)\n141\t\n142\t\n143\tdef check_validity():\n144\t    errors = []\n145\t    server_pem = get_secret_bytes(TLS_CERT_SECRET, \"server.pem\", errors)\n146\t    if server_pem is None:\n147\t        return fail(\"Certificate rotation validity check failed:\", errors)\n148\t\n149\t    not_after = openssl_not_after_from_pem(server_pem, \"server\", errors)\n150\t    if not_after:\n151\t        expires_at = parse_not_after(not_after, errors)\n152\t        if expires_at:\n153\t            now = datetime.datetime.now(datetime.timezone.utc)\n154\t            days_left = (expires_at - now).days\n155\t            if days_left < MIN_VALID_DAYS:\n156\t                errors.append(f\"rotated certificate validity too short: {days_left} days\")\n157\t            if days_left > MAX_VALID_DAYS:\n158\t                errors.append(f\"rotated certificate validity too long: {days_left} days\")\n159\t\n160\t    return fail(\"Certificate rotation validity check failed:\", errors)\n161\t\n162\t\n163\tdef check_tls():\n164\t    errors = []\n165\t\n166\t    tls = run([\n167\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", f\"{CLUSTER_PREFIX}-0\", \"--\", \"mongosh\", \"--quiet\", TLS_URI,\n168\t        \"--tls\", \"--tlsAllowInvalidHostnames\", \"--tlsCAFile\", \"/etc/mongo-ca/ca.crt\", \"--eval\", \"db.hello().ok\",\n169\t    ])\n170\t    if tls.returncode != 0:\n171\t        errors.append(f\"TLS connection failed: {tls.stderr.strip() or tls.stdout.strip()}\")\n172\t\n173\t    plain = run([\n174\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", f\"{CLUSTER_PREFIX}-0\", \"--\", \"mongosh\", \"--quiet\", TLS_URI,\n175\t        \"--eval\", \"db.hello().ok\",\n176\t    ])\n177\t    if plain.returncode == 0:\n178\t        errors.append(\"insecure connection unexpectedly succeeded\")\n179\t\n180\t    return fail(\"Certificate rotation TLS check failed:\", errors)\n181\t\n182\t\n183\tdef main():\n184\t    parser = argparse.ArgumentParser()\n185\t    parser.add_argument(\"--check\", default=\"all\", choices=[\"all\", \"fingerprints\", \"validity\", \"tls\"])\n186\t    args = parser.parse_args()\n187\t\n188\t    if args.check == \"fingerprints\":\n189\t        return check_fingerprints()\n190\t    if args.check == \"validity\":\n191\t        return check_validity()\n192\t    if args.check == \"tls\":\n193\t        return check_tls()\n194\t\n195\t    for fn in (check_fingerprints, check_validity, check_tls):\n196\t        rc = fn()\n197\t        if rc != 0:\n198\t            return rc\n199\t    print(\"Certificate rotation verified\")\n200\t    return 0\n201\t\n202\t\n203\tif __name__ == \"__main__\":\n204\t    sys.exit(main())\n205\t"}]},"parent_tool_use_id":"toolu_013sG6ZhJqQQiaTbK2DvhoA6","session_id":"0656db3c-c9d4-4a0b-8d45-5c2a815a427e","uuid":"0b2ff841-ef62-4f76-bed0-4fbdb1d8e428","timestamp":"2026-06-15T11:32:42.204Z","subagent_type":"Explore","task_description":"Find mongodb cert rotation case definition"}
