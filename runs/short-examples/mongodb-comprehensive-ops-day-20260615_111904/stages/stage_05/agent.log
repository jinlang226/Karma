te-rotation/test.yaml","content":"# mongodb/certificate-rotation\n# MongoDB certificate-rotation task\n\nparams:\n  cluster_prefix:\n    default: mongo-rs\n    description: StatefulSet name / cert CN of the replica set members.\n  replica_set_name:\n    default: rs0\n    description: MongoDB replica set _id used when initiating the set.\n  openssl_pod_name:\n    default: openssl-toolbox\n    description: Helper pod used to generate TLS certificates.\n  tls_ca_secret_name:\n    default: mongodb-tls-ca\n    description: Secret holding the CA certificate and key.\n  tls_cert_secret_name:\n    default: mongodb-tls-cert\n    description: Secret holding the server certificate bundle.\n  old_tls_configmap_name:\n    default: mongodb-tls-old\n    description: ConfigMap recording fingerprints of the pre-rotation certs.\n  old_cert_valid_days:\n    default: 2\n    description: Validity in days of the nearly-expired server certificate.\n\nprompt: |\n  MongoDB is already running with TLS. Its current server certificates are nearing\n  expiry. Rotate the server certificates without downtime, keep the existing CA\n  trust unchanged, and ensure the new server certificates are valid for about one year.\n\n  Notes:\n  - The CA cert and key are stored in the secret {{params.tls_ca_secret_name}}.\n  - The current server cert is stored in {{params.tls_cert_secret_name}}.\n  - The {{params.openssl_pod_name}} pod is available to generate new certificates.\n\nnamespace_contract:\n  required_roles: []\n\nmetrics:\n  - time_to_first_mutation\n\npreconditionUnits:\n  - name: mongo_env_ready\n    on_probe_fail: skip\n    probe:\n      - command: \"kubectl -n mongodb get pod {{params.cluster_prefix}}-0 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n    apply:\n      - command: |\n          /bin/sh -c '\n          kubectl delete namespace mongodb --ignore-not-found=true; kubectl wait --for=delete namespace/mongodb --timeout=120s || true\n          '\n        sleep: 2\n      - command: \"kubectl create namespace mongodb\"\n        sleep: 1\n      - command: \"kubectl -n mongodb apply -f cases/mongodb/certificate-rotation/resource/services.yaml\"\n        sleep: 2\n      - command: \"kubectl -n mongodb apply -f cases/mongodb/certificate-rotation/resource/openssl-toolbox.yaml\"\n        sleep: 2\n      - command: \"kubectl -n mongodb wait --for=condition=ready pod {{params.openssl_pod_name}} --timeout=300s\"\n        sleep: 2\n      - command: |\n          set -e\n          TMP_DIR=$(mktemp -d)\n          kubectl -n mongodb exec {{params.openssl_pod_name}} -- /bin/sh -c '\n          set -e\n          mkdir -p /tmp/certs\n          cat > /tmp/certs/openssl.cnf <<EOF\n          distinguished_name=req_distinguished_name\n          req_extensions=v3_req\n          prompt=no\n          [req_distinguished_name]\n          CN={{params.cluster_prefix}}\n          [v3_req]\n          keyUsage=critical,digitalSignature,keyEncipherment\n          extendedKeyUsage=serverAuth,clientAuth\n          subjectAltName=@alt_names\n          [alt_names]\n          DNS.1=localhost\n          DNS.2=mongo\n          DNS.3=mongo.mongodb\n          DNS.4=mongo.mongodb.svc\n          DNS.5=mongo.mongodb.svc.cluster.local\n          DNS.6=mongo-rs-0.mongo.mongodb.svc.cluster.local\n          DNS.7=mongo-rs-1.mongo.mongodb.svc.cluster.local\n          DNS.8=mongo-rs-2.mongo.mongodb.svc.cluster.local\n          EOF\n          openssl genrsa -out /tmp/certs/ca.key 2048\n          openssl req -x509 -new -nodes -key /tmp/certs/ca.key -sha256 -days 3650 -subj \"/CN=mongo-ca\" -out /tmp/certs/ca.crt\n          openssl genrsa -out /tmp/certs/server.key 2048\n          openssl req -new -key /tmp/certs/server.key -out /tmp/certs/server.csr -config /tmp/certs/openssl.cnf\n          openssl x509 -req -in /tmp/certs/server.csr -CA /tmp/certs/ca.crt -CAkey /tmp/certs/ca.key -CAcreateserial -out /tmp/certs/server.crt -days {{params.old_cert_valid_days}} -extensions v3_req -extfile /tmp/certs/openssl.cnf\n          cat /tmp/certs/server.crt /tmp/certs/server.key > /tmp/certs/server.pem\n          '\n          kubectl -n mongodb cp {{params.openssl_pod_name}}:/tmp/certs \"${TMP_DIR}/certs\"\n          kubectl -n mongodb create secret generic {{params.tls_ca_secret_name}} \\\n            --from-file=ca.crt=\"${TMP_DIR}/certs/ca.crt\" \\\n            --from-file=ca.key=\"${TMP_DIR}/certs/ca.key\" \\\n            --dry-run=client -o yaml | kubectl apply -f -\n          kubectl -n mongodb create secret generic {{params.tls_cert_secret_name}} \\\n            --from-file=server.pem=\"${TMP_DIR}/certs/server.pem\" \\\n            --dry-run=client -o yaml | kubectl apply -f -\n          SERVER_FP=$(openssl x509 -noout -fingerprint -sha256 -in \"${TMP_DIR}/certs/server.crt\" | cut -d= -f2)\n          CA_FP=$(openssl x509 -noout -fingerprint -sha256 -in \"${TMP_DIR}/certs/ca.crt\" | cut -d= -f2)\n          kubectl -n mongodb create configmap {{params.old_tls_configmap_name}} \\\n            --from-literal=server_fingerprint_sha256=\"${SERVER_FP}\" \\\n            --from-literal=ca_fingerprint_sha256=\"${CA_FP}\" \\\n            --dry-run=client -o yaml | kubectl apply -f -\n        sleep: 2\n      - command: \"kubectl -n mongodb apply -f cases/mongodb/certificate-rotation/resource/statefulset.yaml\"\n        sleep: 5\n      - command: |\n          for i in $(seq 1 60); do\n            ready=$(kubectl -n mongodb get sts {{params.cluster_prefix}} -o jsonpath='{.status.readyReplicas}' 2>/dev/null)\n            if [ \"${ready:-0}\" -ge 3 ]; then\n              exit 0\n            fi\n            sleep 5\n          done\n          exit 1\n        sleep: 2\n      - command: |\n          kubectl -n mongodb exec mongo-rs-0 -- mongosh --quiet \\\n          \"mongodb://mongo-rs-0.mongo.mongodb.svc.cluster.local:27017/?directConnection=true\" \\\n          --tls --tlsCAFile /etc/mongo-ca/ca.crt \\\n          --eval '\n          rs.initiate({_id:\"{{params.replica_set_name}}\",members:[\n            {_id:0,host:\"mongo-rs-0.mongo.mongodb.svc.cluster.local:27017\"},\n            {_id:1,host:\"mongo-rs-1.mongo.mongodb.svc.cluster.local:27017\"},\n            {_id:2,host:\"mongo-rs-2.mongo.mongodb.svc.cluster.local:27017\"}\n          ]})'\n        sleep: 5\n      - command: |\n          for i in $(seq 1 20); do\n            kubectl -n mongodb exec mongo-rs-0 -- mongosh --quiet \\\n              \"mongodb://mongo-rs-0.mongo.mongodb.svc.cluster.local:27017/?directConnection=true\" \\\n              --tls --tlsCAFile /etc/mongo-ca/ca.crt \\\n              --eval 'db.hello().isWritablePrimary' | grep true && exit 0\n            sleep 3\n          done\n          exit 1\n        sleep: 2\n    verify:\n      - command: \"kubectl -n mongodb get pods 2>/dev/null | grep -c Running\"\n        timeout_sec: 10\n\noracle:\n  verify:\n    commands:\n      - command: \"python3 cases/mongodb/certificate-rotation/oracle/oracle.py\"\n        timeout_sec: 60\n","numLines":153,"startLine":1,"totalLines":153}}}
