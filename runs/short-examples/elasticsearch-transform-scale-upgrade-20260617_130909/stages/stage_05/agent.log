{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Uhmvvk21eSDVf6VjLg6PHD","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport json\n3\timport os\n4\timport re\n5\timport subprocess\n6\timport sys\n7\t\n8\t\n9\tNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"elasticsearch\")\n10\tSERVICE = os.environ.get(\"BENCH_PARAM_HTTP_SERVICE_NAME\", \"es-http\")\n11\tTARGET_VERSION = os.environ.get(\"BENCH_PARAM_TO_VERSION\", \"8.11.1\")\n12\tSEED_CONFIGMAP = os.environ.get(\"BENCH_PARAM_SEED_CONFIGMAP_NAME\", \"es-seed\")\n13\t# Hint for the Elasticsearch StatefulSet name. Used as an override when it names\n14\t# a StatefulSet that actually exists; otherwise the StatefulSet (and its real\n15\t# pod selector label) are detected live from the cluster. The env PERSISTS\n16\t# across stages, so a workflow's inherited ES cluster may carry a different\n17\t# StatefulSet name/label than this case's standalone default of 'es-cluster'.\n18\tCLUSTER_PREFIX_HINT = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"es-cluster\")\n19\t# ES 8.x runs with security enabled, so the HTTP API requires authenticating as\n20\t# the elastic superuser. When this case inherits a secured cluster from an\n21\t# earlier workflow stage, read its password from the secret that stage created\n22\t# so the oracle's queries aren't rejected with 401. Absent secret -> None -> no\n23\t# -u, so a standalone unsecured cluster still works.\n24\tPASSWORD_SECRET = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_SECRET_NAME\", \"elastic-password\")\n25\tPASSWORD_KEY = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_KEY\", \"password\")\n26\tDEFAULT_SCHEME = \"http\"\n27\t_SCHEME = None\n28\t\n29\t\n30\tdef run(cmd):\n31\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n32\t\n33\t\n34\tdef _elastic_password():\n35\t    \"\"\"Fetch the elastic-user password from its secret (base64-decoded), or None.\"\"\"\n36\t    import base64\n37\t    r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", PASSWORD_SECRET,\n38\t             \"-o\", \"jsonpath={.data.\" + PASSWORD_KEY + \"}\"])\n39\t    if r.returncode != 0 or not r.stdout.strip():\n40\t        return None\n41\t    try:\n42\t        return base64.b64decode(r.stdout.strip()).decode()\n43\t    except Exception:\n44\t        return None\n45\t\n46\t\n47\tELASTIC_PASSWORD = None  # set in main() once kubectl is reachable\n48\t\n49\t\n50\t_ES_STS = None\n51\t\n52\t\n53\tdef _list_es_statefulsets():\n54\t    \"\"\"Return [(name, app_label_value, creationTimestamp)] for the namespace's\n55\t    StatefulSets whose pod template runs an Elasticsearch image.\"\"\"\n56\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n57\t    if res.returncode != 0:\n58\t        return []\n59\t    try:\n60\t        items = json.loads(res.stdout).get(\"items\", [])\n61\t    except (json.JSONDecodeError, AttributeError):\n62\t        return []\n63\t    out = []\n64\t    for sts in items:\n65\t        meta = sts.get(\"metadata\", {})\n66\t        spec = sts.get(\"spec\", {})\n67\t        containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n68\t        if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n69\t            continue\n70\t        app = (spec.get(\"selector\", {}).get(\"matchLabels\", {}) or {}).get(\"app\")\n71\t        out.append((meta.get(\"name\"), app, meta.get(\"creationTimestamp\", \"\")))\n72\t    return out\n73\t\n74\t\n75\tdef resolve_es_sts():\n76\t    \"\"\"Resolve (sts_name, app_label_selector) for the live ES StatefulSet.\n77\t\n78\t    Priority: the BENCH_PARAM_CLUSTER_PREFIX hint when it names a real\n79\t    StatefulSet (explicit override wins) -> the single ES StatefulSet detected\n80\t    live (oldest first if several). Workflow-agnostic: adapts to an inherited\n81\t    cluster whose StatefulSet name/label differ from the standalone default.\n82\t    \"\"\"\n83\t    global _ES_STS\n84\t    if _ES_STS is not None:\n85\t        return _ES_STS\n86\t    es_sets = _list_es_statefulsets()\n87\t    by_name = {n: (n, a) for (n, a, _c) in es_sets if n}\n88\t    if CLUSTER_PREFIX_HINT in by_name:\n89\t        name, app = by_name[CLUSTER_PREFIX_HINT]\n90\t        _ES_STS = (name, f\"app={app}\" if app else f\"app={name}\")\n91\t        return _ES_STS\n92\t    if es_sets:\n93\t        candidates = [s for s in es_sets if s[0]]\n94\t        candidates.sort(key=lambda s: (s[2] or \"\"))\n95\t        name, app, _c = candidates[0]\n96\t        _ES_STS = (name, f\"app={app}\" if app else f\"app={name}\")\n97\t        return _ES_STS\n98\t    _ES_STS = (CLUSTER_PREFIX_HINT, f\"app={CLUSTER_PREFIX_HINT}\")\n99\t    return _ES_STS\n100\t\n101\t\n102\tSTS_NAME = resolve_es_sts()[0]\n103\tAPP_LABEL = resolve_es_sts()[1]\n104\t\n105\t\n106\tdef _list_es_statefulset_replicas():\n107\t    \"\"\"Return {sts_name: spec.replicas} for the namespace's Elasticsearch\n108\t    StatefulSets (those whose pod template runs an Elasticsearch image).\"\"\"\n109\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n110\t    if res.returncode != 0:\n111\t        return {}\n112\t    try:\n113\t        items = json.loads(res.stdout).get(\"items\", [])\n114\t    except (json.JSONDecodeError, AttributeError):\n115\t        return {}\n116\t    out = {}\n117\t    for sts in items:\n118\t        spec = sts.get(\"spec\", {})\n119\t        containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n120\t        if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n121\t            continue\n122\t        name = sts.get(\"metadata\", {}).get(\"name\")\n123\t        replicas = spec.get(\"replicas\")\n124\t        if name and isinstance(replicas, int):\n125\t            out[name] = replicas\n126\t    return out\n127\t\n128\t\n129\tdef _sts_name_for_node(node_name):\n130\t    \"\"\"Map a live ES node name to its backing StatefulSet name.\n131\t\n132\t    An ES node name equals its pod name, which for a StatefulSet pod is\n133\t    ``<statefulset-name>-<ordinal>`` (e.g. ``es-cluster-0`` -> ``es-cluster``,\n134\t    ``es-data-1`` -> ``es-data``). Strip the trailing ``-<digits>`` ordinal.\n135\t    Returns the node name unchanged if it carries no ordinal suffix.\n136\t    \"\"\"\n137\t    if not node_name:\n138\t        return node_name\n139\t    return re.sub(r\"-\\d+$\", \"\", node_name)\n140\t\n141\t\n142\tdef _live_sts_names(node_names):\n143\t    \"\"\"Set of StatefulSet names actually backing the live cluster nodes.\n144\t\n145\t    Derived by stripping each live node name's ordinal. This excludes\n146\t    accumulated/stale/other ES StatefulSets in the (persisted) namespace that\n147\t    back no node in the queried cluster.\n148\t    \"\"\"\n149\t    return {_sts_name_for_node(n) for n in node_names if n}\n150\t\n151\t\n152\tdef _resolve_expected_nodes(node_names, default=3):\n153\t    \"\"\"Expected node count to enforce, derived from the LIVE cluster.\n154\t\n155\t    The expected total is the DESIRED topology of ONLY the StatefulSets that\n156\t    actually back the live cluster (the nodes returned by ``_cat/nodes``): the\n157\t    sum of spec.replicas over just those StatefulSets. The namespace PERSISTS\n158\t    across workflow stages and accumulates multiple ES clusters, so summing\n159\t    replicas across *every* ES StatefulSet overcounts versus the single cluster\n160\t    the oracle queries. Restricting to the live cluster's StatefulSets fixes that.\n161\t\n162\t    Using DESIRED spec.replicas (not the live count) keeps the check strict: a\n163\t    node that FAILED to rejoin after the restart leaves its StatefulSet \"live\"\n164\t    (siblings are up) but absent from ``_cat/nodes``, so EXPECTED stays above the\n165\t    actual count -- no masking. The LIVE cluster is derived FIRST; the param is a\n166\t    FALLBACK used only when no live StatefulSets resolve (e.g. _cat/nodes empty).\n167\t    \"\"\"\n168\t    # Derive from the LIVE cluster FIRST (workflow-agnostic + composition-aware):\n169\t    # sum spec.replicas over the active ES StatefulSets -- the base cluster PLUS\n170\t    # any nodeset a PRIOR stage added to the same cluster (e.g. an inherited\n171\t    # transform nodeset). A static EXPECTED_NODES param encodes a standalone\n172\t    # baseline that wrongly ignores such inherited nodesets, so it is demoted to a\n173\t    # FALLBACK below, used only when the live cluster cannot be resolved.\n174\t    # Robust count: sum spec.replicas over ES StatefulSets that are actually\n175\t    # present (status.replicas > 0). Counts the base cluster + any scaled-up\n176\t    # nodeset WITHOUT the fragile node.name -> StatefulSet string mapping (which\n177\t    # breaks when a nodeset's node.name differs from its pod name). A torn-down\n178\t    # prior cluster's StatefulSet has readyReplicas 0 and is excluded. Still\n179\t    # strict: a node that failed to join leaves its STS ready>0 but short, so the\n180\t    # spec-replica sum exceeds the live node count and the check still fails.\n181\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n182\t    if res.returncode == 0:\n183\t        try:\n184\t            items = json.loads(res.stdout).get(\"items\", [])\n185\t        except Exception:\n186\t            items = []\n187\t        desired = 0\n188\t        for sts in items:\n189\t            spec = sts.get(\"spec\", {}) or {}\n190\t            containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", []) or []\n191\t            if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n192\t                continue\n193\t            replicas = spec.get(\"replicas\")\n194\t            # Use status.replicas (pods that EXIST), not readyReplicas: a\n195\t            # scaled-up nodeset whose pods joined the cluster but lack a passing\n196\t            # STS readiness probe has readyReplicas 0 yet is genuinely live.\n197\t            # Count an ES StatefulSet's DESIRED replicas when it is an active part\n198\t            # of the cluster: spec.replicas > 0 and not being torn down. Gating on\n199\t            # status.replicas undercounts a freshly scaled-up nodeset whose status\n200\t            # lags -- its pods have joined the cluster but status.replicas is still\n201\t            # 0 -- which wrongly made EXPECTED < the live node count.\n202\t            being_deleted = (sts.get(\"metadata\", {}) or {}).get(\"deletionTimestamp\") is not None\n203\t            if isinstance(replicas, int) and replicas > 0 and not being_deleted:\n204\t                desired += replicas\n205\t        if desired > 0:\n206\t            return desired\n207\t\n208\t    # Fallbacks (live cluster unresolvable): explicit param, then the default.\n209\t    for key in (\"BENCH_PARAM_EXPECTED_NODES\", \"BENCH_PARAM_EXPECTED_NODE_COUNT\"):\n210\t        val = os.environ.get(key)\n211\t        if val is not None and str(val).strip():\n212\t            try:\n213\t                return int(val)\n214\t            except ValueError:\n215\t                pass\n216\t    return default\n217\t\n218\t\n219\tdef _probe_scheme(scheme):\n220\t    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\"\"\"\n221\t    result = run([\n222\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\", \"/bin/sh\", \"-c\",\n223\t        f\"curl -s -S -k -o /dev/null -w '%{{http_code}}' --max-time 5 {scheme}://{SERVICE}:9200/\",\n224\t    ])\n225\t    code = (result.stdout or \"\").strip().strip(\"'\")\n226\t    return result.returncode == 0 and code.isdigit() and code != \"000\"\n227\t\n228\t\n229\tdef detect_scheme():\n230\t    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n231\t    global _SCHEME\n232\t    if _SCHEME is not None:\n233\t        return _SCHEME\n234\t    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n235\t        if _probe_scheme(scheme):\n236\t            _SCHEME = scheme\n237\t            return _SCHEME\n238\t    _SCHEME = DEFAULT_SCHEME\n239\t    return _SCHEME\n240\t\n241\t\n242\tdef curl(path, errors):\n243\t    scheme = detect_scheme()\n244\t    auth = \"\"\n245\t    if ELASTIC_PASSWORD:\n246\t        import shlex\n247\t        auth = f\"-u {shlex.quote('elastic:' + ELASTIC_PASSWORD)} \"\n248\t    cmd = [\n249\t        \"kubectl\",\n250\t        \"-n\",\n251\t        NAMESPACE,\n252\t        \"exec\",\n253\t        \"curl-test\",\n254\t        \"--\",\n255\t        \"/bin/sh\",\n256\t        \"-c\",\n257\t        # The client deadline (--max-time 20) must exceed any server-side\n258\t        # ``wait_for`` in `path`, otherwise curl aborts (exit 28) before ES can\n259\t        # answer. The retry loop in main() does the real waiting, so each call's\n260\t        # server wait stays short (10s).\n261\t        f\"curl -s -S -k {auth}--max-time 20 {scheme}://{SERVICE}:9200{path}\",\n262\t    ]\n263\t    result = run(cmd)\n264\t    if result.returncode != 0:\n265\t        stderr = result.stderr.strip()\n266\t        stdout = result.stdout.strip()\n267\t        detail = stderr or stdout or f\"command terminated with exit code {result.returncode}\"\n268\t        errors.append(f\"Failed to query {path}: {detail}\")\n269\t        return None\n270\t    output = result.stdout.strip()\n271\t    if not output:\n272\t        errors.append(f\"Empty response for {path}\")\n273\t        return None\n274\t    try:\n275\t        return json.loads(output)\n276\t    except json.JSONDecodeError:\n277\t        errors.append(f\"Failed to parse JSON from {path}\")\n278\t        return None\n279\t\n280\t\n281\tdef evaluate():\n282\t    \"\"\"Run one full snapshot of the upgrade checks; return the list of errors.\"\"\"\n283\t    errors = []\n284\t\n285\t    seed_result = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"configmap\", SEED_CONFIGMAP, \"-o\", \"json\"])\n286\t    if seed_result.returncode != 0:\n287\t        errors.append(f\"Failed to read {SEED_CONFIGMAP} ConfigMap: {seed_result.stderr.strip()}\")\n288\t        index = None\n289\t        expected = None\n290\t    else:\n291\t        try:\n292\t            seed = json.loads(seed_result.stdout)\n293\t        except json.JSONDecodeError:\n294\t            errors.append(f\"Failed to parse {SEED_CONFIGMAP} ConfigMap JSON\")\n295\t            seed = {}\n296\t        index = seed.get(\"data\", {}).get(\"index\")\n297\t        expected = seed.get(\"data\", {}).get(\"expected_count\")\n298\t\n299\t    root = curl(\"/\", errors)\n300\t    if isinstance(root, dict):\n301\t        version = root.get(\"version\", {}).get(\"number\")\n302\t        if version != TARGET_VERSION:\n303\t            errors.append(f\"Expected version {TARGET_VERSION}, got {version}\")\n304\t    else:\n305\t        errors.append(\"Failed to read Elasticsearch root version\")\n306\t\n307\t    # Resolve the live cluster's node list FIRST: the expected node count is\n308\t    # derived from only the StatefulSets that actually back these live nodes\n309\t    # (the persisted namespace accumulates several ES clusters across stages, so\n310\t    # summing every ES StatefulSet's replicas overcounts the queried cluster).\n311\t    nodes = curl(\"/_cat/nodes?format=json\", errors)\n312\t    node_names = []\n313\t    if isinstance(nodes, list):\n314\t        node_names = [n.get(\"name\") for n in nodes if n.get(\"name\")]\n315\t    expected_nodes = _resolve_expected_nodes(node_names, default=3)\n316\t\n317\t    health = curl(\n318\t        f\"/_cluster/health?wait_for_status=yellow&wait_for_nodes={expected_nodes}&timeout=10s\",\n319\t        errors,\n320\t    )\n321\t    if isinstance(health, dict):\n322\t        status = health.get(\"status\")\n323\t        if status not in {\"yellow\", \"green\"}:\n324\t            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n325\t        if health.get(\"number_of_nodes\") != expected_nodes:\n326\t            errors.append(f\"Expected {expected_nodes} nodes, got {health.get('number_of_nodes')}\")\n327\t    else:\n328\t        errors.append(\"Failed to read cluster health\")\n329\t\n330\t    if isinstance(nodes, list) and len(node_names) != expected_nodes:\n331\t        errors.append(f\"Expected {expected_nodes} nodes in _cat/nodes, got {len(node_names)}\")\n332\t\n333\t    if index and expected:\n334\t        count = curl(f\"/{index}/_count\", errors)\n335\t        if isinstance(count, dict):\n336\t            actual = count.get(\"count\")\n337\t            try:\n338\t                expected_val = int(expected)\n339\t            except ValueError:\n340\t                errors.append(f\"Invalid expected_count value: {expected}\")\n341\t            else:\n342\t                if actual != expected_val:\n343\t                    errors.append(f\"Expected {expected_val} docs in {index}, got {actual}\")\n344\t\n345\t    sts_result = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", STS_NAME, \"-o\", \"json\"])\n346\t    if sts_result.returncode == 0:\n347\t        try:\n348\t            sts = json.loads(sts_result.stdout)\n349\t        except json.JSONDecodeError:\n350\t            sts = {}\n351\t        containers = sts.get(\"spec\", {}).get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n352\t        if containers:\n353\t            image = containers[0].get(\"image\")\n354\t            if image and TARGET_VERSION not in image:\n355\t                errors.append(f\"StatefulSet image not upgraded: {image}\")\n356\t    else:\n357\t        errors.append(f\"Failed to read StatefulSet: {sts_result.stderr.strip()}\")\n358\t\n359\t    settings = curl(\"/_cluster/settings\", errors)\n360\t    if isinstance(settings, dict):\n361\t        for scope in (\"persistent\", \"transient\"):\n362\t            allocation = settings.get(scope, {}).get(\"cluster\", {}).get(\"routing\", {}).get(\"allocation\", {})\n363\t            if allocation.get(\"enable\") == \"none\":\n364\t                errors.append(\"Shard allocation still disabled\")\n365\t                break\n366\t\n367\t    return errors\n368\t\n369\t\n370\tdef main():\n371\t    global ELASTIC_PASSWORD\n372\t    ELASTIC_PASSWORD = _elastic_password()\n373\t\n374\t    # A multi-node ES cluster can flap at the edge of readiness under load: a\n375\t    # node briefly fails its HTTP readiness probe / drops from the cluster during\n376\t    # GC or shard recovery even though it is stably green. A single snapshot can\n377\t    # catch that transient and report a false node-count miss. So verify the\n378\t    # STABLE converged state: re-evaluate for up to ~75s and pass on the first\n379\t    # clean snapshot. This does not loosen the version/N-node/green/doc-count\n380\t    # requirements -- a genuinely degraded cluster fails every attempt.\n381\t    import time\n382\t    deadline = time.monotonic() + 75\n383\t    errors = evaluate()\n384\t    while errors and time.monotonic() < deadline:\n385\t        time.sleep(8)\n386\t        errors = evaluate()\n387\t\n388\t    if errors:\n389\t        print(\"Full restart upgrade verification failed:\", file=sys.stderr)\n390\t        for err in errors:\n391\t            print(f\"  - {err}\", file=sys.stderr)\n392\t        return 1\n393\t\n394\t    print(\"Full restart upgrade (HA) verified\")\n395\t    return 0\n396\t\n397\t\n398\tif __name__ == \"__main__\":\n399\t    sys.exit(main())\n400\t"}]},"parent_tool_use_id":null,"session_id":"b84f9a17-808f-4bbc-883e-f249de9070d1","uuid":"e70e55f0-e0e7-438c-b919-30eca0d11a78","timestamp":"2026-06-17T14:19:22.712Z","tool_use_result":{"type":"text","file":{"filePath":"/mydata/karma/cases/elasticsearch/full-restart-upgrade-ha/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport json\nimport os\nimport re\nimport subprocess\nimport sys\n\n\nNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"elasticsearch\")\nSERVICE = os.environ.get(\"BENCH_PARAM_HTTP_SERVICE_NAME\", \"es-http\")\nTARGET_VERSION = os.environ.get(\"BENCH_PARAM_TO_VERSION\", \"8.11.1\")\nSEED_CONFIGMAP = os.environ.get(\"BENCH_PARAM_SEED_CONFIGMAP_NAME\", \"es-seed\")\n# Hint for the Elasticsearch StatefulSet name. Used as an override when it names\n# a StatefulSet that actually exists; otherwise the StatefulSet (and its real\n# pod selector label) are detected live from the cluster. The env PERSISTS\n# across stages, so a workflow's inherited ES cluster may carry a different\n# StatefulSet name/label than this case's standalone default of 'es-cluster'.\nCLUSTER_PREFIX_HINT = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"es-cluster\")\n# ES 8.x runs with security enabled, so the HTTP API requires authenticating as\n# the elastic superuser. When this case inherits a secured cluster from an\n# earlier workflow stage, read its password from the secret that stage created\n# so the oracle's queries aren't rejected with 401. Absent secret -> None -> no\n# -u, so a standalone unsecured cluster still works.\nPASSWORD_SECRET = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_SECRET_NAME\", \"elastic-password\")\nPASSWORD_KEY = os.environ.get(\"BENCH_PARAM_ELASTIC_PASSWORD_KEY\", \"password\")\nDEFAULT_SCHEME = \"http\"\n_SCHEME = None\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef _elastic_password():\n    \"\"\"Fetch the elastic-user password from its secret (base64-decoded), or None.\"\"\"\n    import base64\n    r = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"secret\", PASSWORD_SECRET,\n             \"-o\", \"jsonpath={.data.\" + PASSWORD_KEY + \"}\"])\n    if r.returncode != 0 or not r.stdout.strip():\n        return None\n    try:\n        return base64.b64decode(r.stdout.strip()).decode()\n    except Exception:\n        return None\n\n\nELASTIC_PASSWORD = None  # set in main() once kubectl is reachable\n\n\n_ES_STS = None\n\n\ndef _list_es_statefulsets():\n    \"\"\"Return [(name, app_label_value, creationTimestamp)] for the namespace's\n    StatefulSets whose pod template runs an Elasticsearch image.\"\"\"\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n    if res.returncode != 0:\n        return []\n    try:\n        items = json.loads(res.stdout).get(\"items\", [])\n    except (json.JSONDecodeError, AttributeError):\n        return []\n    out = []\n    for sts in items:\n        meta = sts.get(\"metadata\", {})\n        spec = sts.get(\"spec\", {})\n        containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n        if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n            continue\n        app = (spec.get(\"selector\", {}).get(\"matchLabels\", {}) or {}).get(\"app\")\n        out.append((meta.get(\"name\"), app, meta.get(\"creationTimestamp\", \"\")))\n    return out\n\n\ndef resolve_es_sts():\n    \"\"\"Resolve (sts_name, app_label_selector) for the live ES StatefulSet.\n\n    Priority: the BENCH_PARAM_CLUSTER_PREFIX hint when it names a real\n    StatefulSet (explicit override wins) -> the single ES StatefulSet detected\n    live (oldest first if several). Workflow-agnostic: adapts to an inherited\n    cluster whose StatefulSet name/label differ from the standalone default.\n    \"\"\"\n    global _ES_STS\n    if _ES_STS is not None:\n        return _ES_STS\n    es_sets = _list_es_statefulsets()\n    by_name = {n: (n, a) for (n, a, _c) in es_sets if n}\n    if CLUSTER_PREFIX_HINT in by_name:\n        name, app = by_name[CLUSTER_PREFIX_HINT]\n        _ES_STS = (name, f\"app={app}\" if app else f\"app={name}\")\n        return _ES_STS\n    if es_sets:\n        candidates = [s for s in es_sets if s[0]]\n        candidates.sort(key=lambda s: (s[2] or \"\"))\n        name, app, _c = candidates[0]\n        _ES_STS = (name, f\"app={app}\" if app else f\"app={name}\")\n        return _ES_STS\n    _ES_STS = (CLUSTER_PREFIX_HINT, f\"app={CLUSTER_PREFIX_HINT}\")\n    return _ES_STS\n\n\nSTS_NAME = resolve_es_sts()[0]\nAPP_LABEL = resolve_es_sts()[1]\n\n\ndef _list_es_statefulset_replicas():\n    \"\"\"Return {sts_name: spec.replicas} for the namespace's Elasticsearch\n    StatefulSets (those whose pod template runs an Elasticsearch image).\"\"\"\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n    if res.returncode != 0:\n        return {}\n    try:\n        items = json.loads(res.stdout).get(\"items\", [])\n    except (json.JSONDecodeError, AttributeError):\n        return {}\n    out = {}\n    for sts in items:\n        spec = sts.get(\"spec\", {})\n        containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n        if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n            continue\n        name = sts.get(\"metadata\", {}).get(\"name\")\n        replicas = spec.get(\"replicas\")\n        if name and isinstance(replicas, int):\n            out[name] = replicas\n    return out\n\n\ndef _sts_name_for_node(node_name):\n    \"\"\"Map a live ES node name to its backing StatefulSet name.\n\n    An ES node name equals its pod name, which for a StatefulSet pod is\n    ``<statefulset-name>-<ordinal>`` (e.g. ``es-cluster-0`` -> ``es-cluster``,\n    ``es-data-1`` -> ``es-data``). Strip the trailing ``-<digits>`` ordinal.\n    Returns the node name unchanged if it carries no ordinal suffix.\n    \"\"\"\n    if not node_name:\n        return node_name\n    return re.sub(r\"-\\d+$\", \"\", node_name)\n\n\ndef _live_sts_names(node_names):\n    \"\"\"Set of StatefulSet names actually backing the live cluster nodes.\n\n    Derived by stripping each live node name's ordinal. This excludes\n    accumulated/stale/other ES StatefulSets in the (persisted) namespace that\n    back no node in the queried cluster.\n    \"\"\"\n    return {_sts_name_for_node(n) for n in node_names if n}\n\n\ndef _resolve_expected_nodes(node_names, default=3):\n    \"\"\"Expected node count to enforce, derived from the LIVE cluster.\n\n    The expected total is the DESIRED topology of ONLY the StatefulSets that\n    actually back the live cluster (the nodes returned by ``_cat/nodes``): the\n    sum of spec.replicas over just those StatefulSets. The namespace PERSISTS\n    across workflow stages and accumulates multiple ES clusters, so summing\n    replicas across *every* ES StatefulSet overcounts versus the single cluster\n    the oracle queries. Restricting to the live cluster's StatefulSets fixes that.\n\n    Using DESIRED spec.replicas (not the live count) keeps the check strict: a\n    node that FAILED to rejoin after the restart leaves its StatefulSet \"live\"\n    (siblings are up) but absent from ``_cat/nodes``, so EXPECTED stays above the\n    actual count -- no masking. The LIVE cluster is derived FIRST; the param is a\n    FALLBACK used only when no live StatefulSets resolve (e.g. _cat/nodes empty).\n    \"\"\"\n    # Derive from the LIVE cluster FIRST (workflow-agnostic + composition-aware):\n    # sum spec.replicas over the active ES StatefulSets -- the base cluster PLUS\n    # any nodeset a PRIOR stage added to the same cluster (e.g. an inherited\n    # transform nodeset). A static EXPECTED_NODES param encodes a standalone\n    # baseline that wrongly ignores such inherited nodesets, so it is demoted to a\n    # FALLBACK below, used only when the live cluster cannot be resolved.\n    # Robust count: sum spec.replicas over ES StatefulSets that are actually\n    # present (status.replicas > 0). Counts the base cluster + any scaled-up\n    # nodeset WITHOUT the fragile node.name -> StatefulSet string mapping (which\n    # breaks when a nodeset's node.name differs from its pod name). A torn-down\n    # prior cluster's StatefulSet has readyReplicas 0 and is excluded. Still\n    # strict: a node that failed to join leaves its STS ready>0 but short, so the\n    # spec-replica sum exceeds the live node count and the check still fails.\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", \"-o\", \"json\"])\n    if res.returncode == 0:\n        try:\n            items = json.loads(res.stdout).get(\"items\", [])\n        except Exception:\n            items = []\n        desired = 0\n        for sts in items:\n            spec = sts.get(\"spec\", {}) or {}\n            containers = spec.get(\"template\", {}).get(\"spec\", {}).get(\"containers\", []) or []\n            if \"elasticsearch\" not in \" \".join(c.get(\"image\", \"\") for c in containers):\n                continue\n            replicas = spec.get(\"replicas\")\n            # Use status.replicas (pods that EXIST), not readyReplicas: a\n            # scaled-up nodeset whose pods joined the cluster but lack a passing\n            # STS readiness probe has readyReplicas 0 yet is genuinely live.\n            # Count an ES StatefulSet's DESIRED replicas when it is an active part\n            # of the cluster: spec.replicas > 0 and not being torn down. Gating on\n            # status.replicas undercounts a freshly scaled-up nodeset whose status\n            # lags -- its pods have joined the cluster but status.replicas is still\n            # 0 -- which wrongly made EXPECTED < the live node count.\n            being_deleted = (sts.get(\"metadata\", {}) or {}).get(\"deletionTimestamp\") is not None\n            if isinstance(replicas, int) and replicas > 0 and not being_deleted:\n                desired += replicas\n        if desired > 0:\n            return desired\n\n    # Fallbacks (live cluster unresolvable): explicit param, then the default.\n    for key in (\"BENCH_PARAM_EXPECTED_NODES\", \"BENCH_PARAM_EXPECTED_NODE_COUNT\"):\n        val = os.environ.get(key)\n        if val is not None and str(val).strip():\n            try:\n                return int(val)\n            except ValueError:\n                pass\n    return default\n\n\ndef _probe_scheme(scheme):\n    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\"\"\"\n    result = run([\n        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\", \"/bin/sh\", \"-c\",\n        f\"curl -s -S -k -o /dev/null -w '%{{http_code}}' --max-time 5 {scheme}://{SERVICE}:9200/\",\n    ])\n    code = (result.stdout or \"\").strip().strip(\"'\")\n    return result.returncode == 0 and code.isdigit() and code != \"000\"\n\n\ndef detect_scheme():\n    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n    global _SCHEME\n    if _SCHEME is not None:\n        return _SCHEME\n    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n        if _probe_scheme(scheme):\n            _SCHEME = scheme\n            return _SCHEME\n    _SCHEME = DEFAULT_SCHEME\n    return _SCHEME\n\n\ndef curl(path, errors):\n    scheme = detect_scheme()\n    auth = \"\"\n    if ELASTIC_PASSWORD:\n        import shlex\n        auth = f\"-u {shlex.quote('elastic:' + ELASTIC_PASSWORD)} \"\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"exec\",\n        \"curl-test\",\n        \"--\",\n        \"/bin/sh\",\n        \"-c\",\n        # The client deadline (--max-time 20) must exceed any server-side\n        # ``wait_for`` in `path`, otherwise curl aborts (exit 28) before ES can\n        # answer. The retry loop in main() does the real waiting, so each call's\n        # server wait stays short (10s).\n        f\"curl -s -S -k {auth}--max-time 20 {scheme}://{SERVICE}:9200{path}\",\n    ]\n    result = run(cmd)\n    if result.returncode != 0:\n        stderr = result.stderr.strip()\n        stdout = result.stdout.strip()\n        detail = stderr or stdout or f\"command terminated with exit code {result.returncode}\"\n        errors.append(f\"Failed to query {path}: {detail}\")\n        return None\n    output = result.stdout.strip()\n    if not output:\n        errors.append(f\"Empty response for {path}\")\n        return None\n    try:\n        return json.loads(output)\n    except json.JSONDecodeError:\n        errors.append(f\"Failed to parse JSON from {path}\")\n        return None\n\n\ndef evaluate():\n    \"\"\"Run one full snapshot of the upgrade checks; return the list of errors.\"\"\"\n    errors = []\n\n    seed_result = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"configmap\", SEED_CONFIGMAP, \"-o\", \"json\"])\n    if seed_result.returncode != 0:\n        errors.append(f\"Failed to read {SEED_CONFIGMAP} ConfigMap: {seed_result.stderr.strip()}\")\n        index = None\n        expected = None\n    else:\n        try:\n            seed = json.loads(seed_result.stdout)\n        except json.JSONDecodeError:\n            errors.append(f\"Failed to parse {SEED_CONFIGMAP} ConfigMap JSON\")\n            seed = {}\n        index = seed.get(\"data\", {}).get(\"index\")\n        expected = seed.get(\"data\", {}).get(\"expected_count\")\n\n    root = curl(\"/\", errors)\n    if isinstance(root, dict):\n        version = root.get(\"version\", {}).get(\"number\")\n        if version != TARGET_VERSION:\n            errors.append(f\"Expected version {TARGET_VERSION}, got {version}\")\n    else:\n        errors.append(\"Failed to read Elasticsearch root version\")\n\n    # Resolve the live cluster's node list FIRST: the expected node count is\n    # derived from only the StatefulSets that actually back these live nodes\n    # (the persisted namespace accumulates several ES clusters across stages, so\n    # summing every ES StatefulSet's replicas overcounts the queried cluster).\n    nodes = curl(\"/_cat/nodes?format=json\", errors)\n    node_names = []\n    if isinstance(nodes, list):\n        node_names = [n.get(\"name\") for n in nodes if n.get(\"name\")]\n    expected_nodes = _resolve_expected_nodes(node_names, default=3)\n\n    health = curl(\n        f\"/_cluster/health?wait_for_status=yellow&wait_for_nodes={expected_nodes}&timeout=10s\",\n        errors,\n    )\n    if isinstance(health, dict):\n        status = health.get(\"status\")\n        if status not in {\"yellow\", \"green\"}:\n            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n        if health.get(\"number_of_nodes\") != expected_nodes:\n            errors.append(f\"Expected {expected_nodes} nodes, got {health.get('number_of_nodes')}\")\n    else:\n        errors.append(\"Failed to read cluster health\")\n\n    if isinstance(nodes, list) and len(node_names) != expected_nodes:\n        errors.append(f\"Expected {expected_nodes} nodes in _cat/nodes, got {len(node_names)}\")\n\n    if index and expected:\n        count = curl(f\"/{index}/_count\", errors)\n        if isinstance(count, dict):\n            actual = count.get(\"count\")\n            try:\n                expected_val = int(expected)\n            except ValueError:\n                errors.append(f\"Invalid expected_count value: {expected}\")\n            else:\n                if actual != expected_val:\n                    errors.append(f\"Expected {expected_val} docs in {index}, got {actual}\")\n\n    sts_result = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"sts\", STS_NAME, \"-o\", \"json\"])\n    if sts_result.returncode == 0:\n        try:\n            sts = json.loads(sts_result.stdout)\n        except json.JSONDecodeError:\n            sts = {}\n        containers = sts.get(\"spec\", {}).get(\"template\", {}).get(\"spec\", {}).get(\"containers\", [])\n        if containers:\n            image = containers[0].get(\"image\")\n            if image and TARGET_VERSION not in image:\n                errors.append(f\"StatefulSet image not upgraded: {image}\")\n    else:\n        errors.append(f\"Failed to read StatefulSet: {sts_result.stderr.strip()}\")\n\n    settings = curl(\"/_cluster/settings\", errors)\n    if isinstance(settings, dict):\n        for scope in (\"persistent\", \"transient\"):\n            allocation = settings.get(scope, {}).get(\"cluster\", {}).get(\"routing\", {}).get(\"allocation\", {})\n            if allocation.get(\"enable\") == \"none\":\n                errors.append(\"Shard allocation still disabled\")\n                break\n\n    return errors\n\n\ndef main():\n    global ELASTIC_PASSWORD\n    ELASTIC_PASSWORD = _elastic_password()\n\n    # A multi-node ES cluster can flap at the edge of readiness under load: a\n    # node briefly fails its HTTP readiness probe / drops from the cluster during\n    # GC or shard recovery even though it is stably green. A single snapshot can\n    # catch that transient and report a false node-count miss. So verify the\n    # STABLE converged state: re-evaluate for up to ~75s and pass on the first\n    # clean snapshot. This does not loosen the version/N-node/green/doc-count\n    # requirements -- a genuinely degraded cluster fails every attempt.\n    import time\n    deadline = time.monotonic() + 75\n    errors = evaluate()\n    while errors and time.monotonic() < deadline:\n        time.sleep(8)\n        errors = evaluate()\n\n    if errors:\n        print(\"Full restart upgrade verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    print(\"Full restart upgrade (HA) verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":400,"startLine":1,"totalLines":400}}}
