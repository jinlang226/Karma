{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01Ta9oEZx9PhEFUW457GqGwp","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport json\n3\timport subprocess\n4\timport sys\n5\t\n6\tNAMESPACE = \"elasticsearch\"\n7\tES_SERVICE = \"es-http\"\n8\tINGRESS_SERVICE = \"ingress-nginx-controller.ingress-nginx.svc\"\n9\tINGRESS_HOST = \"es.example.com\"\n10\t\n11\t\n12\tdef run(cmd):\n13\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n14\t\n15\t\n16\tdef curl_json(args, errors, label):\n17\t    cmd = [\n18\t        \"kubectl\",\n19\t        \"-n\",\n20\t        NAMESPACE,\n21\t        \"exec\",\n22\t        \"curl-test\",\n23\t        \"--\",\n24\t        \"curl\",\n25\t        \"-sS\",\n26\t        \"--connect-timeout\",\n27\t        \"2\",\n28\t        \"--max-time\",\n29\t        \"5\",\n30\t    ] + args\n31\t    result = run(cmd)\n32\t    if result.returncode != 0:\n33\t        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n34\t        errors.append(f\"Failed to query {label}: {detail}\")\n35\t        return None\n36\t    output = result.stdout.strip()\n37\t    if not output:\n38\t        errors.append(f\"Empty response for {label}\")\n39\t        return None\n40\t    try:\n41\t        return json.loads(output)\n42\t    except json.JSONDecodeError:\n43\t        errors.append(f\"Unable to parse JSON for {label}\")\n44\t        return None\n45\t\n46\t\n47\tdef curl_http_code(args):\n48\t    cmd = [\n49\t        \"kubectl\",\n50\t        \"-n\",\n51\t        NAMESPACE,\n52\t        \"exec\",\n53\t        \"curl-test\",\n54\t        \"--\",\n55\t        \"curl\",\n56\t        \"-s\",\n57\t        \"-o\",\n58\t        \"/dev/null\",\n59\t        \"-w\",\n60\t        \"%{http_code}\",\n61\t        \"--connect-timeout\",\n62\t        \"2\",\n63\t        \"--max-time\",\n64\t        \"5\",\n65\t    ] + args\n66\t    result = run(cmd)\n67\t    return result.returncode, result.stdout.strip()\n68\t\n69\t\n70\tdef main():\n71\t    errors = []\n72\t\n73\t    # The backend Elasticsearch serves plain HTTP on 9200 standalone (the\n74\t    # precondition sets xpack.security.http.ssl.enabled: false) -- the task is to\n75\t    # terminate TLS at the ingress, not on the ES service itself. Use this as an\n76\t    # \"ES is up\" sanity gate. Because the env PERSISTS across stages, a prior\n77\t    # stage may have enabled HTTP TLS on the backend, so detect the live scheme\n78\t    # (http first, then https) rather than assuming plain http.\n79\t    es_scheme = \"http\"\n80\t    for _scheme in (\"http\", \"https\"):\n81\t        _rc, _code = curl_http_code(\n82\t            [\"-k\", f\"{_scheme}://{ES_SERVICE}.{NAMESPACE}.svc:9200/\"]\n83\t        )\n84\t        if _rc == 0 and _code.isdigit() and _code != \"000\":\n85\t            es_scheme = _scheme\n86\t            break\n87\t    es_health = curl_json(\n88\t        [\"-k\", f\"{es_scheme}://{ES_SERVICE}.{NAMESPACE}.svc:9200/_cluster/health\"],\n89\t        errors,\n90\t        \"Elasticsearch backend\",\n91\t    )\n92\t    if isinstance(es_health, dict):\n93\t        if es_health.get(\"status\") not in {\"yellow\", \"green\"}:\n94\t            errors.append(f\"Elasticsearch health not yellow/green: {es_health.get('status')}\")\n95\t\n96\t    ingress_health = curl_json(\n97\t        [\n98\t            \"-k\",\n99\t            \"-H\",\n100\t            f\"Host: {INGRESS_HOST}\",\n101\t            f\"https://{INGRESS_SERVICE}/_cluster/health\",\n102\t        ],\n103\t        errors,\n104\t        \"Ingress HTTPS\",\n105\t    )\n106\t    if isinstance(ingress_health, dict):\n107\t        if ingress_health.get(\"status\") not in {\"yellow\", \"green\"}:\n108\t            errors.append(\n109\t                f\"Ingress HTTPS health not yellow/green: {ingress_health.get('status')}\"\n110\t            )\n111\t\n112\t    # NOTE: we intentionally do NOT assert that direct http://es-http:9200 fails.\n113\t    # The backend is plain HTTP by design and only reachable in-cluster; the task\n114\t    # is to block plain HTTP *at the ingress*, which is what the next check covers.\n115\t    rc, code = curl_http_code(\n116\t        [\n117\t            \"-H\",\n118\t            f\"Host: {INGRESS_HOST}\",\n119\t            f\"http://{INGRESS_SERVICE}/_cluster/health\",\n120\t        ]\n121\t    )\n122\t    if rc == 0 and code == \"200\":\n123\t        errors.append(\"Ingress HTTP still succeeds\")\n124\t\n125\t    if errors:\n126\t        print(\"Secure HTTP ingress verification failed:\", file=sys.stderr)\n127\t        for err in errors:\n128\t            print(f\"  - {err}\", file=sys.stderr)\n129\t        return 1\n130\t\n131\t    print(\"Secure HTTP ingress verification passed\")\n132\t    return 0\n133\t\n134\t\n135\tif __name__ == \"__main__\":\n136\t    sys.exit(main())\n137\t"}]},"parent_tool_use_id":null,"session_id":"bcdc7540-3987-4c56-a53c-7548073e6f32","uuid":"1d864c92-21a8-4399-a8b9-35b62224bb7b","timestamp":"2026-06-15T11:41:57.881Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/leo/Karma/cases/elasticsearch/secure-http-ingress/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport json\nimport subprocess\nimport sys\n\nNAMESPACE = \"elasticsearch\"\nES_SERVICE = \"es-http\"\nINGRESS_SERVICE = \"ingress-nginx-controller.ingress-nginx.svc\"\nINGRESS_HOST = \"es.example.com\"\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef curl_json(args, errors, label):\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"exec\",\n        \"curl-test\",\n        \"--\",\n        \"curl\",\n        \"-sS\",\n        \"--connect-timeout\",\n        \"2\",\n        \"--max-time\",\n        \"5\",\n    ] + args\n    result = run(cmd)\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"exit {result.returncode}\"\n        errors.append(f\"Failed to query {label}: {detail}\")\n        return None\n    output = result.stdout.strip()\n    if not output:\n        errors.append(f\"Empty response for {label}\")\n        return None\n    try:\n        return json.loads(output)\n    except json.JSONDecodeError:\n        errors.append(f\"Unable to parse JSON for {label}\")\n        return None\n\n\ndef curl_http_code(args):\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"exec\",\n        \"curl-test\",\n        \"--\",\n        \"curl\",\n        \"-s\",\n        \"-o\",\n        \"/dev/null\",\n        \"-w\",\n        \"%{http_code}\",\n        \"--connect-timeout\",\n        \"2\",\n        \"--max-time\",\n        \"5\",\n    ] + args\n    result = run(cmd)\n    return result.returncode, result.stdout.strip()\n\n\ndef main():\n    errors = []\n\n    # The backend Elasticsearch serves plain HTTP on 9200 standalone (the\n    # precondition sets xpack.security.http.ssl.enabled: false) -- the task is to\n    # terminate TLS at the ingress, not on the ES service itself. Use this as an\n    # \"ES is up\" sanity gate. Because the env PERSISTS across stages, a prior\n    # stage may have enabled HTTP TLS on the backend, so detect the live scheme\n    # (http first, then https) rather than assuming plain http.\n    es_scheme = \"http\"\n    for _scheme in (\"http\", \"https\"):\n        _rc, _code = curl_http_code(\n            [\"-k\", f\"{_scheme}://{ES_SERVICE}.{NAMESPACE}.svc:9200/\"]\n        )\n        if _rc == 0 and _code.isdigit() and _code != \"000\":\n            es_scheme = _scheme\n            break\n    es_health = curl_json(\n        [\"-k\", f\"{es_scheme}://{ES_SERVICE}.{NAMESPACE}.svc:9200/_cluster/health\"],\n        errors,\n        \"Elasticsearch backend\",\n    )\n    if isinstance(es_health, dict):\n        if es_health.get(\"status\") not in {\"yellow\", \"green\"}:\n            errors.append(f\"Elasticsearch health not yellow/green: {es_health.get('status')}\")\n\n    ingress_health = curl_json(\n        [\n            \"-k\",\n            \"-H\",\n            f\"Host: {INGRESS_HOST}\",\n            f\"https://{INGRESS_SERVICE}/_cluster/health\",\n        ],\n        errors,\n        \"Ingress HTTPS\",\n    )\n    if isinstance(ingress_health, dict):\n        if ingress_health.get(\"status\") not in {\"yellow\", \"green\"}:\n            errors.append(\n                f\"Ingress HTTPS health not yellow/green: {ingress_health.get('status')}\"\n            )\n\n    # NOTE: we intentionally do NOT assert that direct http://es-http:9200 fails.\n    # The backend is plain HTTP by design and only reachable in-cluster; the task\n    # is to block plain HTTP *at the ingress*, which is what the next check covers.\n    rc, code = curl_http_code(\n        [\n            \"-H\",\n            f\"Host: {INGRESS_HOST}\",\n            f\"http://{INGRESS_SERVICE}/_cluster/health\",\n        ]\n    )\n    if rc == 0 and code == \"200\":\n        errors.append(\"Ingress HTTP still succeeds\")\n\n    if errors:\n        print(\"Secure HTTP ingress verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    print(\"Secure HTTP ingress verification passed\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":137,"startLine":1,"totalLines":137}}}
