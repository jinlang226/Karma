{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_019VrVTSe8p4AtWhePc5ifzX","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport json\n3\timport os\n4\timport subprocess\n5\timport sys\n6\t\n7\t\n8\tNAMESPACE = \"elasticsearch\"\n9\tSERVICE = \"es-http\"\n10\tCLUSTER_PREFIX = \"es-cluster\"\n11\tDEFAULT_SCHEME = \"http\"\n12\t_SCHEME = None\n13\t\n14\t\n15\tdef run(cmd):\n16\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n17\t\n18\t\n19\tdef _resolve_expected_nodes(default=3):\n20\t    \"\"\"Node count to enforce (param override -> live Ready es pods -> default).\n21\t\n22\t    The env PERSISTS across stages; adapt the target to the live cluster\n23\t    without loosening it (a missing/NotReady node still mismatches).\n24\t    \"\"\"\n25\t    for key in (\"BENCH_PARAM_EXPECTED_NODES\", \"BENCH_PARAM_EXPECTED_NODE_COUNT\"):\n26\t        val = os.environ.get(key)\n27\t        if val is not None and str(val).strip():\n28\t            try:\n29\t                return int(val)\n30\t            except ValueError:\n31\t                pass\n32\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"pods\", \"-l\", f\"app={CLUSTER_PREFIX}\", \"-o\", \"json\"])\n33\t    if res.returncode == 0:\n34\t        try:\n35\t            items = json.loads(res.stdout).get(\"items\", [])\n36\t            ready = sum(\n37\t                1 for p in items\n38\t                if any(c.get(\"type\") == \"Ready\" and c.get(\"status\") == \"True\"\n39\t                       for c in p.get(\"status\", {}).get(\"conditions\", []))\n40\t            )\n41\t            if ready > 0:\n42\t                return ready\n43\t        except (json.JSONDecodeError, AttributeError):\n44\t            pass\n45\t    return default\n46\t\n47\t\n48\tEXPECTED_NODES = _resolve_expected_nodes(3)\n49\t\n50\t\n51\tdef _probe_scheme(scheme):\n52\t    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\n53\t\n54\t    Authenticates with the same $ES_USER/$ES_PASS the real queries use; a 401\n55\t    still proves the scheme is live, so any HTTP status code counts.\n56\t    \"\"\"\n57\t    result = run([\n58\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\", \"/bin/sh\", \"-c\",\n59\t        (\"curl -s -S -k -o /dev/null -w '%{http_code}' --max-time 5 \"\n60\t         \"-u \\\"$ES_USER:$ES_PASS\\\" \"\n61\t         f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200/\"),\n62\t    ])\n63\t    code = (result.stdout or \"\").strip().strip(\"'\")\n64\t    return result.returncode == 0 and code.isdigit() and code != \"000\"\n65\t\n66\t\n67\tdef detect_scheme():\n68\t    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n69\t    global _SCHEME\n70\t    if _SCHEME is not None:\n71\t        return _SCHEME\n72\t    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n73\t        if _probe_scheme(scheme):\n74\t            _SCHEME = scheme\n75\t            return _SCHEME\n76\t    _SCHEME = DEFAULT_SCHEME\n77\t    return _SCHEME\n78\t\n79\t\n80\tdef curl(path, errors):\n81\t    scheme = detect_scheme()\n82\t    cmd = [\n83\t        \"kubectl\",\n84\t        \"-n\",\n85\t        NAMESPACE,\n86\t        \"exec\",\n87\t        \"curl-test\",\n88\t        \"--\",\n89\t        \"/bin/sh\",\n90\t        \"-c\",\n91\t        (\n92\t            \"curl -s -S -k --max-time 10 -u \\\"$ES_USER:$ES_PASS\\\" \"\n93\t            f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\"\n94\t        ),\n95\t    ]\n96\t\n97\t    result = run(cmd)\n98\t    if result.returncode != 0:\n99\t        stderr = result.stderr.strip()\n100\t        stdout = result.stdout.strip()\n101\t        detail = stderr or stdout or f\"command terminated with exit code {result.returncode}\"\n102\t        errors.append(f\"Failed to query {path}: {detail}\")\n103\t        return None\n104\t    output = result.stdout.strip()\n105\t    if not output:\n106\t        errors.append(f\"Empty response for {path}\")\n107\t        return None\n108\t    try:\n109\t        return json.loads(output)\n110\t    except json.JSONDecodeError:\n111\t        errors.append(f\"Failed to parse JSON from {path}\")\n112\t        return None\n113\t\n114\t\n115\tdef main():\n116\t    errors = []\n117\t\n118\t    cm_result = run(\n119\t        [\n120\t            \"kubectl\",\n121\t            \"-n\",\n122\t            NAMESPACE,\n123\t            \"get\",\n124\t            \"configmap\",\n125\t            \"es-transport-ca-bundle\",\n126\t            \"-o\",\n127\t            \"json\",\n128\t        ]\n129\t    )\n130\t    if cm_result.returncode != 0:\n131\t        errors.append(\n132\t            f\"Failed to read es-transport-ca-bundle ConfigMap: {cm_result.stderr.strip()}\"\n133\t        )\n134\t    else:\n135\t        try:\n136\t            cm = json.loads(cm_result.stdout)\n137\t        except json.JSONDecodeError:\n138\t            errors.append(\"Failed to parse es-transport-ca-bundle ConfigMap JSON\")\n139\t            cm = {}\n140\t        bundle = cm.get(\"data\", {}).get(\"ca.crt\", \"\")\n141\t        cert_count = bundle.count(\"BEGIN CERTIFICATE\")\n142\t        if cert_count < 2:\n143\t            errors.append(\n144\t                f\"Transport CA bundle should contain 2 certs, found {cert_count}\"\n145\t            )\n146\t\n147\t    health = curl(\n148\t        f\"/_cluster/health?wait_for_status=yellow&wait_for_nodes={EXPECTED_NODES}&timeout=30s\",\n149\t        errors,\n150\t    )\n151\t    if isinstance(health, dict):\n152\t        status = health.get(\"status\")\n153\t        if status not in {\"yellow\", \"green\"}:\n154\t            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n155\t        if health.get(\"number_of_nodes\") != EXPECTED_NODES:\n156\t            errors.append(\n157\t                f\"Expected {EXPECTED_NODES} nodes, got {health.get('number_of_nodes')}\"\n158\t            )\n159\t\n160\t    nodes = curl(\"/_cat/nodes?format=json\", errors)\n161\t    if isinstance(nodes, list):\n162\t        if len(nodes) != EXPECTED_NODES:\n163\t            errors.append(f\"Expected {EXPECTED_NODES} nodes in _cat/nodes, got {len(nodes)}\")\n164\t\n165\t    if errors:\n166\t        print(\"Transport CA trust verification failed:\", file=sys.stderr)\n167\t        for err in errors:\n168\t            print(f\"  - {err}\", file=sys.stderr)\n169\t        return 1\n170\t\n171\t    print(\"Transport CA trust verified\")\n172\t    return 0\n173\t\n174\t\n175\tif __name__ == \"__main__\":\n176\t    sys.exit(main())\n177\t"}]},"parent_tool_use_id":null,"session_id":"fc8e6738-f7f8-4f52-b64f-fcc1e7ea4b8a","uuid":"b7ef6128-cfeb-401d-aa73-78bc5ae4a023","timestamp":"2026-06-15T11:33:04.917Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/leo/Karma/cases/elasticsearch/transport-additional-ca-trust/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport json\nimport os\nimport subprocess\nimport sys\n\n\nNAMESPACE = \"elasticsearch\"\nSERVICE = \"es-http\"\nCLUSTER_PREFIX = \"es-cluster\"\nDEFAULT_SCHEME = \"http\"\n_SCHEME = None\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef _resolve_expected_nodes(default=3):\n    \"\"\"Node count to enforce (param override -> live Ready es pods -> default).\n\n    The env PERSISTS across stages; adapt the target to the live cluster\n    without loosening it (a missing/NotReady node still mismatches).\n    \"\"\"\n    for key in (\"BENCH_PARAM_EXPECTED_NODES\", \"BENCH_PARAM_EXPECTED_NODE_COUNT\"):\n        val = os.environ.get(key)\n        if val is not None and str(val).strip():\n            try:\n                return int(val)\n            except ValueError:\n                pass\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"pods\", \"-l\", f\"app={CLUSTER_PREFIX}\", \"-o\", \"json\"])\n    if res.returncode == 0:\n        try:\n            items = json.loads(res.stdout).get(\"items\", [])\n            ready = sum(\n                1 for p in items\n                if any(c.get(\"type\") == \"Ready\" and c.get(\"status\") == \"True\"\n                       for c in p.get(\"status\", {}).get(\"conditions\", []))\n            )\n            if ready > 0:\n                return ready\n        except (json.JSONDecodeError, AttributeError):\n            pass\n    return default\n\n\nEXPECTED_NODES = _resolve_expected_nodes(3)\n\n\ndef _probe_scheme(scheme):\n    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\n\n    Authenticates with the same $ES_USER/$ES_PASS the real queries use; a 401\n    still proves the scheme is live, so any HTTP status code counts.\n    \"\"\"\n    result = run([\n        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\", \"/bin/sh\", \"-c\",\n        (\"curl -s -S -k -o /dev/null -w '%{http_code}' --max-time 5 \"\n         \"-u \\\"$ES_USER:$ES_PASS\\\" \"\n         f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200/\"),\n    ])\n    code = (result.stdout or \"\").strip().strip(\"'\")\n    return result.returncode == 0 and code.isdigit() and code != \"000\"\n\n\ndef detect_scheme():\n    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n    global _SCHEME\n    if _SCHEME is not None:\n        return _SCHEME\n    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n        if _probe_scheme(scheme):\n            _SCHEME = scheme\n            return _SCHEME\n    _SCHEME = DEFAULT_SCHEME\n    return _SCHEME\n\n\ndef curl(path, errors):\n    scheme = detect_scheme()\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"exec\",\n        \"curl-test\",\n        \"--\",\n        \"/bin/sh\",\n        \"-c\",\n        (\n            \"curl -s -S -k --max-time 10 -u \\\"$ES_USER:$ES_PASS\\\" \"\n            f\"{scheme}://{SERVICE}.{NAMESPACE}.svc:9200{path}\"\n        ),\n    ]\n\n    result = run(cmd)\n    if result.returncode != 0:\n        stderr = result.stderr.strip()\n        stdout = result.stdout.strip()\n        detail = stderr or stdout or f\"command terminated with exit code {result.returncode}\"\n        errors.append(f\"Failed to query {path}: {detail}\")\n        return None\n    output = result.stdout.strip()\n    if not output:\n        errors.append(f\"Empty response for {path}\")\n        return None\n    try:\n        return json.loads(output)\n    except json.JSONDecodeError:\n        errors.append(f\"Failed to parse JSON from {path}\")\n        return None\n\n\ndef main():\n    errors = []\n\n    cm_result = run(\n        [\n            \"kubectl\",\n            \"-n\",\n            NAMESPACE,\n            \"get\",\n            \"configmap\",\n            \"es-transport-ca-bundle\",\n            \"-o\",\n            \"json\",\n        ]\n    )\n    if cm_result.returncode != 0:\n        errors.append(\n            f\"Failed to read es-transport-ca-bundle ConfigMap: {cm_result.stderr.strip()}\"\n        )\n    else:\n        try:\n            cm = json.loads(cm_result.stdout)\n        except json.JSONDecodeError:\n            errors.append(\"Failed to parse es-transport-ca-bundle ConfigMap JSON\")\n            cm = {}\n        bundle = cm.get(\"data\", {}).get(\"ca.crt\", \"\")\n        cert_count = bundle.count(\"BEGIN CERTIFICATE\")\n        if cert_count < 2:\n            errors.append(\n                f\"Transport CA bundle should contain 2 certs, found {cert_count}\"\n            )\n\n    health = curl(\n        f\"/_cluster/health?wait_for_status=yellow&wait_for_nodes={EXPECTED_NODES}&timeout=30s\",\n        errors,\n    )\n    if isinstance(health, dict):\n        status = health.get(\"status\")\n        if status not in {\"yellow\", \"green\"}:\n            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n        if health.get(\"number_of_nodes\") != EXPECTED_NODES:\n            errors.append(\n                f\"Expected {EXPECTED_NODES} nodes, got {health.get('number_of_nodes')}\"\n            )\n\n    nodes = curl(\"/_cat/nodes?format=json\", errors)\n    if isinstance(nodes, list):\n        if len(nodes) != EXPECTED_NODES:\n            errors.append(f\"Expected {EXPECTED_NODES} nodes in _cat/nodes, got {len(nodes)}\")\n\n    if errors:\n        print(\"Transport CA trust verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    print(\"Transport CA trust verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":177,"startLine":1,"totalLines":177}}}
