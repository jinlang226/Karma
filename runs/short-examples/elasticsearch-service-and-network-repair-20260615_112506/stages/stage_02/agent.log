{"type":"user","message":{"role":"user","content":[{"tool_use_id":"toolu_01XoYWrJGUSGL3GzNmJzv9of","type":"tool_result","content":"1\t#!/usr/bin/env python3\n2\timport json\n3\timport os\n4\timport subprocess\n5\timport sys\n6\t\n7\tNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"elasticsearch\")\n8\tSERVICE = os.environ.get(\"BENCH_PARAM_HTTP_SERVICE_NAME\", \"es-http\")\n9\tCLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"es-cluster\")\n10\tINDEX = os.environ.get(\"BENCH_PARAM_INDEX_NAME\", \"app-data\")\n11\tDEFAULT_SCHEME = \"http\"\n12\t_SCHEME = None\n13\t\n14\t\n15\tdef run(cmd):\n16\t    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n17\t\n18\t\n19\tdef _resolve_expected_nodes(default=3):\n20\t    \"\"\"Topology size to enforce (param override -> live Ready es pods -> default).\n21\t\n22\t    The env PERSISTS across stages; a prior scale stage may change the node\n23\t    count, so adapt the target without loosening it (a missing/NotReady node\n24\t    still mismatches the live count).\n25\t    \"\"\"\n26\t    for key in (\"BENCH_PARAM_EXPECTED_NODE_COUNT\", \"BENCH_PARAM_EXPECTED_NODES\"):\n27\t        val = os.environ.get(key)\n28\t        if val is not None and str(val).strip():\n29\t            try:\n30\t                return int(val)\n31\t            except ValueError:\n32\t                pass\n33\t    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"pods\", \"-l\", f\"app={CLUSTER_PREFIX}\", \"-o\", \"json\"])\n34\t    if res.returncode == 0:\n35\t        try:\n36\t            items = json.loads(res.stdout).get(\"items\", [])\n37\t            ready = sum(\n38\t                1 for p in items\n39\t                if any(c.get(\"type\") == \"Ready\" and c.get(\"status\") == \"True\"\n40\t                       for c in p.get(\"status\", {}).get(\"conditions\", []))\n41\t            )\n42\t            if ready > 0:\n43\t                return ready\n44\t        except (json.JSONDecodeError, AttributeError):\n45\t            pass\n46\t    return default\n47\t\n48\t\n49\tEXPECTED_NODES = _resolve_expected_nodes(3)\n50\t\n51\t\n52\tdef _probe_scheme(scheme):\n53\t    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\"\"\"\n54\t    result = run([\n55\t        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\",\n56\t        \"curl\", \"-s\", \"-S\", \"-k\", \"-o\", \"/dev/null\",\n57\t        \"-w\", \"%{http_code}\", \"--max-time\", \"5\", f\"{scheme}://{SERVICE}:9200/\",\n58\t    ])\n59\t    code = (result.stdout or \"\").strip()\n60\t    return result.returncode == 0 and code.isdigit() and code != \"000\"\n61\t\n62\t\n63\tdef detect_scheme():\n64\t    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n65\t    global _SCHEME\n66\t    if _SCHEME is not None:\n67\t        return _SCHEME\n68\t    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n69\t        if _probe_scheme(scheme):\n70\t            _SCHEME = scheme\n71\t            return _SCHEME\n72\t    _SCHEME = DEFAULT_SCHEME\n73\t    return _SCHEME\n74\t\n75\t\n76\tdef curl_json(path, errors):\n77\t    scheme = detect_scheme()\n78\t    cmd = [\n79\t        \"kubectl\",\n80\t        \"-n\",\n81\t        NAMESPACE,\n82\t        \"exec\",\n83\t        \"curl-test\",\n84\t        \"--\",\n85\t        \"curl\",\n86\t        \"-s\",\n87\t        \"-S\",\n88\t        \"-k\",\n89\t        \"--max-time\",\n90\t        \"10\",\n91\t        f\"{scheme}://{SERVICE}:9200{path}\",\n92\t    ]\n93\t    result = run(cmd)\n94\t    if result.returncode != 0:\n95\t        detail = result.stderr.strip() or result.stdout.strip() or f\"command terminated with exit code {result.returncode}\"\n96\t        errors.append(f\"Failed to query {path}: {detail}\")\n97\t        return None\n98\t    output = result.stdout.strip()\n99\t    if not output:\n100\t        errors.append(f\"Empty response for {path}\")\n101\t        return None\n102\t    try:\n103\t        return json.loads(output)\n104\t    except json.JSONDecodeError:\n105\t        errors.append(f\"Failed to parse JSON from {path}\")\n106\t        return None\n107\t\n108\t\n109\tdef main():\n110\t    errors = []\n111\t\n112\t    health = curl_json(\n113\t        f\"/_cluster/health?wait_for_status=yellow&wait_for_nodes={EXPECTED_NODES}&timeout=30s\",\n114\t        errors,\n115\t    )\n116\t    if isinstance(health, dict):\n117\t        status = health.get(\"status\")\n118\t        if status not in {\"yellow\", \"green\"}:\n119\t            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n120\t        if health.get(\"number_of_nodes\") != EXPECTED_NODES:\n121\t            errors.append(\n122\t                f\"Expected {EXPECTED_NODES} nodes, got {health.get('number_of_nodes')}\"\n123\t            )\n124\t\n125\t    nodes = curl_json(\"/_cat/nodes?format=json\", errors)\n126\t    if isinstance(nodes, list):\n127\t        if len(nodes) != EXPECTED_NODES:\n128\t            errors.append(f\"Expected {EXPECTED_NODES} nodes in _cat/nodes, got {len(nodes)}\")\n129\t\n130\t    count = curl_json(f\"/{INDEX}/_count\", errors)\n131\t    if isinstance(count, dict):\n132\t        if \"count\" not in count:\n133\t            errors.append(\"Unable to verify app-data count\")\n134\t\n135\t    if errors:\n136\t        print(\"Seed hosts repair verification failed:\", file=sys.stderr)\n137\t        for err in errors:\n138\t            print(f\"  - {err}\", file=sys.stderr)\n139\t        return 1\n140\t\n141\t    print(\"Seed hosts repair verified\")\n142\t    return 0\n143\t\n144\t\n145\tif __name__ == \"__main__\":\n146\t    sys.exit(main())\n147\t"}]},"parent_tool_use_id":null,"session_id":"abe5f877-f9de-4658-b585-b82557f7950e","uuid":"3a9a1a2d-6e8b-4e1c-8ddc-a259ec87f1db","timestamp":"2026-06-15T11:29:00.370Z","tool_use_result":{"type":"text","file":{"filePath":"/Users/leo/Karma/cases/elasticsearch/seed-hosts-repair/oracle/oracle.py","content":"#!/usr/bin/env python3\nimport json\nimport os\nimport subprocess\nimport sys\n\nNAMESPACE = os.environ.get(\"BENCH_NAMESPACE\", \"elasticsearch\")\nSERVICE = os.environ.get(\"BENCH_PARAM_HTTP_SERVICE_NAME\", \"es-http\")\nCLUSTER_PREFIX = os.environ.get(\"BENCH_PARAM_CLUSTER_PREFIX\", \"es-cluster\")\nINDEX = os.environ.get(\"BENCH_PARAM_INDEX_NAME\", \"app-data\")\nDEFAULT_SCHEME = \"http\"\n_SCHEME = None\n\n\ndef run(cmd):\n    return subprocess.run(cmd, text=True, stdout=subprocess.PIPE, stderr=subprocess.PIPE)\n\n\ndef _resolve_expected_nodes(default=3):\n    \"\"\"Topology size to enforce (param override -> live Ready es pods -> default).\n\n    The env PERSISTS across stages; a prior scale stage may change the node\n    count, so adapt the target without loosening it (a missing/NotReady node\n    still mismatches the live count).\n    \"\"\"\n    for key in (\"BENCH_PARAM_EXPECTED_NODE_COUNT\", \"BENCH_PARAM_EXPECTED_NODES\"):\n        val = os.environ.get(key)\n        if val is not None and str(val).strip():\n            try:\n                return int(val)\n            except ValueError:\n                pass\n    res = run([\"kubectl\", \"-n\", NAMESPACE, \"get\", \"pods\", \"-l\", f\"app={CLUSTER_PREFIX}\", \"-o\", \"json\"])\n    if res.returncode == 0:\n        try:\n            items = json.loads(res.stdout).get(\"items\", [])\n            ready = sum(\n                1 for p in items\n                if any(c.get(\"type\") == \"Ready\" and c.get(\"status\") == \"True\"\n                       for c in p.get(\"status\", {}).get(\"conditions\", []))\n            )\n            if ready > 0:\n                return ready\n        except (json.JSONDecodeError, AttributeError):\n            pass\n    return default\n\n\nEXPECTED_NODES = _resolve_expected_nodes(3)\n\n\ndef _probe_scheme(scheme):\n    \"\"\"True if the ES HTTP API answers on the given scheme (auth-agnostic).\"\"\"\n    result = run([\n        \"kubectl\", \"-n\", NAMESPACE, \"exec\", \"curl-test\", \"--\",\n        \"curl\", \"-s\", \"-S\", \"-k\", \"-o\", \"/dev/null\",\n        \"-w\", \"%{http_code}\", \"--max-time\", \"5\", f\"{scheme}://{SERVICE}:9200/\",\n    ])\n    code = (result.stdout or \"\").strip()\n    return result.returncode == 0 and code.isdigit() and code != \"000\"\n\n\ndef detect_scheme():\n    \"\"\"Detect the cluster's live HTTP scheme (default first, then the other).\"\"\"\n    global _SCHEME\n    if _SCHEME is not None:\n        return _SCHEME\n    for scheme in (DEFAULT_SCHEME, \"https\" if DEFAULT_SCHEME == \"http\" else \"http\"):\n        if _probe_scheme(scheme):\n            _SCHEME = scheme\n            return _SCHEME\n    _SCHEME = DEFAULT_SCHEME\n    return _SCHEME\n\n\ndef curl_json(path, errors):\n    scheme = detect_scheme()\n    cmd = [\n        \"kubectl\",\n        \"-n\",\n        NAMESPACE,\n        \"exec\",\n        \"curl-test\",\n        \"--\",\n        \"curl\",\n        \"-s\",\n        \"-S\",\n        \"-k\",\n        \"--max-time\",\n        \"10\",\n        f\"{scheme}://{SERVICE}:9200{path}\",\n    ]\n    result = run(cmd)\n    if result.returncode != 0:\n        detail = result.stderr.strip() or result.stdout.strip() or f\"command terminated with exit code {result.returncode}\"\n        errors.append(f\"Failed to query {path}: {detail}\")\n        return None\n    output = result.stdout.strip()\n    if not output:\n        errors.append(f\"Empty response for {path}\")\n        return None\n    try:\n        return json.loads(output)\n    except json.JSONDecodeError:\n        errors.append(f\"Failed to parse JSON from {path}\")\n        return None\n\n\ndef main():\n    errors = []\n\n    health = curl_json(\n        f\"/_cluster/health?wait_for_status=yellow&wait_for_nodes={EXPECTED_NODES}&timeout=30s\",\n        errors,\n    )\n    if isinstance(health, dict):\n        status = health.get(\"status\")\n        if status not in {\"yellow\", \"green\"}:\n            errors.append(f\"Cluster health status expected yellow/green, got {status}\")\n        if health.get(\"number_of_nodes\") != EXPECTED_NODES:\n            errors.append(\n                f\"Expected {EXPECTED_NODES} nodes, got {health.get('number_of_nodes')}\"\n            )\n\n    nodes = curl_json(\"/_cat/nodes?format=json\", errors)\n    if isinstance(nodes, list):\n        if len(nodes) != EXPECTED_NODES:\n            errors.append(f\"Expected {EXPECTED_NODES} nodes in _cat/nodes, got {len(nodes)}\")\n\n    count = curl_json(f\"/{INDEX}/_count\", errors)\n    if isinstance(count, dict):\n        if \"count\" not in count:\n            errors.append(\"Unable to verify app-data count\")\n\n    if errors:\n        print(\"Seed hosts repair verification failed:\", file=sys.stderr)\n        for err in errors:\n            print(f\"  - {err}\", file=sys.stderr)\n        return 1\n\n    print(\"Seed hosts repair verified\")\n    return 0\n\n\nif __name__ == \"__main__\":\n    sys.exit(main())\n","numLines":147,"startLine":1,"totalLines":147}}}
